    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7416" ;
    skos:prefLabel "Establish Marketing Performance Targets"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7417> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7319> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7417" ;
    skos:prefLabel "Report Marketing Performance"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7418> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7388> ;
    skos:definition "Define Brand Positioning business activity is responsible for translating brand strategy, determining and describing the scope and meaning of the enterprise's brand in order to attain a high customer and market mind share. <br/> <br/>Define Brand Positioning includes activities to establish and manage the images, perceptions, and associations that the consumers apply to the enterprises' products and/or services based on the values and beliefs that the enterprise places on its products and/or services.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7418" ;
    skos:prefLabel "Define Brand Positioning"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7419> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7388> ;
    skos:definition "Optimize Brand Strategy business activity is responsible for making modifications and changes that achieve maximum impact on the enterprise's brand(s). <br/> <br/>Optimize Brand Strategy includes activities that identify, analyze, develop, and research the impact and relevance of the brand over time and implement measures to effectively change the brand to respond to an internal change in strategy.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7419" ;
    skos:prefLabel "Optimize Brand Strategy"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7420> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7389> ;
    skos:definition "Identify Brand Elements business activity is responsible for determining tangible and intangible visual and emotional elements used to represent the brand. Identify Brand Elements include activities that identify brand name, logo, tag line, color scheme, typography, packaging design, and other visual and auditory cues that will be used to create a consistent brand identity.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7420" ;
    skos:prefLabel "Identify Brand Elements"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7421> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7389> ;
    skos:definition "Manage Brand Collaterals business activity controls the creation and maintenance of the library of brand marketing and communication materials, and oversees all distribution to assure consistency in representation and use.<br/> <br/>Manage Brand Collaterals includes defining the library for brand material, version managing brand elements, ensuring messaging in communication materials use the formally approved brand information, and distributing brand collaterals.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7421" ;
    skos:prefLabel "Manage Brand Collaterals"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7422> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7390> ;
    skos:definition "Audit Brand Value business activity is responsible for conducting the financial examination of brand awareness given the brand’s current position in various markets compared to its competitors.<br/> <br/>Audit Brand Equity includes the financial evaluation of all the tangible and intangible assets that are associated with a brand. Audit Brand Equity determines the strengths and weaknesses of the brand and involves analyzing the brand identity, brand image, brand equity, and brand positioning.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7422" ;
    skos:prefLabel "Audit Brand Value"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7423> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7390> ;
    skos:definition "Maintain Brand Value Proposition business activity is responsible for assuring the brand is distinct from the competition while affording the enterprise the advantage of consistently attracting and converting customers based on the brand. <br/> <br/>Maintain Brand Value Proposition oversees all initiatives to ensure there is a unique benefit that the brand offers to customers and the market.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7423" ;
    skos:prefLabel "Maintain Brand Value Proposition"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7424> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7391> ;
    skos:definition "Establish Brand Guidelines business activity is responsible for setting and documenting guidelines for the use of branding elements. <br/> <br/>Establish Brand Guidelines includes developing branding rules, setting standards for using branding elements, specifying do's and don'ts, and formalizing the structure and content of brand communication collaterals.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7424" ;
    skos:prefLabel "Establish Brand Guidelines"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7425> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7391> ;
    skos:definition "Monitor Brand Image business activity is responsible for collecting and tracking the brand reputation and perception in the market. <br/> <br/>Monitor Brand Image includes collecting and tracking sentiments, conducting surveys and interviews to observe market views, rolling out focus groups based on market initiatives, collecting feedback on products and/or services, and monitoring channel management initiatives for brand-specific concerns. (need to focus on analysis data)<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7425" ;
    skos:prefLabel "Monitor Brand Image"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7426> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7391> ;
    skos:definition "Improve Brand Image establishes initiatives to change the brand's image and reputation. <br/> <br/>Improve Brand Image includes activities to assess the actual brand image and what the brand strategy established it to be, support improving the creation and setting of brand guidelines, and commissioning initiatives or events to promote the brand.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7426" ;
    skos:prefLabel "Improve Brand Image"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7427> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7392> ;
    skos:definition "Establish Brand Performance Measures sets the measurable goals for brand measurement initiatives that are tied to business objectives. <br/> <br/>Establish Brand Performance Measures includes identifying key brand business objectives, setting clear and measurable goals for brand measurement initiatives, and measuring and interpreting brand performance.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7427" ;
    skos:prefLabel "Establish Brand Performance Measures"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7428> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7392> ;
    skos:definition "Monitor Brand Performance tracks and record publicly available brand mentions about the enterprise brand, service, or product. <br/> <br/>Monitor Brand Performance includes initiatives to collect data that can have a positive effect on the brand, implementing brand monitoring initiatives, identifying key performance indicators (KPIs), and monitoring brand-associated data to identify brand successes and problems.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7428" ;
    skos:prefLabel "Monitor Brand Performance"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7429> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7392> ;
    skos:definition "Improve Brand Performance business activity identifies areas the brand is under-performing and implements initiatives to improve brand performance. Improve Brand Performance includes initiatives that analyze results of customer feedback, identify areas where the brand is under-performing, inter-work with Manage Brand Strategy to improve performance, and implement brand improvement strategies.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7429" ;
    skos:prefLabel "Improve Brand Performance"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7430> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7393> ;
    skos:definition "Manage Brand Visibility business activity controls initiatives that result in consumers and the market becoming familiar with the enterprise's brand. <br/> <br/>Manage Brand Visibility ensures that underlying marketing and sales activities promote quality products and/or services. This includes all activities that add value to an enterprise product or service.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7430" ;
    skos:prefLabel "Manage Brand Visibility"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7431> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7393> ;
    skos:definition "Manage Brand Association business activity controls initiatives to create mind share of the enterprise products or services with the brand. <br/> <br/>Manage Brand Association ensures that the market the enterprise services, and customers (prospective and current) have a feeling of trust, reliability, or nostalgia for the brand.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7431" ;
    skos:prefLabel "Manage Brand Associations"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7432> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7393> ;
    skos:definition "Manage Brand Equity Investment business activity controls initiatives that measure and maximize market behavior for profitable sales over time. <br/> <br/>Manage Brand Equity includes activities to create a marketplace that favors the enterprise through brand equity, the advantage of the brand over others, and the goodwill that the brand enjoys and retains.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7432" ;
    skos:prefLabel "Manage Brand Equity Investment"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7433> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7325> ;
    skos:definition "Identify Market Research Objective business activity identifies the key questions that the research needs to answer in order to establish clear and focused objectives for the market research and to set the direction for the research. Identify Market Research Objective involves asking key questions, guiding every step of the research process, including data collection, argument building, and conclusion development.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7433" ;
    skos:prefLabel "Identify Market Research Objective"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7434> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7325> ;
    skos:definition "Review Existing Market Research Knowledge business activity is responsible for analyzing existing data and market trends, guide the organization to define research objectives, uncover gaps in knowledge or areas where more information is needed and help support research goals in order to avoid reinventing already known facts.<br/><br/>Review Existing Market Research Knowledge enables the organization to maximize the value of existing knowledge and insight, including knowledge from literature reviews, and stakeholder views etc. and to form educated assumptions about what the research will find.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7434" ;
    skos:prefLabel "Review Existing Market Research Knowledge"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7435> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7325> ;
    skos:definition "Formulate Market Research Hypothesis business activity creates statements or a sets of statements that can be tested against an evaluation criteria.<br/><br/>Formulate Market Research Hypothesis provides tests and assumptions that enable the organization verify market analysis is correct.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7435" ;
    skos:prefLabel "Formulate Market Research Hypothesis"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7436> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7325> ;
    skos:definition "Specify Market Research Objectives business activity sets clear and focused objectives of the research in order to help avoid conflicting expectations or wasted time collecting irrelevant data. It ensures that the research is focused, relevant, and contributes to the decision-making process.<br/><br/>Specify Market Research Objectives business identifies the potential ideas of how to solve a market research problem or realize an opportunity.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7436" ;
    skos:prefLabel "Specify Market Research Objectives"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7437> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7325> ;
    skos:definition "Determine Market Research Evaluation Criteria business activity sets the criteria to evaluate the effectiveness and success of market research in order to ensure that the research is focused, relevant, and contributes to the decision-making process.<br/><br/>Determine Market Research Evaluation helps to avoid conflicting expectations, waste of time collecting irrelevant data, and helps to make informed business decisions. This business activity also contributes to the research design and indicates how the research will contribute to existing knowledge.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7437" ;
    skos:prefLabel "Determine Market Research Evaluation Criteria"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7438> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7326> ;
    skos:definition "Design Market Research Plan business activity creates roadmap and courses of actions that detail the way and how the research will be conducted to meet the defined objectives. Design Market Research Plan ensure that market research is conducted in a manner that is systematic, relevant, and efficient to meet business constraints of time, cost and resources.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7438" ;
    skos:prefLabel "Design Market Research Plan"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7439> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7326> ;
    skos:definition "Establish Market Research Method business activity decides and formalizes the research methodology that will be used to gather the necessary data and ensure that research methods provide effective and efficient ways to achieve the research objectives.<br/><br/>Establish Market Research Method involves choosing between different methods such as surveys, interviews, focus groups, or observation. It also ensures chosen methods align with the research objectives and are capable of providing the necessary data and information.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7439" ;
    skos:prefLabel "Establish Market Research Method"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7440> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7326> ;
    skos:definition "Select Market Research Tools business activity is responsible for choosing the appropriate tools and resources that will be used to gather and analyze the data and information to streamline the process of data/information collection and analysis.<br/><br/>Select Market Research Tools business activity ensures that tools selected are capable of providing the necessary data in the most efficient manner.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7440" ;
    skos:prefLabel "Select Market Research Tools"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7444> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7441> ;
    skos:definition "Identify Market Research Information Source is responsible for recognizing and selecting the relevant sources of information that will be used in the market research. Identify Market Research Information Source ensures that the information sources identified are reliable, relevant, and capable of providing the necessary data for the research. The goal is to identify the most appropriate sources of information, which could include internal company information, customer feedback, competitor analysis, social media trends, and industry publications. The underlying activities include reviewing potential information sources, assessing their relevance and reliability, and selecting the ones that are most likely to provide valuable data.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7444" ;
    skos:prefLabel "Identify Market Research Data/Information Source"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7445> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7441> ;
    skos:definition "Organize Market Research Information Source is responsible for the systematic arrangement and categorization of the identified information sources.<br/><br/>Organize Market Research Information Source ensures that the information sources are easily accessible and usable for the research. The goal is to provide a clear and organized structure for the research information, which facilitates easy retrieval and usage. The underlying activities include categorizing the information sources based on their relevance and reliability, and maintaining an organized database or system for easy access and retrieval.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7445" ;
    skos:prefLabel "Organize Market Research Data/Information Source"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7446> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7442> ;
    skos:definition "Source Market Research Information business activity is responsible for recognizing and selecting the relevant sources of information that will be used in the market research.<br/><br/>Source Market Research Information ensures that the information sources identified are reliable, relevant, and capable of providing the necessary data for the research. The goal is to identify the most appropriate sources of information, which could include internal company information, customer feedback, competitor analysis, social media trends, and industry publications. The underlying activities include reviewing potential information sources, assessing their relevance and reliability, and selecting the ones that are most likely to provide valuable data.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7446" ;
    skos:prefLabel "Source Market Research Data/Information"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7447> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7442> ;
    skos:definition "Store Market Research Information business activity is responsible for the systematic arrangement and categorization of the identified information sources.<br/><br/>Store Market Research Information ensures that the information sources are easily accessible and usable for the research. The goal is to provide a clear and organized structure for the research information, which facilitates easy retrieval and usage.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7447" ;
    skos:prefLabel "Store Market Research Data/Information"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7448> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7443> ;
    skos:definition "Prepare Market Research Information business activity is responsible for readying the collected market research data for further analysis.<br/><br/>Prepare Market Research Information ensures that market research data is accurate, consistent, and in a format that facilitates effective onward analysis. This includes cleaning the data to remove any errors or inconsistencies, coding qualitative data into a format that can be quantitatively analyzed, and transforming and translating the data as needed.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7448" ;
    skos:prefLabel "Prepare Market Research Information"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7449> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7443> ;
    skos:definition "Validate Market Research Information business activity is responsible for confirming the reliability and accuracy of the prepared market research information.<br/><br/>Validate Market Research Information ensures that data and information used in the analysis are valid and reliable. This involves checking the sources of information for credibility, verifying the accuracy of the data, and testing the data for consistency with the goal of minimizing the risk of making decisions based on faulty or misleading information.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7449" ;
    skos:prefLabel "Validate Market Research Information"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7452> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7450> ;
    skos:definition "Analyze Market Research Information business activity is responsible for scrutinizing collected market research data and information to extract meaningful insights that guide business decisions.<br/><br/>Analyze Market Research Information covers and includes tasks and tools to perform statistical analysis, trend identification, and comparative analysis in order to realize a comprehensive understanding of the market dynamics, customer behavior, and competitive landscape.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7452" ;
    skos:prefLabel "Analyze Market Research Information"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7453> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7450> ;
    skos:definition "Discover Market Research Data Associations is responsible for identifying relationships and patterns within the gathered market research information in order to uncover hidden associations or trends in the data that may not be immediately apparent.<br/><br/>Discover Market Research Data Associations provides a deeper understanding of the market dynamics with tasks that involve data mining techniques such as association rule learning, clustering, classification, and regression.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7453" ;
    skos:prefLabel "Discover Market Research Data Associations"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7454> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7450> ;
    skos:definition "Draw Market Research Conclusion business activity is responsible for formulating conclusions based on the discovered information and data associations with the purpose of translating data insights into actionable conclusions to guide business strategy.<br/><br/>Draw Market Research Conclusion provides clear, concise, and actionable conclusions that directly address the objectives of the market research.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7454" ;
    skos:prefLabel "Draw Market Research Conclusion"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7455> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7451> ;
    skos:definition "Identify Market Research Facts business activity is responsible for pinpointing and validating the factual information derived from the market research data and information.<br/><br/>Identify Market Research Facts ensure that the insights generated are based on accurate and reliable facts. This business activity will perform data verification, fact-checking, and validation in order to eliminate any inaccuracies or biases in data or information, thereby enhancing the reliability of the market research insights.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7455" ;
    skos:prefLabel "Identify Market Research Facts"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7456> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7451> ;
    skos:definition "Make Market Research Recommendation business activity is responsible for formulating actionable recommendations based on the identified facts and insights. Make Market Research Recommendation provides strategic guidance based on the market research insights to help the business capitalize on market opportunities and mitigate potential risks. The goal is to translate the market research insights into practical recommendations that align with the business's scenario objectives and capabilities.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7456" ;
    skos:prefLabel "Make Market Research Recommendation"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7458> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7329> ;
    skos:definition "Communicate Market Research Findings business activity is responsible for conveying the market research findings to the relevant stakeholders in a clear and effective manner. Communicate Market Research Findings has the goal of providing a clear and comprehensive summary of the research findings, while ensuring that these findings are understood and can be acted upon by the decision-makers.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7458" ;
    skos:prefLabel "Communicate Market Research Findings"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7459> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7457> ;
    skos:definition "Collate Market Research Findings business activity is responsible for gathering, organizing, and categorizing all the data and information obtained from various market research activities. Collate Market Research Findings creates a comprehensive and structured data set and information catalog that accurately represents the market research findings, including tasks to integrate data and information, and data/information reduction.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7459" ;
    skos:prefLabel "Collate Market Research Findings"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7460> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7457> ;
    skos:definition "Identify Market Research Implications business activity is responsible for interpreting the collated market research findings and to draw meaningful and conclusive implications from the market research findings.<br/><br/>Identify Market Research Implications ensures research findings are correlated based on patterns and trends, with opportunities and challenges of associated/related actions.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7460" ;
    skos:prefLabel "Identify Market Research Implications"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7461> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7330> ;
    skos:definition "Validate Market Research Value business activity is responsible for assessing the value and effectiveness of the market research conducted with the purpose of ascertaining that the research has met its objectives and provided valuable insights.<br/><br/>Validate Market Research Value has the goal of validating the usefulness and applicability of the research findings with underlying tasks that include reviewing the research objectives and findings, assessing the impact of the research on decision-making, and evaluating the return on investment of the research.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7461" ;
    skos:prefLabel "Validate Market Research Value"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7462> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7330> ;
    skos:definition "Archive Market Research Information business activity is responsible for storing the research data and findings for future reference with the purpose of ensuring that the research data is preserved and can be accessed / referenced in the future.<br/><br/>Archive Market Research Information creates a comprehensive and accessible archive of market research information with the use of the enterprises Information and data management processes. Underlying activities include categorizing and storing the research data, maintaining an organized database or system for easy access and retrieval, and ensuring the long-term preservation of the research data.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7462" ;
    skos:prefLabel "Archive Market Research Information"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7463> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7330> ;
    skos:definition "Identify Future Market Research business activity is responsible for identifying potential areas for future research based on the findings of the current research.<br/><br/>Identify Future Market Research ensure that the research contributes to the ongoing development of knowledge and informs future research efforts. This includes identify gaps in knowledge, unanswered questions, or new questions raised by the research. Tasks performed within this activity include identifying areas for future research, and developing a research agenda for future application to market researches.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7463" ;
    skos:prefLabel "Identify Future Market Research"@en .

