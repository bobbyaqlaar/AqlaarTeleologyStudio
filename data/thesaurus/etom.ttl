    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7716> ;
    skos:definition "Ensuring the customer inventory repository accurately captures and records all identified customer details, through use of automated or manual audits. Monitoring and reporting on the quality of the data maintained in the inventory. The customer inventory maintains records of all customers, their interactions with the enterprise, any contracts established, and any other customer related- information, required to support CRM and other processes.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7781" ;
    skos:prefLabel "Ensure Customer Inventory Data Quality"@en .

