<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7878> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7881> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7878" ;
    skos:prefLabel "Follow-up QoS Violation Action"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7879> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7881> ;
    skos:definition "Ensure that the customer and the relevant internal processes are informed of service quality degradations and violations. Ensure that the customer is informed of any planned maintenance or other scheduled events likely to impact delivery of the customer's service.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7879" ;
    skos:prefLabel "Inform Customer on QoS Impacts"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7885> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7713> ;
    skos:definition "The objective of the Close Customer QoS Performance Degradation Report processes is to close a customer QoS performance degradation report when the performance of the customer purchased product offerings has been resolved.<br/>These processes monitor the status of all open customer QoS performance degradation reports, and recognize that a customer QoS performance degradation report is ready to be closed when the status is changed to cleared.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7885" ;
    skos:prefLabel "Close Customer QoS Performance Degradation Report"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7886> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7963> ;
    skos:definition "The purpose of this process is to verify that the customer is who they claim they are. This can be achieved by examination of an identity certification issued by a trusted body (such as governmental agency or other accepted means). Certification means can be physical (such as Passport or ID card), biometrical or other.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7886" ;
    skos:prefLabel "Verify Customer"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7887> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7963> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7887" ;
    skos:prefLabel "Establish New Customer Identity"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7888> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7963> ;
    skos:definition "After termination, provides clean-up duplicates of customer identifying information that may exist within the organization. Profile and preference information for terminated customer relationships is archived if acceptable to the customer. All relevant parties are informed of the ended relationship. Other processes are triggered to dismantle the customer solution and servicing arrangements as necessary.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7888" ;
    skos:prefLabel "Clean-up & Archive Customer Identifying Information"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7889> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7963> ;
    skos:definition "The purpose of this process is to check that the customer does not already have an Identity with the Enterprise. This process is also used to ‘clean-up’ duplicates of customer identifying information that may exist within the organization.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7889" ;
    skos:prefLabel "De-duplicate Customer Identity"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7890> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7963> ;
    skos:definition "The purpose of this process is to ensure only one customer identity exists across the Enterprise, which can be referenced across the whole Enterprise and allows the customer to quickly and easily identify himself. Before establishing an identity for a new customer de-duplication check is performed.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7890" ;
    skos:prefLabel "Issue Unique Customer ID"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7891> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7963> ;
    skos:definition "The purpose of this process is to gather information that enables the enterprise to authenticate the customer identity. This information can be documents issued by other authorities (such as ID card or passport) or information that will enable the enterprise to re-authenticate the customer (such as answer to a secret question).<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7891" ;
    skos:prefLabel "Gather Authentication Information"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7892> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7775> ;
    skos:definition "Deliver Customer Support Delivery Capability processes enable planning and effective delivery of the total capabilities required to ensure customer support in a timely, effective and reliable way to meet all existing and potential customer needs for products and services offered. <br/>The customer support capabilities can include dedicated organization, established processes and technology delivered from within the enterprise, and/or capabilities delivered from an external party.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7892" ;
    skos:prefLabel "Deliver Customer Support Delivery Capability"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7893> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7775> ;
    skos:definition "Deliver Customer Support Integration Capability processes <br/>ensure that the support capabilities are well integrated regardless if they are delivered from within the enterprise, or delivered from an external party.<br/>The integration can include dedicated organization, established processes and technology to uphold an effective reliable customer support consisting of multiple support suppliers.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7893" ;
    skos:prefLabel "Deliver Customer Support Integration Capability"@en .

