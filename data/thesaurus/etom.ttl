<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7848> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7884> ;
    skos:definition "Note that some specific product and/or service components may be owned and managed by other Parties. In these cases, initiate requests, through the other party Performance Management for resolution by the other party of the specific service components. These processes will co-ordinate all the actions necessary in order to guarantee that all tasks are finished at the appropriate time and in the appropriate sequence.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7848" ;
    skos:prefLabel "Engage External Product Suppliers"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7849> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7884> ;
    skos:definition "Inform the Close Customer QoS Performance Degradation Report processes by modifying the customer QoS performance degradation report status to cleared when the specific customer purchased product offering performance quality issues have been resolved.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7849" ;
    skos:prefLabel "Clear Customer QoS Report Status"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7853> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7929> ;
    skos:definition "Monitor Customer Problem will ensure the problem is being addressed and the customer is kept informed. It includes tasks to monitor the problem status, progress, and resolution.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7853" ;
    skos:prefLabel "Monitor Customer Problem"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7854> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7929> ;
    skos:definition "Distribute Customer Problem Notifications will keep all stakeholder updated about the problem’s status. It includes tasks to create and send notifications that contain the problem summary, impact, and resolution.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7854" ;
    skos:prefLabel "Distribute Customer Problem Notifications"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7855> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7929> ;
    skos:definition "Distribute Customer Problem Management Report includes tasks to create and send reports that contain the problem analysis, root cause, and solution provided management reports, with any specialized summaries of the efficiency and effectiveness of the overall Customer Problem Management process. These specialized summaries could be specific reports required by specific audiences.<br/>This process was renamed in 23.5 it was called Distribute Customer Problem Management Reports & Summaries<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7855" ;
    skos:prefLabel "Distribute Customer Problem Management Report"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7856> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7929> ;
    skos:definition "Notify Customer Problem will keep the customer informed and manage their expectations. It includes tasks to communicate the problem details, impact, and resolution to the customer.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7856" ;
    skos:prefLabel "Notify Customer Problem"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7857> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7929> ;
    skos:definition "Issue Customer Problem Management Summary will provide specialized overviews of the issue. It includes tasks to create and send summaries that contain the problem description, status, and resolution.<br/><br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7857" ;
    skos:prefLabel "Issue Customer Problem Management Summaries"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7858> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7929> ;
    skos:definition "Generate Customer Management Problem Report will document customer problems, impact, and resolution based on specific audience. It includes tasks to create and formalize problem reporting, save reports that contain the problem analysis, root cause, and solution.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7858" ;
    skos:prefLabel "Generate Customer Problem Management Reports"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7859> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7898> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7859" ;
    skos:prefLabel "Collect Customer Personalization Information"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7860> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7898> ;
    skos:definition "Provides a source of data for performing loyalty and retention marketing campaigns, for retaining existing customers, promoting customer loyalty, winning back customers who have left. It utilizes predictive modeling software to analyze an account, and to return relevant scores, such as: churn score, up-sell score, cross-sell score, bad debt score and customer lifetime value score. Moreover it utilizes scores for customer analysis and marketing campaign purposes.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7860" ;
    skos:prefLabel "Provide Customer Personalization Information"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7861> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7898> ;
    skos:definition "Provides the personalization opportunities for customers that will encourage them not to switch to another Service Provider. Personalization allows delivery of services that more closely match the customer’s need. - Business Planning is essential to allow the Service Provider to match the customer’s future retention needs and potential acquisition needs, rather than just continuing with today's known needs.<br/>-Loyalty schemes allow tangible benefits to be offered to good customers in a mass-market.<br/>- The process aims to ensure that all information is gathered and used to make the best decisions to retain those customers the Service Provider wants to retain, heighten satisfaction and maintain profitability.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7861" ;
    skos:prefLabel "Ensure Customer Personalization Opportunities"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7862> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7795> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7862" ;
    skos:prefLabel "Manage Customer Payment Plan"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA3_EA7863> a skos:Concept ;
