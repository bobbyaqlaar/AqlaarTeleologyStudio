<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8768> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8697> ;
    skos:definition "This process provides the escalations between support levels and actors when a service problem cannot be solved by the current assigned group. Therefore, the escalation can be carried out between supports levels at SM&O level, or, it can be escalated to others actors, such as, resource provider or other external parties. It is essential the ability to rapidly escalate service problems according to clear and agreed rules.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8768" ;
    skos:prefLabel "Escalate/End Service Problem"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8769> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8697> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8769" ;
    skos:prefLabel "Perform Final Service Test"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8770> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8697> ;
    skos:definition "This process is responsible for assigning the prioritization to service problem in order to establish an order for managing it. The prioritization is assigned (usually automatically) according to criteria, such as, categorization, services affected and SLAs.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8770" ;
    skos:prefLabel "Prioritize Service Problem"@en .

