    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10769" ;
    skos:prefLabel "Validate Collected Risk Information"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10770> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10595> ;
