<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10432> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10576> ;
    skos:definition "Manage activities associated with securities/shares of the enterprise and any securities/company regulations impacting on the company, including the administration and management of continuous disclosure/announcements to the securities exchange and/or securities/company regulator.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10432" ;
    skos:prefLabel "Manage Shares/Securities"@en .

