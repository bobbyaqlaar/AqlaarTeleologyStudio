    skos:definition "Update Sales Problem Knowledge business activity is responsible for refreshing learning from a sales problem.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7592" ;
    skos:prefLabel "Update Sales Problem Knowledge"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7596> a skos:Concept ;
