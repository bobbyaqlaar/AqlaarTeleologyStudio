    skos:prefLabel "Approve Product Offering for Launch/Rollout"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8236> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8370> ;
    skos:definition "Manage Product Capacity Thresholds business activity is in charge administering product capacity thresholds based on conditions that are bounded by operational concerns.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8236" ;
    skos:prefLabel "Manage Product Capacity Thresholds"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8237> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8438> ;
    skos:definition "Define Product Offering Catalog uses the generalized Develop Catalog process and its sub-processes to define, update, and remove a specific type of catalog, in this case a product offering catalog.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8237" ;
    skos:prefLabel "Define Product Offering Catalog"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8238> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8438> ;
    skos:definition "Associate Product Offering with Product Offering Catalog associates a product offering and applicable product offering prices with a catalog. The product offering may have been developed by an enterprise or on-boarded from another party.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8238" ;
    skos:prefLabel "Associate Product Offering with Product Offering Catalog"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8239> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8393> ;
    skos:definition "Create Product creates a product as a standalone product, a product bundle, or one that is part of a product bundle. The product is associated with either the product specification or product offering that describes it. If the product is one that is customized by a party and not offered by an enterprise the product is associated to the product specification that describes it.<br/><br/>Features/properties chosen during the Product Offering Purchasing process or chosen by this process if the product is created outside of the Product Offering Purchasing process may also be created for the product. This is done if the Product Configuration process is not used to create them.<br/><br/>A product is associated with its installation location if applicable and the associated product offering terms/conditions that were accepted, such as those for a contract or voucher. It may also be associated with one or more other products. For example, one product may replace another.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8239" ;
    skos:prefLabel "Create Product"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8240> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8393> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8240" ;
    skos:prefLabel "Modify Product"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8241> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8393> ;
    skos:definition "Specify Party Product Involvement specifies the involvement one or more parties have with it and the party account that will pay for the product. If the product is paid for when it is purchased and there are no recurring or other types of charges due at some point in the future, then the party account may not be specified. Involved parties type of involvement is also specified, such as user, owner, payer. <br/><br/>Additionally identity specific information, such as rights and restrictions, are specified for users (parties) of the product.<br/><br/>This process also updates and removes the involvement and identity specific information.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8241" ;
    skos:prefLabel "Specify Party Product Involvement"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8247> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8188> ;
    skos:definition "Product Test Strategy develops the strategies of the enterprise for Product Test.<br/>This process is in charge of identifying types of Product Test to be conducted according to different context (i.e. business activities) for types of products.<br/>The different context for Product Test are:<br/><ul><li>Product Specification Development & Retirement to qualify the capacity to deliver Products before validating a new ProductSpecification,</li><li>Order Handling (Customer Order Orchestration) to test the Product before closing the CustomerOrderItem,</li><li>Product Performance Management to test Product performance,</li><li>Customer Problem Handling to test Product functioning,</li><li>Product Test Management to conduct tests not specific to a customer’s product.</li></ul><p/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8247" ;
    skos:prefLabel "Product Test Strategy"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8248> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8188> ;
    skos:definition "Analyze Product Test Quality process performs quality analysis of testing processes, in order to continuously fine-tune and improve them.<br/>Product Test Quality Analysis processes provide analysis of the performance of product testing processes to ensure their continuous fitness for purpose, and eventually propose modifications or enhancements to the current product test specifications (including: product testing methods, quota, authorized users, recommendations and course of action if needed).<br/>The analysis is done using statistical product test usage data to evaluate product tests performance and required improvements if needed.<br/>Following the analysis, typical course of action can be:<br/> - No changes needed currently,<br/> - Creation of additional product tests,<br/> - Improving existing product tests,<br/> - Removing product tests that are no longer relevant.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8248" ;
    skos:prefLabel "Analyze Product Test Quality"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8252> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8192> ;
    skos:definition "Control Product Performance business activity determine and administer changes and directives the manage product performance accomplishment. Control Product Performance may establish and manage actions that directly or indirectly impact on products, their impact on customers and ultimately their performance in the market.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8252" ;
    skos:prefLabel "Control Product Performance"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8253> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8192> ;
    skos:definition "Report Product Performance Analysis business activity provides detailed account of research findings and outcome of evaluation of product performance. Product Performance Analysis reports is created and re-created repeatedly over the lifecycle of each product.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8253" ;
    skos:prefLabel "Report Product Performance"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8254> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8501> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8254" ;
    skos:prefLabel "Edit Product Usages"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8255> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8501> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8255" ;
    skos:prefLabel "Reformat Product Usages"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8260> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8348> ;
    skos:definition "Product Offering Prototyping iteratively develops a product offering. Product Offering Development & Retirement processes develop each iteration of the offering to a state that enables it to be tested in some way by the Product Offering Development & Retirement’s Conduct Product Offering Acceptance Testing process. Tests can be conducted internally, in the form of a pilot, or field trial. Tests are measured against defined acceptance criteria. Identified improvements/enhancements are made during the next iteration based on test results. Once the final iteration tests are accepted the offering is rolled out and launched to the market at large.<br/><br/>Note: This process is not further decomposed, because the process uses existing Product Offering Development & Retirement processes.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8260" ;
    skos:prefLabel "Product Offering Prototyping"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8265> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8450> ;
    skos:definition "Obtain Product Offering Price Approval handles the approval of the creates, modifications, removals/discontinues to prices and price plans by those parties involved in the approval process. This includes any actions taken by any pricing related core processes.<br/><br/>Additionally enterprise cross-product pricing approval is also obtained.<br/><br/>Upon approval the Provide Product Offering Price Notification process provides notification of the approval to all involved parties.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8265" ;
    skos:prefLabel "Obtain Product Offering Price Approval"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8267> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8450> ;
    skos:definition "Discontinue Product Offering Price discontinues a product offering price including a price plan. Discontinue may remove the price or plan or indicate that the price or plan is no longer valid.<br/><br/>It interacts with the Provide Product Offering Price Notification and Obtain Product Offering Price Approval processes to provide notifications of the discontinued price or plan to parties who are responsible for the approval of the discontinuance or have some other level of involvement, obtain approval to discontinue, and discontinue the price or plan. Once discontinued, notifications are sent to all involved parties, such as approvers, those consulted about the discontinuance, and other involved parties.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8267" ;
    skos:prefLabel "Discontinue Product Offering Price"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8268> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8245> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8268" ;
    skos:prefLabel "Co-ordinate Product Business Plans"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8269> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8245> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8269" ;
    skos:prefLabel "Develop Product Portfolio Forecasts"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8270> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8245> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8270" ;
    skos:prefLabel "Negotiate Product Business Plan Resources"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8271> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8245> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8271" ;
    skos:prefLabel "Develop Outline Market Strategy"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8272> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8245> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8272" ;
    skos:prefLabel "Develop Product Pricing Strategy"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8273> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8245> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8273" ;
    skos:prefLabel "Develop Revenue/Cost Projections"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8274> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8245> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8274" ;
    skos:prefLabel "Develop Product Performance Requirements"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8275> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8245> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8275" ;
    skos:prefLabel "Develop Product Operational Requirements"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8276> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8245> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8276" ;
    skos:prefLabel "Gain Business Plan Commitment and Approval"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8277> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8245> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8277" ;
    skos:prefLabel "Communicate Business Plans"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8278> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8485> ;
    skos:definition "Manage Infrastructure Policy Lifecycle is performed in case a policy lifecycle process needs to become established to meet the challenges of a dynamic offering catalogue. This process would verify that the risks of carrying an offer were acceptable and initiate the development and maturation of any policy development activity to close any gaps.<br/><br/>This process is critical when managing virtual infrastructure such as Could resources or slices of virtual networks.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8278" ;
    skos:prefLabel "Manage Infrastructure Policy Lifecycle"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8279> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8485> ;
    skos:definition "Enforce Infrastructure Policy us responsible for the action of applying every identified applicable policy upon the operation of a resource. If the resources are persistent this can be arranged at build time, by if the resources are intermittent then a continuous process needs to guarantee policy adherence.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8279" ;
    skos:prefLabel "Enforce Infrastructure Policy"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8280> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8485> ;
    skos:definition "Manage Infrastructure Fulfillment Orchestration Intent Lifecycle process ensures that the intents that intermittent orchestration processes provide are managed appropriately by the platform owner. This process needs to be continuous when infrastructure is virtual and the relationships between infrastructure elements are dynamic. (This process can be delivered within the design of persistent offers)<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8280" ;
    skos:prefLabel "Manage Infrastructure Fulfillment Orchestration Intent Lifecycle"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8281> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8485> ;
    skos:definition "Execute Infrastructure Fulfillment Orchestration Intent is responsible for the action of delivering the outcome of an intent provided by an orchestration process.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8281" ;
    skos:prefLabel "Execute Infrastructure Fulfillment Orchestration Intent"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8282> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8485> ;
    skos:definition "Perform Assurance Analysis of Network state is responsible for an asynchronous process to review the state of a network and test that what has been configured is within the boundaries allowed by policies. In a persistent network this process can be executed occasionally as an audit, by a dynamic intermittent network will need constant validation and confirmation.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8282" ;
    skos:prefLabel "Perform Assurance Analysis of Network state"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8283> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8566> ;
    skos:definition "Categorize Product Problem business activity is in charge of organizing and classifying product problems based on business conditions. <br/><br/>Categorize Product Problem helps to cluster and correlate product problems in order to support triaging product problems with product problem solutions (if they exist solutions in the knowledge base.)<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8283" ;
    skos:prefLabel "Categorize Product Problem"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8284> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8566> ;
    skos:definition "Prioritize Product Problem business activity is in charge of ordering product problems by level of urgency and impact based to the business. <br/><br/>Prioritize Product Problem business activity supports Categorize Product Problem in order to effectively Triage Product Problem.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8284" ;
    skos:prefLabel "Prioritize Product Problem Management"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8290> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8231> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8290" ;
    skos:prefLabel "Define Product Offering Acceptance Test"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8291> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8231> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8291" ;
    skos:prefLabel "Identify Product Offering Acceptance Test Participants"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8292> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8231> ;
    skos:definition "Conduct Product Offering Acceptance Test uses commercial pilots and/or market trials of the offering or prototypes of the offering.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8292" ;
    skos:prefLabel "Conduct Product Offering Acceptance Test"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8293> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8251> ;
    skos:definition "Research Product Performance business activity review and investigate product performance concerns. Research Product Performance may leverage case studies etc. to clarify product performance against product performance requirements and to support making a business decision.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8293" ;
    skos:prefLabel "Research Product Performance"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8294> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8251> ;
    skos:definition "Develop Product Performance Insights business activity provide deep understanding on product performance requirements and concerns (such as performance criteria, performance targets, performance hinderance etc.). Develop Product Performance Insights will provide, amongst others, product performance trend Analysis, development sourcing details related to purchased product offers performance and analysis from the product offer inventory (for cases that require assisting the development of trends).<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8294" ;
    skos:prefLabel "Evaluate Product Performance Insights"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8295> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8251> ;
    skos:definition "Report Product Performance Analysis business activity provides detailed account of research findings and outcome of evaluation of product performance.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8295" ;
    skos:prefLabel "Report Product Performance Analysis"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8296> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8513> ;
    skos:definition "Create Configuration Constraint, business activity establishes and implements checks and controls that are necessary to determine when a configuration item or attribute is required during the configuration process.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8296" ;
    skos:prefLabel "Create Configuration Specification Constraint"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8297> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8513> ;
    skos:definition "Create Configuration Specification Constraint Member business activity associates component constraint that represent specific configuration specification check point.<br/>Constraint Members represent another configuration parameter, characteristics or attribute.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8297" ;
    skos:prefLabel "Create Configuration Constraint Member"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8298> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8286> ;
    skos:definition "Identify Product Exception business activity supports the detection of Product Anomaly by investigating (recognizing and establishing) particular activity or event as an exception.<br/>Identify Product Exception business activity will support all Product Anomaly Management business activities - Assess Product Anomaly, Predict Product Anomaly, Mitigate Product Anomaly and Learn Product Anomaly.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8298" ;
    skos:prefLabel "Identify Product Exception"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8299> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8286> ;
    skos:definition "Treat Product Exception business activity provides the set of actions that support managing a products’ anomalous exception.<br/>This covers actions that may be:<br/>Proactive: Where the treatment of the conditions leading from the exception are controlled;<br/>Reactive: Where the treatment is directly in response to the exception.<br/>Treat Product Exceptions business activity helps to outline a series of actions that can expedite decisions for mitigation.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8299" ;
    skos:prefLabel "Treat Product Exception"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8300> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8286> ;
    skos:definition "Escalate Product Exception business activity is in charge of increasing the attention given to handling of a Product Exception.<br/>Escalating a Product’s exception may be based on several factors, including defined business rules of escalation, or the lack thereof for handling a product’s exception.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8300" ;
    skos:prefLabel "Escalate Product Exceptions"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8301> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8198> ;
    skos:definition "This process manages the balance containers assigned to a Product and is used to keep track of usage events, providing input for decision making processes (such as product usage authorization) by means of the balance policies. <br/><br/>The containers include monetary and non-monetary balances (or shared) and are used as prepaid balances (enabling real-time product usage authorization), postpaid balances (in conjunction with an Account-Receivables [AR] application). Examples of non-monetary balances and allowances are: free minutes, WAP-only quota, etc.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8301" ;
    skos:prefLabel "Manage Product Balance Containers"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8302> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8198> ;
    skos:definition "Product Balance policies are rules that describe how balance affecting usages are to be handled. This is done by comparing the value of each usage against criteria such as the following:<br/>- a minimum allowable balance limit (e.g. balance must remain above zero), <br/>- balance expiration dates, <br/>- balance thresholds actions and notifications and<br/>- roll-over & cyclic policies.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8302" ;
    skos:prefLabel "Manage Product Balance Policies"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8303> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8198> ;
    skos:definition "Product Balance operations processes the charged events, using balance policies and then guides the results towards the relevant balance containers. Operations include :<br/>- Reserving amounts from any balance for any session, and crediting unused reservations back into the balance, when a session is released. <br/>- Updating balances by applying charges to the balance and credit/debit adjustments.<br/>- Balance queries.<br/>- Transferring amounts from one balance to another.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8303" ;
    skos:prefLabel "Product Balance Operations Management"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8304> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8198> ;
    skos:definition "This process may include Product balance reservation and must be performed online. <br/>Subsequent balance updates are not required to be done in real-time. In this context a usage is provided by the network, e.g. voice call. Product might be a digital content delivered via the network, e.g. content such as music, games, etc.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8304" ;
    skos:prefLabel "Authorize Transaction Based on Product Balance"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8305> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8263> ;
    skos:definition "Define Product Offering Price Plan creates a grouping of product offering prices that represent a price plan for a product offering. For example a plan may consist of a recurring charge for a data plan and a charge for excess data usage.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8305" ;
    skos:prefLabel "Define Product Offering Price Plan"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8306> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8263> ;
    skos:definition "Modify Product Offering Price Plan modifies a grouping of product offering prices that represent a price plan for a product offering. Included are the removal and addition of product offering prices to the plan.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8306" ;
    skos:prefLabel "Modify Product Offering Price Plan"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8307> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8285> ;
    skos:definition "Forecast Product Anomaly business activity predicts future Product anomaly along with implications using historical, and /or ongoing patterns observed through exceptions.<br/>Forecast Product Anomaly business activity may include what-if analysis, or impact analysis of the anomalous exceptions. Forecast Product Anomaly business activity supports the identification of potential risks of an exception, and the course of action needed to avoid potential risks.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8307" ;
    skos:prefLabel "Forecast Product Anomaly"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8308> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8428> ;
    skos:definition "These processes define the methodology to be adopted for product capability delivery across the enterprise. The processes define the procedures and steps to follow to ensure that all project activities across the enterprise to develop infrastructure capability are co-coordinated, visible and controlled. These processes define the steps in the methodology, and approval process or gates.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8308" ;
    skos:prefLabel "Define Product Capability Delivery Methodology"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8309> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8428> ;
    skos:definition "These processes manage the methodology to be adopted for product capability delivery across the enterprise. These processes may maintain a repository of all activities as a part of the coordination aspects, including approval process or gates to be passed by individual product capability delivery projects.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8309" ;
    skos:prefLabel "Maintain Product Capability Delivery Repository"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8310> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8516> ;
    skos:definition "Modify Product Configuration Object business activity is in charge of altering or amending existing product configuration object.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8310" ;
    skos:prefLabel "Modify Product Configuration Object"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8311> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8516> ;
    skos:definition "Add Product Configuration Object business activity is in charge of introducing new product configuration objects.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8311" ;
    skos:prefLabel "Add Product Configuration Object"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8312> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8516> ;
    skos:definition "Delete Product Configuration Object business activity is in charge of eliminating an existing product configuration object.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8312" ;
    skos:prefLabel "Delete Product Configuration Object"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8313> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8262> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8313" ;
    skos:prefLabel "Create Product Offering Price"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8314> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8262> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8314" ;
    skos:prefLabel "Define Product Offering Price Event"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8315> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8262> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8315" ;
    skos:prefLabel "Associate Product Offering Price with Geographic Area"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8316> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8195> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8316" ;
    skos:prefLabel "Identify Relevant Product Inventory Information"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8317> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8195> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8317" ;
    skos:prefLabel "Maintain Product Inventory facilities"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8318> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8195> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8318" ;
    skos:prefLabel "Control Product Inventory Access"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8319> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8195> ;
    skos:definition "Ensuring the product inventory repository accurately captures and records all identified product details, through use of automated or manual audits. Monitoring and reporting on the quality of the information maintained in the inventory. The product inventory maintains records of all products, their interactions with the enterprise, and any other product related- information, required to support CRM and other processes. The product inventory is also responsible for maintaining the association between customers and purchased product instances, created as a result of the Order Handling processes.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8319" ;
    skos:prefLabel "Ensure Product Inventory Quality"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8320> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8195> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8320" ;
    skos:prefLabel "Track Product Inventory Usage"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8321> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8195> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8321" ;
    skos:prefLabel "Identify Product Inventory Shortcomings"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8326> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8347> ;
    skos:definition "Manage Product Specification Development ensures the co-coordinated delivery in line with the approved business case of all required product specification capabilities for that business case across the enterprise. These processes may use project management disciplines when a project is created to develop a specification to deliver the necessary capabilities, including process development, specific systems & network infrastructure developments, specific channel developments, specific operational procedures, and so forth. required to support the new product specification. <br/>Note that delivery of a product specification within the context of existing commercial agreements is managed through the Party Offering Development & Retirement process. If new partners are required, the Party Agreement Management process is used to deliver the necessary commercial agreements.<br/>Note that the management of major new or enhanced infrastructure development to support Product & Offer Development is managed within the Product & Offer Capability Delivery process<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8326" ;
    skos:prefLabel "Manage Product Specification Development"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8327> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8347> ;
    skos:definition "Remove Product Specification removes a product specification, either by deleting it or indicating it is no longer valid. When all associated Product Offerings have been deemed no longer viable and there are no Product Offerings planned the Product Specification is removed. Notifications are sent to Service Development & Retirement and Resource Development and Retirement processes so that they can determine if the associated service and resource specifications should also be removed. Additionally a notification may be sent to the Party Offering Development & Retirement process so that it can determine if any on-boarded specifications should also be removed.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8327" ;
    skos:prefLabel "Remove Product Specification"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8328> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8442> ;
    skos:definition "Develop Product Configuration Policy business activity is in charge of defining the product configuration policy that governs the use of a product configuration.<br/>The Develop Product Configuration Policy will leverage the Enterprise Management Policy process to define specific Product Configuration Management policies that are used to determine the management of product configuration.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8328" ;
    skos:prefLabel "Develop Product Configuration Policy"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8329> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8442> ;
    skos:definition "Establish Product Configuration Management Plan business activity sets up the course of action that will support managing and auditing product configuration items. Establish Product Configuration Management Plan business activity ensure product requirement management are anticipated and understood through well-defined product configuration plans.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8329" ;
    skos:prefLabel "Establish Product Configuration Management Plan"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8330> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8242> ;
    skos:definition "Collect Market Problem Information business activity is in charge of gathering relevant and related data and information that are directly or correlated to a defined market problem.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8330" ;
    skos:prefLabel "Collect Market Problem Information"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8331> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8242> ;
    skos:definition "Define Market Problem business activity is in charge of establishing a clear case for a market issue, challenge or concern. <br/><br/>Define Market Problem includes tasks that establish the market issue/challenge or concern and the impact it has on the business.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8331" ;
    skos:prefLabel "Define Market Problem"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8332> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8417> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8332" ;
    skos:prefLabel "Develop Product Offering Promotion Metrics"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8333> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8417> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8333" ;
    skos:prefLabel "Gather Product Offering Promotion Metrics"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8334> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8417> ;
    skos:definition "Analyze Product Offering Promotion Metrics analyzes gathered product offering promotion(s) metrics to identify any issues with the promotion(s). The analysis includes identifying any established thresholds that have been crossed and the associated consequence (good or bad). A report is produced that reflects the effectiveness of the product offering promotion(s).<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8334" ;
    skos:prefLabel "Analyze Product Offering Promotion Metrics"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8335> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8417> ;
    skos:definition "Suggest Product Offering Promotion Change feeds back suggested product offering promotion changes to adapt it to become more effective. This is based in part on the analysis of product offering promotion metrics.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8335" ;
    skos:prefLabel "Suggest Product Offering Promotion Change"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8336> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8394> ;
    skos:definition "Apply Product Price applies a product price to a product. The price may be influenced directly or indirectly by a policy. A price may be a single price, a group of prices, or part of the group. For example, a group may consist of a recurring payment for base usage of the product, such as the number of times medical information can be sent to a doctor each month, and another price for any usage that exceeds the base.<br/><br/>The price may also be dependent on a policy or a policy may determine another price to apply to the product or some other product. For example, viewing more than a defined number of videos may result in a free view for a family member. Policies are defined when the product offering is developed and associated with an item on a product offering purchase.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8336" ;
    skos:prefLabel "Apply Product Price"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8337> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8394> ;
    skos:definition "Update Product Price makes changes to the price of a product. The update may include changes to associations with a policy that influences the price. This is typically triggered by changes to the price of a product offering in an enterprise's product catalog.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8337" ;
    skos:prefLabel "Update Product Price"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8338> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8373> ;
    skos:definition "Define Product Offering develops the product offering, which also includes a bundled offering and the number of offerings allowable to be chosen as part of the bundle. Bundles may include offerings on-boarded from other parties.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8338" ;
    skos:prefLabel "Define Product Offering"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8339> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8373> ;
    skos:definition "Define Product Offering Features/Properties associates features/properties known as characteristics to an offering. These features/properties are defined for the associated product specification and/or product configuration specification. For example, the format of a movie may determine the price for the offering.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8339" ;
    skos:prefLabel "Define Product Offering Features/Properties"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8340> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8373> ;
    skos:definition "Associate Price to Product Offering associates a product offering to product offering price. Prices are developed by Product Offering Pricing.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8340" ;
    skos:prefLabel "Associate Price to Product Offering"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8341> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8373> ;
    skos:definition "Define Inter-Product Offering Association defines associations (relationships) between and among product offerings. These associations represent business rules, such as migration, substitution, dependency, or exclusivity between and among the offerings.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8341" ;
    skos:prefLabel "Define Inter-Product Offering Association"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8342> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8373> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8342" ;
    skos:prefLabel "Define Product Offering Associations"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8343> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8373> ;
    skos:definition "Ensure Product Offering Documentation Production ensures that all detailed specifications are produced and appropriately documented for a product offering. Additionally the processes ensure that the documentation is captured in an appropriate enterprise repository.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8343" ;
    skos:prefLabel "Ensure Product Offering Documentation Production"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8344> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8427> ;
    skos:definition "These processes co-ordinate the processes involved in handover of deployed product infrastructure to operational control, including the management and coordination of all stakeholders required to gain approval and acceptance of the handover.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8344" ;
    skos:prefLabel "Co-ordinate Product Operational Handover"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8345> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8427> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8345" ;
    skos:prefLabel "Validate Product Infrastructure Design"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8346> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8427> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8346" ;
    skos:prefLabel "Ensure Product Handover Support"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8349> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8193> ;
    skos:definition "Product Test Development & Retirement is in charge of the Product Test catalog.<br/>A type of Product Test aims at measuring proper functioning and capacities of a Product whatever the context is (Product Specification Development & Retirement, Order Handling, Customer Order Orchestration, Product Performance Management, Customer Problem Handling, Product Test Management).<br/>Product Test Development & Retirement includes:<br/>- Specifying in detail each Product Test according to the different context. It includes specifying:<br/><ul><li>the roles authorized to use the Test and quotas for each type of role</li><li>the method to conduct the Test</li><li>the rules that define the strategies for conducting the test (including the test plan)</li><li>the thresholds and related actions</li><li>the relationships with lower level tests (Service Test or Resource Test)</li><li>the report of test results with rules for enrichment of Service & Resource Tests results according to role asking for it</li></ul>- Specifying test scenarios defining sequence of Tests with rules about context and planning to trigger it. It includes roles allowed for asking test scenario and corresponding quotas.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8349" ;
    skos:prefLabel "Product Specification Test Development & Retirement"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8350> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8244> ;
    skos:definition "Define overall product portfolios structure processes focus on defining overall structure of product portfolios to be used across the enterprise, or between or within business units. These products and product portfolios form the basis of offers made to customers.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8350" ;
    skos:prefLabel "Define Overall Product Portfolios Structure"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8351> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8244> ;
    skos:definition "Implement product portfolio management functions processes focus on agreement on and implementation of cross-portfolio and cross-product co-ordination and management functions.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8351" ;
    skos:prefLabel "Implement Product Portfolio Management Functions"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8352> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8416> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8352" ;
    skos:prefLabel "Manage Product Offering Promotion Channel Capability"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8353> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8416> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8353" ;
    skos:prefLabel "Manage Product Offering Promotion Channel Resources"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8354> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8416> ;
    skos:definition "Wrap-up Start of Product Offering Promotion completes the start of the product offering promotion. It is coordinated with the delivery of the associated marketing campaigns and marketing communications.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8354" ;
    skos:prefLabel "Wrap-up Start of Product Offering Promotion"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8355> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8480> ;
    skos:definition "Define Product Specification develops the product specification, which also includes grouping/bundling of specifications and versioning of the specifications. Groups/bundles may include specifications on-boarded from other parties. The groups/bundles typically contain product specifications that are always included together and not separately priced.<br/><br/>When necessary version information, such as version number, version date, and a description of the version, are created.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8355" ;
    skos:prefLabel "Define Product Specification"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8356> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8480> ;
    skos:definition "Define Product Specification Features/Properties defines non-configurable features known as characteristics. For example, the title of a movie or the temperature range for a smart thermometer. Note that configurable features/properties are managed by the Product Configuration Management process and that this process uses a generalized set of processes to create the features/properties. This process focuses on associating them with a product specification.<br/><br/>Features/properties can be shared among product specifications and can also be grouped. For example, a group of environmental properties or a group of technical properties.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8356" ;
    skos:prefLabel "Define Product Specification Features/Properties"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8357> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8480> ;
    skos:definition "Define Product Specification Type associates the specification with one or more product lines and/or product categories, collectively called a product specification type. If a product line or category does not exist one is created.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8357" ;
    skos:prefLabel "Define Product Specification Type"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8358> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8480> ;
    skos:definition "Associate Price to Product Specification associates a product specification to suggested pricing for product offerings. These prices can be used to assist in determining the price associated with an offering.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8358" ;
    skos:prefLabel "Associate Price to Product Specification"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8359> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8480> ;
    skos:definition "Define Inter-Product Specification Association defines associations (relationships) between and among product specifications. These associations represent business rules, such as migration, substitution, dependency, or exclusivity between and among the specifications.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8359" ;
    skos:prefLabel "Define Inter-Product Specification Association"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8360> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8480> ;
    skos:definition "Ensure Product Specification Documentation Production ensures that all detailed specifications are produced and appropriately documented. Additionally the processes ensure that the documentation is captured in an appropriate enterprise repository.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8360" ;
    skos:prefLabel "Ensure Product Specification Documentation Production"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8361> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8376> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8361" ;
    skos:prefLabel "Gather Product Offering Ideas"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8362> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8376> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8362" ;
    skos:prefLabel "Identify Product Offering Opportunities and Requirements"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8363> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8376> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8363" ;
    skos:prefLabel "Develop New Product Offering Opportunity Concepts"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8364> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8194> ;
    skos:definition "Plan Product Capacity business activity determine the design and organization of the production capacity management activities needed to meet changing demands for products over a period of time, as well as implement the plan for product capacity needs.<br/>A Product's capacity plan ensures Product Management: <br/><ul><li>aligns capacity planning strategies with both commercial and operational goals,</li></ul><ul><li>ensures that there are sufficient product capacity to support planned and forecasted commercial objectives,</li><li>identifies gaps in capacity allocation early,</li><li>determines product capacity needs according to demand,</li><li>determines constraints and usage patterns over time,</li><li>forecasts future capacity needs,</li><li>and communicates products capacity requirements in time.</li></ul>In the context of capacity planning, consideration is given to all input requirements, conversion processes and outputs when planning product capacity.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8364" ;
    skos:prefLabel "Plan Product Capacity"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8365> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8194> ;
    skos:definition "Align Product Capacity Planning Goals business activity is in charge of correlating the product capacity plans with business demand.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8365" ;
    skos:prefLabel "Align Product Capacity Planning Goals"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8366> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8194> ;
    skos:definition "Establish Product Capacity GAP business activity identifies any disparity between product capacity goals and business objectives.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8366" ;
    skos:prefLabel "Establish Product Capacity GAP"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8371> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8194> ;
    skos:definition "Monitor Product Capacity business activity identifies relevant Product Capacity attributes to track, and tracks all attributes, their use, and changes. <br/>Monitor Product Capacity supports all activities of Product Capacity Management by providing timely visibility for all concerns around Product Capacity.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8371" ;
    skos:prefLabel "Monitor Product Capacity"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8372> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8194> ;
    skos:definition "Report Product Capacity business activity prepare and present detailed accounts on all relevant Product Capacity information, as deemed timely, relevant and reliable for use by business functions.<br/>Different business functions with interest for Product Capacity may require specific reports with specific information. This business activity ensures Report Product Capacity business activity ensures information on Product Capacity is collated, organized and presented in forms useful and reliable to the needs of business functions in a timely manner.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8372" ;
    skos:prefLabel "Report Product Capacity"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8374> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8378> ;
    skos:definition "Develop Detailed Product Offering Performance Specifications develops and documents the detailed product offering-related performance specifications.<br/><br/>Performance specifications include the creation of metrics used to measure the performance of individual offerings as well as on or more Key Quality Indicators (KQIs) grouped into service level specifications used for service level agreements. Note, that while this process creates the association to the KQIs, the Develop Service Level Specification process in Service Development & Retirement manages the lifecycle of service level specifications and the KQIs.<br/><br/>The processes ensure that all detailed specifications are produced and appropriately documented. Additionally the processes ensure that the documentation is captured in an appropriate enterprise repository.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8374" ;
    skos:prefLabel "Develop Detailed Product Offering Performance Specifications"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8375> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8523> ;
    skos:definition "Discover Product Problem business activity is in charge of obtaining evidence of the investigation of the product problem.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8375" ;
    skos:prefLabel "Discover Product Problem Cause"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8380> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8256> ;
    skos:definition "Assess Performance of Existing Product Offering analyzes the performance of an existing product offering to identify inadequacies and required improvements. The process uses information from customers and from operational activities to identify required improvements.<br/><br/>Required improvements may involve those to a product specification upon which the offering is based. In this case the improvements are communicated to the Develop Detailed Product Specification process.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8380" ;
    skos:prefLabel "Assess Performance of Existing Product Offering"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8383> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8256> ;
    skos:definition "Manage Product Offering Development ensures the co-coordinated delivery in line with the approved business case of all required product offering capabilities for that business case across the enterprise. These processes may use project management disciplines when a project is created to develop a new product offering to deliver the necessary capabilities, including process development, specific systems & network infrastructure developments, specific channel developments, specific operational procedures, and so forth. required to support the new product offering. <br/>Note that delivery of a product offering within the context of existing commercial agreements is managed through the Party Offering Development & Retirement process. If new partners are required, the Party Agreement Management process is used to deliver the necessary commercial agreements.<br/>Note that the management of major new or enhanced infrastructure development to support Product & Offer Development is managed within the Product & Offer Capability Delivery process<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8383" ;
    skos:prefLabel "Manage Product Offering Development"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8384> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8446> ;
    skos:definition "Organize Product Catalog Content Entry business activity handles Catalog Content organization according to the Product Catalog model.<br/>Organize Catalog Content Entry business activities can include ordering, arranging, sorting, assembling, and grouping.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8384" ;
    skos:prefLabel "Organize Product Catalog Content Entry"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8385> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8446> ;
    skos:definition "Classify Product Catalog Content Entry business activity specifically handles Catalog Content organization according to business classification characteristics for the Product Catalog.<br/>Classify Product Catalog Content Entry is specific to shared qualities or characteristics defined by the organization.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8385" ;
    skos:prefLabel "Classify Product Catalog Content Entry"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8386> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8530> ;
    skos:definition "Product Specification Property enumerate all the product specification attributes and their units, and documents requirements that provides product teams the information they need to build out or enhance features or functionality of products.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8386" ;
    skos:prefLabel "Describe Product Specifications Property"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8387> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8530> ;
    skos:definition "Align Product Specifications business activity handle the alignment, relationships and linkages of product specification to functional and non-functional requirement.<br/>The alignment of product specifications can be to other products as well as realization of the specific services and resource according to business objectives (e.g. cost, other accounting and non-accounting requirements etc.).<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8387" ;
    skos:prefLabel "Align Product Specifications"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8388> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8197> ;
    skos:definition "Process responsible for calculating the value of a product usage or a set of product usages, before, during or after the rendering of the service, based on parameters of the request (type, quantity, etc.), parameters of the customer/subscriber (tariffs, price plans, accumulated usage, contracts, etc.) and other parameters (time-of-day, taxes, etc.). The same request maybe rated differently for different subscribers based on their purchased offers or agreements.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8388" ;
    skos:prefLabel "Perform Rating"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8389> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8197> ;
    skos:definition "This process is responsible for accumulating contributing items, which can be quantities, values (monetary or other) or both. Aggregation can occur over time or can be initiated to gather a “snapshot” of the items at a point in time.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8389" ;
    skos:prefLabel "Aggregate Items For Rate Assignment"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8390> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8197> ;
    skos:definition "Customer hierarchies are commonly used for corporate customers, family plans or other type of affinity groups. This process manages the assignment relationships among subscribers, e.g. sharing, inheriting or restricting balances, price plans and discounts. Thereby assuring that a charge is added to or subtracted from the correct account balance.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8390" ;
    skos:prefLabel "Manage Customer Assignment Hierarchy"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8391> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8197> ;
    skos:definition "The activity of Provide Advice of Rate (aka Advice of Charge) is responsible for providing advice on rates, in real-time or offline, an estimate or value of the rate for a specific usage request. The advice is usually based upon performing a full rating process for the request.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8391" ;
    skos:prefLabel "Provide Advice of Rate"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8392> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8197> ;
    skos:definition "This process applies discounts to product prices at an individual product level. A discount may be expressed as a monetary amount or percentage, and modifies a price for a product. When a discount is expressed as a percentage, the discounting process determines the discount calculated in relation to the price for the product.<br/> <br/>The discount may be displayed as a separate entry on the bill or may be combined with the rate for the product to only show as one entry.<br/> <br/>Discounts may be a one-time event or may have some duration (days, months, life of product, etc.). Discounts may apply to a specific customer or be generally available based on selection of products (for example - bundles). Discounting structures may involve tiers, tapers, or thresholds.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8392" ;
    skos:prefLabel "Apply Rate Level Discounts"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8395> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8289> ;
    skos:definition "Manage Product Anomaly Case History business activity records all past information on Product Anomaly events, Product Anomaly Management activities and data underlying, and representing Product Anomaly cases.<br/>Manage Product Anomaly Case History includes the maintenance of past and present records, all artifacts, knowledge-base (e.g. the specifications, profiles, exception patterns, action patterns etc.) and versioned information.<br/>This business activity supports the organization to maintain skills and learning repository to identify and predict Anomalous Exception patterns and mitigatory actions.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8395" ;
    skos:prefLabel "Manage Product Anomaly Case History"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8396> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8527> ;
    skos:definition "Plan & Schedule Product Catalog Release business activity is used to handle the release plan for the Product Catalog.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8396" ;
    skos:prefLabel "Plan & Schedule Product Catalog Release"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8397> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8527> ;
    skos:definition "Control Product Catalog Release business activity is used to support the various catalog release tasks.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8397" ;
    skos:prefLabel "Control Product Catalog Release"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8398> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8527> ;
    skos:definition "Test Product Catalog business activity is used to establish the quality, reliability and performance requirement of the catalog according to the Product management needs.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8398" ;
    skos:prefLabel "Test Product Catalog"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8399> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8367> ;
    skos:definition "Define Product Capacity Requirement business activity establishes, measures, and adjusts conditions that impact on planning product capacity for business expectations.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8399" ;
    skos:prefLabel "Define Product Capacity Requirement"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8400> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8367> ;
    skos:definition "Establish Product Capacity Availability Timing Requirement business activity identify scheduling needs for product capacity changes.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8400" ;
    skos:prefLabel "Establish Product Capacity Availability Timing Requirement"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8401> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8499> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8401" ;
    skos:prefLabel "Add Product Usage Data"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8402> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8499> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8402" ;
    skos:prefLabel "Assign Product Usage Price"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8403> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8369> ;
    skos:definition "Identify Product Capacity Optimization Need business activity establish the best, or most effective, use of product capacity.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8403" ;
    skos:prefLabel "Identify Product Capacity Optimization Need"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8404> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8369> ;
    skos:definition "Assess Available Product Capacity business activity evaluates unused product capacity in relation to product capacity plans, and product utilization trends.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8404" ;
    skos:prefLabel "Assess Available Product Capacity"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8406> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8369> ;
    skos:definition "Perform Product Capacity and Capacity Demand Trend Analysis business activity analysis trends between available product capacity and product capacity demand according to business and usage.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8406" ;
    skos:prefLabel "Perform Product Capacity and Capacity Demand Trend Analysis"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8407> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8266> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8407" ;
    skos:prefLabel "Issue Pricing Notification"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8408> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8266> ;
    skos:definition "Manage Pricing Notification Involved Party keeps track of individuals and organizations playing various roles who are involved in some way with product offering prices. Included is the type of involvement, such as those responsible for the approval process or those who should be informed about any pricing related activities.<br/><br/>This process communicates these, via a process flow, to the applicable Process Management & Support process in the Enterprise domain which maintains the association between parties playing a variety of roles and the processes in which they are involved.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8408" ;
    skos:prefLabel "Manage Pricing Notification Involved Party"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8409> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8381> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8409" ;
    skos:prefLabel "Identify Unviable Product Offering"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8410> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8381> ;
    skos:definition "Identify Product Offering Exit Impact identifies customers impacted by any exit, and develop customer specific or market segment exit or migration strategies.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8410" ;
    skos:prefLabel "Identify Product Offering Exit Impact"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8411> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8381> ;
    skos:definition "Develop Product Offering Exit Strategies develops infrastructure transition and/or replacement strategies, and manage the operational aspects of the exit process. A business proposal identifying the competitive threats, risks and costs may be required as part of developing the exit strategy. It includes any interaction with cross-enterprise co-ordination and management functions to ensure that the needs of all stakeholders are identified and managed.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8411" ;
    skos:prefLabel "Develop Product Offering Exit Strategies"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8412> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8381> ;
    skos:definition "Exit Product Offering from Market removes a product specification, either by deleting it or indicating it is no longer valid. Notifications are sent to the Product Specification Development & Retirement process so it can determine if the related specifications should also be removed. Additionally a notification may be sent to the Party Offering Development & Retirement process so that it can determine if any on-boarded product offerings should also be removed.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8412" ;
    skos:prefLabel "Exit Product Offering from Market"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8413> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8261> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8413" ;
    skos:prefLabel "Define Product Offering Promotion Scope"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8414> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8261> ;
    skos:definition "Ensure that there is capability (for example, information, materials, systems and resources) so that the product promotion can begin and managed. Monitor planned promotions and redistribute existing capability or enable new capability (people, facilities, infrastructure).<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8414" ;
    skos:prefLabel "Ensure Product Offering Promotion Capability"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8418> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8261> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8418" ;
    skos:prefLabel "Modify Product Offering Promotion"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8419> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8261> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8419" ;
    skos:prefLabel "End Product Offering Promotion"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8420> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8261> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8420" ;
    skos:prefLabel "Undertake Product Offering Promotion Trend Analysis"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8421> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8243> ;
    skos:definition "Gather Product information processes focus on establishment and Management of relationships with external providers of product information, and management of internal resources used for providing product information.<br/><br/>Information may also be gathered by interacting with processes that perform competitive analysis, market research, and market analysis.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8421" ;
    skos:prefLabel "Gather Product Information"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8422> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8243> ;
    skos:definition "Analyze Product information processes focus on research of information relating to product ideas and opportunities and identify product opportunities based on analysis of the external and internal information sources. These processes are responsible for analysis to identify new product offerings as well as review of existing product offerings.<br/><br/>If new resource and/or service infrastructure is needed then this process interacts with the processes that develop resource strategies and/or service strategies to insure new product offerings can be developed. Similarly interaction with market/sales strategy processes may result if new sales channels or market segments are needed.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8422" ;
    skos:prefLabel "Analyze Product Information"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8429> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8200> ;
    skos:definition "Manage Catalog Design business activity cover the design of the Catalog in accordance to the Catalog Management Lifecycle.<br/>Manage Catalog Design business activity will leverage Catalog Specification requirement for all information (features, attributes etc.) to be managed by the catalog in order to enable support the Catalog Lifecycle Management.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8429" ;
    skos:prefLabel "Manage Product Catalog Design"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8430> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8200> ;
    skos:definition "Manage Catalog Design business activity covers the design of the Catalog in accordance to the Catalog Management Lifecycle.<br/>This business activity leverages input from the Catalog Design to construct the product/service/resource Catalog in order to meet the business operations goals.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8430" ;
    skos:prefLabel "Manage Product Catalog Build"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8431> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8200> ;
    skos:definition "Manage Catalog Build business activity establishes, manages and administers the governing of the catalog for operations readiness and operations.<br/>This business activity leverages support of the Enterprise governance processes for product/service/resource catalog lifecycle management.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8431" ;
    skos:prefLabel "Manage Product Catalog Policy"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8432> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8423> ;
    skos:definition "These processes define the detailed infrastructure requirements to support the product portfolio and individual product plans. Product infrastructure requirements to support new product initiatives in the PLM vertical are captured in this process, as well as any product infrastructure requirements needed to support the specific offers being made to customers through the sales channels. These processes also identify the service infrastructure capabilities required to deliver the product infrastructure.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8432" ;
    skos:prefLabel "Capture Product Infrastructure Requirements"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8433> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8423> ;
    skos:definition "These processes obtain agreement to the detailed infrastructure requirements to support the product portfolio and individual product plans. The processes include any interaction with cross-enterprise co-ordination and management functions to ensure that the requirements capture the needs of all stakeholders.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8433" ;
    skos:prefLabel "Agree Product Infrastructure Requirements"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8434> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8423> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8434" ;
    skos:prefLabel "Report Product Infrastructure Requirements"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8435> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8464> ;
    skos:definition "Develop Algorithmic Product Offering Pricing Matrix Specification Definition develops (creates, modifies, and removes) the base product offering pricing matrix specification and associates it to the possible product offering(s) to which it applies.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8435" ;
    skos:prefLabel "Develop Algorithmic Product Offering Pricing Matrix Specification Definition"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8436> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8464> ;
    skos:definition "Develop Algorithmic Product Offering Pricing Matrix Specification Structure defines (creates, modifies, and removes) the structure of a product offering pricing matrix including its row(s)/columns and other dimensions of a multi-dimensional matrix as well as their sequence.<br/><br/>The rows and columns represent the criteria evaluated to determine the charge/allowance. They represent such things as types of product features/properties, types of product offering prices, algorithmic specific criteria such as type of customer, and so forth.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8436" ;
    skos:prefLabel "Develop Algorithmic Product Offering Pricing Matrix Specification Structure"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8437> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8211> ;
    skos:definition "Validate Product Problem Solution business activity is in charge of assuring the answer or corrective measures applied to resolve or mediate a product problem are accepted.<br/><br/>This business activity includes tasks that test the product problem solution, communicate with parties impacted by a product problem and liaising with activities that implement and report product problem solution.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8437" ;
    skos:prefLabel "Validate Product Problem Solution"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8439> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8258> ;
    skos:definition "Develop Product Offering Catalog Specification defines, updates, and removes the specification for a product catalog. It uses the generalized Develop Catalog Specification process to develop a specific type of catalog specification, in this case a product offering catalog specification.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8439" ;
    skos:prefLabel "Develop Product Offering Catalog Specification"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8440> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8258> ;
    skos:definition "Exchange Product Offering Catalog exchanges a catalog with another party engaged in the value fabric. The exchange may be sending a product offering catalog to another party or receiving one from another party.<br/><br/>It uses the generalized Exchange Catalog process to exchange a catalog, in this case a product offering catalog.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8440" ;
    skos:prefLabel "Exchange Product Offering Catalog"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8443> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8191> ;
    skos:definition "Audit Product Configuration business activities examine and verify product configurations for compliance to assurance needs.<br/>Audit Product Configuration perform audits that compare the \"as built\" and \"as planned\" versions of configuration items, investigate discrepancies, and take action on the results. Audit Product Configuration supports Enterprise Audit Management, Enterprise Risk Management and Enterprise Governance.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8443" ;
    skos:prefLabel "Audit Product Configuration"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8444> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8546> ;
    skos:definition "Maintain Product Catalog Content Version business activity handles tracking and controlling changes for Product catalog entries.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8444" ;
    skos:prefLabel "Maintain Product Catalog Content Version"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8445> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8546> ;
    skos:definition "Maintain Product Catalog Content Relationship business activity handles associating Product catalog entries.<br/>Catalog Content Relationship for Product catalog entries can be internal and external to the Product, Service or Resource domains.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8445" ;
    skos:prefLabel "Maintain Product Catalog Content Relationship"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8447> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8415> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8447" ;
    skos:prefLabel "Create Product Offering Promotion"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8448> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8415> ;
    skos:definition "Select Product Offering Promotion Delivery Channels selects the appropriate channel or channels to support delivery of a product offering promotion. A particular promotion may require selection of one or several delivery channels.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8448" ;
    skos:prefLabel "Select Product Offering Promotion Delivery Channels"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8449> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8415> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8449" ;
    skos:prefLabel "Obtain Product Offering Promotion Agreement"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8454> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8502> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8454" ;
    skos:prefLabel "Generate Product Usage Report"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8455> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8502> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8455" ;
    skos:prefLabel "Investigate Product Usage Related Problem"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8456> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8502> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8456" ;
    skos:prefLabel "Support Product Usage Related Process"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8457> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8250> ;
    skos:definition "Determine Product Performance Data Source business activity source and identify all relevant data to support product performance management. Determine Product Performance assures the validity, reliability and relevance of data in the computation and tracking of product performance over a product's lifecycle.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8457" ;
    skos:prefLabel "Determine Product Performance Data Source"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8458> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8250> ;
    skos:definition "Collect Product Performance Data business activity gather data according to prescribed data sources. Product Performance Data may includes all data that impact on the products meeting established performance objectives, including QoS, SLAs and any other form of enumerated qualitative information.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8458" ;
    skos:prefLabel "Collect Product Performance Data"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8459> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8250> ;
    skos:definition "Track Product Performance Measure business activity trace product performance measures to identify trends. Track Product Performance supports tracking and monitoring of products from customer view points, based on defined measures such as QoS or SLAs, and as well from business view point such as costs etc.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8459" ;
    skos:prefLabel "Track Product Performance Measures"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8460> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8368> ;
    skos:definition "Specify Product Capacity Course of Action business activity identifies clearly and definitely sequence of activities that must be followed to meet 'product capacity plan' expectations.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8460" ;
    skos:prefLabel "Specify Product Capacity Course of Action"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8461> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8368> ;
    skos:definition "Specify Required Product Capacity business activity is in charge of implementing product capacity plans by identifying clearly and definitely product capacity expectations.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8461" ;
    skos:prefLabel "Specify Required Product Capacity"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8462> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8465> ;
    skos:definition "Develop Algorithmic Product Offering Pricing Matrix Definition defines the product offering pricing matrix based on a matrix specification and its association(s) to the specific product offering(s) to which it applies.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8462" ;
    skos:prefLabel "Develop Algorithmic Product Offering Pricing Matrix Definition"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8463> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8465> ;
    skos:definition "Develop Algorithmic Product Offering Pricing Matrix Cells defines the content of the product offering pricing matrix cells. <br/><br/>The cells represent the values for the product features/properties, such as excess data usage rates, product offering prices that will be charged/allowed, and values for algorithmic evaluation such as student, normal, or very important person (VIP) types of customers.<br/><br/>Note that features/properties are also known as characteristic specification values.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8463" ;
    skos:prefLabel "Develop Algorithmic Product Offering Pricing Matrix Cells"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8466> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8259> ;
    skos:definition "Define Product Offering Agreement Terms/Conditions defines product offering terms/conditions, such as financial terms (which includes such things as acceptable methods of payment), shipment terms, and service term (which includes early termination fees). <br/><br/>The terms/conditions are accepted by a party when the offering is acquired.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8466" ;
    skos:prefLabel "Define Product Offering Agreement Terms/Conditions"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8467> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8259> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8467" ;
    skos:prefLabel "Associate Product Offering and Price with Product Offering Agreement"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8468> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8288> ;
    skos:definition "Identify Product Exception Mitigation business activity helps to map product’s anomalous exceptions with actions that will reduce impact to business.<br/>Identifying product exception and their mitigatory action involves tasks that may leverage established business policies and constraints, and/or be based on knowledge and skills related to context.<br/>This business activity helps to incorporate the right treatment based on the importance, impact or risk factors involved in a products operation. Any treatment of this nature can be static, based on pre-defined business rules, or dynamic based on skills and knowledge derived from context.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8468" ;
    skos:prefLabel "Identify Product Exception Mitigation"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8469> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8288> ;
    skos:definition "Coordinate Product Exception Mitigation business activity is in charge of managing the different activities of an exception mitigation plan all together to successfully realize a mitigation plan.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8469" ;
    skos:prefLabel "Coordinate Product Exception Mitigation"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8470> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8288> ;
    skos:definition "Initiate Product Exception Mitigation business activity is in charge of starting the correct activities that mitigate product anomaly exceptions, cognizant of business requirement and goals.<br/>Initiate Product Exception Mitigation actions include recommendations for course of actions, fostering dynamic execution of actions, and/or scheduling actions based on predetermined business conditions and policies.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8470" ;
    skos:prefLabel "Initiate Product Exception Mitigation"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8471> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8288> ;
    skos:definition "Monitor Product Exception Mitigation business activity is in charge of observing, checking and keeping a continuous records of mitigatory actions that support Product Anomaly Management.<br/>Monitor Product Exception Mitigation covers the action and data that are involved (including collection and analysis on predefined set of information – e.g. KPIs etc.) in Product Anomaly Management business activities, tasks and workflows.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8471" ;
    skos:prefLabel "Monitor Product Exception Mitigation"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8472> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8288> ;
    skos:definition "Report Product Exception Mitigation business activity is in charge of providing an account (documented or otherwise) of mitigatory actions taken to lessen or reduce the impact of a product anomaly.<br/>Reporting on Product Exception Mitigation may follow well-defined business and operations criteria, or predefined set of metrics (KPIs etc.) that are underlying to mitigate anomaly business activity.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8472" ;
    skos:prefLabel "Report Product Exception Mitigation"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8473> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8190> ;
    skos:definition "The purpose of the Support Product Configuration Management processes is to ensure that there is capability (for example, information, materials, systems and resource) so that the Product Configuration Management processes can operate effectively when a product needs to be configured by specifying how the product operates or functions in terms of a product’s configurable parameters, collectively called characteristics, and related configurations of products, services, and resources that are part of its overall configuration.<br/>Examples are information on how to handle unusual configuration requests based on temporary situations, systems needed to accept and track product configurations, requests for the provisioning of additional parameters or resources where it has been identified that current available parameters or resources will impact on effective product configuration.<br/>These processes are responsible for implementing generic and specific changes to product configuration capabilities. This support could be in updating configuration scripts, batch procedures, etc. <br/>These processes undertake trend analysis on product configurations, e.g. type, frequency, duration, outcome.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8473" ;
    skos:prefLabel "Support Product Configuration Management"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8474> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8190> ;
    skos:definition "The purpose of the Support Product Offering Purchasing processes is to ensure that there is capability (for example, information, materials, systems and resources) so that the Product Offering Purchasing processes can operate effectively when there is an inbound/outbound purchase of one or more product offerings, changes an offering being purchased, or reviewing an entire purchase.<br/>Examples are information on how to handle product purchases including shopping purchases in the form of in-store, shopping cart purchases, window shopping (a form of browsing) and purchases in the form of product (offering) orders that result in a product being delivered to a party or from a party. <br/>These processes are responsible for implementing generic and specific changes to product offering purchasing capabilities. This support could be in updating scripts, batch procedures, etc. <br/>These processes undertake trend analysis on product offerings purchasing, e.g. type, frequency, duration, outcome.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8474" ;
    skos:prefLabel "Support Product Offering Purchasing"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8475> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8190> ;
    skos:definition "The purpose of the Enable Product Performance Management processes is to ensure that there is capability (for example, information, materials, systems and resources) so that the product performance management processes can operate effectively to manage, track, monitor, analyze, improve and report on the performance of specific products. <br/>Examples are information on how to handle product performance management including performance analysis, statistics, trends, etc.<br/>These processes are responsible for implementing generic and specific changes to product performance management capabilities. This support could be in updating scripts, batch procedures, surveys, etc. <br/>These processes undertake trend analysis on product performance management, e.g. product performance categories, performance trends, overall QoS delivered, outcomes, etc.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8475" ;
    skos:prefLabel "Enable Product Performance Management"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8476> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8190> ;
    skos:definition "The purpose of the Support Product Rating & Rate Assignment processes is to make sure that there is capability (for example, information, systems and resources) so that the Charging processes can operate effectively. Examples are information needed to calculate the value of the product e.g. tariffs, price plans, accumulated usage, contracts, etc., information needed to apply the discounts to product prices at an individual product level, information needed to accumulate items for rating and information on how to manage the assignment relationships with Billing Account. <br/>These processes undertake trend analysis on charging.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8476" ;
    skos:prefLabel "Support Product Rating & Rate Assignment"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8477> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8190> ;
    skos:definition "The purpose of the Support Product Usage Mgt process is to make sure that there is capability (for example, information, systems and resources) so that the Product Usage Mgt process can operate effectively. For example the Product Usage records (aka billing events) to process, the information needed to enrich the Product Usages (e.g. customer, product, or other reference data, price), the schema to reformat the Product Usage records.<br/>These processes undertake trend analysis on billing events management.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8477" ;
    skos:prefLabel "Support Product Usage Mgt"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8478> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8190> ;
    skos:definition "The purpose of the Support Product Balance Management process is to make sure that there is capability (for example, information, systems and resources) so that the Support Product Balance Management process can operate effectively. For example policy defined to mange balance (e.g. minimum allowable balance limit, balance expiration dates), account information needed to operating the balance.<br/>These processes undertake trend analysis on balance management.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8478" ;
    skos:prefLabel "Support Product Balance Management"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8479> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8190> ;
    skos:definition "Manage Product Test processes manage the end-to-end execution of a test or test scenario for products not specific to a customer. Tests can be manual or automated.<br/>Product Test Management processes rely on Service Test Management and Resource Test Management processes due to dependencies between product tests, service tests and resource tests.<br/>Product Test Management includes:<br/>- Identification of product tests needed according to fulfilment and assurance issues<br/>- triggering of product tests in manual or automated mode<br/>- Execution of product tests<br/>- Verification of test authorization (role and context) and quota management<br/>- Identification and prioritization of tests <br/>- Setting up the test context and configuration<br/>- Triggering appropriate service & resource Tests<br/>- Tests can be on-demand or planned according to specific needs<br/>- Enrichment with service and resource tests results based on applicable product test rules <br/>- Reporting of test results<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8479" ;
    skos:prefLabel "Manage Product Test"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8481> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8325> ;
    skos:definition "Develop Detailed Product Technical Specifications develops and documents the detailed product-related technical specifications. It associates the specification with the service and resource specifications that represent the realization of the product specification. It ensures that all detailed specifications are produced and appropriately documented. And it ensures that the documentation is captured in an appropriate enterprise repository.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8481" ;
    skos:prefLabel "Develop Detailed Product Technical Specifications"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8482> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8325> ;
    skos:definition "These processes develop and document the detailed product specification-related performance specifications.<br/><br/>Performance specifications include the creation of metrics used to measure the performance of individual specifications as well as on or more Key Quality Indicators (KQIs) grouped into service level specifications used for service level agreements. Note, that while this process creates the association to the KQIs, the Develop Service Level Specification process in Service Development & Retirement manages the lifecycle of service level specifications and the KQIs.<br/><br/>The processes ensure that all detailed specifications are produced and appropriately documented. Additionally the processes ensure that the documentation is captured in an appropriate enterprise repository.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8482" ;
    skos:prefLabel "Develop Detailed Product Performance Specifications"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8483> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8325> ;
    skos:definition "Develop Detailed Product Operational Specifications develops and documents the detailed product-related operational specifications. These processes develop and document the specific operational requirements and support activities, along with any product specific data required for the service and resource infrastructure. The processes ensure that all detailed specifications are produced and appropriately documented. Additionally the processes ensure that the documentation is captured in an appropriate enterprise repository.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8483" ;
    skos:prefLabel "Develop Detailed Product Operational Specifications"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8484> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8325> ;
    skos:definition "Develop Detailed Product Customer Manuals develops and documents the detailed customer manuals. The processes ensure that all detailed specifications are produced and appropriately documented. Additionally the processes ensure that the documentation is captured in an appropriate enterprise repository.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8484" ;
    skos:prefLabel "Develop Detailed Product Customer Manuals"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8486> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8287> ;
    skos:definition "Triage Product Exception business activity is in charge of identifying and assigning the degrees of urgency, and the order of treatment of products’ anomalous exceptions.<br/>Triage Product Exceptions sub activities may include prioritizing exceptions and underlying product anomaly events while examining causes that enable apply an initial set of mediatory actions.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8486" ;
    skos:prefLabel "Triage Product Exception"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8487> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8287> ;
    skos:definition "Plan and Select Product Anomaly Assessment Criteria business activity define the course of action to assess a product anomaly, along with organizing the product’s anomaly assessment criteria in order to best facilitate detection and mitigation of anomalies.<br/>The 'Plan and Select Assessment Criteria' process helps the organization to optimize the approaches to assess product anomaly criteria in order to continually avoid impact of false positives and false negatives in the detection of product anomalies.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8487" ;
    skos:prefLabel "Plan and Select Product Anomaly Assessment Criteria"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8488> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8287> ;
    skos:definition "Analyze Product Anomalies to Learning business activity establish actions to discover and correlate anomalous behavior to 'learned normal' or 'expected behavior'.<br/>Analyze Product Anomalies to Learning sub activities help to enrich the organization's Anomaly Detection activities altogether, which can result in a reduction in the time to detect, triage and treat product anomalies.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8488" ;
    skos:prefLabel "Analyze Product Anomalies to Learning"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8489> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8287> ;
    skos:definition "Classify Product Anomaly business activity establish ways to organize product anomalies into established categories according to business priorities and product management objectives.<br/>Classify Product Anomaly includes establishing robust classification models that help to triage anomalies, determine communication needs, determine and measure impact, and report on product anomalies.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8489" ;
    skos:prefLabel "Classify Product Anomaly"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8490> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8287> ;
    skos:definition "Manage Product Anomaly Assessment Feedback Reporting business activity is in charge of establishing and handling the activities that prepare and report the feedback based of Product Anomaly Assessment activity.<br/>Manage Product Anomaly Assessment Feedback business activity covers tasks that prepare and report feedback of an Anomaly Assessment activity. This business activity is also helpful in supporting the optimization of the Anomaly Detection business activity, such as fine-tuning know-how for product anomaly detection.<br/>Reports generated from this business activity can be utilized for Product Anomaly Mitigation and can help to select the consequent actions required to mitigate a product anomaly.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8490" ;
    skos:prefLabel "Manage Product Anomaly Assessment Feedback Reporting"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8493> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8204> ;
    skos:definition "Monitor Product Anomaly Management Closed Loop business activity provides the capability to observe Product Anomaly Management Closed Loops.<br/>This business activity helps to scan; watch; monitor; gain awareness of Product Anomaly Management activities that close the loop in an Product Anomaly Management Lifecycle(s).<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8493" ;
    skos:prefLabel "Monitor Product Anomaly Management Closed Loop"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8494> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8204> ;
    skos:definition "Report Product Anomaly Management Closed Loop business activity documents information organized to deliver an account of any, and all Product Anomaly Closed Loops.<br/>Anomaly Closed Loops may fall into either or across any of the four stages in any of the overarching Closed Loop pattern - Observe, Orient, Decide and Act - or other variations.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8494" ;
    skos:prefLabel "Report Product Anomaly Management Closed Loop"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8495> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8204> ;
    skos:definition "Manage Product Anomaly Intelligence business activity is in charge of acquiring and applying new learning, knowledge and skills to Product Anomaly Management.<br/>This business activity supports improving, optimizing, or evolving Product Anomaly Management activities. Manage Product Anomaly Intelligence helps to incorporate new knowledge and skills into Product Anomaly Management processes. This is as well to enable improvement and optimization of Anomaly Management in a continuum.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8495" ;
    skos:prefLabel "Manage Product Anomaly Intelligence"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8496> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8204> ;
    skos:definition "Manage Product Anomaly Optimization business activity is in charge of actions that make the best and most effective use of Product Anomaly Management activities to improve Product Anomaly Management.<br/>Manage Product Anomaly Optimization business activity can manage the business logic and business rules associated with Product Anomaly Detection, Product Anomaly Assessment, Product Anomaly Forecasting and Prediction, Product Anomaly Mitigation, as well as underlying Product Knowledge Management.<br/>This business activity also includes fine-tuning of business logic, operations logic, business and operations rules that improve efficiency of Anomaly Management as a whole.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8496" ;
    skos:prefLabel "Manage Product Anomaly Optimization"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8497> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8491> ;
    skos:definition "Define Product Anomaly Closed Loop business activity state and describe the Product Anomaly Closed Loops along with associated information that lead to identifying, detecting or predicting a Product Anomaly.<br/>This business activity supports Anomaly definition process and the Closed Loops associated, including all associated inputs that reasonably affect the management of an Anomaly Lifecycle. This activity also ensures that the organization understands, and has well-defined operational workflows underpinning Anomaly Management.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8497" ;
    skos:prefLabel "Define Product Anomaly Closed Loop"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8498> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8491> ;
    skos:definition "Establish Product Anomaly Closed Loop Information Sources business activity identifies all information sources and the requisite data that must be managed to support Product Anomaly Management Closed Loops.<br/>Establish Product Anomaly Closed Loop Information Sources help to identify the information (not limited to business and operations rules), business logic, levels of classification (by importance, by period etc.), impact and urgency etc. that can help detect Product Anomaly. This process supports Product Anomaly Management during day-to-day operations.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8498" ;
    skos:prefLabel "Establish Product Anomaly Closed Loop Information Sources"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8503> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8424> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8503" ;
    skos:prefLabel "Capture Product Capacity Shortfalls"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8504> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8424> ;
    skos:definition "These processes identify specific or imminent product performance shortfalls. These processes take information available from the Customer Relationship Management processes to establish detailed views of anticipated product performance issues.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8504" ;
    skos:prefLabel "Capture Product Performance Shortfalls"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8505> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8424> ;
    skos:definition "These processes identify specific or imminent product operational support shortfalls. These processes take information available from the Customer Relationship Management processes to establish detailed views of anticipated product operational support issues.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8505" ;
    skos:prefLabel "Capture Product Operational Support Shortfalls"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8506> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8426> ;
    skos:definition "These processes ensure the co-coordinated delivery in line with the approved business case of all required product infrastructure capabilities for that business case across the enterprise. It is predominantly a program/project management function, with the detailed management of individual infrastructure component delivery managed through separate processes.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8506" ;
    skos:prefLabel "Co-ordinate Product Capability Delivery"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8507> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8426> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8507" ;
    skos:prefLabel "Track Product Capability Business Case Costs"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8508> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8426> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8508" ;
    skos:prefLabel "Ensure Product Capability Benefits & Operational Costs"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8509> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8264> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8509" ;
    skos:prefLabel "Suggest Product Offering Price Modification"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8510> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8264> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8510" ;
    skos:prefLabel "Make Product Offering Price Modification"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8511> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8453> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8511" ;
    skos:prefLabel "Develop Simple Feature/Property Product Offering Pricing"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8512> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8453> ;
    skos:definition "Develop Complex Feature/Property Product Offering Pricing defines (creates, modifies, removes) a group of features/properties upon which series of operations is performed to determine the price. The series of operations defines an expression that when evaluated determines the price for the product offering. A feature/property is also known as a characteristic.<br/><br/>Single members of the group can be modified and/or removed as well as the entire group upon which the price is based.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8512" ;
    skos:prefLabel "Develop Complex Feature/Property Product Offering Pricing"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8514> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8441> ;
    skos:definition "Control Product Configuration business activity check, determine and direct product configuration change and use.<br/>Control Product Configuration helps users (customers, business partners etc.) to manage preparation, justification, evaluation, coordination, disposition, and implementation of proposed changes.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8514" ;
    skos:prefLabel "Control Product Configuration"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8517> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8441> ;
    skos:definition "Monitor Product Configuration business activity handles monitoring product configurations, changes and/or use.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8517" ;
    skos:prefLabel "Monitor Product Configuration"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8518> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8441> ;
    skos:definition "Report Product Configuration business activity handles reporting and status accounting of product configuration changes and/or use.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8518" ;
    skos:prefLabel "Report Product Configuration"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8519> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8246> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8519" ;
    skos:prefLabel "Identify Stakeholders to Product Business plans"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8520> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8246> ;
    skos:definition "Gain Product Business Plans Stakeholders Approval negotiates and gains stakeholders' approval for product business plans. <br/><br/>Typical questions that may be asked are:<br/><ul><li>Is it necessary to introduce a new product?</li><li>When will the product break even?</li></ul>If the answer to the first question is no, then the plan may be rejected. If the break even point is too far in the future the plan may be rejected or the plan may have to be revised so that the break even point is reached sooner.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8520" ;
    skos:prefLabel "Gain Product Business Plans Stakeholders Approval"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8521> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8246> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8521" ;
    skos:prefLabel "Gain Enterprise Commitment to Product Business plans"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8522> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8565> ;
    skos:definition "Investigate Product Problem business activity is in charge of observing and identifying the cause of a product problem. <br/><br/>Investigate Product Problem includes tasks that study and examine product problems and associated information in order to discover product problem cause.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8522" ;
    skos:prefLabel "Investigate Product Problem"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8524> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8224> ;
    skos:definition "Provide New Product Specification Business Proposal Notification issues notifications to parties involved in the approval of it or to other parties involved in some way with the approval process. The parties may be those who approve the proposal or those that are informed about it, and so forth.<br/><br/>It also identifies involved parties to whom notifications should be sent. These parties are specified by the Manage New Product Specification Notification Involved Party process.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8524" ;
    skos:prefLabel "Provide New Product Specification Business Proposal Notification"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8525> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8224> ;
    skos:definition "Manage New Product Specification Notification Involved Party keeps track of individuals and organizations playing various roles who are involved in some way with the approval of a new product specification business proposal. Included is the type of involvement, such as those responsible for the approval process or those who should be informed about the new product specification business proposal.<br/><br/>This process communicates these, via a process flow, to the applicable Process Management & Support process in the Enterprise domain which maintains the association between parties playing a variety of roles and the processes in which they are involved.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8525" ;
    skos:prefLabel "Manage New Product Specification Involved Party"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8526> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8201> ;
    skos:definition "Deploy Product Catalog business activity manage the availability and use of the Product catalog in operations.<br/>Deploy Product Catalog business activity includes identifying stakeholders, creating catalog category hierarchies, catalog integration, and catalog federation for any scenario, such as with business partners and between business functions.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8526" ;
    skos:prefLabel "Deploy Product Catalog"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8528> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8544> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8528" ;
    skos:prefLabel "Issue New Product Offering Business Proposal Notification"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8529> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8544> ;
    skos:definition "Manage New Product Offering Notification Involved Party keeps track of individuals and organizations playing various roles who are involved in some way with the approval of a new product offering business proposal. Included is the type of involvement, such as those responsible for the approval process or those who should be informed about the new product offering business proposal.<br/><br/>This process communicates these, via a process flow, to the applicable Process Management & Support process in the Enterprise domain which maintains the association between parties playing a variety of roles and the processes in which they are involved.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8529" ;
    skos:prefLabel "Manage New Product Offering Involved Party"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8531> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8203> ;
    skos:definition "Model Product Specification business activity is in charge of determining independent product specifications variables to include and exclude from asserting the product's specification relationships and connections.<br/><br/>The need for modelling product specifications often begins when a product manager seeks to define the relationship between independent product variables and the dependent product variable.<br/>This business activity is used by organizations to establish and manage the collection of standardized, pre-documented product specifications and their dependencies to guide Lifecycle Management and Operations.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8531" ;
    skos:prefLabel "Model Product Specifications"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8532> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8203> ;
    skos:definition "Analyze Product Specifications business activity research, assess and evaluate performance criteria and factors to develop, master, control and update in products specifications, according to ongoing requirements.<br/>This business activity can include multiple analyzes of product specifications, including standard analysis (based on empirical research) or custom analysis (based on other standards). Analysis of Service Specification include testing product specifications, and the ability to meet business requirements, as well as conformance to operational mandates.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8532" ;
    skos:prefLabel "Analyze Product Specifications"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8533> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8203> ;
    skos:definition "Update Product Specification business activity updates, tracks and versions changes to existing product specifications according to versioning policies to support product requirement management and product's operational activities.<br/>This business activity manages all changes to product specifications over their lifecycle. As part of this business activity, Product Specification versioning is a sub-activity which ensures communicating changes to product specifications, so that product planners and consumers know what to expect. It includes communicating when changes are made to product specification properties.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8533" ;
    skos:prefLabel "Update and Version Product Specifications"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8534> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8451> ;
    skos:definition "Develop Product Offering Price Condition develops (creates, updates, and removes) a product offering price condition that represents a single constraint that defines how a policy rule is assessment.<br/><br/>A condition is part of a policy rule that is made up of a conditions and actions. Conditions and actions are defined by policy statements. For example a statement for a condition may be \"If a premium software package is purchased\".<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8534" ;
    skos:prefLabel "Develop Product Offering Price Condition"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8535> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8451> ;
    skos:definition "Develop Product Offering Price Action develops (creates, updates, and removes) a product offering price action that represents the outcome of the successful evaluation of one or more policy conditions. <br/><br/>An action is part of a policy rule that is made up of a conditions and actions. Conditions and actions are defined by policy statements. For example a statement for an action may be \"get two software packages from a choice of five for free\".<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8535" ;
    skos:prefLabel "Develop Product Offering Price Action"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8536> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8451> ;
    skos:definition "Develop Product Offering Price Variable develops (creates, updates, and removes) a product offering price variable that represents a product offering, product offering price, or product specification type.<br/><br/>A variable is part of a policy that can be used to form a policy statement. The variable specifies an attribute or concept that should either be matched or in some way compared to a value when a condition is evaluated or set to some value when an action is taken. For example, \"get two of five software packages\".<br/><br/>If some cases the variables value is determined via the use of a derivation algorithm.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8536" ;
    skos:prefLabel "Develop Product Offering Price Variable"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8537> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8451> ;
    skos:definition "Develop Product Offering Price Value develops (creates, updates, and removes) a product offering price value that represents amount expressed in money or another medium of exchange for a product offering.<br/><br/>A value is part of a policy that can be used to form a policy statement. The value specifies an attribute that should either be set or cleared (if used in a policy action) or matched or compared in some way to a value of the policy variable in a policy condition. For example \"get the two software packages for free (a zero price)\".<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8537" ;
    skos:prefLabel "Develop Product Offering Price Value"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8538> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8451> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8538" ;
    skos:prefLabel "Manage Pricing Policy Association with Product Offering"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8539> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8377> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8539" ;
    skos:prefLabel "Identify New Product Offering Requirements"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8540> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8377> ;
    skos:definition "Identify New Product Offering Development Costs and Anticipated Benefits identifies the development costs and anticipated benefits. This includes forecasted demand, revenue gains, productivity gains, performance improvements, and/or operational cost improvements.<br/><br/>It also defines the proposed attributes specific to the product offering based on those for the associated product specification and used for advertising and sales.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8540" ;
    skos:prefLabel "Identify New Product Offering Development Costs and Anticipated Benefits"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8541> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8377> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8541" ;
    skos:prefLabel "Assess New Product Offering Risks and Competitive Positioning"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8542> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8377> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8542" ;
    skos:prefLabel "Develop New Product Offering Feasibility Assessment"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8543> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8377> ;
    skos:definition "Prepare New Product Offering Business Proposal assembles the various components of the new product offering business proposal for issuance to parties involved in the approval of it or other parties involved in this activity.<br/><br/>The components are the parts of the proposal that have been developed by other Develop New Product Offering Business Proposal processes, such as Assess New Product Offering Risks and Competitive Positioning.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8543" ;
    skos:prefLabel "Prepare New Product Offering Business Proposal"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8545> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8377> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8545" ;
    skos:prefLabel "Approve New Product Offering Business Proposal"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8547> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8202> ;
    skos:definition "Manage Product Catalog Access business activity handles access to the catalog according to the Catalog Content Management standards and policies.<br/>Manage Product Catalog Access will handle assigning catalog managers and granting privileges.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8547" ;
    skos:prefLabel "Manage Product Catalog Access"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8548> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8202> ;
    skos:definition "Manage Product Catalog Content Lifecycle business activity handles changes to catalog content according to the Catalog Content Management standards and policies.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8548" ;
    skos:prefLabel "Manage Product Catalog Content Lifecycle"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8549> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8202> ;
    skos:definition "Distribute Product Catalog business activity handles exchange and distribution of catalogs according to the Catalog Content Management standards and policies.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8549" ;
    skos:prefLabel "Distribute Product Catalog"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8550> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8500> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8550" ;
    skos:prefLabel "Assign Product Usages"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8551> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8500> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8551" ;
    skos:prefLabel "Distribute Product Usage"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8552> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8500> ;
    skos:definition "Guide Product Usages process is in charge of identifying Product Usages based on Service Usages.<br/>For example, for a Video on Demand where you can watch a video as many time as you want during 72 hours, several Service Usages might have been tracked (each time the user watches the video) and only one Product Usage will be identified for all Service Usages in the 72 hours after the first watch.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8552" ;
    skos:prefLabel "Guide Product Usages"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8553> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8323> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8553" ;
    skos:prefLabel "Gather Product Specification Ideas"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8554> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8323> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8554" ;
    skos:prefLabel "Identify Product Specification Opportunities and Requirements"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8555> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8323> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8555" ;
    skos:prefLabel "Develop New Product Specification Opportunity Concepts"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8556> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8515> ;
    skos:definition "Check Product Configuration Compatibility business activity enables product configuration parameters to be specified that meet products expected behavior and performance.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8556" ;
    skos:prefLabel "Check Product Configuration Compatibility"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8557> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8515> ;
    skos:definition "Add Product Configuration Relationship business activity joins Product Configuration Relationship.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8557" ;
    skos:prefLabel "Add Product Configuration Relationship"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8558> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8249> ;
    skos:definition "Establishing and managing facilities to inform customers of, and negotiate agreement for, planned service outages.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8558" ;
    skos:prefLabel "Determine Product Performance Criteria"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8559> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8249> ;
    skos:definition "Define Product Performance Plan business activity describe in detail the activities that support accomplishing or meeting product performance objectives/goals.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8559" ;
    skos:prefLabel "Define Product Performance Plan"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8560> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8249> ;
    skos:definition "Establish Product Performance Objectives business activity set up the desired measurable outcome to fulfilling product proposition.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8560" ;
    skos:prefLabel "Establish Product Performance Objectives"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8561> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8249> ;
    skos:definition "Set Product Performance Targets business activity establish performance management targets.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8561" ;
    skos:prefLabel "Set Product Performance Targets"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8562> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8564> ;
    skos:definition "Define Product Problem business activity is in charge of describing a product problem.<br/><br/>This business activity supports identifying product problem by leveraging collected product information to clearly describe the product problem for subsequent resolution.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8562" ;
    skos:prefLabel "Define Product Problem"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8563> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8564> ;
    skos:definition "Collect Product Problem Information business activity is in charge of gathering all data/information that enable establish a product problem.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8563" ;
    skos:prefLabel "Collect Product Problem Information"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8569> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8492> ;
    skos:definition "Manage Product Anomaly Profile business activity is in charge of recording and analyzing Product Anomaly Management frameworks in order to enable assess and predict Anomaly Management capabilities according to well-specified models.<br/>Manage Product Anomaly Profile supports Product Anomaly Management operations, as well as capturing the business intents that need to be associated with Product Anomaly Closed Loops and Product Anomaly Management Lifecycle.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8569" ;
    skos:prefLabel "Manage Product Anomaly Profile"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8580> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8578> ;
    skos:definition "Add Product Item business activity adds new product related items (product lines, version etc.) to the product order.<br/><br/>Add Product Item enables product orders of varieties of product based on business defined unit of acquisition. This business activity helps the business offer and support product variations.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8580" ;
    skos:prefLabel "Add Product Item"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8581> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8578> ;
    skos:definition "Assign Product Item Quantity business activity defines the units of quantity for every product item. <br/><br/>Assign Product Item Quaintly ensures minimum and maximum quantities that may apply to a product item within a given product order.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8581" ;
    skos:prefLabel "Assign Product Item Quantity"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8582> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8578> ;
    skos:definition "Customize Product Order business activity supports product ordering for products that can be customized or personalized. <br/><br/>Customize Product Order enables the business to offer products that are unique and built-to-order. This includes making products have different variants, with different settings and configurations.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8582" ;
    skos:prefLabel "Customize Product Order"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8583> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8579> ;
    skos:definition "Change Product Item business activity is responsible for adjusting product order items in a product order requirement. <br/><br/>Change Product Item supports 'Change Product Order Requirement' by enabling product items to be modified according to business rules and policies supporting the product ordering lifecycle.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8583" ;
    skos:prefLabel "Change Product Item"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8584> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8579> ;
    skos:definition "Modify Product Order Item Quantity business activity is responsible for adjusting quantities of product order items in a product order requirement. <br/><br/>Modify Product Order Item Quantity supports 'Change Product Order Requirement' by enabling product item quantities are modified according to business rules and policies supporting the product ordering lifecycle.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8584" ;
    skos:prefLabel "Modify Product Order Item Quantity"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8585> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8579> ;
    skos:definition "Remove Product Order Requirement business activity is responsible for taking out or deleting product order requirement. <br/><br/>Remove Product Order Requirement supports 'Change Product Order Requirement' by enabling product orders can be effectively moved from the valid or active or available product order schedule or queue.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8585" ;
    skos:prefLabel "Remove Product Order Requirement"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8586> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8577> ;
    skos:definition "Validate Product Order Requirement Availability business activity is responsible for checking and proving the validity of new product order requirements. <br/><br/>Validate Product Order Requirement Availability ensure the business accepts product order that meet defined product order management requirements, business rules and policies, and can that can be honored.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8586" ;
    skos:prefLabel "Validate Product Order Requirement Availability"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8587> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8577> ;
    skos:definition "Approve Product Order Processing business activity is responsible for officially accepting the product orders for processing. <br/><br/>Approve Product Order Processing supports 'Approve Product Order' business activity to make the business initiate processing of the order. This business activity ensures the business is able to, and accountable to actions to honor the order.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8587" ;
    skos:prefLabel "Approve Product Order Processing"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8593> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8571> ;
    skos:definition "Track Product Order Fulfillment business activity records all the product order fulfillment processing status.<br/><br/>Track Product Order Fulfillment supports detecting early evidence of \"something going wrong\" or not according to business rules and policies for a product order accepted for fulfillment. It supports escalation of product order fulfillment challenges and remediation.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8593" ;
    skos:prefLabel "Track Product Order Fulfilment"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8594> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8571> ;
    skos:definition "Close Product Order Fulfillment business activity finalizes a product order fulfillment to be complete. <br/><br/>Close Product Order Fulfillment supports successful product order delivery can take place to ensure the business can meet the obligations for product order management.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8594" ;
    skos:prefLabel "Close Product Order Fulfilment"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8595> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8588> ;
    skos:definition "Make to Product Order business activity is responsible for all arrangement to make products based on product order.<br/><br/>Make to Product Order business activity supports the business to offer customized products. This business activity supports 'manage product order fulfillment' by ensuring there is a fulfillment plan in place to facilitate customized products in a product order.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8595" ;
    skos:prefLabel "Make to Product Order"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8596> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8588> ;
    skos:definition "Assemble to Product Order business activity is responsible for all arrangement to put together products based on product order.<br/><br/>Make to Product Order business activity supports the business to build or construct products in a product order. This business activity supports 'manage product order fulfillment' by ensuring there is a fulfillment plan in place to facilitate putting together requirements in a product order.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8596" ;
    skos:prefLabel "Assemble to Product Order"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8597> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8588> ;
    skos:definition "Schedule Product Order Fulfillment business activity is responsible for making a plan for fulfilling a product order according to the product order. <br/><br/>Schedule Product Order Fulfillment supports 'manage product order fulfillment' by ensuring appropriate prioritization and \"resources\" available to facilitate processing the delivery of a product order.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8597" ;
    skos:prefLabel "Schedule Product Order Fulfilment"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8598> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8589> ;
    skos:definition "Manage Product Preorder business activity direct and control Product Pre-orders which are product orders that are taken for products that are not yet available. <br/><br/>Manage Product Preorder supports 'Manage Product Order Fulfillment Profile' by providing businesses with input to plan production effectively.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8598" ;
    skos:prefLabel "Manage Product Preorder"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8599> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8589> ;
    skos:definition "Manage Product Backorder business activity directs and controls placement of product orders where the business has insufficient product capacity or product-related supplies. <br/><br/>Manage Product Backorder enables 'manage product order fulfillment profiles' that effectively estimate demand, manage capacity and supplies in a proactive way to support sudden increases in product orders.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8599" ;
    skos:prefLabel "Manage Product Backorder"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8600> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8590> ;
    skos:definition "Manage Product Order Picking/Packing Rule business activity directs and controls the regulations that define or restrict actions that guide packing and picking activities. <br/><br/>Manage Product Order Picking/Packing Rule ensures that the right picking and packing procedures are in place to support all product orders accepted for product order delivery. Picking/packing rules may be defined for single product orders, batch product orders, zone-based product orders etc.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8600" ;
    skos:prefLabel "Manage Product Order Picking/Packing Rule"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8601> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8590> ;
    skos:definition "Pick Product Order Item business activity identifies and collects product items according to a product order from where they are stored in readiness to satisfy the product order fulfillment process.<br/><br/>Pick Product Order Item includes activities like sorting (sort while picking, or sort after pick) and ensures that all the types of picking for all types of products can be completed according to the product order management requirements. Pick Product Order Item can apply to piece picking, case picking, single order picking, batch picking, wave picking, pallet picking etc.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8601" ;
    skos:prefLabel "Pick Product Order Item"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8602> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8590> ;
    skos:definition "Pack Product Order Item business activity is responsible for packaging all the product order items into the business approved shipping standard. <br/><br/>Pack Product Order Item ensures all the items in a product order can be appropriately organized for product order delivery process, along with all information needed to assure successful delivery.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8602" ;
    skos:prefLabel "Package Product Order Item"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8605> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8603> ;
    skos:definition "Manage Product Order Shipping Rule business activity directs and controls the definition and management activities for Product Order Shipping procedures and rules.<br/><br/>Manage Product Order Shipping Rule include rules that may be specific for, say, products and locations or both.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8605" ;
    skos:prefLabel "Manage Product Order Shipping Rule"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8606> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8603> ;
    skos:definition "Manage Product Order Shipping Rate business activity directs and controls the definition and management Product Order Shipping rates. <br/><br/>Manage Product Order Shipping Rate address custom and pre-defined shipping rate for product order shipping profiles.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8606" ;
    skos:prefLabel "Manage Product Order Shipping Rate"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8607> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8604> ;
    skos:definition "Create Product Order Shipment Advice business activity is responsible for creating the alert given by the product order shipper to the product order consignee before arrival of the product order.<br/><br/>Create Product Order Shipment Advice helps consignees to track product orders.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8607" ;
    skos:prefLabel "Create Product Order Shipment Advice"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8608> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8604> ;
    skos:definition "Schedule Product Order Shipment business activity is responsible for supporting the product order delivery by providing schedule <br/><br/>Schedule Product Order Shipment helps to plan out shipments and deliveries in advance based on the organizations supply chain and customer demand.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8608" ;
    skos:prefLabel "Schedule Product Order Shipment"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8609> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8592> ;
    skos:definition "Create Reverse Product Order Return business activity is responsible for generating reverse orders for previously delivered product orders. <br/><br/>Create Reverse Product Order ensures there is a correlation between product orders delivered and product order returns in accordance to the business rules and policies for product management.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8609" ;
    skos:prefLabel "Create Reverse Product Order Return"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8610> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8592> ;
    skos:definition "Authorize Product Order Return business activity is responsible for permitting a product order reverse order to be processed. <br/><br/>Authorize Product Order Return ensures that product order returns are acceptable and valid according to product ordering rules.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8610" ;
    skos:prefLabel "Authorize Product Order Return"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8611> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8592> ;
    skos:definition "Receive Returned Product Order business activity is responsible for accepting and processing the product order return. <br/><br/>Receive Returned Product Order ensures that product order returns are compliant with product order return policies.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8611" ;
    skos:prefLabel "Receive Returned Product Order"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8612> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8592> ;
    skos:definition "Close Product Order Return business activity is responsible for ensuring communication and confirmation of product order returns. <br/><br/>Close Product Order Return ensures that all activities to ensure the closure of product order return are completed successfully.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8612" ;
    skos:prefLabel "Close Product Order Return"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8613> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8572> ;
    skos:definition "Validate Product Order Delivery Requirement business activity proves validity of the delivery requirements in the product order. <br/><br/>Validate Product Order Delivery Requirement checks to ensure that a given product order has delivery requirement that conform to consignee expectations in the product order.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8613" ;
    skos:prefLabel "Validate Product Order Delivery Requirement"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8615> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8572> ;
    skos:definition "Close Product Order Delivery business activity is responsible for ensuring communication and confirmation of product order delivery. <br/><br/>Close Product Order Delivery ensures that all activities to ensure the closure of product order delivery are completed successfully.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8615" ;
    skos:prefLabel "Close Product Order Delivery"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8616> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8614> ;
    skos:definition "Activate Product Order Item business activity is responsible for making a product order item active. <br/><br/>Activate Product Order is available when an order is either ready to be shipped or provisioned. This business activity may require the consignee to initiate the request for activation through a request/response interaction, or by getting the product provision at the time of shipping.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8616" ;
    skos:prefLabel "Activate Product Order Items"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8617> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8614> ;
    skos:definition "Track Product Order Delivery business activity is responsible for tracing or following up with the status and stages in the product order delivery activity.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8617" ;
    skos:prefLabel "Track Product Order Delivery"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8618> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8614> ;
    skos:definition "Notify Product Order Delivery business activity is responsible for sending information or alerts/advice on product order delivery stages or to advice the product order delivery completion. <br/><br/>Notify Product Order Delivery ensures there is communication at all times during the product order delivery stage.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8618" ;
    skos:prefLabel "Notify Product Order Delivery"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8619> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8573> ;
    skos:definition "Request Product Order Cancellation business activity enables product orders to be dropped or removed from product order processing. <br/><br/>Request Product Order Cancellation ensures that there is a process in place within the organization product order process to address requests that are legitimate or acceptable by the organizations business rules and policies.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8619" ;
    skos:prefLabel "Request Product Order Cancellation"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8621> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8573> ;
    skos:definition "Track Product Order Cancellation business activity is responsible for following up product order cancellation stages and states within the stages. <br/><br/>Track Product Order Cancellation ensures that product order cancellations are followed and their states at all stages can be traced and accounted for.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8621" ;
    skos:prefLabel "Track Product Order Cancellation"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8622> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8573> ;
    skos:definition "Close Product Order Cancellation business activity is responsible for ensuring communication and confirmation of product order cancellation. <br/><br/>Close Product Order Cancellation ensures that all activities to ensure the closure of product order cancellation are completed and acknowledged by the consignee.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8622" ;
    skos:prefLabel "Close Product Order Cancellation"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8623> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8620> ;
    skos:definition "Review Product Order Cancellation business activity is responsible for assessing a product order cancellation request can be honored by the business. <br/><br/>Review Product Order Cancellation ensures that cancellation requests meet the product order cancellation policies established for product order management.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8623" ;
    skos:prefLabel "Review Product Order Cancellation"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8624> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8620> ;
    skos:definition "Reject Product Order Cancellation business activity is responsible for disqualifying or dismissing a product order cancellation request. <br/><br/>Reject Product Order Cancellation ensures that requestors are adequately advised and understand product order cancellation terms and conditions. The process ensures the business rules and policies for product order management are used in support of product order cancellation rejection.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8624" ;
    skos:prefLabel "Reject Product Order Cancellation"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8625> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8620> ;
    skos:definition "Complete Product Order Cancellation business activity is responsible for concluding the processing of product order cancellation requests.<br/><br/>Complete Product Order Cancellation ensures that information and actions necessary to finalize the product order cancellation are complete.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8625" ;
    skos:prefLabel "Complete Product Order Cancellation"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8626> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8574> ;
    skos:definition "Monitor Product Order Management Activity is responsible for observing and recording every activity in the product order management process.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8626" ;
    skos:prefLabel "Monitor Product Order Management Activity"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8627> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8574> ;
    skos:definition "Notify Product Order Management Status business activity is responsible for sending information about product order management activities.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8627" ;
    skos:prefLabel "Notify Product Order Management Status"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8628> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8574> ;
    skos:definition "Report Product Order Management business activity is responsible for formally accounting for product order management.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8628" ;
    skos:prefLabel "Report Product Order Management Activity"@en .

