    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7349> ;
    skos:definition "Create Marketing Campaign manages all activities and stakeholder engagement to develop a marketing campaign.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7355" ;
    skos:prefLabel "Create Marketing Campaign"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7356> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA1_EA7349> ;
    skos:definition "Define Marketing Campaign Criteria develops the criteria used to identify the customer and other parties targeted by the marketing campaign. It also develops a target list of customers and other parties that will be contacted as part of the campaign.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7356" ;
    skos:prefLabel "Define Marketing Campaign Criteria"@en .

