<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8757> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8760> ;
    skos:definition "These processes identify specific or imminent service operational support shortfalls. These processes take information available from the Service Management & Operations processes to establish detailed views of anticipated service operational support issues.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8757" ;
    skos:prefLabel "Capture Service Operational Support Shortfalls"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8758> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8760> ;
    skos:definition "These processes identify specific or imminent service performance shortfalls. These processes take information available from the Service Management & Operations processes to establish detailed views of anticipated service performance issues.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8758" ;
    skos:prefLabel "Capture Service Performance Shortfalls"@en .

