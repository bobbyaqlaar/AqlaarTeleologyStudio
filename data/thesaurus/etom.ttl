    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7599" ;
    skos:prefLabel "Update Sales Repository"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7600> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7586> ;
    skos:definition "Identify Sales Problem Solution business activity is in charge of finding and identifying answers to a defined sales problem. <br/><br/>Identify Sales Problem Solution includes activities that define sales problem solutions, and prioritize sales problem solutions based on their impact on selling.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7600" ;
    skos:prefLabel "Identify Sales Problem Solution"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7603> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7504> ;
    skos:definition "Manage Channel Reporting business activity is responsible for the collection and analysis of data related to Channel Sales and Channel Partner activities with the aim of providing insights into how well channel partners and sales channels are performing. Manage Channel Reporting ensures sales channels and channel partners are performing through effective channel management activities. This includes developing reporting structures for Market and Sales Channels with metrics and report visualizations, overseeing the generation of Channel reports, assessing channel reports and tracking Channel performance.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7603" ;
    skos:prefLabel "Manage Channel Reporting"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7606> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7532> ;
    skos:definition "Initiate Interaction With Sales Contact initiates contact with a party to acknowledge their interest via the Customer or Party Interaction Management process. This process may be repeated based on the response to the interaction that is provided to the Record Additional Sales Contact Information process.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7606" ;
    skos:prefLabel "Initiate Interaction With Sales Contact"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7607> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7532> ;
    skos:definition "Record Additional Sales Contact Information records more party information about a contact, such as offerings that are of interest based on the interaction with the party.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7607" ;
    skos:prefLabel "Record Additional Sales Contact Information"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7608> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7532> ;
    skos:definition "Analyze Sales Contact Interaction determines if a contact should be turned over to Manage Sales Lead or to the Manage Sales Prospect process. If not, then the contact's status is changed to reflect this, such as no longer of interest (to the enterprise) or inactive.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7608" ;
    skos:prefLabel "Analyze Sales Contact Interaction"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7609> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7601> ;
    skos:definition "Identify Channel business activity is responsible for selecting the most effective Sales and Marketing channel model to reach target customers and achieve sales and marketing goals. <br/><br/>Identify Channels includes assessing the market to identify potential sales channels, and channel partners, as well as evaluating different channel structures fit for use.<br/>Process Name was chagned in 25.5 old process name was Identify Channel<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7609" ;
    skos:prefLabel "Identify Sales Channel"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7610> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7601> ;
    skos:definition "Plan Channel business activity is responsible for the preparation and development of selection criteria, selection of intermediaries, and development of required training to support channel management.<br/><br/>Plan Channel includes plans for channel partners to sell, motivating channel partners whenever required, and assessment of sales channels along with channel partners.<br/>Process Name was chagned in 25.5 old process name was Plan Channel<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7610" ;
    skos:prefLabel "Plan Sales Channel"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7611> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7604> ;
    skos:definition "Identify Sales Channel Route business activity is responsible for selecting the specific pathway to use for selling products and services to consumers. <br/> <br/>Identify Sales Channel Routes' includes activities to identify from all available direct and indirect routes established for business.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7611" ;
    skos:prefLabel "Identify Sales Channel Route"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7612> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7604> ;
    skos:definition "Implement Sales Channel Organization business activity is responsible for organizing the sales channel, and creating a sales team structure that is aligned with sales goals and objectives. <br/> <br/>Implement Sales Channel Organization includes defining the roles and responsibilities of the sales team members, establishing performance metrics and targets, and developing training programs to ensure that the sales team is equipped with the necessary skills and knowledge to achieve sales goals.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7612" ;
    skos:prefLabel "Implement Sales Channel Organization"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7613> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7604> ;
    skos:definition "Develop Sales Channel Reward business activity is responsible for creating a reward system for the sales team that incentivizes them to meet market targets of products and services. <br/> <br/>Develop Sales Channel Reward includes defining the reward structure, setting performance metrics and targets, and developing training programs to ensure that sales teams are equipped with the necessary skills and knowledge to achieve sales goals.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7613" ;
    skos:prefLabel "Develop Sales Channel Reward"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7614> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7605> ;
    skos:definition "Develop Sales Channel Contract business activity formulates legally binding agreements, setting out detailed terms and conditions of business, and requirements for Sales Channel partners. <br/> <br/>Develop Sales Channel Contract includes defining the terms and conditions of the contract, setting performance metrics and targets, and developing obligations to ensure that sales channel partners achieve their goals.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7614" ;
    skos:prefLabel "Develop Sales Channel Contract"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7615> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7605> ;
    skos:definition "Maintain Sales Channel Contract business activity is responsible for the legal, regulatory, and financial relevance of Sales Channel Contracts in line with the enterprise's business.<br/><br/>Maintain Sales Channel ensures that at all times, the organizations' Sales Channel contracts are updated in accordance with the enterprises' Channel Management ambitions.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7615" ;
    skos:prefLabel "Maintain Sales Channel Contract"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7616> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7602> ;
    skos:definition "Develop Channel Communication is responsible for creating and implementing effective communications for Channels. <br/> <br/>Develop Channel Communication includes identifying the most effective communication channel for Channel Partners, developing communication messages that resonate with Channel Partners, and providing Channel partners with information the need to be successful.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7616" ;
    skos:prefLabel "Develop Channel Communication"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7617> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7602> ;
    skos:definition "Establish Channel Collaboration is responsible for building relationships between Channel Partners in order to create mutually beneficial relationships between Channel Partners.<br/> <br/>Establish Channel Collaboration includes identifying common goals and objectives, developing joint Channel marketing campaigns, and collaborating on a product development roadmap.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7617" ;
    skos:prefLabel "Establish Channel Collaboration"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7618> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7602> ;
    skos:definition "Manage Channel Promotion business activity is responsible for controlling the publication of products and/or services through Sales and Distribution Channels. <br/><br/>Manage Channel Promotion includes developing joint promotion campaigns, providing Channel Partners with marketing materials and resources, and tracking the effectiveness of Channel Partner marketing initiatives. <br/><br/>Manage Channel Promotion business activities are supported by advertising, promotions, and other marketing efforts designed to increase awareness and drive sales through channel partners.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7618" ;
    skos:prefLabel "Manage Channel Promotion"@en .

