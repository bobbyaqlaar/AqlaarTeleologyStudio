    skos:prefLabel "Selling"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7510> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7547> ;
    skos:definition "These processes create and document proposals for sales processes and sales channels. The processes define proposals to change existing sales processes and/or channels, or to develop new sales processes and/or channels. These processes undertake the necessary identification of the needs of products, and an analysis of the existing or proposed enterprise sales process and/or channel capabilities. The proposals can be based on industry analysis from the Monitoring Sales & Channel Best Practice processes, on feedback of the effectiveness of existing sales channels from the Selling processes, or on specific requirements associated with the development of new or enhanced products. These processes include defining product sales targets for each channel, as well as sales and sales personnel performance indicators for each channel.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7510" ;
    skos:prefLabel "Create Sales Proposals"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7511> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7547> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7511" ;
    skos:prefLabel "Gain Sales Proposals Approval"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7512> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7547> ;
    skos:definition "Forecasts sales performance for existing or proposed channels to inform channel targets, performance indicators, and business justification.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7512" ;
    skos:prefLabel "Forecast Channel Sales"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7513> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7547> ;
    skos:definition "Forecast sales performance for existing or proposed products to inform channel targets, performance indicators and business justification.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7513" ;
    skos:prefLabel "Forecast Product Sales"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7514> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7573> ;
    skos:definition "Analyze Customer or Other Party Trends uses ongoing analysis of customer or other party trends, such as usage, problems, complaints, to identify when the current product offerings may no longer be appropriate, or when the opportunity for a larger sale arises. The purpose is to ensure that the value of the relationship with a customer or other party is maximized by selling additional or more of the existing, product offerings.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7514" ;
    skos:prefLabel "Analyze Customer or Other Party Trends"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7515> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7573> ;
    skos:definition "Recommend Appropriate Product Offering(s) recommends more appropriate or other product offering(s) to the customer or other party that may be based on the results of Analyze Customer or Other Party Trends or based on known other offerings that represent an upsell.<br/><br/>For example, a potential new partner may be offered the opportunity to have there logo and contact information added to an enterprise's application that manages a IoT device.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7515" ;
    skos:prefLabel "Recommend Appropriate Product Offering(s)"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7516> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7572> ;
    skos:definition "Determine Required Sales Prospect Data determines the precise customer information required to support the agreed sales proposal if not provided by the sales prospect. Data is captured through forms, or sales prospect interviews, and so forth, the required sales prospect information, and storing the details in a form required by other processes.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7516" ;
    skos:prefLabel "Determine Required Sales Prospect Data"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7517> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7572> ;
    skos:definition "Capture & Record Sales Prospect Data captures and records all pertinent sales prospect data required for qualifying an opportunity and for the initiation, realization and deployment of the agreed sales proposal. In most standard offerings the necessary sales prospect data is often captured by Contact/Lead/Prospect Management. For non-standard and/or complex sales agreements associated, for instance, with a customer RFP, extensive customer information may be required to plan and roll-out the agreed solution. For example, a smart city may require extensive capture of details surrounding deployment of IoT devices and applications to manage them.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7517" ;
    skos:prefLabel "Capture & Record Sales Prospect Data"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7518> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7524> ;
    skos:definition "Assess Sales Forecasts is the process of analyzing and validating forecasted sales data to determine its strategic relevance for sales strategy development. It uses forecast insights to accurately reflect market dynamics, customer demand, and internal performance trends, providing a sound basis for defining strategic sales objectives, priorities, and resource allocations.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7518" ;
    skos:prefLabel "Assess Sales Forecasts"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7519> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7524> ;
    skos:definition "Defines sales metrics, service levels, and performance standards, including the selection of KPIs, targets, thresholds, and measurement criteria needed to evaluate sales performance and support performance reviews and adjustments.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7519" ;
    skos:prefLabel "Define Sales Metrics"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7520> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7524> ;
    skos:definition "Review Sales Performance vs Goals reviews actual sales results against defined goals and metrics to identify discrepancies and performance gaps, analyze variances, and provide insights that support performance management and goal adjustment.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7520" ;
    skos:prefLabel "Review Sales Performance vs Goals"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7521> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7524> ;
    skos:definition "Adjust Sales Metrics adjusts sales goals, metrics, and standards based on performance reviews, forecasts, and business needs to maintain alignment with strategic objectives.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7521" ;
    skos:prefLabel "Adjust Sales Metrics"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7522> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7501> ;
    skos:definition "Develop Sales Relationship sets the overall relationship strategy. It also initiates the development of sales relationships with other parties, such as sales partnerships and brokering, in advance of entering into formal agreements. Identifying and entering into agreements with other parties are managed Party Tender Management and Party Agreement Management. A party in the agreement may represent a sales channel for the other. This process initiates flows to these other processes as appropriate.<br/><br/>Strategies for managing relationships and relationship goals are identified and agreed upon. Sales relationship opportunities are identified along with the methods for selecting parties and for managing the relationship. Candidate parties are also identified.<br/><br/>This process also periodically analyzes relationship strategies and makes any necessary changes to them, including the removal of a strategy.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7522" ;
    skos:prefLabel "Develop Sales Relationship"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7523> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7501> ;
    skos:definition "Establish Sales Budgets calculate product revenue targets for the budget, determines variable and fixed costs and overhead budgets. It uses these to estimate net profit. The combination of all of these represents the sales budget for the enterprise.<br/><br/>This process also conducts reviews of the budget as appropriate and makes any changes to elements that compose it.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7523" ;
    skos:prefLabel "Establish Sales Budget"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7526> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7501> ;
    skos:definition "Establish Revenue Coverage Plan develops revenue targets, conducts financial and operational planning to support revenue objectives, and define sales account coverage plans.<br/><br/>Revenue targets are developed in order to meet revenue objectives. Financial and operational plans are also developed to support revenue objectives.<br/><br/>Sales account coverage plans, which include the enterprise sales targets, are defined and communicated throughout the Sales organization including any channels outside of the enterprise that may have been developed by Develop Sales Relationship.<br/><br/>This process also conducts reviews of revenue coverage plan as appropriate and adjusts them if needed.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7526" ;
    skos:prefLabel "Establish Revenue Coverage Plan"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7527> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7570> ;
    skos:definition "Develop, as required, alternative solutions or customization to the specific customer's requirements. This focuses on the definition of these solutions at this stage, and not the actual development of new capabilities (which may follow on)<br/>Develop, as required, alternative solutions or customization to the specific prospect's requirements. This focuses on the definition of these solutions at this stage, and not the actual development of new capabilities (which may follow on).<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7527" ;
    skos:prefLabel "Define Alternative/Customized Solutions"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7528> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7570> ;
    skos:definition "Assess the size of the potential development and its risk. The resources, financing and potential on-going customer commitment to the developed solution are all factors that must be assessed.<br/>Assess the size of the potential development and its risk. The resources, financing and potential on-going sales prospect commitment to the developed solution are all factors that must be assessed.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7528" ;
    skos:prefLabel "Assess Potential Development & Risk"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7529> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7570> ;
    skos:definition "Assess the strategic importance of the opportunity, the potential for wider application, and the importance of the specific customer to the enterprise. The solution alternatives must be available (e.g. capacity) or scheduled on a product roadmap<br/>Assess the strategic importance of the opportunity, the potential for wider application, and the importance of the specific prospect to the enterprise. The solution alternatives must be available, such as capacity, or scheduled on a product roadmap.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7529" ;
    skos:prefLabel "Assess Strategic Impacts"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7530> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7570> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7530" ;
    skos:prefLabel "Ensure Sales Prospect Expectations Met"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7531> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7593> ;
    skos:definition "Create Sales Contact creates a sales related contact that has been initiated by an interaction with a party. For example, an individual from an existing customer may make contact with an enterprise to express an interest expanding the customer's relationship with the enterprise; a potential partner may make contact with an enterprise based on viewing an enterprise's web site that has advertised for new partners who are interested marketing the enterprise's offerings; or an enterprise may assemble a list of contacts to whom marketing communications are to be sent.<br/><br/>Information about the contacting party is collected via an interaction with the Party Relationship & Development process.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7531" ;
    skos:prefLabel "Create Sales Contact"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7533> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7574> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7533" ;
    skos:prefLabel "Manage Sales Agreement"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7534> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7574> ;
    skos:definition "Create Customer or Party Order Request creates a standard and/or non-standard order request (in ITIL, \"RFCs\") for handover to be fulfilled. The request is passed to other processes to allow formal party or customer orders to be generated and processed or to allow the purchase of one or more product offerings.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7534" ;
    skos:prefLabel "Create Customer or Party Order Request"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7535> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7550> ;
    skos:definition "Initiate Interaction With Sales Prospect initiates contact with a sales prospect to acknowledge their interest via the Customer or Party Interaction Management process. This process may be repeated based on the response to the interaction that is provided to the Gather Sales Prospect Needs and based on the results of Analyze Sales Prospect Needs and Identify Sales Prospect Potential Solutions processes.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7535" ;
    skos:prefLabel "Initiate Interaction With Sales Prospect"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7536> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7550> ;
    skos:definition "Gather Sales Prospect Needs collect needs from a sales prospect in addition to one or more product offerings that may have already been expressed as of interest to a prospect or recommended to a prospect. The needs are collected via the Party or Customer Interaction Management processes that is triggered by Initiate Interaction With Sales Prospect.<br/><br/>For example, a marketing communication sent to a sales prospect may have suggested one or more product offerings; a potential partner may have expressed interest in marketing one or more of an enterprise's offerings.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7536" ;
    skos:prefLabel "Gather Sales Prospect Needs"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7537> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7550> ;
    skos:definition "Analyze Sales Prospect Needs analyzes the needs of a sales prospect. Based on the analysis of a prospect's needs, one or more potential product offerings are identified from an enterprise's product catalog to recommend to a prospect.<br/><br/>The product offerings may be in addition or different than the offerings in which a prospect expressed interest. For example the offering or offerings may represent upselling/cross selling; it may be that a customized offering is needed. If this is the case then the solution is further analyzed by the Selling process.<br/><br/>Initiate Interaction With Sales Prospect triggers an interaction with a party to communicate the suggested offering(s) to a party.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7537" ;
    skos:prefLabel "Analyze Sales Prospect Needs"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7538> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7507> ;
    skos:definition "Analyze sales performance against forecasts, strategy, measured by e.g. sales revenue, sales growth, sales quotas, new accounts won, upselling and cross selling, referrals, win/loss ratios, client retention, customer complaints/customer satisfaction. consider describing action that happens if threshold is not met, refer here to the generic metrics that were added in 15.0<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7538" ;
    skos:prefLabel "Analyze Sales Performance"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7539> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7507> ;
    skos:definition "Report Sales Performance business activity documents formal account of information on estimates of the total and expected value of sales pipeline. Report Sales Performance allows the organization to view what sales representatives are doing so that the business can measure performance. This business activity supports improving the sales strategy.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7539" ;
    skos:prefLabel "Report On Sales Performance"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7540> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7507> ;
    skos:definition "Improve sales performance by identifying what worked and what didn't, feeding into training (individual, group), recruiting and compensation. Includes best practice identification and replication.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7540" ;
    skos:prefLabel "Improve Sales Performance"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7541> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7507> ;
    skos:definition "Establish Sales Performance Strategy define and operationalize documented plans that successfully fulfill selling the organization's products and/or service to qualified buyers/consumers. Establish Sales Performance Strategy set clear sales goals and objectives, define compensation plans, and provide guidance for execution and accomplishment of sales initiatives. A Sales Performance Strategy will include, for example, key sales growth goals, sales KPIs, buyer personas, sales processes objectives, competitive analysis, product positioning etc.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7541" ;
    skos:prefLabel "Establish Sales Performance Strategy"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7542> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7507> ;
    skos:definition "Plan Sales Performance business activity establishes the detailed sales execution blueprint. Plan Sales Performance business activity outlines the steps underperforming sales initiatives must take in order to achieve optimal performance levels. This business activity ensures there are clear performance goals and performance growth metrics along with the roadmap to achieve those performance goals.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7542" ;
    skos:prefLabel "Plan Sales Performance"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7543> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7507> ;
    skos:definition "Manage Sales Performance Dispute business activity directs and controls sales compensation-based performance disputes. Manage Sales Performance Dispute enables dispute management lifecycle for performance-based payouts, sales crediting, and sales performance inquiries. It enables a view on all open disputes, analysts and approve or reject dispute requests, or require additional information about dispute requests.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7543" ;
    skos:prefLabel "Manage Sales Performance Dispute"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7544> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7507> ;
    skos:definition "Monitor Sales Performance business activity keeps track of sales team to identify winning opportunities, tactics and approaches that are not effective. Monitor Sales Performance sees how sales initiatives are performing to inform educated decisions. Monitor Sales Performance includes monitoring sales opportunities, sales, lead conversion rate, sell through rate, cannibalization rate etc.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7544" ;
    skos:prefLabel "Monitor Sales Performance"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7545> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7507> ;
    skos:definition "Reward Sales Performance business activity incentivizes sales achievements. Reward Sales Performance business activity includes actions to award incentives, award bonuses, and provide other motivation tools that boost sales performance. When combined with sales compensation plans, it can motivate sales to increase performance and maintain high levels of quota attainment.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7545" ;
    skos:prefLabel "Reward Sales Performance"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7549> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7595> ;
    skos:definition "Identify Sales Prospect creates a sales prospect based on input from other processes, such as Analyze Sales Contact Interaction or Evaluate Sales Lead. Assign a prospect to the appropriate sales channel.<br/><br/>A sales prospect is considered to be a qualified sales lead or qualified sales contact. Qualification is dependent on an enterprise's criteria. Criteria may be that the prospect has the money, the authority, and the need to acquire an enterprise's offering(s). And, that the acquisition fits within an enterprise's timeline guidelines for the acquisition; for example, acquisition will be made within the next month, two months, and so forth.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7549" ;
    skos:prefLabel "Identify Sales Prospect"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7551> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7595> ;
    skos:definition "Evaluate Sales Prospect tracks the lifecycle of a sales prospect and records/reports the outcome (win or loss) for a prospect. A prospect represents a “pipeline” of potential sales, each of which is expressed in terms of the probability of successful sales closure and an estimate of the total attainable revenue. The evaluation is also based on the interactions with the sales prospect.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7551" ;
    skos:prefLabel "Evaluate Sales Prospect"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7552> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7571> ;
    skos:definition "Ascertain Sales Prospect Requirements ascertains a sales prospect’s requirements. This process commences following approval by the Qualify Opportunity process. The development of a sales proposal may require the selection of a standard product offering, may require the development of a non-standard offering, or may require the creation of a project team to construct an offering in response to a customer’s Request For Proposal.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7552" ;
    skos:prefLabel "Ascertain Sales Prospect Requirements"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7553> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7571> ;
    skos:definition "Determine Support for Sales Prospect Requirements determines the ability of the enterprise to support a sales prospect's requirements. These processes assess the extent of enterprise support required to develop the sales proposal, marshal the necessary support across the enterprise and administer the sales proposal development activity to ensure that any timing constraints associated with the prospect's requirements are achieved.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7553" ;
    skos:prefLabel "Determine Support for Sales Prospect Requirements"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7554> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7571> ;
    skos:definition "Develop Proposal against Sales Prospect Requirements develops a proposal (or proposals) for a sales prospect which meets the stated requirements. The development of a sales proposal may require the selection of a standard product offering, may require the development of a non-standard offering, or may require the creation of a project team to construct an offering in response to a customer’s Request For Proposal.<br/><br/>Note that development of a non-standard sales proposal or the response to a customer’s RFP may require the development of unique solution designs. The development of unique solutions, within the context of current deployed capabilities, may require the development of new product offerings to be considered along with supporting infrastructure.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7554" ;
    skos:prefLabel "Develop Proposal against Sales Prospect Requirements"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7558> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7503> ;
    skos:definition "This process provides support to the \"Contact/Lead/Prospect Management\" in Operations by ensuring that these processes can operate effectively.<br/>The purpose of this process is ensure there is capability (for example, information, sales supporting capabilities and related resources) so that the 'Contact/Lead/Prospect Management' processes can operate effectively. <br/>Examples of supporting capabilities are: information on how to process and distribute Sales Leads to corresponding Sales Channels. Contacts, Leads and Prospects may be identified through various processes, both customer facing processes and back-end processes are distributed for further processing by sub-processes under ‘Contact/Lead/Prospect Management’.<br/>Furthermore, these processes undertake trend analysis on contacts, leads and prospects management and they are responsible for providing support to the collection, administration and distribution of contacts, leads and prospects to the appropriate sales channels.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7558" ;
    skos:prefLabel "Support Contact/Lead/Prospect Management"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7559> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7594> ;
    skos:definition "Identify Sales Lead identifies a sales lead following on from marketing campaign advertising, or one that arises otherwise in the course of business and collected here.<br/>A sales lead, rather than a contact, may be identified as the target for a marketing communication, such as one that invites a party to initiate contact with an enterprise about one or more product offerings and provides a personal invitation number with the communication.<br/>Information about the contacting sales lead is collected via an interaction with the Party Relationship & Development process.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7559" ;
    skos:prefLabel "Identify Sales Lead"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7561> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7594> ;
    skos:definition "Evaluate Sales Lead evaluates a sales lead and notifies other processes, such as Manage Sales Prospect, that a lead exists for further action. If a lead is not turned over to another process, then the lead's status is changed to reflect this, such as no longer of interest (to the enterprise) or inactive.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7561" ;
    skos:prefLabel "Evaluate Sales Lead"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7562> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7546> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7562" ;
    skos:prefLabel "Develop Sales & Channel Requirements"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7563> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7546> ;
    skos:definition "These processes ensure that the enterprise can provide sales and channel capabilities as effectively as possible at all times. The monitoring captures issues such as compensation plans, product related sales training approaches and techniques, prospective customer identification methodologies, selling processes/methods and procedures for new products.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7563" ;
    skos:prefLabel "Monitor Sales & Channel Practices"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7564> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7508> ;
    skos:definition "The Manage Sales Commissions process describes rules and policies for managing commissions to the organization's salespeople for each individual sale.<br/>When planning a commission structure, sales leaders should consider factors like how much of their budget they can allocate for commission, how much they’ll pay for different levels of sales output, employees’ base salaries, and any potential bonuses or incentives they’re willing to include.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7564" ;
    skos:prefLabel "Manage Sales Commissions"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7565> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7548> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7565" ;
    skos:prefLabel "Develop External Relationships"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7566> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7548> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7566" ;
    skos:prefLabel "Manage Process & Channel Coordination"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7567> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7548> ;
    skos:definition "These processes include the definition of commercialization manpower profile, training program development and sales methods and procedures, compensation plans, identification of product potential customers to each channel and sale method<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7567" ;
    skos:prefLabel "Define Processes & Channels"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7568> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7560> ;
    skos:definition "Initiate Interaction With Sales Lead initiates contact with a sales lead to acknowledge their interest via the Customer or Party Interaction Management process. This process may be repeated based on the response to the interaction that is provided to the Record Additional Sales Lead Information process.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7568" ;
    skos:prefLabel "Initiate Interaction With Sales Lead"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7569> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7560> ;
    skos:definition "Record Additional Sales Lead Information records more party information about the sales lead, such as offerings that are of interest based on the interaction with the lead.<br/><br/>If a marketing communication included product offering information this process may also confirm interest in it and/or record additional offerings for which the sales lead is interested.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7569" ;
    skos:prefLabel "Record Additional Sales Lead Information"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7575> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7555> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7575" ;
    skos:prefLabel "Ensure Selling Capability"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7576> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7555> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7576" ;
    skos:prefLabel "Undertake Selling Trend Analysis"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7577> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7556> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7577" ;
    skos:prefLabel "Identify Relevant Sales Inventory Information"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7578> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7556> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7578" ;
    skos:prefLabel "Maintain Sales Inventory facilities"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7579> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7556> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7579" ;
    skos:prefLabel "Manage Sales Inventory Capture"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7580> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7556> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7580" ;
    skos:prefLabel "Control Sales Inventory Access"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7581> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7556> ;
    skos:definition "Ensuring the sales inventory repository accurately captures and records all identified sales details, through use of automated or manual audits. Monitoring and reporting on the quality of the data maintained in the inventory. The sales inventory maintains records of all sales, sales prospects and sales leads, sales channel activity, marketing campaign targets and performance, sales commissions and any other sales related- information, required to support both the Support Selling and the Selling processes. The sales inventory is also responsible for maintaining the association between customers and sales instances, created as a result of the Selling processes.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7581" ;
    skos:prefLabel "Ensure Sales Inventory Data Quality"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7582> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7556> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7582" ;
    skos:prefLabel "Track Sales Inventory Usage"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7583> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7556> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7583" ;
    skos:prefLabel "Identify Sales Inventory Shortcomings"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7584> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7590> ;
    skos:definition "Prioritize Sales Problem business activity is in charge of organizing Sales Problems by order of business established conditions or attributes.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7584" ;
    skos:prefLabel "Prioritize Sales Problem"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7585> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7590> ;
    skos:definition "Collect Sales Problem Information business activity is in charge of gathering all information/data that relate or apply to a defined sales problem.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7585" ;
    skos:prefLabel "Collect Sales Problem Information"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7587> a skos:Concept ;
