    skos:definition "Develop Sales Problem Solution Plan business activity is in charge of identifying and creating the tasks and course of action that correct or resolve sales problems.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7596" ;
    skos:prefLabel "Develop Sales Problem Solution Plan"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7597> a skos:Concept ;
