<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA6_EA9308> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA6_EA9169> ;
