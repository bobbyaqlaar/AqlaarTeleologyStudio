    skos:definition "Manage service research investigations processes manage internally driven research investigations and activities which are used to provide detailed assessment or investigation of new and emerging service capabilities. The actual research activity may be totally internally delivered , or may be outsourced to external parties.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8733" ;
