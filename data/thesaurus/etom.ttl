    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8694> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8771" ;
    skos:prefLabel "Generate Service Problem"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8772> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8694> ;
    skos:definition "If the service trouble report is created as a result of a notification or request from processes other than the Survey & Analyze Service Problem processes, this process is responsible for converting the received information into a form suitable for the Service Problem Management processes, and for requested additional information if required.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8772" ;
    skos:prefLabel "Convert Report To Service Problem Format"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8773> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8694> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8773" ;
    skos:prefLabel "Estimate Time For Restoring Service"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8774> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8713> ;
    skos:definition "This process assesses the information contained in the customer order, through a service order request, relating to the purchased product offering, initiating service process or party initiated request, to determine the associated service orders that need to be issued.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8774" ;
    skos:prefLabel "Assess Service Request"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8775> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8713> ;
    skos:definition "The service orders may be required to satisfy pertinent customer order information received, may arise as a result of requests for service provisioning to satisfy service problem recovery activities, may arise to alleviate service performance issues, or may arise as a result of information received from parties in relations to specific services. <br/>The issued service order may require a service feasibility assessment or a service design to be produced, may require new provisioning activities for specific services, may require a change to a previously issued service order, or may require deletion and/or recovery of previously delivered specific services. Where, the initiating request or the purchased product offering has a standard set of associated service orders this process is responsible for issuing the service orders, and for creating a record of the relevant initiating request or customer order information and the associated service orders. <br/>Where the initiating request or the purchased product offering has special or unusual requirements, and a specific feasibility assessment and/or service design has been previously created, this process is responsible for issuing the service orders, and for creating a record of the relevant initiating request or customer order information and the associated service orders.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8775" ;
    skos:prefLabel "Create Service Orders"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8776> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8713> ;
    skos:definition "Where the purchased product offering has special or unusual requirements, and a specific feasibility assessment and/or specific service design has not been previously created, this process marks the issued service order as requiring special handling, and passes management for further processing to the Track & Manage Service Provisioning process. <br/>The orchestration, if required, and tracking of the service order progress is the responsibility of the Track & Manage Service Provisioning processes.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8776" ;
    skos:prefLabel "Mark Service Order for Special Handling"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8777> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8764> ;
    skos:definition "These processes ensure the provision, implementation and roll-out of the new or enhanced service capability and associated operational support processes. These processes are predominantly program/project management process functions, and require the detailed management and co-ordination of the delivery of individual service infrastructure components, and any underlying resource infrastructure capability delivery, to achieve the delivery of the overall service capability.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8777" ;
    skos:prefLabel "Co-ordinate Service Capability Delivery"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8778> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8764> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8778" ;
    skos:prefLabel "Ensure Service Capability Quality"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8779> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8764> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8779" ;
    skos:prefLabel "Establish Service Capability Sourcing"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8780> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8764> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8780" ;
    skos:prefLabel "Develop Service Capability Timetables"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8781> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8764> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8781" ;
    skos:prefLabel "Track and Report Service Capability Delivery"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8782> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8764> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8782" ;
    skos:prefLabel "Ensure Service Capability Costs"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8783> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8877> ;
    skos:definition "Define Service Capacity Requirement business activity establishes, measures, and adjusts conditions that impact on planning service capacity performance.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8783" ;
    skos:prefLabel "Define Service Capacity Requirement"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8784> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8877> ;
    skos:definition "Establish Service Capacity Availability Timing Requirement business activity identify scheduling needs for service capacity changes to be effective.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8784" ;
    skos:prefLabel "Establish Service Capacity Availability Timing Requirement"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8785> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8708> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8785" ;
    skos:prefLabel "Develop Overall Service Design"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8786> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8708> ;
    skos:definition "Develop an implementation plan considering training and operational support measures and needs, such as the proper parameter information for the Service Quality Management process; <br/>� Consideration of current and future service and underlying resources infrastructure, as well as expected solution results, budget, duration and risks; <br/>� Consideration of the time schedule according with customer requirements; <br/>� Ensure service and provisioning efficiency; <br/>� Undertaking a business assessment, ensuring an appropriate time-to-revenue as a result of the service and underlying resource investment;<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8786" ;
    skos:prefLabel "Develop Service Implementation Plan"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8787> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8708> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8787" ;
    skos:prefLabel "Develop Detailed Service Design"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8789> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8689> ;
    skos:definition "Manage Service Catalog Access business activity handles access to the catalog according to the Catalog Content Management standards and policies.<br/>Manage Service Catalog Access will handle assigning catalog managers and granting privileges.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8789" ;
    skos:prefLabel "Manage Service Catalog Access"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8790> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8689> ;
    skos:definition "Manage Service Catalog Content Lifecycle business activity handles changes to catalog content according to the Catalog Content Management standards and policies.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8790" ;
    skos:prefLabel "Manage Service Catalog Content Lifecycle"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8791> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8689> ;
    skos:definition "Distribute Service Catalog business activity handles exchange and distribution of catalogs according to the Catalog Content Management standards and policies.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8791" ;
    skos:prefLabel "Distribute Service Catalog"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8792> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8896> ;
    skos:definition "Adjust Service Capacity business activity is in charge of fulfilling changes to Service Capacity.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8792" ;
    skos:prefLabel "Adjust Service Capacity"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8793> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8896> ;
    skos:definition "Allocate Service Capacity business activity assign the amount in capacity that a service must support.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8793" ;
    skos:prefLabel "Allocate Service Capacity"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8794> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8732> ;
    skos:definition "Classify Service Catalog Content Entry business activity specifically handles Catalog Content organization according to business classification characteristics for the Service Catalog.<br/>Classify Service Catalog Content Entry is specific to shared qualities or characteristics defined by the organization.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8794" ;
    skos:prefLabel "Classify Service Catalog Content Entry"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8795> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8732> ;
    skos:definition "Organize Service Catalog Content Entry business activity handles Catalog Content organization according to the Service Catalog model.<br/>Organize Catalog Content Entry business activities can include ordering, arranging, sorting, assembling, and grouping.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8795" ;
    skos:prefLabel "Organize Service Catalog Content Entry"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8796> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8926> ;
    skos:definition "Plan & Schedule Service Catalog Release business activity is used to handle the release plan for the Service Catalog.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8796" ;
    skos:prefLabel "Plan & Schedule Service Catalog Release"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8797> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8926> ;
    skos:definition "Control Service Catalog Release business activity is used to support the various catalog release tasks.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8797" ;
    skos:prefLabel "Control Service Catalog Release"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8798> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8926> ;
    skos:definition "Test Service Catalog business activity is used to establish the quality, reliability and performance requirement of the catalog according to the Service management needs.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8798" ;
    skos:prefLabel "Test Service Catalog"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8800> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8693> ;
    skos:definition "Model Resource Specifications business activity represents the understanding of collections of service specifications and the relationship dependencies in order to manage dependencies, improvement or evolution of standards that affect overall design and delivery of service.<br/>This business activity is used by organizations to establish a collection of standardized, pre-documented specifications, and their dependencies to guide service lifecycle management and service operations.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8800" ;
    skos:prefLabel "Model Service Specifications"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8801> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8693> ;
    skos:definition "Analyze Service Specifications business activity research, assess and evaluate performance criteria and factors to develop, master, control/update services according to requirements.<br/>This business activity can include multiple analyzes of service specifications, including standard analysis (based on empirical research) or custom analysis (based on other standards). Analysis of Service Specification include testing service specifications and the ability to meet business requirements, as well as conform to operational mandates.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8801" ;
    skos:prefLabel "Analyze Service Specifications"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8802> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8687> ;
    skos:definition "Manage Catalog Design business activity cover the design of the Catalog in accordance to the Catalog Management Lifecycle.<br/>Manage Catalog Design business activity will leverage Catalog Specification requirement for all information (features, attributes etc.) to be managed by the catalog in order to enable support the Catalog Lifecycle Management.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8802" ;
    skos:prefLabel "Manage Service Catalog Design"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8803> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8687> ;
    skos:definition "Manage Catalog Design business activity covers the design of the Catalog in accordance to the Catalog Management Lifecycle.<br/>This business activity leverages input from the Catalog Design to construct the product/service/resource Catalog in order to meet the business operations goals.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8803" ;
    skos:prefLabel "Manage Service Catalog Build"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8804> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8687> ;
    skos:definition "Manage Catalog Build business activity establishes, manages and administers the governing of the catalog for operations readiness and operations.<br/>This business activity leverages support of the Enterprise governance processes for product/service/resource catalog lifecycle management.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8804" ;
    skos:prefLabel "Manage Service Catalog Policy"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8806> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8680> ;
    skos:definition "The Assess Performance of Existing Services processes analyze the performance of existing services to identify inadequacies and required improvements. These processes use information from customers and from operational activities to identify required improvements.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8806" ;
    skos:prefLabel "Assess Performance of Existing Services"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8811> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8680> ;
    skos:definition "The Manage Service Exit processes identify existing service classes which are unviable and manage the process to exit the Service from the products they support. The processes analyze existing service classes to identify economically or strategically unviable classes, identify products & customers impacted by any exit, develop product & customer specific exit or migration strategies, develop service infrastructure transition and/or replacement strategies, and manage the operational aspects of the exit process. A business proposal identifying the competitive threats, risks and costs may be required as a part of developing the exit strategy. These processes include any interaction with cross-enterprise co-ordination and management functions to ensure that the needs of all stakeholders are identified and managed.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8811" ;
    skos:prefLabel "Manage Service Exit"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8812> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8680> ;
    skos:definition "Service Test Development & Retirement is in charge of the Service Test catalogue.<br/>A type of Service Test aims at measuring proper functioning and capacities of a Service.<br/>Service Test Development & Retirement includes:<br/> - Specifying in detail each Service Test according to the different context. It includes specifying:<br/> - the roles authorized to use the Test and quotas for each type of role<br/> - the method to conduct the Test<br/> - the rules that define the strategies for conducting the test (including the test plan)<br/> - the thresholds and related actions<br/> - the relationships with lower level tests (Resource Test)<br/> - the report of test results with rules for enrichment of Resource Tests results according to role asking for it<br/> - Specifying test scenarios defining sequence of Tests with rules about context and planning to trigger it. It includes roles allowed for asking test scenario and corresponding quotas.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8812" ;
    skos:prefLabel "Service Specification Test Development & Retirement"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8813> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8714> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8813" ;
    skos:prefLabel "Monitor Service Order Status"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8814> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8714> ;
    skos:definition "Provide notifications of any changes the status of service orders. Notifications are used to notify the owner of the current status of the order and also distributed to the other parties who require it. Notification lists are managed and maintained by the Enable Service Configuration & Activation processes.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8814" ;
    skos:prefLabel "Distribute Service Order Notification"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8815> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8714> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8815" ;
    skos:prefLabel "Distribute Service Provisioning Reports"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8816> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8929> ;
    skos:definition "Manage Service Anomaly Profile business activity is in charge of recording and analyzing Service Anomaly Management frameworks in order to enable assess and predict Service Anomaly Management capabilities according to well-specified service management models.<br/>Manage Service Anomaly Profile supports Service Anomaly Management operations, as well as capturing the business intents that need to be associated with Service Anomaly Closed Loops and Service Anomaly Management Lifecycle.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8816" ;
    skos:prefLabel "Manage Service Anomaly Profile"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8824> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8678> ;
    skos:definition "Service Test Strategy develops the strategies of the enterprise for Service Test.<br/>This process is in charge of identifying types of Service Test to be conducted according to different context (i.e. business activities) for types of Services.<br/>The different context for Service Test are:<br/> - Service Development & Retirement to qualify the capacity to deliver Services before validating a new ServiceSpecification<br/> - Service Configuration & Activation to test the Service before closing the ServiceOrderItem<br/> - Service Quality Management to test Service Quality<br/> - Service Problem Management to test Service functioning<br/> - Service Test Management to conduct tests not specific to a customer’s product<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8824" ;
    skos:prefLabel "Service Test Strategy"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8825> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8678> ;
    skos:definition "Analyze Service Test Quality process performs quality analysis of service testing processes, in order to continuously fine-tune and improve them.<br/>Service Test Quality Analysis processes provide an offline analysis of the performance of service testing processes to ensure their continuous fitness for purpose, and eventually propose modifications or enhancements to the current service test specifications (including: service testing methods, quota, authorized users, recommendations and course of action if needed).<br/>The analysis is done using statistical service test usage data to evaluate service tests performance and required improvements if needed.<br/>Following the analysis, typical course of action can be:<br/> - No changes needed currently,<br/> - Creation of additional service tests,<br/> - Improving existing service tests,<br/> - Removing service tests that are no longer relevant.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8825" ;
    skos:prefLabel "Analyze Service Test Quality"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8826> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8690> ;
    skos:definition "Service Design Catalog Plan business activity understands requirements and capabilities demanded from the business to establish the Catalog plan based on the Service strategy for Service Catalog Planning Management.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8826" ;
    skos:prefLabel "Design Service Catalog Plan"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8827> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8690> ;
    skos:definition "Define Catalog Specification business activity establishes the Catalog specifications based on the product/service/resource strategy to support Catalog Planning Management.<br/>Define Catalog Specification leverages Specification Management business activities to establish the mandatory and optional design requirements, as well as catalog entry fields according to product/service/resource management needs. This process will be governed by the Enterprise Business Process for Catalog Management.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8827" ;
    skos:prefLabel "Define Service Catalog Specification"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8828> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8696> ;
    skos:definition "Depending on the nature of the specific service failure, these processes may possibly re-assign services or re-configure service and/or security parameters. It also reports successful restoration of normal operation or an unsuccessful attempt at restoration to Track & Manage Service Problem through updates to the associated Service Trouble report.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8828" ;
    skos:prefLabel "Reassign / Reconfigure Failed Service"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8829> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8696> ;
    skos:definition "Based on the nature of the service failure leading to the associated service alarm event notification, this restoration process might be triggered. It reports successful restoration of normal operation or an unsuccessful attempt at restoration to Track & Manage Service Problem through updates to the associated Service Trouble report.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8829" ;
    skos:prefLabel "Manage Service Restoration"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8830> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8696> ;
    skos:definition "For large service failures requiring extensive re-assignment and/or re-configuration activity to restore normal operation, this process will attempt to implement workarounds to recover the specific service operation. It also reports restoration through temporary workarounds or an unsuccessful attempt at restoration to Track & Manage Service Problem through updates to the associated Service Trouble report.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8830" ;
    skos:prefLabel "Implement Service Problem Work Arounds"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8831> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8696> ;
    skos:definition "This process recovers normal operation by invocation of the Support Service Problem Management processes. It also reports successful restoration of normal operation or an unsuccessful attempt at restoration to Track & Manage Service Problem through updates to the associated Service Trouble report.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8831" ;
    skos:prefLabel "Invoke Support Service Problem Management Processes"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8832> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8696> ;
    skos:definition "To review the resolution of service problems that have been categorized as major impact, in order to prevent recurrence and learn lessons for the future.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8832" ;
    skos:prefLabel "Review Major Service Problem"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8833> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8878> ;
    skos:definition "Specify Required Service Capacity business activity supports implementing service capacity plans by identifying clearly, and definitely, service capacity expectations (SLAs, SLOs etc.).<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8833" ;
    skos:prefLabel "Specify Required Service Capacity"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8834> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8878> ;
    skos:definition "Specify Service Capacity Course of Action business activity identifies clearly, and definitely, the sequence of activities that must be followed to support the 'Service Capacity Plan' expectations.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8834" ;
    skos:prefLabel "Specify Service Capacity Course of Action"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8835> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8761> ;
    skos:definition "These processes capture all activities required to gain necessary approval for business proposals to develop and deliver the required service capabilities, including identification of potential other parties.<br/>The processes include any interaction with cross-enterprise coordination and management functions to ensure that the investment proposals capture the needs of, and are supported by, all stakeholders<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8835" ;
    skos:prefLabel "Approve Service Capability Investment"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8836> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8761> ;
    skos:definition "These processes capture all activities required to develop business proposals to develop and deliver the required service capabilities, including identification of potential other parties. These processes take the input from the Map & Analyze Service Requirements, the Capture Service Capability Shortfalls and the Define Product Capability Requirements processes to develop and gain approval for any business proposals arising. In some cases the business proposal may require the creation and approval of a formal business case, in other cases the business proposal approval may be delegated to local management. In any event requirements for the service infrastructure, identification of required Resource infrastructure capabilities, the cost estimates for delivering the service and supporting resource infrastructure, including costs for materials (equipment and tools), labor and training are part of the investment proposal. <br/>The rules and procedures outlining the necessary approval process to be used are also part of these processes.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8836" ;
    skos:prefLabel "Develop Service Capability Investment Proposals"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8841> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8681> ;
    skos:definition "The purpose of the Support Service & Specific Instance Rating processes ensure that rating and tariff information is maintained for each service class, for use by Service & Specific Instance Rating. They are also responsible for the processing of this information related to administration of the services<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8841" ;
    skos:prefLabel "Support Service & Specific Instance Rating"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8842> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8681> ;
    skos:definition "Manage Service Test process manages the end-to-end execution of a test or test scenario for services not specific to a customer. Tests can be manual or automated.<br/>Service Test Management processes rely on Product and Resource Test Management processes due to dependencies between product tests and resource tests.<br/>Service Test Management includes:<br/>- Identification of service tests needed according to fulfillment and assurance issues<br/>- triggering of service tests in manual or automated mode<br/>- Execution of service tests<br/>- Verification of test authorization (role and context) and quota management<br/>- Identification and prioritization of tests <br/>- Setting up the test context and configuration<br/>- Triggering appropriate product and resource Tests<br/>- Tests can be on-demand or planned according to specific needs<br/>- Enrichment with product and resource tests results based on applicable service test rules <br/>- Reporting of test results<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8842" ;
    skos:prefLabel "Manage Service Test"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8843> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8928> ;
    skos:definition "Define Service Anomaly Closed Loop business activity state and describe the Service Anomaly Closed Loops along with associated information that lead to identifying, detecting or predicting a Service Anomaly.<br/>This business activity supports Anomaly definition process and the Closed Loops associated, including all associated inputs that reasonably affect the management of an Anomaly Lifecycle. This activity also ensures that the organization understands, and has well-defined operational workflows underpinning Anomaly Management.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8843" ;
    skos:prefLabel "Define Service Anomaly Closed Loop"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8844> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8928> ;
    skos:definition "Establish Service Anomaly Criteria business activity is in charge of defining and identifying all criteria needed to identify and predict deviation from what is known standard, normal, or expected of Products according to business dictates.<br/>Establishing a Product’s anomalous criterion is key to enable differentiate norms or standards from what is not. This will include specific Service design constraints (e.g. Service strategy, service offering, service goals) or Service operations.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8844" ;
    skos:prefLabel "Establish Anomaly Criteria"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8845> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8928> ;
    skos:definition "Establish Service Anomaly Closed Loop Information Sources business activity identifies all information sources and the requisite data that must be managed to support Service Anomaly Management Closed Loops.<br/>Establish Service Anomaly Closed Loop Information Sources help to identify the information (not limited to business and operations rules), business logic, levels of classification (by importance, by period etc.), impact and urgency etc. that can help detect Service Anomaly. This process supports Service Anomaly Management during day-to-day service delivery.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8845" ;
    skos:prefLabel "Establish Service Anomaly Closed Loop Information Sources"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8846> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8709> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8846" ;
    skos:prefLabel "Determine Service Parameter Availability"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8847> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8709> ;
    skos:definition "Depending on business rules, and on any specific levels of commitment contained in the initiating service order or service design request, these processes may reserve specific service parameters linked to the initiating service order or service design request for a period of time<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8847" ;
    skos:prefLabel "Reserve Service Parameters"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8848> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8709> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8848" ;
    skos:prefLabel "Release Service Parameter"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8849> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8709> ;
    skos:definition "Where the Allocate Specific Service Parameters to Services processes are requested by a service order issued in response to a confirmed customer order, this process is responsible for allocating the specific service parameters required to satisfy the initiating service order. Any previously reserved specific service parameters are marked as allocated.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8849" ;
    skos:prefLabel "Allocate Service Parameters"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8850> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8763> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8850" ;
    skos:prefLabel "Design Service Operational Support Process Improvements"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8851> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8763> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8851" ;
    skos:prefLabel "Identify Service Support Groups, Skills & Training"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8852> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8763> ;
    skos:definition "These processes ensure the identification, collation and coordination of support requirements from all approved investment proposals, and from any operational support shortfalls identified in the Capture Service Capability Shortfalls processes.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8852" ;
    skos:prefLabel "Identify Service Support Requirements"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8853> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8837> ;
    skos:definition "• Identifying the inventory-relevant information requirements to be captured for service infrastructure and service instances;<br/>• Identifying, establishing and maintaining service inventory repository facilities;<br/>• Establishing and managing the service inventory management and information capture processes;<br/>• Managing the registration and access control processes that enable processes to create, modify, update, delete and/or download service data to and from the service inventory<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8853" ;
    skos:prefLabel "Manage Service Inventory Database and Processes"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8854> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8837> ;
    skos:definition "• Ensuring the service inventory repository accurately captures and records all identified service infrastructure and service instance details, through use of automated or manual audits;<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8854" ;
    skos:prefLabel "Perform Service Inventory Audit Tests"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8855> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8837> ;
    skos:definition "• Tracking and monitoring of the usage of, and access to, the service inventory repository and associated costs, and reporting on the findings;<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8855" ;
    skos:prefLabel "Track and Monitor Service Inventory Capabilities"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8856> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8837> ;
    skos:definition "• Identifying any technical driven shortcomings of the service inventory repository, and providing input to Service Development & Management processes to rectify these issues.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8856" ;
    skos:prefLabel "Identify Service Inventory Issues and Provide Reports and Warnings"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8857> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8710> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8857" ;
    skos:prefLabel "Assign Service Provisioning Activity"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8858> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8710> ;
    skos:definition "This process coordinates all the actions necessary in order to guarantee that all tasks are finished at the appropriate time and in the appropriate sequence. It schedules, assigns and coordinates repair and restoration activities, undertakes necessary tracking of the execution progress, modifies information in an existing Service Trouble report based on assignments, and modifies the Service Trouble report status.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8858" ;
    skos:prefLabel "Coordinate Service Problem"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8859> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8710> ;
    skos:definition "Responsibilities of this processes include, but are not limited to: <br/>- Generating the respective resource order creation request(s) to Issue Resource Orders based on specific service orders; <br/><ul><li> Escalating status of service orders in accordance with local policy; </li><li> Undertaking necessary tracking of the execution process; </li><li> Adding additional information to an existing service order; </li><li> Modifying information in an existing service order;� </li><li> Modifying the service order status; </li><li> Canceling a service order when the initiating customer order is cancelled; </li><li> Indicating completion of a service order by modifying the service order status. </li></ul><br/>Note that some specific service components may be delivered by other parties. In these cases the Track & Manage Service Provisioning process is responsible for initiating requests, through Party Order handling for the delivery by the party of the specific service components.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8859" ;
    skos:prefLabel "Manage Service Provisioning Activity"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8860> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8710> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8860" ;
    skos:prefLabel "Track Service Provisioning Activity"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8861> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8838> ;
    skos:definition "Planning, managing, deploying, monitoring and reporting of new and/or modified service infrastructure to ensure availability of sufficient service infrastructure to support the Service Provisioning processes. This includes:<br/>• Forecasting at an operational level service infrastructure volume requirements and run-out timeframes;<br/>• Managing capacity planning associated with the deployment of new and/or modified service infrastructure<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8861" ;
    skos:prefLabel "Plan & Forecast Service Infrastructure Requirements and Manage Capacity Planning"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8862> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8838> ;
    skos:definition "• Establishing and monitoring of organizational arrangements to support deployment and operation of new and/or modified service infrastructure;<br/>• Creating, deploying, modifying and/or upgrading of service infrastructure deployment support tools (including service Inventory) and processes for new and/or modified service infrastructure;<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8862" ;
    skos:prefLabel "Establish, Manage, and Develop Service Infrastructure Organization, Tools and Processes"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8863> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8838> ;
    skos:definition "• Developing and promulgating service infrastructure capacity deployment rules and controls;<br/>• Authoring, reviewing and approving operational procedures developed by Service Development & Management processes prior to service infrastructure deployment;<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8863" ;
    skos:prefLabel "Develop and Implement Service Infrastructure Capacity and Operational Rules and Procedures"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8864> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8838> ;
    skos:definition "• Testing and acceptance of new and/or modified service infrastructure as part of the handover procedure from the Service Development & Management processes to Operations;<br/>• Detecting service infrastructure operational limitations and/or deployment incompatibilities and providing requirements to address these aspects to Service Development & Management processes;<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8864" ;
    skos:prefLabel "Perform Service Infrastructure Acceptance Test and Address & Monitor the Change"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8865> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8838> ;
    skos:definition "• Monitoring capacity utilization of deployed service infrastructure to provide early detection of potential service infrastructure shortfalls;<br/>• Monitoring of, and reporting on, service infrastructure and resource instance currency and version management;<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8865" ;
    skos:prefLabel "Monitor, Report and Release Mgmt. of Service Infrastructure and Capacity Utilization"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8866> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8838> ;
    skos:definition "• Reconfiguring and re-arranging under-utilized deployed service infrastructure<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8866" ;
    skos:prefLabel "Optimize Existing Service Infrastructure Utilization"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8867> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8838> ;
    skos:definition "• Updating the Service Inventory of any changes to the available service infrastructure capacity.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8867" ;
    skos:prefLabel "Update Service Inventory Record"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8868> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8711> ;
    skos:definition "Assess and plan the approach to be undertaken for configuration. <br/>Re-use standard configuration and processes applicable to specific services. <br/>Configure and reconfigure specific services, including customer premises equipment if part of the service provider offering. <br/>Provide notifications as required if the configuration activity requires a planned outage or is likely to initiate false specific service alarm event notifications.<br/>Update the information contained in the service inventory as to the configuration of specific services and their status.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8868" ;
    skos:prefLabel "Configure Service"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8869> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8711> ;
    skos:definition "Assess and plan the approach to be undertaken for implementation. <br/>Re-use standard implementation processes applicable to specific services.<br/>Implement specific services, including customer premises equipment if part of the service provider offering. <br/>Provide notifications as required if the implementation activity requires a planned outage or is likely to initiate false specific service alarm event notifications.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8869" ;
    skos:prefLabel "Implement Service"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8870> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8711> ;
    skos:definition "Assess and plan the approach to be undertaken for activation. <br/>Re-used standard activation processes applicable to specific services. <br/>Provide notifications as required if the activation activity requires a planned outage or is likely to initiate false specific service alarm event notifications. <br/>At the successful conclusion of this activity, the status of the specific services will be changed from allocated to activated, which means they are in-use.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8870" ;
    skos:prefLabel "Activate Service"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8871> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8889> ;
    skos:definition "Identify Service Exception business activity supports the detection of Service Anomaly by investigating (recognizing and establishing) particular activity or event as an exception.<br/>Identify Service Exception business activity will support all Service Anomaly Management business activities - Assess Service Anomaly, Predict Service Anomaly, Mitigate Service Anomaly and Learn Service Anomaly.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8871" ;
    skos:prefLabel "Identify Service Exception"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8872> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8889> ;
    skos:definition "Treat Service Exception business activity provides the set of actions that support managing a products’ anomalous exception.<br/>This covers actions that may be:<br/>Proactive: Where the treatment of the conditions leading from the exception are controlled;<br/>Reactive: Where the treatment is directly in response to the exception.<br/>Treat Service Exceptions business activity helps to outline a series of actions that can expedite decisions for mitigation.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8872" ;
    skos:prefLabel "Treat Service Exception"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8873> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8889> ;
    skos:definition "Escalate Service Exception business activity is in charge of increasing the attention given to handling of a Service Exception.<br/>Escalating a Product’s exception may be based on several factors, including defined business rules of escalation, or the lack thereof for handling a product’s exception.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8873" ;
    skos:prefLabel "Escalate Service Exceptions"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8874> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8686> ;
    skos:definition "Plan Service Capacity business activity is in charge of determining the service delivery capacity needed to meet changing demand for services over a period of time, as well as implementing the plan that supports the goals of Service Capacity Management.<br/><br/>Service Capacity Plan ensures Service Management aligns capacity planning strategies with business goals, while: ensuring that there are sufficient capability or supporting service capabilities to meet planned and forecasted business goals; identifying gaps in capacity allocation early; determining resource capacity needs according to demand, determining constraints and usage patterns over time; forecasting future capacity needs; and communicating resource capacity requirements in time.<br/><br/>In the context of service capacity planning, consideration is given to measuring performance and comparing it to requirements that are set in Service Level Agreements (SLAs) or Service Level Requirements (SLRs).<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8874" ;
    skos:prefLabel "Plan Service Capacity"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8875> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8686> ;
    skos:definition "Align Service Capacity Planning Goals business activity correlates Service Capacity Plans (established as Service Level Objectives) with business demand, as defined in service level requirements (SLRs).<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8875" ;
    skos:prefLabel "Align Service Capacity Planning Goals"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8876> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8686> ;
    skos:definition "Establish Service Capacity GAP business activity identifies any disparity between Service capacity goals (SLAs) and business objectives (SLOs).<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8876" ;
    skos:prefLabel "Establish Service Capacity GAP"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8881> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8686> ;
    skos:definition "Monitor Service Capacity business activity identifies relevant service capacity attributes/properties, and monitors and tracks all service attributes, their use, and changes. <br/>Monitor Service Capacity supports all activities in Service Capacity Management by providing timely visibility for all concerns around service capacity.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8881" ;
    skos:prefLabel "Monitor Service Capacity"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8882> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8686> ;
    skos:definition "Report Service Capacity business activity prepares and presents detailed accounts of all relevant service capacity information, in a timely manner, and in ways that are relevant and reliable for use by business.<br/>Different business functions with interest for Resource Capacity may require specific reports with specific information. This business activity ensures reports for Resource Capacity are collated, organized and presented in ways that are useful, and reliable to the needs of business functions in a timely manner.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8882" ;
    skos:prefLabel "Report Service Capacity"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8883> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8892> ;
    skos:definition "Manage Service Anomaly Case History business activity records all past information on Service Anomaly events, Service Anomaly Management activities and data underlying, and representing Service Anomaly cases.<br/>Manage Service Anomaly Case History includes the maintenance of past and present records, all artifacts, knowledge-base (e.g. the specifications, profiles, exception patterns, action patterns etc.) and versioned information.<br/>This business activity supports the organization to maintain skills and learning repository to identify and predict Anomalous Exception patterns and mitigatory actions.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8883" ;
    skos:prefLabel "Manage Service Anomaly Case History"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8884> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8808> ;
    skos:definition "These processes develop and document the required service features for the systems and network infrastructure as agreed through the Develop New Service Business Proposal processes. The processes ensure that all detailed specifications are produced and appropriately documented. Additionally the processes ensure that the documentation is captured in an appropriate enterprise repository.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8884" ;
    skos:prefLabel "Develop Detailed Service Technical Specifications"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8885> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8808> ;
    skos:definition "These processes develop and document the specific underpinning resource requirements and selections required for the systems and network infrastructure as agreed through the Develop New Service Business Proposal processes. The processes ensure that all detailed specifications are produced and appropriately documented. Additionally the processes ensure that the documentation is captured in an appropriate enterprise repository.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8885" ;
    skos:prefLabel "Develop Detailed Service Support Specifications"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8886> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8808> ;
    skos:definition "These processes develop and document the specific operational, and quality requirements and support activities, and any service specific data required for the systems and network infrastructure required for the systems and network infrastructure as agreed through the Develop New Service Business Proposal processes. The processes ensure that all detailed specifications are produced and appropriately documented. Additionally the processes ensure that the documentation is captured in an appropriate enterprise repository.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8886" ;
    skos:prefLabel "Develop Detailed Service Operational Specifications"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8887> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8808> ;
    skos:definition "These processes develop and document the customer manuals as agreed through the Develop New Service Business Proposal processes. The processes ensure that all detailed specifications are produced and appropriately documented. Additionally the processes ensure that the documentation is captured in an appropriate enterprise repository.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8887" ;
    skos:prefLabel "Develop Detailed Service Customer Manuals"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8893> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8822> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8893" ;
    skos:prefLabel "Identify the requirements for service aspects"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8894> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8822> ;
    skos:definition "Recommend service partnership processes focus on scanning external availability of sourcing Service aspects and make recommendations about specific parties who should be used to provide the service aspects<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8894" ;
    skos:prefLabel "Recommend Service Partnership"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8895> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8822> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8895" ;
    skos:prefLabel "Determine extent of service aspect sourcing"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8897> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8840> ;
    skos:definition "• Developing and maintaining a repository of acceptable performance threshold standards for resource instances to support the Service Quality Management processes;<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8897" ;
    skos:prefLabel "Establish and Maintain Service Performance Threshold Standards"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8898> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8840> ;
    skos:definition "• Monitoring and analyzing the service instance analyses produced by the Service Quality Management processes to identify problems that may be applicable to the service infrastructure as a whole;<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8898" ;
    skos:prefLabel "Monitor and Analyze Service Performance Reports, and Identify Issues"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8899> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8840> ;
    skos:definition "• Sourcing details relating to service instance performance and analysis from the resource inventory to assist in the development of trend analyses;<br/>• Logging the results of the analysis into the service inventory repository;<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8899" ;
    skos:prefLabel "Correlate the Service Performance Problem Reports & Manage Inventory Repository"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8900> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8840> ;
    skos:definition "• Establishing and managing service quality data collection schedules, including managing the collection of the necessary information from the Resource Data Collection & Distribution processes, to support proactive monitoring and analysis activity, and requests from Service Quality Management processes for additional data to support service instance performance analysis;<br/><br/>• Management processes for additional data to support service instance performance analysis;<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8900" ;
    skos:prefLabel "Manage Service Performance Data Collection"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8901> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8840> ;
    skos:definition "• Tracking and monitoring of the Service Quality Management processes and associated costs (including where service infrastructure is deployed and managed by third parties), and reporting on the capability of the Service Quality Management processes;<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8901" ;
    skos:prefLabel "Assess and Report Service Quality Management Processes"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8902> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8807> ;
    skos:definition "These processes develop and document business proposals for the identified new or enhanced Service ideas (including if necessary a business case). The business proposal (or business case) identifies the new service requirements, including the specific resource components which underpin the service. The business proposal also identifies the service development, management and operations costs and anticipated benefits, including forecast demand, performance gains, productivity gains and/or operational cost improvements. The business proposal also includes an assessment of the risks and the competitive positioning of the service proposal. As a part of the business proposal development a feasibility assessment can be produced. Potential parties who can assist in the development of the service classes are also identified (note that commercial arrangements may already be in place with these potential party).<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8902" ;
    skos:prefLabel "Develop Service Business Proposal"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8903> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8807> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8903" ;
    skos:prefLabel "Gain Service Business Proposal Approval"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8904> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8890> ;
    skos:definition "Triage Service Exception business activity is in charge of identifying and assigning the degrees of urgency, and the order of treatment of products’ anomalous exceptions.<br/>Triage Service Exceptions sub activities may include prioritizing exceptions and underlying Service anomaly events while examining causes that enable apply an initial set of mediatory actions.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8904" ;
    skos:prefLabel "Triage Service Exception"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8905> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8890> ;
    skos:definition "Plan and Select Service Anomaly Assessment Criteria business activity define the course of action to assess a Service anomaly, along with organizing the product’s anomaly assessment criteria in order to best facilitate detection and mitigation of anomalies.<br/>The 'Plan and Select Service Assessment Criteria' process helps the organization to optimize the approaches to assess Service anomaly criteria in order to continually avoid impact of false positives and/or false negatives in the detection of Service anomalies.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8905" ;
    skos:prefLabel "Plan and Select Service Anomaly Assessment Criteria"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8906> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8890> ;
    skos:definition "Analyze Service Anomalies to Learning business activity establish actions to discover and correlate anomalous behavior to 'learned normal' or 'expected behavior'.<br/>Analyze Service Anomalies to Learning sub activities help to enrich the organization's Anomaly Detection activities altogether, which can result in a reduction in the time to detect, triage and treat Service anomalies.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8906" ;
    skos:prefLabel "Analyze Service Anomalies to Learning"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8907> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8890> ;
    skos:definition "Classify Service Anomaly business activity establish ways to organize Service anomalies into established categories according to business priorities and Service management objectives.<br/>Classify Service Anomaly includes establishing robust classification models that help to triage anomalies, identify communication needs, determine and measure impact, and report on Service anomalies.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8907" ;
    skos:prefLabel "Classify Service Anomaly"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8908> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8890> ;
    skos:definition "Manage Service Anomaly Assessment Feedback Reporting business activity is in charge of establishing and handling the activities that prepare and report the feedback based of Service Anomaly Assessment activity.<br/>Manage Service Anomaly Assessment Feedback business activity covers tasks that prepare and report feedback of an Anomaly Assessment activity. This business activity is also helpful in supporting the optimization of the Anomaly Detection business activity, such as fine-tuning know-how for Service anomaly detection.<br/>Reports generated from this business activity can be utilized for Service Anomaly Mitigation and can help to select the consequent actions required to mitigate a Service anomaly.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8908" ;
    skos:prefLabel "Manage Service Anomaly Assessment Feedback Reporting"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8909> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8695> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8909" ;
    skos:prefLabel "Verify Service Configuration"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8910> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8695> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8910" ;
    skos:prefLabel "Perform Specific Service Problem Diagnostics"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8911> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8695> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8911" ;
    skos:prefLabel "Perform Specific Service Problem Tests"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8913> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8695> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8913" ;
    skos:prefLabel "Stop And Start Audit On Services"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8914> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8695> ;
    skos:definition "This process makes the results of the root cause analysis available to other processes. It updates the open Service Trouble report, as required during the assessment, and when the root cause has been identified. This process notifies the Track & Manage Service Problem processes.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8914" ;
    skos:prefLabel "Notify T&M Root Cause Service Problem"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8915> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8695> ;
    skos:definition "This process is responsible for categorizing the service problem according to the type of the problem, impact, and standardized criteria at SM&O level. Moreover, this activity will be carried out with appropriate diligence, in order to provide inputs to the \"Track & Manage Service Problem\" process.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8915" ;
    skos:prefLabel "Categorize Service Problem"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8916> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8799> ;
    skos:definition "Describe Service Specifications Property business activity set out and develop the rules, constraints, models and framing that bound the principles by which Service Specification can be modeled to support service requirements and the business objectives. <br/>A Service Specification Property enumerates all the specification attributes and their units of management.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8916" ;
    skos:prefLabel "Describe Service Specifications Property"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8917> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8799> ;
    skos:definition "Align Service Specifications business activity is in charge of the alignment of service specification to functional and nonfunctional requirement.<br/>The alignment of service specifications can be to other services as well as realization of the specific resource according to business concerns (e.g. cost, other accounting and non-accounting requirements etc.).<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8917" ;
    skos:prefLabel "Align Service Specifications"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8918> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8765> ;
    skos:definition "These processes co-ordinate the processes involved in handover of deployed service infrastructure to operational control, including the management and coordination of all stakeholders required to gain approval and acceptance of the handover.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8918" ;
    skos:prefLabel "Co-ordinate Service Operational Handover"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8919> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8765> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8919" ;
    skos:prefLabel "Validate Service Infrastructure Design"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8920> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8765> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8920" ;
    skos:prefLabel "Ensure Service Handover Support"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8921> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8891> ;
    skos:definition "Identify Service Exception Mitigation business activity helps to map product’s anomalous exceptions with actions that will reduce impact to business.<br/>Identifying Service exception and their mitigatory action involves tasks that may leverage established business policies and constraints, and/or be based on knowledge and skills related to context.<br/>This business activity helps to incorporate the right treatment based on the importance, impact or risk factors involved in a products operation. Any treatment of this nature can be static, based on pre-defined business rules, or dynamic based on skills and knowledge derived from context.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8921" ;
    skos:prefLabel "Identify Service Exception Mitigation"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8922> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8891> ;
    skos:definition "Coordinate Service Exception Mitigation business activity is in charge of managing the different activities of an exception mitigation plan all together to successfully realize a mitigation plan.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8922" ;
    skos:prefLabel "Coordinate Service Exception Mitigation"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8923> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8891> ;
    skos:definition "Initiate Service Exception Mitigation business activity is in charge of starting the correct activities that mitigate Service anomaly exceptions, cognizant of business requirement and goals.<br/>Initiate Service Exception Mitigation actions include recommendations for course of actions, fostering dynamic execution of actions, and/or scheduling actions based on predetermined business conditions and policies.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8923" ;
    skos:prefLabel "Initiate Service Exception Mitigation"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8924> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8891> ;
    skos:definition "Monitor Service Exception Mitigation business activity is in charge of observing, checking and keeping a continuous record of mitigatory actions that support Service Anomaly Management.<br/>Monitor Service Exception Mitigation covers the action and data that are involved (including collection and analysis on predefined set of information – e.g. SLOs, SLAs, SLI etc.) in Service Anomaly Management business activities, tasks and workflows.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8924" ;
    skos:prefLabel "Monitor Service Exception Mitigation"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8925> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8891> ;
    skos:definition "Report Service Exception Mitigation business activity is in charge of providing an account (documented or otherwise) of mitigatory actions taken to lessen or reduce the impact of a Service anomaly.<br/>Reporting on Service Exception Mitigation may follow well-defined business and operations criteria, or predefined set of metrics (e.g. SLOs, SLAs, SLIs, OLAs etc.) that are underlying to mitigate Service Anomaly Management business processes.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8925" ;
    skos:prefLabel "Report Service Exception Mitigation"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8927> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8688> ;
    skos:definition "Deploy Service Catalog business activity manage the availability and use of the Service catalog in operations.<br/>Deploy Service Catalog business activity includes identifying stakeholders, creating catalog category hierarchies, catalog integration, and catalog federation for any scenario, such as with business partners and between business functions.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8927" ;
    skos:prefLabel "Deploy Service Catalog"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8930> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8691> ;
    skos:definition "Monitor Service Anomaly Management Closed Loop business activity provides the capability to observe Service Anomaly Management Closed Loops.<br/>This business activity helps to scan; watch; monitor; and gain awareness of Service Anomaly Management activities that provide feedback between Service Anomaly Management Lifecycle(s) stages.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8930" ;
    skos:prefLabel "Monitor Service Anomaly Management Closed Loop"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8931> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8691> ;
    skos:definition "Report Service Anomaly Management Closed Loop business activity documents information organized to deliver an account of any, and all Service Anomaly Closed Loops.<br/>Anomaly Closed Loops may fall into either or across any of the four stages in any of the overarching Closed Loop pattern - Observe, Orient, Decide and Act - or other variations.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8931" ;
    skos:prefLabel "Report Service Anomaly Management Closed Loop"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8932> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8691> ;
    skos:definition "Manage Service Anomaly Intelligence business activity is in charge of acquiring and applying new learning, knowledge and skills to Service Anomaly Management.<br/>This business activity supports improving, optimizing, or evolving Service Anomaly Management activities. Manage Service Anomaly Intelligence helps to incorporate new knowledge and skills into Service Anomaly Management processes. This is as well to enable improvement and optimization of all Anomaly Management in a continuum.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8932" ;
    skos:prefLabel "Manage Service Anomaly Intelligence"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8933> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8691> ;
    skos:definition "Manage Service Anomaly Optimization business activity is in charge of actions that make the best and most effective use of Service Anomaly Management activities to improve Service Anomaly Management and ultimately Service Management.<br/>Manage Service Anomaly Optimization business activity can manage the business logic and business rules associated with Service Anomaly Detection, Service Anomaly Assessment, Service Anomaly Forecasting and Prediction, Service Anomaly Mitigation, as well as underlying Service Knowledge Management.<br/>This business activity also includes fine-tuning of business logic, operations logic, business and operations rules that improve efficiency of Anomaly Management as a whole.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8933" ;
    skos:prefLabel "Manage Service Anomaly Optimization"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8934> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8759> ;
    skos:definition "These processes provide detailed analysis of new service demand forecasts linked to service relevant geographic distributions. The processes also establish the detailed performance requirements. These processes take the forecast information available from the Produce Service Business Plans and requirements information from the Define Product Capability Requirements processes, as well as service infrastructure requirements developed by the Develop Detailed Service Specifications processes, to establish detailed views of anticipated service demand and performance requirements. These processes define the detailed infrastructure requirements to support the marketing strategies and forecasts. These processes provide requirements, including process performance targets, for the development of new and/or enhancement of existing marketing infrastructure which are captured by this process.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8934" ;
    skos:prefLabel "Capture Service Demand & Performance Requirements"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8935> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8759> ;
    skos:definition "These processes obtain agreement to the detailed infrastructure requirements to support the product capabilities required by the enterprise. The processes include any interaction with cross-enterprise coordination and management functions to ensure that the demand distributions capture the needs of all stakeholders.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8935" ;
    skos:prefLabel "Agree Service Infrastructure Requirements"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8936> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8759> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8936" ;
    skos:prefLabel "Report Service Infrastructure Requirements"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8937> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8820> ;
    skos:definition "Define Service Support Principles processes define principles for service levels and service quality on existing services or new services<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8937" ;
    skos:prefLabel "Define service support Principles"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8938> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8820> ;
    skos:definition "Define Service Support Policies processes define policies for service levels and service quality on existing services or new services<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8938" ;
    skos:prefLabel "Define service support Policies"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8939> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8820> ;
    skos:definition "These processes define the targets, and operational requirements, in this changing environment. The required performance standards are driven by community expectations, internal process and technology capabilities and competitive offerings. These processes also provide the feedback point from analyses undertaken in the Service Management & Operations process to determine bottlenecks and problems associated with existing service support activities. A major input to these processes arises from the Gather & Analyze Service Information processes, and from the product portfolio, resource strategy and market strategy processes.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8939" ;
    skos:prefLabel "Define Service Support performance standards"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8940> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8964> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8940" ;
    skos:prefLabel "Validate Service Usage Record"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8941> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8964> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8941" ;
    skos:prefLabel "Normalize Service Usage Record"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8942> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8964> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8942" ;
    skos:prefLabel "Convert Service Usage Record"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8943> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8964> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8943" ;
    skos:prefLabel "Correlate Service Usage Record"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8944> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8964> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8944" ;
    skos:prefLabel "Remove Duplicate Service Usage Record"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8945> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8819> ;
    skos:definition "Establish service strategy processes are responsible for establishing the service strategies based on markets trends, future products needs, technical capabilities, and addressing shortcomings in existing service performance and support. These processes also highlight issue associated with resourcing and skill sets. The result of this assessment sets the objectives of the service strategy.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8945" ;
    skos:prefLabel "Establish service strategy"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8946> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8819> ;
    skos:definition "Develop Service Strategy processes accept the changing service requirements and develop appropriate service strategies based on the changing needs of enterprise, and increasing expectations of the markets. The service strategy is documented.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8946" ;
    skos:prefLabel "Develop Service Strategy"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8947> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8819> ;
    skos:definition "Establish Service goals processes focus on establishing realistic service goals for the enterprise and for the products they support.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8947" ;
    skos:prefLabel "Establish Service goals"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8948> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8819> ;
    skos:definition "Determine Service Strategy Perspective processes generate Mission and Vision statements. Vision statements lead to service goals and Mission statements indicate the value and purpose that the organization uses to realize its vision.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8948" ;
    skos:prefLabel "Determine Service Strategy Perspective"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8949> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8819> ;
    skos:definition "Formulate Strategic Position Processes defines how the organization and the services it provides will be differentiated from other organizations providing similar services in the same industry.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8949" ;
    skos:prefLabel "Formulate Strategic Position"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8950> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8819> ;
    skos:definition "Produce Strategic Plan Process describes how the organization will achieve its service objectives, position and vision<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8950" ;
    skos:prefLabel "Produce Service Strategic Plan"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8951> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8819> ;
    skos:definition "Determine Actionable Patterns processes find efficient and effective patterns of auctioning the plan to achieve goals. These processes also find best patterns for dealing with change in Service Strategy. This allows the Service Strategy to adapt and evolve along with the organization and its environment.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8951" ;
    skos:prefLabel "Determine Actionable Patterns"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8952> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8879> ;
    skos:definition "Assess Available Service Capacity business activity evaluates unused service capacity in relation to service capacity plans, and service utilization trends.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8952" ;
    skos:prefLabel "Assess Available Service Capacity"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8954> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8879> ;
    skos:definition "Perform Service Capacity and Capacity Demand Trend Analysis business activity analysis trends between available service capacity and service capacity demand according to business and ongoing service usage.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8954" ;
    skos:prefLabel "Perform Service Capacity and Capacity Demand Trend Analysis"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8955> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8700> ;
    skos:definition "This process may determine that a service alarm event notification may represent a customer impacting condition. In these circumstances this process is responsible for indicating a potential customer problem to the Problem Handling processes. As a part of this indication this process is responsible for identifying the impacted deployed product instances associated with the service instances presenting alarm event notifications and passing this information to the Problem Handling processes.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8955" ;
    skos:prefLabel "Manage Service Alarm Event Notifications"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8956> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8700> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8956" ;
    skos:prefLabel "Filter Service Alarm Event Notifications"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8957> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8700> ;
    skos:definition "This process encompasses the correlation of redundant, transient or implied service alarm event notifications with a specific �root cause� service alarm event notification and associated service alarm event record. This process correlates service alarm event notifications to planned outage notifications to remove false service alarm event notifications arising as a result of the planned outage activity.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8957" ;
    skos:prefLabel "Correlate Service Alarm Event Notifications"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8958> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8700> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8958" ;
    skos:prefLabel "Abate Service Alarm Event Records"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8959> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8700> ;
    skos:definition "This process triggers a well-defined action based on specific service alarm event notification information as well as the non-arrival of service alarm event notification information after a specific time interval has elapsed. This process is also responsible for monitoring and triggering the appropriate action when a service alarm event record is not cleared within a pre-defined period of time.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8959" ;
    skos:prefLabel "Trigger Defined Service Alarm Action"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8960> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8700> ;
    skos:definition "This process is responsible for collecting and monitoring events and alarms provided by services though systems and monitoring tools.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8960" ;
    skos:prefLabel "Monitor Service Alarms Events"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8961> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8700> ;
    skos:definition "This process is responsible for categorizing the service alarm events in order to support the management, filtering and correlation of events at SM&O level.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8961" ;
    skos:prefLabel "Categorize Service Alarm Event"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8962> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8762> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8962" ;
    skos:prefLabel "Define Service Capability Requirements"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8963> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8762> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8963" ;
    skos:prefLabel "Select Service Capability At Parties"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8965> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8685> ;
    skos:definition "The purpose of the Report Service Usage Record processes is to generate reports on service usage records based on requests from other processes. These processes produce reports that may identify abnormalities, which may be caused by fraudulent activity or related to customer complaints.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8965" ;
    skos:prefLabel "Report Service Usage Records"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8966> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8685> ;
    skos:definition "The Guide Resource Usage Records process converts/relates the record to the appropriate service.<br/><br/>In many cases, this process is performed by a resource such as a network element.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8966" ;
    skos:prefLabel "Guide Resource Usage Records"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8967> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8953> ;
    skos:definition "Establish Service Capacity Utilization Behavior business activity develops Service Capacity usage models.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8967" ;
    skos:prefLabel "Establish Service Capacity Utilization Behavior"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8975> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8968> ;
    skos:definition "Define Service Performance Requirement Information involves defining the information required to measure service performance.<br/><br/>Define Service Performance Requirement Information's goal is to ensure that there is a clear and true facts to measure and track service performance.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8975" ;
    skos:prefLabel "Define Service Performance Requirement Information"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8976> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8974> ;
    skos:definition "Set Service Performance Goals is responsible for setting the performance goals for a service.<br/><br/>Set Service Performance Goals ensures that the service performance goals that are defined are registered and acknowledged. It involves laying out service performance goals and supporting any changes to these goals as necessary.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8976" ;
    skos:prefLabel "Set Service Performance Goals"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8977> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8974> ;
    skos:definition "Change Service Performance Goals is responsible for making changes to the service performance goals, as necessary.<br/><br/>Change Service Performance Goals ensures that the service performance goals are always aligned with the current needs and objectives of the business.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8977" ;
    skos:prefLabel "Change service Performance Goals"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8978> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8969> ;
    skos:definition "Define Services Performance Plan is responsible for creating a plan for service performance.<br/><br/>Define Services Performance Plan's goal is to ensure that there is a clear and effective plan in place for managing service performance.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8978" ;
    skos:prefLabel "Define Services Performance Plan"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8979> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8969> ;
    skos:definition "Implement Service Performance Plan is responsible for putting the service performance plan into action.<br/><br/>Implement Service Performance Plan's goal is to ensure that the plan is effectively implemented and that it leads to linked business outcomes.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8979" ;
    skos:prefLabel "Implement Service Performance Plan"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8980> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8969> ;
    skos:definition "Improve Service Performance Plan is responsible for making improvements to the service performance plan over time.<br/><br/>Improve Service Performance Plan ensures that the plan remains effective and relevant as the needs and objectives of the business evolve.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8980" ;
    skos:prefLabel "Improve Service Performance Plan"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8981> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8969> ;
    skos:definition "Terminate Service Performance Plan is responsible for ending the service performance plan when it is no longer needed. Terminate Service Performance Plan's goal is to ensure that resources judiciously allocated and effective. It is essentially to make sure that resources are not wasted on unnecessary plans or plans that are not effectively supporting business goals and outcome.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8981" ;
    skos:prefLabel "Terminate Service Performance Plan"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8982> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8970> ;
    skos:definition "Define Service Performance Measure is responsible for defining what measures will be used to track service performance.<br/><br/>Define Service Performance Measure's goal is to ensure that service performance is accurately measured and tracked.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8982" ;
    skos:prefLabel "Define Service Performance Measure"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8983> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8970> ;
    skos:definition "Change Service Performance Measure is responsible for making modifications to performance measures as necessary.<br/><br/>Change Service Performance Measure's goal is to ensure that the measures used are approved, and remain relevant and useful as the service performance needs and objectives of the business evolve.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8983" ;
    skos:prefLabel "Change Service Performance Measure"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8984> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8970> ;
    skos:definition "Remove Service Performance Measure involves removing measures that are no longer relevant or useful.<br/><br/>Remove Service Performance Measure's goal is to ensure that service performance measures can be appropriately terminated from use in service performance measures in a timely manner.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8984" ;
    skos:prefLabel "Remove Service Performance Measure"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8985> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8971> ;
    skos:definition "Assess Service Performance is responsible for evaluating current performance levels.<br/><br/>Assess Service Performance's goal is to gain a deep understanding of how well the service is currently performing.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8985" ;
    skos:prefLabel "Assess Service Performance"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8986> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8971> ;
    skos:definition "Investigate Service Performance is responsible for looking into any issues or anomalies in service performance. Investigate Service Performance goal is to identify and address any problems that may be affecting service performance.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8986" ;
    skos:prefLabel "Investigate Service Performance"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8987> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8971> ;
    skos:definition "Audit Service Performance is responsible for checking the accuracy and effectiveness of service performance information and measures.<br/><br/>Audit Service Performance goal is to ensure that the measures used are effective, accurate and reflective of service performance objectives.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8987" ;
    skos:prefLabel "Audit Service Performance"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8988> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8971> ;
    skos:definition "Report Service Performance Analysis is responsible for reporting on the results of service performance analyses.<br/><br/>Report Service Performance Analysis's goal is to communicate information about service performance to relevant stakeholders.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8988" ;
    skos:prefLabel "Report Service Performance Analysis"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8992> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8989> ;
    skos:definition "Collect Service Performance Information is responsible for gathering data and facts on service performance.<br/><br/>Collect Service Performance Information ensures that there is accurate and up-to-date information available on how the service is performing.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8992" ;
    skos:prefLabel "Collect Service Performance Information"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8993> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8989> ;
    skos:definition "Track Service Performance task is responsible for tracing or keeping an eye on service performance over time.<br/><br/>Track Service Performance goal is to identify and follow any trends or patterns in service performance, which can help in making informed decisions about how to improve the performance of service.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8993" ;
    skos:prefLabel "Track Service Performance"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8994> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8990> ;
    skos:definition "Measure Service Performance task involves measuring how well the service is performing against its predefined performance standards.<br/><br/>Measure Service Performance task goal is to provide a clear and objective record or observation of service performance to support any assessment of service performance.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8994" ;
    skos:prefLabel "Measure Service Performance"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8995> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8990> ;
    skos:definition "Review Service Performance Level task is responsible for surveying, reviewing, and making a judgment of service performance. Assess Service Performance goal is to gain a deep understanding of how well the service is performing and identify any areas where improvements could be made.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8995" ;
    skos:prefLabel "Review Service Performance Level"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8996> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8991> ;
    skos:definition "Plan Service Performance Improvement task is responsible for creating a plan for improving service performance.<br/><br/>Plan Service Performance Improvement's goal is to ensure that there are detailed proposals for improving service performance. This includes ensuring plans are clear and effective to support service performance management strategies.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8996" ;
    skos:prefLabel "Plan Service Performance Improvement"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8998> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8997> ;
    skos:definition "Pilot Service Performance Improvement task is responsible for testing the service performance improvement plan on a small scale before it is fully implemented.<br/><br/>Pilot Service Performance Improvement goal is to identify any potential issues or challenges that may arise during the implementation of the plan. It provides an opportunity to make necessary adjustments to the plan before it is rolled out on a larger scale.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8998" ;
    skos:prefLabel "Pilot Service Performance Improvement"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8999> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8997> ;
    skos:definition "Execute Service Performance Improvement task is responsible for putting the service performance improvement plan into action on a full scale.<br/><br/>Execute Service Performance Improvement goal is to improve service performance according to the strategies outlined in the plan. It involves implementing the strategies and monitoring their impact on service performance.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8999" ;
    skos:prefLabel "Execute Service Performance Improvement"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA9000> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8973> ;
    skos:definition "Create Service Performance Report process involves creating reports that accurately reflect current performance levels.<br/><br/>Create Service Performance Report's goal is to communicate information (results) about service performance to relevant stakeholders.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA9000" ;
    skos:prefLabel "Create Service Performance Report"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA9001> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8973> ;
    skos:definition "Change Service Performance Report is responsible for making modifications to service performance reports as necessary.<br/><br/>Change Service Performance Report's goal is to ensure that the reports remain accurate and relevant.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA9001" ;
    skos:prefLabel "Change Service Performance Report"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA9002> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8973> ;
    skos:definition "Publish Service Performance Report involves preparing and issuing service performance reports in a timely manner.<br/><br/>Publish Service Performance Report goal is to ensure that stakeholders have access to up-to-date facts and records about service performance.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA9002" ;
    skos:prefLabel "Publish Service Performance Report"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA6_EA9003> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA6_EA9429> ;
    skos:inScheme thes:etom ;
