    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10453" ;
    skos:prefLabel "Manage Messaging"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10454> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10182> ;
    skos:definition "Assess Training Needs business activity evaluates training gaps and needs, sets training objectives, evaluates roles, prepares plans and identifies place, people, process and technology capacity required to conduct and achieve a specified training objective.<br/>Assess Training Needs lays the necessary groundwork for determining the enterprises needs and how participants in the training will best receive the required training. <br/>Assess Training Needs captures skills proficiency of participants, frequency of skill usage and level of participants skill value to performance. <br/>Output of an Assess Training Need business activity include a map of participant (who) and type of training approach that will be most impactful (how, what, when).<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10454" ;
    skos:prefLabel "Assess Training Needs"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10456> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10182> ;
    skos:definition "Acquire Training Capability business activity establishes and makes ready the capability required to support a training plan.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10456" ;
    skos:prefLabel "Acquire Training Capability"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10457> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10182> ;
    skos:definition "Acquire Training Capability business activity establishes and makes ready the capability required to support a training plan.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10457" ;
    skos:prefLabel "Schedule Training Program"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10460> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10372> ;
    skos:definition "Verify Performance Data business activity handles all tasks that make sure or demonstrate that enterprise performance data are true, accurate or justified. <br/>The tasks here include verifying consistency of independent records of information related to all core processes altogether i.e. market, customer, product, service, business partner and resources within. It works with Manage Performance Consolidation, Reconciliation and Close and undertakes synchronization performance data across all core and enterprise activities for consistency.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10460" ;
    skos:prefLabel "Verify Performance Data"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10461> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10518> ;
    skos:definition "Define Information & Data Governance Plan business activity is in charge of tasks that oversee the establishment of the blueprint and courses of action for the execution and enforcement of authority over the management of information and data and their related assets.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10461" ;
    skos:prefLabel "Define Information & Data Governance Plan"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10462> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10606> ;
    skos:definition "Forecast Enterprise Performance business activity is in charge of calculating or estimating, based on data from previous performance results combined with recent trends, future enterprise performance.<br/>Forecast Enterprise Performance makes use of forecasting techniques that use samples of enterprise performance observations to predict future enterprise performance.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10462" ;
    skos:prefLabel "Forecast Enterprise Performance"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10463> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10606> ;
    skos:definition "Manage Enterprise Performance Plan business activity is in charge of controlling and directing the enterprise performance blueprint based on all activities that are required to achieve performance goals and objectives. <br/>In Manage Enterprise Performance Plan business activity, reference is made to the overall purpose/mission of the enterprise based on its desired results by taking stock of outside and inside activities, understanding the enterprises' situation, understanding performance goals and the strategic management goals, along with the objectives that help to achieve the goals.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10463" ;
    skos:prefLabel "Manage Enterprise Performance Plan"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10464> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10606> ;
    skos:definition "Manage Enterprise Performance Budgeting business activity is in charge of directing and controlling performance information for the allocation, spending, and management of enterprise resources.<br/>An enterprise resource is enterprise stock, or supply of money, materials, staff and other assets that can be drawn on by the enterprise in order to function effectively. Manage Enterprise Performance Budgeting activities improve investment and spend prioritization for enterprise resources in order to increase the efficiency and effectiveness of all enterprise expenditure.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10464" ;
    skos:prefLabel "Manage Enterprise Performance Budgeting"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10466> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10563> ;
    skos:definition "Manage Stakeholder Privacy Profile process is used to handle the life cycle of employee privacy profiles.<br/>It helps to administer processes that ensure that all entities processing data do conform with the organization's privacy policies and the laws & regulation under which it operates.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10466" ;
    skos:prefLabel "Manage Stakeholder Privacy Profile"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10467> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10246> ;
    skos:definition "Identify Relevant Research Information business activity find and discern the right research information to support analyzing for research findings.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10467" ;
    skos:prefLabel "Identify Relevant Research Information"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10468> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10246> ;
    skos:definition "Identify Research Reports & References business activity capture reports and references that support analyzing research findings.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10468" ;
    skos:prefLabel "Identify Research Reports & References"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10469> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10246> ;
    skos:definition "Clarify Unclear Research Points business activity provide comprehensible information around research points that are need explanation to resolve answers to points around research topics.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10469" ;
    skos:prefLabel "Clarify Unclear Research Points"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10470> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10246> ;
    skos:definition "Explain Research Findings business activity describe in detail findings from research topics.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10470" ;
    skos:prefLabel "Explain Research Findings"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10471> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10305> ;
    skos:definition "Analyze Program Benefits business activity handles tasks that examine the enterprises program benefits are aligned according to the designed program vision and goals.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10471" ;
    skos:prefLabel "Analyze Program Benefits"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10472> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10305> ;
    skos:definition "Measure Program Benefits business activity handle tasks that appraise 'how' Programs add value to the enterprise, and contribute to corporate and shared business objectives. <br/><br/>Manage Program Benefits business activities include identifying benefit assumptions, all necessary changes and tasks to achieve the intended benefits (e.g. procedures and metrics, including key performance indicators (KPIs) that need to be in place to measure benefits achievement progress - Benefits Dependency Maps, performance of roles and responsibilities required to meet benefits etc.), and planning that sustains or increases program benefits.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10472" ;
    skos:prefLabel "Measure Program Benefits"@en .

