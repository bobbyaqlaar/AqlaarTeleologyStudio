<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8699> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8683> ;
    skos:definition "The objective of the Close Service Trouble Report processes is to close a service trouble report when the service problem has been resolved. <br/>These processes monitor the status of all open service trouble reports, and recognize that a service trouble report is ready to be closed when the status is changed to cleared.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8699" ;
    skos:prefLabel "Close Service Trouble Report"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8701> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8712> ;
    skos:definition "Test specific services to ensure all components are operating within normal parameters, and that the service is working to agreed performance levels before its activation for the customer. <br/>This purpose is performed through testing the service end-to-end as far as possible. <br/>These processes test specific services against external party defined test plans, or against test plans developed by the service provider.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8701" ;
    skos:prefLabel "Test Service"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8703> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8712> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8703" ;
    skos:prefLabel "Capture Service Test Results"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8704> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8817> ;
    skos:definition "Gather Service information processes focus on establishment and Management of relationships with external providers of service information, and management of internal resources used for providing service information.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8704" ;
    skos:prefLabel "Gather Service Information"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8705> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8817> ;
    skos:definition "Analyze new service directions/enhance existing service processes focus on research and analyze customer, technology, competitor and marketing information identify new service directions and industry best practice, and potential enhancements to existing services<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8705" ;
    skos:prefLabel "Analyze new service directions/enhance existing service"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8706> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8817> ;
    skos:definition "Analyze to develop new service requirements processes undertake the responsibility of necessary analysis to identify potential opportunities, compare current capabilities with the identified opportunities, and as result of these analysis develop new service requirements. This process also include an analysis of the customer value proposition.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8706" ;
    skos:prefLabel "Analyze to develop new service requirements"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8707> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8817> ;
    skos:definition "Analyze service growth processes capture and analyze service growth which is driven by expansion of housing estates, building developments and building approvals forecasts,<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8707" ;
    skos:prefLabel "Analyze service growth"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8715> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8682> ;
    skos:definition "The objective of the Close Service Order processes is to close a service order when the service provisioning activities have been completed.<br/>These processes monitor the status of all open service orders, and recognize that a service order is ready to be closed when the status is changed to completed.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8715" ;
    skos:prefLabel "Close Service Order"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8717> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8698> ;
    skos:definition "This process is responsible for continuously monitoring the status of Service Trouble reports and managing notifications to processes and other parties registered to receive notifications of any status changes, for example, Resource Performance Management and Service Quality Management. Notification lists are managed and maintained by the Support Service Problem Management processes.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8717" ;
    skos:prefLabel "Monitor Service Problem"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8718> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8698> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8718" ;
    skos:prefLabel "Distribute Service Problem Notifications"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8719> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8698> ;
    skos:definition "This process records, analyzes and assesses the Service Performance Degradation Report status changes to provide management reports and any specialized summaries of the efficiency and effectiveness of the overall Service Quality Management process. These specialized summaries could be specific reports required by specific audiences.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8719" ;
    skos:prefLabel "Distribute Service Problem Management Reports & Summaries"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8720> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8839> ;
    skos:definition "• Requesting scheduling of additional service instance data collection to assist in the analysis activity;<br/>• Requesting scheduling of service instance performance testing to assist in analysis activity;<br/>• Developing and managing service infrastructure and service instance proactive maintenance programs;<br/>• Requesting service provisioning activity to prevent anticipated resource troubles associated with capacity limitations identified in the analysis activities;<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8720" ;
    skos:prefLabel "Manage Service Infrastructure, Provisioning and Preventive Maintenance Schedules"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8721> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA5_EA8839> ;
    skos:definition "• Extracting and analyzing, including undertaking trend analysis, historical and current service instance trouble reports and performance reports to identify potential service infrastructure or service instances requiring proactive maintenance and/or replacement;<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA5_EA8721" ;
