<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7588> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7590> ;
    skos:definition "Prioritize Sales Problem Solution business activity is in charge of organizing answers that correct sales problem in an order that effectively address the sales problem. <br/><br/>This business activity includes tasks that identify all answers to a Sales Problem based on business requirements.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7588" ;
    skos:prefLabel "Prioritize Sales Problem Solution"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7589> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7509> ;
    skos:definition "Define Sales Problem business activity is in charge of determining and describing issues and concerns that impact selling. <br/><br/>Define Sales Problem includes tasks that identify problems with leads management, sales planning, poor sales forecasting, ineffective sale tactic, loosing sales etc.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA2_EA7589" ;
    skos:prefLabel "Define Sales Problem"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA2_EA7592> a skos:Concept ;
