    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10770" ;
    skos:prefLabel "Analyze Risk Insights for Prioritization"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10771> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10595> ;
    skos:definition "Develop clear, actionable, and audience-specific outputs (e.g., dashboards, scorecards, summaries) using appropriate tools and visualizations.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10771" ;
    skos:prefLabel "Prepare Risk Reports for Distribution"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10772> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10595> ;
    skos:definition "Deliver reports through secure and effective channels, ensuring the right information reaches the right audience at the right time.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10772" ;
    skos:prefLabel "Distribute Risk Reports to Stakeholders"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10773> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10595> ;
    skos:definition "Support two-way communication with stakeholders by explaining key insights, clarifying impacts, and addressing questions or feedback.<br/>"@en ;
