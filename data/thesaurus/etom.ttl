    skos:prefLabel "Report Change"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10446> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10521> ;
    skos:definition "Review Change business activity is responsible for examining a change to ensure that it is ready for release for implementation.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10446" ;
    skos:prefLabel "Review Change"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10447> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10203> ;
    skos:definition "Define Desired Outcomes business activity support 'Define Learning Objectives; by establishing the specific performance statement to describe the results after a learning cycle. Define Desired Outcomes business activity establish performance conditions and criteria that describe what the learner will know or be able to do in specific, measurable terms. Example of a Learning Objective is \"Be able to felicitate customer requirements correctly.\"<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10447" ;
    skos:prefLabel "Define Desired Outcomes"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10448> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10510> ;
    skos:definition "Define Warehousing Policies business activity define the warehousing structure (centralized and/or distributed) and the associated management policies to be applied to purchased goods.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10448" ;
    skos:prefLabel "Define Warehousing Policy"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10449> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10510> ;
    skos:definition "Develop Logistics/Transport Policies business activity develop the policies for Transporting or moving supplies between locations.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10449" ;
    skos:prefLabel "Develop Logistics/Transport Policy"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10450> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10510> ;
    skos:definition "Develop Stock/Inventory Management Policy business activity develop the corporate policies, in conjunction with Asset Management processes which provide the inventory information resource, relating to locations of, and levels of, stock/inventory holdings.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10450" ;
    skos:prefLabel "Develop Stock/Inventory Management Policy"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10451> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA8_EA10571> ;
    skos:definition "Promote the desired corporate image for the enterprise and its general business and products. Areas such as sponsorship, corporate-level advertising and general contact with industry bodies, and government and regulatory agencies, are addressed here. Responsible for communicating the required messages to the market and industry about the overall enterprise<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10451" ;
    skos:prefLabel "Promote Desired Corporate Image"@en .

