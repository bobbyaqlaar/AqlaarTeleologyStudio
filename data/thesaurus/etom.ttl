    skos:definition "Import Customer Privacy Profile process ingests the privacy profile pre-defined by a customer, and integrates it into the organizations privacy management.<br/>"@en ;
    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7905" ;
    skos:prefLabel "Import Customer Privacy Profile"@en .

