    skos:inScheme thes:etom ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8233" ;
    skos:prefLabel "Manage Product Offering Improvements"@en .

<http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8234> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/etom/etom_EARoot_EA5_EA1_EA4_EA8379> ;
