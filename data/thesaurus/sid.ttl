<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA10_EA1432> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA1186> ;
    skos:definition "The <b>Customer Statistic ABE</b> represents the analysis of customer usage patterns, customer profitability statistics and churn and retention statistics.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA4_EA10_EA1432" ;
    skos:prefLabel "Customer Statistic ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA2_EA2_EA1587> a skos:Concept ;
