<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA11_EA1453> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA11_EA1444> ;
