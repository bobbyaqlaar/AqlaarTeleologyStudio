<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA11_EA5364> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA11_EA5356> ;
    skos:definition "Other subclasses include various IP variables, as well as Ports, QoS variables, and generic variables such as strings and integers.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA11_EA5364" ;
    skos:prefLabel "EARoot_EA4_EA2_EA10_EA11_EA5364"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA11_EA5365> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA11_EA5356> ;
    skos:definition "Subclasses define values for IP and MAC addresses, as well as generic values (e.g. a string).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA11_EA5365" ;
    skos:prefLabel "EARoot_EA4_EA2_EA10_EA11_EA5365"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA11_EA5366> a skos:Concept ;
