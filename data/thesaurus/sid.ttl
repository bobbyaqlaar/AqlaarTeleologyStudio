<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA1086> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA1090> ;
    skos:definition "The diagram below lists the Sales Domain's ABEs.<br/><br/><b>Sales Party Roles ABE</b><br/><ul><li>Sales Party Roles ABE contains all PartyRoles related to the Sales Domain such as , SalesAgent, and Prospect.</li></ul><b>Sales Commission ABE</b><br/><ul><li>The Sales Commission ABE contains all Business Entities used to specify commissions for Sales Agent, Employees... including commission rules and commissions applied.</li></ul><b>Sales Lead and Opportunity ABE</b><br/><ul><li>Sales Lead and Opportunity ABE provides the ability to track sales leads through their life cycle up until the time the prospect become customers, including proposals made to potential customers, and the amount of potential revenue the leads represent in the form of a sales pipeline.</li></ul><b>Sales Forecast ABE (not fully developed)</b><br/><ul><li>Sales Forecast ABE maintains market and sales forecasts, new service requirements, customer needs, and customer education.</li></ul><b>Sales Channel ABE (not fully developed)</b><br/><ul><li>Sales Channel ABE keeps track of distribution channels and sales activities, sales quotas, sales, contests, commission/bonus plans, commissions/bonuses, and maintain groups of individuals that make up the sales force.</li></ul><b>Sales Statistics ABE (not fully developed)</b><br/><ul><li>The Market Sales Statistics maintains market and sales key performance indicators about Sales & Marketing revenue and sales channel performance.</li></ul><b>Sales Strategy Plan ABE (not fully developed)</b><br/><ul><li>Sales Strategy Plan ABE supports the business plans and strategies within the Sales domain.</li></ul><p/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA3_EA1086" ;
    skos:prefLabel "[SD-01]Sales ABEs Level 1"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA1088> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA1090> ;
    skos:definition "The diagram below lists the Sales Domain's ABEs Level 1 & 2.<br/><b>Sales Opportunity ABE</b><br/><ul><li>Sales Opportunity ABE provides the ability to track pending deals and the amount of potential revenue the leads represent in the form of a sales pipeline including proposals made to potential customers.</li></ul><b>Sales Lead ABE</b><br/><ul><li>Sales Lead ABE provides the ability to track sales leads through their lifecycle up until the time the prospect becomes a customer.</li></ul><p/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA3_EA1088" ;
    skos:prefLabel "[SD-02] Sales ABEs Level 1 & 2"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA1091> a skos:Concept ;
