<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA8_EA1415> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA1186> ;
    skos:definition "The<b> Customer Interaction ABE</b> represents communications with customers, and the translation of customer requests and inquiries into appropriate “events” such as the creation of a customer product order, the creation of a customer bill inquiry, or the creation of a customer problem.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA4_EA8_EA1415" ;
    skos:prefLabel "Customer Interaction ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1_EA1711> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1676> ;
    skos:definition "The Pricing Logic Algorithm ABE contains entities representing an instantiation of an interface specification to external rating function (without a modeled bahavior in SID).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA1_EA1711" ;
    skos:prefLabel "Pricing Logic Algorithm ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA5_EA1761> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1676> ;
    skos:definition "The Product Offering Price Tax ABE describes how taxation is modelled in the context of ProductOfferingPrice and ProductPrice. The model covers the following aspects:<br/> • TaxDefinition and TaxExemption - these specify what the tax is and how it is calculated, including the influence of specific circumstances on the calculation<br/> • TaxProdOfferPriceAlteration - this is an alteration to a ProductOfferingPrice that projects how much tax will be added for a <font color=\"#29313b\">ProductOfferingSpecification</font><br/> • TaxProdPriceAlteration - this is an alteration to a ProductPrice that represents how much tax will be added for a Product that was actually purchased and delivered to a Party. The tax amounts are ultimately represented on the invoice as AppliedCustomerBillingTaxRate (or AppliedPartyBillingTaxRate as per the Engaged Party model).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA5_EA1761" ;
    skos:prefLabel "Product Offering Price Tax ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1_EA1826> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1_EA1819> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA1_EA1826" ;
    skos:prefLabel "NEW Product Lifecycle"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA2_EA1864> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA2_EA1861> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA2_EA1864" ;
    skos:prefLabel "NEW ProductOfferingInstance Lifecycle"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA4_EA1_EA2220> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA4_EA2208> ;
    skos:definition "The Customer Facing Service ABE defines the characteristics of a particular CustomerFacingService that represents a realization of a Product within an organization's infrastructure. In contrast, the Resource Facing Service ABE is an abstraction that defines the characteristics of a particular ResourceFacingService which support the network/infrastructure facing part of CustomerFacingService. ResourceFacingServices are \"internal\" Services that are required to support a CustomerFacingService.<br/><br/>Entities in this ABE provide different views to examine, analyze, configure, monitor and repair CustomerFacingServices of all types. Entities in this ABE are derived from Customer Service Specification entities.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA6_EA4_EA1_EA2220" ;
    skos:prefLabel "Customer Facing Service ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA3_EA2546> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA2456> ;
    skos:definition "The Logical Resource Specification ABE is used to define the invariant characteristics and behavior (attributes, methods, constraints, and relationships) of a LogicalResource.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA2_EA3_EA2546" ;
    skos:prefLabel "Logical Resource Specification ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA2_EA2797> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA2749> ;
    skos:definition "<font color=\"#e0121d\"><b>Computing and Software Resources Introduction</b></font><br/><font color=\"#29313b\">The model components presented here demonstrates support for Computing and Software Resources. A number of scenarios are used to demonstrate this support. Note that Computing Resources are not explicitly modelled in the Information Framework (SID). Support for them is shown via the scenarios and associated object (instance) diagrams.</font><br/><font color=\"#29313b\"><br/></font><font color=\"#29313b\"><b>Computing and Software Resource Requirements</b></font><br/><font color=\"#29313b\">Described here are the requirements that drove the development of this part of the SID.</font><br/><ul><li><font color=\"#29313b\">Support the entire software lifecycle processes from ordering through to running software. Some key items: </font></li></ul><ul><li><font color=\"#29313b\">Software inventory (planning to actively installed and running) provided in a manner consistent with hardware inventory</font></li><li><font color=\"#29313b\">Usage and performance management (already supported by the SID)</font></li><li><font color=\"#29313b\">Fault management with the possible addition of enumerations to Probable Cause</font></li><li><font color=\"#29313b\">Configuration, including dependencies <b>to</b> underlying resources and dependencies <b>from</b> applications that rely on given software, for example Application A or Function B may require Software Packages X, Y and Z in order to operate. </font></li><li><font color=\"#29313b\">Activation and deactivation </font></li><li><font color=\"#29313b\">Support running software functionality in a way that is consistent with and integrates with hardware functionality (OSI stack thinking).</font></li><li><font color=\"#29313b\">Support the management of hardware-based resources <u>used by</u> software (CPU, memory, disk)</font></li></ul><ul><li><font color=\"#29313b\">Do we want to consider management of the specific applications and functions supported by a given software instance? This is effectively Application management, for example the management of Software network elements</font></li><li><font color=\"#29313b\">Allow for future support of data centers, including VMs.</font></li></ul><font color=\"#29313b\">There are eTOM impacts implied here as it does not make much mention of Computing and Applications.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA2_EA2797" ;
    skos:prefLabel "Computing and Software Addendum Figures"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA2_EA2948> a skos:Concept ;
