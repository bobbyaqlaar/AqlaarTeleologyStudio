<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA5_EA6628> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA5_EA6627> ;
    skos:definition "An official document issued to record a person's birth, including such identifying data as name, gender, date of birth, place of birth, and parentage.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA5_EA6628" ;
    skos:prefLabel "BirthCertificateIdentification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA5_EA6629> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA5_EA6627> ;
    skos:definition "A registration statement with the a government agency, such as the United States Securities and Exchange Commission in connection with a public offering of securities and must therefore comply with SEC Disclosure requirements.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA5_EA6629" ;
    skos:prefLabel "CompanyRegistration"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA5_EA6630> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA5_EA6627> ;
    skos:definition "A document used to identify a contractor.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA5_EA6630" ;
    skos:prefLabel "ContractorIdentification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA5_EA6631> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA5_EA6627> ;
    skos:definition "A permit, such as one issued by a state's motor vehicle bureau, that allows the holder to drive a motor vehicle on public roads.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA5_EA6631" ;
    skos:prefLabel "DriversLicenseIdentification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA5_EA6632> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA5_EA6627> ;
    skos:definition "A medium, such as a card or document, used to identify an employee.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA5_EA6632" ;
    skos:prefLabel "EmployeeIdentification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA5_EA6633> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA5_EA6627> ;
    skos:definition "Individual Identification represents our registration of information used as proof of identity by an Individual<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA5_EA6633" ;
    skos:prefLabel "IndividualIdentification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA5_EA6634> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA5_EA6627> ;
    skos:definition "A portable document, typically a plasticized card with digitally-embedded information, that someone is required or encouraged to carry as a means of confirming their identity.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA5_EA6634" ;
    skos:prefLabel "NationalIdentityCardIdentification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA5_EA6635> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA5_EA6627> ;
    skos:definition "Organization Identification represents our registration of information used as proof of identity by an Organization<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA5_EA6635" ;
    skos:prefLabel "OrganizationIdentification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA5_EA6636> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA5_EA6627> ;
    skos:definition "Party Identification represents our registration of information used as proof of identity by a Party<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA5_EA6636" ;
    skos:prefLabel "PartyIdentification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA5_EA6637> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA5_EA6627> ;
    skos:definition "Passport information used to Identify an Individual<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA5_EA6637" ;
    skos:prefLabel "PassportIdentification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA5_EA6638> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA5_EA6627> ;
    skos:definition "A document that serves of proof of registration with the United States Social Security Administration.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA5_EA6638" ;
    skos:prefLabel "SocialSecurityNrIdentification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6470> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "<font color=\"#29313b\">At the most fundamental level [Zachman], [Coad-Archetypes] the world can be thought of as comprising of entities that answer the 5 fundamental questions.</font><br/><font color=\"#29313b\">This section of the SID answers the question “who?” and deals with people and organizations in the context of the eTOM, which looks at processes from a Service Provider’s point of view.</font><br/><font color=\"#29313b\">“The eTOM is a business process model or framework that provides the enterprise processes required for a service provider.” [eTOM]</font><br/><font color=\"#29313b\">Organizations can be internal (department, subsidiary) or external to the Service Provider (suppliers, customers).</font><br/><font color=\"#29313b\">Individuals can be internal (employees, board members) or external to the Service Provider (customers, organization contacts, shareholders).</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6470" ;
    skos:prefLabel "Figure P.00 – Showing how Party fits in"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6472> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "The following figure shows our starting point for the model, based on [Fowler-AP], and shows a Party representing an Individual or Organization. <br/>In this model, both organization and organization unit (e.g. consortium, parent company, subsidiary, division, department, branch or team) are represented by the Organization entity.<br/>Organization can also represent government agencies, clubs, societies, charities and educational & religious organizations.<br/>Whilst Party is not a term often used in the business, the concept of “a person or a company” is often heard, and the Party abstraction makes the domain model easier to understand. <br/>Stephen Palmer [Coad Letter] uses the definition that “A party is a legal entity, something or someone that can be sued in a court of law”. But in SID, an Organization might be \"not a legal entity\" as long as it is of interest for the company to know it.<br/>An Organization might be composite or atomic.<br/>AtomicOrganization is a type of Organization that does not have any subordinate Organization. That is, an AtomicOrganization is a leaf-level Organization. <br/>CompositeOrganization is a type of Organization that is formed by aggregating other Organizations, which may be atomic or composite Organizations.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6472" ;
    skos:prefLabel "Figure P.01 - Basic Party Model"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6474> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "A Party may possess one or many PartyAccounts through PartyRoles. <br/>An Account is an arrangement that a Party has with an enterprise (such as a communication service provider) through which the enterprise collects charges to structure bills. <br/>It also collects payments for Products that are supplied by the enterprise to the Party. The charges are invoiced to the Account via bills.<br/>A PartyRole might be evaluated for its worthiness (PartyCreditProfile) and this evaluation might be based on external information (PartyCreditProfileReference). Note: This part is still preliminary and might evolve.<br/>The AccountContact qualifies for an Account a contact point (PartyRole and ContactMedium) such as primary, secondary, and emergency contact.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6474" ;
    skos:prefLabel "Figure P.01a - Party and related Business Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6476> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "An individual is referred to by their name. This name can change over time (e.g. After marriage, by deed poll) and to allow for this we will model an individual’s name as a separate entity. Similarly, organizations can change their names (e.g. from Telecom to Telstra) and we will also model organization names as a separate entity. Note that this model does not provide support for individual name or organization name aliases. If aliases are required, they will be added to a later version of this model.<br/><i>“A name is an informal way of identifying an entity” [Fowler-AP]</i><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6476" ;
    skos:prefLabel "Figure P.02 - Naming for Parties"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6478> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "As well as being having names for Parties, we also need more formal ways of identification [Coad Letter]. When a customer applies for a service, for instance, they may need to provide some proof of identity. The Party Identification entities allow for this information to be stored and accessed as required.<br/>Note that the Party Identification structure has been defined in a similar manner to Party Name.<br/>Concrete subclasses to Individual Identification and Organization Identification should be created as required. Figure 3 shows some common example concrete entities.<br/>The Party Identification Specification entity may be implemented as a Policy, using a Rules Engine or via a set of Templates that detail a valid set of Identification entries sufficient for a given purpose.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6478" ;
    skos:prefLabel "Figure P.03 - Party Identification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6480> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "People and Organizations exhibit complex behavior. A lot of the behavior can be grouped, based on a particular context, or participation in a certain interaction. <br/>For instance, a child at school will behave as a student and an adult may behave as a teacher. A person playing cricket may behave as a bowler, a batsman or as a fielder or wicket-keeper.<br/>These behavior groups will change over time and will cause problems if we model them using inheritance / specialization. Also, we need to allow for the fact that a Party may play more than one role at any given point in time (an employee may also be a customer; a graduate student may also be a tutor).<br/>By modeling PartyRole as a separate concept from Party, we allow for proper representation of these complex sets of behaviors.<br/>When looking at the eTOM, we see that Parties play roles in the context of an interaction to provide Customer value. <br/>This interaction may be per service or per event (e.g. a phone call).<br/><i>“Note that these are roles and that individual enterprises can adopt different roles in different value networks. Roles represent activities that businesses can engage in and, for example, a service provider may be the customer-facing service provider in one value network and a third party (e.g. wholesale) service provider in another. Relationships are established between the roles, hence the business relationship context model. In today’s fast-moving marketplace, relationships can be very short-lived compared with the more static relationships of the traditional telecommunications market. By focusing on roles rather than organizations, a more flexible business relationship context model can be achieved. Enterprises can adopt and shed roles dynamically, but the relationships between the roles are established, so the adoption of a particular role will also define the relationship of the enterprise playing that role towards another role player.” [eTOM]</i><br/>The roles defined in the eTOM are shown as subclasses of PartyRole in Figure P.04 – Party and the Main eTOM Roles.<br/>Note:<br/><ul><li>To support these roles, we will use the “Role Object” pattern [Fowler-Role] [Larman].</li><li>The PartyRole entity represents the common behavior by a Party when acting in the role.</li><li>This model explicitly separates the information held about individuals and organizations from the roles that they perform and the relationships between the roles.</li><li>PartyRole is shown with an id attribute. Existing data may have different id formats for different role types, e.g. “customer number”, “supplier id”, “employee nr” …</li><li>In a value fabric, roles may not be exclusive, e.g. a customer may also be a supplier</li><li>In a number of cases we are interested in parties playing a combination of roles, e.g. staff who use our products get staff discount, suppliers who use our products are “preferred suppliers”</li><li>If the number of roles becomes very large, then it may be necessary to create “sub-roles” so that the inheritance tree does not become unmanageable.</li></ul>Parties & PartyRoles may be recorded, even if there is no interaction with the Service Provider.<br/>e.g. a Service Provider may wish to keep a list of Phone Dealers (including competitors) to help in determining shop placements. The Organizations are stored, with a role of “Phone Dealer”, but there may never be any “Interaction” between the dealers and the Service Provider.<br/>Other roles are governmental entities, such as regulators, law enforcement, and tax. Shareholders also have a place. Such Business Process Framework process areas, such as Stakeholder and External Relations Management and Enterprise Risk Management (Fraud Management processes often engage Law Enforcement parties) and Shareholder & External Relations Management have various modes of engagement with these. <br/>Examples of roles played by parties include those of interest, such as competitors, sales prospects that provides value directly or indirectly, such as service providers, operators, cloud brokers, infrastructure providers and application developers.<br/>So, there is a need to maintain information about many different roles played by parties and for a common set of business process elements with which many roles are involved. <br/>The introduction of a Party ABE in the Common domain with the PartyRole entity in it simplifies interactions among business enablers, enabling other organizations playing new/different roles in the value fabric to be represented in the model in their specific domain as specialization of PartyRole. Companies become more open to sharing information and process visibility. And the community of actors self-select themselves into like-minded communities of parties.<br/>Process flows that show the roles engaged in a scenario or use case can take advantage of the common process elements. It contains information about the entities whose lifecycles are managed by these process elements.<br/>It keeps Frameworx sufficiently agile to not require major structure changes to four of the component frameworks when new roles are introduced.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6480" ;
    skos:prefLabel "Figure P.04 - Party and the Main eTOM Roles"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6482> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "The Market Sales Domain roles presently identified are:<br/><ul><li><b>MarketingCampaignRole</b>: A MarketingCampaignRole is a type of PartyRole involved in OperationalMarketingCampaigns and/or in MarketingCampaigns such as MarketingManager and MarketingOperator.</li><li><b>MarketingManager</b>: Agreed & done: A MarketingManager is a role played by a Party. A MarketingManager is responsible for the Marketing management process. It is the process of developing strategies and planning for product or services, advertising, promotions, sales to reach desired customer segment.</li><li><b>MarketingOperator</b>: The marketing campaign Operator is responsible for executing the campaign. He executes and tracks communication interactions with Parties using Media or communicationModes.</li><li><b>MarketingDesigner</b>: The marketing campaign Designer is responsible for the set-up of the campaign. He generates the target list and produces the campaign follow-up reports. He is in charge to monitor the campaign management performance in real time as the campaign is being executed and to propose corrective actions if necessary.</li><li><b>SalesAgent</b>: A SalesAgent is a role played by a Party. A SalesAgent is responsible for selling the Service Provider’s <font color=\"#29313b\">ProductOfferingSpecifications </font>to wholesale and / or retail customers.</li><li><b>Competitor</b>: A Party playing a PartyRole that offers <font color=\"#29313b\">ProductOfferingSpecifications </font>similar to the enterprise's <font color=\"#29313b\">ProductOfferingSpecifications </font>in a MarketSegment.</li></ul><ul><li><b>Prospect</b>: A Prospect is a type of PartyRole played by a Party specifying the Party is a potential buyer of Products from the Service Provider. A Party playing a SalesLead role may play later several other PartyRoles such as Prospect and eventually Customer. The Party playing a SalesLead might be a Customer for some offers or not. Businesses gain access to sales leads through advertising, trade shows, direct mailings, third parties, and other marketing efforts.</li></ul><p/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6482" ;
    skos:prefLabel "Figure P.04a1 - Market Sales Roles (Copy from MS.00)"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6484> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "The Customer Domain roles presently identified are:<br/><ul><li><b>Customer</b>: A person or organization that buys products from the enterprise or receives free offers or products. This is modelled as a Party playing the role of Customer. A Customer is a type of PartyRole. Customers can also be other service providers who resell the enterprises products, other service providers that lease the enterprise's resources for utilization by the other service provider's products and services, and so forth.</li><li><b>Buyer</b>: A PartyRole played by a Party, who imposed a Supplier to provide a deliverable by a formal Agreement (Commitment).</li><li><b>CustomerServiceRepresentative</b>: Agreed & done: CustomerServiceRepresentative (CSR) is an Employee from the Operator or Dealer. A CSR is in charge of customer relationship, may act on behalf of the customer for sales and in support of the customer.</li></ul><p/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6484" ;
    skos:prefLabel "Figure P.04a2 - Customer Roles (Copy from C.00)"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6486> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "The Product Domain roles presently identified are:<br/><ul><li><b>ProductUser</b>: A ProductUser is a type of PartyRole corresponding to the role of using a NetworkProduct.</li><li><b>ProductManager</b>: Agreed & done: A ProductManager is a party role which is responsible for the development of products for an organization. Product managers own the business strategy behind a product, specify its functional requirements and generally manage the launch of corresponding ProductOfferingSpecifications. They coordinate work done by many other functions (like software engineers, data scientists and product designers) and are ultimately responsible for the business success of the product.</li><li><b>TaxJurisdiction</b>: TaxJurisdiction is a specific party role played by an organization that has the authority to levy tax. The geographic area over which tax can be levied is derived from the base PartyRole class relationship to AdministrativeArea.</li><li><b>LoyaltyProgramMember</b>: A LoyaltyProgramMember is defined on each LoyaltyAccount. A LoyaltyProgramMember is a type of PartyRole and is granted with the rights on the LoyaltyAccount such as to execute LoyaltyBurn used to realize a CustomerPayment.</li></ul><p/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6486" ;
    skos:prefLabel "Figure P.04a3 - Product Roles (Copy from Pr.00)"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6488> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "The Service Domain roles presently identified are:<br/><ul><li><b>ServiceDesigner</b>: Agreed & done: A ServiceDesigner is a party role which is responsible for the design of the Service Provider’ know-how (CustomerFacingServiceSpecs). To be valid a know-how needs to align with one or more technical solutions (ResourceFacingServiceSpec or Supplier’s ProductSpec).</li><li><b>TechnicalSolutionDesigner</b>: A TechnicalSolutionDesigner is a party role which is responsible for the design of technical solutions (ResourceFacingServiceSpec). To be valid a technical solution needs to align with one or more Resources (ResourceSpec or Supplier’s ProductSpec).</li></ul><p/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6488" ;
    skos:prefLabel "Figure P.04a4 - Service Roles (Copy from SO.00)"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6490> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "The Resource Domain roles presently identified are:<br/><ul><li><b>Technician</b>: An individual who possesses specific technical training and competence in a specific area, such as digital services.</li><li><b>ResourceInstaller</b>: An individual who installs PhysicalResources. It specifically doesn't provide all of the capabilities of a Technician role, but also represents a less costly PartyRole. Specifically, a ResourceInstaller is limited to simple physical installation of Equipment. A ResourceInstaller does not configure Resources or Services.</li><li><b>TelecomTechnician</b>: An individual who possesses specific technical training and competence in telecommunications.</li></ul><p/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6490" ;
    skos:prefLabel "Figure P.04a5 - Resource Roles (Copy from R.00)"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6492> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "The Business Partner Domain roles presently identified are:<br/><ul><li><b>Partner</b>: A PartyRole, played by a Party being an equitable partner in a business interaction with other parties, playing the Partner role. Usually all Partner have the same (or even compatible) business objectives.</li><li><b>Supplier</b>: A PartyRole played by a Party, who commits to provide a deliverable to a Buyer by a formal Agreement (Commitment)</li><li><b>Carrier</b>: A Carrier is a type of Supplier played by a Company in charge of shipping material goods.</li></ul><p/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6492" ;
    skos:prefLabel "Figure P.04a6 - Business Partner Roles (Copy from BP.00)"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6494> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "The Enterprise Domain roles presently identified are:<br/><ul><li><b>ServiceProvider</b>: An organization or individual which offers products to others in exchange for payment in some form.</li><li><b>ComplementaryProvider</b>: A type of ServiceProvider that complements another provider.</li><li><b>ThirdPartyProvider</b>: A ServiceProvider besides the two primarily involved in a situation.</li><li><b>ServiceProviderEmployee</b>: A Service ProviderEmployee is an Individual who is employed by the Service Provider for wages or salary. This is modelled as an Individual playing the role of ServiceProviderEmployee. A ServiceProviderEmployee is a type of PartyRole.</li><li><b>Regulator</b>: A party that supervises a particular industry or business activity</li></ul><p/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6494" ;
    skos:prefLabel "Figure P.04a7 - Enterprise Roles (Copy from E.00)"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6496> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "In addition to roles identified in specific Domains, the Common Domain contains roles related to common ABEs. The Common Domain roles presently identified are:<br/><ul><li><b>ProjectPartyRole</b>: A role played in the context of a Project.</li><li><b>WorkforceEmployeeRole</b>: This is a PartyRole that represents individuals who are involved in the workforce process as employees with particular skills. For example, Field Technician, Network Engineer, Supervisor, etc.</li><li><b>WorkforceOrganizationRole</b>: This is a PartyRole that represents organizations involved in field operations. It can be the CSP Field Technician department itself, or a 3rd-party contractor company. Note that OrganizationRole has Calendar, inherited from Calendar of PartyRole.</li></ul><ul><li><b>Community</b>: A Community is a PartyRole, played by an Organization. CommunityMembers can commit to a Community, contribute Contributions to the Community and consume Assets from a Community.</li></ul><ul><li><b>CommunityMember</b>: A CommunityMember is a PartyRole, played by an Individual, who is committing to a Community, contributes to it and consumed Assets from the Community.</li></ul><ul><li><b>CommunityAdministrator</b>: A CommunityAdministrator is a PartyRole, played by a Party, who administers a Community.</li></ul>Other PartyRoles are identified only as examples.<br/><ul><li><b>BusinessOperationEntity</b>: An entity operating its business independently based on its business objective and which a Customer, Partner or other business related PartyRole has an agreement with. For example, from Enterprise’s perspective, BusinessOperationEntity can be used to model MVNO and MVNE. For BusinessOperationEntity, the type of Organization might be company.</li><li><b>FunctionOrProcessProvider</b>: A type of PartyRole that provides functions or processes.</li><li><b>Intermediary</b>: A Party playing a PartyRole, such as a broker or consultant, who acts as a mediator on a link between parties to a business deal, investment decision, negotiation, and so forth.</li></ul><ul><li><b>OrganizationPost</b>: An OrganizationPost is a PartyRole that is used to model where one or more employees share a function.</li><li><b>TechnologyAdministrator</b>: A PartyRole who manages and maintains Resources and Services. Potential subclasses of this class administer specific types of Resources and Services. In general, an Administrator can configure and provision many more features and functions of a Resource or a Service than a Technician can.</li></ul><ul><li><b>Vendor</b>: An individual or organization that sells goods or products to someone else in the value fabric.</li></ul><p/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6496" ;
    skos:prefLabel "Figure P.04a8 - PartyRoles in Common"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6498> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "PartyRole entities can be modeled explicitly as shown in the previous section. However, explicitly modeling them requires a change to the model which can impact databases, interfaces, and applications. The PartyRoleSpecification and PartyRole entities represent the application of the EntitySpecification/Entity pattern.<br/>This pattern enables new roles to be added for parties without explicitly modeling them. There is also an association with the generalized Characteristic ABE that enables attributes for specific instances of PartyRoleSpecifications to be defined as shown in the following Figure. More information about the Characteristic ABE can be found in the Root Business Entities guide book.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6498" ;
    skos:prefLabel "Figure P.04b - Party Role Specification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6500> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "PartyRoleCategory allows for PartyRoles to be categorized (e.g. into Customer Demographics)<br/>A BusinessInteraction will involve one or more Parties playing roles participating in the value fabric to provide Customer value.<br/>A BusinessInteraction may also have links to Product (through BusinessInteractionItem) & Location.<br/>For more information on Business Interaction refer to the corresponding paragraph in this guide book.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6500" ;
    skos:prefLabel "Figure P.05 - Parties Interact Via Their Roles"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6502> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "We need to be able to show associations between Parties playing roles that are not directly involved in the value fabric.<br/>Examples of these associations include<br/><ul><li>Organizational associations in the service provider’s own business (organization unit – employee, organization unit – organization unit)</li><li>Associations in other Organizations participating in the value fabric (organization unit – employee, organization unit – organization unit)</li></ul>PartyRoleAssociation must not be linked to Location, Product or Agreement.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6502" ;
    skos:prefLabel "Figure P.06 - Parties Can Be Associated Via Their Roles"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6504> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "Parties may play PartyRoles in a specific context. This context is represented by a PartyRoleGroup that groups PartyRoles. A PartyRoleGroup might be a Family, a Club, a Friends' group...<br/>A PartyRoleGroup may or may not represent an Organization that has a legal standing or not, meaning they may not have a formal means to identify them (think Facebook groups).<br/>A PartyRoleGroup is described by a unique PartyRoleGroupSpecification.<br/>A PartyRoleGroupSpecification specifies for a type of PartyRoleGroup, the applicable rules for the creation of a PartyRoleGroup:<br/><ul><li>the type of PartyRole (PartyRoleSpecification) that might be part of a corresponding PartyRoleGroup,</li><li>rules (PRGSpecRule) applying for the Party being part of the PartyRoleGroup through their PartyRole such as \"all Parties must live at the same location to be considered as member of the same Family\"</li></ul>The type of PartyRoleGroupSpecification might be a Family, a Club, a group of Friends... <br/><ul><li>A family can include a number of Individuals. The individuals are part of this family (PartyRoleGroup) via PartyRoles such as father, mother, son, and daughter…</li><li>Individuals can also be part of PartyRoleGroups such as a Bridge Club, with PartyRoles such as Member, Chairman/Chairwoman, Treasurer, etc. </li></ul>A PartyRoleGroupSpecification may describe one or many PartyRoleGroups.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6504" ;
    skos:prefLabel "Figure P.06a – PartyRoleGroup"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6506> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "<font color=\"#29313b\">To illustrate, consider an example well-known to all of us.</font><br/><font color=\"#29313b\">The Smith’ Family is composed of four members</font><br/><ul><li><font color=\"#29313b\">Mr. John Smith, the father</font></li><li><font color=\"#29313b\">Mrs. Mary Smith the mother,</font></li><li><font color=\"#29313b\">Mr. Richard Smith the son,</font></li><li><font color=\"#29313b\">and Miss Kathy Smith the daughter.</font></li></ul><font color=\"#29313b\">Each person plays a specific role in the Family.</font><br/><font color=\"#29313b\">Mary Smith also plays the role of Chairwoman and Member in a Bridge Club.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6506" ;
    skos:prefLabel "Figure P.06a.I01 – PartyRoleGroup illustration"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6508> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "ContactMedium linked with Party and PartyRole can be used to interact with them.<br/>ContactMedium is an abstraction of commonly used contact types: email, postal address, telephone etc. According to the ContactMediumSpecification, a Party or PartyRole can be contacted using a CommunicationInteractionMeans. For instance, a mobile phone type enables phone call, SMS, MMS modes to interact.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6508" ;
    skos:prefLabel "Figure P.07 - Contact Medium"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6510> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "<font color=\"#e0121d\"><b>Party ABE Business Entities Examples</b></font><br/><font color=\"#29313b\">A few simplified examples have been included to help understand the model (so this model is not completely consistent with the main model).</font><br/><font color=\"#29313b\">Note that Visio cannot display association class objects, so these are missing from the examples.</font><br/><font color=\"#29313b\">Note that these examples are designed to be instructive. They are not designed to be complete and are simplified to show the main points of the model.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6510" ;
    skos:prefLabel "Figure P.07.I01 – Simplified Class Diagram Used for Examples"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6512> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "<font color=\"#29313b\">Telco is a Service Provider that has two departments, Engineering and Operations. Chris works for Telco, in the Internal plant section of the engineering department.</font><br/><font color=\"#29313b\">Jane is the head of the Engineering department. Jane got married on 23/11/01 and her name changed from Jane Smith to Jane Lamborgizzia. </font><br/><font color=\"#29313b\">Chris was assigned to the post of “Engineering Department Fire Warden” from 22/8/1988 to 25/12/2001.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6512" ;
    skos:prefLabel "Figure P.07.I02 – Organization Hierarchy & Name Change"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6514> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "<font color=\"#29313b\">Telco has a business customer EveDotCom. EveDotCom is also a supplier to Telco.</font><br/><font color=\"#29313b\">Adam is the managing director of EveDotCom and he is also a customer of Telco. Telco has an Internal Communications section to manage its own communication needs.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6514" ;
    skos:prefLabel "Figure P.07.I03 – Value Fabric, Supplier, Customer"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6516> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "<font color=\"#29313b\">Telco is looking at expanding by opening an international section in Germany.</font><br/><font color=\"#29313b\">It is building a list of prospective employees, clients and suppliers.</font><br/><font color=\"#29313b\">Hans is a possible customer. His language abilities are unknown. (He may be from Eastern Europe so we won’t assume he speaks German).</font><br/><font color=\"#29313b\">BayernElectronik are a possible design and construct company (supplier). </font><br/><font color=\"#29313b\">Gretel is a possible employee. She can speak German and good English.</font><br/><font color=\"#29313b\">Telco bought a mailing list containing Hans’s name and has had no contact with him yet.</font><br/><font color=\"#29313b\">Telco has signed a Memorandum of Understanding (MOU) with BayernElectronik.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6516" ;
    skos:prefLabel "Figure P.07.I04 - Prospective Party Roles, Contact Medium & Language Ability"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6518> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "<font color=\"#29313b\">This is a simple example, showing how the SID Party model can be used to represent a matrix organization.</font><br/><font color=\"#29313b\">The matrix is formed by considering both line control & functional control as separate axes of the matrix.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6518" ;
    skos:prefLabel "Figure P.07.I05 – Example 4"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6520> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "A PartyRole can be contacted using a contact medium [ACIA], which is an abstraction of the commonly used contact types: email, Postal Address, telephone, fax, etc. We model a PartyRole to having contact mediums rather than a Party. This allows us to cater for role based e-mail addresses and work queues and Contact Details for a POST.<br/>Another way to contact parties is by Media via a CommunicationInteractionRole. This is a mechanism by which processes such as “Marketing Campaign Management” and “Marketing Communications and Advertising” advertise broadly to parties. It describes such mechanisms as the press, radio, trade shows, internet, and so forth.<br/>To allow for international usage, we also model the languages and dialects that Parties are able to use. Language Ability tells us which languages a party can converse in. <br/>The Language entity links to Party, not Individual, as it also allows us to represent languages that an Organization supports. For instance, a Service Provider may provide interpreters in certain languages for Customer inquiries.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6520" ;
    skos:prefLabel "Figure P.07a - Contacting a Party"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6522> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "The following Figure shows possible links to other Parts of the SID Model with the main Party classes and the expected connections to other parts of the SID model.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6522" ;
    skos:prefLabel "Figure P.08 - Showing Possible Links to Other Parts of the SID Model"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6524> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "A PartyProfileSpec is a type of AtomicSegmentSpecification to specify rules for classifying Parties or PartyRoles.<br/>A PartyProfile is a type of AtomicSegment that classifies Party’s or PartyRole’s instances for which the CriterionCondition is “True” when it is built.<br/>A PartyProfile is the result of applying a PartyProfileSpec when a triggering Event occurs.<br/>A DemographicSegment is a type of PartyProfile where corresponding rules are based on feature or quality of the Party such as age, income, education, revenue, and so forth.<br/>A MarketSegment is a type of PartyProfile that groups Parties. MarketSegments are the target of MarketingCampaigns, ProductOfferingSpecifications, product promotions, product placements, and product programs from both internal and external (Competitors, and other Suppliers) perspective.<br/>Please refer to the Common guide book section Segmentation ABE for additional information.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6524" ;
    skos:prefLabel "Figure P.09 - Party Role and Party Profile Spec overview"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6526> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "A PartyProfileSpec defines the criterion used to group Parties that may typify MarketSegments or specifies the formulation of criteria for targeting of MarketingCampaigns. A PartyProfileSpec might be used to categorize PartyRoleSpecifications. In this case, the resulting PartyProfiles categorize PartyRoles else they categorize directly one or many PartiesTypes.<br/>A PartyProfileSpec can be defined for one or more GeographicAreas. <br/>The profile spec can target one or more ProductOfferingSpecifications and one or more MarketSegments. <br/>PartyProfileSpecs can be based on (or defined by) demographic characteristics or any other type of characteristics (croterion).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6526" ;
    skos:prefLabel "Figure P.10 - Party Profile Specification Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6528> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "A MarketSegment is a type of PartyProfile that groups Parties. MarketSegments are the target of MarketingCampaigns, ProductOfferingSpecifications, product promotions, product placements, and product programs from both internal and external (Competitors, and other Suppliers) perspective.<br/>Please refer to the Common Pattern guide book section Segmentation ABE for additional information.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6528" ;
    skos:prefLabel "Figure P.11 - Party Profile inheritance"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6530> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "Demographics deal with the study of individuals and organizations (Parties), including their size, growth, density, and distribution, as well as statistics regarding birth, marriage, disease, and death. Demographic data is information about parties that allows decisions to be made such as the make-up and size of a market segment, classification and ranking of customers, and so forth. Demographics provide the key “what” information and can be broken down into two categories: individual demographics and organization demographics.<br/>Individual demographic data provides information pertaining to the consumer market. Examples of this type of demographic are:<br/><ul><li>Age, income, education, vehicle registration, gender, ethnicity, and the source of the information</li><li>Geography, or sizing, demographics </li><li>Number of households</li><li>Number of telephone lines (single vs. multiple, switched vs. dedicated)</li><li>Population</li><li>Telecom spending by segment related back to another demographic (wireless, calling features, calling card, etc.)</li></ul>Organization demographic data provides information pertaining to the non-consumer market. Examples of business demographic data are: <br/><ul><li>Standard industry (SIC) code (for vertical industries)</li><li>Geographic dispersal</li><li>Headquarters location, number and location of offices (domestic vs. international, regions/triads); each have different access requirements</li><li>By hierarchy (headquarters vs. regions vs. sales offices)</li><li>Existing networks</li><li>Private vs. frame relay</li><li>WAN/LAN (in every office vs. stand-alone)</li><li>By SIC code (partially)</li><li>Network equipment</li><li>Centralized vs. distributed processing</li></ul><ul><li>Applications (Human Resources, Payroll, FTP, Intranet, and so forth)</li><li>Voice mail, audio/video</li><li>Infrastructure setup (type of computer) by geography</li><li>Usage (switched vs. dedicated, intra-company vs. intercompany)</li><li>Features (large sales force could indicate use of calling cards); related to number and type of employees</li><li>Number of employees by type (for example, sales force)</li><li>Number of customers and prospects</li><li>Geographies covered</li><li>Target markets</li><li>Sales channels </li><li>Current telecom spending by product (inbound vs. outbound vs. calling card)</li></ul><ul><li>Date acquired, current provider, provider products</li><li>Percent of existing telecom bill spent with the service provider by product</li><li>Public information (revenue, profit, employees, and so forth)</li></ul>The business entities that support PartyDemographic (and also support PartyProfileType and MarketSegment as described later) should be generic enough to allow new demographic characteristics and other types of characteristics to be defined as needed. To accomplish this, the Demographic entity employs the Characteristic Spec/Characteristic pattern used throughout the SID. PartyDemographic also employs the Composite/Atomic pattern to represent collections of related DemographicCharacteristics.<br/><i>Note: This pattern is used throughout the Market/Sales domain. Additional information about the Characteristic pattern can be found in GB922 Root guide book. The application of the pattern in the Market/Sales domain does not use all the association classes defined by the pattern; if needed, they can be added by a SID implementer.</i><br/>An example of the use of the Composite/Atomic pattern from the list of example demographics above is a CompositeDemographicCharacteristic called “employee type and number” that aggregates the AtomicDemographicCharacteristics “type employee” and “number of employees”.<br/>The DemographicCharacteristicValues for \"type employee\" might be engineer, salesperson, administrator and the values for \"\"number of employee\" might be 0-50, 51-100, 101-500, +500.<br/>A PartyDemographic is a feature or quality used to make recognizable or to define a Party playing a PartyRole, such as age, income, education, revenue, and so forth. The figure below shows the entities that make up the PartyDemographic ABE. Notice that PartyDemographic also uses the Composite/Atomic pattern for defining PartyDemographics that are aggregates of other PartyDemographics. For example, a standard of living composite may be the aggregation of income level, value of investments, and home value (assuming a home is not an investment!).<br/>Note that one of the members of the associations from PartyDemographicValue to DemographicCharacteristic and DemographciCharacteristicValue are of cardinality of 0,1. This is because not all DemographicCharacteristics have a set of defined values. For example, a characteristic of children’s names does not have set of “valid” values, but is entered as text for an instance of PartyDemographicValue; in this example there is not an instance of the association between PartyDemographicValue and DemographicCharacteristicValue. Similarly, if there is a set of DemographicCharacteristic values (1, 2, 3 or more) for number of children living at home, there is an instance of the association between PartyDemographicValue and DemographicCharacteristicValue, but not one between PartyDemographicValue and DemogrpahicCharacteristic. This second association is derived via the first association.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6530" ;
    skos:prefLabel "Figure P.12 - Demographic Characteristic Business Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6532> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "PartyDemographics characterize a single PartyRole. There was thought given to describing both PartyDemographics and PartyRoleDemographics. However, as was done with PartyRoleContacts, having demographics at both the Party and PartyRole seemed to be a bit of over-modeling. Therefore, if the same demographic characterizes two or more PartyRoles played by the same Party, the demographic is repeated for each role.<br/>PartyDemographics can also be defined in part by a ProductOfferingSpecification that a Party has obtained and/or used. For example, the number of minutes of long distance used within a Calling Plan offering.<br/>PartyDemographics can also be grouped by GeographicArea and MarketSegment.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6532" ;
    skos:prefLabel "Figure P.13 - Party Demographics Business Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6534> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "Parties and PartyRoles can possess a number of skills. Each skill is specified (defined), maintained in a SkillCatalog and associated with a PartyRole as shown in the following Figure.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6534" ;
    skos:prefLabel "Figure P.14 - Parties and Skills"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6536> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "First of all, a Community is a PartyRole, played by a Party of type organization. Parties of type Individual can play the PartyRole of a CommunityMember. The “plain membership” may be expressed by a PartyRoleAssociation between those both PartyRoles.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6536" ;
    skos:prefLabel "Figure P.15 - Committing to a Community"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6538> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "A Contribution to a community is a sub-class of BusinessInteraction with CommunityMember and Community as involved PartyRoles. For this new type of BusinessInteraction, two new BusinessInteractionRoles are introduced: ContributionProviderRole, associated with the CommunityMember who is contributing, and the ContributionReceiverRole, associated with the Community.<br/>A Contribution might consist of BusinessInteraction item, a Resource, Service or Product is associated to, which is contributed to the Community.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6538" ;
    skos:prefLabel "Figure P.17 - Contributing to a Community"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6540> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "Contributions are assembled to Assets by the community – i.e. multiple Contributions, contributed by different CommunityMembers may be assembled together to one consumable asset.<br/>Examples for assets are open source software; in that case the source code might be contributions of various CommunityMembers. Another example is Facebook; the original post and the comments are contributions, provided by different CommunityMembers, a whole discussion thread is an asset that can be consumed by other CommunityMembers.<br/>Consuming an Asset from a Community, again, is a BusinessInteraction, which items are associated to Products, which is the consumed asset. That product might be instantiated from a ProductOfferingSpecification and associated to a ProductPrice, so it possible to model Assets with a price, too.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6540" ;
    skos:prefLabel "Figure P.18 - Consuming Assets from a Community"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6542> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "BusinessOperationEntity is an entity operating its business independently based on its business objective and which a Customer, Partner or other business related PartyRole has an agreement with. For example, from Enterprise’s perspective, BusinessOperationEntity can be used to model MVNO and MVNE. For BusinessOperationEntity, the type of Organization might be company. <br/>It may have organization hierarchy and the lower BusinessOperationEntity may inherit the upper BusinessOperationEntity’s strategy and have its own one. E.g.: Headquarter and divisions. AtomicOrganization is a type of Organization that does not have any subordinate Organization. That is, an AtomicOrganization is a leaf-level Organization. CompositeOrganization is a type of Organization that is formed by aggregating other Organizations, which may be atomic Organizations or OrganizationDecompositionComponents. OrganizationDecompositionType describes and specifies certain type of organization decomposition. OrganziationDecompositionComponent describes certain component after organization decomposition based on defined type by OrganizationDecompositionType.<br/>BusinessOperationEntity may use different Logo, Language and Currency (including CurrencyExchangeRate related to Currency).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6542" ;
    skos:prefLabel "Figure P.19 – Organization structure, Currency and Business Operation Entity"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6544> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "The Currency represents the currency in reality. <br/>CurrencyUnit is measurement unit of a Currency. Currency uses 1 or more CurrencyUnits. For example, Currency (code=CNY, symbol= ￥) uses three CurrencyUnits (Yuan, Jiao, Fen). <br/>Each CurrencyUnit might have a specific name according to the Language (CurrencyUnitName). For CurrencyUnitName Yuan associated to Language (alphabetName=Chinese), CurrencyUnit (rate =1, isStadUnit = True, isMinUnit = False).<br/>Under different languages, a CurrencyUnit has different names, e.g Yuan in English and 元 in Chinese to express the same basic currency unit in Chinese currency. <br/>A Currency might be exchanged with a specific rate. So Currency is associated to many CurrencyExchangeRates with CurrencyUsedAsSource and CurrencyUsedAsDestination relationships.<br/>Currency can be used in many different Countries and for each language a specific name might exist (CurrencyName) such as Renminbi Yuan in English and 人民币元 in Chinese to express the same Chinese currency.<br/>PartyRoleCurrency represents the currency that PartyRole may use.<br/>AccountCurrency represents the currency that might be used for producing bills related to the Account. One of them specifies the default Currency used.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6544" ;
    skos:prefLabel "Figure P.20 - Currency Model"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6547> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6547" ;
    skos:prefLabel "EARoot_EA4_EA2_EA11_EA1_EA6547"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6548> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6548" ;
    skos:prefLabel "EARoot_EA4_EA2_EA11_EA1_EA6548"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6549> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6549" ;
    skos:prefLabel "EARoot_EA4_EA2_EA11_EA1_EA6549"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6550> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6550" ;
    skos:prefLabel "EARoot_EA4_EA2_EA11_EA1_EA6550"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6551> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6551" ;
    skos:prefLabel "EARoot_EA4_EA2_EA11_EA1_EA6551"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6552> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6552" ;
    skos:prefLabel "EARoot_EA4_EA2_EA11_EA1_EA6552"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6553> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6553" ;
    skos:prefLabel "EARoot_EA4_EA2_EA11_EA1_EA6553"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6554> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "There will ber rules defining the types of Party that can play roles, Party Roles combinations & the interaction types that Party roles can peform.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6554" ;
    skos:prefLabel "EARoot_EA4_EA2_EA11_EA1_EA6554"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6555> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "There will be rules defining the types of Party that can play roles, Party Roles combinations & the interaction types that Party roles can perform.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6555" ;
    skos:prefLabel "EARoot_EA4_EA2_EA11_EA1_EA6555"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6556> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "Remove BusinessInteraction and BusinessInteractionRole from this diagram.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6556" ;
    skos:prefLabel "EARoot_EA4_EA2_EA11_EA1_EA6556"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6557> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "Remove OrganizationDecompositionComponent and OrganizationDecompositionType from this figure.<br/>This figure is an introduction. Details on organization are provided in figure P.19<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6557" ;
    skos:prefLabel "EARoot_EA4_EA2_EA11_EA1_EA6557"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6558> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "A person or organization that buys products and services from the enterprise or receives free offers or services. This is modeled as a Party playing the role of Party. A Party is a type of PartyRole. Partys can also be other service providers who resell the enterprises products, other service providers that lease the enterprise's resources for utilization by the other service provider's products and services, and so forth.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6558" ;
    skos:prefLabel "AdditionalPartyAttributes"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6561> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "Represents a single human being (a man, woman or child).<br/><br/>The individual could be a customer, an employee or any other person that the organization needs to store information about. An Individual is a type of Party.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6561" ;
    skos:prefLabel "Individual"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6562> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "A word, term, or phrase by which an individual is known and distinguished from other individuals.A name is an informal way of identifying an object [Fowler]This entity allows for international naming variations. An IndividualName is a type of PartyName.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6562" ;
    skos:prefLabel "IndividualName"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6563> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "Represents a spoken and/or written language.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6563" ;
    skos:prefLabel "Language"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6564> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "Represents the ability of a Party to understand or converse in a Language<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6564" ;
    skos:prefLabel "LanguageAbility"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6565> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "Logo of Organization.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6565" ;
    skos:prefLabel "Logo"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6566> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "A group of people identified by shared interests or purpose. Examples include business, department, enterprise. Because of the complex nature of many businesses, both organizations and organization units are represented by the same business entity in this model. An Organization is a type of Party.<br/><br/>An Organization might be composite or atomic.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6566" ;
    skos:prefLabel "Organization"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6567> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "A word, term, or phrase by which an organization is known and distinguished from other organizations.A name is an informal way of identifying an object [Fowler]An OrganizationName is a type of PartyName.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6567" ;
    skos:prefLabel "OrganizationName"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6568> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "Represents an individual, organization or organization unit.Party is an abstract concept that should be used in places where the business says something can be an organization , organization unit or an individual<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6568" ;
    skos:prefLabel "Party"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6576> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "An outline of a Party's credit worthiness.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6576" ;
    skos:prefLabel "PartyCreditProfile"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6577> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "A source of information that helps define a Party's credit worthiness.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6577" ;
    skos:prefLabel "PartyCreditProfileReference"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6578> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "A word, term, or phrase by which a party (individual or organization) is known and distinguished from other parties.A name is an informal way of identifying an object [Fowler].PartyName is an abstract concept that should be used in places where the business refers to an organization name, organization unit name or individual name<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6578" ;
    skos:prefLabel "PartyName"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6579> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "The part played by a party in a given con text with any characteristics, such as expected pattern of behavior, attributes, and/or associations that it entails. PartyRole should be used in places where the business refers to a Party playing a Role.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6579" ;
    skos:prefLabel "PartyRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6580> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "Allows PartyRoles to be associated.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6580" ;
    skos:prefLabel "PartyRoleAssociation"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6581> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "This is an entity that can be used to provide simple grouping or categorization of PartyRoles. In some cases this is done in a more specific manner (e.g. Customer demographics).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6581" ;
    skos:prefLabel "PartyRoleCategory"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6582> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "Represents the currency that PartyRole may use.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6582" ;
    skos:prefLabel "PartyRoleCurrency"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6583> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "The definition of a role a party may play. this is \"#gt;<font color=\"#0000ff\"><u>entityone</u></font></a> Task<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6583" ;
    skos:prefLabel "PartyRoleSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6585> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "The certificate describing an exemption from tax (partial or complete) granted for a party and/or a place. <br/><br/>Examples include:<br/><br/> - Party-based<br/><br/> - Individual might be exempt due to health or other personal situation<br/><br/> - Organization might be exempt due to its business (e.g. a charity, or government)<br/><br/> - Location-based<br/><br/> - A City might have a global exemption from purchase tax<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6585" ;
    skos:prefLabel "TaxExemptionCertificate"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6_EA6639> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6_EA6641> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Party Organization </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6_EA6639" ;
    skos:prefLabel "Figure PO.01 - Party Organization ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6_EA6642> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6_EA6641> ;
    skos:definition "AtomicOrganization is a type of Organization that does not have any subordinate Organization. That is, an AtomicOrganization is a leaf-level Organization.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6_EA6642" ;
    skos:prefLabel "AtomicOrganization"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6_EA6643> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6_EA6641> ;
    skos:definition "CompositeOrganizaiton is a type of Organization that is formed by aggregating other Organizations, which may be atomic or composite Organizations.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6_EA6643" ;
    skos:prefLabel "CompositeOrganization"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6_EA6644> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6_EA6641> ;
    skos:definition "The OrganizationDecompositionComponent specifies the valid period for the relationship between CompositeOrganization and Organization and relates to the OrganizationDecompositionType.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6_EA6644" ;
    skos:prefLabel "OrganizationDecompositionComponent"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6_EA6645> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6_EA6641> ;
    skos:definition "OrganizationDecompositionType describes and specifies certain type of organization decomposition such as geographical, hierarchical, financial.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA6_EA6645" ;
    skos:prefLabel "OrganizationDecompositionType"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA7_EA6646> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA7_EA6648> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Party Profile </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA7_EA6646" ;
    skos:prefLabel "Figure PyP.01 - Party Profile ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA7_EA6649> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA7_EA6648> ;
    skos:definition "A match between a Party and a PartyProfileType. It is based on matching PartyDemographics and other Party characteristics, such as use of a product, with the characteristics of a PartyProfileType.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA7_EA6649" ;
    skos:prefLabel "PartyProfile"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA7_EA6650> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA7_EA6648> ;
    skos:definition "Characteristics used for classifying Parties for the formulation and targeting of MarketingCampaigns. ProfileTypes can be based on PartyDemographics, GeographicAreas, ProductOfferings, and MarketSegments. User-defined DataPoints can also be specified.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA7_EA6650" ;
    skos:prefLabel "PartyProfileSpec"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA8_EA6651> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA8_EA6653> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Party Role Examples</b> Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA8_EA6651" ;
    skos:prefLabel "Figure PRE.01 - Party Role Examples ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA8_EA6654> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA8_EA6653> ;
    skos:definition "An entity operating its business independently based on its business objective and which a Customer, Partner or other business related PartyRole has an agreement with. For example, from Enterprise’s perspective, BusinessOperationEntity can be used to model MVNO and MVNE. For BusinessOperationEntity, the type of Organization might be company.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA8_EA6654" ;
    skos:prefLabel "BusinessOperationEntity"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA8_EA6655> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA8_EA6653> ;
    skos:definition "A type of PartyRole that provides functions or processes.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA8_EA6655" ;
    skos:prefLabel "FunctionOrProcessProvider"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA8_EA6656> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA8_EA6653> ;
    skos:definition "A Party playing a PartyRole, such as a broker or consultant, who acts as a mediator on a link between parties to a business deal, investment decision, negotiation, and so forth.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA8_EA6656" ;
    skos:prefLabel "Intermediary"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA8_EA6657> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA8_EA6653> ;
    skos:definition "An OrganizationPost is a PartyRole that is used to model where one or more employees share a function.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA8_EA6657" ;
    skos:prefLabel "OrganizationPost"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA8_EA6658> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA8_EA6653> ;
    skos:definition "A PartyRole who manages and maintains Resources and Services. Potential subclasses of this class administer specific types of Resources and Services. In general, an Administrator can configure and provision many more features and functions of a Resource or a Service than a Technician can.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA8_EA6658" ;
    skos:prefLabel "TechnologyAdministrator"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA8_EA6659> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA8_EA6653> ;
    skos:definition "An individual or organization that sells goods or products to someone else in the value fabric.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA8_EA6659" ;
    skos:prefLabel "Vendor"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA9_EA6660> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA9_EA6662> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Party Role Group </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA9_EA6660" ;
    skos:prefLabel "Figure PRG.01 - Party Role Group ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA9_EA6663> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA9_EA6662> ;
    skos:definition "Parties may play PartyRoles in a specific context. This context is represented by a PartyRoleGroup that groups PartyRoles. A PartyRoleGroup might be a Family, a Club, a Friends' group...<br/><br/>A PartyRoleGroup may or may not represent an Organization that has a legal standing or not, meaning they may not have a formal means to identify them (think Facebook groups).<br/><br/>A PartyRoleGroup is described by a unique PartyRoleGroupSpecification.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA9_EA6663" ;
    skos:prefLabel "PartyRoleGroup"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA9_EA6664> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA9_EA6662> ;
    skos:definition "A PartyRoleGroupSpecification specifies for a type of PartyRoleGroup, the applicable rules for the creation of a PartyRoleGroup:<br/><br/>- the type of PartyRole (PartyRoleSpecification) that might be part of a corresponding PartyRoleGroup,<br/><br/>- rules (PRGSpecRule) applying for the Party being part of the PartyRoleGroup through their PartyRole such as \"all Parties must live at the same location to be considered as member of the same Family\"<br/><br/>The type of PartyRoleGroupSpecification might be a Family, a Club, a group of Friends... <br/><br/>- A family can include a number of Individuals. The individuals are part of this family (PartyRoleGroup) via PartyRoles such as father, mother, son, and daughter…<br/><br/>- Individuals can also be part of PartyRoleGroups such as a Bridge Club, with PartyRoles such as Member, Chairman/Chairwoman, Treasurer, etc. <br/><br/>A PartyRoleGroupSpecification may describe one or many PartyRoleGroups.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA9_EA6664" ;
    skos:prefLabel "PartyRoleGroupSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA9_EA6665> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA9_EA6662> ;
    skos:definition "A PRGSpecClub is a type of PartyRoleGroupSpecification specifying rules applying for being member of a Club.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA9_EA6665" ;
    skos:prefLabel "PRGSpecClub"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA9_EA6666> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA9_EA6662> ;
    skos:definition "A PRGSpecFamily is a type of PartyRoleGroupSpecification specifying rules applying for being part of a Family.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA9_EA6666" ;
    skos:prefLabel "PRGSpecFamily"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA9_EA6667> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA9_EA6662> ;
    skos:definition "A PRGSpecFriends is a type of PartyRoleGroupSpecification specifying rules applying for being member of a Friends Group.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA9_EA6667" ;
    skos:prefLabel "PRGSpecFriends"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA9_EA6668> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA9_EA6662> ;
    skos:definition "A PRGSpecRule is a type of PolicyRule specifying rules that have to be checked up to allow a PartyRole to be part of a PartyRoleGroup. For example, \"all Parties must live at the same location to be considered as member of the same Family\".<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA9_EA6668" ;
    skos:prefLabel "PRGSpecRule"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6675> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6685> ;
    skos:definition "PermissionSpecSet specifies a set of permissions that might concern one or many PartyRoleSpecifications or one or many ResourceRoleSpecifications. Each PermissionSet may refer to a PermissionSpecSet if it corresponds to applying permissions specified for a PartyRoleSpecification. If PermissionSet corresponds to permissions granted by another PartyRole it has no relationship with a PermissionSpecSet.<br/>Any Entity of the model may enable actions (RootEntityTypeAction). Ex: A Contract (ProductBundle) might be created, updated or removed.<br/>Some actions can be defined on the RootEntityType and not available for a PartyRoleSpecification such as the “change email@” that isn’t available for Users.<br/><i>Note: An action might refer to a business process such as Customer Order Handling</i><br/>ImplicitPermissionSpec defines one or many actions allowed on a type of Entity (RootEntityType). A PermissionSpecSet contains one or many ImplicitPermissionSpec.<br/>When a PartyRole corresponds to a PartyRoleSpec it benefits from all implicit permissions on its own Entities (RootEntity).<br/>A Party playing a role may delegate all or part of his permissions to another Party through ExplicitPermission.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA2_EA6675" ;
    skos:prefLabel "Figure Perm.01 - Roles and Permission"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6677> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6685> ;
    skos:definition "The Permission specification defines that all PartyRole corresponding to PartyRoleSpecification Customer will have all the same implicit permission (i.e. default permission) on the Contract and CustomerBillingAccount they own.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA2_EA6677" ;
    skos:prefLabel "Figure Perm.01.I01 – PermissionSpec for Customer PartyRoleSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6679> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6685> ;
    skos:definition "John Smith owns “My Broadband Contract” and therefore he plays the Role of Customer on it.<br/>The PartyRole Customer played by John Smith corresponds to the PartyRoleSpecification “Customer”, “My Broadband Contract” corresponds to the RootEntityType “ProductBundle/Contract” and “JS BillingAccount” to the RootEntityType “CustomerBillingAccount”.<br/>According to the Permission specification, implicit permissions on “My Broadband Contract” and “John Smith BA” will be allocated to the role Customer played by John Smith.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA2_EA6679" ;
    skos:prefLabel "Figure Perm.01.I02 – PermissionSpec and Permission for Customer PartyRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6681> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6685> ;
    skos:definition "PermissionSpecSet / PermissionSet and ImplicitPermissionSpec / ImplicitPermission applies the EntitySpec / Entity pattern.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA2_EA6681" ;
    skos:prefLabel "Figure Perm.02 - Permission inheritance"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6683> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6685> ;
    skos:definition "We also may need to specify a scope for the permissions.<br/>PermissionScopeSpec defines through PermissionScopeSpecPolicyRuleSpec criteria that might be used to define the scope such as market segment, geographic area, time…<br/>To describe these criteria that might be complex a PermissionScopeSpec might be managed by one or many PolicyRuleSpec (PermissionScopeSpecPolicyRuleSpec).<br/>PermissionScope specifies for each criteria the value(s) for the Permission if different values are possible in the PermissionScopeSpec.<br/>To describe these criteria that might be complex a PermissionScopeSpec might be managed by one or many PolicyRuleSpec (PermissionScopeSpecPolicyRuleSpec).<br/>The PermissionScopePolicyRule inherits from PolicyRule and PermissionScopeSpecPolicyRuleSpec inherits from PolicyRuleSpec.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA2_EA6683" ;
    skos:prefLabel "Figure Perm.03 - Permission Scope"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6686> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6685> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA2_EA6686" ;
    skos:prefLabel "EARoot_EA4_EA2_EA11_EA2_EA6686"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6687> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6685> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA2_EA6687" ;
    skos:prefLabel "EARoot_EA4_EA2_EA11_EA2_EA6687"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6688> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6685> ;
    skos:definition "*<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA2_EA6688" ;
    skos:prefLabel "EARoot_EA4_EA2_EA11_EA2_EA6688"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6689> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6685> ;
    skos:definition "A Party playing a role may delegate all or part of his permissions to another Party through ExplicitPermission.<br/><br/>ExplicitPermission is a type of Permission.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA2_EA6689" ;
    skos:prefLabel "ExplicitPermission"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6690> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6685> ;
    skos:definition "An ImplicitPermission is a type of Permission and describes permissions granted to a PartyRole according to an ImplicitPermissionSpec.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA2_EA6690" ;
    skos:prefLabel "ImplicitPermission"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6691> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6685> ;
    skos:definition "ImplicitPermissionSpec defines one or many actions allowed on a type of Entity (RootEntityType).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA2_EA6691" ;
    skos:prefLabel "ImplicitPermissionSpec"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6692> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6685> ;
    skos:definition "Permission represents permissions granted to a PartyRole that might be either implicit (ImplicitPermission) or explicit through delegation (ExplicitPermission).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA2_EA6692" ;
    skos:prefLabel "Permission"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6693> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6685> ;
    skos:definition "PermissionScope specifies for each criteria the value(s) for the Permission if different values are possible in the PermissionScopeSpec.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA2_EA6693" ;
    skos:prefLabel "PermissionScope"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6694> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6685> ;
    skos:definition "PermissionScopePolicyRule is used for describing PermissionScope criterias and the value(s) that limit the scope of permission.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA2_EA6694" ;
    skos:prefLabel "PermissionScopePolicyRule"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6695> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6685> ;
    skos:definition "PermissionScopeSpec defines through PermissionScopeSpecPolicyRuleSpec criteria that might be used to define the scope such as market segment, geographic area, time…<br/><br/>To describe these criteria that might be complex a PermissionScopeSpec might be managed by one or many PolicyRuleSpec (PermissionScopeSpecPolicyRuleSpec).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA2_EA6695" ;
    skos:prefLabel "PermissionScopeSpec"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6696> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6685> ;
    skos:definition "PermissionScopeSpecPolicyRuleSpec is used for describing PermissionScopeSpec criterias and the possible values.<br/><br/>To describe these criteria that might be complex a PermissionScopeSpec might be managed by one or many PermissionScopeSpecPolicyRuleSpec.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA2_EA6696" ;
    skos:prefLabel "PermissionScopeSpecPolicyRuleSpec"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6697> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6685> ;
    skos:definition "Each PermissionSet may refer to a PermissionSpecSet if it corresponds to applying permissions specified for a PartyRoleSpecification. If PermissionSet corresponds to permissions granted by another PartyRole it has no relationship with a PermissionSpecSet.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA2_EA6697" ;
    skos:prefLabel "PermissionSet"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6698> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6685> ;
    skos:definition "PermissionSpecSet specifies a set of permissions that might concern one or many PartyRoleSpecifications. A PermissionSpecSet contains one or many ImplicitPermissionSpec.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA2_EA6698" ;
    skos:prefLabel "PermissionSpecSet"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6699> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6685> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA2_EA6699" ;
    skos:prefLabel "XOR"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6700> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA2_EA6685> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA2_EA6700" ;
    skos:prefLabel "XOR"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA1_EA6738> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA1_EA6740> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Party Privacy Profile </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA3_EA1_EA6738" ;
    skos:prefLabel "Figure PPP.01 - Party Privacy Profile ABE and Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA1_EA6741> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA1_EA6740> ;
    skos:definition "A PartyPrivacyAgreement is a type of ContractualAgreement. It enables tracking the approval made by the Party either globally for a PartyPrivacyProfile or just for a specific PartyPrivacyProfileCharValue.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA3_EA1_EA6741" ;
    skos:prefLabel "PartyPrivacyAgreement"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA1_EA6742> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA1_EA6740> ;
    skos:definition "A PartyPrivacyProfile corresponds of the instantiation of a PartyPrivacyProfileType agreed by a PartyRole.<br/><br/>The PartyPrivacyProfile is described by the Privacy choices made by the Party (related PartyPrivacyProfileCharValue).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA3_EA1_EA6742" ;
    skos:prefLabel "PartyPrivacyProfile"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA1_EA6743> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA1_EA6740> ;
    skos:definition "Each PartyPrivacyProfileCharValue instantiates a PartyPrivacyProfileTypeCharValue and specifies the chosen value.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA3_EA1_EA6743" ;
    skos:prefLabel "PartyPrivacyProfileCharValue"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA2_EA6744> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA2_EA6746> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Party Privacy Profile Type </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA3_EA2_EA6744" ;
    skos:prefLabel "Figure PPPT.01 - Party Privacy Profile Type ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA2_EA6747> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA2_EA6746> ;
    skos:definition "A PartyPrivacyProfileType is a type of PartyProfileType.<br/><br/>A PartyPrivacyProfileType specifies for a Party playing a type of PartyRole (PartyRoleSpecification) such as Customer or User and possibly restricted to a context such as a set of ProductOfferings, all the available options that the Party may choose for each information concerned by the Privacy.<br/><br/>A PartyPrivacyProfileType may specify Privacy for several information using PartyPrivacyProfileTypeCharacteristic.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA3_EA2_EA6747" ;
    skos:prefLabel "PartyPrivacyProfileType"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA2_EA6748> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA2_EA6746> ;
    skos:definition "Each PartyPrivacyProfileTypeCharacteristic specifies:<br/>• the information concerned by the Privacy (CharacteristicSpecification via RootEntityTypeCharUse),<br/>• and the corresponding Privacy rule (i.e. available choices for the party) using PartyPrivacyProfileTypeCharValue.<br/>A PartyPrivacyProfileTypeCharacteristic has a privacyType such as “Internal Purpose”, “External Purpose”, “Internal Retention” or “External Retention”.<br/>If the privacyType is “Internal Purpose” or “External Purpose”, then the PartyPrivacyProfileTypeCharacteristic specifies the usage purpose of the information concerned by the privacy such as Administration, Marketing, Research…<br/>Each PartyPrivacyProfileTypeCharacteristic is categorized by a PrivacyCategory for helping Graphical User Interface (GUI) to have a nice presentation for Privacy viewing and configuration.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA3_EA2_EA6748" ;
    skos:prefLabel "PartyPrivacyProfileTypeCharacteristic"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA2_EA6749> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA2_EA6746> ;
    skos:definition "A PartyPrivacyProfileTypeCharValue specifies a confuguration that can be chosen for an information in a Privacy context.<br/><br/>For example, the usage of an information might Authorized or Unauthorized.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA3_EA2_EA6749" ;
    skos:prefLabel "PartyPrivacyProfileTypeCharValue"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA2_EA6750> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA2_EA6746> ;
    skos:definition "A PrivacyCategory specifies a category grouping PartyPrivacyProfileTypeCharacteristic for helping Graphical User Interface (GUI) to have a nice presentation for Privacy viewing and configuration.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA3_EA2_EA6750" ;
    skos:prefLabel "PrivacyCategory"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA2_EA6751> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA2_EA6746> ;
    skos:definition "A PrivacyUsagePurpose corresponds to a type of usage of an information concerned by Privacy such as Administration, Marketing, Research, Information,...<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA3_EA2_EA6751" ;
    skos:prefLabel "PrivacyUsagePurpose"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA6701> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA6727> ;
    skos:definition "The Party Privacy Management process manages privacy information and agreement with party.<br/>Therefore, it needs to specify the information concerned by Privacy rules and the Privacy rules themselves.<br/><br/>The following Figure depicts how all information of the SID model might be addressed.<br/>Each SID Entity corresponds to an instance of RootEntityType and each attribute of an Entity corresponds to the use (RootEntityTypeCharUse) of a CharacteristicSpecification.<br/>Each possible value of a CharacteristicSpecification (CharacteristicSpecValue) might be used or not in the context of a RootEntityType (RootEntityTypeCharValueUse).<br/>Each instance of a SID Entity corresponds to an instance of RootEntity and the value of its attributes are carried by an instance of CharacteristicValue.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA3_EA6701" ;
    skos:prefLabel "Figure Ppr.01 - Reminder about RootEntityType and RootEntity"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA6703> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA6727> ;
    skos:definition "<font color=\"#29313b\">To illustrate the use of RootEntityType and RootEntity, let’s take the example of the Entity IndividualName that is described by the attributes legalName, formattedName, formOfAddress, etc.</font><br/><font color=\"#29313b\">The IndividualName would be described (non-exhaustive representation) as follows:</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA3_EA6703" ;
    skos:prefLabel "Figure Ppr.01 – Illustration.01 Reminder about RootEntityType and RootEntity"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA6705> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA6727> ;
    skos:definition "<font color=\"#29313b\">And now if we consider John Doe whose legal Name is “John Doe”, formatted Name is “John Doe Sr.” and form of address is “Mr.”, it would be instantiated as follows:</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA3_EA6705" ;
    skos:prefLabel "Figure Ppr.01 – Illustration.02 Reminder about RootEntityType and RootEntity"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA6707> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA6727> ;
    skos:definition "Thanks to the capacity of RootEntityType / RootEntity that enables the description of any information of the model, we can specify the available options of Privacy for each information concerned by Privacy.<br/>The following Figure gives an overview on how to specify the information concerned by Privacy rules and the Privacy rules themselves.<br/>A PartyPrivacyProfileType specifies for a Party playing a type of PartyRole (PartyRoleSpecification) such as Customer or User and possibly restricted to a context such as a set of ProductOfferings, all the available options that the Party may choose for each information concerned by the Privacy.<br/>A PartyPrivacyProfileType may specify Privacy for several information using PartyPrivacyProfileTypeCharacteristic.<br/>Each PartyPrivacyProfileTypeCharacteristic may specifyies:<br/> • the one or many information concerned by the Privacy (CharacteristicSpecification via RootEntityTypeCharUse),<br/> • the PartyRoleSpecifications that must apply the Privacy rule (For example, specific rules might be specified about the postal address for Party playing a role of shipping company),<br/> • and the corresponding Privacy rule (i.e. available choices for the party) using PartyPrivacyProfileTypeCharValue.<br/>A PartyPrivacyProfileTypeCharacteristic has a privacyType such as “Internal Purpose”, “External Purpose”, “Internal Retention” or “External Retention”.<br/>If the privacyType is “Internal Purpose” or “External Purpose”, then the PartyPrivacyProfileTypeCharacteristic specifies the usage purpose of the information concerned by the privacy such as Administration, Marketing, Research…<br/>The criticityLevel specifies a level of criticity for the set of Personal Identifiable Information (PII) defined by RootEntityTypeCharUse. <br/>Each PartyPrivacyProfileTypeCharacteristic is categorized by a PrivacyCategory for helping Graphical User Interface (GUI) to have a nice presentation for Privacy viewing and configuration.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA3_EA6707" ;
    skos:prefLabel "Figure Ppr.02 - Party Privacy Profile Type overview"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA6709> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA6727> ;
    skos:definition "<font color=\"#29313b\">To illustrate the previous Diagram, let’s consider the Privacy that might be defined for the eMail address.</font><br/><font color=\"#29313b\">The company defines a “Customer Mass Market Privacy” for Parties playing a role of Customer.</font><br/><font color=\"#29313b\">For the eMail Address information, it is decided that the company is always authorized to use it for Administration purpose.</font><br/><font color=\"#29313b\">This would be instantiated as follow in the model:</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA3_EA6709" ;
    skos:prefLabel "Figure Ppr.02 – Illustration.03 Party Privacy Profile Type overview"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA6711> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA6727> ;
    skos:definition "<font color=\"#29313b\">Now, let’s consider other privacy rules for Internal Purposes concerning the eMail Address:</font><br/><ul><li><font color=\"#29313b\">For Administration purpose, it can always be used by the company (ALWAYS rule),</font></li><li><font color=\"#29313b\">For Information purpose: by default, the company can use it, but the Customer can refuse the use of it (OPT-OUT rule),</font></li><li><font color=\"#29313b\">For Marketing purpose: by default, the company is not authorized to use it, but the Customer can authorize the use of it and in this case after 3 months the use of it is again unauthorized (OPT-IN rule),</font></li></ul><font color=\"#29313b\">For Research purpose: the company is never authorized to use it (NEVER rule).</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA3_EA6711" ;
    skos:prefLabel "Figure Ppr.02 – Illustration.04 Party Privacy Profile Type overview"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA6713> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA6727> ;
    skos:definition "<font color=\"#29313b\">We could have different privacy rules defined for external companies to which the information is transferred. It could be described as follows:</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA3_EA6713" ;
    skos:prefLabel "Figure Ppr.02 – Illustration.05 Party Privacy Profile Type overview"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA6715> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA6727> ;
    skos:definition "<font color=\"#29313b\">And now, to illustrate the specification of retention rules, let’s assume that:</font><br/><ul><li><font color=\"#29313b\">For the eMail Address,</font></li></ul> - <font color=\"#29313b\">the company can keep the information indefinitely,</font><br/> - <font color=\"#29313b\">other companies to which the information can’t keep it.</font><br/><ul><li><font color=\"#29313b\">For the Invoice amount,</font></li></ul> - <font color=\"#29313b\">the legal duration of retention is minimum 10 years and is the default duration,</font><br/> - <font color=\"#29313b\">the companies accept to keep the information for 20 years</font><br/> - <font color=\"#29313b\">and the Customer is able to choose a duration between 10 and 20 years.</font><br/><font color=\"#29313b\">This would be described like this:</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA3_EA6715" ;
    skos:prefLabel "Figure Ppr.02 – Illustration.06 Party Privacy Profile Type overview"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA6717> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA6727> ;
    skos:definition "The Figure Ppr.03 - Party Privacy Profile Type detailed view shows the inheritance of the Privacy’s entities from Profile entities:<br/> • the PartyPrivacyProfileType is a type of PartyProfileType,<br/> • the PartyPrivacyProfileTypeCharacteristic is a type of PartyProfileTypeCharacteristic,<br/> • and the PartyPrivacyProfileTypeCharValue is a type of PartyProfileTypeCharacteristicValue.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA3_EA6717" ;
    skos:prefLabel "Figure Ppr.03 - Party Privacy Profile Type detailed view"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA6719> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA6727> ;
    skos:definition "When a Party is eligible for a Privacy, then a default PartyPrivacyProfile is created for him according to the PartyPrivacyProfileType. Then if several Privacy options are available, the Party will be able to choose for other values.<br/>The Figure Ppr.04 - Party Privacy Profile overview depicts the relationships between PartyPrivacyProfile and PartyPrivacyProfileType.<br/>A PartyPrivacyProfile corresponds of the instantiation of a PartyPrivacyProfileType agreed by a PartyRole.<br/>The PartyPrivacyProfile is described by the Privacy choices made by the Party (related PartyPrivacyProfileCharValue).<br/>Each PartyPrivacyProfileCharValue instantiates a PartyPrivacyProfileTypeCharValue and specifies the chosen value.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA3_EA6719" ;
    skos:prefLabel "Figure Ppr.04 - Party Privacy Profile overview"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA6721> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA6727> ;
    skos:definition "<font color=\"#29313b\">As an example, Jon Doe’s default Privacy profile would be like this.</font><br/><font color=\"#29313b\">Note: the example isn’t exhaustive.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA3_EA6721" ;
    skos:prefLabel "Figure Ppr.04 – Illustration.07 Party Privacy Profile overview"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA6723> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA6727> ;
    skos:definition "<font color=\"#29313b\">Then Jon Doe is able to choose a different configuration for his Privacy, such as allowing the company to use his eMail Address for Marketing purposes. Then it would change like this:</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA3_EA6723" ;
    skos:prefLabel "Figure Ppr.04 – Illustration.07 Party Privacy Profile overview"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA6725> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA6727> ;
    skos:definition "The following Figure shows the relationship between Privacy and Agreement.<br/>A complete PartyPrivacyProfile might be agreed by a PartyPrivacyAgreement or sometimes for a high criticity level of a PartyPrivacyProfileTypeCharacteristic, then an agreement might be required for each corresponding PartyPrivacyProfileCharValue.<br/>The PartyPrivacyAgreement enables to track the approval made by the Party.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA3_EA6725" ;
    skos:prefLabel "Figure Ppr.05 - Privacy Agreement"@en .

