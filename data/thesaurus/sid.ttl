<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4760> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "A group of AgreementAuthorizations that materializes the fact that an Agreement has been approved by the participants involved in an Agreement.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4760" ;
    skos:prefLabel "AgreementApproval"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4761> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "Represents the authorization of an Agreement through its signature.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4761" ;
    skos:prefLabel "AgreementAuthorization"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4762> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "The purpose for an Agreement that, depending on Agreement Specialization can be expressed in terms of a ProductOfferingSpecification and/or ProductSpecification or ServiceSpecification or ResourceSpecification and / or specific elements that could be part of an Agreement like compliance, ethic, confidentiality, invoicing, payments...<br/>Please note that AgreementItem has also a validFor attribute. This attribute exists at AgreementItem level because its validity period can be different from the Agreement validity period.<br/>As examples:<br/><ul><li>An AgreementItem related to information / data confidentiality can be valid for a much more important period than the Agreement itself. Generaly, a text indicates that the corresponding clauses remain valid for a given period (example: 10 years) after the end of the Agreement.</li><li>In some cases, an AgreementItem related to prices or availability of a ProductOfferingSpecification (example: prices related to or availability of a ProductOfferingSpecification provided by a supplier) may have a shorter duration than the Agreement itself. Generaly, a text indicates that these elements may be reviewed periodically.</li></ul><p/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4762" ;
    skos:prefLabel "AgreementItem"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4763> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "AgreementItemSpecification describes elements that should be discussed for an Agreement between the Organization and involved third parties (example: Ethics & Compliance, Confidentiality of information, Privacy, Payment conditions, maximum level of discount, prices negotiation margin…).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4763" ;
    skos:prefLabel "AgreementItemSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4764> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "A Location role involved in an Agreement or AgreementItem. For examples: an Agreement is valid only for EU countries, an AgreementItem will be delivered in a specific site of a company...<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4764" ;
    skos:prefLabel "AgreementLocationRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4765> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "An entity involved in an Agreement and/or an AgreementItem. The entity is a Party playing a PartyRole.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4765" ;
    skos:prefLabel "AgreementRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4766> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "AgreementSpecification is an abstract BE which allows specifying (and then refer to) different types of Agreements (work contract …) with their characteristics (terms or conditions; mandatory items, optional items…).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4766" ;
    skos:prefLabel "AgreementSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4767> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "Aspects of the ContractualAgreement not formally specified elsewhere in the ContractualAgreement and that cannot be captured elsewhere in a formal notation, or automatically monitored and require a more human level of management.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4767" ;
    skos:prefLabel "AgreementTermOrCondition"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4768> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "AgreementTermsOrConditionSpecification specifies a set of Terms or conditions may be formally applied to an AgreementSpecification or an AgreementItemSpecification. It includes common characteristics of aspects of the Agreement or AgremmentItem that are not formally specified elsewhere in the Agreement and that cannot be captured elsewhere in a formal notation.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4768" ;
    skos:prefLabel "AgreementTermOrConditionSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4769> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "An AmendmentAgreement allows changing terms or conditions (examples: Prices, Privacy, Compliance, List of Beneficiaries of a Framework Agreement…) defined in a previously validated version of an Agreement. In the specific context of a FrameworkAgreement, all Beneficiaries automatically inherit from the new conditions.<br/>It may concern a legally binding agreement or a non legally binding agreement.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4769" ;
    skos:prefLabel "AmendmentAgreement"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4770> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "Describes the elements that can be negotiated or discussed in the context of an AmendmentAgreement.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4770" ;
    skos:prefLabel "AmendmentAgreementSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4772> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "A Commitment can include a set of CommitmentItems.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4772" ;
    skos:prefLabel "CommitmentItem"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4773> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "A ContractualAgreement is a type of Agreement governed by laws or any type of legal rules. A ContractualAgreement is described in a formal document.<br/>This type of Agreement can involve:<br/>- several registered companies,<br/>- several individuals,<br/>- individuals and registered companies.<br/>Approval and Authorizations of a ContractualAgreement are strict.<br/>A ContractualAgreement is a contract according to Cambridge definition: \" a legal document that states and explains a formal agreement between two different people or groups, or the agreement itself\".<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4773" ;
    skos:prefLabel "ContractualAgreement"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4774> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "A ContractualAgreement can include a set of ContractualAgreementItems that may concern, as examples, negotiated Prices of ProductOfferingSpecification, Ethic clauses, Security clauses, Privacy clauses, Non disclosure clauses, Payment clauses, Revenue share clause, Liquidated damages, Responsibility, Target customers…<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4774" ;
    skos:prefLabel "ContractualAgreementItem"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4775> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "Describes the elements that can be negotiated or discussed in the context of a ContractualAgreement.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4775" ;
    skos:prefLabel "ContractualAgreementSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4776> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "FixedTermWorkContract are WorkContracts that are valid for a “specific period of time” … or for a “specific task”. The \"fixed term\" is discharged by either the efflux of time at the end of the period specified in the contract or at the completion of the specified task.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4776" ;
    skos:prefLabel "FixedTimeWorkContract"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4777> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "A FrameworkAgreement defines the general rules under which the Organization and third parties (that are not part of the same registered company than the Organization) will work together. A FrameworkAgreement can be established between an Organization and a Customer (generally B2B or B2B2X), an Organization and its Supplier or Partner…<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4777" ;
    skos:prefLabel "FrameworkAgreement"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4778> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4778" ;
    skos:prefLabel "FrameworkAgreement Example Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4779> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "The FrameworkAgreementBeneficiaryRole represents a role played by an Organization that has the right to benefit from a FrameworkAgreement.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4779" ;
    skos:prefLabel "FrameworkAgreementBenificiaryRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4780> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "A FrameworkAgreement can include a set of FrameworkAgreementItems that may concern, as examples, negotiated Prices of ProductOfferingSpecification, Restriction on ProductSpecification Characteristics possible values through ProductConfigSpec, Restriction on AllowedProductAction, Ethic clauses, Security clauses, Privacy clauses, Non disclosure clauses, Payment clauses, Revenue share clause, Liquidated damages, Responsibility, Target customers…<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4780" ;
    skos:prefLabel "FrameworkAgreementItem"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4781> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "Describes the elements that can be negotiated or discussed in the context of a FrameworkAgreement.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4781" ;
    skos:prefLabel "FrameworkAgreementSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4782> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "A FrameworkAgreementSubscription allows an identified possible Beneficiary towards a FrameworkAgreement to subscribe to this FrameworkAgreement (through the signature of a person representing the Beneficiary and playing an AgreementRole for this Party).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4782" ;
    skos:prefLabel "FrameworkAgreementSubscription"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4783> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "An ImplementationAgreement corresponds to an agreement between parties (that are not entities of the same registered company) related to the delivery of ProductOfferingInstances and associated Products.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4783" ;
    skos:prefLabel "ImplementationAgreement"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4784> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4784" ;
    skos:prefLabel "ImplementationAgreement Example Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4785> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "An ImplementationAgreement can include a set of ImplementationAgreementItems that may concern, as examples, negotiated Prices of ProductOfferingSpecification, Ethic clauses, Security clauses, Privacy clauses, Non disclosure clauses, Payment clauses, Revenue share clause, Liquidated damages, Responsibility, Target customers…<br/>As an ImplementationAgreement is established between Parties that do not belong to the same registered Company, ImplementationAgreementItem can only involve ProductOfferingSpecification and their associated ProductSpecification, ProductOfferingInstance and Product.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4785" ;
    skos:prefLabel "ImplementationAgreementItem"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4786> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "Describes the elements that can be negotiated or discussed in the context of an ImplementationAgreement.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4786" ;
    skos:prefLabel "ImplementationAgreementSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4787> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "An InternalAgreement is a specific type of NonContractualAgreement that can occur between two (or more) entities of the same registered company. These entities can correspond to different establishments or departments in the same registered company.<br/>Approval and Authorizations of an InternalAgreement can be less strict than a ContractualAgreement.<br/>An InternalAgreement can be described in a formal document or as a decision transcribed in meeting minutes or as an exchange of mail.<br/>A InternalAgreement can include a set of Items that may concern transfer price, ServiceSpecification or ResourceSpecification, duration…<br/>Please note that in some specific cases (example: historical operator), due to regulation, two entities of the same registered company may have an external agreement for equity between all operators of the country.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4787" ;
    skos:prefLabel "InternalAgreement"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4788> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "An InternalAgreement can include a set of InternalAgreementItems that may concern, as examples, the internal services or resources concerned by the agreement, internal fund transfers for the use of services and resource, Security clauses, Privacy clauses, Responsibility…<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4788" ;
    skos:prefLabel "InternalAgreementItem"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4789> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "A NonContractualAgreement is a specific type of agreement that is not governed by laws or legal rules. It corresponds either to an informal agreement or an internal agreement.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4789" ;
    skos:prefLabel "NonContractualAgreement"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4790> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4790" ;
    skos:prefLabel "NonContractualAgreement Example Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4791> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "Describes the elements that can be negotiated or discussed in the context of a NonContractualAgreement.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4791" ;
    skos:prefLabel "NonContractualAgreementSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4792> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "A PermanentWorkContract corresponds to a work contract with no defined termination date (other than retirement).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4792" ;
    skos:prefLabel "PermanentWorkContract"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4793> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "A service level agreement (SLA) is a type of ContractualAgreement that represents a formal negotiated agreement between two parties designed to create a common understanding about products, services, priorities, responsibilities, and so forth. The SLA is a set of appropriate procedures and targets formally or informally agreed between parties in order to achieve and maintain specified Quality of Service.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4793" ;
    skos:prefLabel "ServiceLevelAgreement"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4794> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "The purpose for a ServiceLevelAgreement expressed in terms of a Product, Service, Resource, and/or their respective specifications, inherited from ContractualAgreementItem and in terms of ServiceLevelSpecification(s).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4794" ;
    skos:prefLabel "ServiceLevelAgreementItem"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4795> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "A WorkContract is a specific type of ContractualAgreement governed by labour law. A WorkContract defines the relationship between an Employer and an Employee. It attributes responsibilities, rights and duties to each parties and also job, position, job location, potentially expectations, mission description, working hours scheme, working time modalities, salary, benefits…<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4795" ;
    skos:prefLabel "WorkContract"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4796> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "Describes the elements that can be negotiated or discussed in the context of a WorkContract.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4796" ;
    skos:prefLabel "WorkContractSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4797> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4759> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4797" ;
    skos:prefLabel "Active"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4798> a skos:Concept ;
