<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA1_EA404> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA1_EA416> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA1_EA404" ;
    skos:prefLabel "Party Revenue & Settlement ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA1_EA407> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA1_EA406> ;
    skos:definition "The Applied Business Partner Billing Rate ABE contains business entities involved with charges/credits from the business partner assigned with respect to a business partner billing account.<br/>This ABE is still preliminary.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA1_EA407" ;
    skos:prefLabel "Applied Business Partner Billing Rate ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA1_EA408> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA1_EA406> ;
    skos:definition "Business Partner Account ABE inherits from Account ABE and contains all entities needed for specifying basic attributes and relationships that describe an account.<br/><br/>It also represents specificities in the context of a BusinessPartner.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA1_EA408" ;
    skos:prefLabel "Business Partner Account ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA1_EA410> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA1_EA406> ;
    skos:definition "The Business Partner Party Roles ABE manages Partner roles and related information.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA1_EA410" ;
    skos:prefLabel "Business Partner Party Roles ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA1_EA411> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA1_EA406> ;
    skos:definition "The Business Partner Product Order ABE contains all entities required to specify a communication used to procure, update or remove one or many Products in the context of a ProductOffering for the Service Provider. <br/>Note: Some but not all enterprises consider an Order to be a type of an Agreement. From a SID model perspective, an Order can be formalized by an Agreement and the Agreements relationship between the Agreement and the ProductOrder. This philosophy has the advantage of clearly separating two different concepts: the order from the legal formalisms associated with the order. For example, several orders may refer to the same Agreement.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA1_EA411" ;
    skos:prefLabel "Business Partner Product Order ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA1_EA413> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA1_EA406> ;
    skos:definition "Party Interaction ABE represents communications with parties, and the translation of requests and inquiries into appropriate \"events\" such as the creation of an order, the creation of a bill inquiry, or the creation of a problem. This ABE is still preliminary<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA1_EA413" ;
    skos:prefLabel "Party Interaction ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA1_EA414> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA1_EA406> ;
    skos:definition "Focuses on technical assistance and problem handling reported to and by other parties. This ABE is still preliminary<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA1_EA414" ;
    skos:prefLabel "Party Problem ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA1_EA417> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA1_EA406> ;
    skos:definition "Party Service Level Agreement ABE represents an SLA with one or more other parties. See the Agreement ABE for additional details. This ABE is still preliminary<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA1_EA417" ;
    skos:prefLabel "Party Service Level Agreement ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA1_EA418> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA1_EA406> ;
    skos:definition "Party Statistic ABE represents the analysis of party usage patterns, profitability statistics. This ABE is not fully developed<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA1_EA418" ;
    skos:prefLabel "Party Statistic ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA1_EA419> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA1_EA406> ;
    skos:definition "The strategies and the planning of the business relation with the other parties with input from other ABEs, such as MarketSales, Party Performance and Competitor Analysis. This ABE is not fully developed<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA1_EA419" ;
    skos:prefLabel "Party Strategy & Plan ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA1_EA420> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA1_EA415> ;
    skos:definition "The Party Role Product Offering ABE represents the involvement parties playing roles have with ProductOfferings.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA1_EA420" ;
    skos:prefLabel "Party Role Product Offering ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA1_EA421> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA1_EA415> ;
