    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA5_EA6832" ;
    skos:prefLabel "CommunicationInteractionMeans"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA5_EA6833> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA5_EA6811> ;
    skos:definition "A CommunicationInteractionResult specifies describes the main result which entity (RootEntity) is impacted and for which action (CommunicationInteractionAction) by the CommunicationInteractionItem.<br/><br/><br/><br/>For example:<br/><br/> - Action: \"creates\" for Entity: \"CustomerProductOrder CO1\"<br/><br/> - Action: \"create\" for Entity: \"CustomerProblem CP1\"<br/><br/> - Action: \"Help for use\" for Entity: \"Billy's Broadband\"<br/><br/> - Action: \"explain\" Entity: \"Billy's Customer Bill\"<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA5_EA6833" ;
    skos:prefLabel "CommunicationInteractionResult"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA5_EA6834> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA5_EA6811> ;
    skos:definition "A CommunicationInteractionRole specifies which roles (PartyRole or ResourceRole) are involved in a CommunicationInteractionItem.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA5_EA6834" ;
    skos:prefLabel "CommunicationInteractionRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA5_EA6835> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA5_EA6811> ;
    skos:definition "A CommunicationInteractionUseCase specifies which entity (RootEntity) is concerned and which action (CommunicationInteractionAction) are concerned by the CommunicationInteractionItem.<br/><br/>For example:<br/><br/> - Action: \"buy\" for Entity: \"ProductOffering PO1\"<br/><br/> - Action: \"ask for recovery\" for Entity: \"Billy's Broadband\"<br/><br/> - Action: \"notify\" Entity: \"Billy's Customer Bill\"<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA5_EA6835" ;
    skos:prefLabel "CommunicationInteractionUseCase"@en .

