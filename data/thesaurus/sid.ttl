<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA501> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA495> ;
