<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA8_EA3060> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA8_EA3052> ;
    skos:definition "WAN Protocols operate at the lowest three levels of the OSI model (i.e., physical, data link, and network) and are used to define communications over different types of wide-area media.<br/><br/><br/><br/>The SID model defines ATM, FrameRelay, HDLC, ISDN, PPP, SLIP, SMDS, and X.25 as examples of subclasses of this class.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA8_EA3060" ;
    skos:prefLabel "WANProtocol"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA8_EA3061> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA8_EA3052> ;
    skos:definition "Values: true,falseDefault: False"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA8_EA3061" ;
    skos:prefLabel "X25"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA7_EA3062> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA7_EA3064> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Resource Number </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA7_EA3062" ;
    skos:prefLabel "Figure RN.01 - Resource Number ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA7_EA3065> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA7_EA3064> ;
    skos:definition "Sub-class of the abstract LogicalResource. This is the main class for numbers that relates to the number portability, but it can contain more general and shared characteristics like the inventory of numbers. It has an ID (inherited), name (inherited), description(inherited), status (inherited) and a dialedNumber (For mobile: MDN, fixed, and IP type of numbers) - escribir más sobre resourceNumber. The association with NumberPortabilityRequest is of one-to-many since a number can have many ports and a port can happen to a specific number. Nevertheless, they are already related through the order, for that reason the relationship they have is derived.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA7_EA3065" ;
    skos:prefLabel "ResourceNumber"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA7_EA3066> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA7_EA3064> ;
    skos:definition "This class defines the specification for the resource number to admit a completion of its characteristics, since the number is a very complex and broad entity, with specific things like format, ranges,area code, etc. This class can be thought of as a template, which represents a generic specification for implementing a particular resource number.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA7_EA3066" ;
    skos:prefLabel "ResourceNumberSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA8_EA3067> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA8_EA3069> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Statistics </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA8_EA3067" ;
    skos:prefLabel "Figure Stat.01 - Statistics ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA8_EA3070> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA8_EA3069> ;
    skos:definition "Values: true,falseDefault: False"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA8_EA3070" ;
    skos:prefLabel "StatisticalEntity"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA9_EA3071> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA2841> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA9_EA3071" ;
    skos:prefLabel "TIP Logical Resource ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA1_EA3088> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA1_EA3090> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Auxiliary Component </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA1_EA3088" ;
    skos:prefLabel "Figure AC.01 - Auxiliary Component ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA1_EA3091> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA1_EA3090> ;
    skos:definition "This is an abstract base class that represents managed entities, such as power supplies, fans and cables, wihch are required for the proper operation of the Device but have a primary function that is different than the primary end-user function(s) of the Device.<br/><br/>The difference between AuxiliaryComponents and other subclasses of Equipment are whether or not the physical object performs a function intrinsic to the main function of the Device. This is best understood by way of example. Consider a Router. Its main function is to route and forward packets. A PowerSupply is an AuxiliaryComponent, because even though it is needed for the proper operation of the Router, it does not directly help in routing and forwarding packets. A LineCard (that provides routing functionality) is a subclass of Equipment because its purpose is to route and forward packets. Similar examples exist for different types of equipment, where their criteria may be different. For example, instead of whether it routes or forwards packets, the criterion \"does it carry signal\" may be useful to appropriately classify components.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA1_EA3091" ;
    skos:prefLabel "AuxiliaryComponent"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA1_EA3092> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA1_EA3090> ;
    skos:definition "This class represents the capabilities of a generic cooling device. It will be filled out later.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA1_EA3092" ;
    skos:prefLabel "CoolingDevice"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA1_EA3093> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA1_EA3090> ;
    skos:definition "This defines the capabilities of fans that are used for cooling.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA1_EA3093" ;
    skos:prefLabel "Fan"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA1_EA3094> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA1_EA3090> ;
    skos:definition "This class represents the capabilities of a generic power supply.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA1_EA3094" ;
    skos:prefLabel "PowerSupply"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA2_EA3095> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA2_EA3097> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Equipment </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA2_EA3095" ;
    skos:prefLabel "Figure E.01 - Equipment ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA2_EA3098> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA2_EA3097> ;
    skos:definition "This class represents a type of physical container that can be plugged into a Slot. It may represent a primary function (e.g., a networking card) or an auxiliary function (e.g., a memory card) that supports another card. All objects of this type are capable of carrying electrical and/or optical signals. They also provide a mounting point for other types of ManagedePhysicalElements, such as Chips or Cards.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA2_EA3098" ;
    skos:prefLabel "Card"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA2_EA3099> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA2_EA3097> ;
    skos:definition "This association class represents the semantics of the CardOnCard aggregation. It defines an attribute that describes how the Card is mounted on or plugged into the 'other' Card.This aggregation defines Cards that can accept (but not require) an additional Card to augment the base functionality of the hosting Card.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA2_EA3099" ;
    skos:prefLabel "CardOnCardDetails"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA2_EA3100> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA2_EA3097> ;
    skos:definition "This class is based on the m.3100 specification, and is described as follows:<br/><br/><br/><br/>The Equipment object class is a class of managed objects that represents physical components of a managed device, including replaceable components. An instance of this object class must be present in only a single geographic location. An Equipment object may be nested within another Equipment object, thereby creating a containment relationship. The Equipment type shall be identified by sub-classing this object class. Either the name of the sub-class or an attribute may be used for identifying the equipment type.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA2_EA3100" ;
    skos:prefLabel "Equipment"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA2_EA3101> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA2_EA3097> ;
    skos:definition "This is a type of Card that is dedicated to providing additional memory for use by other components of a Resource. Cards that are used to expand memory, or provide different types of memory, are examples of this type of Card. The SID differentiates between this and other types of Cards, such as NetworkCards and MemoryCards.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA2_EA3101" ;
    skos:prefLabel "MemoryCard"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA2_EA3103> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA2_EA3097> ;
    skos:definition "This object is used as a generic placeholder to represent Cards that are known to exist but are not yet identifiable via Software means.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA2_EA3103" ;
    skos:prefLabel "UnknownCard"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA2_EA3104> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA2_EA3102> ;
    skos:definition "This is a type of Card that is dedicated to providing system functions. Main processor boards and controller boards are examples of this type of Card. The SID differentiates between this and other types of Cards, such as NetworkCards and MemoryCards.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA2_EA3104" ;
    skos:prefLabel "SystemCard"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3072> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3074> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Physical Resource </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA3072" ;
    skos:prefLabel "Figure PRes.01 - Physical Resource ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3076> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3074> ;
    skos:definition "An ElectronicConnectionPoint realizes a ConnectionPoint and implements an ElectronicConnectionPointSpec.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA3076" ;
    skos:prefLabel "ElectronicConnectionPoint"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3084> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3074> ;
    skos:definition "A PhysicalBlackBox implements a PhysicalBlackBoxSpec.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA3084" ;
    skos:prefLabel "PhysicalBlackBox"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3085> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3074> ;
    skos:definition "This is a concrete class that represents the connecting or cabling together of hardware entities. This enables both wireless and connector-based communication to be modeled.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA3085" ;
    skos:prefLabel "PhysicalLink"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3086> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3074> ;
    skos:definition "This is an abstract base class for describing different types of hardware that constitute a Product. It has two main purposes: (1) to collect common attributes and relationships for all hardware, and (2) to provide a convenient, single point where relationships with other managed objects can be defined.<br/><br/>The HasWarrantyInfo association (not shown) describes warranty information of hardware.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA3086" ;
    skos:prefLabel "PhysicalResource"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3087> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3074> ;
    skos:definition "A SofwareSupportPackage represents the package acquired by a consumer from a software vendor. It can be materialized as one or several files (data) downloaded online or copied on a physical support. It contains all files required for deployment and installation such as installation manager and at minimum, one of the files constitutes the set of machine readable instructions that will be executed automatically after it is installed.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA3087" ;
    skos:prefLabel "SoftwareSupportPackage"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA1_EA3111> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA1_EA3113> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>HolderAtomic </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA1_EA3111" ;
    skos:prefLabel "Figure HA.01 - HolderAtomic ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA1_EA3114> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA1_EA3113> ;
    skos:definition "This association class represents the semantics of the AdjacentSlots association. It includes two attributes that are used to provide general layout information describing the Slots in the EquipmentHolder. The first, DistanceBetweenSlots, defines the distance in inches between two adjacent Slots in the PhysicalPackage. The second, SharedSlots, is a boolean attribute that describes the dependency between two Slots that are located in close proximity to each other. Sometimes, the two Slots are so close that if one of these Slots is populated by an adapter Card, the other Slot must be left empty. If this attribute is set to TRUE, then the second Slot must be left unoccupied.This association describes the layout of Slots in an EquipmentHolder. This association is implemented as an association class.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA1_EA3114" ;
    skos:prefLabel "AdjacentSlotDetails"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA1_EA3115> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA1_EA3113> ;
    skos:definition "This class represents atomic holders of Equipment that are individually manageable and do NOT form composite, or nested, Equipment Holders.<br/><br/>Each HolderAtomic object can be a FRU.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA1_EA3115" ;
    skos:prefLabel "HolderAtomic"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA1_EA3116> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA1_EA3113> ;
    skos:definition "This is a concrete class that has two main purposes. One is to model the ability of a hosting board to accept a daughter card to add or complete the base functionality of the hosting board. The second is to represent the different expansion slots supported by a Chassis.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA1_EA3116" ;
    skos:prefLabel "Slot"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA2_EA3117> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA2_EA3119> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>HolderAtomic </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA2_EA3117" ;
    skos:prefLabel "Figure HC.01 - HolderComposite ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA2_EA3120> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA2_EA3119> ;
    skos:definition "A Bay is a type of EquipmentHolder that is designed to hold various types of Equipment. It has a logical identifier, usually a component of port AIDs in TL1 based switches.<br/><br/>Note that the logical identifier of a Bay is typically associated with the Device (i.e., the NetworkElement). This means that the Bay IS explicitly a part of the logical model of a network.<br/><br/>A Bay is usually built as a pre-wired hardware assembly that contains a set of shelves and accompanying ancillary Equipment.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA2_EA3120" ;
    skos:prefLabel "Bay"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA2_EA3121> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA2_EA3119> ;
    skos:definition "A Chassis is a type of SecureHolder that encloses other ManagedPhysicalEntities and provides a definable functionality in its own right, such as a desktop or a network device (e.g., a router or a switch).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA2_EA3121" ;
    skos:prefLabel "Chassis"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA2_EA3122> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA2_EA3119> ;
    skos:definition "This class represents the semantics of the ChassisInRack aggregation. This class defines two attribute - Position and Location - to define where the Chassis is located in the Rack.This aggregation defines the set of Chassis that are contained within this Rack. It is implemented as an aggregation class.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA2_EA3122" ;
    skos:prefLabel "ChassisPosition"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA2_EA3123> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA2_EA3119> ;
    skos:definition "This class represents EquipmentHolders that are made up of other EquipmentHolders (i.e., instances of this class as well as the HolderAtomic base class). This provides the semantics of collecting a set of components, each of which is individually manageable, and being able to manage the set of objects as a whole. This containment is modeled using the HasHolders aggregation.<br/><br/>Each HolderComposite element can be a FRU.<br/><br/>A characteristic of this class is that its subclasses are physical objects that have complex cabling and mounting options. This class is meant to differentiate complex holders, like a Chassis, from simple holders, like a Slot.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA2_EA3123" ;
    skos:prefLabel "HolderComposite"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA2_EA3124> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA2_EA3119> ;
    skos:definition "A Rack is a type of SecureHolder that represents an enclosure in which EquipmentHolders, such as Chassis, are placed. Typically a Rack is nothing more than the enclosure, and all the functioning componentry is packaged in the Chassis.<br/><br/>Note that the logical identifier of a Rack is NOT typically associated with the Device (i.e., the NetworkElement). Compare this to either a Bay or a Shelf, whose logical identifier IS associated with the Device. This means that the Rack is explicitly NOT a part of the logical model of a network.<br/><br/>The Rack typically serves as the \"master enclosure\" for Chassis, Shelves and Bays. In addition, Racks can have multiple instances of multiple Devices mounted in them.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA2_EA3124" ;
    skos:prefLabel "Rack"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA2_EA3125> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA2_EA3119> ;
    skos:definition "This class is a type of HolderComposite that serves as the parent for the Rack and Chassis classes. This class generalizes common properties that apply to Racks and Chassis.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA2_EA3125" ;
    skos:prefLabel "SecureHolder"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA2_EA3126> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA2_EA3119> ;
    skos:definition "A Shelf is a type of EquipmentHolder that is designed to hold various types of Equipment. It has a logical identifier that is often relative to the Bay that contains the Shelf (i.e., the unique identifier for a Shelf is often a concatenation of the network element identifier, the Bay identifier, and the Shelf identifier).<br/><br/>Note that the logical identifier of a Shelf is typically associated with the Device (i.e., the NetworkElement). Compare this to a Rack, whose logical identifier is NOT associated with the Device. This means that the Shelf IS explicitly a part of the logical model of a network.<br/><br/>Often, a Shelf is used to contain not just pluggable components (e.g., Cards, Power Supplies, etc.) but also cabling (e.g., both fiber and wire), with optional connections to external fuse, alarm, and other types of panels.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA2_EA3126" ;
    skos:prefLabel "Shelf"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA3105> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA3107> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Equipment Holder </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA3105" ;
    skos:prefLabel "Figure EH.01 - Equipment Holder ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA3108> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA3107> ;
    skos:definition "This class is based on the M.3100 specification, and is a base class that represents physical objects that are both manageable as well as able to host, hold, or contain other physical objects. Examples of physical objects that can be represented by instances of this object class are Racks, Chassis, Shelfs, and Slots.<br/><br/>The difference between subclasses of EquipmentHolder (such as a Slot or a Chassis) and subclasses of Equipment that have a Holder role (such as a Card) is that the subclasses of EquipmentHolder are dedicated to holding other Hardware. The subclasses of Equipment that have a holder role have a holding capability as a secondary capability, usually for expansion. Their primary function, however, is not to hold other objects.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA3108" ;
    skos:prefLabel "EquipmentHolder"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA4_EA3127> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA4_EA3129> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Hardware </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA4_EA3127" ;
    skos:prefLabel "Figure H.01 - Hardware ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA4_EA3130> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA4_EA3129> ;
    skos:definition "A container of conductors or fibres. At least two connectors will be attached to a cable.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA4_EA3130" ;
    skos:prefLabel "Cable"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA4_EA3131> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA4_EA3129> ;
    skos:definition "This class represents any type of hardware entity that exists as an atomic unit that is not a PhysicalLink or a PhysicalConnector. Hardware is defined as any component that has a distinct physical identity and can be a component of a PhysicalDevice. An object has a physical identity if it has a physical manifestation that enables it to be held and have a label attached to it. Thus, software, files, protocols, and policies are not physical objects.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA4_EA3131" ;
    skos:prefLabel "Hardware"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA4_EA3132> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA4_EA3129> ;
    skos:definition "This is an abstract base class that adds additional semantics to the Hardware base class. These semantics are used to provide management information on the hardware. For example, attributes defined by this class can provide the administrative and operational state of the entity, and tell whether it has any alarms.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA4_EA3132" ;
    skos:prefLabel "ManagedHardware"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA4_EA3133> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA4_EA3129> ;
    skos:definition "This is a concrete class that represents any type of hardware unit that is used to connect to other hardware units and transmit signals and/or power between them.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA4_EA3133" ;
    skos:prefLabel "PhysicalConnector"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA4_EA3134> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA4_EA3129> ;
    skos:definition "This is an abstract class that is used to add additional semantics to the ManagedHardware class. Its attributes define whether a ManagedHardware object can be removed and/or replaced, and whether this action requires power to be removed or not when the action is performed.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA4_EA3134" ;
    skos:prefLabel "PhysicalContainer"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA4_EA3135> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA4_EA3129> ;
    skos:definition "This class represents an actual or potential end point of a topological (physical) link, and corresponds directly to a physical port on a topology map. PhysicalPorts are always contained by another physical object - they can't exist by themselves. The two most common examples are PhysicalPorts on a Card and on a Chassis.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA4_EA3135" ;
    skos:prefLabel "PhysicalPort"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA5_EA3136> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA5_EA3138> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Physical Capacity </b>Aggregate Business Entity.</font><br/><font color=\"#29313b\"><br/></font><font color=\"#29313b\">Note: PhysicalContainer is not part of the ABE, but is shown to show context for association class PhysicalCapacityDetails.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA5_EA3136" ;
    skos:prefLabel "Figure PCap.01 - Physical Capacity ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA5_EA3139> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA5_EA3138> ;
    skos:definition "This is an abstract class that represents the minimum and maximum requirements, limits, or other variable features of a ManagedDevice or ManagedHardware object.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA5_EA3139" ;
    skos:prefLabel "PhysicalCapacity"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA5_EA3140> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA5_EA3138> ;
    skos:definition "This class represents the semantics of the HasPhysicalCapactiy association. It provides additional semantics describing the different types of PhysicalCapacities that this ManagedComponent contains, and provides methods to tell how many PhysicalCapacities are associated with this particular ManagedComponent instance.This generic association enables any of the different types of PhysicalCapacity subclasses to be associated to a given PhysicalContainer. This enables different types of PhysicalContainers (e.g., memory chips as well as Chassis) to have the notion of physical capacity.<br/><br/>It is implemented as an association class to enable an application to query for all, or a specific type of, PhysicalCapacity association, and to define additional semantics on a per-association basis.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA5_EA3140" ;
    skos:prefLabel "PhysicalCapacityDetails"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA5_EA3141> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA5_EA3138> ;
    skos:definition "This is a concrete class that defines the type of Memory that can be installed on a ManagedHardware instance, along with its minimum and maximum limits.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA5_EA3141" ;
    skos:prefLabel "PhysicalMemoryCapacity"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA5_EA3142> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA5_EA3138> ;
    skos:definition "This is a concrete class that defines the type of power that a ManagedHardware instance can use, along with its minimum and maximum limits.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA5_EA3142" ;
    skos:prefLabel "PowerCapacity"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA6_EA3143> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA6_EA3145> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Physical Component </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA6_EA3143" ;
    skos:prefLabel "Figure PComp.01 - Physical Component ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA6_EA3146> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA6_EA3145> ;
    skos:definition "An ASIC is an Application Specific Integrated Circuit.<br/><br/>This class represents a special type of Chip that is used to upgrade the functionality of a networking device. Examples include upgrading the modem function of a device, increasing the processing capability of a Card or Device, and implementing some type of networking functionality, such as fast switching, directly in hardware (as opposed to emulating it in software).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA6_EA3146" ;
    skos:prefLabel "ASIC"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA6_EA3147> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA6_EA3145> ;
    skos:definition "This class models the backplane that is present in devices.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA6_EA3147" ;
    skos:prefLabel "Backplane"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA6_EA3148> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA6_EA3145> ;
    skos:definition "This is a concrete class that models different types of chips that are either directly configurable by the end-user (e.g., a programmable device) and/or represent FRUs (e.g., a special ASIC that can be upgraded by replacing it with a new version of that same ASIC).<br/><br/>Note that capacity characteristics (e.g., how much memory can a Flash chip hold) are defined through the PhysicalCapacity association.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA6_EA3148" ;
    skos:prefLabel "Chip"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA6_EA3149> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA6_EA3145> ;
    skos:definition "Flash are memory-based devices that conform to the PC Card (formerly PCMCIA) standard, and that present an ATA (AT Attachment) interface to the device. The Flash Disk has controller circuitry that allows it to emulate a hard disk and that automatically maps out bad blocks and performs automatic block erasure. Furthermroe, the Flash Disk provides the capability to allocate noncontiguous sectors, which a Flash memory device can't.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA6_EA3149" ;
    skos:prefLabel "FlashDisk"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA6_EA3150> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA6_EA3145> ;
    skos:definition "This class represents memory devices that are implemented as Chips. Note that this only represents the physical packaging of the Memory Chip - the logical functionality is defined in a separate class, called Memory, that is part of the LogicalResource model.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA6_EA3150" ;
    skos:prefLabel "MemoryComponent"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA6_EA3151> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA6_EA3145> ;
    skos:definition "This is the base class for different types of PhysicalComponents that can reside either in an Equipment or an EquipmentHolder object. They can NOT be used as a stand-alone object.<br/><br/>From a management point-of-view, this object either can not or does not need to be split into its constituent parts. For example, an ASIC (or Chip) can not , and a tape for data storage does not, need to be split up into their constituent parts. Any piece of hardware that is not a PhysicalLink, PhysicalConnector, Equipment, or EquipmentHolder, is a subclass of this class.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA6_EA3151" ;
    skos:prefLabel "PhysicalComponent"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA7_EA3152> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA7_EA3154> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Physical Device </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA7_EA3152" ;
    skos:prefLabel "Figure PD.01 - Physical Device ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA7_EA3155> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA7_EA3154> ;
    skos:definition "This is an abstract base class for representing hardware devices that can be managed. This class represents a convenient aggregation point for combining different aspects of a device (e.g., the cables, connectors, cards, power supplies, and other objects that together make up the device). Thus, it enables the device itself to have a physical manifestation (e.g., the \"Internet Gateway Router\" can be identified as a PhysicalDevice). Examples of this class include routers and switches, computers, and other end-devices that are managed.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA7_EA3155" ;
    skos:prefLabel "PhysicalDevice"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA7_EA3156> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA7_EA3154> ;
    skos:definition "This is a concrete base class for representing hardware devices that can be managed that contains no sub-ordinate devices. In other words, this physical device is a stand-alone physical device.<br/><br/>This class represents a convenient aggregation point for combining different aspects of a device (e.g., its physical composition as well as the set of services that it offers). It also enables the device itself to have a physical manifestation. Examples of this class include routers and switches, computers, and other end-devices that are managed.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA7_EA3156" ;
    skos:prefLabel "PhysicalDeviceAtomic"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA7_EA3157> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA7_EA3154> ;
    skos:definition "This is a concrete base class for representing hardware devices that can be managed that contains one or more sub-ordinate devices. In other words, this physical device is not a stand-alone physical device; rather, it represents an aggregation of physical devices. Each physical device in this aggregation can be managed.<br/><br/>This class represents a convenient aggregation point for combining different aspects of a device (e.g., its physical composition as well as the set of services that it offers). It also enables the device itself to have a physical manifestation. Examples of this class include routers and switches, computers, and other end-devices that are managed.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA7_EA3157" ;
    skos:prefLabel "PhysicalDeviceComposite"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3163> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3165> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Physical Role Example </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3163" ;
    skos:prefLabel "Figure PRE.01 - Physical Role Example ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3166> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3165> ;
    skos:definition "This is a concrete class that defines the basic physical characteristics of a CPE (Customer Premise Edge) device. For example, what types of line cards are needed for this device to perform its role of a CPE device.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3166" ;
    skos:prefLabel "CPEPhysicalDeviceRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3167> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3165> ;
    skos:definition "This is an abstract base class for representing the different types of roles that various physical resources can take on. For this first iteration, two specialized roles have been defined: holder and adapter. This enables a single object, such as a Card, to have additional functions. For example, a Card may also serve as a motherboard or hosting board for another Card. In this situation, there isn't a separate EquipmentHolder - rather, the Card acts as a holder in addition to providing its normal functions. This class is the base class for defining different types of physical resource roles. Attributes are TBD.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3167" ;
    skos:prefLabel "HardwareRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3168> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3165> ;
    skos:definition "This is a concrete class that defines the basic physical characteristics of a PE Provider Edge) device. For example, what types of line cards are needed for this device to perform its role of a PE device.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3168" ;
    skos:prefLabel "PEPhysicalDeviceRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3169> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3165> ;
    skos:definition "This is a concrete class that represents any type of physical resource that can play a physical adapter role. The Adapter role enables a piece of Hardware to adapt its use. For example, sometimes Cards and Chassis evolve along separate paths, causing future versions of one to no longer be physically compatible with present and/or future versions of the other. The solution to this is to use an intermediate piece of Hardware, called an Adapter, to extend the existing physical structure of an EquipmentHolder to enable otherwise incompatible Equipment to be plugged into an EquipmentHolder. The Adapter conceptually creates a new type of EquipmentHolder that fits into the existing EquipmentHolder. This enables Cards that would otherwise be physically and/or electrically incompatible with the existing EquipmentHolder to be supported, by interfacing to the old EquipmentHolder via the new Adapter.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3169" ;
    skos:prefLabel "PhysicalAdapterRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3170> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3165> ;
    skos:definition "This is an abstract base class that defines the different types of physical roles that a PhysicalDevice can take on. This enables us to correlate different logical roles to physical hardware. For example, the logical capability of encryption may need dedicated physical hardware. The PhysicalDeviceRole Encryption enables us to model this dependency.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3170" ;
    skos:prefLabel "PhysicalDeviceRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3171> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3165> ;
    skos:definition "This is a physical role that a device has. It enables us to correlate physical components that are used to encrypt traffic with the logical capability of encrypting.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3171" ;
    skos:prefLabel "PhysicalEncryptionRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3172> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3165> ;
    skos:definition "This is a physical role that a device can play. It enables us to correlate physical components that are used to perform firewall functions with the logical capability of acting as a firewall.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3172" ;
    skos:prefLabel "PhysicalFirewallRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3173> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3165> ;
    skos:definition "This is a concrete class that represents any type of physical resource that can play a holding role. A common example is a Card that can also serve as a motherboard, or a Card that can serve as a daughter card that attaches to a motherboard. This class enables a single Entity, such as a Line Card, to have multiple roles - it can function as a Router Processor as well as a Holder.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3173" ;
    skos:prefLabel "PhysicalHolderRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3174> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3165> ;
    skos:definition "This is a physical role that a device has. It enables us to correlate physical components that are used to route traffic with the logical capability of routing traffic.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3174" ;
    skos:prefLabel "PhysicalRouterRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3175> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3165> ;
    skos:definition "This is a physical role that a device has. It enables us to correlate physical components that are used to forward traffic with the logical capability of forwarding traffic.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3175" ;
    skos:prefLabel "PhysicalSwitchRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3176> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3165> ;
    skos:definition "This is a concrete class that defines the basic characteristics of a P (Provider Core) device. For example, what types of line cards are needed for this device to perform its role of a P device.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA1_EA3176" ;
    skos:prefLabel "PPhysicalDeviceRole"@en .

