<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA4_EA3203> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2391> ;
    skos:definition "The <b>Resource Configuration ABE</b> represents the specification of the different possible Resource configurations as well as the Resource Configurations instantiated for a Resource.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA4_EA3203" ;
    skos:prefLabel "Resource Configuration ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA5_EA2_EA3237> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA5_EA3220> ;
    skos:definition "The Resource Number Portability Role ABE contains entities related to the roles taked for the portability.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA5_EA2_EA3237" ;
    skos:prefLabel "Resource Number Portability Role ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA7_EA3258> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2391> ;
    skos:definition "The <b>Resource Test ABE</b> contains entities that are used to test PhysicalResources, LogicalResources and CompoundResources. These entities are usually invoked during installation, as a part of trouble diagnosis or after trouble repair has been completed.<br/>The Resource Test ABE defines measurement including units and values and how the values are determined. It also includes thresholds used to evaluate the measure and the consequences of violating the thresholds as well as the Resource Test measures being produced that reflect the functioning of the Resource under test.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA7_EA3258" ;
    skos:prefLabel "Resource Test ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA8_EA3263> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2391> ;
    skos:definition "The <b>Resource Performance ABE</b> collects information used to correlate, consolidate, and validate various performance statistics and other operational characteristics of Resources. Each of these entities also enables network performance assessment against planned goals, performs various aspects of trend analysis, including error rate and cause analysis and Resource degradation.<br/>Entities in this ABE also includes statistics defining Resource loading, and traffic trend analysis.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA8_EA3263" ;
    skos:prefLabel "Resource Performance ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA1_EA1_EA3519> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA1_EA3513> ;
    skos:definition "The Example Party Role Product Offering Specification Entities ABE contains examples of more explicit modeling for PartyRoleProductOfferingSpecs.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA1_EA1_EA3519" ;
    skos:prefLabel "Example Party Role Product Offering Specification Entities ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA7_EA2_EA3702> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA7_EA3686> ;
    skos:definition "The Business PartnerPayment ABE contains description of transfer of wealth between the CSP and a Business Partner.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA7_EA2_EA3702" ;
    skos:prefLabel "Business Partner Payment ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3_EA1_EA3867> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3_EA3854> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3_EA1_EA3867" ;
    skos:prefLabel "Work ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA4_EA3948> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3913> ;
    skos:definition "KeyPerformanceIndicators and RAObjectives that may trigger the creation of a RATroubleTicket. KeyPerformanceIndicator are defined on RAViolations, and on other Revenue Assurance related entities, such as CustomerBills and CallDetailRecords.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA4_EA3948" ;
    skos:prefLabel "RA Key Performance Indicator ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA5_EA3953> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3913> ;
    skos:definition "A TroubleTicket opened to resolve one or several causes (for example, RA Violations) that resulted in a RAKeyPerformanceIndicator exceeding one or more RAObjective thresholds.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA5_EA3953" ;
    skos:prefLabel "RA Trouble Ticket ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA6_EA3958> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3913> ;
    skos:definition "A discrepancy identified based on applying Policies associated with RAControl(s) to Revenue Assurance related entities, such as Products and ResourceUsage.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA6_EA3958" ;
    skos:prefLabel "RA Violation ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA863> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA857> ;
    skos:definition "The Location ABE represents the site or position of something, such as a customer’s address, the site of equipment where there is a fault and where is the nearest person who could repair the equipment, and so forth. Locations can take the form of coordinates and/or addresses and/or physical representations. <br/>.\\doc\\Figure L.10b - Geographic Location Symbology.docx <br/>.\\doc\\Figure L.15 - Links to Other Parts of the SID Model.docx<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA10_EA863" ;
    skos:prefLabel "Location ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA1_EA430> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA1_EA416> ;
    skos:definition ".\\doc\\Figure PRS.07 - Party Revenue Share Reconciliation Discrepancy.docx<br/>Revenue sharing is the distribution of revenue, the amount paid by customers or other parties to an enterprise, between stakeholders, who could be partners, a company's employees, or between companies in a business alliance. The purpose of revenue sharing is using shared revenue to benefit parties involved. Before the revenue is shared by enterprise and one or more other parties, they enter into a party revenue sharing agreement, which specifies how revenue will be shared among the parties involved.<br/><br/>The Party Revenue Sharing ABE contains party revenue sharing models, party revenue sharing agreements, party revenue shares, and party revenue sharing reconciliations. The Party Revenue Sharing Model contains revenue sharing models that define how revenue is shared by an enterprise with one or more other parties. Revenue sharing models are a key component revenue sharing agreements. The Party Revenue Sharing Agreement ABE contains an agreement that specifies how revenue will be shared between an enterprise and one or more other parties whose product offerings are made available in some way by an enterprise. The Party Revenue Share ABE uses existing artifacts such as usage, invoices, product prices, and applied billing rates that specifies how revenues will be shared. The Party Revenue Share Reconciliation ABE represents the alignment and agreement for two sets of party revenue sharing records. Each ABE is further described in upcoming sections.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA1_EA430" ;
    skos:prefLabel "Party Revenue Sharing ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA587> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA563> ;
    skos:definition "An occurrence of employing a Product, Service or Resource for its intended purpose, which is of interest to the business and can have charges applied to it. It is comprised of characteristics, which represent attributes of usage.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA587" ;
    skos:prefLabel "Usage ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA670> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA661> ;
    skos:definition "The Product Specification ABE contains all what represent a product specification as perceived by the business user and specifies what the marketing operator wants to sell at a functional level (i.e. what are the capacities, which usages are available…). .<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA6_EA670" ;
    skos:prefLabel "Product Specification ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA7_EA777> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA7_EA712> ;
    skos:definition "The Logical Resource Specification ABE is used to define the invariant characteristics and behavior (attributes, methods, constraints, and relationships) of a LogicalResource.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA7_EA777" ;
    skos:prefLabel "LogicalResource Specification ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA813> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA804> ;
    skos:definition "The Service Specification ABE contains entities that define the shared characteristics of both types of Service entities. This enables multiple instances to be derived from a single specification entity. In this derivation, each instance will use the characteristics defined in its associated specification.<br/><br/>Entities in this ABE focus on adherence to standards, distinguishing features of a Service, dependencies (both physical and logical, as well as on other services), quality, and cost. In general, entities in this ABE enable Services to be bound to Products and run using Resources.<br/><br/>Network services are one example of Services that can be built. Additional examples include installation, maintenance, monitoring, and content authentication, authorization, accounting, and auditing functions.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA813" ;
    skos:prefLabel "Service Specification ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA829> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA806> ;
    skos:definition "The Customer Facing Service ABE defines the characteristics of a particular CustomerFacingService that represents a realization of a Product within an organization's infrastructure. In contrast, the Resource Facing Service ABE is an abstraction that defines the characteristics of a particular ResourceFacingService which support the network/infrastructure facing part of CustomerFacingService. ResourceFacingServices are \"internal\" Services that are required to support a CustomerFacingService.<br/><br/><br/><br/>Entities in this ABE provide different views to examine, analyze, configure, monitor and repair CustomerFacingServices of all types. Entities in this ABE are derived from Customer Service Specification entities.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA829" ;
    skos:prefLabel "Customer Facing Service ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA10_EA2_EA1_EA5247> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA10_EA2_EA5236> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA10_EA2_EA1_EA5247" ;
    skos:prefLabel "Performance Collection ABE"@en .

