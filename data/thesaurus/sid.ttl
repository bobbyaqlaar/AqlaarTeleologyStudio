    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA6_EA657" ;
    skos:prefLabel "Product Specification ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA659> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA672> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA6_EA659" ;
    skos:prefLabel "Product Usage ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA664> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA661> ;
    skos:definition "Specific ability of Product domain entities measured in quantity and units of quantity over an extended period.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA6_EA664" ;
    skos:prefLabel "Product Capacity ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA667> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA661> ;
    skos:definition "The Product Order ABE contains all entities required to specify a communication used to procure or update one or many Products in the context of a ProductOffering. This pattern is used to define: • CustomerProductOrder corresponding to Products ordered by a Customer to the Service Provider • and BusinessPartnerProductOrder corresponding to Products ordered by the Service Provider to a Business Partner Note: Some but not all enterprises consider an Order to be a type of an Agreement. From a SID model perspective, an Order can be formalized by an Agreement and the Agreements relationship between the Agreement and the ProductOrder. This philosophy has the advantage of clearly separating two different concepts: the order from the legal formalisms associated with the order. For example, several orders may refer to the same Agreement.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA6_EA667" ;
    skos:prefLabel "Product Order ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA668> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA661> ;
    skos:definition "Product Party Roles ABE contains all PartyRoles related to the Product Domain such as ProductManager. Roles related to Customer such as Payer are located in Customer Domain<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA6_EA668" ;
    skos:prefLabel "Product Party Roles ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA669> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA661> ;
    skos:definition "The Product Performance ABE handles product performance goals, the results of end-to-end product performance assessments, and the comparison of assessments against goals. The results may include the identification of potential capacity issues. This ABE is not fully developed<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA6_EA669" ;
    skos:prefLabel "Product Performance ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA671> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA661> ;
    skos:definition "A Product Test is a function performed on a product that results in measures being produced that reflect the functioning of the product under test.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA6_EA671" ;
    skos:prefLabel "Product Test ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA673> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA661> ;
    skos:definition "A strategy employed to promote a ProductOffering. Strategic Product Portfolio Plan ABE is concerned with the plans of the product portfolio, which product offerings to make available to each market segment and the plans to development and deploy product offerings, as well as retirement of products. This ABE is not fully developed<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA6_EA673" ;
    skos:prefLabel "Strategic Product Portfolio Plan ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA674> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA677> ;
    skos:definition "The PLA Spec ABE specifies Pricing Logic Algorithm.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA6_EA674" ;
    skos:prefLabel "PLA Spec ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA678> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA666> ;
    skos:definition "Product Catalog ABE is a collection of entities that represent the specification of ProductCatalogs and catalogs described by them that contain ProductOfferings and their associated ProductOfferingPrices.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA6_EA678" ;
    skos:prefLabel "Product Catalog ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA679> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA666> ;
    skos:definition "The Product Offering Price ABE describes all the prices related to ProductOfferings.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA6_EA679" ;
    skos:prefLabel "Product Offering Price ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA680> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA666> ;
    skos:definition "The Product Offering Price Rule ABE describes all rules related to prices concerning ProductOfferings.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA6_EA680" ;
    skos:prefLabel "Product Offering Price Rule ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA681> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA666> ;
    skos:definition "The Product Offering Price Tax ABE describes how taxation is modelled in the context of ProductOfferingPrice and ProductPrice. The model covers the following aspects:<br/><br/> • TaxDefinition and TaxExemption - these specify what the tax is and how it is calculated, including the influence of specific circumstances on the calculation<br/><br/> • TaxProdOfferPriceAlteration - this is an alteration to a ProductOfferingPrice that projects how much tax will be added for a ProductOffering<br/><br/> • TaxProdPriceAlteration - this is an alteration to a ProductPrice that represents how much tax will be added for a Product that was actually purchased and delivered to a Party. The tax amounts are ultimately represented on the invoice as AppliedCustomerBillingTaxRate (or AppliedPartyBillingTaxRate as per the Engaged Party model).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA6_EA681" ;
    skos:prefLabel "Product Offering Price Tax ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA682> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA665> ;
    skos:definition "The Product Action ABE contains Business Entities describing possible actions for ProductSpecifications, ProductOfferings and ProductConfigSpecs.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA6_EA682" ;
    skos:prefLabel "Product Action ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA683> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA672> ;
    skos:definition "The Product Usage Entity ABE collects product consumption information, and generates ProductUsage according to ProductUsageSpecification for use by other business entities.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA6_EA683" ;
    skos:prefLabel "Product Usage Entity ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA684> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA672> ;
    skos:definition "The Product Usage Spec ABE specifies types of usage of ProductSpecifications.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA6_EA684" ;
    skos:prefLabel "Product Usage Specification ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA685> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA670> ;
    skos:definition "Goods and Shipping Product Spec ABE describe specificity of Goods and Shipping Product Spec and their relationships.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA6_EA685" ;
    skos:prefLabel "Goods and Shipping Product Spec ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA686> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA670> ;
    skos:definition "The Network Product Spec ABE contains the NetworkProductSpec description and relationships.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA6_EA686" ;
    skos:prefLabel "Network Product Spec ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA687> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA670> ;
    skos:definition "The Usage Volume Product Spec ABE contains the UsageVolumeProductSpec and all the entities specific to this type of product.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA6_EA687" ;
    skos:prefLabel "Usage Volume Product Spec ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA688> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA662> ;
    skos:definition "The Loyalty Program ABE contains all entities needed to instantiate a loyalty program for a specific customer such as LoyaltyProgram and LoyaltyAccount.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA6_EA688" ;
    skos:prefLabel "Loyalty Program ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA689> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA662> ;
    skos:definition "The Loyalty Program Specification ABE contains all entities specifying a loyalty program such as LoyaltyProgramProdSpec and LoyaltyRule.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA6_EA689" ;
    skos:prefLabel "Loyalty Program Specification ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA690> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA675> ;
    skos:definition "The Network Product ABE contains the NetworkProduct description and relationships.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA6_EA690" ;
    skos:prefLabel "Network Product ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA691> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA675> ;
    skos:definition "The Usage Volume Product ABE contains the UsageVolumeProduct and all the entities specific to this type of product.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA6_EA691" ;
    skos:prefLabel "Usage Volume Product ABE"@en .

