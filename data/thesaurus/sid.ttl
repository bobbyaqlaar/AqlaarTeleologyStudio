<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA2_EA2045> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA2023> ;
