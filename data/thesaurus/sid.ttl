<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA2_EA1_EA1876> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA2_EA1_EA1875> ;
    skos:definition "Part of a ProductPrice representing a single element of the price.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA2_EA1_EA1876" ;
    skos:prefLabel "ComponentProdPrice"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA2_EA1_EA1877> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA2_EA1_EA1875> ;
    skos:definition "A ProductPrice that is made up of parts. The parts may be other CompositeProdPrices or ComponentProdPrices.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA2_EA1_EA1877" ;
    skos:prefLabel "CompositeProdPrice"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA2_EA1_EA1878> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA2_EA1_EA1875> ;
    skos:definition "A DiscountProdPriceAlteration represents a discount (a reduction of price) for a Product.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA2_EA1_EA1878" ;
    skos:prefLabel "DiscountProdPriceAlteration"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA2_EA1_EA1879> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA2_EA1_EA1875> ;
    skos:definition "A OneTimeProdPriceCharge represents a charge to apply for a Product action that has been done such as creation fee.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA2_EA1_EA1879" ;
    skos:prefLabel "OneTimeProdPriceCharge"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA2_EA1_EA1880> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA2_EA1_EA1875> ;
    skos:definition "An amount, usually of money, that modifies the price charged for a Product.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA2_EA1_EA1880" ;
    skos:prefLabel "ProdPriceAlteration"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA2_EA1_EA1881> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA2_EA1_EA1875> ;
    skos:definition "An amount, usually of money, that is asked for when a Product is bought, rented, or leased.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA2_EA1_EA1881" ;
    skos:prefLabel "ProdPriceCharge"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA2_EA1_EA1882> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA2_EA1_EA1875> ;
    skos:definition "An amount, usually of money, that represents the actual price paid by a Customer for a purchase, a rent or a lease of a ProductOfferingInstance. The price is valid for a defined period of time.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA2_EA1_EA1882" ;
    skos:prefLabel "ProductPrice"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA2_EA1_EA1883> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA2_EA1_EA1875> ;
    skos:definition "A Party playing a PartyRole that is involved in the pricing/charging of a Product. For example, a parent's usage results in free SMS messaging being allocated to a child of the parent.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA2_EA1_EA1883" ;
    skos:prefLabel "ProductPricePartyRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA2_EA1_EA1884> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA2_EA1_EA1875> ;
    skos:definition "A RecurringProdPriceCharge represents a charge that must be applied on a recurring basis for a Product.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA2_EA1_EA1884" ;
    skos:prefLabel "RecurringProdPriceCharge"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA2_EA1_EA1885> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA2_EA1_EA1875> ;
    skos:definition "A ReplacementProdPriceAlteration represents a new price that replaces a charge for a Product.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA2_EA1_EA1885" ;
    skos:prefLabel "ReplacementProdPriceAlteration"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA2_EA1_EA1886> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA2_EA1_EA1875> ;
    skos:definition "A UsageProdPriceCharge represents a charge applicable to ProductCharges for a Product.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA2_EA1_EA1886" ;
    skos:prefLabel "UsageProdPriceCharge"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA5_EA1887> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA5_EA1893> ;
    skos:definition "<font color=\"#29313b\">A ProductOrder represents a request used to procure, update or remove one or many Products and ProductOffering</font>Instances <font color=\"#29313b\">in the context of a ProductSpecifications and ProductOffering</font>Specifications through all its ProductOfferingOrderItems and <font color=\"#29313b\">ProductOrderItems.</font><br/><i>Note that ProductSpecifications / Products cover 2 cases: 1) ProductSpecifications / Products bought by a Customer from the Service Provider, 2) ProductSpecifications / Products bought by the Service Provider from Business Partners.</i><br/><font color=\"#29313b\">ProductOrder is a sub-class of RootEntity and therefore inherits from all its attributes and relationships.</font><br/><font color=\"#29313b\">At least one CommunicationInteraction is the source of a ProductOrder. Then, additional interactions might happen such as the Customer asking why his order isn’t yet delivered or the Service Provider informing the Customer his order is completed.</font><br/><font color=\"#29313b\">A ProductOrder might refer to an Agreement specifying all what has been approved by the PartyRoles involved in the ProductOrder.</font><br/><font color=\"#29313b\">A ProductOrder</font>, ProductOfferingOrderItems <font color=\"#29313b\">and ProductOrderItems might be further described by Attachments.</font><br/>A ProductOfferingOrderItem may need other ProductOfferingOrderItems to be completed; this dependency is represented through the ProductOfferingOrderItemRelationship.<br/><font color=\"#29313b\">A ProductOrderItem may need other ProductOrderItems to be completed; this dependency is represented through the ProductOrderItemRelationship.</font><br/><font color=\"#29313b\"><br/></font><font color=\"#29313b\">ProductOrder </font>/ ProductOfferingOrderItem /<font color=\"#29313b\"> ProductOrderItem are sub-classed as</font><br/><ul><li><font color=\"#29313b\">BusinessPartnerProductOrder used to procure, update or remove ProductOfferingInstances for the Service Provider</font></li><li><font color=\"#29313b\">CustomerProductOrder used to procure, update or remove ProductOfferingInstances for Customers</font></li></ul><p/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA5_EA1887" ;
    skos:prefLabel "Figure ProdO.01 ProductOrder overview"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA5_EA1889> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA5_EA1893> ;
    skos:definition "<font color=\"#29313b\">One or many PartyRoles might be involved in a ProductOrder </font>/ ProductOfferingOrderItem /<font color=\"#29313b\"> ProductOrderItem such as Distributor, Holder, Buyer or Product User.</font><br/><font color=\"#29313b\">A ProductOrder</font>, ProductOfferingOrderItem <font color=\"#29313b\">and ProductOrderItems might be further described by Attachments related to Documents.</font><br/><font color=\"#29313b\">Each ProductOrderItem requires an action (AllowedProductAction) on a ProductSpecification.</font><br/><font color=\"#29313b\">An AllowedProductAction is either an action on ProductSpecification or exclusively on a ProductOfferingSpecification.</font><br/><font color=\"#29313b\">The configuration required is described by the related Product even if it isn’t delivered yet.</font><br/><font color=\"#29313b\">A ProductOrderItem may contain ProductOrderItems according to ProductSpecification (Composite / Atomic ProductSpecification) structure.</font><br/><font color=\"#29313b\">To deliver the corresponding Product, Place(s) to deliver and Appointment(s) might be needed. An Appointment is an arrangement to do something or meet someone at a particular time and location.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA5_EA1889" ;
    skos:prefLabel "Figure ProdO.02 ProductOrderItem detailed view"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA5_EA1891> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA5_EA1893> ;
    skos:definition "<font color=\"#29313b\">One or many PartyRoles might be involved in a ProductOrder / ProductOfferingOrderItem such as Distributor, Holder, Buyer or Product User.</font><br/><font color=\"#29313b\">A ProductOrder and ProductOfferingOrderItems might be further described by Attachments related to Documents.</font><br/><font color=\"#29313b\">Each ProductOfferingOrderItem requires an action (AllowedProductAction) on a ProductOfferingSpecification.</font><br/><font color=\"#29313b\">An AllowedProductAction is, in the context of this diagram, an action on a ProductOfferingSpecification.</font><br/><font color=\"#29313b\">The prices applicable are related to the ProductOfferingInstance or to ProductOfferingOrderItem / ProductOrder when it corresponds to prices not specific to a ProductOfferingInstance such as a global of 5% on ProductOrder one-time fees.</font><br/><font color=\"#29313b\">A ProductOfferingOrderItem may contain ProductOfferingOrderItems according to ProductOfferingSpecification (CompositeProductOfferingSpecification / AtomicProductOfferingSpecification) structure.</font><br/><font color=\"#29313b\">A ProductOfferingOrderItem may also specify the commitments chosen for a ProductOfferingSpecification (i.e. CommitmentTermOrCondition).</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA5_EA1891" ;
    skos:prefLabel "Figure ProdO.02b ProductOfferingOrderItem detailed view"@en .

