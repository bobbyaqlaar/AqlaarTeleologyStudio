<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA3_EA4572> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA3_EA4571> ;
    skos:definition "A type of EntityIdentification that does not have any subordinate EntityIdentifications, that is, an ComponentEntityIdentification is a leaf-level EntityIdentification.<br/>"@en ;
