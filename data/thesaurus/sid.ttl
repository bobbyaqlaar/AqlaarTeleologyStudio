<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6109> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6105> ;
    skos:definition "assign to activity / workflow closedloop<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA18_EA1_EA6109" ;
    skos:prefLabel "EARoot_EA4_EA2_EA10_EA18_EA1_EA6109"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6110> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6105> ;
    skos:definition "Abstract with many subclasses<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA18_EA1_EA6110" ;
