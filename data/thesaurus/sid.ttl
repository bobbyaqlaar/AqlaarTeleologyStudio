<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA8_EA1_EA1992> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA8_EA1_EA1987> ;
    skos:definition "An AllowedProductAction specifies the actions allowed for a ProductSpecification or a ProductOfferingSpecification and might limit this action to a sub-set of SalesChannel. An AllowedProductAction has a type represented by a ProductActionType.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA8_EA1_EA1992" ;
    skos:prefLabel "AllowedProductAction"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA8_EA1_EA1993> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA8_EA1_EA1987> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA8_EA1_EA1993" ;
