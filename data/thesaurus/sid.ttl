    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA2_EA1_EA4035" ;
    skos:prefLabel "Figure SEEn.01 - Security Entity Business Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA1_EA4038> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA1_EA4037> ;
    skos:definition "States whether the fix action fully avoids the risk associated with the vulnerability or reduces risk to some extent. Enumeration values: Partial, Complete.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA2_EA1_EA4038" ;
    skos:prefLabel "CommonPlatformEnumeration"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA1_EA4039> a skos:Concept ;
