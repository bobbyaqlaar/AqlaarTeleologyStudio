<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA2_EA449> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA2_EA444> ;
    skos:definition "The <b>Customer Billing Inquiry and Dispute ABE</b> represents requests for information and disputes related to invoices (CustomerBill) sent to the Customer and / or charges (AppliedCustomerBillingCharge).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA2_EA449" ;
    skos:prefLabel "Customer Billing Inquiry and Dispute ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA2_EA450> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA2_EA444> ;
    skos:definition "The Customer Interaction ABE represents communications with customers, and the translation of customer requests and inquiries into appropriate “events” such as the creation of a customer product order, the creation of a customer bill inquiry, or the creation of a customer problem.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA2_EA450" ;
    skos:prefLabel "Customer Interaction ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA2_EA451> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA2_EA444> ;
    skos:definition "The Customer Party Roles ABE is the focus on all the PartyRoles related to Customer.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA2_EA451" ;
    skos:prefLabel "Customer Party Roles ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA2_EA452> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA2_EA444> ;
    skos:definition "The Customer Problem ABE focuses on technical assistance and problem handling for customers.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA2_EA452" ;
    skos:prefLabel "Customer Problem ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA2_EA453> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA2_EA444> ;
    skos:definition "The Customer Product Order ABE handles single customer product orders and the various types thereof, such as regulated and non-regulated orders. Note: Some but not all enterprises consider an Order to be a type of an Agreement. From a SID model perspective, an Order can be formalized by an Agreement and the Agreements relationship between the Agreement and the ProductOrder. This philosophy has the advantage of clearly separating two different concepts: the order from the legal formalisms associated with the order. For example, several orders may refer to the same Agreement.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA2_EA453" ;
    skos:prefLabel "Customer Product Order ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA2_EA454> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA2_EA444> ;
    skos:definition "The Customer SLA ABE is a special case of the Service Level Agreement ABE where an involved party in the agreement is a Customer. See the Agreement ABE in the Engaged Party Domain for details.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA2_EA454" ;
    skos:prefLabel "Customer Service Level Agreement ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA2_EA455> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA2_EA444> ;
    skos:definition "The Customer Statistic ABE represents the analysis of customer usage patterns, customer profitability statistics and churn and retention statistics.<br/>"@en ;
