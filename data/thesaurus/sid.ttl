    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA4_EA3022" ;
    skos:prefLabel "IP"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA4_EA3023> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA4_EA3019> ;
    skos:definition "Values: true,falseDefault: False"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA4_EA3023" ;
    skos:prefLabel "IPX"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA4_EA3024> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA4_EA3019> ;
    skos:definition "This is an abstract base class for representing different types of routed protocols that can be managed. Routed protocols are those protocols that can be routed by a router. Specifically, the router must be able to interpret the logical internetwork as specified by that routed protocol. This class represents a convenient aggregation point for defining how routed protocols are managed and used.<br/><br/><br/><br/>The SID model defines AppleTalk, DecNET, IP, and IPX as examples of subclasses of this class.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA4_EA3024" ;
    skos:prefLabel "RoutedProtocol"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3025> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3027> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Routing Protocols </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3025" ;
    skos:prefLabel "Figure RgP.01 - Routing Protocols ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3028> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3027> ;
    skos:definition "This is the base class for representing the BGP protocol. This class represents a convenient aggregation point for defining how the BGP protocol is managed, configured and used.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3028" ;
    skos:prefLabel "BGP"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3029> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3027> ;
    skos:definition "This is the base class for defining protocols that use a distance vector routing algorithm. In this algorithm, each router sends its entire routing table in each update, but only to its neighbors. By iterating through each hop, the shortest-path spanning tree is found.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3029" ;
    skos:prefLabel "DistanceVectorRoutingProtocol"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3030> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3027> ;
    skos:definition "Values: true,falseDefault: False"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3030" ;
    skos:prefLabel "EIGRP"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3031> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3027> ;
    skos:definition "Values: true,falseDefault: False"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3031" ;
    skos:prefLabel "HybridRoutingProtocol"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3032> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3027> ;
    skos:definition "Values: true,falseDefault: False"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3032" ;
    skos:prefLabel "IGRP"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3033> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3027> ;
    skos:definition "Values: true,falseDefault: False"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3033" ;
    skos:prefLabel "IS_IS"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3034> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3027> ;
    skos:definition "This is the base class for defining protocols that use a link state routing algorithm. In this algorithm, each router broadcasts or multicasts information regarding the cost of reaching each of its neighbors to all nodes in the internetwork. In other words, each router sends only the portion of its routing table that describes the state of its own link. Link state algorithms enable each router to build a picture of the entire network in its routing table.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3034" ;
    skos:prefLabel "LinkStateRoutingProtocol"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3035> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3027> ;
    skos:definition "This is the base class for representing the OSPF protocol. This class represents a convenient aggregation point for defining how the OSPF protocol is managed, configured and used.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3035" ;
    skos:prefLabel "OSPF"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3036> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3027> ;
    skos:definition "Values: true,falseDefault: False"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3036" ;
    skos:prefLabel "PathVectorRoutingProtocol"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3037> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3027> ;
    skos:definition "Values: true,falseDefault: False"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3037" ;
    skos:prefLabel "RIP"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3038> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3027> ;
    skos:definition "This is an abstract base class for representing different types of routing protocols that can be managed. Routing protocols are used to determine how information is routed (e.g., how it traverses an intermediate system). This class represents a convenient aggregation point for defining how routing protocols are managed and used.<br/><br/><br/><br/>The SID model defines LinkStateRoutingProtocols (e.g., OSPF and IS-IS), DistanceVectorRoutingProtocols (e.g., RIP and IGRP), PathVectorRoutingProtocols (e.g., BGP) and HybridRoutingProtocols (e.g., EIGRP) as examples of subclasses of this class.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA5_EA3038" ;
    skos:prefLabel "RoutingProtocol"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA6_EA3039> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA6_EA3041> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Signaling Protocols </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA6_EA3039" ;
    skos:prefLabel "Figure SP.01 - Signaling Protocols ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA6_EA3042> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA6_EA3041> ;
    skos:definition "Values: true,falseDefault: False"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA6_EA3042" ;
    skos:prefLabel "COPS"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA6_EA3043> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA6_EA3041> ;
    skos:definition "Notes: This is a Boolean attribute that, if TRUE, signifies that this RSVPService instance is enabled.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA6_EA3043" ;
    skos:prefLabel "RSVP"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA6_EA3044> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA6_EA3041> ;
    skos:definition "This is an abstract base class for representing different types of signaling protocols that can be managed. Signaling protocols are used to convey information along a specific path. This class represents a convenient aggregation point for defining how signaling protocols are managed and used.<br/><br/><br/><br/>The SID model defines COPS and RSVP as examples of subclasses of this class.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA6_EA3044" ;
    skos:prefLabel "SignalingProtocol"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA7_EA3045> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA7_EA3047> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA7_EA3045" ;
    skos:prefLabel "Figure SwP.01 - Switching Protocols ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA7_EA3048> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA7_EA3047> ;
    skos:definition "This class is the base class of the MPLS (Multi-Protocol Label Switching) Protocol. Subclasses of the MPLS class are used to configure various aspects of MPLS.<br/><br/>MPLS separates forwarding packets from defining what the label means. The forwarding paradigm used is based on the notion of label swapping. MPLS supports a wide variety of forwarding behavior, ranging from a label being associated to a group of routes to a label being associated to a particular flow.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA7_EA3048" ;
    skos:prefLabel "MPLS"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA7_EA3049> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA7_EA3047> ;
    skos:definition "This is an abstract base class for representing different types of switching protocols that can be managed. Switching protocols are those protocols that enable routing to take into account layer 2 information, such as bandwidth and QoS. (Remember that traditional routing protocols are designed to evaluate each frame's layer 3 header only). <br/><br/><br/><br/>Several methods are available for accomplishing the task of looking at layer 2 information and defining a next hop. Most now use the concept of a label, which is a means to define the next hop without evaluating all of the information of a traditional header.<br/><br/><br/><br/>The SID model currently concentrates on defining MPLS as an example of a SwitchingProtocol.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA7_EA3049" ;
    skos:prefLabel "SwitchingProtocol"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA8_EA3050> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA8_EA3052> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>WAN Protocols </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA8_EA3050" ;
    skos:prefLabel "Figure WP.01 - WAN Protocols ABE Reatled Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA8_EA3053> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA8_EA3052> ;
    skos:definition "Values: true,falseDefault: False"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA8_EA3053" ;
    skos:prefLabel "ATM"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA8_EA3054> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA8_EA3052> ;
    skos:definition "Values: true,falseDefault: False"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA8_EA3054" ;
    skos:prefLabel "FrameRelay"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA8_EA3055> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA8_EA3052> ;
    skos:definition "Values: true,falseDefault: False"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA8_EA3055" ;
    skos:prefLabel "HDLC"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA8_EA3056> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA8_EA3052> ;
    skos:definition "Values: true,falseDefault: False"@en ;
