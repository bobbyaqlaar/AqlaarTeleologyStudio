    skos:prefLabel "EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA2933"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA2_EA2946> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA2_EA2948> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Management Method </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA2_EA2946" ;
    skos:prefLabel "Figure MM.01 - Management Method ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA2_EA2949> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA2_EA2948> ;
    skos:definition "This is an abstract base class for defining different types of CLI methods to perform various FCAPS functions.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA2_EA2949" ;
    skos:prefLabel "CLIMethod"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA2_EA2950> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA2_EA2948> ;
    skos:definition "This is an association class that defines the semantics of the DescribedByMgmtInfo aggregation. This class defines the specific semantics for different types of ManagementInfo, and how that information is obtained from the associated ManagedEntity. This enables different methods to be used to obtain different types of management information.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA2_EA2950" ;
    skos:prefLabel "DescribedMgmtInfoDetails"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA2_EA2951> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA2_EA2948> ;
    skos:definition "This is an abstract base class for representing the different types of management methods that can be used to gather a particular type of management information. For example, this enables configuration setting classes to be defined as using CLI, while configuration monitoring classes could be defined as using a different method, such as SNMP.<br/><br/>The design of how management information is obtained uses this class to gather specific type of information, and the ManagementMethodEntity class to obtain the desired data using an appropriate method. This combination of class hierarchies enables different management methods (e.g., CLI vs. SNMP) to be used to gather different types of management data, and is unique to the SID information model.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA2_EA2951" ;
    skos:prefLabel "ManagementMethodEntity"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA2_EA2952> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA2_EA2948> ;
    skos:definition "Values: true,falseDefault: False"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA2_EA2952" ;
    skos:prefLabel "ProprietaryMethod"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA2_EA2953> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA2_EA2948> ;
    skos:definition "This is an abstract base class for defining different types of RMON methods to perform various FCAPS functions.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA2_EA2953" ;
    skos:prefLabel "RMONMethod"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA2_EA2954> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA2_EA2948> ;
    skos:definition "This is an abstract base class for defining different types of SNMP methods to perform various FCAPS functions.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA2_EA2954" ;
    skos:prefLabel "SNMPMethod"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA2_EA2955> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA2_EA2948> ;
    skos:definition "This is an association class, and defines the semantics of the SupportedMgmtMethods aggregation. This enables different management methods (e.g., CLI vs. SNMP) to be used to perform configuration versus monitoring functions.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA2_EA2955" ;
    skos:prefLabel "SupportedMgmtMethodDetail"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA2_EA2956> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA2_EA2948> ;
    skos:definition "This is an abstract base class for defining different types of TL1 methods to perform various FCAPS functions.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA2_EA2956" ;
    skos:prefLabel "TL1Method"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA3_EA2957> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA3_EA2959> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Performance Info </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA3_EA2957" ;
    skos:prefLabel "Figure PI.01 - Performance Info ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA3_EA2960> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA3_EA2959> ;
    skos:definition "PerformanceInfo is the base class for all performance monitoring classes. Resource Performance is the act of collecting, correlating, consolidating, and validating various performance statistics and other operational characteristics of PhysicalResource, LogicalResource, CompoundResource, and Network entities. Service Performance is similar, except that it applies to CustomerFacingServices and ResourceFacingServices. Both of these entities also include specific subclasses for conducting network performance assessment against planned goals, performs various aspects of trend analysis, including error rate and cause analysis and Resource degradation.<br/><br/>Different types of performance indicators are associated with a particular Resource or Service using the DescribedByMgmtInfo aggregation. Performance information Subclasses of this class define the detailed characteristics and behavior of this class. Performance monitors are reported by associating the parent of this class, ManagementInfo, with the ManagementMethodEntity class through a combination of the DescribedByMgmtInfo and the MgmtInfoObtainedBy aggregation.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA3_EA2960" ;
    skos:prefLabel "PerformanceInfo"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA4_EA2961> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA4_EA2963> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Resource State </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA4_EA2961" ;
    skos:prefLabel "Figure RS.01 - Resource State ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA4_EA2964> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA4_EA2963> ;
    skos:definition "ResourceStateInfo is an abstract base class for representing different types of management information that describes the state of a particular Resource.<br/><br/>Subclasses of this class include classes to represent Faults, Outages, Alarms, the usage of this Resource, and its current operational state.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA4_EA2964" ;
    skos:prefLabel "ResourceStateInfo"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA5_EA2965> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA5_EA2967> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Resource Statistical </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA5_EA2965" ;
    skos:prefLabel "Figure RStat.01 - Resource Statistical ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA5_EA2968> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA5_EA2967> ;
    skos:definition "ResourceStatisticalInfo is an abstract base class for representing different types of statistical information that describes the state of a particular Resource or set of Resources (or a particular Service or set of Services). Subclasses of this class represent domain-specific information, including:<br/><br/> - specific LogicalResource statistics, such as those for a<br/> DeviceInterface (e.g., number of packets dropped)<br/> - specific PhysicalResource statistics, such as a fiber cut<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA5_EA2968" ;
    skos:prefLabel "ResourceStatisticalInfo"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA6_EA2969> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA6_EA2971> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Security </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA6_EA2969" ;
    skos:prefLabel "Figure Sec.01 - Security ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA6_EA2972> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA6_EA2971> ;
    skos:definition "Values: true,falseDefault: False"@en ;
