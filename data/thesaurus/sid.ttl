<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA1_EA1_EA1142> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA1_EA1_EA1128> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA3_EA1_EA1_EA1142" ;
    skos:prefLabel "start"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA1_EA2_EA1143> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA1_EA2_EA1145> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>SalesLead </b>Aggregate Business Entity</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA3_EA1_EA2_EA1143" ;
    skos:prefLabel "Figure SL.01 - Sales Lead ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA1_EA2_EA1146> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA1_EA2_EA1145> ;
    skos:definition "The SalesLead corresponds to the nominal result of an interaction involving a Prospect towards one of our offers (the first stage (S) of the SPANCO process).<br/><br/>In a nominal way, once the interest towards ours offers is confirmed and the Prospect is clearly identified, then an Opportunity might be created.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA3_EA1_EA2_EA1146" ;
    skos:prefLabel "SalesLead"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA2_EA1147> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA2_EA1149> ;
    skos:definition "The Sales Domain roles presently identified are:<br/><ul><li><b>SalesAgent</b>: A SalesAgent is a role played by a Party. A SalesAgent is responsible for selling the Service Provider’s <font color=\"#29313b\">ProductOfferingSpecifications </font>to wholesale and / or retail customers.</li><li><b>Competitor</b>: A Party playing a PartyRole that offers <font color=\"#29313b\">ProductOfferingSpecifications </font>similar to the enterprise's <font color=\"#29313b\">ProductOfferingSpecifications </font>in a MarketSegment.</li></ul><ul><li><b>Prospect</b>: A Prospect is a type of PartyRole played by a Party specifying the Party is a potential buyer of Products from the Service Provider. A Party playing a SalesLead role may play later several other PartyRoles such as Prospect and eventually Customer. The Party playing a SalesLead might be a Customer for some offers or not. Businesses gain access to sales leads through advertising, trade shows, direct mailings, third parties, and other marketing efforts.</li></ul><p/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA3_EA2_EA1147" ;
    skos:prefLabel "Figure S.00 - Sales Party Roles"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA2_EA1150> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA2_EA1149> ;
    skos:definition "A Prospect is a type of PartyRole played by a Party specifying the Party is a potential buyer of Products from the Service Provider. A Party playing a SalesLead role may play later several other PartyRoles such as Prospect and eventually Customer. The Party playing a SalesLead might be a Customer for some offers or not. Businesses gain access to sales leads through advertising, trade shows, direct mailings, third parties, and other marketing efforts.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA3_EA2_EA1150" ;
    skos:prefLabel "Prospect"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA2_EA1151> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA2_EA1149> ;
    skos:definition "A SalesAgent is a role played by a Party. A SalesAgent is responsible for selling the Service Provider’s <font color=\"#29313b\">ProductOfferingSpecifications </font>to wholesale and / or retail customers.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA3_EA2_EA1151" ;
    skos:prefLabel "SalesAgent"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA3_EA1152> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA1090> ;
    skos:definition "<b>Sales Forecast ABE </b>maintains sales forecasts, new service requirements, customer needs, and customer education.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA3_EA3_EA1152" ;
    skos:prefLabel "Sales Forecast ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA4_EA1153> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA1090> ;
    skos:definition "The <b>Sales Statistics ABE</b> maintains sales key performance indicators about Sales revenue and sales channel performance.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA3_EA4_EA1153" ;
    skos:prefLabel "Sales Statistics ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA5_EA1154> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA1090> ;
    skos:definition "<b>Sales Strategy Plan ABE</b> supports the business plans and strategies within the Sales domain.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA3_EA5_EA1154" ;
    skos:prefLabel "Sales Strategy Plan ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA6_EA1155> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA6_EA1169> ;
    skos:definition "The Figure “SC.01 – Sales Commission overview” presents the Sales Commission main entities.<br/>The primary business entities in the Sales Commission model are SalesCommission, SalesCommissionSpecification and SalesCommissionSpecificationType. <br/><ul><li>The SalesCommissionSpecification is the type of EntitySpecification which represents a sales commission specification as perceived by the business user and specifies how the commission is calculated at a functional level (i.e. what are the rules, which conditions are applicable). The commission might be a fixed value, a percentage or even a more complex formula.</li><li>A SalesCommissionSpecificationType is a type of EntitySpecificationType and represents a classification that groups SalesCommissionSpecification that share common characteristics. For e.g. SalesCommissionSpefication “Sales” is composed of different Sales Categories “Handset”, “Accessories” etc.</li><li>SalesCommission is an Entity and it represents a form of remuneration (fixed value, percentage or formula) for services rendered or products<font color=\"#29313b\"> (i.e. ProductSpecification or ProductOfferingSpecification)</font> sold by a sales agent.</li></ul>The SalesCommissionSpecificationType categorises the SalesCommissionSpecification, one or more SalesCommissionSpecificationType can be used to provide SalesCommissionSpecification categories based upon e.g., Product (device/service) ProductUsage. SalesCommissionSpecification further defines the SalesCommission. <br/>SalesCommissionSpecification is applicable for a PartyRoleSpecification (the specification used to describe the PartyRole).<br/>SalesCommission is applied to the PartyRole (Sales Agent, Employee etc.).<br/>Additional business entities, unique to a given enterprise, can be added to extend this model.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA3_EA6_EA1155" ;
    skos:prefLabel "Figure SC.01 Sales Commission overview"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA6_EA1157> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA6_EA1169> ;
    skos:definition "John (PartyRole: employee) is an employee of the CSP and he is a RetailSalesAgent.<br/>The CSP provides Sales Commission to the retail sales agents, when they achieve a Sales target. <br/>Three commissions (SalesCommissionSpecification) are specified and triggered every first of a month (defined as SalesCommissionRule):<br/><ul><li>for handset device sold 5% of total amount if total amount is above $100</li><li>for accessory sold 6% of total amount if total amount is above $50</li><li>for Usage Volume Products (such as $50 national calls) sold $1 for each Usage Volume Product equal or above $50</li></ul><p/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA3_EA6_EA1157" ;
    skos:prefLabel "Figure SC.01-I01 Sales Commission overview – SalesCommisionSpecification for Retail Sales Agent"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA6_EA1159> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA6_EA1169> ;
    skos:definition "The Figure “SC.02 – Sales Commission Specification” presents the SalesCommissionSpecification main entities.<br/>The primary business entities in the Sales Commission Specification model are SalesCommissionSpecification, SalesCommissionSpecificationType and SalesCommissionRule. <br/>SalesCommissionSpecification are further managed by the SalesCommissionRule. Additional business entities, unique to a given enterprise, can be added to extend this model.<br/>A SalesCommissionRule is a type of PolicyRule. The SalesCommissionRule is used to add complex rule, as the formula supplied as part of the SalesCommissionSpecification is simple in nature. The SalesCommissionRule specifies:<br/><ul><li>Events triggering the evaluation of the rule (Sales Events)</li></ul> • Ex: Every first of a month, on reaching a predefined amount of sale or on the request of an employee/agent<br/><ul><li>Conditions that need to be checked</li></ul> • Ex: If the invoice amount is above 100 $, If more than 2 hours of international call etc.,<br/><ul><li>Actions that should be performed if the condition clause is evaluated to TRUE </li></ul> • Ex: Calculate the Sales Commission based upon percentage of the Sales Value.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA3_EA6_EA1159" ;
    skos:prefLabel "Figure SC.02 Sales Commission Specification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA6_EA1161> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA6_EA1169> ;
    skos:definition "The Figure “SC.03 – Sales Commission Applied” presents the SalesCommission main entities.<br/>The primary business entities in the Sales Commission model are SalesCommission, SalesCommissionSpecification, CustomerProductOrder, Product and ProductUsage. SalesCommission is applied to the PartyRole (Sales Agent, Partner, Employee etc.,) and is applied as per the ProductUsage, CustomerProductOrderItem, or CustomerBill. Additional business entities, unique to a given enterprise, can be added to extend this model.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA3_EA6_EA1161" ;
    skos:prefLabel "Figure SC.03 Sales Commission applied"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA6_EA1163> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA6_EA1169> ;
    skos:definition "<font color=\"#29313b\">Let’s consider John has placed two orders in January</font><br/><ul><li><font color=\"#29313b\">One containing an iPhone 12 Pro Max for $200, AirPods Pro for $15 and a Big Usage Volume Package for $50</font></li><li><font color=\"#29313b\">The other containing a Samsung handset for $50, headset for $10 and a Small Usage Volume Package for $20</font></li></ul><p/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA3_EA6_EA1163" ;
    skos:prefLabel "Figure SC.03-I01 Sales Commission context"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA6_EA1165> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA6_EA1169> ;
    skos:definition "<font color=\"#29313b\">For January, the Handset commission for John is based on iPhone 12 Pro Max and Samsung handset he has sold.</font><br/><font color=\"#29313b\">The corresponding total amount is $250 ($200+$50). The Commission rule specifies the condition “if handset total amount is #gt; $100”, so the condition is True.</font><br/><font color=\"#29313b\">Then the formula is 5% of total amount, so $250 * 5% = $12.5.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA3_EA6_EA1165" ;
    skos:prefLabel "Figure SC.03-I02 Sales Commission applied"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA6_EA1167> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA6_EA1169> ;
    skos:definition "<font color=\"#29313b\">For January, the Accessory commission for John is based on AirPods Pro and Headset he has sold.</font><br/><font color=\"#29313b\">The corresponding total amount is $25 ($15+$10). The Commission rule specifies the condition “if accessory total amount is #gt; $50”, so the condition is False. John won’t have any accessory commission in January.</font><br/><font color=\"#29313b\">For January, the Usage Volume commission for John is based on Big National calls and Small National calls he has sold.</font><br/><font color=\"#29313b\">The Commission rule specifies the condition “if Usage Volume price is #gt; $50”, so the condition is False for the small National calls and True for the Big National call. So commission is only applicable for the Big National calls.</font><br/><font color=\"#29313b\">So John will have $1 for the Usage Volume Product commission.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA3_EA6_EA1167" ;
    skos:prefLabel "Figure SC.03-I03 Sales Commission applied"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA6_EA1170> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA6_EA1169> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA3_EA6_EA1170" ;
    skos:prefLabel "EARoot_EA4_EA2_EA3_EA6_EA1170"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA6_EA1171> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA6_EA1169> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA3_EA6_EA1171" ;
    skos:prefLabel "EARoot_EA4_EA2_EA3_EA6_EA1171"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA6_EA1172> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA6_EA1169> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA3_EA6_EA1172" ;
    skos:prefLabel "EARoot_EA4_EA2_EA3_EA6_EA1172"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA6_EA1173> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA6_EA1169> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA3_EA6_EA1173" ;
    skos:prefLabel "EARoot_EA4_EA2_EA3_EA6_EA1173"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA6_EA1174> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA6_EA1169> ;
    skos:definition "SalesCommission represents a form of remuneration (fixed value, percentage or formula) for services rendered or products sold by a sales agent.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA3_EA6_EA1174" ;
    skos:prefLabel "SalesCommission"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA6_EA1175> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA6_EA1169> ;
    skos:definition "A SalesCommissionRule is a type of PolicyRule. The SalesCommissionRule is used to add complex rule, as the formula supplied as part of the SalesCommissionSpecification is simple in nature. The SalesCommissionRule specifies:<br/><br/> • Events triggering the evaluation of the rule (Sales Events)<br/><br/> • Ex: Every first of a month, on reaching a predefined amount of sale or on the request of an employee/agent<br/><br/> • Conditions that need to be checked<br/><br/> • Ex: If the invoice amount is above 100 $, If more than 2 hours of international call etc.,<br/><br/> • Actions that should be performed if the condition clause is evaluated to TRUE <br/><br/> • Ex: Calculate the Sales Commission based upon percentage of the Sales Value.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA3_EA6_EA1175" ;
    skos:prefLabel "SalesCommissionRule"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA6_EA1176> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA6_EA1169> ;
    skos:definition "The SalesCommissionSpecification represents a sales commission specification as perceived by the business user and specifies how the commission is calculated at a functional level (i.e. what are the rules, which conditions are applicable).<br/><br/>The commission might be a fixed value, a percentage or even a more complex formula.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA3_EA6_EA1176" ;
    skos:prefLabel "SalesCommissionSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA6_EA1177> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA6_EA1169> ;
    skos:definition "A SalesCommissionSpecificationType is a type of EntitySpecificationType and represents a classification that groups SalesCommissionSpecification that share common characteristics. For e.g. SalesCommissionSpefication “Sales” is composed of different Sales Categories “Handset”, “Accessories” etc.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA3_EA6_EA1177" ;
    skos:prefLabel "SalesCommissionSpecificationType"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA7_EA1179> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA7_EA1178> ;
    skos:definition "A means by which a ServiceProvider makes available and sells ProductOfferings to the market. SalesChannels include DirectSalesForce, SalesAgents, TeleMarketers, and AlternateChannels.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA3_EA7_EA1179" ;
    skos:prefLabel "SalesChannel"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA10_EA1428> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA10_EA1432> ;
    skos:definition "The CustomerBillingStatistic and related business entities are used to model various totals and other statistical data associated with a customer account and its products that are of billing process interest over a certain period of time. For example, they can represent customer account total annual revenue or total volume of product usage per quarter. Application of various billing credits (e.g. discount, credit) can be triggered by billing statistic data meeting (for example, exceeding) a certain value.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA4_EA10_EA1428" ;
    skos:prefLabel "Figure C.15 - Customer Billing Statistic, Part 1"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA10_EA1430> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA10_EA1432> ;
    skos:definition "The CustomerBillingStatisticSpec is used to describe the statistic that needs to be collected. The UsageCharacteristicSumSpec describes the collection of usage characteristic statistic (for example, the total sum of the duration of voice calls in a month). Policy rules can be used to define, which statistic data are of the billing process interest, when they should be created and expired, how they should be calculated, and what actions should be triggered when statistic data meet certain conditions.<br/>CustomerBillingStatistic entity instances are typically created and updated during rating and billing process. Since a quantity represented by CustomerBillingStatistic changes over time corresponding Balance entities are used to track its history as shown in the figure below.<br/>For example, for a certain product a billing system may track total number of kilobytes transferred over GPRS connection per quarter. The total sum is recorded by a billing system and stored in an instance of UsageCharacteristicSum entity. When a certain volume is exceeded a DiscountProductPriceAlteration instance may be generated entitling customer to a certain discount.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA4_EA10_EA1430" ;
    skos:prefLabel "Figure C.16 - Customer Billing Statistic, Part 2"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA10_EA1433> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA10_EA1432> ;
    skos:definition "The set of CustomerBillingStatisticSpec's subclasses does not represent the complete set, but serves merely as an example into which other subclasses easily fit.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA4_EA10_EA1433" ;
    skos:prefLabel "EARoot_EA4_EA2_EA4_EA10_EA1433"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA10_EA1434> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA10_EA1432> ;
    skos:definition "A meaure of Customer churn (turnover of Customers) or Customer retention (keeping Customers).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA4_EA10_EA1434" ;
    skos:prefLabel "ChurnRetentionStatistic"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA1180> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA1186> ;
    skos:definition "The diagram below lists the Customer Domain's ABEs.<br/><b>Customer Party Roles ABE</b><br/> • The Customer Party Roles ABE contains all PartyRoles related to the Customer Domain such as Customer, Buyer or Customer Service Representative.<br/><b>Customer Product Order ABE</b><br/> • The Customer Product Order ABE handles single customer product orders and the various types thereof, such as regulated and non-regulated orders. It contains all information needed to procure Products by a Customer.<br/><b>Customer Service Level Agreement ABE</b><br/> • The Customer SLA ABE is a special case of the Service Level Agreement ABE where an involved party in the agreement is a Customer. <br/><b>Customer Interaction ABE</b><br/> • The Customer Interaction ABE represents communications with customers, and the translation of customer requests and inquiries into appropriate “events” such as the creation of a customer product order, the creation of a customer bill inquiry, or the creation of a customer problem.<br/><b>Customer Problem ABE</b><br/> • The Customer Problem ABE focuses on technical assistance and problem handling for customers.<br/><b>Applied Customer Billing Rate ABE</b><br/> • The Applied Customer Billing Rate ABE represents charges or credits assigned to the customer’s billing account in the course or for the purpose of the billing process.<br/><b>Customer Bill ABE</b><br/> • The Customer Bill ABE represents the specification of different formats of CustomerBill, the schedule of the production of bills and the Customer Bills themselves.<br/><b>Customer Bill Collection ABE</b><br/> • The Customer Bill Collection ABE handles Customer payments to the CSP and actions for overdue debts.<br/><b>Customer Billing Account ABE</b><br/> • The Customer Billing Account ABE groups the classes concerned with the CustomerBillingAccount, i.e. the billing structure, billing cycles.<br/> • The Customer Billing Account receives all charges (recurring, one time charge and usage) of the ProductOfferingInstances and Products assigned to it.<br/><b>Customer Billing Inquiry and Dispute ABE (not fully developed)</b><br/> • The Customer Billing Inquiry and Dispute ABE represents requests for information and disputes related to invoices (CustomerBill) sent to the Customer and / or charges (AppliedCustomerBillingCharge).<br/><br/><b>Customer Statistic ABE (not fully developed)</b><br/> • The Customer Statistic ABE represents the analysis of customer usage patterns, customer profitability statistics and churn and retention statistics.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA4_EA1180" ;
    skos:prefLabel "[CuD-01] Customer ABEs Level 1"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA1182> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA1186> ;
    skos:definition "The diagram below lists the Customer Domain's ABEs Level 1 and Level 2.<br/><br/><b> Customer Billing Statistic ABE</b><br/> • The Customer Billing Statistic ABE represents collected data derived from CustomerBills.<br/><b>Applied Customer Billing Rate Spec ABE</b><br/> • The Applied Customer Billing Rate Spec ABE is detailed description of AppliedCustomerBillingRate entity.<br/><b>Customer Payment ABE</b><br/> • The Customer Payment ABE represents the transfer of wealth from a customer for a product or usage of product.<br/><b>Dunning ABE</b><br/> • The Dunning ABE represents attempts to collect payment from a customer for overdue payments.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA4_EA1182" ;
    skos:prefLabel "[CuD-02] Customer ABEs Level 1 & 2"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA1184> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA1186> ;
    skos:definition "The diagram below lists the Customer Domain's ABEs and presents in each ABE the main Business Entities and relationships between these entities.<br/><b>Customer Party Roles ABE</b><br/> • The Customer represents a Party (person or legal entity or part of a legal entity) that has a contractual relationship with the CSP by buying ProductOfferingSpecifications. A Customer is a type of PartyRole and may be the Holder, the User, the Payer…<br/> • A Customer may order offers and products through CustomerOrders.<br/> • A customer may pay for one or several CustomerBillingAccounts.<br/><b>Customer Bill ABE</b><br/> • A CustomerBillingAccount is an entity that receives all charges (recurring, one-time charge and usage) of the Products assigned to it and logs accounting events on a FinancialAccount (financial entity).<br/> • According to the billing cycle, CustomerBills are produced for a CustomerBillingAccount.<br/> • Between two billing cycles, AppliedCustomerBillingRates are calculated and assigned to a CustomerBillingAccount. <br/> • An AppliedCustomerBillingRates is an amount, usually of money, for which a Party is financially liable and may be recurring, non-recurring or usage charge.<br/><b>Customer Problem ABE</b><br/> • When a Customer has a problem and points it out, a CustomerProblem is traced.<br/><b>Customer Bill Collection ABE</b><br/> • When a Customer enters a dunning process, i.e. he has not paid his invoice, a DunningCase is created. At the beginning, this DunningCase concerns the debt of his CustomerBillingAccount and it contains all details pertaining to the debt. Later if the debt is still not covered, the DunningCase will concern the FinancialAccount.<br/> • A CustomerPayment is received from a Customer and may concern many CustomerBillingAccounts.<br/><b>Customer Product Order ABE</b><br/> • A CustomerProductOrder orders ProductSpecification through ProductOfferingSpecifications and concerns Products and PoductOfferingInstances.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA4_EA1184" ;
    skos:prefLabel "[CuD-03] Customer main BEs"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA11_EA1435> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA11_EA1441> ;
    skos:definition "The <b>Customer Billing Inquiry and Dispute ABE</b> represents requests for information and disputes related to invoices (CustomerBill) sent to the Customer and / or charges (AppliedCustomerBillingCharge).<br/>CustomerBillingDispute inherits from RootEntity. Thanks to this inheritance, it can be a result of CommunicationInteraction.<br/>A CustomerBillingDispute can be related to a CustomerBillingInquiry.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA4_EA11_EA1435" ;
    skos:prefLabel "Figure CBI.01 - Customer Billing Inquiry and Dispute ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA11_EA1437> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA11_EA1441> ;
    skos:definition "As a result of a CommunicationInteraction, a CustomerBillingDispute can be produced to materialize a disagreement on several CustomerBill and / or AppliedCustomerBillingCharge.<br/>CustomerBillingDispute will follow a clearly defined lifecycle where it will be studied by the Service Provider teams. The study result can be either a rejection of the CustomerBillingDispute or a validation of it.<br/>If the CustomerBillingDispute is validated, it can be solved either:<br/>- Through an AppliedCustomerBillingRebate,<br/>- Through 0 to many AppliedCustomerBillingChargeAdjustment (to fix incorrect AppliedCustomerBillingCharge),<br/>- Through 0 to many AppliedCustomerBillAdjustment (to fix incorrect CustomerBill).<br/>AppliedCustomerBillingChargeAdjustment can concern serveral AppliedCustomerBillingCharge. AppliedCustomerBillAdjustment concerns only one CustomerBillingAccount.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA4_EA11_EA1437" ;
    skos:prefLabel "Figure CBI.02 - CustomerBillingDispute associations to other business entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA11_EA1439> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA11_EA1441> ;
    skos:definition "A CustomerBillingDispute is created as a result of a CommunicationInteraction. It is then sent to the appropriate team to study its validity.<br/>The study determines if the CustomerBillingDispute is accepted or rejected.<br/>If the CustomerBillingDispute is rejected, the lifecycle is finished.<br/>If the CustomerBillingDispute is validated, solving actions are applied (AppliedCustomerBillingRebate, AppliedCustomerBillingChargeAdjustment or AppliedCustomerBillAdjustment).<br/>The status is then \"Solved\". The lifecyle is finished.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA4_EA11_EA1439" ;
    skos:prefLabel "Figure CBI.03 - CustomerBillingDispute Lifecycle"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA11_EA1442> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA11_EA1441> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA4_EA11_EA1442" ;
    skos:prefLabel ":CommunicationInteraction"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA11_EA1443> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA11_EA1441> ;
    skos:definition "These entities should be placed in AppliedCustomerBillingRate ABE, and inherit from AppliedCustomerBillingCredit<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA4_EA11_EA1443" ;
    skos:prefLabel "EARoot_EA4_EA2_EA4_EA11_EA1443"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA11_EA1445> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA11_EA1441> ;
    skos:definition "CustomerBillingInquiry represents a request for information about a statement of money owed by or charge to a customer. This can concern a CustomerBill or an AppliedCustomerBillingCharge.<br/>CustomerBillingInquiry is a result of a CommunicationInteraction.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA4_EA11_EA1445" ;
    skos:prefLabel "CustomerBillingInquiry"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA11_EA1446> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA11_EA1444> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA4_EA11_EA1446" ;
    skos:prefLabel "Created"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA11_EA1447> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA11_EA1444> ;
    skos:inScheme thes:sid ;
