<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA638> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA568> ;
    skos:definition "Example of use of Base Type Entities in the type of attribute.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA638" ;
    skos:prefLabel "Base Types Example ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA639> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA567> ;
    skos:definition "The Anomaly Entity ABE contains entities that are used to represent the various aspects of an Anomaly. This includes Product, Service, and Resource Anomalies as well as entities for concepts such as anomaly categorization, grouping, indicators, thresholds, consequences, reporting and notification.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA639" ;
    skos:prefLabel "Anomaly Entity ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA640> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA567> ;
    skos:definition "<font color=\"#29313b\">The Anomaly Management Plan ABE contains a group of entities that define the management plan for an Anomaly. For instance, the Anomaly management process typically involves stages such as Prediction, Detection, Mitigation, etc. Each stage necessitates a tailored strategy, which could include fixed logic for addressing the Anomaly and machine learning modules offering recommendations. </font><br/><font color=\"#29313b\">The AnomalyManagementPlan ABE comprises the AnomalyManagementPlanSpecification and AnomalyManagementPlan entities. These entities, adhering to the EntitySpecification-Entity pattern, allow Anomaly Management implementers to specify additional attributes essential for articulating the management plan. </font><br/><font color=\"#29313b\">The AnomalyManagementPlan is commonly utilized by the Closed Loop system, which oversees Anomalies, to configure the functions and workflows responsible for Anomaly Management.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA640" ;
    skos:prefLabel "Anomaly Management Plan ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA641> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA567> ;
    skos:definition "The Anomaly Specification ABE contains entities that are used to define the shared characteristics and behavior of Anomaly entities associated with Product, Service and Resource. It also includes related entities that specify the characteristic of grouping, categorization, indicators, and applicability of the Anomaly.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA641" ;
    skos:prefLabel "Anomaly Specification ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA642> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA572> ;
    skos:definition "BusinessRule ABE represents a set of information that captures the definition of instructions to determine how a process (task/activity/workflow/etc.) is performed. <br/><br/>Business rules guide operations in an organization as they determine how processes should be executed to maintain the organization's integrity. Business rules are essential for business process models (workflows) and input to have complete conceptional modeling during requirement elicitation. <br/><br/>In a model-driven domain, modeling activities and workflows without modeling business rules limit the degree of flexibility in automating operations. In a zero-touch operation, the ability to model information using machine-based platforms requires capturing all the entities at play. BusinessRule ABE is one such primary entity that is represented by this contribution.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA642" ;
    skos:prefLabel "Business Rule ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA643> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA576> ;
    skos:definition "The Maturity Model Entity represents the structure framework used to assess the maturity of an entity.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA643" ;
    skos:prefLabel "Maturity Model Entity ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA644> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA576> ;
    skos:definition "The Maturity Model Specification ABE contains all what represent a Maturity Model specification as perceived by the capability assessment relevant to specify what the function or organization wants to evaluate as representation of being performant.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA644" ;
    skos:prefLabel "Maturity Model Specification ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA645> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA662> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA6_EA645" ;
    skos:prefLabel "Loyalty ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA647> a skos:Concept ;
