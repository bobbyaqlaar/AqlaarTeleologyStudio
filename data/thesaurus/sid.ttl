<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA3_EA3_EA2608> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA3_EA3_EA2603> ;
    skos:definition "An OfficeFunctionSpec is an example of type of ResourceFunctionSpec. It describes Office Suite's functions.<br/>"@en ;
