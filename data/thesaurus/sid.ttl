<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA858> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA857> ;
    skos:definition "The <b>Document ABE</b> defines the specification of documents and the corresponding records, i.e. documents of interest for a company.<br/>A Document might be a SimpleDocument (simple text or image), a GeneratedDocument (a Document generated using a PatternDocument like a welcome email customized for each new customer), or a PatternDocument (a Document specifying the background and the variables to fill in order to produce a GeneratedDocument).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA10_EA858" ;
    skos:prefLabel "Document ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA859> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA857> ;
    skos:definition "Pemission ABE contains all Business Entities for describing Permission Specifications, effective Permissions granted including the scope of permissions.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA10_EA859" ;
    skos:prefLabel "Permission ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA861> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA857> ;
    skos:definition "The Communication Interaction ABE contains all entities needed for specifying a CommunicationInteraction describing an exchange of information during a communication between two or more human(s) and/or machine(s) during a period of time. CommunicationInteraction might concern Parties playing a role of Customer, Supplier… or even Resource, therefore the ABE « CommunicationInteraction ABE » is located in « Shared Domain ». <br/>.\\doc\\Figure CI.04 - CommunicationIteractionItem Hierarchy.docx<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA10_EA861" ;
    skos:prefLabel "Communication Interaction ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA862> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA857> ;
    skos:definition "A Digital Identity ABE contains all Business Entities used for enabling identification / authentification of Party or Resource in order to allow Party or Resource to use their permission carried by their roles.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA10_EA862" ;
    skos:prefLabel "Digital Identity ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA868> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA863> ;
    skos:definition "A set of entities that determine where things are in relation to a local coordinate system. It provides a linking point to other parts of the SID model.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA10_EA868" ;
    skos:prefLabel "Local Place ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA869> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA863> ;
    skos:definition "A set of geometric standards defined by the Open Geospatial Consortium (OGC), an international industry consortium made up of companies, government agencies, and universities participating in a consensus process to develop publicly available interface standards.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA10_EA869" ;
    skos:prefLabel "OpenGisSFS ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA870> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA864> ;
    skos:definition "The various means by which a PartyRole or PartyAccount/BillingAccountContact can be reached, such as by telephone, fax, email.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA10_EA870" ;
    skos:prefLabel "Contact Medium ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA871> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA864> ;
    skos:definition "Groups main entities within currency model.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA10_EA871" ;
    skos:prefLabel "Currency ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA872> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA864> ;
    skos:definition "The Party Community ABE is composed of a Community, which is a PartyRole played by an Organization, CommunityMembers who can commit to a Community, make Contributions to the Community and consume Assets from a Community.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA10_EA872" ;
    skos:prefLabel "Party Community ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA873> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA864> ;
    skos:definition "Demographics deal with the study of individuals and organizations (Parties), including their size, growth, density, and distribution, as well as statistics regarding birth, marriage, disease, and death. Demographic data is information about parties that allows decisions to be made such as the make-up and size of a market segment, classification and ranking of customers, and so forth. Demographics provide the key “what” information and can be broken down into two categories: individual demographics and organization demographics.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA10_EA873" ;
    skos:prefLabel "Party Demographic ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA874> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA864> ;
    skos:definition "The various forms of identification used by individuals and organizations, collectively called parties.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA10_EA874" ;
    skos:prefLabel "Party Identification ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA875> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA864> ;
    skos:definition "Used to model Party Organization.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA10_EA875" ;
    skos:prefLabel "Party Organization ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA876> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA864> ;
    skos:definition "The characteristics used to group Parties that typify MarketSegments and for the formulation and targeting of MarketingCampaigns. A Party ProfileType is used to categorize one or more PartyRoleSpecifications. A PartyProflieType can be defined for one or more GeographicAreas. The profile can target one or more ProductOfferings and one or more MarketSegments. PartyProfileTypes can be based on (or defined by) DemographicCharacteristics.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA10_EA876" ;
    skos:prefLabel "Party Profile ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA877> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA864> ;
    skos:definition "A set of example PartyRoles that a Party may play.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA10_EA877" ;
    skos:prefLabel "Party Role Examples ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA878> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA864> ;
    skos:definition "Party Role Group ABE contains all Business Entities used to specify PartyRoleGroups.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA10_EA878" ;
    skos:prefLabel "Party Role Group ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA879> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA864> ;
    skos:definition "The skills an individual or organization possesses and a catalog of specification of skills.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA10_EA879" ;
    skos:prefLabel "Skill ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA880> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA860> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA10_EA880" ;
    skos:prefLabel "Schedule Definition ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA881> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA865> ;
    skos:definition "Bank ABE inclueds entitites related to Bank.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA10_EA881" ;
    skos:prefLabel "Bank ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA882> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA865> ;
    skos:definition "The Payment Method ABE contains all the types of PaymentMethods. PaymentMethod is the way in which party provides payment, for example cash ,credit,transfer.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA10_EA882" ;
    skos:prefLabel "Payment Method ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA883> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA867> ;
    skos:definition "A group of entities used to represent the geographic address of a location.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA10_EA883" ;
    skos:prefLabel "Geographic Address ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA884> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA867> ;
    skos:definition "An set of object, such as lines, surfaces, and points, used to represents something.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA10_EA884" ;
    skos:prefLabel "Symbology ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA885> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA866> ;
    skos:definition "The Party Privacy Profile ABE contains all entities used by the Party Privacy Management process for specifying the choices made by Parties for their own Privacy.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA10_EA885" ;
    skos:prefLabel "Party Privacy Profile ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA886> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA866> ;
    skos:definition "The Party Privacy Profile ABE contains all entities used by the Party Privacy Management process for specifying <br/><br/> - the information concerned by Privacy rules,<br/><br/> - the Privacy rules themselves.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA10_EA886" ;
    skos:prefLabel "Party Privacy Profile Type ABE"@en .

