    skos:prefLabel "ImageAsset"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA2467> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA2456> ;
    skos:definition "This is the abstract base class for all ResourceRoleSpecification subclasses. It exists to enable relationships to be defined between it and other classes in the model. This helps prevent relationship explosion. It is used to define the invariant attributes, methods, relationships, and constraints of various types of roles associated with Resources (both physical and logical) in the model.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA2_EA2467" ;
    skos:prefLabel "ResourceRoleSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA2468> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA2456> ;
    skos:definition "A characteristic quality or distinctive feature of a ResourceSpecification. The characteristic can be take on a discrete value, such as color, can take on a range of values, (for example, sensitivity of 100-240 mV), or can be derived from a formula (for example, usage time (hrs) = 30 - talk time *3). Certain characteristics, such as color, may be configured during the ordering or some other process.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA2_EA2468" ;
    skos:prefLabel "ResourceSpecCharacteristic"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA2469> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA2456> ;
    skos:definition "A number or text that can be assigned to a ResourceSpecCharacteristic.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA2_EA2469" ;
    skos:prefLabel "ResourceSpecCharacteristicValue"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA2470> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA2456> ;
    skos:definition "A use of the ResourceSpecCharacteristic by an ServiceSpecification to which additional properties (attributes) apply or override the properties of similar properties contained in ResourceSpecCharacteristic.This aggregation defines the set of characteristics, or distinguishing features, of a particular ResourceSpecification.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA2_EA2470" ;
    skos:prefLabel "ResourceSpecCharUse"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA2471> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA2456> ;
    skos:definition "A use of theResourceSpecCharacteristicValue by an EntitySpecification to which additional properties (attributes) apply or override the properties of similar properties contained in ResourceSpecCharacteristicValue.This association defines the allowed set of values (represented as instances of the ResourceSpecCharacteristicValue object) that a specific ResourceSpecification can have when that ResourceSpecification object is instantiated.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA2_EA2471" ;
    skos:prefLabel "ResourceSpecCharValueUse"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA2472> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA2456> ;
    skos:definition "ResourceSpecification is an abstract base class that is used to define the invariant characteristics and behavior (attributes, methods, constraints, and relationships) of a managed or unmanaged Resource.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA2_EA2472" ;
    skos:prefLabel "ResourceSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA2473> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA2456> ;
    skos:definition "A role that a ResourceSpecification plays in defining a PerformanceSpecification.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA2_EA2473" ;
    skos:prefLabel "ResourceSpecificationPerfRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA2474> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA2456> ;
    skos:definition "A migration, substitution, dependency, or exclusivity relationship between/among ResourceSpecifications.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA2_EA2474" ;
    skos:prefLabel "ResourceSpecificationRelationship"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA2475> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA2456> ;
    skos:definition "A ResourceSpecificationType entity is used to categorize sets of ResourceSpecifications.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA2_EA2475" ;
    skos:prefLabel "ResourceSpecificationType"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA2476> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA2456> ;
    skos:definition "This class represents the ability to distinguish between different instances of ResourceSpecifications. It represents a particular form or variety of a ResourceSpecification that is different from others or from the original. The form represents differences in attributes, methods, relationships, and/or constraints that characterize this particular ResourceSpecification, but which are not enough to warrant creating a new ResourceSpecification.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA2_EA2476" ;
    skos:prefLabel "ResourceSpecVersion"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA2477> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA2456> ;
    skos:definition "This class defines the semantics of the modifiesResourceSpec aggregation. Specifically, it enables an application to define which set of versions of this ResourceSpecification are appropriate for a given task.This aggregation represents the set of versions of this ResourceSpecification. The semantics of this aggregation are implemented with the ResourceSpecVersionDetails class.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA2_EA2477" ;
    skos:prefLabel "ResourceSpecVersionDetails"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA2_EA2539> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA2_EA2541> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>CompoundResource Specification </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA2_EA2_EA2539" ;
    skos:prefLabel "Figure CRS.01 - CompoundResource Specification ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA2_EA2542> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA2_EA2541> ;
    skos:definition "The CompoundResourceSpec used to define the invariant characteristics and behavior (attributes, methods, constraints, and relationships) of a CompoundResource.<br/><br/>The key difference between a CompoundResourceSpec and either a PhysicalResourceSpec and a LogicalResourceSpec is that a PhysicalResourceSpec and LogicalResourceSpec define templates for specifying the invariant characteristics and behavior of PhysicalResources and LogicalResources, respectively. Optionally, one or more CompoundResourceSpecs may also be specified.<br/><br/>Thus, a CompoundResourceSpec is in effect a \"shorthand notation\" for specifying complementary PhysicalResourceSpecs and / or LogicalResourceSpecs.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA2_EA2_EA2542" ;
    skos:prefLabel "CompoundResourceSpec"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA2_EA2543> a skos:Concept ;
