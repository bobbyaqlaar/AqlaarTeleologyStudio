<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA1_EA2525> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA1_EA2519> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA2_EA1_EA2525" ;
