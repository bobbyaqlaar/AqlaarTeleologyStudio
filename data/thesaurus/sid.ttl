    skos:prefLabel "LocalPolygon"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7147> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7128> ;
    skos:definition "A LocalLocation that is defined using coordinates that are relative to another LocalLocation.<br/><br/>The coordinate units are defined in the LocalCoordinateSystem.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA2_EA7147" ;
    skos:prefLabel "RelativeLocalLocation"@en .

