    skos:notation "sid:EARoot_EA4_EA2_EA10_EA12_EA5_EA5684" ;
    skos:prefLabel "Project Role ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA12_EA9_EA5720> a skos:Concept ;
