    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA6_EA1377> ;
    skos:definition "The Customer Payment ABE represents the transfer of wealth from a customer for a product or usage of product.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA4_EA6_EA1_EA1384" ;
    skos:prefLabel "Customer Payment ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA9_EA1425> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA1186> ;
