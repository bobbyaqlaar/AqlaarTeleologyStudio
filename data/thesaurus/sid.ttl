    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA21_EA2_EA6300> ;
    skos:definition "MaturityModel represents the structured framework used to assess the maturity of an entity: organization, processes, capabilities, services or systems. Maturity Model provide a systematic approach to evaluate current state, identify areas for improvement, and develop a roadmap for achieving higher levels of performance and effectiveness. Maturity model consists of several levels or stages, each representing a different degree of sophistication and capability.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA21_EA2_EA6314" ;
    skos:prefLabel "MaturityModel"@en .

