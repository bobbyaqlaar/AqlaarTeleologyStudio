<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA4_EA529> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA4_EA526> ;
    skos:definition "Market Sales Party Roles ABE contains all PartyRoles related to the Market Sales Domain such as MarketingManager, SalesAgent...<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA4_EA529" ;
    skos:prefLabel "Market Party Roles ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA4_EA530> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA4_EA526> ;
    skos:definition "Market Segment ABE supports market segments description.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA4_EA530" ;
    skos:prefLabel "Market Segment ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA4_EA531> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA4_EA526> ;
    skos:definition "The Market Sales Statistics maintains market and sales key performance indicators about Sales & Marketing revenue and sales channel performance.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA4_EA531" ;
    skos:prefLabel "Market Statistics ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA4_EA532> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA4_EA526> ;
    skos:definition "Market & Sales Strategy Plan ABE supports the business plans and strategies on how to address the market with appropriate products and channels.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA4_EA532" ;
    skos:prefLabel "Market Strategy Plan ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA4_EA533> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA4_EA526> ;
    skos:definition "The Marketing Campaign ABE represents the strategy, or approach, for marketing new or existing ProductOfferings to identified target markets. The campaign could be for one of the following: <br/><ul><li> The launch of a pre-paid ProductOffering with multiple promotions across SalesChannels, MarketSegments, and so forth </li><li>A new campaign for an existing ProductOffering; the ProductOffering is not new, but the relationships, collateral, and so forth could be new </li><li>A re-launch of a campaign for an existing ProductOffering</li></ul><p/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA4_EA533" ;
    skos:prefLabel "Marketing Campaign ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA4_EA534> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA4_EA526> ;
    skos:definition "<b>Marketing Performance ABE</b> contains all information used to define Marketing and Sales performance objectives and Marketing indicators measured.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA4_EA534" ;
    skos:prefLabel "Marketing Performance ABE"@en .

