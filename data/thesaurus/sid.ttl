    skos:prefLabel "Security Incident ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA504> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA503> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA3_EA504" ;
    skos:prefLabel "Security Vulnerability Score ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA506> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA514> ;
    skos:definition "The<b> Sales Revenue ABE</b> captures gross revenue from the sale of goods (e.g., handsets, CPE) and non-recurring services before deductions. Often tracked separately from recurring service Revenue to support margin analysis between device sales and service bundles.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA3_EA506" ;
    skos:prefLabel "Sales Revenue ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA507> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA481> ;
    skos:definition "<b>Accounts Payable ABE</b> represents the total amount the CSP owes to suppliers, vendors, or partners for received goods and services. It aggregates obligations from purchase orders, supplier invoices, and expense claims, supporting payment processing, vendor reconciliation, and liability tracking.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA3_EA507" ;
    skos:prefLabel "Accounts Payable ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA508> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA481> ;
    skos:definition "<b>Accounts Receivable ABE</b> represents the total amount owed to the CSP by customers or other parties for delivered products and services. It aggregates unpaid or partially paid PartyAccounts and tracks receivables from invoicing until payment or write-off. Used internally for revenue recognition, aging analysis, dunning, and bad-debt provisioning.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA3_EA508" ;
    skos:prefLabel "Accounts Receivable ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA510> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA481> ;
    skos:definition "<b>Debt ABE</b> aggregates the total obligations of the CSP to repay borrowed funds to lenders or bondholders. It includes short-term and long-term loans, bonds, leases classified as debt, and other financing liabilities, including accrued interest.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA3_EA510" ;
    skos:prefLabel "Debt ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA511> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA481> ;
    skos:definition "<b>EBITDA ABE</b>, or Earnings Before Interest, Taxes, Depreciation, and Amortization measures the CSP’s operating profitability from core business activities only. It is calculated as Operating Income + Depreciation of tangible assets + Amortization of intangible assets (or equivalently: Revenue − COGS − Opex excluding all non-cash depreciation and amortization charges). EBITDA is widely used in the telecom industry for valuation multiples, covenant testing in debt agreements, and operational performance comparison because it eliminates the effects of financing structure, tax regimes, and non-cash accounting choices.<br/>To summarize: EBITDA = Revenue − Cost of Revenue (COGS) − Opex (cash operating expenses)<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA3_EA511" ;
    skos:prefLabel "EBITDA ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA515> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA513> ;
    skos:definition "<b>Net Income ABE</b> representing the CSP’s profit or loss for a period. It is calculated as total Income plus/minus other gains/losses minus all Costs, Opex, depreciation/amortization, interest expense, taxes, and extraordinary items. Also known as Profit (Loss) After Tax or Bottom-Line Result. <br/>To summarize: NetIncome (\"bottom line\") = Income - Interest - Taxes<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA3_EA515" ;
    skos:prefLabel "Net Income ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA516> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA513> ;
    skos:definition "<b>Operating Income ABE</b> measures the profit a CSP generates from its core telecommunications operations before deducting interest expenses, taxes, and non-operating items. It is calculated as total Revenue minus Cost of Revenue (COGS) and all Operating Expenses (Opex, including network operations, customer care, marketing, administrative expenses, and depreciation/amortization of operational assets). Operating Income reflects the operational profitability of the CSP’s service and product delivery activities. Also known as EBIT – Earnings Before Interest and Taxes, or Operating Profit.<br/>To summarize: Operating Income (EBIT) = EBITDA − Depreciation (network, buildings, etc.) − Amortization (spectrum licenses, software, customer base, etc.)<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA3_EA516" ;
    skos:prefLabel "Operating Income ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA517> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA509> ;
    skos:definition "<b>Capex ABE</b>, or Capital Expenditure records expenditures used by the CSP to acquire, upgrade, or extend the useful life of long-term tangible or intangible assets (e.g., network equipment, fiber, software licenses, spectrum). Capex is typically capitalized and depreciated/amortized over time.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA3_EA517" ;
    skos:prefLabel "Capex ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA518> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA512> ;
    skos:definition "<b>Cost ABE</b> aggregates all expenses incurred by the CSP to produce and deliver its services and products. Includes Cost of Goods Sold (COGS), network operating costs, interconnection fees, content costs, and commissions. Used for profitability and margin analysis.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA3_EA518" ;
    skos:prefLabel "Cost ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA519> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA512> ;
    skos:definition "<b>Opex ABE</b>, or Operating Expenditure, records day-to-day expenses required to run the CSP’s operations that are expensed in the period incurred. Includes network maintenance, salaries, marketing, customer care, IT operations, rent, and utilities (excluding Capex and cost of goods sold related to device sales).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA3_EA519" ;
    skos:prefLabel "Opex ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA4_EA520> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA4_EA527> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA4_EA520" ;
    skos:prefLabel "Competitor ABE"@en .

