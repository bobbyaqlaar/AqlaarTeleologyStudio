    skos:prefLabel "Product Domain"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA655> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA666> ;
