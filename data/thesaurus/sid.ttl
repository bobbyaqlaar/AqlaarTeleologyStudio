<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA484> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA496> ;
    skos:definition "A measure of the effectiveness of RAControls, RAObjectives, and RA KPIs. RAAssessment also includes recommendations for refining RAControls, RAObjectives, and RAKPIs.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA3_EA484" ;
    skos:prefLabel "RA Assessment ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA485> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA496> ;
    skos:definition "Policy-based rules that represent the logical definition of comparisons performed on entities, such as CustomerBills and CallDetailRecords, to identify RAViolations.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA3_EA485" ;
    skos:prefLabel "RA Control ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA486> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA496> ;
    skos:definition "KeyPerformanceIndicators and RAObjectives that may trigger the creation of a RATroubleTicket. KeyPerformanceIndicator are defined on RAViolations, and on other Revenue Assurance related entities, such as CustomerBills and CallDetailRecords.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA3_EA486" ;
    skos:prefLabel "RA Key Performance Indicator ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA487> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA496> ;
    skos:definition "A TroubleTicket opened to resolve one or several causes (for example, RA Violations) that resulted in a RAKeyPerformanceIndicator exceeding one or more RAObjective thresholds.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA3_EA487" ;
    skos:prefLabel "RA Trouble Ticket ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA488> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA496> ;
    skos:definition "A discrepancy identified based on applying Policies associated with RAControl(s) to Revenue Assurance related entities, such as Products and ResourceUsage.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA3_EA488" ;
    skos:prefLabel "RA Violation ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA489> a skos:Concept ;
