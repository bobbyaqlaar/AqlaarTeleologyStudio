    skos:definition "The following state diagram provides an overview of the allowed states for the ActualCost entity.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA23_EA6390" ;
    skos:prefLabel "Figure Co.05 - ActualCost State Diagram"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA23_EA6392> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA23_EA6398> ;
    skos:definition "The following state diagram provides an overview of the allowed states for the ProjectedCostItem entity.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA23_EA6392" ;
    skos:prefLabel "Figure Co.06 - ProjectedCostItem State Diagram"@en .

