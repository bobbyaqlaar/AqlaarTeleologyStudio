<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA7_EA3064> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA2841> ;
    skos:definition "The Resource Number ABE contains entities that are used to represent the various aspects of a Number.<br/>For this we have the generical classes: ResourceNumber and ResourceNumberSpecification with its respective Figure to describe its relationships between them and with other entities from other domains.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA7_EA3064" ;
    skos:prefLabel "Resource Number ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA3160> a skos:Concept ;
