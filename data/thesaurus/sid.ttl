    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA796" ;
    skos:prefLabel "Service Domain"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA798> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA804> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA798" ;
    skos:prefLabel "Service Domain Structure"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA800> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA811> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA800" ;
    skos:prefLabel "Service Performance ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA802> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA813> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA802" ;
    skos:prefLabel "Service Specification ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA807> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA804> ;
    skos:definition "Specific ability of Service domain entities measured in quantity and units of quantity over an extended period.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA807" ;
    skos:prefLabel "Service Capacity ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA808> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA804> ;
    skos:definition "The definition of how a Service operates or functions in terms of CharacteristicSpecification(s) and related ResourceSpec(s) and ServiceSpec(s) as well as a representation of how a Product operates or functions in terms of characteristics and related Resource(s) and Service(s). For more detail refer to Configuration & Profiling ABE in Common Domain<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA808" ;
    skos:prefLabel "Service Configuration ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA809> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA804> ;
    skos:definition "The Service Order ABE contains entities that represent a type of Request that decomposes a Customer Order's products into the services associated with a ServiceOrder through which the products are realized.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA809" ;
    skos:prefLabel "Service Order ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA810> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA804> ;
    skos:definition "Service Party Roles ABE contains all PartyRoles related to the Service Domain such as ServiceManager.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA810" ;
    skos:prefLabel "Service Party Roles ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA812> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA804> ;
    skos:definition "The Service Problem ABE manages faults, alarms, and outages from a Service point-of-view. This is then correlated to trouble tickets, regardless of whether the cause is physical or logical.<br/><br/>Other entities in this ABE are used to direct the recovery from each of these three types of problems. They provide the ability to associate Resource faults and alarms to degradation and outages of Services that run on those Resources. These functions are independent of the Resources and technologies used to build the Service.<br/><br/>A third set of entities in this ABE is used to differentiate between customer-reported problems and network-induced problems.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA812" ;
    skos:prefLabel "Service Problem ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA814> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA804> ;
    skos:definition "The Service Strategy and Plan ABE contains entities that are used to address the need for enhanced or new Services, as well as the retirement of existing Services, by the enterprise. These entities have a strong dependency to both entities in the Resource and Product domains. Resulting efforts, such as deciding what Resources to use to host a Service, or what Services are used to support new Product Specifications, are also supported, as are service demand forecasts.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA814" ;
    skos:prefLabel "Service Strategy & Plan ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA815> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA804> ;
    skos:definition "A Service Test is a function performed on a service that results in measures being produced that reflect the functioning of the entity under test.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA815" ;
    skos:prefLabel "Service Test ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA817> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA804> ;
    skos:definition "<font color=\"#ff0000\">This ABE is likely to be removed in Release 25.5</font><br/><br/>The TMF Interface Program introduced in the Multi-Technology Operations System Interface (MTOSI) 2.0, Service Management interfaces based upon extensions to the SID service model in this ABE. The resulting solution set introduced two new service management activation interfaces, and a service inventory interface.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA817" ;
    skos:prefLabel "TIP Service Management ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA818> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA816> ;
    skos:definition "The Service Usage Entity ABE collects service usage information, and generates ServiceUsage according to ServiceUsageSpecification for use by other business entities.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA818" ;
    skos:prefLabel "Service Usage Entity ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA819> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA816> ;
    skos:definition "The Service Usage Specification ABE specifies types and characteristics of usage of ServiceSpecifications.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA819" ;
    skos:prefLabel "Service Usage Specification ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA820> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA827> ;
    skos:definition "The Resource Facing Service Spec Role ABE defines a ServiceSpecification, in terms of a set of ServiceSpecificationRoles, for a ResourceFacingService. It is used to represent the shared characteristics of a ResourceFacingService. This enables the ResourceFacingService to be managed abstractly using ServiceSpecificationRoles. It also helps define a ResourceFacingServiceSpecification in terms of the functions that it has or provides.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA820" ;
    skos:prefLabel "Resource Facing Service Spec Role ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA822> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA829> ;
    skos:definition "The Customer Facing Service Example ABE contains an example CustomerFacingService entity.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA822" ;
    skos:prefLabel "Customer Facing Service Example ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA823> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA829> ;
    skos:definition "The Customer Facing Service Role ABE defines CustomerServiceRoles that are used to represent the variable characteristics of a CustomerFacingService in terms of roles that this type of Service plays.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA823" ;
    skos:prefLabel "CustomerFacing Service Role ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA824> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA829> ;
    skos:definition "The Network Service ABE contains the NetworkService description and relationships.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA824" ;
    skos:prefLabel "Network Service ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA825> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA829> ;
    skos:definition "The Usage Volume Service ABE contains the UsageVolumeService and all the entities specific to this type of service.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA825" ;
    skos:prefLabel "Usage Volume Service ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA828> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA813> ;
    skos:definition "A collection of entities that represent the specification of ServiceCatalogs and catalogs described by them that contain ServiceSpecifications.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA828" ;
    skos:prefLabel "Service Catalog ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA831> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA821> ;
    skos:definition "The Service Bundle Examples ABE contains example subclasses of ServiceBundleSpec.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA831" ;
    skos:prefLabel "Service Bundle Examples ABE"@en .

