<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA2_EA6782> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA2_EA6777> ;
    skos:definition "CreditCardPM is an example of payment method, using which payment can be made by credit card.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA4_EA2_EA6782" ;
    skos:prefLabel "CreditCardPM"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA2_EA6783> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA2_EA6777> ;
    skos:definition "Pay with a debit card issued by a bank.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA4_EA2_EA6783" ;
    skos:prefLabel "DebitCardPM"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA2_EA6784> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA2_EA6777> ;
    skos:definition "A DigitalWalletPM enables debit on a digital wallet.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA4_EA2_EA6784" ;
    skos:prefLabel "DigitalWalletPM"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA2_EA6785> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA2_EA6777> ;
    skos:definition "A payment method that uses loyalty points to make a payment.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA4_EA2_EA6785" ;
    skos:prefLabel "LoyaltyBurnPM"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA2_EA6786> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA2_EA6777> ;
    skos:definition "PaymentMethod is the way in which party provides payment, for example cash ,credit,transfer.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA4_EA2_EA6786" ;
    skos:prefLabel "PaymentMethod"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA2_EA6787> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA2_EA6777> ;
    skos:definition "A PaymentMethodSpecification defines characteristics that mighnt be used to describe a PaymentMethod.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA4_EA2_EA6787" ;
    skos:prefLabel "PaymentMethodSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA2_EA6788> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA2_EA6777> ;
    skos:definition "ThirdPartyCollectionPM is an example of payment method, using which payment can be made through the third party,such as bank transfer, payment tool(like PayPal, Alipay).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA4_EA2_EA6788" ;
    skos:prefLabel "ThirdPartyCollectionPM"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA6752> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA6760> ;
    skos:definition "A PartyPayment represents the transfer of wealth from one Party to another. So it is received from a PartyRole and made to a PartyRole.<br/>The PartyPayment might be either inbound or outbound and always uses a PaymentMethod.<br/>A PartyPayment might specify the BankAccount to which the payment is transferred.<br/>The diagram below shows different types of PaymentMethods identified at the present time, currently allowed for paying due amounts such as CheckPM, DigitalWalletPM, LoyaltyBurnPM...<br/>A PaymentMethod is declared and owned by a PartyRole that has the right to use it.<br/>As all the PaymentMethod might not be yet described as a sub-class of PaymentMethod, a PaymentMethod might be described by a PaymentMethodSpecification defining the characteristics.<br/>ThirdPartyCollectionPM is an example of payment method, using which payment can be made through the third party, such as bank transfer, payment tool(like PayPal, Alipay).<br/>A PaymentMethod is owned by a PartyRole.<br/>A PaymentPlan may specify PaymentMethods to use for auto-pay. If several PaymentMethod are specified, a priority is given to each of them. Over time, PartyPayments are collected according to the PaymentPlan.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA4_EA6752" ;
    skos:prefLabel "Figure PAY.01 - Payment Method and Payment Plan"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA6754> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA6760> ;
    skos:definition "The following diagram shows the relationships between Bank and PaymentMethods.<br/>A Bank might own many BankAccounts.<br/>A Check and Bank Card payment method debits a BankAccount related to a Bank.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA4_EA6754" ;
    skos:prefLabel "Figure PAY.02 - Payment Method and Bank"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA6756> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA6760> ;
    skos:definition "The following Diagram describes <br/> • the use of CharacteristicSpecification (EntitySpecCharUse) for a PaymentMethodSpecification<br/> • and the CharacteristicValues that may describe a PaymentMethod<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA4_EA6756" ;
    skos:prefLabel "Figure PAY.02a - Payment Method and Payment Method Specification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA6758> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA6760> ;
    skos:definition "The following Diagram describes the inheritance of CustomerPayment and BusinessPartnerPayment from PartyPayment and specific relationships for each of them.<br/>But some relationships used between the Party’s Entities are not reused when they are further defined in Customer Entities. In this case, the relationship between Party’s Entities are highlighted in bold pale orange such as the one between PartyBill and BusinessPartnerPaymentItem.<br/>A payment item is the application of PartyPayment. Each PaymentItem represents an amount applied to a Bill or applied BillingRate.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA4_EA6758" ;
    skos:prefLabel "Figure PAY.03 -Business Partner and Customer Payment"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA6761> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA6760> ;
    skos:definition "the relationship starting by a \"/\" corresponds to a derived relationship \"/TPPAOwnsTPCM\" is derived from \"PartyRoleOwnsPaymentMethod\"<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA4_EA6761" ;
    skos:prefLabel "EARoot_EA4_EA2_EA11_EA4_EA6761"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA6762> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA6760> ;
    skos:definition "BPAccountBanace Entity should be added later<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA4_EA6762" ;
    skos:prefLabel "EARoot_EA4_EA2_EA11_EA4_EA6762"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA6763> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA6760> ;
    skos:definition "PartyFinancialCharge Entity Should be added later<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA4_EA6763" ;
    skos:prefLabel "EARoot_EA4_EA2_EA11_EA4_EA6763"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA6765> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA6760> ;
    skos:definition "The PartyPayment represents the transfer of wealth from any Party to another one.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA4_EA6765" ;
    skos:prefLabel "PartyPayment"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA6767> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA6760> ;
    skos:definition "PaymentPlan defines the plan for payment via its associations to the PaymentMethod and PaymentAccount.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA4_EA6767" ;
    skos:prefLabel "PaymentPlan"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA6768> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA6760> ;
    skos:definition "A PaymentPlanPaymentMethod specifies the priority and valid period for each PaymentMethod in a PaymentPlan context.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA4_EA6768" ;
    skos:prefLabel "PaymentPlanPaymentMethod"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA6769> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA6760> ;
    skos:definition "ThirdPartyPayeeAgency is a third party between SP and party. This agency takes a role of receiving payment for SP from SP's party.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA4_EA6769" ;
    skos:prefLabel "ThirdPartyPaymentAgency"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA5_EA6789> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA5_EA6811> ;
    skos:definition "A CommunicationInteraction is a kind of action that occurs as two or more objects have an effect upon one another (wikipedia).<br/>More precisely, in SID, a CommunicationInteraction describes an exchange of information during a communication between two or more human(s) and/or machine(s) during a period of time. As CommunicationInteraction might concern Parties playing a role of Customer, Supplier… or even Resources.<br/>For example:<br/> • A person calling another one with a request such as questions about his customer order not yet delivered or claiming about his product dysfunction<br/> • A company broadcasting advertising on a media such as TV or radio<br/> • A computer sending information to another one such as an order sent to a supplier<br/> • A customer ordering a ProductOfferingSpecification using the CSP web portal<br/>A CommunicationInteraction specifies means used to interact such as PhoneCall, MMS, SMS...<br/>A CommunicationInteraction consists of one or more CommunicationInteractionItems. Each of them concerns a unique CommunicationInteractionUseCase (i.e. action on a subject) and involves the same CommunicationInteractionRoles from the beginning to the end of it.<br/>A CommunicationInteractionMeans represents the content of A CommunicationInteraction such as email, phone call, SMS, MMS…<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA5_EA6789" ;
    skos:prefLabel "Figure CI.01 - CommunicationInteraction overview"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA5_EA6791> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA5_EA6811> ;
    skos:definition "A CommunicationInteractionItem is the smallest entity in a CommunicationInteraction tree.<br/>It concerns a unique CommunicationInteractionUseCase and involves the same CommunicationInteractionRoles from the beginning to the end of it.<br/>A CommunicationInteractionItem might have one or many CommunicationResult such as “create a CustomerOrder” and “notify the CustomerOrder”.<br/>A CommunicationInteractionItem might have related Attachment such as the recorded conversation or embedded document in an email.<br/>A CommunicationInteractionItem cannot be contained in more than one CommunicationInteraction.<br/>A CommunicationInteractionRole is either a PartyRole or a ResourceRole involved in a CommunicationInteractionItem.<br/>There might be one to many CommunicationInteractionRoles involved in a CommunicationInteractionItem.<br/> • 1 CommunicationInteractionRole if the interaction corresponds to a communication through Media<br/> • 2 CommunicationInteractionRoles for simple interactions between Parties and / or Resources<br/> • more than 2 CommunicationInteractionRoles when all the parties interact in the same Place (ex: face-to-face training, face-to-face marketing presentation) or through the same ContactMedium (ex: conference call)<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA5_EA6791" ;
    skos:prefLabel "Figure CI.02 - CommunicationInteractionItem overview"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA5_EA6793> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA5_EA6811> ;
    skos:definition "A CommunicationInteractionAction specifies which action is done on a RootEntity in the context of a CommunicationInteractionUseCase or CommunicationInteractionResult. <br/>A CommunicationInteractionUseCase specifies which entity (RootEntity) is concerned and which action (CommunicationInteractionAction) are concerned by the CommunicationInteractionItem.<br/>For example:<br/> • Action: \"buy\" for Entity: \"ProductOfferingSpecification PO1\"<br/> • Action: \"ask for recovery\" for Entity: \"Billy's Broadband\"<br/> • Action: \"notify\" Entity: \"Billy's Customer Bill\"<br/>A CommunicationInteractionResult specifies describes the main result which entity (RootEntity) is impacted and for which action (CommunicationInteractionAction) by the CommunicationInteractionItem.<br/>For example:<br/> • Action: \"creates\" for Entity: \"CustomerOrder CO1\"<br/> • Action: \"Help for use\" for Entity: \"Billy's Broadband\"<br/> • Action: \"explain\" Entity: \"Billy's Customer Bill\"<br/><i>Note: About Inheritance from RootEntity, the issue is that many Entities that might be concerned by a CommunicationInteractionUseCase or representing a CommunicationInteractionResult do not inherit currently from RootEntity (in Red).</i><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA5_EA6793" ;
    skos:prefLabel "Figure CI.03 - CommunicationInteraction UseCase and Result"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA5_EA6795> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA5_EA6811> ;
    skos:definition "The following figure shows CommunicationInteraction inheritance tree.<br/>It might be completed later.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA5_EA6795" ;
    skos:prefLabel "Figure CI.04 - CommunicationIteractionItem Hierarchy"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA5_EA6797> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA5_EA6811> ;
    skos:definition "<font color=\"#29313b\">Any new Interaction occurring has the “<b>Initialized</b>” status.</font><br/><font color=\"#29313b\">The “<b>Failed</b>” status (final status) tracks any unsuccessful attempt to interact like “Not Found at This Address –NFTA” for postal mail or bounce for email.</font><br/><font color=\"#29313b\">Once the contact is established in between the CommunicationInteractionActors, Interaction is “<b>In Progress</b>”. It will stay so until it ends properly (“<b>Completed</b>” status) or prematurely (“<b>Disrupted</b>” status), for instance in case of a drop call.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA5_EA6797" ;
    skos:prefLabel "Figure CI.05 – CommunicationInteraction life cycle"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA5_EA6799> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA5_EA6811> ;
    skos:definition "<b>Illustration CommunicationInteraction Use Case 1</b><br/><font color=\"#29313b\">In this example, we assume that the duration of the Interaction is split in several parts. Each part corresponds to an CommunicationInteractionItem:</font><br/><ul><li><font color=\"#29313b\">CommunicationInteractionItem1: IVR (Interactive Voice Response) menu: the customer navigates in the voice menu to select what best fits his/her concern;</font></li><li><font color=\"#29313b\">CommunicationInteractionItem2: Hold period: the customer waits until somebody answers:</font></li></ul><ul><li><font color=\"#29313b\">Typically, the SP wants to collect some information/metric such as the time the customer spent on hold, or whether he abandoned the call before being served;</font></li></ul><ul><li><font color=\"#29313b\"> CommunicationInteractionItem3: During this period the customer expresses an issue #1 he has with a first product he already has;</font></li><li><font color=\"#29313b\"> CommunicationInteractionItem4: During this last period, the customer expresses interest in a specific ProductOffering</font>Specification<font color=\"#29313b\"> and requests more information about it.</font></li></ul><font color=\"#29313b\">Each of these CommunicationInteractionItem corresponds to a different \"use case\" during which the ResourceRole and PartyRole or PartyRoles (the \"Who\")) engaged in the interaction share a concern (the “why”) about something (the \"What\").</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA5_EA6799" ;
    skos:prefLabel "Figure CI.01 – I01 - CommunicationInteraction & CommunicationInteractionItems"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA5_EA6801> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA5_EA6811> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA5_EA6801" ;
    skos:prefLabel "Figure CI.02 – I01 - CommunicationInteractionItems illustration in detail"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA5_EA6803> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA5_EA6811> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA5_EA6803" ;
    skos:prefLabel "Figure CI.03 – I01 - CommunicationInteraction & CommunicationInteractionItems illustration"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA5_EA6805> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA5_EA6811> ;
    skos:definition "<b>Illustration CommunicationInteraction Use Case 2</b><br/><font color=\"#29313b\">In this example, we assume that Billy interacts twice with the CSP:</font><br/><ul><li><font color=\"#29313b\">CommunicationInteractionItem1: The Customer Billy calls the CSP November 23rd to order a Broadband contract</font></li></ul><ul><li><font color=\"#29313b\">CommunicationInteractionItem2: One week later Billy calls the CSP to ask why he isn’t yet delivered</font></li></ul><p/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA5_EA6805" ;
    skos:prefLabel "Figure CI.01 – I02 - CommunicationInteraction & CommunicationInteractionItems illustration"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA5_EA6807> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA5_EA6811> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA5_EA6807" ;
    skos:prefLabel "Figure CI.02 – I02 - CommunicationInteractionItems illustration in detail"@en .

