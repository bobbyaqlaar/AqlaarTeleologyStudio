<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3623> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3625> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under or related to the <b>Party Revenue Share </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3623" ;
    skos:prefLabel "Figure PRSh.01 - Party Revenue Share ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3626> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3625> ;
    skos:definition "An accumlation of ComponentRevShareProdOffers if a PartyRevShareTermOrCondition specifies that revenue shares for an offering should be aggregated.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3626" ;
    skos:prefLabel "AggregateRevShareProdOffer"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3627> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3625> ;
    skos:definition "An aggregation of revenue, units acquired/used, or some other measure contained in other PartyRevenueShareProdOfferItems that is used to determine the revenue shared with another party or parties. For example, for a tiered based revenue sharing model the total number of acquisitions for a product offering may need to be calculated in order to determine the revenue share.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3627" ;
    skos:prefLabel "AggregateRevShareProdOfferItem"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3628> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3625> ;
    skos:definition "A base amount of revenue shared for a ProductOffering.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3628" ;
    skos:prefLabel "ComponentRevShareProdOffer"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3629> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3625> ;
    skos:definition "An item that is used to determine revenue shared with another party for a ProductOffering. The item may be a ProductPrice paid to acquire an offering if a bill/invoice charge is not created for it or an AppliedParty/CustomerBillingRate, which could be a charge, discount, usage charge, and so forth.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3629" ;
    skos:prefLabel "ComponentRevShareProdOfferItem"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3630> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3625> ;
    skos:definition "The amount of revenue shared among parties involved in a revenue sharing agreement. Revenue share is determined using existing artifacts such as usage, invoices, product prices, and applied billing rates. The revenue share may result in a payment to/from a party and/or an bill/invoice to/from a party. It may also be shown as a reduction of or increase to an bill/invoice sent to or received from a party, or a credit/debit to a party's account balance.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3630" ;
    skos:prefLabel "PartyRevenueShare"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3631> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3625> ;
    skos:definition "An adjustment to the revenue to be shared among an enterprise and one or more other parties. This could be required, but not limited to, based on changes to a revenue sharing model associated with a party revenue sharing agreement or based on discrepancies found by the Party Revenue Share Reconciliation process.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3631" ;
    skos:prefLabel "PartyRevenueShareAdjustment"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3632> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3625> ;
    skos:definition "A communication of the revenue to be shared to processes and/or a party with whom revenue will be shared. The notification includes the revenue to be shared for all product offerings. For example, to a Party Revenue Sharing Reconciliation process for reconciliation with a received bill/invoice, to Party Payment Management to make a payment to another party, or to a party so that they can reconcile what is to be shared before sending or receiving an bill/invoice.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3632" ;
    skos:prefLabel "PartyRevenueShareNotification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3633> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3625> ;
    skos:definition "A ProductOffering which qualifies for revenue sharing.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3633" ;
    skos:prefLabel "PartyRevenueShareProdOffer"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3634> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3625> ;
    skos:definition "An item that is used to determine revenue shared with another party for a ProductOffering.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3634" ;
    skos:prefLabel "PartyRevenueShareProdOfferItem"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3635> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3625> ;
    skos:definition "A relationship between two PartyRevenueShares.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3635" ;
    skos:prefLabel "PartyRevenueShareRelationship"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3636> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3625> ;
    skos:definition "A relationship between two PartyRevenueShareProdOffers. For example, after shares are reconciled a new PartyRevenueShareProdOffer may be determined that replaces the original share that was determined.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA2_EA3636" ;
    skos:prefLabel "RevenueShareProdOfferRelationship"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA3562> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA3576> ;
    skos:definition "Revenue sharing is the distribution of revenue, the amount paid by customers or other parties to an enterprise, between stakeholders, who could be partners, a company's employees, or between companies in a business alliance. The purpose of revenue sharing is using shared revenue to benefit parties involved. Before the revenue is shared by enterprise and one or more other parties, they enter into a party revenue sharing agreement, which specifies how revenue will be shared among the parties involved.<br/>The Party Revenue Sharing ABE contains party revenue sharing models, party revenue sharing agreements, party revenue shares, and party revenue sharing reconciliations. The Party Revenue Sharing Model contains revenue sharing models that define how revenue is shared by an enterprise with one or more other parties. Revenue sharing models are a key component of revenue sharing agreements. The Party Revenue Sharing Agreement ABE contains an agreement that specifies how revenue will be shared between an enterprise and one or more other parties whose product offerings are made available in some way by an enterprise. The Party Revenue Share ABE uses existing artifacts such as usage, invoices, product prices, and applied billing rates that specifies how revenues will be shared. The Party Revenue Share Reconciliation ABE represents the alignment and agreement for two sets of party revenue sharing records. Each ABE is further described in upcoming sections.<br/><br/>The Party Revenue Sharing Model ABE contains party revenue sharing models, and their specifications, that define how revenue is shared by and enterprise with one or more other parties. Revenue sharing models are a key component of revenue sharing agreements. The following Figure shows the model for the specification part of the ABE.<br/>RevShareModelSpecNegotiableRange specifies ranges expressed in percentages or some other quantitative measure that an enterprise will use to negotiate the aspects of a party revenue sharing model. More complex ranges, such as for tiered and progressive revenue sharing models may be based on policy defined by an enterprise. For example, a tiered model may have a range of 60-70% revenue share for up to 100 product offerings acquired and a range of 80-90% for above 100 offerings. Ranges may also include a range of prices for an offering paired with revenue sharing ranges. To date there are no common processes that can be used to define policies defined by an enterprise.<br/>The association to EntitySpecCharUse provides the ability to associate additional attributes for PartyRevenueSharingModelSpecifications.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA3562" ;
    skos:prefLabel "Figure PRS.01 - Party Revenue Sharing Model Specification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA3564> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA3576> ;
    skos:definition "The following Figure shows the model part of the ABE.<br/>RevenueSharingModelRelationship provides way to relate models, such as supplier/partner or other party equivalent, alternate, replaces, and so forth. For example, a partner may provide their equivalent of a model to an enterprise to ensure both parties involved are in agreement as to the revenue that will be shared.<br/>PartyRevenueSharingModelInvolvement specifies a party, including an enterprise, who participates in revenue sharing, their type of involvement, and their associated offering(s). The involvement may also apply to one or more ProductSpecificationTypes, and its subclasses ProductLine and ProductCategory, instead of PartyRoleProductOfferingSpecs. If the involvement applies to all of a parties’ offerings, then neither association is used. The type of involvement specifies whether revenue is retained by an enterprise and whether a party participates in revenue sharing. For example, an enterprise may charge a listing fee for a party's offering or offerings as part of an agreement between a party and an enterprise, and an enterprise passes all revenue on to the party for sales of the party's offering. The party is invoiced separately for the listing fee. For a template revenue sharing model, only an enterprise's involvement is specified. When a party enters into a revenue sharing agreement and a template is used their involvement is specified. Multiple parties may be specified if the enterprise offers a bundle that is composed of offerings by two or more parties or if multiple party's offerings are used to create a single offering for an enterprise.<br/>Product Offering Price ABE entities are used to represent amounts of revenue shared. For example, an enterprise may charge 10 euros for an offering and share a flat 4 euros with another party, such as an application developer. For configurable offerings the revenue shared may be dependent on those features chosen by the party who acquires the offering. In this case the revenue shared is also governed by the configuration of the party's product. It includes ranges expressed in percentages or some other quantitative measure that an enterprise will use to negotiate the aspects of a party revenue sharing model. For example, for a flat rate revenue sharing model an enterprise may be willing to share 70% of the product offering price with another party. The range can be based on the processes that an enterprise and a party provide. For example, if an enterprise only accepts an order for an offering while a party performs all other processes, such as fulfilling the order, accepting payment for it, and billing for it, it may be willing to share up to 90 percent of the revenue it receives for the offering.<br/>The association between ProductOfferingPrice and PolicySet specifies what policy or policies govern how revenue is shared. PolicySet contains the revenue sharing rules for different models. For example, there may be rules that specify the revenue shared for various tiers in a tiered type of revenue sharing model.<br/>The various types of revenue sharing models are contained in the technical report TR211 – Online B2B2X Partnering Step by Step Guide. One point to note is that the flat rate model does not appear to be a model where revenue is shared, because an enterprise purchases a product or products from another party. This is handled via an order placed with the party and the enterprise receiving and paying an invoice.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA3564" ;
    skos:prefLabel "Figure PRS.02 - Party Revenue Sharing Model"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA3566> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA3576> ;
    skos:definition "The Party Revenue Sharing Agreement ABE represents an agreement that specifies how revenue will be shared between an enterprise and one or more other parties whose product offerings are made available in some way by an enterprise. For example, an enterprise may make offerings available on behalf of another party or use another party's offering to develop its own offering. It includes template party revenue sharing agreements that are used as the basis for entering into a revenue sharing agreement with one or more parties.<br/>It uses, via inheritance, applicable Agreement ABE entities, such as ContractualAgreement and ContractualAgreementItem. The focus of the ABE is on associating party revenue sharing model(s) with the items on the agreement and updating agreement items with agreed upon changes to revenue sharing models by associating revisions to the models to agreement items.<br/>PartyRevShareTermOrCondition specifies terms and conditions for a party revenue sharing agreement in addition to those specified by the Party Agreement Management process. Terms specific to a revenue sharing agreement may include the requirement to aggregate revenue shared for a product offering as well as providing details about each acquisition of an offering supported by the aggregateSharedRevenue attribute. The terms specify the time period for which revenue shares should be determined supported by the revenueShareTimePeriod attribute. This information is provided on a revenue sharing notice, bill/invoice, or payment. How the information is provided is also specified as part of the terms supported by the revenueShareProvidedUsing attribute.<br/>The following Figure shows the model for this ABE.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA3566" ;
    skos:prefLabel "Figure PRS.03 - Party Revenue Sharing Agreement"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA3568> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA3576> ;
    skos:definition "The Party Revenue Share ABE represents the amount of revenue shared among parties involved in a revenue sharing agreement. Revenue share is determined using existing artifacts such as usage, invoices, product prices, and applied billing rates. The revenue share may result in a payment to/from a party and/or a bill/invoice to/from a party. It may also be shown as a reduction of or increase to a bill/invoice sent to or received from a party, or a credit/debit to a party's account balance. There are a variety of revenue sharing models that determines how revenue may be split among an enterprise and other parties. Based on the type of revenue sharing model different determinants are used to calculate the final bill/invoice or payment. Flat rate and usage based revenue sharing models are just two of a number of models, which also include but are not limited to tiered, commitment, progressive, along with multi-party variations of each. <br/>A party revenue sharing agreement defines the period for which a revenue share for a product offering is determined.<br/>PartyRevenueShare represents the amount of revenue shared among parties involved in a revenue sharing agreement. Revenue share is determined using existing artifacts such as usage, invoices, product prices, and applied billing rates. The revenue share may result in a payment to/from a party and/or a bill/invoice to/from a party. It may also be shown as a reduction of or increase to a bill/invoice sent to or received from a party, or a credit/debit to a party's account balance. (Note that the Party Account Balance ABE needs to be added to the model.) PartyRevenueShareRelationship is a categorization of the relationship, such as reconciled to, replaces, and so forth. PartyRevenueShareNotification is a communication of the revenue to be shared to processes and/or a party with whom revenue will be shared. The notification includes the revenue to be shared for all product offerings. For example, to a Party Revenue Sharing Reconciliation process for reconciliation with a received bill/invoice, to Party Payment Management to make a payment to another party, or to a party so that they can reconcile what is to be shared before sending or receiving a bill/invoice.<br/>PartyRevenueShareProdOffer is a ProductOffering which qualifies for revenue sharing, including the quantity of offerings and the amount of revenue to be shared for the offering. RevenueShareProdOfferRelationship is a relationship between two PartyRevenueShareProdOffers. For example, after shares are reconciled a new PartyRevenueShareProdOffer may be determined that replaces the original share that was determined.<br/>ComponentRevShareProdOffer is a base amount of revenue shared for a ProductOffering. AggregateRevShareProdOffer is the total revenue to be shared for a product offering when the party revenue sharing agreement specifies an aggregation must be provided. The aggregation is performed after the determination of the revenue share represented by ComponentRevShareProdOffer. For example, a flat rate model calculates a revenue share for each acquisition of a product offering, and AggregateRevShareProdOffer contains the total revenue share for the offering.<br/>The following Figure shows an initial view of the Party Revenue ABE.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA3568" ;
    skos:prefLabel "Figure PRS.04 - Party Revenue Share and Product Offering"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA3570> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA3576> ;
    skos:definition "The following Figure shows the remainder of the entities that make up this ABE.<br/>ProductRevenueShareProdOfferItem is an item that is used to determine revenue shared with another party for a ProductOfferingSpecification. ComponentReveShareProdOfferItem is an item that is used to determine revenue shared with another party for a ProductOfferingSpecification. The item may be a ProductPrice paid to acquire an offering if a bill/invoice charge is not created for it or an AppliedParty/CustomerBillingRate, which could be a charge, discount, usage charge, and so forth. AggregateRevShareProdOfferItem is an aggregation of revenue, units acquired/used, or some other measure contained in other PartyRevenueShareProdOfferItems that is used to determine the revenue shared with another party or parties. For example, for a tiered based revenue sharing model the total number of acquisitions for a product offering may need to be calculated in order to determine the revenue share. In some cases, such as the one just mentioned, a PolicyAction is associated with ProductRevenueShareProdOfferItem in order to specify the ProductOfferingPrice used to calculate the revenue share that is contained in PartyRevenueShareProdOffer.<br/>During the party revenue share reconciliation process adjustments to ProdRevenueShareProdOfferItems may need to be made. PartyRevenueShareAdjustment represents an adjustment to the revenue to be shared among an enterprise and one or more other parties. This could be required, but not limited to, based on changes to a revenue sharing model associated with a party revenue sharing agreement or based on discrepancies found by the Party Revenue Share Reconciliation process. For example, an enterprise's calculated revenue share for a product offering may be missing a product that has been acquired that appears on a bill/invoice from another party.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA3570" ;
    skos:prefLabel "Figure PRS.05 - Party Revenue Share Product Offering Item"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA3572> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA3576> ;
    skos:definition "The Party Revenue Sharing Reconciliation ABE ensures that two sets of party revenue sharing records are aligned and agreed upon. For example, an enterprise may receive an invoice from another party that is compared to the revenue share that has been determined to be shared with the party contained in the Party Revenue Share ABE.<br/>Reconciliation includes comparing what is received with what is to be paid, invoiced or credited/debited to a bill/invoice or account balance, identifying and resolving discrepancies, identifying adjustments to revenue to be shared, and tracking discrepancy resolution.<br/>PartyRevenueShareReconciliation and PartyRevShareConciliationItem represent a comparison of two sets of party revenue sharing records to ensure they are aligned and agreed upon. A comparison identifies and resolves discrepancies and identifies revenue share adjustments. This is done by comparing the revenue determined by an enterprise that is to be shared with another party with the information provided by the party. The information used in the reconciliation is provided on a revenue sharing notice, bill/invoice, or payment according to terms specified by a party revenue sharing agreement. For example, a party may provide their own version of a party revenue share for one or more of its product offerings.<br/>PartyRevShareReconDiscrepancy represents the result of comparing information received from another party with the revenue share determined by an enterprise. Differences are classified as a discrepancy that is to be resolved. For example, an enterprise's calculated revenue share for a product offering may be missing a product that has been acquired that appears on a bill/invoice from another party. A discrepancy is communicated using RevShareReconDiscrepNotification. The communication contains information used in the reconciliation process from another party. The information provided is designated as preliminary until the reconciliation is complete. Because different forms of information can be provided by a party other processes and their associated entities may be involved. For example, if a bill/invoice is provided by a party then the Party Bill Inquiry Handling process may be invoked; if a payment is provided then the Party Payment Handling process may be invoked; if a revenue share notification is provided then the Identify Party Revenue Share Adjustment process may be invoked.<br/>An overview of the entities within the Party Revenue Share Reconciliation ABE is shown in the following Figure.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA3572" ;
    skos:prefLabel "Figure PRS.06 - Party Revenue Share Reconciliation"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA3574> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA3576> ;
    skos:definition "Details about the discrepancy are provided in the following Figure.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA3574" ;
    skos:prefLabel "Figure PRS.07 - Party Revenue Share Reconciliation Discrepancy"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA3577> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA3576> ;
    skos:definition "Remove Agreement and AgreementItem from this diagram<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA3577" ;
    skos:prefLabel "EARoot_EA4_EA2_EA8_EA5_EA2_EA3577"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA3_EA3637> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA3_EA3639> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under or related to the <b>Party Revenue Share Reconciliation </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA3_EA3637" ;
    skos:prefLabel "Figure PRSR.01 - Party Revenue Share Reconciliation ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA3_EA3640> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA3_EA3639> ;
    skos:definition "A comparison of two sets of party revenue sharing records are aligned and agreed upon. A comparison identifies and resolves discrepancies and identifies revenue share adjustments. This is done by comparing the revenue determined by an enterprise that is to be shared with another party with the information provided by the party.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA3_EA3640" ;
    skos:prefLabel "PartyRevenueShareReconciliation"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA3_EA3641> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA3_EA3639> ;
    skos:definition "A PartyRevenueShare, Party/CustomerBill, or Party/CustomerPayment used to reconcile revenue shared with an enterprise and another party.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA3_EA3641" ;
    skos:prefLabel "PartyRevShareReconciliationItem"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA3_EA3642> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA3_EA3639> ;
    skos:definition "A difference between information received from another party with the revenue share determined by an enterprise that is to be resolved. For example, an enterprise's calculated revenue share for a product offering may be missing a product that has been acquired that appears on an bill/invoice from another party.<br/><br/><br/><br/>Note: This entity is related to two of any combination of PartyPayment, PartyPaymentItem, ComponentShareProdOfferItem, AppliedPartyBillingRate.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA3_EA3642" ;
    skos:prefLabel "PartyRevShareReconDiscrepancy"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA3_EA3643> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA3_EA3639> ;
    skos:definition "A communication from another party that initiates the party revenue sharing reconciliation process. The communication contains information used in the process from another party. The information used in the reconciliation is provided on a revenue sharing notice, bill/invoice, or payment according to terms specified by a party revenue sharing agreement. For example a party may provide their own version of a party revenue share for one or more of its product offerings.<br/><br/><br/><br/>The information provided is designated as preliminary until the reconciliation is complete.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA3_EA3643" ;
    skos:prefLabel "RevShareReconDiscrepNotification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA4_EA3644> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA4_EA3646> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under or related to the <b>Party Revenue Sharing Agreement </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA4_EA3644" ;
    skos:prefLabel "Figure PRSA.01 - Party Revenue Sharing Agreement ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA4_EA3647> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA4_EA3646> ;
    skos:definition "A ContractualAgreement that specifies how revenue will be shared between an enterprise and one or more other parties whose product offerings are made available in some way by an enterprise. For example an enterprise may make offerings available on behalf of another party or use another party's offering to develop its own offering. It includes template party revenue sharing agreements that are used as the basis for entering into a revenue sharing agreement with one or more parties.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA4_EA3647" ;
    skos:prefLabel "PartyRevenueSharingAgreement"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA4_EA3648> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA4_EA3646> ;
    skos:definition "The purpose of a PartyRevenueSharingAgreement expressed in terms of the agreed upon terms and conditions specific to the item and the PartyRevenueSharingModel that specifies how revenue will be shared among parties invovled in the agreement.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA4_EA3648" ;
    skos:prefLabel "PartyRevenueSharingAgreementItem"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA4_EA3649> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA4_EA3646> ;
    skos:definition "The terms and conditions for a party revenue sharing agreement in addition to those specified by an AgreementItem. For example, terms specific to a revenue sharing agreement may include the requirement to aggregate revenue shared for a product offering as well as providing details about each acquisition of an offering.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA4_EA3649" ;
    skos:prefLabel "PartyRevShareTermOrCondition"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA5_EA3650> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA5_EA3652> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under or related to the <b>Party Revenue Sharing Model </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA5_EA3650" ;
    skos:prefLabel "Figure PRSM.01 - Party Revenue Sharing Model ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA5_EA3653> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA5_EA3652> ;
    skos:definition "The definition of how revenue is shared by an enterprise with one or more other parties. Revenue sharing models are a key component revenue sharing agreements.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA5_EA3653" ;
    skos:prefLabel "PartyRevenueSharingModel"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA5_EA3654> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA5_EA3652> ;
    skos:definition "Specification of a party, including an enterprise, who participates in revenue sharing, their type of involvement, and their associated offering(s).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA5_EA3654" ;
    skos:prefLabel "PartyRevenueSharingModelInvolvement"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA5_EA3655> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA5_EA3652> ;
    skos:definition "The definition of a party revenue sharing model. It includes a related entity that specifies ranges expressed in percentages or some other quantitative measure that an enterprise will use to negotiate the aspects of a party revenue sharing model.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA5_EA3655" ;
    skos:prefLabel "PartyRevenueSharingModelSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA5_EA3656> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA5_EA3652> ;
    skos:definition "A relationship between two PartyRevenueSharingModels. For example, a partner may provide their equivalent of a model to an enterprise to ensure both parties involved are in agreement as to the revenue that will be shared.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA5_EA3656" ;
    skos:prefLabel "RevenueSharingModelRelationship"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA5_EA3657> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA5_EA3652> ;
    skos:definition "Ranges that may be expressed in percentages or some other quantitative measure that an enterprise will use to negotiate the aspects of a party revenue sharing model. For example, for a flat rate revenue sharing model an enterprise may be willing to share 70% of the product offering price with another party<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA5_EA3657" ;
    skos:prefLabel "RevShareModelSpecNegotiableRange"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA1_EA3671> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA1_EA3673> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under or related to the <b>Party Bill Statistic </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA6_EA1_EA3671" ;
    skos:prefLabel "Figure PBS.01 - Party Billing Statistic ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA1_EA3674> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA1_EA3673> ;
    skos:definition "An total of all charges applied to a PartyAccount.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA6_EA1_EA3674" ;
    skos:prefLabel "PartyAccountChargeSum"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA1_EA3675> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA1_EA3673> ;
    skos:definition "A balance of the aggregation of all charges applied to a PartyAccount.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA6_EA1_EA3675" ;
    skos:prefLabel "PartyAccountChargeSumBalance"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA1_EA3676> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA1_EA3673> ;
    skos:definition "A detailed description of the aggregation of all charges applied to a PartyAccount.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA6_EA1_EA3676" ;
    skos:prefLabel "PartyAccountChargeSumSpec"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA1_EA3677> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA1_EA3673> ;
    skos:definition "A total of all PartyAccount charges applied to a Product.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA6_EA1_EA3677" ;
    skos:prefLabel "PartyBillingProductChargeSum"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA1_EA3678> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA1_EA3673> ;
    skos:definition "An aggregation of all PartyAccount charges applied to a Product.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA6_EA1_EA3678" ;
    skos:prefLabel "PartyBillingProductChargeSumBalance"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA1_EA3679> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA1_EA3673> ;
    skos:definition "A detailed description of the aggregation of all PartyAccount charges applied to a Product.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA6_EA1_EA3679" ;
    skos:prefLabel "PartyBillingProductChargeSumSpec"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA1_EA3680> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA1_EA3673> ;
    skos:definition "Collected data derived from PartyBills. It is defined by PartyBillingStatisticSpecification.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA6_EA1_EA3680" ;
    skos:prefLabel "PartyBillingStatistic"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA1_EA3681> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA1_EA3673> ;
    skos:definition "The balance of collected statistical data.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA6_EA1_EA3681" ;
    skos:prefLabel "PartyBillingStatisticBalance"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA1_EA3682> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA1_EA3673> ;
    skos:definition "A detailed description of a collection of statistical data derived from PartyBills (for example, party account charge sum over a certain period of time). Statistical data are typically collected during rating and billing processes. A specification may be implemented using a rules engine or a policy to determine collection rules.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA6_EA1_EA3682" ;
    skos:prefLabel "PartyBillingStatisticSpec"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA1_EA3683> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA1_EA3673> ;
    skos:definition "A balance of the aggregation of UsageCharacteristic'Values.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA6_EA1_EA3683" ;
    skos:prefLabel "PartyBillingStatisticUsageCharacteristicSumBalance"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA1_EA3684> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA1_EA3673> ;
    skos:definition "A detailed description of the aggregation of UsageCharacteristicValues.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA6_EA1_EA3684" ;
    skos:prefLabel "PartyBillingStatisticUsageCharacteristicSumSpec"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA1_EA3685> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA1_EA3673> ;
    skos:definition "A total of UsageCharacteristicValues for a Party.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA6_EA1_EA3685" ;
    skos:prefLabel "UsageCharacteristicSum"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA3658> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA3660> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under or related to the <b>Party Bill </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA6_EA3658" ;
    skos:prefLabel "Figure PB.01 - Party Bill ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA3661> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA3660> ;
    skos:definition "A billing time period. It can be recurring (for example, a week, a month, a quarter of year, a year) or partyom (in this case additional business entities to describe partyom dates would be needed).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA6_EA3661" ;
    skos:prefLabel "BillingPeriod"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA3662> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA3660> ;
    skos:definition "This entity represents a PartyBill which was generated as a result of an event different from cycle run (such as party request or an account close)<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA6_EA3662" ;
    skos:prefLabel "OffCyclePartyBill"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA3663> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA3660> ;
    skos:definition "This entity represents a PartyBill which was generated as a result of a cycle run<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA6_EA3663" ;
    skos:prefLabel "OnCyclePartyBill"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA3665> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA3660> ;
    skos:definition "A total amount due from a PartyAccount for all products during the billing period.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA6_EA3665" ;
    skos:prefLabel "PartyBill"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA3666> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA3660> ;
    skos:definition "A detailed description of the way in which a party's bill is presented. The current version of this entity serves as a placeholder. It will be further developed in a future version of this document.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA6_EA3666" ;
    skos:prefLabel "PartyBillFormat"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA3667> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA3660> ;
    skos:definition "An occurrence of a billing cycle. Besides significant dates, it records who triggered the cycle.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA6_EA3667" ;
    skos:prefLabel "PartyBillingCycle"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA3668> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA3660> ;
    skos:definition "A detailed description of when to initiate a billing cycle and the various sub steps of a billing cycle.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA6_EA3668" ;
    skos:prefLabel "PartyBillingCycleSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA3669> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA3660> ;
    skos:definition "A means of communicating a PartyBill, supported by the associated bill format. For example, post mail, email, web page.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA6_EA3669" ;
    skos:prefLabel "PartyBillPresentationMedia"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA3670> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA6_EA3660> ;
    skos:definition "A detailed description of a party's bill structure. The current version of this class is serving as a placeholder. It will be further developed in the next version of this document.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA6_EA3670" ;
    skos:prefLabel "PartyBillSpec"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA7_EA1_EA3689> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA7_EA1_EA3691> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the<b> Business Partner Dunning</b> Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA7_EA1_EA3689" ;
    skos:prefLabel "Figure Dun.01 - Business Partner Dunning ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA7_EA1_EA3692> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA7_EA1_EA3691> ;
    skos:definition "The DunningCase represents a type of cases open for a party. Whenever a party enters the dunning process, a dunning case is linked to his party account debt and it contains all details pertaining to the debt, such as dunning case rules, interactions… The status of a dunning case evolves according to internal or external events (payments made by the party, payment schedule granted…).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA7_EA1_EA3692" ;
    skos:prefLabel "DunningCase"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA7_EA1_EA3693> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA7_EA1_EA3691> ;
    skos:definition "The DunningCaseRule represents an action performed by the company (or on its behalf) to recover a debt.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA7_EA1_EA3693" ;
    skos:prefLabel "DunningCaseRule"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA7_EA1_EA3694> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA7_EA1_EA3691> ;
    skos:definition "A DunningNotification is a communication or joint activity from the Telecommunication Operator to the party to ask for a PartyPayment or negotiate a PaymentPlan.<br/><br/>The relation resulting from a DunningCaseRule might be <br/><br/>• either only from the telecommunication operator to the party (Ex: send a SMS) <br/><br/>• or in both ways (Ex: a CSR call the party to negotiate a PaymentPlan).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA7_EA1_EA3694" ;
    skos:prefLabel "DunningNotification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA7_EA1_EA3695> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA7_EA1_EA3691> ;
    skos:definition "A DunningRule is a type of PolicyRule.<br/><br/>It represents rules to apply to a dunning case: the events that trigger dunning rules evaluation, the conditions to evaluate and the actions that must be done (Ex: SMS, letters, outbound calls, barring/unbarring actions, late fees, penalties…)<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA7_EA1_EA3695" ;
    skos:prefLabel "DunningRule"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA7_EA1_EA3696> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA7_EA1_EA3691> ;
    skos:definition "A dunning scenario describes the company’s dunning strategy. It must be easily configurable to describe the dunning rules to apply to a case, the order in which applying them, the events that trigger dunning rules evaluation, the actions that must be done…<br/><br/>If a DunningScenario is assigned to a PartyAcount, the DunningCase will follow this DunningScenario in case of debt; else it will follow a default DunningScenario.<br/><br/>DunningScenario is assigned to a PartyAccount, depending on the Holder quality.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA7_EA1_EA3696" ;
    skos:prefLabel "DunningScenario"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA7_EA1_EA3697> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA7_EA1_EA3691> ;
    skos:definition "A PartyAccount may be written off for two main reasons:<br/><br/> • When the dunning procedures failed to recover the debt, the bad debt must be written off and reported as such to the General Ledger<br/><br/> • When a contract terminates with a “minimal” credit or debit balance (smaller than a threshold reflecting the cost of the collection process).<br/><br/>The DunningWriteOff corresponds, in a dunning context, to a credit to definitively balance the PartyAccount before being able to close it.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA7_EA1_EA3697" ;
    skos:prefLabel "DunningWriteOff"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA7_EA1_EA3698> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA7_EA1_EA3691> ;
    skos:definition "The HardDuning is a type of DunningCase.<br/>Hard dunning means all actions performed to recover the party’s debt after the contract termination by the company.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA7_EA1_EA3698" ;
    skos:prefLabel "HardDunning"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA7_EA1_EA3699> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA7_EA1_EA3691> ;
    skos:definition "The SoftDunning is a type of DunningCase. It represents all actions performed to recover the partys’ debt from the due date until the contract termination<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA7_EA1_EA3699" ;
    skos:prefLabel "SoftDunning"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA7_EA2_EA3700> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA7_EA2_EA3702> ;
    skos:definition "The following Diagram describes the inheritance of BusinessPartnerPayment from PartyPayment and specific relationships.<br/>A BusinessPartnerPayment item is the application of BusinessPartnerPayment. Each Payment Item represents an amount applied to a Bill or applied BillingRate.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA7_EA2_EA3700" ;
    skos:prefLabel "Figure BPA.01 - Business Partner Payment"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA7_EA2_EA3703> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA7_EA2_EA3702> ;
    skos:definition "The BusinessPartnerPayment is a type of PartyPayment and represents the transfer of wealth between the CSP and a Business Partner.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA7_EA2_EA3703" ;
    skos:prefLabel "BusinessPartnerPayment"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA7_EA2_EA3704> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA7_EA2_EA3702> ;
    skos:definition "BusinessPartnerPaymentItem is the application of BusinessPartnerPayment. BusinessPartnerPaymentItem is applied to PartyBill or AppliedPartyBillingRate.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA7_EA2_EA3704" ;
    skos:prefLabel "BusinessPartnerPaymentItem"@en .

