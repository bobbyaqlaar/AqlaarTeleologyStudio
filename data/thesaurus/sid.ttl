    skos:prefLabel "Figure Co.07 - ProjectedCost State Diagram"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA23_EA6396> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA23_EA6398> ;
    skos:definition "Following is an example of the actual cost associated with a a ServiceOrder containing two cost items, one related to E-line connectivity, the other electricity and power consumption.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA23_EA6396" ;
    skos:prefLabel "Figure Co.08 - Cost Example"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA23_EA6399> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA23_EA6398> ;
    skos:definition "Is cost a subclass of entity, or just has a relationship with entity?<br/><br/>If a relationship, then any entity can have a cost associated with it. <br/><br/>If a subclass, then only Managed Entities can have a relationship.<br/>"@en ;
