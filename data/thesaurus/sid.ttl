<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA2_EA1550> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA2_EA1529> ;
    skos:definition "A type of ProductSpecification that does not have any subordinate ProductSpecifications, that is, an AtomicProductSpecification is a leaf-level ProductSpecification.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA2_EA1550" ;
    skos:prefLabel "AtomicProductSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA2_EA1551> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA2_EA1529> ;
    skos:definition "A type of ProductSpecification that is formed by aggregating other ProductSpecifications, which may be Composite or Atomic ProductSpecifications.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA2_EA1551" ;
    skos:prefLabel "CompositeProductSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA2_EA1552> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA2_EA1529> ;
    skos:definition "<font color=\"#29313b\">The Catalog Lifecycle Management process builds the specifications starting with the technical view, then the functional view and finally the marketing view.</font><br/><font color=\"#29313b\">On the contrary, the Order Handling process starts looking for what can functionally answer to the customer requirements and then find the ProductOfferingSpecifications making available the ProductSpecifications.</font><br/><font color=\"#29313b\">The Delivery process has to identify the know-how (CFSSpec) corresponding to the ProductSpecification, then identify the different technical solutions (RFSSpec) corresponding to the know-how, chose the technical solution according to rules, and finally implement the ResourceSpecifications corresponding to the technical solution (RFSSpec).</font><br/><font color=\"#29313b\">Like this, </font><br/><ul><li><font color=\"#29313b\">OSS people specify functionally what can be done with OSS (Know-How i.e. CFSSpec)</font></li></ul><ul><li><font color=\"#29313b\">IT and Network are isolated from Marketing changes</font></li></ul><font color=\"#29313b\"> ₀ Changing ProductOfferingSpecifications and/or ProductSpecifications does impact only the order handling and catalog management</font><br/><font color=\"#29313b\"> ₀ Marketing people can define new ProductSpecifications without impacting the know-how (CFSSpec)</font><br/><ul><li><font color=\"#29313b\">The delivery process is only impacted by CFSSpec / RFSSpec and Resource changes</font></li></ul><font color=\"#29313b\"> ₀ Technical solutions might be changed without changing what is seen by the Customer (ProductSpecification and ProductOfferingSpecification)</font><br/><font color=\"#29313b\"> ₀ The know-how might be improved without impacting existing ProductSpecifications</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA2_EA1552" ;
    skos:prefLabel "Figure Pr.02 I01"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA2_EA1553> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA2_EA1529> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA2_EA1553" ;
    skos:prefLabel "Figure SI.01 - StockItem and other domains overview"@en .

