<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA1_EA3513> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3492> ;
    skos:definition "The Party Role Product Offering Specification ABE represents the involvement parties playing roles with ProductOfferingSpecifications.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA1_EA3513" ;
    skos:prefLabel "Party Role Product Offering Specification ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA2_EA3524> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3492> ;
    skos:definition "The Party Role Product Specification ABE represents the involvement parties playing roles have with ProductSpecifications.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA2_EA3524" ;
    skos:prefLabel "Party Role Product Specification ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA4_EA3537> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3411> ;
    skos:definition "<b>Business Partner Account ABE</b> inherits from Account ABE and contains all entities needed for specifying basic attributes and relationships that describe an account.<br/>It also represents specificities in the context of a BusinessPartner.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA4_EA3537" ;
    skos:prefLabel "Business Partner Account ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA4_EA3646> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA3576> ;
    skos:definition "The Party Revenue Sharing Agreement ABE represents an agreement that specifies how revenue will be shared between an enterprise and one or more other parties whose product offerings are made available in some way by an enterprise. For example an enterprise may make offerings available on behalf of another party or use another party's offering to develop its own offering. It includes template party revenue sharing agreements that are used as the basis for entering into a revenue sharing agreement with one or more parties.<br/>It uses, via inheritance, applicable Agreement ABE entities, such as Agreement and AgreementItem. The focus of the ABE is on associating party revenue sharing model(s) with the items on the agreement and updating agreement items with agreed upon changes to revenue sharing models by associating revisions to the models to agreement items.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA4_EA3646" ;
    skos:prefLabel "Party Revenue Sharing Agreement ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA4_EA1_EA4148> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA4_EA4146> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA4_EA1_EA4148" ;
    skos:prefLabel "Business Objective ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA1_EA4158> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA4153> ;
    skos:definition "The Budget ABE contains all Business Entities needed to describe the different budgets allocated to at least one Party. The Party might be an Organization.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA5_EA1_EA4158" ;
    skos:prefLabel "Budget ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA479> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA474> ;
    skos:definition "Represents dispatched Field Force Management - human and other field resource with their roles, skills, calendars and other characteristics. Also models work orders, catalog of work descriptions, various schedules, as well as reservation and assignment of a technician to a task.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA3_EA479" ;
    skos:prefLabel "Workforce ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA495> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA477> ;
    skos:definition "Represents all items that relate to security vulnerabilities and related events.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA3_EA495" ;
    skos:prefLabel "Enterprise Security ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA577> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA563> ;
    skos:definition "The Metric ABE defines standards of measurement including units and values and how the values are determined. It also includes thresholds used to evaluate the metric and the consequences of violating the thresholds. It’s in vision that other projects use and specialize the Metric ABE in some way (creating sub-classes and adding new entities) such as PM (Performance Management), RA (Revenue Assurance), SLA (Service Level Agreement), etc.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA577" ;
    skos:prefLabel "Metric ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA578> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA563> ;
    skos:definition "Represents a measure of the manner in which a Product and/or Service and/or Resource is functioning.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA578" ;
    skos:prefLabel "Performance ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA7_EA706> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA7_EA705> ;
    skos:definition "The Resource ABE contains entities that are used to represent the various aspects of a Resource. This includes four sets of entities that represent: the physical and logical aspects of a Resource; show how to aggregate such resources into aggregate entities that have physical and logical characteristics and behavior; and show how to represent networks, sub-networks, network components, and other related aspects of a network.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA7_EA706" ;
    skos:prefLabel "Resource ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA7_EA712> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA7_EA705> ;
    skos:definition "The Resource Specification ABE contains entities that define the shared characteristics and behavior of each of the four types of Resource entities. This enables multiple instances to be derived from a single specification entity. In this derivation, each instance will use the shared characteristics and behavior defined in its associated template.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA7_EA712" ;
    skos:prefLabel "Resource Specification ABE"@en .

