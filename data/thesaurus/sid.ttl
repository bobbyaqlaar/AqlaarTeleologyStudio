    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA23_EA6398> ;
    skos:definition "The following state diagram provides an overview of the allowed states for the ProjectedCost entity.<br/>"@en ;
