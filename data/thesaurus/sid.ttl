    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA614" ;
    skos:prefLabel "Policy Statement ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA615> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA601> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA615" ;
    skos:prefLabel "Policy Value ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA616> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA601> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA616" ;
    skos:prefLabel "Policy Variable ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA617> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA597> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA617" ;
    skos:prefLabel "Policy Server ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA618> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA597> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA618" ;
    skos:prefLabel "PolicyApp Role ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA619> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA566> ;
    skos:definition "The Commitment ABE, derived from the Business Interaction ABE, reflects the mutual agreement between parties about services, products, resources or some other kind of deliverable that has to be provided by the party playing the role of a Commitment fulfiller to the party, playing the role of a Commitment procurer.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA619" ;
    skos:prefLabel "Commitment ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA620> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA587> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA620" ;
    skos:prefLabel "IP Detail Record ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA621> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA587> ;
    skos:definition "The Usage Entity ABE collects consumption information, and generates Usage according to UsageSpecification for use by other business entities.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA621" ;
    skos:prefLabel "Usage Entity ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA622> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA587> ;
    skos:definition "The UsageSpecification ABE specifies usage in a generic way and its related characteristics.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA622" ;
    skos:prefLabel "Usage Specification ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA623> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA624> ;
    skos:definition "The Metric Definition Dimension ABE contains all entities describing the Dimension in a Metric context.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA623" ;
    skos:prefLabel "Metric Definition Dimension ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA626> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA577> ;
    skos:definition "The Metric Measure ABE contains entities describing measures according to a MetricDefMeasure such as MetricMeasure.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA626" ;
    skos:prefLabel "Metric Measure ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA628> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA571> ;
    skos:definition "The Entity Catalog ABE represents specifications and entities and their attributes, and associations for EntityCatalogSpecification, FederatedCatalogSpecification, EntityCatalog, and FederatedCatalog.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA628" ;
    skos:prefLabel "Entity Catalog ABE"@en .

