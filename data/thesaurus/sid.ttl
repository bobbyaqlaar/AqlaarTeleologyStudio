<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA4_EA528> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA4_EA526> ;
    skos:definition "Market Sales Forecast ABE maintains market and sales forecasts, new service requirements, customer needs, and customer education.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA4_EA528" ;
