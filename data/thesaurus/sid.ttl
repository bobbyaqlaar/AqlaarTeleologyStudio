    skos:definition "Enables dynamic creation of new SecurityThreatIndicators<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA2_EA4_EA4084" ;
    skos:prefLabel "SecurityThreatIndicatorSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA1_EA4120> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA1_EA4122> ;
    skos:definition "Following are the business entities aggregated under the Security Vulnerability Score Aggregate Business Entity.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA1_EA4120" ;
    skos:prefLabel "Figure SVS.01 - Security Vulnerability Score Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA1_EA4123> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA1_EA4122> ;
    skos:definition "A type of SecurityVulnerabilityMetric that does not have any subordinate SecurityVulnerabilityMetrics, that is, an AtomicSecurityVulnerabilityMetric is a leaf-level SecurityVulnerabilityMetric.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA1_EA4123" ;
    skos:prefLabel "AtomicSecurityVulnerabilityMetric"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA1_EA4124> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA1_EA4122> ;
    skos:definition "A type of SecurityVulnerabilityMetric that is formed by aggregating other SecurityVulnerabilityMetrics, which may be Composite or Atomic SecurityVulnerabilityMetrics.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA1_EA4124" ;
    skos:prefLabel "CompositeSecurityVulnerabilityMetric"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA1_EA4125> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA1_EA4122> ;
    skos:definition "The metrics used for scoring a particular type of security vulnerability.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA1_EA4125" ;
    skos:prefLabel "SecurityVulnerabilityMetric"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA1_EA4126> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA1_EA4122> ;
    skos:definition "The value assigned to a SecurityVulnerabilityMetric based on one or more standard values defined by SecurityVulnerabilityMetricValueDefn.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA1_EA4126" ;
    skos:prefLabel "SecurityVulnerabilityMetricValue"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA1_EA4127> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA1_EA4122> ;
    skos:definition "The risk value calculated by the scoring system for a SecurityVulnerability.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA1_EA4127" ;
    skos:prefLabel "SecurityVulnerabilityScore"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA1_EA4138> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA1_EA4140> ;
    skos:definition "Following are the business entities aggregated under the Security Vulnerability Scoring Algorithm Aggregate Business Entity.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA1_EA4138" ;
    skos:prefLabel "Figure SVSA.01 - Security Vulnerability Scoring Algorithm Related Business Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA1_EA4141> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA1_EA4140> ;
    skos:definition "A type of SecVulnerabilityScoringAlgorithmMember that indicates some combination of delimiter, operator, value should be used at this point in the algorithm. The combination is dependent on the value(s) present for the three attributes that describe this entity.<br/><br/><br/><br/>Notes: For example, \"20 *\" , \"*\", \"/\".<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA1_EA4141" ;
    skos:prefLabel "SecVulnerabilityGeneralMbr"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA1_EA4142> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA1_EA4140> ;
    skos:definition "A type of SecVulnerabilityScoringAlgorithmMember that indicates the score of the associated SecurityVulnerabilityMetric should be used at this point in the algorithm.<br/><br/><br/><br/>Notes: For example, the score for the Access Vector should be used at this point in the algorithm Exploitability score = 20 * Access Vector score * Authentification score * Access Complexity score.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA1_EA4142" ;
    skos:prefLabel "SecVulnerabilityMetricDefnMbr"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA1_EA4143> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA1_EA4140> ;
    skos:definition "A type of SecVulnerabilityScoringAlgorithmMember that indicates the value of the associated SecurityVulnerabilityMetricValue should be used at this point in the algorithm.<br/><br/><br/><br/>Notes: For example, Access Vector = case of Access Vector value of L: .395, where L is the value of the Acess Vector's security vulnerability metric value; A: .646; N: 1.0.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA1_EA4143" ;
    skos:prefLabel "SecVulnerabilityMetricValueDefnMbr"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA1_EA4144> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA1_EA4140> ;
    skos:definition "A step-by-step procedure for calculating the a security vulnerability score.<br/><br/><br/><br/>Notes: For example, BaseScore = round-to-1-decimal(((0.6 * Impact) + (0.4 * Exploitability) - 1.5) * f(Impact)).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA1_EA4144" ;
    skos:prefLabel "SecVulnerabilityScoreAlgorithm"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA1_EA4145> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA1_EA4140> ;
    skos:definition "A fragment of an algorithm that represents a security vulnerability metric definition (score), a security vulnerability metric value definition, or a general fragment which represents a delimiter, operator, or a value.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA1_EA4145" ;
    skos:prefLabel "SecVulnerabilityScoreAlgorithmMember"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA4128> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA4130> ;
    skos:definition "Following are the business entities aggregated under the Security Vulnerability Scoring Definition Aggregate Business Entity.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA4128" ;
    skos:prefLabel "Figure SVSD.01 - Security Vulnerability Scoring Definition Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA4131> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA4130> ;
    skos:definition "A type of SecurityVulnerabilityMetricDefn that does not have any subordinate SecurityVulnerabilityMetricDefns, that is, an AtomicSecurityVulnerabilityMetricDefn is a leaf-level SecurityVulnerabilityMetric. <br/><br/><br/><br/>Notes: Examples include Base Metrics - Access Vector, Authentication, and Access Complexity.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA4131" ;
    skos:prefLabel "AtomicSecVulScoringMetricDefn"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA4132> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA4130> ;
    skos:definition "A type of SecurityVulnerabilityMetricDefn that is formed by aggregating other SecurityVulnerabilityMetricDefns, which may be Composite or Atomic SecurityVulnerabilityMetricDefns.<br/><br/><br/><br/>Notes: A Base Score Metric which is made up of Base Exploitability and Base Impact, Base Exploitability made up of Acess Vector, Authentication, and so forth.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA4132" ;
    skos:prefLabel "CompositeSecVulScoringMetricDefn"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA4134> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA4130> ;
    skos:definition "A standard value for a defined scoring metric (SecVulnerabilityScoringMetricDefn). Each metric has multiple instances which represent multiple values.<br/><br/><br/><br/>Notes: For example, Base Metric Access Vector has three pre-defined values - L/Local, A/Adjacent Network, and N/Network.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA4134" ;
    skos:prefLabel "SecVulnerabilityMetricValueDefn"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA4135> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA4130> ;
    skos:definition "The definition of a metric which may be categorized into three groups (Base, Temporal, and Environmental). These three groups are further decomposed into groupings for exploitability and/or impact which define metrics used to score vulnerability severity. <br/><br/><br/><br/>Notes: For example, Base Metrics are grouped into Base Exploitability and Base Impact Metrics. Base Exploitability Metrics include Access Vector, Authentication, and Access Complexity Metrics.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA4135" ;
    skos:prefLabel "SecVulnerabilityScoringMetricDefn"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA4136> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA4130> ;
    skos:definition "The scoring system specification defines three groups of metrics to determine a score a vulnerability. <br/><br/><br/><br/>Notes: The three types of metrics include Base Metrics, Temporal Metrics, and Environmental Metrics.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA4136" ;
    skos:prefLabel "SecVulnerabilityScoringMetricDefnAssignment"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA4137> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA4130> ;
    skos:definition "A standardized method for vulnerability measurement and severity scoring.<br/><br/><br/><br/>Notes: Three scoring specifications have been created, one for each of the categories of system vulnerabilities defined by NIST SCAP. They include the Common Vulnerability Scoring System (CVSS) which address software flaw vulnerabilies (introduced in 2004/v2 in 2007), the Common Misuse Scoring System (CMSS) which was designed for measuring and scoring misuse vulnerabilities. And the Common Configuration Scoring System (CCSS) which addresses software security configuration issue vulnerabilities.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA2_EA4137" ;
    skos:prefLabel "SecVulnerabilityScoringSystem"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA4107> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA4109> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the Security Vulnerability Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA4107" ;
    skos:prefLabel "Figure SV.01 - Security Vulnerability Related Business Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA4110> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA4109> ;
    skos:definition "This attribute is for weaknesses realted to the vulnerability. Comon Weakness Enumerations (CWE). <br/><br/>CWE™ provides a unified, measurable set of software weaknesses that is enabling more effective discussion, description, selection, and use of software security tools and services that can find these weaknesses in source code and operational systems as well as better understanding and management of software weaknesses related to architecture and design. <br/><br/>Source: http://cwe.mitre.org/<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA4110" ;
    skos:prefLabel "CommonWeaknessEnumeration"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA4111> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA4109> ;
    skos:definition "Represents an update to software which mitigates or resolves the vulnerability.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA4111" ;
    skos:prefLabel "Patch"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA4114> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA4109> ;
    skos:definition "An information security \"vulnerability\" is a mistake in software that can be directly used by a hacker to gain access to a system or network. <br/><br/>CVE considers a mistake a vulnerability if it allows an attacker to use it to violate a reasonable security policy for that system (this excludes excluding entirely \"open\" security policies in which all users are trusted, or where there is no consideration of risk to the system). <br/><br/>For CVE, a vulnerability is a state in a computing system (or set of systems) that either: <br/><br/> · allows an attacker to execute commands as another user <br/> · allows an attacker to access data that is contrary to the specified access restrictions for that data <br/> · allows an attacker to pose as another entity <br/> · allows an attacker to conduct a denial of service <br/><br/>source: http://cve.mitre.org<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA4114" ;
    skos:prefLabel "SecurityVulnerability"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA4115> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA4109> ;
    skos:definition "It is the instance of a particular SecurityVulnerability that has been classified into one of the three categories (software flaw, software feature misuse, or software configuration issue). <br/><br/><br/><br/>Notes: For example (hypothetically), Internet Explorer could have a bug that is categorized as a software flaw. There can be vulnerabilities that have one or more of the three category types associated with it. In this case, the vulnerability would be scored for all three types.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA4115" ;
    skos:prefLabel "SecurityVulnerabilityCategoryAssignment"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA4116> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA4109> ;
    skos:definition "Identifies the type of SecurityVulnerability for the purposes of vulnerability scoring.<br/><br/><br/><br/><br/><br/>Notes: The three types defined include software flaws, security configuration issues, and software feature misuses.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA4116" ;
    skos:prefLabel "SecurityVulnerabilityCategoryType"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA4117> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA4109> ;
    skos:definition "A single patch application, software update, configuration change, or external fix. Dependencies are documented by using the nextFixAction association<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA4117" ;
    skos:prefLabel "SecurityVulnerabilityFixAction"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA4118> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA4109> ;
    skos:definition "The software that contains the mistake, or flaw, which caused the vulnerability. The SecurityVulnerabilitySoftware may be updated to fully resolve the vulnerability.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA4118" ;
    skos:prefLabel "SecurityVulnerabilitySoftware"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA4119> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA4109> ;
    skos:definition "A tool that can be used to scan and/or fix the security vulnerability.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA2_EA5_EA4119" ;
    skos:prefLabel "SecurityVulnerabilityTool"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA4_EA1_EA4149> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA4_EA1_EA4148> ;
    skos:definition "A type of BusinessObjective that does not have any subordinate BusinessObjectives, that is, an AtomicBusinessObjective is a leaf-level BusinessObjective.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA4_EA1_EA4149" ;
    skos:prefLabel "AtomicBusinessObjective"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA4_EA1_EA4150> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA4_EA1_EA4148> ;
    skos:definition "A formal and measurable objective a Party, playing a PartyRole, has regarding that respective role. A BusinessObjective may represent an atomic business objective or consists of other business objectives.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA4_EA1_EA4150" ;
    skos:prefLabel "BusinessObjective"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA4_EA1_EA4151> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA4_EA1_EA4148> ;
    skos:definition "Detailed description of a BusinessObjective. The composite and entity charactieristic pattern may be applied for BusinessEntitySpecifications if applicable.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA4_EA1_EA4151" ;
    skos:prefLabel "BusinessObjectiveSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA4_EA1_EA4152> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA4_EA1_EA4148> ;
    skos:definition "A type of BusinessObjective that is formed by aggregating other BusinessObjectives, which may be composite or atomic BusinessObjectives.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA4_EA1_EA4152" ;
    skos:prefLabel "CompositeBusinessObjective"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA1_EA4156> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA1_EA4158> ;
    skos:definition "A Budget is a global class which contains the different budgets allocated to at least one Party. The Party might be an Organisation. A Budget might be split into several parts related to a sub-division of the initial Budget.<br/>A CompositeBudget is broken down into Budgets atomic or not.<br/>To find examples of CompositeBudget refer to the Marketing Campaign ABE.<br/>A Budget specifies the unit used for each amount: allocated, forecasted and achieved.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA5_EA1_EA4156" ;
    skos:prefLabel "Figure Bud.01 - Budget"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA1_EA4159> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA1_EA4158> ;
    skos:definition "An AtomicBudget is a type of Budget that isn’t broken into other Budgets. It might be part of a CompositeBudget or not.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA5_EA1_EA4159" ;
    skos:prefLabel "AtomicBudget"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA1_EA4160> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA1_EA4158> ;
    skos:definition "A Budget contains the different budgets allocated to at least one Party. The Party might be an Organization. A Budget might be split into several parts related to a sub-division of the initial Budget.<br/><br/>A Budget specifies the unit used for each amount: allocated, forecasted and achieved.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA5_EA1_EA4160" ;
    skos:prefLabel "Budget"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA1_EA4161> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA1_EA4158> ;
    skos:definition "A CompositeBudget is a type of Budget.<br/><br/>A CompositeBudget is broken down into Budgets atomic or not.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA5_EA1_EA4161" ;
    skos:prefLabel "CompositeBudget"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA2_EA1_EA4174> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA2_EA4164> ;
    skos:definition "<b>Accounts Payable ABE</b> represents the total amount the CSP owes to suppliers, vendors, or partners for received goods and services. It aggregates obligations from purchase orders, supplier invoices, and expense claims, supporting payment processing, vendor reconciliation, and liability tracking.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA5_EA2_EA1_EA4174" ;
    skos:prefLabel "Accounts Payable ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA2_EA2_EA4175> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA2_EA4164> ;
    skos:definition "<b>Accounts Receivable ABE</b> represents the total amount owed to the CSP by customers or other parties for delivered products and services. It aggregates unpaid or partially paid PartyAccounts and tracks receivables from invoicing until payment or write-off. Used internally for revenue recognition, aging analysis, dunning, and bad-debt provisioning.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA5_EA2_EA2_EA4175" ;
    skos:prefLabel "AccountsReceivable ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA2_EA3_EA1_EA4178> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA2_EA3_EA4176> ;
    skos:definition "<b>Capex ABE</b>, or Capital Expenditure records expenditures used by the CSP to acquire, upgrade, or extend the useful life of long-term tangible or intangible assets (e.g., network equipment, fiber, software licenses, spectrum). Capex is typically capitalized and depreciated/amortized over time.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA5_EA2_EA3_EA1_EA4178" ;
    skos:prefLabel "Capex ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA2_EA4162> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA2_EA4164> ;
    skos:definition "An Account specifies basic attributes and relationships that describe an account.<br/>An Account aims to register all Credits and Debits according to criteria. It carries one or many Balances (results of Credits and Debits) and might use one or many Currencies.<br/>Each Account is possessed by one or many PartyRoles such as the Holder or the Payer of a CustomerBillingAccount.<br/>Each Account might be related to other Accounts such as a parent / child relationship.<br/>BusinessPartnerAccount, CustomerBillingAccount and FinancialAccount are types of Account.<br/>A BusinessPartnerAccount and CustomerBillingAccount carries additional information (such as creditLimit) and have specific relationships.<br/>A FinancialAccount is part of the sub-ledger accounting that aggregates the amounts of one or more business partner and / or Customer accounts owned by a given party. It’s an internal view of the CSP to manage incomes and outcomes.<br/>Each accounting event from a BusinessPartnerAccount or CustomerBillingAccount is logged to a FinancialAccount according to the assignment rules specified by BsuinessPartnerAccountAssignment and CustomerBillingAccountAssignment.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA5_EA2_EA4162" ;
    skos:prefLabel "Figure Acc.01 - Account Overview (copy from common)"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA2_EA4171> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA2_EA4164> ;
    skos:definition "A FinancialAccount is part of the sub-ledger accounting that aggregates the amounts of one or more party accounts owned by a given party. It’s an internal view of the CSP to manage incomes and outcomes. It is only an internal accounting which does not need to follow the GeneralLedger accounting regulation.<br/><br/>Each accounting event from a PartyAccount is logged to a FinancialAccount according to the assignment rules specified by PartyAccountAssignment.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA5_EA2_EA4171" ;
    skos:prefLabel "FinancialAccount"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA2_EA4_EA4179> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA2_EA4164> ;
    skos:definition "<b>Debt ABE</b> aggregates the total obligations of the CSP to repay borrowed funds to lenders or bondholders. It includes short-term and long-term loans, bonds, leases classified as debt, and other financing liabilities, including accrued interest.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA5_EA2_EA4_EA4179" ;
    skos:prefLabel "Debt ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA2_EA5_EA4180> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA2_EA4164> ;
    skos:definition "<b>EBITDA ABE</b>, or Earnings Before Interest, Taxes, Depreciation, and Amortization measures the CSP’s operating profitability from core business activities only. It is calculated as Operating Income + Depreciation of tangible assets + Amortization of intangible assets (or equivalently: Revenue − COGS − Opex excluding all non-cash depreciation and amortization charges). EBITDA is widely used in the telecom industry for valuation multiples, covenant testing in debt agreements, and operational performance comparison because it eliminates the effects of financing structure, tax regimes, and non-cash accounting choices.<br/>To summarize: EBITDA = Revenue − Cost of Revenue (COGS) − Opex (cash operating expenses)<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA5_EA2_EA5_EA4180" ;
    skos:prefLabel "EBITDA ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA2_EA6_EA1_EA4184> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA2_EA6_EA4181> ;
    skos:definition "<b>Cost ABE</b> aggregates all expenses incurred by the CSP to produce and deliver its services and products. Includes Cost of Goods Sold (COGS), network operating costs, interconnection fees, content costs, and commissions. Used for profitability and margin analysis.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA5_EA2_EA6_EA1_EA4184" ;
    skos:prefLabel "Cost ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA2_EA6_EA2_EA4185> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA2_EA6_EA4181> ;
    skos:definition "<b>Opex ABE</b>, or Operating Expenditure, records day-to-day expenses required to run the CSP’s operations that are expensed in the period incurred. Includes network maintenance, salaries, marketing, customer care, IT operations, rent, and utilities (excluding Capex and cost of goods sold related to device sales).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA5_EA2_EA6_EA2_EA4185" ;
    skos:prefLabel "OPEX ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA2_EA7_EA1_EA4189> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA2_EA7_EA4186> ;
    skos:definition "<b>Net Income ABE</b> representing the CSP’s profit or loss for a period. It is calculated as total Income plus/minus other gains/losses minus all Costs, Opex, depreciation/amortization, interest expense, taxes, and extraordinary items. Also known as Profit (Loss) After Tax or Bottom-Line Result. <br/>To summarize: NetIncome (\"bottom line\") = Income - Interest - Taxes<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA5_EA2_EA7_EA1_EA4189" ;
    skos:prefLabel "Net Income ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA2_EA7_EA2_EA4190> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA2_EA7_EA4186> ;
    skos:definition "<b>Operating Income ABE</b> measures the profit a CSP generates from its core telecommunications operations before deducting interest expenses, taxes, and non-operating items. It is calculated as total Revenue minus Cost of Revenue (COGS) and all Operating Expenses (Opex, including network operations, customer care, marketing, administrative expenses, and depreciation/amortization of operational assets). Operating Income reflects the operational profitability of the CSP’s service and product delivery activities. Also known as EBIT – Earnings Before Interest and Taxes, or Operating Profit.<br/>To summarize: Operating Income (EBIT) = EBITDA − Depreciation (network, buildings, etc.) − Amortization (spectrum licenses, software, customer base, etc.)<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA5_EA2_EA7_EA2_EA4190" ;
    skos:prefLabel "Operating Income ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA2_EA8_EA1_EA4193> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA2_EA8_EA4191> ;
    skos:definition "The<b> Sales Revenue ABE</b> captures gross revenue from the sale of goods (e.g., handsets, CPE) and non-recurring services before deductions. Often tracked separately from recurring service Revenue to support margin analysis between device sales and service bundles.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA5_EA2_EA8_EA1_EA4193" ;
    skos:prefLabel "Sales Revenue"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA491> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA479> ;
    skos:definition "WorkforceResource ABE represents the employees and other non-human resources involved in field operations.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA3_EA491" ;
    skos:prefLabel "Workforce Resource ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA505> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA503> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA3_EA505" ;
    skos:prefLabel "Security Vulnerability Scoring Definition ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA509> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA481> ;
    skos:definition "<b>Asset ABE</b> represents resources controlled by the CSP from which future economic benefits are expected. Includes tangible assets (network infrastructure, land), intangible assets (licenses, goodwill), financial assets (investments, receivables), and deferred assets.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA3_EA509" ;
    skos:prefLabel "Asset ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA514> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA481> ;
    skos:definition "The<b> Revenue ABE</b> aggregates recognized income earned by the CSP from providing telecommunication services and products to customers. It includes recurring charges, usage-based fees, one-time fees, and other billable items after revenue recognition rules are applied, excluding taxes and discounts. Also known as the \"top line\". Total revenue will greater than sales.<br/>To summarize: (Total) Revenue = Service Revenue + Product Sales<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA3_EA514" ;
    skos:prefLabel "Revenue ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA572> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA563> ;
    skos:definition "Closedloop is a \"management framework\" in which current outcomes are used to improve future outcomes in order to achieve specified goals. The management framework includes the feedforward workflow and a feedback workflow, where the feedforward is a control loop meant to continually optimize and improve <br/><br/>There can be different management frameworks, referred to in this model as \"closedloop models\". Optimized versions of closedloop management frameworks may be derived for specific scenarios. Closedloop can be typified as fast or slow and can work hierarchically or as peers or both, based on implementation choices.<br/><br/>For more information please refer to IG1219.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA572" ;
    skos:prefLabel "Closed Loop ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA590> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA578> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA590" ;
    skos:prefLabel "Performance Category ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA603> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA581> ;
    skos:definition "A pattern (the content of the ABE) enables attributes unique to a type of entity to be created via its association to EntitySpecification and enables attributes unique to a certain entity to be created via its association to RootEntityType. A RootEntityType is an entity in the SID. For example, characteristics could be defined for entities (instances of RootEntityType) such as Product, Customer, and ProductSpecification that apply to all instances of those entities.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA603" ;
    skos:prefLabel "Characteristic ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA624> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA577> ;
    skos:definition "The Metric Definition ABE contains the main entities describing a MetricDefinition such as MetricDefinition itself, MetricDefinitionCategory and MetricDefinitionDimension.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA624" ;
    skos:prefLabel "Metric Definition ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA625> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA577> ;
    skos:definition "The MetricDefMeasure specifies a measure of a specific aspect of an entity and is the main part of a MetricDefinition.<br/><br/>The Metric Definition Measure ABE contains all entities describing the MetricDefMeasure such as the related threshold, notification and consequence.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA625" ;
    skos:prefLabel "Metric Definition Measure ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA676> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA663> ;
    skos:definition "<font color=\"#29313b\">A ProductOfferingInstance represents the instantiation of a ProductOfferingSpecification for a specific Customer. It may carry ProductPrice and commitment choice.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA6_EA676" ;
    skos:prefLabel "Product Offering Instance ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA677> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA666> ;
    skos:definition "The Pricing Logic Algorithm ABE contains entities representing an instantiation of an interface specification to external rating function (without a modeled bahavior in SID).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA6_EA677" ;
    skos:prefLabel "Pricing Logic Algorithm ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA7_EA737> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA7_EA774> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA7_EA737" ;
    skos:prefLabel "Physical Role ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA7_EA751> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA7_EA773> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA7_EA751" ;
    skos:prefLabel "Computing and Software ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA7_EA778> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA7_EA712> ;
    skos:definition "The Physical Resource Specification ABE describes the invariant characteristics and behavior (attributes, methods, constraints, and relationships) of a PhysicalResource.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA7_EA778" ;
    skos:prefLabel "PhysicalResource Specification ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA821> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA827> ;
    skos:definition "The Service Bundle ABE is a collection of ResourceFacingServiceSpecifications. This enables the needs of different sets of ResourceFacingServiceSpecifications to be grouped together, hence the name “bundle”. Since these are ResoureFacingSpecifications, they define reusable templates for implementing the ResourceFacingServices that are required by a particular CustomerFacingService (as represented by a ServicePackage).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA821" ;
    skos:prefLabel "Service Bundle ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA840> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA826> ;
    skos:definition "The Service Package ABE defines the concept of bundling a set of different CustomerFacingServiceSpecs to meet the functionality specified by one or more ProductSpecifications. This enables the shared characteristics of these CustomerFacingServices to be specified, so that multiple Products can be built from their associated ProductSpecification.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA840" ;
    skos:prefLabel "Service Package ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA12_EA1_EA5621> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA12_EA1_EA5620> ;
    skos:definition "A small item of work, that aligns to a task in a process<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA12_EA1_EA5621" ;
    skos:prefLabel "Activity"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA16_EA1_EA5925> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA16_EA1_EA5904> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA16_EA1_EA5925" ;
    skos:prefLabel "Active"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA17_EA6008> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA17_EA6001> ;
    skos:definition "<b>Intent</b> is the formal specification of all <b>expectations</b> including <b>requirements, goals</b>, and <b>constraints</b> given to a technical system.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA17_EA6008" ;
    skos:prefLabel "Intent"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6134> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6105> ;
    skos:definition "Describes the set of instructions that determine how something is performed.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA18_EA1_EA6134" ;
    skos:prefLabel "BusinessRule"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA6043> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA6027> ;
    skos:definition "Defines a Closed Loop.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA18_EA6043" ;
    skos:prefLabel "ClosedLoop"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA19_EA6212> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA19_EA6191> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA19_EA6212" ;
    skos:prefLabel "Suspended"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA20_EA6229> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA20_EA6228> ;
    skos:definition "Represents a set of activities orchestrated together based on a set of goals/objectives and specific partyRoles.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA20_EA6229" ;
    skos:prefLabel "Workflow"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7137> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7128> ;
    skos:definition "This is an abstract modeling concept that provides a linking point to other parts of the SID model.<br/><br/>Its subclasses are entities that are locations that are defined using floating point Cartesian coordinates<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA2_EA7137" ;
    skos:prefLabel "LocalContinuativeLocation"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7242> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7195> ;
    skos:definition "This entity corresponds to any document provided or produced during the execution of a business process.<br/>This can also be a document that was provided by the Customer (such as report, log or picture showing a problem with one of the products), or a document provided by the CSP to the customer as part of the interaction (such as manual or a brochure).<br/>Examples:<br/><ul><li>Dunning process will generate reminder mails. Reminder mails are documents.</li><li>Billing process will generate Invoices. Invoices are documents.</li><li>An agreement between at least two parties may be formalized as one Document or a DocumentSet</li></ul><br/>It is understood that a document might be of some type other than SimpleDocument, GeneratedDocument, or PatternDocument, and therefore is concrete.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA9_EA7242" ;
    skos:prefLabel "Document"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA1_EA1_EA1123> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA1_EA1_EA1122> ;
    skos:definition "A SalesOpportunity is an opportunity to generate revenue from a SalesLead that can already be an existing Customer. Opportunities are the pending deals that need to be tracked. Opportunities build the pipeline, which will contribute to the forecast. A SalesOpportunity represents an interest expressed by a Party known as a SalesLead to at least one ProductOffering/ProductSpecification proposed by the CSP.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA3_EA1_EA1_EA1123" ;
    skos:prefLabel "SalesOpportunity"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA7_EA1178> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA1090> ;
    skos:definition "<b>Sales Channel ABE</b> keeps track of distribution channels and sales activities, sales quotas, sales, contests, commission/bonus plans, commissions/bonuses, and maintain groups of individuals that make up the sales force.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA3_EA7_EA1178" ;
    skos:prefLabel "Sales Channel ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA2_EA1257> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA2_EA1230> ;
    skos:definition "A SalesQuote is a document that allows a Prospect to view the cost involved in purchasing specific Products. It is generally used by suppliers or resellers to begin a business transaction and specifies validity period for acceptance of the quote and possibly an authorisation process depending on the value of the quote.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA4_EA2_EA1257" ;
    skos:prefLabel "SalesQuote"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA12_EA2021> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA1458> ;
    skos:definition "A strategy employed to promote a <font color=\"#29313b\">ProductOfferingSpecification</font>. <b>Strategic Product Portfolio Plan ABE</b> is concerned with the plans of the product portfolio, which product offerings to make available to each market segment and the plans to development and deploy product offerings, as well as retirement of products. <i>This ABE is not fully developed</i><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA12_EA2021" ;
    skos:prefLabel "Strategic Product Portfolio Plan ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA2_EA1565> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA2_EA1529> ;
    skos:definition "A ProdSpecCharUse limits the possible values of a ProdSpecCharacteristic for a ProductSpecification.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA2_EA1565" ;
    skos:prefLabel "ProductSpecCharUse"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1_EA1819> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1_EA1816> ;
    skos:definition "Represents an instance in the product inventory of a ProductSpecification subscribed or not yet subscribed by a Customer to the CSP or by the CSP to a BusinessParnter, the place where the product is in use, as well as configuration characteristics, such as assigned telephone numbers and internet addresses. <br/><font color=\"#29313b\">It may come from a CustomerProductOrderItem or a BusinessPartnerOrderItem. At one time, it might be contained in a unique ProductOfferingInstance.</font><br/>The Product ABE also tracks the links to services and/or resources through which the product is realized.<br/>A Product might be Composite or Atomic.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA1_EA1819" ;
    skos:prefLabel "Product"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA2_EA1861> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA2_EA1858> ;
    skos:definition "<font color=\"#29313b\">A ProductOfferingInstance represents the instantiation of a ProductOfferingSpecification for a specific Customer. It may carry ProductPrice and commitment choice.</font><br/><font color=\"#29313b\">A ProductOfferingInstance is either Composite or Atomic.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA2_EA1861" ;
    skos:prefLabel "ProductOfferingInstance"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA4_EA1_EA2_EA2233> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA4_EA1_EA2220> ;
    skos:definition "The Customer Facing Service Role ABE defines CustomerServiceRoles that are used to represent the variable characteristics of a CustomerFacingService in terms of roles that this type of Service plays.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA6_EA4_EA1_EA2_EA2233" ;
    skos:prefLabel "CustomerFacing Service Role ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA2_EA2874> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA2_EA2871> ;
    skos:definition "The state describes a model that is stored in a Model catalog or registry for version control and management. This state enable capture details sub-states such as Specification Documentation: Maintain detailed records of each phase for transparency and reproducibility and Stakeholder Reporting: Provide regular updates to stakeholders on model performance and any necessary adjustments.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA2_EA2874" ;
    skos:prefLabel "Cataloged"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA2_EA2878> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA2_EA2871> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA2_EA2878" ;
    skos:prefLabel "Evaluated"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA2_EA2883> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA2_EA2871> ;
    skos:definition "The state elaborates a model's performance is being monitored in a real-world environment. Monitoring state can include detailed sub-states such as Performance Monitoring: Continuously track model performance against established KPIs to detect any degradation over time. Model Retraining: Update the model with new data or adjust its architecture in response to changes in underlying data distributions or business needs. Bias Mitigation: Regularly assess for bias in predictions and implement strategies to address any identified issues.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA2_EA2883" ;
    skos:prefLabel "Monitoring"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA2_EA2884> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA2_EA2871> ;
    skos:definition "The state that indicates a model that is no longer in use, and has been archived or decommissioned.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA2_EA2884" ;
    skos:prefLabel "Retired"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA2_EA2887> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA2_EA2871> ;
    skos:definition "The state represents an existing model instance that is undergoing some change, which can include retrained, or fine-tuned AI model using new data.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA2_EA2887" ;
    skos:prefLabel "Updating"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA2_EA2888> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA2_EA2871> ;
    skos:definition "The state represents when a model is being validated against a separate dataset to evaluate performance. This stage can have further sub-states including Validation Testing: Assess model performance using a separate validation dataset to ensure generalization. Performance Metrics matching: Evaluate using metrics such as accuracy, precision, recall, F1 score, and AUC-ROC curves to gauge effectiveness. Iterative Refinement: If performance is unsatisfactory, revisit earlier stages for adjustments in data preparation or model design.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA2_EA2888" ;
    skos:prefLabel "Validation"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA3_EA2902> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA2841> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA3_EA2902" ;
    skos:prefLabel "Computing and Software ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA2_EA3102> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA2_EA3097> ;
    skos:definition "This is a type of Card that is dedicated to providing networking functions, such as routing and forwarding. Line cards and port adapter cards are examples of this type of card. The SID differentiates between this and other types of Cards, such as NetworkCards and MemoryCards.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA2_EA3102" ;
    skos:prefLabel "NetworkCard"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA4_EA4146> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3755> ;
    skos:definition "<b>Enterprise Effectiveness ABE </b>represents all information used to evaluate the enterprise effectiveness, such as Business Objectives and Processes.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA4_EA4146" ;
    skos:prefLabel "Enterprise Effectiveness ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA2_EA3_EA4176> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA2_EA4164> ;
    skos:definition "<b>Asset ABE</b> represents resources controlled by the CSP from which future economic benefits are expected. Includes tangible assets (network infrastructure, land), intangible assets (licenses, goodwill), financial assets (investments, receivables), and deferred assets.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA5_EA2_EA3_EA4176" ;
    skos:prefLabel "Asset ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA2_EA8_EA4191> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA2_EA4164> ;
    skos:definition "The<b> Revenue ABE</b> aggregates recognized income earned by the CSP from providing telecommunication services and products to customers. It includes recurring charges, usage-based fees, one-time fees, and other billable items after revenue recognition rules are applied, excluding taxes and discounts. Also known as the \"top line\". Total revenue will greater than sales.<br/>To summarize: (Total) Revenue = Service Revenue + Product Sales<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA5_EA2_EA8_EA4191" ;
    skos:prefLabel "Revenue ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA365> a skos:Concept ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA365" ;
    skos:prefLabel "SID Domains"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA368> a skos:Concept ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA368" ;
    skos:prefLabel "EARoot_EA4_EA368"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA374> a skos:Concept ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA374" ;
    skos:prefLabel "Business Partner Domain : Business Partner Domain"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA375> a skos:Concept ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA375" ;
    skos:prefLabel "Common Domain :Patterns Domain Level 1"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA376> a skos:Concept ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA376" ;
    skos:prefLabel "Product Domain :Product Domain"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA377> a skos:Concept ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA377" ;
    skos:prefLabel "Resource Domain :Resource Domain"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA378> a skos:Concept ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA378" ;
    skos:prefLabel "Service Domain :Service Domain"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA379> a skos:Concept ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA379" ;
    skos:prefLabel "Views"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA860> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA857> ;
    skos:definition "Represents Entities used to provide time related functions. This includes scheduling, time conflicts and time based presentation support.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA10_EA860" ;
    skos:prefLabel "Calendar ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA867> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA863> ;
    skos:definition "A group of entities that are used to define a geographic location and enable it to be marked it on a map or given an address.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA10_EA867" ;
    skos:prefLabel "Geographic Place ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA2_EA445> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA2_EA444> ;
    skos:definition "The Applied Customer Billing Rate ABE deals with the correlation of related usage for subsequent rating, rates applied to the usage (both regulated and non-regulated), discounts to usage, and any taxes due on the rated usage.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA2_EA445" ;
    skos:prefLabel "Applied Customer Billing Rate ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA2_EA446> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA2_EA444> ;
    skos:definition "The Customer Billing ABE handles real-time and non-real-time Call Detail Records (CDRs) and other sources of data that result in invoice items. The Customer Bill ABE also represents the format of a bill, schedule the production of bills, customer invoicing profiles, all the financial calculations necessary to determine the total of the bill (except for rating and rating discounts), and credits and adjustments to bills.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA2_EA446" ;
    skos:prefLabel "Customer Bill ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA2_EA448> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA2_EA444> ;
    skos:definition "Used to manage account and its balance information. Balance (or balances) represents an amount, usually with some monetary value, usually an aggregation, that indicates an aspect of liability (often financial) between the service provider and the account holder (usually a customer). This amount can be monetary amount, or non-monetary (such as free minutes, or amount of loyalty points), can represent credit that the CSP holds for the customer (for example pre-paid balance) or debt that the customer owes the CSP (as is the normal case for post-paid A/R balance). <br/><br/>Related tightly with customer payment and other ABEs especially in charing domain. It is intended to support a converged model applicable for both prepaid and postpaid cases.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA2_EA448" ;
    skos:prefLabel "Customer Billing Account ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA2_EA460> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA2_EA445> ;
    skos:definition "The Applied Customer Billing Rate Spec ABE is detailed description of AppliedCustomerBillingRate entity.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA2_EA460" ;
    skos:prefLabel "Applied Customer Billing Rate Spec ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA475> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA474> ;
    skos:definition "Represents all information used to evaluate the enterprise effectiveness, such as Business Objectives and Processes.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA3_EA475" ;
    skos:prefLabel "Enterprise Effectiveness ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA478> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA474> ;
    skos:definition "The Finance ABE aims to describe all what is related to the Enterprise finance such as financial accounts, general ledger...<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA3_EA478" ;
    skos:prefLabel "Finance ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA502> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA495> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA3_EA502" ;
    skos:prefLabel "Security Threat ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA503> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA495> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA3_EA503" ;
    skos:prefLabel "Security Vulnerability ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA512> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA481> ;
    skos:definition "The <b>Expense ABE</b> aggregates all outflows of economic benefits during a period resulting in a decrease in equity (other than distributions to owners). It primarily comprises costs and operating expenses incurred in the course of delivering telecommunication services and products, including Cost of Goods Sold (COGS such as interconnection fees, content royalties, device costs), Operating Expenses (Opex such as network maintenance, salaries, marketing, customer care, rent, utilities), depreciation and amortization of assets used in operations, and other period costs. Expenses are recognized when incurred (accrual basis) and are used to calculate operational profitability and net financial results.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA3_EA512" ;
    skos:prefLabel "Expense ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA513> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA481> ;
    skos:definition "<b>Income ABE</b> aggregates all inflows of economic benefits during a period resulting in an increase in equity (other than contributions from owners). It primarily comprises recognized Revenue from core operations plus non-operating income such as interest received, dividends, gains on asset disposal, foreign exchange gains, and other miscellaneous income items.<br/>To summarize: Income = Operating Income (EBIT) +/− Other Income/Expenses(non-operating items)<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA3_EA513" ;
    skos:prefLabel "Income ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA566> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA563> ;
    skos:definition "An Agreement represents a contract or arrangement, either written or verbal and sometimes enforceable by law, such as a service level agreement or a customer price agreement. An agreement involves a number of other business entities, such as products, services, and resources and/or their specifications.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA566" ;
    skos:prefLabel "Agreement ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA568> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA563> ;
    skos:definition "A small simple object, like money or a date range, whose equality isn't based on identity.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA568" ;
    skos:prefLabel "Base Types ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA569> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA563> ;
    skos:definition "The Business Interaction ABE represents an arrangement, contract, or communication between an enterprise and one or more other entities such as individuals and organizations (or parts of organizations). Interactions take on the form of requests, responses, and notifications.<br/>.\\doc\\Figure BI.13 - DisputedAmountActivity classes modeling the DisputedAmount life cycle.docx<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA569" ;
    skos:prefLabel "Business Interaction ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA571> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA563> ;
    skos:definition "A generalized ABE that represents common Catalog Specification and Catalog entities, attributes, and associations shared (inherited) by components of the Entity, Federated, Product, Service, and Resource Catalog ABEs. .<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA571" ;
    skos:prefLabel "Catalog ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA576> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA563> ;
    skos:definition "The Maturity Model ABE is the focus of all maturity models, maturity model levels, model assessment structure, and the embodiment of the maturity models capabilities for the topic of capability maturity.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA576" ;
    skos:prefLabel "Maturity Model ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA591> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA578> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA591" ;
    skos:prefLabel "Performance Monitoring ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA597> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA579> ;
    skos:definition "The Policy Application ABE defines concepts and application components that can use policy entities to manage the behavior and configuration of other entities. This consists of entities to provide policy decision-making capabilities, as well as entities to enforce and execute policies. It also includes entities required to build an NGOSS policy system. These include entities to coordinate management and usage aspects of policy as well as entities to enable policy components to scale to large distributed systems.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA597" ;
    skos:prefLabel "Policy Application ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA627> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA577> ;
    skos:definition "The Metric Monitoring ABE contains all entities enabling the monitoring of MetricMeasures such as MetricMeasurementJob.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA627" ;
    skos:prefLabel "Metric Monitoring ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA665> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA661> ;
    skos:definition "The definition of how a Product operates or functions in terms of CharacteristicSpecification(s) and related ResourceSpec(s), ProductSpec(s), ServiceSpec(s) as well as a representation of how a Product operates or functions in terms of characteristics and related Resource(s), Product(s), Service(s).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA6_EA665" ;
    skos:prefLabel "Product Configuration ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA675> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA663> ;
    skos:definition "Represents an instance in the product inventory of a ProductSpecification subscribed or not yet subscribed by a Customer to the CSP or by the CSP to a BusinessParnter, the place where the product is in use, as well as configuration characteristics, such as assigned telephone numbers and internet addresses. <br/><font color=\"#29313b\">It may come from a CustomerProductOrderItem or a BusinessPartnerOrderItem. At one time, it might be contained in a unique ProductOfferingInstance.</font><br/>The Product ABE also tracks the links to services and/or resources through which the product is realized.<br/>The Product ABE also contains detailed concerning Network Products and Usage Volume Products as well as other examples of Products.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA6_EA675" ;
    skos:prefLabel "Product ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA7_EA717> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA7_EA705> ;
    skos:definition "The Resource Usage ABE collects Resource consumption data, and generates Resource usage records, for use by other business entities. The entities in this ABE provide physical, logical, and network usage information.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA7_EA717" ;
    skos:prefLabel "Resource Usage ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA7_EA732> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA7_EA774> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA7_EA732" ;
    skos:prefLabel "Equipment Holder ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA7_EA771> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA7_EA777> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA7_EA771" ;
    skos:prefLabel "Software Resource and Software Specifications ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA7_EA775> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA7_EA706> ;
    skos:definition "Values: Released,Preliminary,Draft,Not Fully Developed,likelyToChange,likelyToBeDeprecated"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA7_EA775" ;
    skos:prefLabel "TIP Resource ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA816> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA804> ;
    skos:definition "The Service Usage ABE collects Service consumption data, and generates Service usage records, for use by other business entities. The entities in this ABE provide physical, logical, and network usage information. For more detail refer to Usage ABE in Common Domain.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA816" ;
    skos:prefLabel "Service Usage ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA827> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA813> ;
    skos:definition "The Resource Facing Service Spec ABE defines the common characteristics for a set of ResourceFacingServices. This scales by enabling multiple ResourceFacingServiceSpecs to be defined to model the common characteristics of different groups of ResourceFacingServices.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA827" ;
    skos:prefLabel "Resource Facing Service Spec ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA830> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA806> ;
    skos:definition "The Service ABE contains entities that are used to represent two fundamentally different types of Services, called CustomerFacingServices and ResourceFacingServices.<br/><br/><br/><br/>A CustomerFacingService defines the characteristics of a particular Service that represents a realization of a Product within an organization's infrastructure. In contrast, a ResourceFacingService is an abstraction that defines the characteristics of a particular Service which support the network/infrastructure facing part of the service. For example, a VPN is an example of a CustomerFacingService, while the sub-services that perform different types of routing between network devices making up the VPN are examples of ResourceFacingServices. ResourceFacingServices are \"internal\" Services that are required to support a CustomerFacingService.<br/><br/><br/><br/>Entities in this ABE provide different views to examine, analyze, configure, monitor and repair Services of all types. Entities in this ABE are derived from Service Specification entities.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA830" ;
    skos:prefLabel "Resource Facing Service ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA10_EA2_EA2_EA5253> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA10_EA2_EA5236> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA10_EA2_EA2_EA5253" ;
    skos:prefLabel "Performance Production ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6139> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6105> ;
    skos:definition "BusinessRuleArea describe where a set of BusinesslRule apply, including Processes, Data, Systems, and Stakeholders. It includes details such as the area's ID, name, description, validity period, associated business rule group ID, and creation date.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA18_EA1_EA6139" ;
    skos:prefLabel "BusinessRuleArea"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA1_EA2_EA1145> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA3_EA1_EA1110> ;
    skos:definition "Sales Lead ABE provides the ability to track sales leads through their lifecycle up until the time the prospect becomes a customer.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA3_EA1_EA2_EA1145" ;
    skos:prefLabel "Sales Lead ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA3_EA1_EA1316> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA3_EA1287> ;
    skos:definition "The Applied Customer Billing Rate Spec ABE is detailed description of AppliedCustomerBillingRate entity.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA4_EA3_EA1_EA1316" ;
    skos:prefLabel "Applied Customer Billing Rate Spec ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA2_EA3_EA1593> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA2_EA1529> ;
    skos:definition "The Network Product Spec ABE contains the NetworkProductSpec description and relationships.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA2_EA3_EA1593" ;
    skos:prefLabel "Network Product Spec ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA11_EA2367> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA2023> ;
    skos:definition "The <b>Service Problem ABE</b> manages faults, alarms, and outages from a Service point-of-view. This is then correlated to trouble tickets, regardless of whether the cause is physical or logical.<br/><br/>Other entities in this ABE are used to direct the recovery from each of these types of problems. They provide the ability to associate Resource faults and alarms to degradation and outages of Services that run on those Resources.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA6_EA11_EA2367" ;
    skos:prefLabel "Service Problem ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA1_EA2042> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA2023> ;
    skos:definition "The Service domain represents roles, information and activities carried out by parties (e.g. individuals / organizations) playing roles that are involved in the strategic planning, definition, development and operational aspects of Services that are used to realize Product offerings to the market. Activities include management of: strategies, capabilities, lifecycles, catalogs, inventories, installations, activations, problems, performance, guiding, mediation, usage statistics and support of customer-facing services that are offered to customers and resource-facing services that are presented to resources by an enterprise.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA6_EA1_EA2042" ;
    skos:prefLabel "Service Domain Overviews"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA3_EA1_EA2_EA2128> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA3_EA1_EA2110> ;
    skos:definition "The Customer Facing Service Spec Role ABE defines a ServiceSpecification, in terms of a set of ServiceSpecificationRoles, for a CustomerFacingService. It is used to represent the shared characteristics of a CustomerFacingService. This enables the CustomerFacingService to be managed abstractly using ServiceSpecificationRoles. It also helps define a CustomerFacingServiceSpecification in terms of the functions that it has or provides.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA6_EA3_EA1_EA2_EA2128" ;
    skos:prefLabel "Customer Facing Service Spec Role ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA3_EA1_EA3_EA2132> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA3_EA1_EA2110> ;
    skos:definition "The Network Service Spec ABE contains the NetworkServiceSpec description and relationships.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA6_EA3_EA1_EA3_EA2132" ;
    skos:prefLabel "Network Service Spec ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA3_EA2_EA1_EA2168> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA3_EA2_EA2158> ;
    skos:definition "The Resource Facing Service Spec Role ABE defines a ServiceSpecification, in terms of a set of ServiceSpecificationRoles, for a ResourceFacingService. It is used to represent the shared characteristics of a ResourceFacingService. This enables the ResourceFacingService to be managed abstractly using ServiceSpecificationRoles. It also helps define a ResourceFacingServiceSpecification in terms of the functions that it has or provides.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA6_EA3_EA2_EA1_EA2168" ;
    skos:prefLabel "Resource Facing Service Spec Role ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA4_EA1_EA1_EA2231> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA4_EA1_EA2220> ;
    skos:definition "The Customer Facing Service Example ABE contains an example CustomerFacingService entity.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA6_EA4_EA1_EA1_EA2231" ;
    skos:prefLabel "Customer Facing Service Example ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA4_EA1_EA3_EA2237> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA4_EA1_EA2220> ;
    skos:definition "The Network Service ABE contains the NetworkService description and relationships.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA6_EA4_EA1_EA3_EA2237" ;
    skos:prefLabel "Network Service ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA4_EA2_EA2_EA2267> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA4_EA2_EA2250> ;
    skos:definition "The Resource Facing Service Role ABE defines ResourceServiceRoles that are used to represent the variable characteristics of a ResourceFacingService in terms of roles that this type of Service plays.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA6_EA4_EA2_EA2_EA2267" ;
    skos:prefLabel "Resource Facing Service Role ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA7_EA1_EA2304> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA7_EA2296> ;
    skos:definition "<span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);font-family:Arial;font-size:13px;\"><span style=\"-webkit-text-stroke-width:0px;display:inline !important;float:none;font-style:normal;font-variant-caps:normal;font-variant-ligatures:normal;font-weight:400;letter-spacing:normal;orphans:2;text-align:start;text-decoration-color:initial;text-decoration-style:initial;text-decoration-thickness:initial;text-indent:0px;text-transform:none;white-space:normal;widows:2;word-spacing:0px;\">The Service Usage Specification ABE specifies types and characteristics of usage of ServiceSpecifications.</span></span><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA6_EA7_EA1_EA2304" ;
    skos:prefLabel "Service Usage Specification ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA7_EA2_EA2308> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA7_EA2296> ;
    skos:definition "<span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);font-family:Arial;font-size:13px;\"><span style=\"-webkit-text-stroke-width:0px;display:inline !important;float:none;font-style:normal;font-variant-caps:normal;font-variant-ligatures:normal;font-weight:400;letter-spacing:normal;orphans:2;text-align:start;text-decoration-color:initial;text-decoration-style:initial;text-decoration-thickness:initial;text-indent:0px;text-transform:none;white-space:normal;widows:2;word-spacing:0px;\">The Service Usage Entity ABE collects service usage information, and generates ServiceUsage according to ServiceUsageSpecification for use by other business entities.</span></span><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA6_EA7_EA2_EA2308" ;
    skos:prefLabel "Service Usage Entity ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA9_EA2_EA2352> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA9_EA2331> ;
    skos:definition "The Service Performance Specification ABE defines measure of the manner in which a Service is functioning.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA6_EA9_EA2_EA2352" ;
    skos:prefLabel "Service Performance Specification ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA11_EA3384> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2391> ;
    skos:definition "The<b> Resource Trouble ABE</b> collects information about problems found in allocated resource instances, regardless of whether the problem is physical or logical. Entities in this ABE capture detection, root cause, and resoluiton of these problems and maintain a history of the activities involved in diagnosing and solving the problem. This history includes tracking, reporting, assigning people to fix the problem, testing and verification, and overall administration of repair activities.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA11_EA3384" ;
    skos:prefLabel "Resource Trouble ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA3_EA2_EA2599> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA3_EA2546> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA2_EA3_EA2_EA2599" ;
    skos:prefLabel "Logical Role Specification ABE"@en .

