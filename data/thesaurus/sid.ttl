<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA7072> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA7071> ;
    skos:definition "Administrative Area represents the many areas that are controlled or managed by an Administration. Administrations could include councils, governments …<br/><br/>This is an example of a concrete Geographic Location entity.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA1_EA7072" ;
    skos:prefLabel "AdministrativeArea"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA7073> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA7071> ;
    skos:definition "This is an example of a concrete Geographic Location entity.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA1_EA7073" ;
    skos:prefLabel "Country"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA7074> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA7071> ;
    skos:definition "A geographic loaction, typically a building, used to house the inside plant equipment of potentially several telephone exchanges, each serving a certain geographical exchange area.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA1_EA7074" ;
    skos:prefLabel "ExchangeLocation"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA7075> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA7071> ;
    skos:definition "A region or part of a town, a country, or the world that is served by an exchange.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA1_EA7075" ;
    skos:prefLabel "ExchangeServiceArea"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA7077> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA7071> ;
    skos:definition "This is a generic entity, used to represent areas defined on maps that relate to areas of settlement.This is an example of a concrete Geographic Location entity.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA1_EA7077" ;
    skos:prefLabel "GeographicArea"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA7078> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA7071> ;
    skos:definition "A defined place on or near the earth's surface. It is an abstract modeling concept that provides a linking point to other parts of the SID model.It holds attributes common to all Geographic Location subclasses.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA1_EA7078" ;
    skos:prefLabel "GeographicLocation"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA7079> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA7071> ;
    skos:definition "A word, term, or phrase by which a Geographic Location is known and distinguished from other Geographic Locations. A name is an informal way of identifying an object [Fowler]Separating Location Name from Location allows for a Location to have many names at the same time and for names to change over time.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA1_EA7079" ;
    skos:prefLabel "GeographicLocationName"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA7080> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA7071> ;
    skos:definition "This association allows us to show direct relationships between Geographic Locations.This should be used with care to ensure that the association reflects reality<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA1_EA7080" ;
    skos:prefLabel "GeographicLocationRelationship"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA7081> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA7071> ;
    skos:definition "This is a simple specification entity used to provide a list of allowable geographic location types. These types correspond to the concrete entity names shown on fig 10a<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA1_EA7081" ;
    skos:prefLabel "GeographicLocationType"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA7082> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA7071> ;
    skos:definition "Allows us to determine where things are in relation to the earth's surface.<br/><br/>It is an abstract modeling concept that provides a linking point to other parts of the SID model.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA1_EA7082" ;
    skos:prefLabel "GeographicPlace"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA7083> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA7071> ;
