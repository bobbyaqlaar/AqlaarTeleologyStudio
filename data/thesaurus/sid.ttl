<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA5048> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA5032> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA9_EA5048" ;
    skos:prefLabel "EARoot_EA4_EA2_EA10_EA9_EA5048"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA5049> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA5032> ;
    skos:definition "These 2 associations are mutually exclusive.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA9_EA5049" ;
    skos:prefLabel "EARoot_EA4_EA2_EA10_EA9_EA5049"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA5_EA5140> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA5_EA5142> ;
    skos:definition "<font color=\"#29313b\">Following are business entities aggregated under the <b>Metric Measure </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA9_EA5_EA5140" ;
    skos:prefLabel "Figure MM.01 - Metric Measure ABE Related ABEs"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA5_EA5143> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA5_EA5142> ;
    skos:definition "A communication that occurs as part of a MetricMeasureConsquence to inform about a MetricDefMeasureThresholdRule being crossed.<br/><br/>A Notification is typically one-sided, in that no Response is expected.<br/><br/>For example, a notification might be sent to a supervisor and another one to a technician as the result of a MetricDefMeasureThresholdRule fixing the limits of lost packets, being crossed. Each ConsequenceMetricNotification will include the value of the MetricMeasure and other information according to the scope of interest from the supervisor and the technician.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA9_EA5_EA5143" ;
    skos:prefLabel "ConsequenceMetricNotification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA5_EA5144> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA5_EA5142> ;
    skos:definition "A numerical value or text determined for a MetricDefMeasure that may be collected for a RootEntity, such as a connection or a dealer.<br/><br/>A MetricMeasure might be part of a group of MetricMeasures realized at a specific moment (MetricMeasureGroup).<br/><br/>For example, a value of .005 ms that represents average packet delay.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA9_EA5_EA5144" ;
    skos:prefLabel "MetricMeasure"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA5_EA5145> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA5_EA5142> ;
    skos:definition "A MetricMeasureConsequence is the MetricDefMeasureConsequence applied for a specific MetricMeasureThresholdRule.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA9_EA5_EA5145" ;
    skos:prefLabel "MetricMeasureConsequence"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA5_EA5146> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA5_EA5142> ;
    skos:definition "A MetricMeasureGroup is a set of MetricMeasures, usually reported in the same message by the equipment or the EMS.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA9_EA5_EA5146" ;
    skos:prefLabel "MetricMeasureGroup"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA5_EA5147> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA5_EA5142> ;
    skos:definition "A MetricMeasureThresholdRule specifies the MetricDefMeasureThresholdRule whose threshold has been crossed by a MetricMeasure.<br/><br/>It triggers one or more MetricMeasureConsequences.<br/><br/>For example, the prescribed action (prescribedAction attribute) by a consequence might be to monitor the MetricMeasure more closely or to notify a specific person.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA9_EA5_EA5147" ;
    skos:prefLabel "MetricMeasureThresholdRule"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA6_EA1_EA5157> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA6_EA1_EA5159> ;
    skos:definition "<font color=\"#29313b\">Following are business entities aggregated under the <b>Metric Collection </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA9_EA6_EA1_EA5157" ;
    skos:prefLabel "Figure MC.01 - Metric Collection ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA6_EA1_EA5160> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA6_EA1_EA5159> ;
    skos:definition "A job for collecting MetricMeasures produced by another job to make available MetricMeasures for subscribers.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA9_EA6_EA1_EA5160" ;
    skos:prefLabel "AdhocMetricCollection"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA6_EA1_EA5161> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA6_EA1_EA5159> ;
    skos:definition "A job for collecting MetricMeasures produced by another job to make available MetricMeasures for subscribers.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA9_EA6_EA1_EA5161" ;
    skos:prefLabel "MetricMeasurementCollectionJob"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA6_EA2_EA5162> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA6_EA2_EA5164> ;
    skos:definition "<font color=\"#29313b\">Following are business entities aggregated under the <b>Metric Job </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA9_EA6_EA2_EA5162" ;
    skos:prefLabel "Figure MJ.01 - Metric Job ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA6_EA2_EA5165> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA6_EA2_EA5164> ;
    skos:definition "A MetricManagementJob is a management activity that may consist of several steps but is performed as a single logical unit in a Metric context.<br/><br/>It can be a one-time activity or a regular one. In the latter case, a schedule definition is attached to it.<br/><br/>A MetricMeasurementJob defines a measurement job for a scope of monitored objects using the MonitoredMetricObjectCriterion.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA9_EA6_EA2_EA5165" ;
    skos:prefLabel "MetricMeasurementJob"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA6_EA2_EA5166> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA6_EA2_EA5164> ;
    skos:definition "A job for producing (gathering raw data or calculating data) MetricMeasures according to a MetricDefMeasure.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA9_EA6_EA2_EA5166" ;
    skos:prefLabel "MetricMeasurementProductionJob"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA6_EA2_EA5167> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA6_EA2_EA5164> ;
    skos:definition "A job for evaluating thresholds defined over MetricDefMeasure.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA9_EA6_EA2_EA5167" ;
    skos:prefLabel "MetricMeasurementThresholdJob"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA6_EA5148> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA6_EA5150> ;
    skos:definition "<font color=\"#29313b\">Following are business entities aggregated under the <b>Metric Monitoring </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA9_EA6_EA5148" ;
    skos:prefLabel "Figure MM.01 - Metric Monitoring ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA6_EA5153> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA6_EA5150> ;
    skos:definition "A MetricMeasurementObservation represents the contextual information of a measurement such as the observation period, the MetricMeasurementJob used, the requester of the observation and the scope of the observation through the related MonitoredMetricObjectCriterion.<br/><br/>The MonitoredMetricObjectCriterion related to MetricMeasurementObservation has to be equal to or a sub-set of the one related to the concerned MetricMeasurementJob.<br/><br/>A MetricMeasurementObservation also specifies the MectricMeasures resulting from this observation.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA9_EA6_EA5153" ;
    skos:prefLabel "MetricMeasurementObservation"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA6_EA5154> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA6_EA5150> ;
    skos:definition "A MonitoredMetricClassCriterion is a type of MonitoredMetricObjectCriterion.<br/><br/>It defines the scope of monitored objects for which a MeasurementJob is executed.by a filter on a class through the relationship with RootEntityType.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA9_EA6_EA5154" ;
    skos:prefLabel "MonitoredMetricClassCriterion"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA6_EA5155> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA6_EA5150> ;
    skos:definition "A MonitoredMetricInstanceCriteripn is a type of MonitoredMetricObjectCriterion.<br/><br/>It defines the scope of monitored objects for which a MeasurementJob is executed by a list of instances through the relationship with one or several RootEntity instances.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA9_EA6_EA5155" ;
    skos:prefLabel "MonitoredMetricInstanceCriterion"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA6_EA5156> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA6_EA5150> ;
    skos:definition "A MonitoredMetricObjectCriterion defines the scope of monitored objects for which a MeasurementJob is executed.<br/><br/>The scope is either defined:<br/><br/>• by a filter on a Class (sub-class MonitoredMetricClassCriterion) <br/><br/>• or by a list of instances (sub-class MonitoredMetricInstanceCriterion).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA9_EA6_EA5156" ;
    skos:prefLabel "MonitoredMetricObjectCriterion"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA10_EA6669> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA10_EA6671> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Skill </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA10_EA6669" ;
    skos:prefLabel "Figure Sk.01 - Skill ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA10_EA6672> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA10_EA6671> ;
    skos:definition "The ability, coming from one's knowledge, practice, aptitude, and so forth to do something well.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA10_EA6672" ;
    skos:prefLabel "Skill"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA10_EA6673> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA10_EA6671> ;
    skos:definition "A complete list of SkillSpecifications, typically one in alphabetical or other systematic order, on particular subject.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA10_EA6673" ;
    skos:prefLabel "SkillCatalog"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA10_EA6674> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA10_EA6671> ;
    skos:definition "The definition of a Skill.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA10_EA6674" ;
    skos:prefLabel "SkillSpecification"@en .

