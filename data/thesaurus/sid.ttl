    skos:definition "The RootEntityGroupMemeberExpression defines part of a mathematical expression composed of variables (represented by the members), operators, and delimiters. For example \"(memberA or\", \"memberB}\"<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA6_EA4600" ;
    skos:prefLabel "RootEntityGroupMemberExpression"@en .

