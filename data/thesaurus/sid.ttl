    skos:notation "sid:EARoot_EA4_EA2_EA11_EA4_EA2_EA6780" ;
    skos:prefLabel "CashPM"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA2_EA6781> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA2_EA6777> ;
    skos:definition "Pay with a check.<br/>"@en ;
    skos:inScheme thes:sid ;
