    skos:prefLabel "RootEntityGroupRelationship"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA3_EA4602> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA3_EA4604> ;
    skos:definition "An Account specifies basic attributes and relationships that describe an account.<br/>An Account aims to register all Credits and Debits according to criteria. It carries one or many Balances (results of Credits and Debits) and might use one or many Currencies.<br/>Each Account is possessed by one or many PartyRoles such as the Holder or the Payer of a CustomerBillingAccount.<br/>Each Account might be related to other Accounts such as a parent / child relationship.<br/>BusinessPartnerAccount, CustomerBillingAccount and FinancialAccount are types of Account.<br/>A BusinessPartnerAccount and CustomerBillingAccount carries additional information (such as creditLimit) and have specific relationships.<br/>A FinancialAccount is part of the sub-ledger accounting that aggregates the amounts of one or more business partner and / or Customer accounts owned by a given party. It’s an internal view of the CSP to manage incomes and outcomes.<br/>Each accounting event from a BusinessPartnerAccount or CustomerBillingAccount is logged to a FinancialAccount according to the assignment rules specified by BsuinessPartnerAccountAssignment and CustomerBillingAccountAssignment.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA3_EA4602" ;
    skos:prefLabel "Figure Acc.01 - Account Overview"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA3_EA4605> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA3_EA4604> ;
    skos:definition "An Account specifies basic attributes and relationships that describes an account.<br/><br/>An Account aims to register all Credits and Debits according to criteria. It carries one or many Balances (results of Credits and Debits) and might use one or many Currencies.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA3_EA4605" ;
    skos:prefLabel "Account"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA3_EA4606> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA3_EA4604> ;
    skos:definition "AccountBalance represents and tracks debits and credits applied to an Account for a period.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA3_EA4606" ;
    skos:prefLabel "AccountBalance"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA3_EA4607> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA3_EA4604> ;
    skos:definition "AccountBalanceType describes and defines certain type of AccountBalance.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA3_EA4607" ;
    skos:prefLabel "AccountBalanceType"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA3_EA4608> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA3_EA4604> ;
    skos:definition "An individual or organization used as a contact point for an Account and accessed via some contact medium. The contact may be a member of the party’s organization or a member of some other enterprise, such as the provider who services the Account.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA3_EA4608" ;
    skos:prefLabel "AccountContact"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA3_EA4609> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA3_EA4604> ;
    skos:definition "AccountCurrency represents the currency that might be used for the Account. One of them specifies the default Currency used.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA3_EA4609" ;
    skos:prefLabel "AccountCurrency"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA3_EA4610> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA3_EA4604> ;
    skos:definition "A significant connection between two Accounts.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA3_EA4610" ;
    skos:prefLabel "AccountRelationship"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4194> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4200> ;
    skos:definition "The diagram below lists the Pattern Domain's ABEs. <br/><b>Base Types ABE</b><br/><ul><li>The Base Types ABE contains entities used for defining complex types of attributes like money or a date range.</li></ul><b>Root Business Entities ABE</b><br/><ul><li>The Root Business Entities ABE contains a set of common business entities that collectively serve as the foundation of the Information Framework. This set of abstract superclasses and associations provide a basis for entities in other domains of the SID Framework as well as entity interrelationships, providing greater overall coherence to the Information Framework.</li><li>In addition, this ABE contains some Basic Patterns such as Entity / Entity Specification, Entity / Entity Role and Characteristic Specification / Characteristic Value.</li></ul><b>Account ABE</b><br/><ul><li>The Account ABE contains all entities needed for specifying basic attributes and relationships that describe an account.</li></ul><b>Business Interaction ABE</b><br/><ul><li>The Business Interaction ABE represents an arrangement, contract, or communication between an enterprise and one or more other entities such as individuals and organizations (or parts of organizations). Business Interactions take on the form of requests, responses, and notifications.</li></ul><b>Agreement ABE</b><br/><ul><li>An Agreement represents a contract or arrangement, either written or verbal and sometimes enforceable by law, such as a service level agreement or a customer price agreement. An agreement involves a number of other business entities, such as products, services, and resources and/or their specifications.</li></ul><b>Capacity ABE</b><br/><ul><li>The Capacity ABE describes a pattern for specifying capacity and capacity demand from an Entity. This pattern is used for Products, Services, and Resources.</li><li>Capacity is the ability to provide some capability. For example, one measure of network capacity is the ability of a network to provide a certain amount of bandwidth during the month of May.</li></ul><b>Catalog ABE</b><br/><ul><li>The Catalog ABE is a pattern that represents common Catalog Specification and Catalog entities, attributes, and associations shared (inherited) by components of the Entity, Federated, Product, Service, and Resource Catalog ABEs.</li></ul><b>Configuration and Profiling ABE</b><br/><ul><li>The Configuration and Profiling ABE is a pattern that represents the specification of the different possible configurations of an Entity as well as the Entity Configurations instantiated for an Entity.</li><li>This pattern provides a flexible dynamic basis for the configuration of products, services, and resources, as well as the interrelationships between these entities.</li></ul><b>Cost ABE</b> <br/><ul><li>The Cost ABE represents a set of information that captures the expense needed to be spent by the service provider to acquire, execute, produce, activate, operate or qualify any entity (project, service, product, resource etc). It encompasses the amount of money needed in various aspects of a telco's business processes</li></ul><b>Metric ABE</b><br/><ul><li>The Metric ABE specifies measurements definitions including units and values and how the values are determined.</li><li>It also includes thresholds used to evaluate the metric and the consequences of violating the thresholds. It also contains the results of measurements.</li></ul><b>Performance ABE</b><br/><ul><li>The Performance ABE is a pattern that represents a measure of the manner in which a Product and/or Service and/or Resource is functioning.</li></ul><b>Policy ABE</b><br/><ul><li>The Policy ABE represents specification of Policy (i.e. set of Policy Rules) as well as Policy Entities. It also carries information needed for managing Policies and tracking Policy application.</li></ul><b>Project ABE</b><br/><ul><li>The Project ABE represents the tools used by project managers to ensure that enterprise objectives of quality, cost and time are achieved by planning and scheduling work. It uses common industry definitions of Project, Work Breakdown Structure and Activity to provide support to project managers.</li></ul><b>Test ABE</b><br/><ul><li>The Test ABE carries all information specifying Test and the Test results. The Test ABE corresponds to a pattern that can be applied in several Domains such as Service Test ABE in the Service Domain.</li></ul><b>Usage ABE</b><br/><ul><li>The Usage ABE contains all the Entities to define Usages types specifying a type of employment of an Entity and track their records. The Usage ABE pattern can be applied in several Domains such as Product Usage ABE in the Product Domain. For example, Product Usage Specification enables describing different types of usages enabled by a type of Product such as SMS, MMS, Voice call... enabled by a Mobile Line Product Specification.</li></ul><b>Segmentation ABE</b><br/><ul><li>The Segmentation ABE contains all entities used for specifying rules to divide a large set of Entities instances into subsets according to criteria. These subsets are called segments.</li></ul><b>Intent ABE</b><br/><ul><li>The Intent ABE contains the entities needed for specifying basic attributes and relationships that describe an Intent.</li></ul><b>Closed Loop ABE</b><br/><ul><li><font color=\"#29313b\">The Closed Loop ABE describes a \"management framework\" in which current outcomes are used to improve future outcomes in order to achieve specified goals. The management framework includes the feedforward workflow and a feedback workflow, where the feedforward is a control loop meant to continually optimize and improve</font></li></ul><b>Goal ABE (Preliminary)</b><br/><ul><li>Goal ABE represents a set of information that captures the definition of a goal or target for a process (task/activity/workflow/etc.) to reach or achieve.</li></ul><font color=\"#29313b\"><b>Workflow ABE </b></font><b>(Preliminary)</b><br/><ul><li>A Workflow represents a set of business activities orchestrated together based on a set of goals/objectives and specific partyRoles that collectively through them a piece of work passes from initiation to completion. A workflow ties business activities together in sequence to enable realize specified objectives.</li><li>The Workflow ABE contains all information enabling the definition of Workflow Specifications and Workflows.</li></ul><b>Anomaly ABE</b><br/><ul><li>Anomaly ABE represents any unusual or unexpected event, observation, pattern, or item that is significantly different from the norm that an enterprise wishes to detect, analyze, assess and mitigate within an autonomous environment.</li></ul><b>Topology ABE (Preliminary)</b><br/><ul><li>The Topology ABE enables specifying Graphs and their instantiation.</li><li>Graphs are mathematical structures used to model pairwise relations between objects. A graph in this context is made up of Vertices (also called nodes or points) which are connected by Edges (also called arcs, links or lines) [ ref graph theory - Wikipedia ].</li></ul><b>Maturity Model (Preliminary)</b><br/><ul><li>The Maturity Model ABE is the focus of all maturity models, maturity model levels, model assessment structure, and the embodiment of the maturity models capabilities for the topic of capability maturity.</li></ul><b>Event ABE (not fully developed)</b><br/><ul><li>The Event ABE contains entities that are used to represent events, their occurrence and their recording within systems.</li></ul><b>Trouble Ticket ABE (not fully developed)</b><br/><ul><li>Trouble Ticket ABE represents a record used for reporting and managing the resolution of Trouble or Problem..</li></ul><b>Trouble or Problem ABE (not fully developed)</b><br/><ul><li>Trouble or Problem ABE collects all information describing a problem that can be shared between several PartyRoles such as the service provider and the customer. Trouble or Problem is an indication that an entity (such as Resource, Service or Product) is no longer functioning according to the expected SLA.</li></ul><p/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4194" ;
    skos:prefLabel "[PatternD-01] Pattern ABEs Level 1"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4196> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4200> ;
    skos:definition "The diagram below lists the Pattern Domain's ABEs Level 1 and 2.<br/><br/><b>Entity Catalog ABE</b><br/><ul><li>The Entity Catalog ABE represents specifications and entities and their attributes, and associations for EntityCatalogSpecification, FederatedCatalogSpecification, EntityCatalog, and FederatedCatalog.</li></ul><b>Commitment ABE</b><br/><ul><li>The Commitment ABE, derived from the Business Interaction ABE, reflects the mutual agreement between parties about services, products, resources or some other kind of deliverable that has to be provided by the party playing the role of a Commitment fulfiller to the party, playing the role of a Commitment procurer.</li></ul><b>Association ABE</b><br/><ul><li>Association ABE contains a pattern that enables associations to be dynamically created between explicitly modeled SID entities (classes and subclasses) as well as implicit subclasses created using the EntitySpecification/Entity pattern.</li></ul><b>Entity Identification ABE</b><br/><ul><li>Entity Identification ABE contains a collection of entities that can be used to dynamically specify various identification formats for any type of entity and to represent identification instances associated with entities.</li></ul><b>Root Entity Group ABE</b><br/><ul><li>The Root Entity Group ABE enables groups of Root Entities to be related as an alternate to using the RootEntityRelationship entity in order to reduce the number of instances of RootEntityRelationship. It also enables choices of Root Entities to be made from the group. For example, choose 3 out of 7 channel packs. And, to define expressions that constrain Root Entity members of a group. For example, either channel pack 3 or channel pack 4 can be chosen, but not both.</li></ul><b>Characteristic ABE</b><br/><ul><li>Characteristic ABE contains a pattern that enables attributes unique to a type of entity to be created via its association to EntitySpecification and enables attributes unique to a certain entity to be created via its association to RootEntityType. A RootEntityType is an entity in the SID. For example, characteristics could be defined for entities (instances of RootEntityType) such as Product, Customer, and ProductSpecification that apply to all instances of those entities.</li></ul><b>Entity Specification Action ABE</b><br/><ul><li>Entity Specification Action ABE contains a collection of entities that can be used to define related entity specification actions and workflows.</li></ul><b>External System Capability ABE</b><br/><ul><li>External System Capability ABE contains a collection of entities that can be used to define external system capabilities like fulfillment, charging, assurance, policy and billing.</li></ul><b>All Project ABE sub-ABEs have no description</b><br/><b>Usage Specification ABE</b><br/><ul><li>The Usage Specification ABE specifies usage in a generic way and its related characteristics.</li></ul><b>Usage Entity ABE</b><br/><ul><li>The Usage Entity ABE collects consumption information, and generates Usage according to UsageSpecification for use by other business entities.</li></ul><b>IP Detail Record ABE</b><br/><ul><li>no description</li></ul><b>Metric Definition ABE</b><br/><ul><li>The Metric Definition ABE contains the main entities describing a MetricDefinition such as MetricDefinition itself, MetricDefinitionCategory and MetricDefinitionDimension.</li></ul><b>Metric Definition Measure ABE</b><br/><ul><li>The MetricDefMeasure specifies a measure of a specific aspect of an entity and is the main part of a MetricDefinition.</li><li>The Metric Definition Measure ABE contains all entities describing the MetricDefMeasure such as the related threshold, notification and consequence.</li></ul><b>Metric Monitoring ABE</b><br/><ul><li>The Metric Monitoring ABE contains all entities enabling the monitoring of MetricMeasures such as MetricMeasurementJob.</li></ul><b>Metric Measure ABE</b><br/><ul><li>The Metric Measure ABE contains entities describing measures according to a MetricDefMeasure such as MetricMeasure.</li></ul><b>All Performance ABE sub-ABEs have no description</b><br/><b>Policy Structure ABE</b><br/><ul><li>The Policy Structure ABE contains entities that are used to represent the various components of a Policy. These components center around the concept of a PolicyRule, which is a triplet defined as {event, condition, action}</li><li>This has the semantics of: \"ON receipt of an event, IF the condition clause is TRUE, THEN execute a set of actions.</li></ul><b>Policy Management ABE</b><br/><ul><li>The Policy Management ABE contains entities that are used to manage other entities in other Domains. This includes entities from other Common Business Entities sub-domains (e.g., Location and Party) as well as other sibling Domains (e.g., Product, Service and Resource).</li></ul><b>Policy Framework Spec ABE</b><br/><ul><li>The Policy Framework Spec ABE contains entities that define the invariant characteristics and behavior of policy entities. This enables multiple instances to be derived from a single specification entity. In this derivation, each instance will use the invariant characteristics and behavior defined in its associated template.</li></ul><b>Policy Application ABE</b><br/><ul><li>Th<b>e</b> Policy Application ABE defines concepts and application components that can use policy entities to manage the behavior and configuration of other entities. This consists of entities to provide policy decision-making capabilities, as well as entities to enforce and execute policies. It also includes entities required to build an NGOSS policy system. These include entities to coordinate management and usage aspects of policy as well as entities to enable policy components to scale to large distributed systems.</li></ul><b>Anomaly Specification ABE</b><br/><ul><li>The Anomaly Specification ABE contains entities that are used to define the shared characteristics and behavior of Anomaly entities associated with Product, Service and Resource. It also includes related entities that specify the characteristic of grouping, categorization, indicators, and applicability of the Anomaly.</li></ul><b>Anomaly Entity ABE</b><br/><ul><li>The Anomaly Entity ABE contains entities that are used to represent the various aspects of an Anomaly. This includes Product, Service, and Resource Anomalies as well as entities for concepts such as anomaly categorization, grouping, indicators, thresholds, consequences, reporting and notification.</li></ul><b>Maturity Model Specification</b><br/><ul><li>The Maturity Model Specification ABE contains all what represent a Maturity Model specification as perceived by the capability assessment relevant to specify what the function or organization wants to evaluate as representation of being performant.</li></ul><b>Maturity Model Entity</b><br/><ul><li>The Maturity Model Entity represents the structure framework used to assess the maturity of an entity.</li></ul><p/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4196" ;
    skos:prefLabel "[PatternD-02] Pattern ABEs Level 1 & 2"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4198> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4200> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4198" ;
    skos:prefLabel "Common Kanban"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4201> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4200> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4201" ;
    skos:prefLabel "Rule"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4225> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4200> ;
    skos:definition "<b>Trouble or Problem ABE</b> collects all information describing a problem that can be shared between several PartyRoles such as the service provider and the customer. Trouble or Problem is an indication that an entity (such as Resource, Service or Product) is no longer functioning according to the expected SLA.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4225" ;
    skos:prefLabel "Trouble or Problem ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA1_EA4670> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA1_EA4672> ;
    skos:definition "<font color=\"#29313b\">Following are business entities aggregated under the <b>Disputed Amount </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA1_EA4670" ;
    skos:prefLabel "Figure DA.01 - Disputed Amount ABE Related Business Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA1_EA4673> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA1_EA4672> ;
    skos:definition "This entity represents the state of acceptance (completely or partially) of the DisputedAmount by the enterprise<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA1_EA4673" ;
    skos:prefLabel "DAAAccepted"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA1_EA4674> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA1_EA4672> ;
    skos:definition "This entity represents the state of cancelation of the DisputedAmount by the Customer<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA1_EA4674" ;
    skos:prefLabel "DAACancelled"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA1_EA4675> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA1_EA4672> ;
    skos:definition "This entity represents the completion of the DisputedAmount lifecycle.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA1_EA4675" ;
    skos:prefLabel "DAACompleted"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA1_EA4676> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA1_EA4672> ;
    skos:definition "This entity represents the creation of DisputedAmount<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA1_EA4676" ;
    skos:prefLabel "DAACreated"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA1_EA4677> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA1_EA4672> ;
    skos:definition "This entity represents the state of rejection of the DisputedAmount by the enterprise<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA1_EA4677" ;
    skos:prefLabel "DAARejected"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA1_EA4678> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA1_EA4672> ;
    skos:definition "This entity represents a request by an external party (Customer or Supplier/Partner) to change the amount it is required to pay the enterprise. The amount in disagreement is being in dispute, and may be handled differently from financial aspects (for example, an amount in dispute may not be target to late payment fees calculations or being considered as part of collection calculations)<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA1_EA4678" ;
    skos:prefLabel "DisputedAmount"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA1_EA4679> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA1_EA4672> ;
    skos:definition "This is an abstract base class for the different states in the DisputedAmount lifecycle<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA1_EA4679" ;
    skos:prefLabel "DisputedAmountActivity"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4611> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "In the course of doing business a service provider interacts with other entities such as individuals and organizations (or parts of organizations). Individuals and organizations are known as parties. Parties can play a number of different roles from a service provider’s perspective. A party could play the role of customer, employee, supplier, partner, and so forth. Business interactions can also involve such things as applications, intelligent devices, and other types of resources. Interactions can also involve customer accounts.<br/>Business interactions take the form of requests, responses and notifications. The figure below depicts a business interaction and its various types.<br/>The following Figure also shows that business interactions can be related to each other. For example, a request for information from an individual is followed by a response from a service provider back to the individual. The request and the response are associated with each other so that the string of related business interactions is maintained. The figure below shows this type of relationship between business interactions.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4611" ;
    skos:prefLabel "Figure BI.01 - Types of Business Interactions"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4613> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "Other types of associations can exist between business interactions. For example, a Product may be realized by configuring a number of services. A provisioning (or service) order is created for the product and associated to a number of orders that configure each of the services.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4613" ;
    skos:prefLabel "Figure BI.02 - Relationship Between Business Interactions"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4615> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "The Business Interaction ABE model employs the commonly used SID EntitySpecification/Entity pattern. Conceptually, a BusinessInteractionSpec defines the invariant attributes and relationships (and in the system view, methods and constraints as well) for defining a set of BusinessInteractions. A BusinessInteraction uses these invariant characteristics and behavior and adds instance-specific characteristics and behavior to them such that, by building from a base of standard capabilities, it becomes possible to create unique BusinessInteractions that are specifically targeted at different users, market segments, and so forth. The figure below shows the relationship between a BusinessInteractionSpec and a BusinessInteraction.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4615" ;
    skos:prefLabel "Figure BI.03 - Business Interaction Specification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4617> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "More than one version of a business interaction may exist during the interaction’s life. This is an important facet of an interaction. The figure below depicts a minimalist approach for handling interaction versions. The different versions can be linked together using the BusinessInteractionRelationship entity. Much more elaborate versioning models can be developed as needed by a user of the SID model. The figure below shows the minimalist approach to business interaction versions.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4617" ;
    skos:prefLabel "Figure BI.04 - Business Interaction Version"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4619> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "More than one business entity can be involved in an interaction. For example, Bob Smith, a business entity playing the party role of a customer, requests information about cable modem service from Joe Jones, a business entity playing the party role of a customer service representative.<br/>In some cases, the Party related to the business interaction plays a temporary role that relates only to the interaction lifecycle (for example, the person reporting a customer problem), in such cases it is possible to model a Party involvement with Business Interaction (in addition to PartyRole involvement).<br/>As stated earlier, business entities involved in an interaction can also be resources. For example,<br/>a) A soft drink machine receives an inquiry from a third-party servicing agent (or an automatic timed status report transmission from the machine) to gather data on the stock level, fault or performance data or even a cash transaction report.<br/>b) Activation instructions could be delivered to your home heating/cooling system ready for your arrival. A burglar alarm could send a video image of an intruder to a monitoring office.<br/>c) A car could have a mobile radio device to communicate with the engine management system as well as the vehicle user. This could be an extension of a personal communicator using a ‘Blue Tooth’ radio access system.<br/>Business entities involved in an interaction can also be customer accounts. For example, different products offerings involved as interaction items could be charged to one or more customer accounts.<br/>The figure below depicts the relationship that business entities have with business interactions and how the business entities party role, resource role, business partner account and customer account, are involved in business interactions.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4619" ;
    skos:prefLabel "Figure BI.05 - Business Interaction Relationships With Party Roles, Resource Roles, and Accounts"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4621> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "As described in the example above, the inquiry request type of business interaction from Bob Smith involves a product offering that is made available by a service provider. The figure below depicts the involvement that product offerings have with all types of business interactions.<br/>A number of product offerings can be involved in a business interaction. The business interaction business entity in Figure BI.06 allows for multiple items, such as product offerings, to be handled by a single instance of a business interaction.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4621" ;
    skos:prefLabel "Figure BI.06 - Relationship Between Business Interaction and Product Offering"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4623> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "Prices are often associated with product offerings involved in business interaction, such as requests for quotes, and so forth. Additionally, these prices are sometimes influenced by rules (in the form of policies) that govern product offering prices. Figure BI.07, below, shows these associations.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4623" ;
    skos:prefLabel "Figure BI.07 - Product Offering Price and Business Interaction"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4625> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "The figure below depicts the involvement that products have with all types of business interactions.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4625" ;
    skos:prefLabel "Figure BI.08 - Relationship Between Business Interaction and Product Domain Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4627> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "In addition to product offerings and products, services and resources are also the focus of in business interactions. For example, one service provider may enter into a lease agreement to use a connection belonging to another service provider; the failure of a network device may precipitate the need to send a notification communicating the need to repair the device to a technician, while another notification must be sent to the service subscribes offering an alternative product offering for use by the subscribers. The relationship that product, service, and resource business entities have with business interaction is shown in the figure below.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4627" ;
    skos:prefLabel "Figure BI.09 - Business Interaction Item Association with Product, Service, and Resource Domain Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4629> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "During the interaction, Bob Smith may also provide information about the location (referred to as a Location or Place in the SID Model) of his cable modem. Therefore, as shown in the figure below, a business interaction also can involve one or more Locations. In the SID model, locations, such as addresses, geographic areas, and geographic coordinates are collectively called Locations.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4629" ;
    skos:prefLabel "Figure BI.10 - Relationship Between Business Interaction and Location"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4631> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "In some cases, additional information is provided for the BusinessInteraction in the form of external document. Such a document can be provided by the CSP (such as a brochure or a manual) or by the Customer (such as a picture, screenshot or a report of a diagnostic software). These supporting documents are normally stored in a central document management system, and the BusinessInteraction can link to such document(s) via the Attachment entity.<br/>In summary, a business interaction involves a number of other business entities, including product offerings, products, Locations, and business participants.<br/>By using the concept of a business interaction, each of its various types, such as agreement and notification, can inherit the business interaction’s relationships, attributes and behaviors without having to explicitly show these for each type. For example, it would be quite redundant and unstable to show an agreement and a notification, and a request, and a response, and a command each participating in relationships to business participants, locations, products, services, and resources. What would happen if this was done and another type of business interaction was discovered?<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4631" ;
    skos:prefLabel "Figure BI.11 - Business Interaction and Attachments"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4633> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "DisputedAmount is modeled as type of request since it is a state in the lifecycle of a request for credit from the Customer or Supplier/Partner.<br/>Following is the model of DisputedAmount main business entities.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4633" ;
    skos:prefLabel "Figure BI.13 - DisputedAmountActivity classes modeling the DisputedAmount life cycle"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4635> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "<font color=\"#29313b\">DisputedAmount represents a business interaction in which a party (Customer or Supplier/Partner) complains about an amount it is charged for by the enterprise, and this complaint is under investigation. From financial perspective this amount is handled differently than other charges as it may not be included in Collections (dunning) calculations and in late payment fee calculations. The base class is defined here and is further refined in the appropriate domains (Customer and Supplier/Partner).</font><br/><font color=\"#29313b\">The lifecycle of disputed amount is described in the following diagram:</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4635" ;
    skos:prefLabel "Figure BI.13-I01 - DisputedAmount Lifecycle"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4637> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "<i>Note: Supplier/Partner dispute is not included here since it is not modeled in the Information Framework yet. This is a candidate for future improvement of this model.</i><br/>The modeling of the DisputedAmount state is depicted in the following diagram. Since UML does not support lifecycle modeling directly the states are modeled as subclasses of DisputedAmountActivity, which are contained by DisputedAmount.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4637" ;
    skos:prefLabel "Figure BI.14 - DisputedAmountActivity Entities Representing the DisputedAmount Life Cycle"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4639> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "DisputedAmountActivity is not a subclass of BusinssInteractionItem since it does not need all association from BusinessInteractionItem to other business entities<br/>DAARejected represents rejection by the enterprise, while DAACancelled represents cancellation of the request by the Customer.<br/>Further refinement of this model can be found in the Customer and Supplier/Partner domains.<br/>Figure BI.15 - Business Interaction Model (BusinessInteractionVersion not shown) shows the majority of the entities contained within the ABE.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4639" ;
    skos:prefLabel "Figure BI.15 - Business Interaction Model (BusinessInteractionVersion not shown)"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4641> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "The following Figure shows some of the subclasses of the Request entity.<br/>A DisputedAmount represents a request by an external party (Customer or Supplier/Partner) to change the amount it is required to pay the enterprise. CustomerDisputedAmount is a type of DisputedAmount which represents an amount of money in dispute between the enterprise and one of its customers.<br/>An InquiryRequest is a request for information such as a request for information about a statement of money owed by a customer.(CustomerBillingInquiry), or about a written record of goods or services provided and the amount charged for them, sent to a Customer as a request for payment (CustomerInvoiceInquiry) or any request for information from a Customer (CustomerInquiry).<br/>A Command is a Request that cannot be refused. Any failure to service the Command as expected is treated as an exception, meaning something is wrong and needs to be fixed.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4641" ;
    skos:prefLabel "Figure BI.16 - Request Business Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4644> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4644" ;
    skos:prefLabel "EARoot_EA4_EA2_EA10_EA4_EA4644"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4645> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "Instantiation of Party or PartyRole is mutually exclusive<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4645" ;
    skos:prefLabel "EARoot_EA4_EA2_EA10_EA4_EA4645"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4646> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "Remove Agreement from this diagram<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4646" ;
    skos:prefLabel "EARoot_EA4_EA2_EA10_EA4_EA4646"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4647> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "Remove CustomerBillingDispute from this diagram.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4647" ;
    skos:prefLabel "EARoot_EA4_EA2_EA10_EA4_EA4647"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4648> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "Remove CustomerBillingDispute from this diagram<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4648" ;
    skos:prefLabel "EARoot_EA4_EA2_EA10_EA4_EA4648"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4649> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "A BusinessInteraction may consist of one or more BusinessInteractionItems. A BusinessInteractionItem may refer to a Product, Service, Resource, or one of their specifications. A BusinessInteraction is further defined by one or more Places. One BusinessInteraction may reference another BusinessInteraction and one BusinessInteractionItem may reference another BusinessInteractionItem on the same or different BusinessInteraction.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4649" ;
    skos:prefLabel "BusinessInteraction"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4650> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "The purpose for the BusinessInteraction expressed in terms of a ProductSpecification, ProductOffering, ServiceSpecification or ResourceSpecification or may refer to a Product, Service, or Resource.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4650" ;
    skos:prefLabel "BusinessInteractionItem"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4651> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "An amount associated with a BusinessInteractionItem that is valued by the associated ProductOfferingPrice.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4651" ;
    skos:prefLabel "BusinessInteractionItemPrice"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4652> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "The BusinessInteractionItemRelationship enables specifying any kind of relationships between BusinessInteractionItemRelationship such as contains, relies on...<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4652" ;
    skos:prefLabel "BusinessInteractionItemRelationship"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4653> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "A Location involved in an interaction. For example, John R.s home address is the location where an ordered Product will be installed.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4653" ;
    skos:prefLabel "BusinessInteractionLocation"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4654> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "An association between two Interactions. For example, a Notification sent to customers affected by a problem contained on a Trouble Report; a response to a request.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4654" ;
    skos:prefLabel "BusinessInteractionRelationship"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4655> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "An entity involved in a BusinessInteraction. The entity may be a Party playing a PartyRole or a Resource playing a ResourceRole, such as a system.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4655" ;
    skos:prefLabel "BusinessInteractionRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4656> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "The invariant characteristics (attributes in the business view, and methods, constraints, relationships, and behavior in the system view) and behavior of a BusinessInteraction. This is done by optionally defining a set of BusinessInteractionSpecItems, each of which aggregates one or more other types of Specifications. This helps to ensure that different BusinessInteractions have the same basic characteristics and behavior by deriving them from the same BusinessInteractionSpec.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4656" ;
    skos:prefLabel "BusinessInteractionSpec"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4657> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "The possible types of BusinessInteractions that can occur. BusinessInteractionTypes can be with the associated BusinessParticipantTypes that can participate in a BusinessInteraction.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4657" ;
    skos:prefLabel "BusinessInteractionType"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4658> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "A record of changes made to an BusinessInteraction.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4658" ;
    skos:prefLabel "BusinessInteractionVersion"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4659> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "A BusinessPartnerAccount playing a role in a BusinessInteraction.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4659" ;
    skos:prefLabel "BusinessPartnerAccountInteractionRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4660> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "A Command is a Request that cannot be refused. Any failure to service the Command as expected is treated as an exception, meaning something is wrong and needs to be fixed.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4660" ;
    skos:prefLabel "Command"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4661> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "A BillingAccount playing a role in a BusinessInteraction.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4661" ;
    skos:prefLabel "CustomerBillingAccountInteractionRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4663> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "A Request for information.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4663" ;
    skos:prefLabel "InquiryRequest"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4664> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "A reply to a InquiryRequest.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4664" ;
    skos:prefLabel "InquiryResponse"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4665> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "A communication that informs about something that has or will happen. A Notification is typically one-sided, in that no Response is expected. A Notification can be created as the result of a Request; for example, a Trouble Report may result in Notifications being sent to affected Parties. A Notification is a type of Business Interaction.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4665" ;
    skos:prefLabel "Notification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4666> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "A Party (represented as a Party or PartyRole) playing a role in a Business Interaction. An instantiation of this class is associated either to a Party or PartRole (mutually exclusive) but not both.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4666" ;
    skos:prefLabel "PartyInteractionRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4667> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "The act of asking that something be done that typically involves a Response. Request is a type of Business Interaction.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4667" ;
    skos:prefLabel "Request"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4668> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "A Resource playing a role in a Business Interaction.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4668" ;
    skos:prefLabel "ResourceInteractionRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4669> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "A reply to a Request.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA4669" ;
    skos:prefLabel "Response"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA1_EA4815> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA1_EA4817> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Commitment </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA1_EA4815" ;
    skos:prefLabel "Figure Com.01 - Commitment ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA1_EA4818> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA1_EA4817> ;
    skos:definition "A detailed description of the mutual agreement between parties about services, products, resources or some other kind of deliverable that has to be provided by the party playing the role of a Commitment fulfiller to the party, playing the role of a Commitment procurer. A Commitment may be associated to a KPI to govern the Commitment.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA1_EA4818" ;
    skos:prefLabel "Commitment"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA1_EA4819> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA1_EA4817> ;
    skos:definition "A role a party plays when approving a commitment such as Buyer, Supplier or Partner<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA1_EA4819" ;
    skos:prefLabel "CommitmentApproverRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA1_EA4820> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA1_EA4817> ;
    skos:definition "A role a party plays in a relationship to a Commitment and in that role the party, such as a Buyer, Supplier, or Partner, has to fulfill the commitment.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA1_EA4820" ;
    skos:prefLabel "CommitmentFulfilmentRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA1_EA4821> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA1_EA4817> ;
    skos:definition "A role a party plays in a relationship to a Commitment, such as a Buyer or Supplier, and in that role the party has procured the commitment of another party playing a role.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA1_EA4821" ;
    skos:prefLabel "CommitmentProcurementRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA1_EA4822> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA1_EA4817> ;
    skos:definition "A formal term or condition to govern a commitment.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA1_EA4822" ;
    skos:prefLabel "CommitmentTermOrCondition"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4680> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "Parties (for example, Service Providers or Customers) engage themselves through an Agreement. An Agreement is a contract or arrangement, either written or verbal and sometimes enforceable by law, such as a Work Contract or an implementation agreement. An Agreement can involve a number of other business entities, such as ProductOfferingInstances, Products, Services, and/or Resources depending on Agreement specializations. This can also extend to ProductOfferingInstance, Product, Service and/or Resource specifications depending on Agreement specializations. In the SID model an Agreement is a subclass (type) of Entity.<br/>An Agreement possesses a number of attributes and relationships that are unique to it. The figure below shows the attributes unique to an Agreement. The reminder of this overview provides a glimpse of the relationships and other business entities that make up the aggregate business entity Agreement.<br/>Relationship can exist between AgreementItems. This relationship is derived from Catalog.<br/>An Agreement and an AgreementItem may be associated to Places, each Place having an AgreementLocationRole like, as examples, Agreement / AgreementItem geographical area validity, workplace location for a WorkContract…<br/>An Agreement may be formalized through several Documents.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4680" ;
    skos:prefLabel "Figure A.01 - Agreement Business Entity and main associations"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4682> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "Entities participating in an Agreement take on a number of Roles. These Roles include:<br/> • Agreement owners; those entities who have entered into an agreement, such as a Customer and a Service Provider<br/> • Agreement contacts; those entities who help with the administration of the agreement, such as emergency contacts, help desk contacts, and so forth<br/> • Agreement authorizers; those entities who are responsible for the approval of the agreement.<br/>Agreement owner, Agreement contact information, Agreement authorizers are a specific type of PartyRole.<br/>The AgreementRole business entity is shown within the context of a Agreement in the figure below.<br/>The three roles and their derivatives become enumerated values for the name attribute that characterizes the AgreementRole business entity. For example, role values could include owner, emergency contact, authorizer, and so forth.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4682" ;
    skos:prefLabel "Figure A.02 - Agreement Role"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4684> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "Authorizations of an Agreement indicate approval of the agreement. This involves more than just capturing who is the authorizer. For example, an Agreement and its versions may go through many different levels of approval. Two business entities, AgreementApproval and AgreementAuthorization, are used to model approvals in the SID model. These business entities are shown in the figure below. <br/>AgreementApproval represents the acceptance of the agreement by the owners of the Agreement. During the negotiation of the Agreement, there could be several iterations of approvals. Approval may require the involvement of a number of business Parties. Each authorized signature may be recorded electronically or by the more traditional signature. The signatureRepresentation attribute is a record of the means by which the signature was obtained, for example electronically or by hand.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4684" ;
    skos:prefLabel "Figure A.03 - Agreement Approval Business Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4686> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "AgreementSpecification is an abstract BE which allows specifying (and then refer to) different types of Agreements (work contract …) with their characteristics (terms or conditions; mandatory items, optional items…).<br/>AgreementSpecification corresponds to the set of elements that should be discussed for an Agreement between the Organization and involved third parties (example: Ethics & Compliance, Confidentiality of information, Privacy, Payment conditions, maximum level of discount, prices negotiation margin…). These different elements can be described in AgreementItemSpecification.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4686" ;
    skos:prefLabel "Figure A.05 - Agreement Specification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4688> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "This diagram shoes a first level of specialization of Agreement.<br/>An AmendmentAgreement allows changing terms or conditions defined in a previously validated version of an Agreement. It may concern any type of agreement. So, it inherits directly from Agreement.<br/>A ContractualAgreement is a type of Agreement governed by laws or any type of legal rules. A ContractualAgreement is a Contract.<br/>A NonContractualAgreement is a specific type of agreement that is not governed by laws or legal rules. It corresponds either to an informal agreement or an internal agreement.<br/>All specializations of Agreement have their corresponding Specifications.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4688" ;
    skos:prefLabel "Figure A.06 - Agreement Specialization overview"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4690> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "At this time, NonContractualAgreement is considered as a concrete BE. So, it can be used to represent some additional types of non legaly binding agreements that are not identified as subclasses. Example:<br/><ul><li>A Memory Of Understanding (MOU) is an agreement between several parties that could be in different registered companies. This type of agreement is in almost all cases non binding.</li></ul>If needed in the future versions of Information Framework, additional specialization of NonContractualAgreement may be added.<br/>An InternalAgreement is a specific type of NonContractualAgreement that can occur between two (or more) entities of the same registered company. These entities can correspond to different establishments or services in the same company.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4690" ;
    skos:prefLabel "Figure A.06a - NonContractualAgreement specialization overview"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4692> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "This figure illustrates an example of InternalAgreement.<br/>Greenfield Organization has several internal divisions. These divisions are not legal entities.<br/>Greenfield International Wholesale division needs to host several applications. Application hosting infrastructure is managed by Greenfield Germany division.<br/>Both divisions will enter into an InternalAgreement that has been formalized through an email (Document) on the 5th of June 2025.<br/>This InternalAgreement related to Greenfield International Wholesale applications hosting will have one InternalAgreementItem related to the share of Virtual Machines.<br/>Virtual Machines are described as CompoundResourceSpec.<br/>One CompoundResource (instance) will be created for each Application that requires hosting.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4692" ;
    skos:prefLabel "Figure A.06a - Illustration 01: Internal Agreement"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4694> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "ContractualAgreements are bound by terms and conditions. In addition, individual items (ContractualAgreementItems) that make up a ContractualAgreement may be bound by their own set of terms and conditions. Terms and conditions can include such things as exclusions, legal issues, and contract termination clauses. The figure below depicts the relationships that ContractualAgreements have with terms and conditions.<br/>AgreementTermsOrConditionSpecification specifies a set of Terms or conditions we may formally apply to an ContractAgreementSpecification.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4694" ;
    skos:prefLabel "Figure A.06b - ContractualAgreement Overview"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4696> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "This diagram presents the currently identified different types of ContractualAgreements.<br/>A Commitment is a detailed description of the mutual agreement between parties about services, products, resources or some other kind of deliverable that has to be provided by the party playing the role of a Commitment fulfiller to the party, playing the role of a Commitment procurer.<br/>A service level agreement (SLA) is a type of ContractualAgreement that represents a formal negotiated agreement between two parties designed to create a common understanding about products, services, priorities, responsibilities, and so forth.<br/>A SalesQuoteAgreement is a type of ContractualAgreement. It enables tracking the approval made by a Party playing the role of Customer of a technical & commercial proposal (materialized as a SalesQuote) from the Company. Once approved by the Company and the Customer, the SalesQuote becomes a type of ContractualAgreement represented as a SalesQuoteAgreement.<br/>A PartyPrivacyAgreement is a type of ContractualAgreement. It enables tracking the approval of the company's Privacy conditions, made by the Party either globally for a PartyPrivacyProfile or just for a specific PartyPrivacyProfileCharValue.<br/>A FrameworkAgreement defines the general rules under which the Organization and third parties (that are not part of the same registered company than the Organization) will work together. A FrameworkAgreement can be established between an Organization and a Customer (generally B2B or B2B2X), an Organization and its Supplier or Partner…<br/>An ImplementationAgreement corresponds to an agreement between parties (that are not entities of the same registered company) related to the delivery of ProductOfferingInstances and associated Products.<br/>A WorkContract is a specific type of ContractualAgreement governed by labour law. A WorkContract defines the relationship between an Employer and an Employee. It attributes responsibilities, rights and duties to each parties and also job, position, job location, potentially expectations, mission description, working hours scheme, working time modalities, salary, benefits…<br/>FrameworkAgreement, ImplementationAgreement and WorkContract are described by their corresponding Specifications.<br/><b>Please note</b> that Commitment and ServiceLevelAgreement may be reviewed in the version 25.5 of Information Framework.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4696" ;
    skos:prefLabel "Figure A.06c - ContractualAgreement specialization"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4698> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "Managing value creation in a value fabric is much more complex than it used to be with the traditional value creation chain. <br/>A key entity to establish governance processes on the cooperation between parties on a value fabric is Commitment, derived from ContractualAgreement<font color=\"#ff0000\"> </font>which reflects the mutual agreement between two party roles about services, products, resources or some other kind of deliverable that has to be provided by the party playing the role of a Commitment fulfiller to the party, playing the role of a Commitment procurer.<br/><b>Example 1:</b><br/>The enterprise plans to launch a new product to the market that requires new capabilities of its billing infrastructure. Because the implementation of such infrastructure capabilities is not the core competence of the enterprise it is decided to get this capability realized by a supplier. Because the key business objectives of the enterprise is to save costs rather than to fasten time market to maximize gross margin, a tender process will be initiated to find a supplier providing the lowest price. For this supplier/buyer relationship the business objectives of the supplier are not relevant – the governance process for the supply process will be established by agreeing tightly measured Commitments with the supplier, regarding functionality and quality of the capabilities together with Commitment to deliver these capabilities according to the overall schedule.<br/><b>Example 2:</b><br/>The enterprise plans to launch a set of “communication services in a cloud” to the SoHo market. Because the enterprise is to capable to provide a web mail service of high quality and availability in time and provide such as service is not the core business of the enterprise, it is decided to look for a partner for re-selling an email service, operated as managed service by the partner, to be integrated in the set of cloud services, the enterprise offers to the end customer. For such a partner relationship it is essential to assess the business objectives of potential partners to ensure a reliable and sustainable partnership. Such a partner must share same business objectives like providing high quality services with a fast time to market (to avoiding the partner being a time-to-market bottle neck for future extensions of the service). At the same time the partner must not have conflicting business objectives, like provide the same service to the same market segment on its own. If the partner is targeting another market segment like large business customers, the partnership agreement might include that the partner markets the cloud to this market segment. Again, the mutual agreement between the enterprise and the partner is reflected by Commitments. In such kinds of partnership, the enterprise might play the role of a Commitment fulfiller for some Commitments and at the same time play the role of a Commitment procurer for others. These Commitments are defined to establish a governance to ensure that the common business objectives of both partners are achieved in this partnership and to ensure adoption of Commitments in case of changing business objectives.<br/><b>Example 3:</b><br/>The enterprise plans to source out IT (infrastructure) capabilities – e.g. services for network planning – to a supplier, who operates these services as managed services. The services, which are required to be provided by the supplier, are specified from a functional perspective as business services and KPIs are defined, to measure the required SLAs. The enterprise initiates a tender process, to find a cost-efficient supplier, who is capable to extend these business services for future requirements. Providing the services with the agreed service level is ensured by defining Commitments accordingly and to establish a governance model based on these.<br/>How Commitments are defined as business entities and how the involved roles are associated to Commitments is shown in Figure below.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4698" ;
    skos:prefLabel "Figure A.09 - Commitment Overview"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4700> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "As mentioned earlier, Commitment can be associated with a concrete deliverable. <br/>Commitment inherits from ContractualAgreement which inherits from Agreement. CommitmentItem has an association with ProductOfferingSpecification and ProductSpecification. <br/>If the supplier/partner is obligated to provide a product, the Commitment is associated to the corresponding specification.<br/>If any other kind of project deliverable is the Commitment of a supplier/partner this can be modeled CommitmentTermOrCondition, which inherits from AgreementTermOrCondition. CommitmentTermOrCondition is associated to ProjectDeliverable, defined in the Project ABE.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4700" ;
    skos:prefLabel "Figure A.10 - Commitment Deliverables"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4702> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "As Commitment is a mutual agreement between a party playing the CommitmentFulfilmentRole and a party playing the CommitmentProcurementRole, the Commitment must be approved by those.<br/>This approval is modeled, applying the AgreementApproval. In case of a Commitment there will be usually be two instances of AgreementAuthorization – one signed by a CommitmentApproverRole from “procurer side”, the other signed by a CommitmentApproverRole from “fulfillment side”.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4702" ;
    skos:prefLabel "Figure A.11 - Commitment Approval"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4704> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "An InternalAgreement is a specific type of NonContractualAgreement that can occur between two (or more) entities of the same registered company. These entities can correspond to different establishments or services in the same company.<br/>Approval and Authorizations of an InternalAgreement may not be necessary and not require a signature.<br/>An InternalAgreement can be described in a formal document or as a decision transcribed in meeting minutes or as an exchange of mail.<br/>Please note that, as Agreement inherits from Entity (that inherits from RootEntity), the association between Agreement and Attachment (and also Document) is inherited from RootEntity (See figure D.05: Links Between Document and other ABEs).<br/>A InternalAgreement can include a set of Items that may concern, as examples, Internal transfer Prices, related ServiceSpecification or ResourceSpecification, duration…<br/>InternalAgreementItem can be associated to ServiceSpecification, Service, ResourceSpecification and / or Resource.<br/>Please note that in some specific cases (example: historical operator), due to regulation, two entities of the same registered company may have an external agreement for equity between all operators of the country.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4704" ;
    skos:prefLabel "Figure A.12 - InternalAgreement"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4706> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "A WorkContract is a specific type of ContractualAgreement governed by labour law. A WorkContract defines the relationship between an Employer and an Employee. It attributes responsibilities, rights and duties to each parties and also job, position, job location, potentially expectations, mission description, working hours scheme, working time modalities, salary, benefits…<br/>Specialization of WorkContract have been defined:<br/><ul><li>FixedTermWorkContract: FixedTermWorkContract are WorkContracts that are valid for a “specific period of time” … or for a “specific task”. The \"fixed term\" is discharged by either the efflux of time at the end of the period specified in the contract or at the completion of the specified task.</li><li>PermanentWorkContract: A PermanentWorkContract corresponds to a work contract with no defined termination date (other than retirement).</li></ul><p/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4706" ;
    skos:prefLabel "Figure A.13 - WorkContract specializations"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4708> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "Authorizations of a WorkContract is identical to the authorizations of an Agreement. AgreementAuthorization indicates approval of the WorkContract. This involves more than just capturing who is the authorizer. For example, a WorkContract and its versions may go through many different levels of approval. Two business entities, AgreementApproval and AgreementAuthorization, are used to model approvals in the SID model. These business entities are shown in the figure below. <br/>AgreementApproval represents the acceptance of the agreement (and thanks to inheritance, the WorkContract) by the owners of the Agreement. During the negotiation of the WorkContract, there could be several iterations of approvals. Approval may require the involvement of a number of business Parties. Each authorized signature may be recorded electronically or by the more traditional signature. The signatureRepresentation attribute is a record of the means by which the signature was obtained, for example electronically or by hand.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4708" ;
    skos:prefLabel "Figure A.13a - WorkContract roles"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4710> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "A FrameworkAgreement defines the general rules under which the Organization and a third party will work together. A FrameworkAgreement can be established between an Organization and a Customer (generally B2B or B2B2X), an Organization and its Supplier or Partner…<br/>A FrameworkAgreement can include a set of FramewokAgreementItems that may concern, as examples, negotiated Prices of ProductOfferingSpecification, Restriction on ProductSpecification Characteristics possible values through ProductConfigSpec, Restriction on AllowedProductAction, Ethic clauses, Security clauses, Privacy clauses, Non disclosure clauses, Payment clauses, Revenue share clause, Liquidated damages, Responsibility, Target customers…<br/>CustomerProductOrders can be associated to FrameworkAgreement through an ImplementationAgreement. There is no direct relationship between FrameworkAgreement and CustomerProductOrder.<br/>ProductOfferingInstance and Product can be associated to FrameworkAgreement through an ImplementationAgreement. There is no direct relationship between FrameworkAgreement and ProductOfferingInstance and Product.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4710" ;
    skos:prefLabel "Figure A.14 - Framework Agreement"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4712> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "Affiliates or subsidiaries of the Operator or of the Customer can benefit from a FrameworkAgreement.<br/>The beneficiaries are described by the FrameworkAgreementBenificiaryRole.<br/>This role is played towards an Organization.<br/>This Organization plays also the role of LegalEntity.<br/>A legal entity delegates the AgreementSubscription signature to 0 to many AgreementRoles played by Individuals.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4712" ;
    skos:prefLabel "Figure A.14a - Framework Agreement subscription"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4714> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "In most of the B2B and B2B2X cases, before accepting any CustomerOrder from a prospect, a FrameworkAgreement has to be established.<br/>A FrameworkAgreement defines the general rules under which the Organization and third parties (that are not part of the same registered company than the Organization) will work together.<br/>As FrameworkAgreement production requires workload and negotiation on ProductOfferingSpecification prices and / or Terms or Conditions and also general rules under which the Organization and third parties will work together, it may not be established for a prospective customer before the creation of a first SalesOpportunity So, the first SalesOpportunity for a prospective customer may trigger the production of a FrameworkAgreement.<br/>In the case of a FrameworkAgreement not concerning prospective customer or customer, a first SalesOpportunity is not needed to create a FrameworkAgreement.<br/>Once a FrameworkAgreement is validated and agreed by the CSP and its prospective customer or customer, SalesOpportunity may be created based on the elements negotiated in this FrameworkAgreement. At least the initial SalesOpportunity that triggered the production of the FrameworkAgreement is associated with it.<br/>SalesOpportunityItem concerns 1 ProductOfferingSpecification. As for FrameworkAgreement, the first SalesOpportunityItem will trigger the creation of a corresponding FrameworkAgreementItem.<br/>Once FrameworkAgreement is approved, its FrameworkAgreementItem will be used to produce SalesOpportunityItem.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4714" ;
    skos:prefLabel "Figure A.14b FrameworkAgreement & SalesOpportunity"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4716> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "This illustration goal is to present the catalog that will be used for the illustration of FrameworkAgreement and ImplementationAgreement.<br/>The company Greenfield International Business plays the role of CSP.<br/>As a CSP, it markets a SASE offer (CompositeProductOfferingSpecification).<br/>This composite offer includes 3 atomic offers:<br/>- SDWAN AtomicProductOfferingSpecification,<br/>- SSE AtomicProductOfferingSpecification<br/>- Cloud Hosting AtomicProductOfferingSpecification.<br/>In real life, all these ProductOfferingSpecifications would correspond to complex CompositeProductOfferingSpecification. To simplify the understanding of the modeling concepts, we decided to represent here AtomicProductOfferingSpecification with associated AtomicProductSpecification.<br/>Cloud Hosting AtomicProductOfferingSpecification corresponds to a ProductSpecification provided by Cloud Experts supplier. The description of the supplier offer is provided in Figure A.14 - Illustration 01.02: CSP Catalog - Supplier Offer.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4716" ;
    skos:prefLabel "Figure A.14 - Illustration 01.01: CSP Catalog"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4718> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "This illustration goal is to present the catalog that will be used for the illustration of FrameworkAgreement and ImplementationAgreement.<br/>The company Greenfield International Business plays the role of CSP.<br/>As a CSP, it markets a SASE offer (CompositeProductOfferingSpecification).<br/>This composite offer includes 3 atomic offers:<br/>- SDWAN AtomicProductOfferingSpecification,<br/>- SSE AtomicProductOfferingSpecification<br/>- Cloud Hosting AtomicProductOfferingSpecification.<br/>In real life, all these ProductOfferingSpecifications would correspond to complex CompositeProductOfferingSpecification. To simplify the understanding of the modeling concepts, we decided to represent here AtomicProductOfferingSpecification with associated AtomicProductSpecification.<br/>Cloud Hosting AtomicProductOfferingSpecification corresponds to a ProductSpecification provided by Cloud Experts supplier.<br/>Cloud Expert can either sell this product:<br/>- to is customer through its CE Cloud Hosting AtomicProductOfferingSpecification,<br/>- to Greenfield International Business customers through Greenfield International Business.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4718" ;
    skos:prefLabel "Figure A.14 - Illustration 01.02: CSP Catalog - Supplier Offer"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4720> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "Greenfield International Business (Greenfield IB) wants to provide a SASE offer to its customers. Greenfield IB needs to be able to provide Cloud Experts' Cloud Hosting product as an option of the SASE offer.<br/>Greenfield IB needs to have a global agreement with Cloud Experts in order to be able to provide this option to its customers. Greenfield IB and Cloud Experts will sign a FrameworkAgreement to materialize this capacity to resell Cloud Experts' Cloud Hosting product.<br/>This illustration represents the Framework Agreement between Greenfield International Business (Greenfield IB) and a supplier called Cloud Experts.<br/>This Framework Agreement is formalized through a Document that includes all elements.<br/>This Framework Agreement is valid worldwide (AgreementRole has associated \"World\" Place).<br/>In this example, the FrameworkAgreement has three FrameworkAgreementItems.<br/>One concerns Ethic clauses (includes Greenfield IB code of ethics and commitment from all parties to respect this code).<br/>A second FrameworkAgreementItem includes clauses related to payments (like payments made by Greenfield International Business are performed latest 60 days end of the months after invoice reception).<br/>The third FrameworkAgreementItem concerns CE Cloud Hosting Offer. It is valid only for 1 year (the FrameworkAgreement is valid for 3 years) as prices may change after 1 year.<br/>This FrameworkAgreementItem is valid only for Middle East region (AgreementLocationRole / Place).<br/>With this FrameworkAgreementItem, Greenfield IB benefits from specific prices alteration (ProdOfferPriceAlteration) that impact the standard CE Cloud Hosting offer price plan (ProductOfferingPrice).<br/>This FrameworkAgreementItem allows Greenfield IB to perform Create, Update and Cancel actions on CE Cloud Hosting Offer. So, Greenfield IB can place orders, update its installed base (existing ProductOfferingInstances and associated Producs)and cancel existing ProductOfferingInstances.<br/>This FrameworkAgreementItem also limits the possible CE Cloud Hosting product characteristics values through an associated ProductConfigurationSpec.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4720" ;
    skos:prefLabel "Figure A.14 - Illustration 02: FrameworkAgreement between CSP and Supplier"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4722> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "This illustration represents a Framework Agreement between Greenfield International Business (Greenfield IB) and one organization called Middle East Finance Systems (MEF Systems).<br/>During DTW, a representative of Greenfield IB met a representative of MEF Systems. As their meeting was productive and could trigger sales, Greenfield IB created a Sales Lead for this potential customer. After some additional interactions, MEF Systems raised interest for some B2B offers and especially Greenfield IB SASE offer. A SalesOpportunity was created with one SalesOpportunityItem concerning SASE offer.<br/>Before doing any business with MEF Systems, Greenfield IB process requires the signature of a FrameworkAgreement with MEF System. This first SalesOpportunity with MEF Systems triggers the creation of a FrameworkAgreement between Greenfield IB and MEF Systems. The SalesOpportunityItem related to SASE offer raised the creation of a FrameworkAgreementItem related to SASE ProductOfferingSpecification.<br/>This Framework Agreement is produced by Greenfield IB based on its standard Sale FrameworkAgreementSpec.<br/>This Framework Agreement is valid for 2 years from the 1st of October 2025. It is formalized through a Document that includes all elements.<br/>This Framework Agreement is valid for Middle East area (AgreementLocationRole has associated \"Middle East\" Place).<br/>In this example, the FrameworkAgreement has three FrameworkAgreementItems.<br/>One concerns Ethic clauses (includes Greenfield IB code of ethics and commitment from all parties to respect this code).<br/>A second FrameworkAgreementItem includes clauses related to payments (like payments by MEF Systems are performed latest 30 days end of the months after invoice reception).<br/>The third FrameworkAgreementItem concerns Greenfield IB SASE Offer. This FrameworkAgreementItem is valid only until the 31st of August 2026 because the prices are guaranteed by Greenfield IB's supplier (Cloud Experts) only until this date.<br/>This FrameworkAgreementItem is valid only for Middle East region (AgreementLocationRole / Place).<br/>With this FrameworkAgreementItem, MEF Systems benefits from specific prices alteration (ProdOfferPriceAlteration) that impact the standard SASE offer price plan (ProductOfferingPrice).<br/>This FrameworkAgreementItem allows MEF Systems to perform Create, Update and Cancel actions on SASE Offer. So, MEF Systems can place orders, update its installed base (existing ProductOfferingInstances and associated Products) and cancel existing ProductOfferingInstances.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4722" ;
    skos:prefLabel "Figure A.14 - Illustration 03: FrameworkAgreement between CSP and Customer"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4724> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "An ImplementationAgreement corresponds to a ContractualAgreement related to the delivery of ProductOfferingInstances and their associated Products. <br/>An ImplementationAgreement <b>can be</b> related to a FrameworkAgreement. In this case, it benefits from the conditions negotiated within the FrameworkAgreement (ProductOfferingPrice, AgreementTermOrCondition, AgreementItemPrice…).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4724" ;
    skos:prefLabel "Figure A.15 - ImplementationAgreement overview"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4726> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "An ImplementationAgreement is a type of ContractualAgreement related to the delivery of ProductOfferingInstances and their associated Products.<br/>In a stable status, an ImplementationAgreement shall refer to 1 to several ProductOrder. The same applies for ImplementationAgreementItem. It shall refer to 1 to several ProductOfferingOrderItem that correspond to the ordering of ProductOfferingSpecification associated to the ImplementationAgreement.<br/><b>Note:</b> Please note that, as the ImplementationAgreement may be created before the ProductOrder, the cardinality shown in this diagram is 0..*. But in a stable state, an ImplementationAgreement refers to at least 1 ProductOrder. The same applies to ImplementationAgreementItem.<br/>As CustomerProductOrder / CustomerProductOfferingOrderItem and BusinessPartnerProductOrder / BusinessPartnerProductOfferingOrderItem inherit from ProductOrder / ProductOrderItem, the relationships with ImplementationAgreement / ImplementationAgreementItem described in this figure are also valid for CustomerProductOrder / CustomerProductOfferingOrderItem and BusinessPartnerProductOrder / BusinessPartnerProductOfferingOrderItem.<br/>The ImplementationAgreement can redefine, for the associated ProductOrder, some Terms or Conditions (AgreementTermOrCondition) and Prices (ProdOfferPriceAlteration) even if the ImplementationAgreement is associated to a FrameworkAgreement in which termes, conditions and prices were already agreed.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4726" ;
    skos:prefLabel "Figure A.15a - Implementation Agreement details"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4728> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "A SalesOpportunity is an opportunity to generate revenue from a Prospect that can already be an existing Customer. Opportunities are the pending deals that need to be tracked. Opportunities build the pipeline, which will contribute to the forecast.<br/>In B2B and B2B2X context, a won SalesOpportunity will trigger the creation of an ImplementationAgreement. The associated SalesOpportunityItems will trigger the creation of the ImplementationAgreementItems.<br/>In most of the cases, for B2C, small office home office and very small enterprises, the validation of a SalesQuote through the SalesQuoteAgreement will be sufficient and no ImplementationAgreement will be generated.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4728" ;
    skos:prefLabel "Figure A.15b - ImplementationAgreement & SalesOpportunity / SalesQuote"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4730> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "This illustration represents an Implementation Agreement between Greenfield International Business (Greenfield IB) and one organization called Middle East Finance Systems (MEF Systems) for the order of a SASE offer.<br/>After the approval of the FrameworkAgreement between Greenfield IB and MEF Systems, Greenfield IB generated several SalesQuote on SASE offer. A last version of SalesQuote was generated on the 5th of October and accepted by MEF Systems. This SalesQuote was valid for 1 month (until the 4th of November).<br/>According to Greenfield IB process, an ImplementationAgreement has to be generated to formalize the agreement on the last SalesQuote and to trigger the delivery of the SASE offer to MEF Systems.<br/>The SalesOpportunity associated to the accepted SalesQuote triggers the creation of an ImplementationAgreement between Greenfield IB and MEF Systems for the delivery of SASE Offer. The SalesOpportunityItem related to SASE offer raises the creation of an ImplementationAgreementItem related to SASE ProductOfferingSpecification.<br/>The ImplementationAgreement is produced by Greenfield IB based on its standard Sales ImplementationAgreementSpec.<br/>The ImplementationAgreement and the ImplementationAgreementItem refer to the approved FrameworkAgreement and FrameworkAgreementItem.<br/>The Implementation Agreement is valid for 3 months (corresponds to the estimated time required to deliver) from the 15th of October 2025. It is formalized through a Document that includes all elements (not represented in this figure to limit its size).<br/>In this example, the ImplementationAgreement has one ImplementationAgreementItem.<br/>This ImplementationAgreementItem concerns MEF CustomerProductOfferingOrderItem related to Greenfield IB SASE Offer.<br/>This CustomerProductOfferingOrderItem will deliver <br/>With this ImplementationAgreementItem, MEF Systems benefits from specific installed tariff (corresponds to Greenfield IB SASE Offer ProductOfferingPrice impacted by MEF System ProdOfferPriceAlteration).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4730" ;
    skos:prefLabel "Figure A.15 - Illustration 01: ImplementationAgreement between CSP and Customer"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4732> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "This illustration represents an Implementation Agreement between Greenfield International Business (Greenfield IB) and Cloud Experts for the order of a Cloud Hosting offer.<br/>After the approval of the first sale made by Greenfield IB to MEF Systems (See Figure A15 - Illustration 01: ImplementationAgreement between CSP and Customer), Greenfield IB ordered Cloud Hosting Offer to Cloud Experts in order to be able to deliver the SASE Offer to MEF Systems.<br/>According to Greenfield IB process, an ImplementationAgreement has to be generated to formalize the purchase of the Cloud Hosting Offer before placing the corresponding BusinessPartnerProductOrder to Cloud Experts.<br/>An ImplementationAgreement is created between Greenfield IB and Cloud Experts for the delivery of Cloud Hosting Offer and Product.<br/>The ImplementationAgreement is produced by Greenfield IB based on its standard Purchase ImplementationAgreementSpec.<br/>The ImplementationAgreement and the ImplementationAgreementItem refer to the approved FrameworkAgreement and FrameworkAgreementItem.<br/>The Implementation Agreement is valid for 2 months (corresponds to the estimated time required to deliver the Cloud Hosting Product and Offer to Greenfield IB) from the 15th of October 2025. It is formalized through a Document that includes all elements (not represented in this figure to limit its size).<br/>In this example, the ImplementationAgreement has one ImplementationAgreementItem.<br/>This ImplementationAgreementItem concerns Cloud Experts BusinessPartnerProductOfferingOrderItem related to Cloud Experts Cloud Hosting Offer.<br/>This CustomerProductOfferingOrderItem will deliver a Cloud Hosting Offer instance to Greenfield IB.<br/>With the FrameworkAgreementItem related to Cloud Hosting offer, Greenfield IB benefits from specific prices alteration (ProdOfferPriceAlteration) that impact the Cloud Hosting offer price plan (ProductOfferingPrice) and be formalized as an Installed Tarif (ProductPrice) specific for Greenfield IB.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4732" ;
    skos:prefLabel "Figure A.15 - Illustration 02: ImplementationAgreement between CSP and Supplier"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4734> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "“A Service Level Agreement (SLA) (also known as a Service Level Guarantee) is a type of ContractualAgreement that represents a formal negotiated Agreement between two Parties designed to create a common understanding about Products, Services, priorities, responsibilities, and so forth. The SLA is a set of appropriate procedures and targets formally or informally agreed between parties in order to achieve and maintain specified Quality of Service”. <br/>“There are three distinct types of SLAs:<br/>1. Customer SLAs<br/> • These are aimed at the ProductOffering between the customer and the Service Provider, and are usually subject to a formal contract between the Customer and the Service Provider. They are written in terms that the customer understands and based on the end-to-end delivery of the product components defined in the ProductOffering.<br/>2. Supplier/Partner SLAs<br/> • These are aimed at Suppliers and/or Partners, and are meant to ensure that the performance objectives are met for services that are provided by suppliers, partners, and other parties from whom an enterprise obtains services. They are derived from or form part of the contractual agreement between the Supplier/Partner and the Service Provider.<br/>3. Internal SLAs<br/> • These are primarily Service- and/or Resource-focused. They are aimed at services or groups of services, and are subject to agreements between organizational functions within the operators business”<br/>Please note that this last type of SLA is considered as a NonContractualAgreement.<br/>As a type of ContractualAgreement, ServiceLevelAgreements inherit all the informational characteristics of agreements previously describe in this addendum. Their inheritance is shown in the figure below.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4734" ;
    skos:prefLabel "Figure A.16 - Service Level Agreement's Inherited Associations"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4736> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "ServiceLevelAgreements do possess one unique characteristic. An AgreementItem is related to a ServiceLevelSpecification (see GB922 – Service guide book). A ServiceLevelSpecification is a group of ServiceLevelObjectives, such as thresholds, metrics, and tolerances, along with consequences that result from not meeting the objectives. ServiceLevelSpecifications are also characterized by exclusions associated to the Specification. These concepts are shown in the figure below.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4736" ;
    skos:prefLabel "Figure A.16a - Service Level Agreement Item's Association to Service Level Specification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4738> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "The Agreement Lifecycle outlines the journey an agreement takes from its initial conception to its eventual expiration, and archival. It's a lifecycle detailing how agreements are initiated, reviewed, negotiated, executed, managed during their active period, and ultimately handled when they reach the end of their lifecycle.<br/>The lifecycle begins with initiation and internal review. An agreement can originate as an internal proposal requiring internal scrutiny, or as an external proposal needing review. This initial phase involves internal assessment and potential refinement. Following this, the agreement moves into the negotiation phase, where terms are discussed and finalized with the other party. Successful negotiation leads to agreement approval, signifying the agreement is ready for formal execution. Upon execution, the agreement transitions to an active state, where it is legally binding and in effect. During this active period, the agreement may undergo amendments. This involves a dedicated process for proposing, negotiating, and ultimately implementing changes to the agreement's terms. The active phase also includes management activities like renewals, where the agreement's continuation is considered, and actions taken in response to breaches or policy issues, potentially leading to suspension or termination.<br/>The agreement's active period eventually concludes, either through natural expiry, strategic exit, or termination due to unresolved issues. Once the agreement reaches its end, it enters a post-lifecycle phase. This involves archiving the agreement for historical record-keeping, ensuring compliance with established retention policies. The lifecycle concludes when the retention period for the agreement has elapsed, signifying its final state.<br/>Throughout this entire process, the agreement can potentially revisit earlier stages. For instance, a negotiation might be re-initiated, or an agreement might be reinstated from an expired state. This dynamic nature of the lifecycle reflects the iterative and adaptable processes involved in managing agreements effectively. The diagram illustrates these transitions and pathways, providing a clear understanding of the agreement's complete lifecycle.<br/>Definitions of the Agreement Lifecycle states are as follows:<br/><b>Drafted</b>: The initial creation of the agreement's text and terms, before it has been shared with other parties.<br/><b>Review In Progress</b>: The draft has been submitted to stakeholders (internal or external) for feedback, comments, and assessment.<br/><b>Negotiated</b>: Parties are actively discussing, redlining, and modifying the terms to reach a mutually acceptable version.<br/><b>Approved: </b>The agreement has been accepted by all parties involved.<br/><b>Canceled: </b>The negotiation or review process has been halted, and the agreement has been withdrawn or abandoned by the parties.<br/><b>Executed:</b> The point where all parties have formally signified their acceptance of the terms, typically through signatures.<br/><b>Active:</b> The period during which the terms of the agreement are in effect and parties are expected to perform their duties.<br/><b>Suspended:</b> A temporary, formal pause on the performance of the agreement due to a significant issue.<br/><b>Renewed:</b> A formal process to extend the lifecycle of the agreement, often initiated before the expiry date.<br/><b>Terminated:</b> The agreement has been deliberately ended by one or more parties before its natural expiry date.<br/><b>Expired: </b>The agreement has reached its defined end date, and the performance period is naturally concluded.<br/><b>Archived: </b>The final resting state for a completed agreement, where it is stored for record-keeping<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA4738" ;
    skos:prefLabel "New Figure A.17 - Agreement Lifecycle Diagram"@en .

