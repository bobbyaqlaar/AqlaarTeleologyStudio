<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6083> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6105> ;
    skos:inScheme thes:sid ;
