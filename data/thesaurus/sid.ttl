    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA6727> ;
    skos:definition "The Party Privacy Profile Type ABE contains all entities used by the Party Privacy Management process for specifying <br/> - the information concerned by Privacy rules,<br/> - the Privacy rules themselves.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA3_EA2_EA6746" ;
    skos:prefLabel "Party Privacy Profile Type ABE"@en .

