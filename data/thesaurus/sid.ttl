<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1_EA3_EA1848> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1_EA1816> ;
