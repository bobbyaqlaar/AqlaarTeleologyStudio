<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA5_EA6822> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA5_EA6811> ;
    skos:definition "List of Entities that might be concerned by a CommunicationInteractionUseCase or a CommunicationInteractionResult.<br/>Note: the list of Entities is not exhaustive and must be completed wen requested.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA5_EA6822" ;
    skos:prefLabel "EARoot_EA4_EA2_EA11_EA5_EA6822"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA5_EA6823> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA5_EA6811> ;
    skos:definition "Most of BusinessInteraction’s Notification sub-classes correspond to « simple » Interaction with a type Notification.<br/>The qualification of the type of notification comes from the Entity it is related to.<br/>3 types of sub-classes<br/> - Some of the sub-classes only have a relationship with another Entity<br/> - DunningNotification, PartyRevenueShareNotification, RevShareReconDiscrepNotification<br/> - The inheritance of simple notifications sub-classes have been moved to inherit from CommunicationInteraction<br/> - Some of the sub-classes need a corresponding specification Entity<br/> - PerformanceNotification, ConsequencePerformanceNotification, RevenueAssuranceViolation, ConsequenceMetricNotification<br/> - We keep them as BusinessInteraction sub-classes as long as CommunicationInteractionSpecification is not yet introduced<br/> - Some of the sub-classes have a complex structure<br/> - AgreementApproval<br/> - We keep it as BusinessInteraction sub-class<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA5_EA6823" ;
    skos:prefLabel "EARoot_EA4_EA2_EA11_EA5_EA6823"@en .

