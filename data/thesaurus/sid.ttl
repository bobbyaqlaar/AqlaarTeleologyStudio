<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA12_EA5575> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA12_EA5563> ;
    skos:definition "Retsrictions implemented via a rules engine or policy<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA12_EA5575" ;
    skos:prefLabel "EARoot_EA4_EA2_EA10_EA12_EA5575"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA12_EA5576> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA12_EA5563> ;
    skos:definition "A policy, rule or template implementation should be used to enforce how each project uses its work calendars and the related special and standard work periods.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA12_EA5576" ;
    skos:prefLabel "EARoot_EA4_EA2_EA10_EA12_EA5576"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA12_EA5577> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA12_EA5563> ;
    skos:definition "A policy, rules, or template implementation should be used to enforce how Projects, WorkOrders, and WorkOrderItems interact<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA12_EA5577" ;
    skos:prefLabel "EARoot_EA4_EA2_EA10_EA12_EA5577"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA12_EA5580> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA12_EA5563> ;
    skos:definition "A type of ProjectDeliverable that does not have any subordinate ProjectDeliverables, that is, an Atomic ProjectDeliverable is a leaf-level ProjectDeliverable.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA12_EA5580" ;
    skos:prefLabel "AtomicProjectDeliverable"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA12_EA5581> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA12_EA5563> ;
    skos:definition "A type of Vision that does not have any subordinate Vision, that is, an Atomic Vision is a leaf-level Vision.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA12_EA5581" ;
    skos:prefLabel "AtomicVision"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA12_EA5582> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA12_EA5563> ;
    skos:definition "A type of ProjectDeliverable that is formed by aggregating other ProjectDeliverables, which may be composite or atomic ProjectDeliverables.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA12_EA5582" ;
    skos:prefLabel "CompositeProjectDeliverable"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA12_EA5583> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA12_EA5563> ;
    skos:definition "A type of Vision that is formed by aggregating other Visions, which may be composite or atomic Visions.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA12_EA5583" ;
    skos:prefLabel "CompositeVision"@en .

