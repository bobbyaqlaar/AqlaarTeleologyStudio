    skos:prefLabel "[Pr.05c - I01]"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1694> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1676> ;
    skos:definition "A type of ProductOffering that does not have any subordinate ProductOfferings, that is, an SimpleProductOffering is a leaf-level ProductOffering.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA1694" ;
    skos:prefLabel "AtomicProductOfferingSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1695> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1676> ;
    skos:definition "A type of ProductOffering that represents a grouping of ProductOfferings made available to the market. The grouping may consist of other BundledProductOffering(s) or SimpleProductOffering(s).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA1695" ;
    skos:prefLabel "CompositeProductOfferingSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1696> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1676> ;
    skos:definition "A set of numbers that specifies the lower and upper limits for a ProductOfferingSpecification that can be procured as part of the related CompositeProductOfferingSpecification.<br/>Values can range from 0 to unbounded.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA1696" ;
    skos:prefLabel "CompositeProductOfferingSpecificationOption"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1697> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1676> ;
    skos:definition "The ability of a distribution channel to distribute a product that has been ordered (as a product offering).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA1697" ;
    skos:prefLabel "DistChannelProdOffer"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1698> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1676> ;
    skos:definition "A distribution channel is the organization or entity by which a product catalog is presented to a customer.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA1698" ;
    skos:prefLabel "DistributionChannel"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1699> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1676> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA1699" ;
    skos:prefLabel "ImageAsset"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1700> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1676> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA1700" ;
    skos:prefLabel "Pr.05c-I01"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1701> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1676> ;
    skos:definition "A significant connection or similarity between two or more ProductOfferings. For example, the relationship between a provider's ProductOffering and a supplier/partner's ProductOffering used to fulfill the provider's ProductOffering; a service provider offers various photos for download and printing...a print shop prints them for the provider and considers one photo (ProductOffering) the same as any other from a pricing perspective...one partners' photo offering is related to many of the provider's photos.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA1701" ;
    skos:prefLabel "ProductOfferingRelationship"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1702> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1676> ;
    skos:definition "The presentation of one or more ProductSpecifications to the marketplace for sale, rental, or lease for ProductOfferingPrices. <br/>A ProductOfferingSpecification may target one or more MarketSegments, be included in one or more ProductCatalog, presented in support of one or more ProductStrategies, and made available in one or more Places. ProductOfferingSpecification may represent a simple offering of a single ProductSpecification (AtomicProductOfferingSpecification) or could represent a bundling of one or more other ProductOfferingSpecifications (CompositeProductOfferingSpecification).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA1702" ;
    skos:prefLabel "ProductOfferingSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1703> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1676> ;
    skos:definition "A condition under which a ProductOffering is made available to Customers. ProductOfferingTerm include ProductOfferingFinancialTerm, which includes such things as acceptable methods of payment, ShipmentTerm, and ServiceTerm.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA1703" ;
    skos:prefLabel "ProductOfferingTermOrCondition"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1_EA1709> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1_EA1711> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the Pricing Logic Algorithm Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA1_EA1709" ;
    skos:prefLabel "Figure PLA.01 - Pricing Logic Algorithm ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1_EA1712> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1_EA1711> ;
    skos:definition "Holds the value of a single cell of MarixCharacteristic and associations to the indices of this value in the matrix<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA1_EA1712" ;
    skos:prefLabel "MatrixCellCharValue"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1_EA1713> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1_EA1711> ;
    skos:definition "Holds the list of scalar values of MarixCharacteristic. In addition it includes the indices of the dimensions of the matrix.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA1_EA1713" ;
    skos:prefLabel "MatrixCharValue"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1_EA1714> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1_EA1711> ;
    skos:definition "Holds the value of a single index into a dimension of MatrixCharValue.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA1_EA1714" ;
    skos:prefLabel "MatrixCharValueIndex"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1_EA1715> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1_EA1711> ;
    skos:definition "PLA that rates One Time events and generates type of AppliedCustomerBillingProductCharge<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA1_EA1715" ;
    skos:prefLabel "OneTimeRatingPLA"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1_EA1717> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1_EA1711> ;
    skos:definition "The PricingLogicAlgorithm entity represents an instantiation of an interface specification to external rating function (without a modeled bahavior in SID). Some of the parameters of the interface definiition may be already set (such as price per unit) and some may be gathered during the rating process from the event (such as call duration) or from ProductCharacteristicValues (such as assigned bandwidth)<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA1_EA1717" ;
    skos:prefLabel "PricingLogicAlgorithm"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1_EA1718> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1_EA1711> ;
    skos:definition "PLA that rates Recurring events and generates type of AppliedCustomerBillingProductCharge<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA1_EA1718" ;
    skos:prefLabel "RecurringRatingPLA"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1_EA1719> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1_EA1711> ;
    skos:definition "PLA that rates ProductUsage events and generates type of AppliedCustomerBillingProductUsageRate<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA1_EA1719" ;
    skos:prefLabel "UsageRatingPLA"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1_EA1_EA1720> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1_EA1_EA1722> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>PLA Spec</b> Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA1_EA1_EA1720" ;
    skos:prefLabel "Figure PLAS.01 - PLA Spec ABE Related Elements"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1_EA1_EA1723> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1_EA1_EA1722> ;
    skos:definition "This entity specifies a characteristic which is not a scalar value but rather n-dimensional matrix.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA1_EA1_EA1723" ;
    skos:prefLabel "MatrixCharacteristicSpec"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1_EA1_EA1724> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1_EA1_EA1722> ;
    skos:definition "A specification of a single dimension of MatrixCharacteristic. Each dimension is defined by a single CharacteristicSpecification or ProductSpecCharacteristic which specifies the legal values for this dimension.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA1_EA1_EA1724" ;
    skos:prefLabel "MatrixSpecDimension"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1_EA1_EA1725> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1_EA1_EA1722> ;
    skos:definition "Interface specification for a function that rates one time events.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA1_EA1_EA1725" ;
    skos:prefLabel "OneTimePLASpec"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1_EA1_EA1726> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1_EA1_EA1722> ;
    skos:definition "The PricingLogicAlgorithmSpec entity specifies an interface to (potentially external) rating function that can rate billing events (usage, recurring or on time). This entity lists all the parameters that should be passed to the rating function in order to rate the events correctly. Parameters can be determined when instantiating this entity as PricingLogicAlgorithm (e.g. price per unit) or come from the rated event (e.g. call duration) or the ProductCharacteristicValue (e.g. bandwidth).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA1_EA1_EA1726" ;
    skos:prefLabel "PricingLogicAlgorithmSpec"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1_EA1_EA1727> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1_EA1_EA1722> ;
    skos:definition "Interface specification for a function that rates recurring events.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA1_EA1_EA1727" ;
    skos:prefLabel "RecurringPLASpec"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1_EA1_EA1728> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1_EA1_EA1722> ;
    skos:definition "Interface specification for a function that rates usage events.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA1_EA1_EA1728" ;
    skos:prefLabel "UsagePLASpec"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA2_EA1729> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA2_EA1731> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Product Catalog</b> Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA2_EA1729" ;
    skos:prefLabel "Figure PC.01 - Product Catalog ABE Related Elements"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA2_EA1732> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA2_EA1731> ;
    skos:definition "ProdCatProdOffer characterizes the membership of a ProductOffering to a ProductCatalog.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA2_EA1732" ;
    skos:prefLabel "ProdCatProdOffer"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA2_EA1733> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA2_EA1731> ;
    skos:definition "A list of ProductOfferings for sale, with prices and illustrations, for example in book form or on the web. ProductCatalogs can be used by Customers during a self-care ordering process and may be used across one or more DistributionChannels.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA2_EA1733" ;
    skos:prefLabel "ProductCatalog"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA2_EA1734> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA2_EA1731> ;
    skos:definition "A ProductCatalogSpecification defines the invariant characteristics of a ProductCatalog.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA2_EA1734" ;
    skos:prefLabel "ProductCatalogSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA3_EA1735> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA3_EA1737> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Product Offering Price</b> Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA3_EA1735" ;
    skos:prefLabel "Figure POP.01 - Product Offering Price ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA3_EA1738> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA3_EA1737> ;
    skos:definition "Part of a ProductOfferingPrice representing a single element of the price. Subclasses further define these elements.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA3_EA1738" ;
    skos:prefLabel "ComponentProdOfferPrice"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA3_EA1739> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA3_EA1737> ;
    skos:definition "A ProductOfferingPrice that is made up of parts. The parts may be other CompositeProdOfferPrices or ComponentProdOfferPrices.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA3_EA1739" ;
    skos:prefLabel "CompositeProdOfferPrice"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA3_EA1740> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA3_EA1737> ;
    skos:definition "A discount is a reduction in price. It could be a flat fee such as 10 dollars or a percentage, such as 50% off. A discount always applies to, and thus is associated with, one or more other ProdOfferPrices. So a discount would be 10 dollars off the installation fee or 50% off the per-minute rate.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA3_EA1740" ;
    skos:prefLabel "DiscountProdOfferPriceAlteration"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA3_EA1741> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA3_EA1737> ;
    skos:definition "A particular type of one time charge, such as an activation fee or installation fee.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA3_EA1741" ;
    skos:prefLabel "FeeProdOfferingPrice"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA3_EA1742> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA3_EA1737> ;
    skos:definition "A one time charge is levied once. An example is the cost of a cell phone handset or installation fee.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA3_EA1742" ;
    skos:prefLabel "OneTimeProdOfferPriceCharge"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA3_EA1743> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA3_EA1737> ;
    skos:definition "An occurrence (happening) or schedule that triggers the creation of a billing charge for a product offering. For example, a price event instance may represent the end of a month when monthly recurring billing charges are created. In some cases, the creation of a charge associated with a ProductOfferingPrice may be triggered by multiple events. For example, a penalty (ProductOfferingPrice) may be triggered by over- or under-usage of a service. Under- and over-usage are represented as two separate PriceEvent entity instances.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA3_EA1743" ;
    skos:prefLabel "PriceEvent"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA3_EA1744> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA3_EA1737> ;
    skos:definition "An amount (usually of money) or a percentage that modifies or replaces a price charged (ProductOfferingPrice composite or component) for a ProductOffering.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA3_EA1744" ;
    skos:prefLabel "ProdOfferPriceAlteration"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA3_EA1745> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA3_EA1737> ;
    skos:definition "An amount, usually of money, that is asked for when a ProductOffering is bought, rented, or leased.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA3_EA1745" ;
    skos:prefLabel "ProdOfferPriceCharge"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA3_EA1746> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA3_EA1737> ;
    skos:definition "An amount, usually of money, that is asked for or allowed for<br/> - a ProductOffering bought, rented, or leased<br/> - a ProductUsage<br/> - or an Action on Product (AllowedProductAction)<br/>The price is valid for a defined period of time.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA3_EA1746" ;
    skos:prefLabel "ProductOfferingPrice"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA3_EA1747> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA3_EA1737> ;
    skos:definition "A charge that is levied repeatedly. It has a period, such as monthly, quarterly, or yearly. An example would be a monthly charge for long distance. A recurring charge may also limit the application duration. For example, a recurring charge applied only during 6 months for an expensive device.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA3_EA1747" ;
    skos:prefLabel "RecurringProdOfferPriceCharge"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA3_EA1748> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA3_EA1737> ;
    skos:definition "A price that replaces another ProductOfferingPrice (charged in lieu of another price). For example, purchasing two of a single product offering may result in a discounted price for both.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA3_EA1748" ;
    skos:prefLabel "ReplacementProdOfferPriceAlteration"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA3_EA1749> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA3_EA1737> ;
    skos:definition "A rate where the charge is the same for all events. A 10 cents a minute for long distance plan is one example.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA3_EA1749" ;
    skos:prefLabel "SimpleUsageProdOfferPriceCharge"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA3_EA1750> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA3_EA1737> ;
    skos:definition "A specific rate that applies to ProductUsages aggregated during a certain period. <br/><br/>For example, all evening minutes are aggregated during one month before being globally rated by a TarifUsageProdOfferPriceCharge 1. And all daytime minutes are aggregated during one month before being globally rated by a TarifUsageProdOfferPriceCharge 2.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA3_EA1750" ;
    skos:prefLabel "TariffUsageProdOfferPriceCharge"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA3_EA1751> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA3_EA1737> ;
    skos:definition "A charge levied for usage (ProductUsageSpec), based on measuring events. This model distinguishes between simple usage and usage where the charge is described by a tariff.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA3_EA1751" ;
    skos:prefLabel "UsageProdOfferPriceCharge"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA4_EA1752> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA4_EA1754> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the Product Offering Price Rule Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA4_EA1752" ;
    skos:prefLabel "Figure POPR.01 - Product Offering Price Rule ABE Related Elements"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA4_EA1755> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA4_EA1754> ;
    skos:definition "The outcome of the successful evaluation of a PolicyStatement (that is, one that has met its condition(s)). The outcome is expressed in terms of the price of a ProductOffering. A ProdOfferPriceAction is a type of PolicyAction.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA4_EA1755" ;
    skos:prefLabel "ProdOfferPriceAction"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA4_EA1756> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA4_EA1754> ;
    skos:definition "Part of a PolicyStatement representing a single constraint that defines the assessment of the rule. The constraint is specified in terms of one or more ProductOffering, ProductSpecificationType, ProductOfferingPrice, and/or ProductOfferingPriceComponent. ProdOfferPriceRuleCondition is a type of PolicyCondition.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA4_EA1756" ;
    skos:prefLabel "ProdOfferPriceCondition"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA4_EA1757> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA4_EA1754> ;
    skos:definition "An amount expressed in money or another medium of exchange that is thought to be a fair exchange for a ProductOffering as the result of the evaluation of a PolicyStatement.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA4_EA1757" ;
    skos:prefLabel "ProdOfferPricePolicyValue"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA4_EA1758> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA4_EA1754> ;
    skos:definition "A type of PolicyVariable that represents a ProductOffering, ProductOfferingPrice, or ProductSpecificationType.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA4_EA1758" ;
    skos:prefLabel "ProdOfferPricePolicyVariable"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA5_EA1759> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA5_EA1761> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Product Offering Price Tax</b> Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA5_EA1759" ;
    skos:prefLabel "Figure POPT.01 - Product Offering Price Tax ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA5_EA1762> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA5_EA1761> ;
    skos:definition "A ComplexTaxDefinition is defined by one or many TaxRules. It can be a Tax based on the age of the building or a tax with a different rate according to the amount.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA5_EA1762" ;
    skos:prefLabel "ComplexTaxDefinition"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA5_EA1763> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA5_EA1761> ;
    skos:definition "A tax that is a fixed amount, e.g. 0.50 euro levied as an environmental surcharge for mobile device sales.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA5_EA1763" ;
    skos:prefLabel "SimpleAmountTaxDefinition"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA5_EA1764> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA5_EA1761> ;
    skos:definition "A tax that is calculated by a rate, e.g. Value Added Tax is 17% of the purchase price.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA5_EA1764" ;
    skos:prefLabel "SimpleRateTaxDefinition"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA5_EA1765> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA5_EA1761> ;
    skos:definition "Definition of a tax that should be levied and defined by a TaxJurisdiction.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA5_EA1765" ;
    skos:prefLabel "TaxDefinition"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA5_EA1766> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA5_EA1761> ;
    skos:definition "TaxJurisdiction is a specific party role played by an organization that has the authority to levy tax. The geographic area over which tax can be levied is derived from the base PartyRole class relationship to AdministrativeArea.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA5_EA1766" ;
    skos:prefLabel "TaxJurisdiction"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA5_EA1767> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA5_EA1761> ;
    skos:definition "A TaxProdOfferPriceAlteration is a type of ProdOfferPriceAlteration defined by a TaxDefinition.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA5_EA1767" ;
    skos:prefLabel "TaxProdOfferPriceAlteration"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA5_EA1768> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA5_EA1761> ;
    skos:definition "A TaxProdPriceAlteration is a type of ProdPriceAlteration that applies a TaxDefinition.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA5_EA1768" ;
    skos:prefLabel "TaxProdPriceAlteration"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA5_EA1769> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA5_EA1761> ;
    skos:definition "A rule to calculate a complex Tax, such as a Tax based on the age of the building or a tax with a different rate according to the amount.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA5_EA1769" ;
    skos:prefLabel "TaxRule"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1770> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1790> ;
    skos:definition "Each Product corresponds to a unique ProductSpecification provided to a party. A Product might be either contained in another Product (CompositeProduct) or in a unique ProductOfferingInstance at one time.<br/>Each ProductOfferingInstance corresponds to a unique ProductOfferingSpecification provided to a party. It might be either be composite (CompositeProductOfferingInstance) and then contain ProductOfferingInstance or be atomic (AtomicProductOfferingInstance) and contain a unique Product.<br/>A ProductOfferingSpecification is marketed exclusively by the CSP playing a PartyRole of MarketingOperator or by a PartyRole Supplier played by another company.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA1770" ;
    skos:prefLabel "Figure Pr.07a1 - Simple Product & Offering Spec and instances"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1772> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1790> ;
    skos:definition "<font color=\"#29313b\">When the ProductOfferingSpecification is marketed by the MarketingOperator i.e. the CSP, when a Customer buys it, he will hold the corresponding ProductOfferingInstance and by navigation the contained ProductOfferingInstances and the related Products.</font><br/><font color=\"#29313b\">In this case, the ProductOfferingInstance is charged to one or many CustomerBillingAccounts.</font><br/><font color=\"#29313b\">Note: The ProductOfferingInstance might be charged to many CustomerBillingAccounts but no split billing rules are specified for the moment in SID.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA1772" ;
    skos:prefLabel "Figure Pr.07a2 - CSP Product & Offering Spec and instances"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1774> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1790> ;
    skos:definition "<font color=\"#29313b\">When the ProductOfferingSpecification is marketed by Supplier, when the ServiceProvider buys it, he will hold the corresponding ProductOfferingInstance and by navigation the contained ProductOfferingInstances and the related Products.</font><br/><font color=\"#29313b\">In this case, the ProductOfferingInstance is charged to one or many BusinessPartnerAccounts.</font><br/><font color=\"#29313b\">Note: The ProductOfferingInstance might be charged to many BusinessPartnerAccounts but no split billing rules are specified for the moment in SID.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA1774" ;
    skos:prefLabel "Figure Pr.07a3 - Supplier Product & Offering Spec and instances"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1776> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1790> ;
    skos:definition "<font color=\"#29313b\">The following diagram provides a complete view of the Product & Offering Spec and Instances.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA1776" ;
    skos:prefLabel "Figure Pr.07a4 - Complete Product & Offering Spec and instances"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1778> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1790> ;
    skos:definition "<font color=\"#29313b\">A Product represents the realisation of a configured ProductSpecification for a Customer. Product follows the same Composite / Atomic pattern as ProductSpecification.</font><br/><font color=\"#29313b\">A Product is the functional view of what is used by the ProductUser and is always provided through an AtomicProductOfferingInstance that carries the corresponding commercial part such as the price.</font><br/><font color=\"#29313b\">When A Customer makes a selection, they may also have a number of options to select from. These are associated to a ProductSpecification and modeled in ProductCharacteristicValue (see Figure below), which defines the Product delivered to the Customer. The ProductCharacteristicValue comprises the detail of the ProductSpecCharacteristics, such as color, selected by the Customer.</font><br/><font color=\"#29313b\">Examples of characteristics might be the Voice package duration or Internet speed. </font><br/><font color=\"#29313b\">When an enterprise agrees to deliver a Product to a Customer, there is a significant amount of information that needs to be recorded to implement that Product on the provider’s infrastructure or Resources and to activate the Service via with the Product is realized. This is modeled in Product and associated entities below.</font><br/><font color=\"#29313b\"><br/></font><font color=\"#29313b\">The users/recipients that are entitled to use the Product are specified through PartyRoles ProductUsers related to the Product. </font><br/><font color=\"#29313b\">The ProductUser may be the signatory to an agreement, particularly if the Customer is an Individual, but they may also be an agent or Employee of the Customer where that Customer is a large Organization.Note that the ProductUser might be played by a Party different from the one who plays the role of Customer. For example, the mother might be the customer who holds a mobile line ProductOfferingInstance and the son might play the role of ProductUser of the mobile line Product.</font><br/><font color=\"#29313b\">In the context of a Company, the company holds the mobile fleet and each company’s employee plays the role of ProductUser of one Product of the mobile line fleet.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA1778" ;
    skos:prefLabel "Figure Pr.07b - Product Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1780> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1790> ;
    skos:definition "<font color=\"#29313b\">The features of a Product to which a Customer subscribes are represented by ProductCharacteristicValues. In the email example, the features Spam protection, storage, message size, virus scanning and cleaning, mail forwarding, and archiving all have fixed values. These values are sometimes referred to as invariant characteristics. User name and password are variant characteristics in that the values are specified for each Product. The values may come from a list of permitted values specified in ProductSpecCharacteristicValues or may be simply be entered Product by Product. User name and password are examples of the latter. In the example, user name may take on a value of “Gsmith” and password may take on a value of “mom001”.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA1780" ;
    skos:prefLabel "Figure Pr.07b – I01 - 1.4.1.1.ProductCharacteristicValue Example – Email Product"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1782> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1790> ;
    skos:definition "When A Customer makes a selection, they may also have a number of options to select from. These are associated with the ProductOffering via its association to a ProductSpecification and modeled in ProductCharacteristicValue (see Figure below), which defines the Product delivered to the Customer. The ProductCharacteristicValue comprises the detail of the ProductSpecCharacteristics, such as color, selected by the Customer.<br/>When an enterprise agrees to deliver a Product to a Customer, there is a significant amount of information that needs to be recorded to implement that Product on the provider’s infrastructure or Resources and to activate the Service via with the Product is realized. This is modeled in Product and associated entities below.<br/>A Product bundle in an instantiation of the BundledProductOffering that was used when the customer purchased a product or products from the provider. The ProductBundle holds the information (usually business information) that relates to the specific product offering (such as special prices or commitment terms) in case the customer changes its products and is no more eligible to the special business terms that are attached to the ProductOffering. <br/>If the customer, purchased, as example a triple play bundle (VoIP, High speed internet and Cable TV) and as a result is eligible for a 10$ monthly discount on the Cable TV charges, then this information should be kept so when the customer cancels the VoIP product the TV discount is removed. In the same way the bundle can also have changes on commitment terms and other business terms. The information which BundledProductOffering was used for the purchase is kept in the ProductBundle entity and when a product is cancelled, possibly the ProductBundle may change (to reflect the fact that now the product business terms are derived form a different ProductOffering<br/>A Product component in an instantiation of the SimpleProductOffering that was used when the customer purchased a product or products from the provider. The ProductComponent holds the information (usually business information) that relates to the specific product offering (such as special prices or commitment terms) in case the customer changes its products and is no more eligible to the special business terms that are attached to the ProductOffering. <br/>If the customer, purchased, as example a VoIP line and as a result is eligible for a low recurring charge because of a special promotion in order to penetrate a new city, then this information should be kept so when the customer changes her address the special rate is replaced with a normal monthly rate. In the same way the product component can also have changes on commitment terms and other business terms. The information which SimpleProductOffering was used for the purchase is kept in the ProductComponent entity and when a product is cancelled, possibly the ProductComponent may change (to reflect the fact that now the product business terms are derived from a different ProductOffering.<br/><br/>ProductOfferings may be obtained by the Customer in a number of ways. Two different examples are Products are equipment obtained directly by the Customer, compared to Products that are realized by Services provided across the provider’s Resources and which the Customer accesses and uses, rather than owns. In some cases, a provider may give the Customer access to a Product resident on a third party’s resources. Where a third-party Product is involved, it may be branded/labeled as coming from another provider or it may be re-branded/labeled as the first provider’s Product. Whichever of these is applicable, once the customer is using the Product, we are talking about a realization of the Product Offering that is based on a standard Product Specification. <br/>The price someone pays, the rate charged for usage of a Product, discounts and allowances related to a Product are represented by the ProductPrice entity. ProductPrice is a separate SID ABE that is further detailed in this addendum.<br/>We are also talking about the user/recipient that is entitled to use the Product. This is represented by a PartyRole, which is in turn related to the Product using the Product Involvement Role business entity and its involvementRole derived attribute.<br/>The Product that the Customer has obtained is not truly realized until it is in use. The user may be the signatory to an agreement, particularly if the Customer is an Individual, but they may also be an agent or Employee of the Customer where that Customer is a large Organization.<br/>Finally, a CustomerAccount may also be involved with a Product. For example, the role could be the CustomerAccount that pays for a Product; the CustomerAccount to which a Product was charged; the CustomerAccount associated with ordering a Product. This is represented by the CustomerAccountProductInvolvement business entity.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA1782" ;
    skos:prefLabel "Figure Pr.07c - Product Offering Instance Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1784> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1790> ;
    skos:definition "When an enterprise agrees to deliver a product to a customer, one or many ProductOfferingPrice might be identified as applicable for this Product and therefore one or many prices (ProductPrice) are associated with the Product.<br/>The figure below presents the set of entities that are used to hold this information. The ProductPrice represents an amount, usually of money, that represents the actual price paid by a customer for a purchase, a rent or a lease of a Product. <br/>The ProductPrice is associated with the Product entity and the ProductOfferingPrice entity. The structure of ProductPrice subclasses resembles the structure of ProductOfferingPrice subclasses. <br/>The ProductPrice validFor attribute represents the time period during which it is applicable. For example, an alteration might be applicable only 6 months on a recurring charge.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA1784" ;
    skos:prefLabel "Figure Pr.32 - Product Price"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1786> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1790> ;
    skos:definition "The following diagram shows the ProdPriceCharge hierarchy.<br/><ul><li>A <b>UsageProdPriceCharge </b>represents a charge applicable to ProductCharges for a Product.</li><li>A <b>OneTimeProdPriceCharge </b>represents a charge to apply for a Product action that has been done such as creation fee.</li><li>A <b>RecurringProdPriceCharge </b>represents a charge that must be applied on a recurring basis for a Product.</li></ul><p/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA1786" ;
    skos:prefLabel "Figure Pr.32a - Product Price Charge hierarchy"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1788> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1790> ;
    skos:definition "The following diagram shows the ProdPriceAlteration hierarchy.<br/><ul><li>A ReplacementProdPriceAlteration represents a new price that replaces a charge for a Product.</li><li>A DiscountProdPriceAlteration represents a discount (a reduction of price) for a Product.</li><li>A TaxProdPriceAlteration is a type of ProdPriceAlteration that applies a TaxDefinition.</li></ul><p/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA1788" ;
    skos:prefLabel "Figure Pr.32b - Product Price Alteration hierarchy"@en .

