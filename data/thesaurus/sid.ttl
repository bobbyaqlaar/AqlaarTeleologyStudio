<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7232> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7195> ;
    skos:definition "Cécile: In SID all the relationships with Document and other entities are done through Attament and its relationship with RootEntity<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA9_EA7232" ;
    skos:prefLabel "EARoot_EA4_EA2_EA11_EA9_EA7232"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7233> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7195> ;
    skos:definition "Cécile: I would say, we should not reuse a value for several Documents, else it means that if it is changed in one document, it is changed in the others that reuse the value.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA9_EA7233" ;
    skos:prefLabel "EARoot_EA4_EA2_EA11_EA9_EA7233"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7234> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7195> ;
    skos:definition "Add a name attribute?<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA9_EA7234" ;
    skos:prefLabel "EARoot_EA4_EA2_EA11_EA9_EA7234"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7235> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7195> ;
    skos:definition "Long discussion regarding 2..* or 0..*<br/><br/>Example of Document set with zero docuyments: A case is created, but will require supporting documentation. The document Set is created for that supporting documentation, and exists to attach the documentation as it comes in. It begins and remains for some period of time as a VALID but INCOMPLERTE document set.<br/><br/>A second example would be regarding a case with taxes, and a case is opened and documents then come in. It might be some time (maybe never) for the documents to be provided.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA9_EA7235" ;
    skos:prefLabel "EARoot_EA4_EA2_EA11_EA9_EA7235"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7236> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7195> ;
    skos:definition "An Attachment represents the valid period of a Document attached to another Entity such as the scanned paper contract signed by the Customer attached to his subscription (i.e. Product).<br/>A Document might be attached to any type of RootEntity for a certain period of time through the Attachment Entity.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA9_EA7236" ;
    skos:prefLabel "Attachment"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7237> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7195> ;
    skos:definition "CharValueDocSpecType is a type of DocumentSpecCharValue.<br/>CharValueDocSpecType is used in the case of inclusion of a DocumentSpecification in a Document.<br/>CharValueDocSpecType describes the type of inclusion (file inclusion or content inclusion) and the DocumentSpecification that has to be calculated and included in the final document.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA9_EA7237" ;
    skos:prefLabel "CharValueDocSpecType"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7238> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7195> ;
    skos:definition "A CharValueDocument is a type of DocumentCharacteristicValue.<br/>A CharValueDocument specifies the Document that has been included in the final document according to the CharValueDocumentType.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA9_EA7238" ;
    skos:prefLabel "CharValueDocument"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7239> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7195> ;
    skos:definition "CharValueDocumentType is a type of DocumentSpecCharValue.<br/>CharValueDocumentType is used in the case of inclusion of a Document in a Document (example: User's guide included in a Welcome notification document).<br/>A CharValueDocumentType describes the type of inclusion (file inclusion or content inclusion) and the Document that has to be included in the final Document.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA9_EA7239" ;
    skos:prefLabel "CharValueDocumentType"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7240> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7195> ;
    skos:definition "A CharValueInformation is a type of DocumentCharacteristicValue.<br/>A CharValueInformation contains the value retrieved or captured using the rule described in the CharValueInformationType (Ex: name of the customer).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA9_EA7240" ;
    skos:prefLabel "CharValueInformation"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7241> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7195> ;
    skos:definition "A CharValueInformationType describes the rule to capture or retrieve the information (Ex: name of the customer) that has to be included in the final document.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA9_EA7241" ;
    skos:prefLabel "CharValueInformationType"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7243> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7195> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA9_EA7243" ;
    skos:prefLabel "Document Example Elements"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7244> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7195> ;
    skos:definition "The information and documents used to build a Document are specified through DocumentCharacteristicValues.<br/>A DocumentCharacteristicValue refers to a DocumentSpecCharacteristicValue.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA9_EA7244" ;
    skos:prefLabel "DocumentCharacteristicValue"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7245> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7195> ;
    skos:definition "A DocumentFileType describes the format of a document like paper, binary, basic text (non formatted document), PDF, Word…<br/>When a GeneratedDocument is built from a PatternDocument, it has the same DocumentFileType as the PatternDocument.<br/>A Document can have only one DocumentFileType. If it exists in different formats, it will correspond to several Document.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA9_EA7245" ;
    skos:prefLabel "DocumentFileType"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7246> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7195> ;
    skos:definition "A Document has a nature represented by DocumentNature BE.<br/>DocumentNature allows the classification and / or categorization of a Document according to its use or goal like advertising, note, sales contract, notification…<br/>A note represents a brief record, especially one written down to aid the memory.<br/>A sales contract (agreement) is a legal document representing an agreement between seller (or vendor) and buyer (or purchaser) for the sale of goods or services.<br/>A Document can have several DocumentNature (like a mail corresponding to a welcome notification and containing advertising).<br/>When a GeneratedDocument is built from a PatternDocument, it has the same DocumentNature as the PatternDocument.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA9_EA7246" ;
    skos:prefLabel "DocumentNature"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7247> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7195> ;
    skos:definition "Values: true,falseDefault: False"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA9_EA7247" ;
    skos:prefLabel "DocumentRepresentation"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7248> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7195> ;
    skos:definition "A DocumentSet corresponds to a group of consistent or associated documents.<br/>Examples:<ul><li>An Agreement may be a DocumentSet made of one core document (core contract) and several additional documents (appendixes)</li><li>SID documentation is a DocumentSet made of several documents (Read me first, Release notes, Poster, Excel, one document per domain…)</li></ul><p/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA9_EA7248" ;
    skos:prefLabel "DocumentSet"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7249> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7195> ;
    skos:definition "A DocumentSetSpecification enables to specify a DocumentSet (group of Document that have a meaning together like a customer contract containing general, particular and specific clauses).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA9_EA7249" ;
    skos:prefLabel "DocumentSetSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7250> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7195> ;
    skos:definition "A DocumentSpecCharacteristic allows to specify information, documents or documents’ specification that have to be included or captured (examples: Author Name, Validation Responsible, Version, content of the different sections of the document…) when building a Document based on the DocumentSpecification.<br/>Each DocumentSpecCharacteristic is described by a rule giving the conditions to evaluate to choose between the possible values (DocumentSpecCharacteristicValue).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA9_EA7250" ;
    skos:prefLabel "DocumentSpecCharacteristic"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7251> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7195> ;
    skos:definition "Each DocumentSpecCharacteristic is described by a rule giving the conditions to evaluate to choose between the possible values (DocumentSpecCharacteristicValue).<br/>The type of information that has to be captured or retrieved is defined by the type of DocumentSpecCharacteristicValue (sub-classes).<br/><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA9_EA7251" ;
    skos:prefLabel "DocumentSpecCharValue"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7252> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7195> ;
    skos:definition "A Document can be produced according to a DocumentSpecification.<br/>DocumentSpecification corresponds to a template of document that can be used to produce either automatically or manually documents.<br/>DocumentSpecification can define, through DocumentSpecCharacteristic the different characteristics of a document like the fact that an Author Name, a Validation Responsible or a Version shall be captured, or the awaited content of the different sections of the document…<br/>A DocumentSpecification can have one to many DocumentNature (like a mail corresponding to a welcome notification and containing advertising).<br/>A DocumentSpecification can have one to several file type (DocumentFileType) and a type of file may be managed by zero to several Software.<br/>A DocumentSpecification can use a Document as pattern (PatternDocument) in case of automatically generated documents. The later specifies fixed content (simple text) and elements that have to be retrieved to build the final document. These elements might be either simple information, or Document or DocumentSpecification.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA9_EA7252" ;
    skos:prefLabel "DocumentSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7253> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7195> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA9_EA7253" ;
    skos:prefLabel "Figure R.01 - View of the RootEntity Class"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7254> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7195> ;
    skos:definition "A GeneratedDocument is a specialization of Document. It corresponds to a Document generated using a DocumentSpecification and a PatternDocument (like a welcome email customized for a new customer or like a letter of formal notice for a customer who did not pay his invoices).<br/>A GeneratedDocument is a type of Document.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA9_EA7254" ;
    skos:prefLabel "GeneratedDocument"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7255> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7195> ;
    skos:definition "A PatternDocument is a specialization of Document. It corresponds to a Document specifying the background and the variables to fill in order to produce, according to DocumentSpecification, a GeneratedDocument.<br/>A PatternDocument is a type of Document.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA9_EA7255" ;
    skos:prefLabel "PatternDocument"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7260> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7195> ;
    skos:definition "SimpleDocument is a specialization of Document. It corresponds to an unstructured simple document like basic unformatted text or image.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA9_EA7260" ;
    skos:prefLabel "SimpleDocument"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7262> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7261> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA9_EA7262" ;
