<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA6_EA4597> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA6_EA4596> ;
