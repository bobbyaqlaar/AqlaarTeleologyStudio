<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA3_EA1_EA5108> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA3_EA1_EA5107> ;
    skos:definition "Values of the MetricDimension used by a MetricDefinition, for example for payment timing dimension values can be prepaid or postpaid.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA9_EA3_EA1_EA5108" ;
    skos:prefLabel "MetricDefDimValueUse"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA3_EA1_EA5109> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA3_EA1_EA5107> ;
    skos:definition "The use of a dimension by MetricDefinition<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA9_EA3_EA1_EA5109" ;
    skos:prefLabel "MetricDefinitionDimensionUse"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA3_EA1_EA5110> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA3_EA1_EA5107> ;
    skos:definition "A metric dimension designates a method of organizing individual metrics into common sets, related by the value of the named dimension. An example would be a metric for revenue--individual instance values of revenue could be organized in the dimension of geography (Region 1 Revenues, Region 2 Revenues, etc.), or by Product (Wireless Revenue, Wire-line Revenue, Broadband Revenue, Advertising Revenue, etc.). The characteristic term when discussing Dimension is \"by\", as in \"Revenue, by Product\" or \"Revenue, by Region\".<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA9_EA3_EA1_EA5110" ;
    skos:prefLabel "MetricDimension"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA3_EA1_EA5111> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA3_EA1_EA5107> ;
    skos:definition "A value that a MetricDimension can take on.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA9_EA3_EA1_EA5111" ;
    skos:prefLabel "MetricDimensionValue"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA3_EA5092> a skos:Concept ;
