<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA3_EA1_EA2586> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA3_EA1_EA2563> ;
    skos:definition "AIModelSpecification is a generalization of invariiant characteristic attributes and associations that are common to AIModels. This characterizes things like the expected behavior, performance, and accuracy of an Artificial Intelligence (AI) model. It may include requirements and constraints that the AI model must meet in order to be considered successful, reliable, and trustworthy. Multiple AIModelSpecifications may arise due to multi-task learning, domain adapatation, model ensembling, hybridization etc. <br/><br/>AIModelSpecifcations also capture the invariant characteristics and behavior (attributes, methods, constraints, and relationships) of an AI Model - managed or unmanaged - such as i/o behavior, accuracy and precision, robustness and stability, interpretability, fairness and biass, scalability and performance (altogether called Model data sheet), data requirements, model updates and maintenance etc. AIModelSpecification define common characteristics and behavior of AIModels.<br/><br/>AIModelSpecifiation might be related to each other (AIModelSpecificationRelationship) with relationship type such as migration, substitution, dependency, or exclusivity.<br/><br/>Some charcteristics value of AI Specification include architecture of the AI Model, the type of learning used by the AI Model, and derivate sub-types applicable etc.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA2_EA3_EA1_EA2586" ;
    skos:prefLabel "AiModelSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA3_EA1_EA2587> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA3_EA1_EA2563> ;
    skos:definition "Maintains a record of changes made to the specifications of an AI model over time.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA2_EA3_EA1_EA2587" ;
    skos:prefLabel "AiModelSpecificationHistory"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA3_EA1_EA2588> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA3_EA1_EA2563> ;
