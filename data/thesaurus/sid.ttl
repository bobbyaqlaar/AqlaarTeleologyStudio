    skos:notation "sid:EARoot_EA4_EA2_EA10_EA9_EA5_EA5142" ;
    skos:prefLabel "Metric Measure ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA2_EA6598> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "The Currency ABE groups main entities within currency model.<br/>"@en ;
