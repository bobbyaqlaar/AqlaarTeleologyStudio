    skos:prefLabel "Figure AnMP.02 - AnomalyManagement Plan"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA16_EA3_EA5967> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA16_EA3_EA5971> ;
    skos:definition "The following figure shows the relationship between AnomalyManagementPlan, AnomalyManagementPlanSpecification with Anomaly and AnomalySpecification respectively. <br/><br/>AnomalyManagementPlan and AnomalyManagementPlanSpecification makes use of the same characteristic pattern as does other Anomaly entities.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA16_EA3_EA5967" ;
    skos:prefLabel "Figure AnMP.03 - AnomalyManagement Plan Entity Associations"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA16_EA3_EA5969> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA16_EA3_EA5971> ;
    skos:definition "Following is the state model for an Anomaly Management Plan:<br/><br/><ul><li>Designed : Initial state of the Anomaly Management Plan where the management plan attributes are populated as per the use case requirement </li></ul><ul><li>UnderReview : Designed Anomaly Management Plan is under Review by relevant stakeholders </li></ul><ul><li>Certified : Anomaly Management Plan is Reviewed and found valid , If it is not valid the Plan is rejected and the state moves back to Designed </li></ul><ul><li>Assigned: Certified Anomaly Management Plan is Assigned for managing an Anomaly stage . If the management plan is no longer applicable for the Anomaly it is unassigned and state moves back to Certified </li></ul><ul><li>Active : An Assigned Anomaly Management Plan is activated , the deactivation moves the Management plan back into assigned state </li></ul><ul><li>Archive : A Designed Anomaly Management plan is not relevant and archived. The archived Anomaly Management Plan can be recovered and cycled back through the review and certification stage</li></ul><p/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA16_EA3_EA5969" ;
    skos:prefLabel "Figure AnMP.04 - Anomaly Management Plan Lifecycle"@en .

