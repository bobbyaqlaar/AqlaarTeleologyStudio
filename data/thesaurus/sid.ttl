    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA2_EA1_EA4040" ;
    skos:prefLabel "PartySecurityEntity"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA1_EA4041> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA1_EA4037> ;
    skos:definition "The resource involved in Enterprise Security<br/>"@en ;
