    skos:prefLabel "GeographicPostcode"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA7084> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA7071> ;
