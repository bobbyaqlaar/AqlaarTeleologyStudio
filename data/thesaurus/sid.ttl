    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Physical Role </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA3158" ;
    skos:prefLabel "Figure PhyR.01 - Physical Role ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA3162> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA3160> ;
    skos:definition "This is representing the different types of roles that various physical resources can take on. Two specialized roles have been defined: holder and adapter. This enables a single object, such as a Card, to have additional functions. For example, a Card may also serve as a motherboard or hosting board for another Card. In this situation, there isn’t a separate EquipmentHolder - rather, the Card acts as a holder in addition to providing its normal functions.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA8_EA3162" ;
    skos:prefLabel "PhysicalResourceRole"@en .

