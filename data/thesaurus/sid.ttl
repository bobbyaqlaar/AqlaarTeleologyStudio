<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA2_EA4551> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA2_EA4549> ;
    skos:definition "A quality or distinctive feature that defines an entity. The characteristic can be take on a discrete value, such as color, can take on a range of values, (for example, sensitivity of 100-240 mV), or can be derived from a formula (for example, usage time (hrs) = 30 - talk time *3).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA2_EA4551" ;
    skos:prefLabel "CharacteristicSpecification"@en .

