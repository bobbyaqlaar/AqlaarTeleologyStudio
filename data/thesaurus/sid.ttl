    skos:prefLabel "Figure MD.01 - Metric Definition ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA3_EA5095> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA3_EA5094> ;
