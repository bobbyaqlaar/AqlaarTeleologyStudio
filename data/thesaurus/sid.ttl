<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA2_EA1258> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA2_EA1230> ;
    skos:definition "A SalesQuoteAgreement is a type of ContractualAgreement. It enables tracking the approval made by the Party within CSP for the SalesQuote.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA4_EA2_EA1258" ;
    skos:prefLabel "SalesQuoteAgreement"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA2_EA1259> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA2_EA1230> ;
    skos:definition "SalesQuoteSpecification is used to define the common characteristics (attributes, constraints and relationships) of a SalesQuote i.e. CSP would have a pre-defined template (specification) to generate the quote for different customer segments &/or products.<br/><br/>e.g. SalesQuote specification might be different depending on type of products. The quote specs for broadband products will differ from those for mobile.<br/><br/>Need examples of differences<br/><br/>e.g. the SaleQuote specification might be different depending on the size of enterprise lead. The quote generated for SOHO (Small Office Home Office) may be in a different format to that for an SME (Small and Medium sized Enterprises).<br/><br/>e.g. MPLS multi-protocol label switching. Though it is one overarching complex product it has multiple subtypes of products that should be included in the SalesQuote.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA4_EA2_EA1259" ;
    skos:prefLabel "SalesQuoteSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA2_EA1260> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA2_EA1230> ;
    skos:definition "A SalesQuoteSpecificationType is a Classification that groups SalesQuoteSpecification.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA4_EA2_EA1260" ;
    skos:prefLabel "SalesQuoteSpecificationType"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA2_EA1261> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA2_EA1230> ;
    skos:definition "Shopping Cart entity is used for the temporarily selection and reservation of product offerings in e-commerce and retail purchase. Shopping cart supports purchase of both tangible and intangible goods and service (e.g. handset, telecom network service). The charge includes the one-off fee such as the fee for handset and the recurring fee such as the fee of a network service.<br/><br/>It is mainly used in case of unknown customer with only a ContactMedium instead of a Party and PartyRole with their ContactMedium.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA4_EA2_EA1261" ;
    skos:prefLabel "ShoppingCart"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA2_EA1262> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA2_EA1230> ;
    skos:definition "A shopping cart offering item is decomposed into one or more shopping cart item. Cart item represents a reference to product in case of configured characteristic or installation address.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA4_EA2_EA1262" ;
    skos:prefLabel "ShoppingCartItem"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA2_EA1263> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA2_EA1230> ;
    skos:definition "A shopping cart is decomposed into one or more shopping cart offering item. Cart Offering item represents a reference to product offering instance selected and configured associated characteristics.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA4_EA2_EA1263" ;
    skos:prefLabel "ShoppingCartOfferingItem"@en .

