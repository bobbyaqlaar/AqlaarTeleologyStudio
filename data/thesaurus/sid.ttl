    skos:prefLabel "LAN Protocols ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA1_EA3090> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3074> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA1_EA3090" ;
    skos:prefLabel "Auxiliary Component ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA5_EA3138> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3074> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA5_EA3138" ;
    skos:prefLabel "Physical Capacity ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA2_EA1_EA3530> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA2_EA3524> ;
    skos:definition "The Example Party Role Product Specification Entities ABE contains examples of more explicit modeling for PartyRoleProductSpecifications.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA2_EA1_EA3530" ;
    skos:prefLabel "Example Party Role Product Spec Entities ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA3_EA3639> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA2_EA3576> ;
    skos:definition "The Party Revenue Sharing Reconciliation ABE ensures that two sets of party revenue sharing records are aligned and agreed upon. For example, an enterprise may receive an invoice from another party that is compared to the revenue share that has been determined to be shared with the party contained in the Party Revenue Share ABE.<br/>Reconciliation includes comparing what is received with what is to be paid, invoiced or credited/debited to an bill/invoice or account balance, identifying and resolving discrepancies, identifying adjustments to revenue to be shared, and tracking discrepancy resolution.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA2_EA3_EA3639" ;
    skos:prefLabel "Party Revenue Share Reconciliation ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA496> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA477> ;
    skos:definition "The Revenue Assurance area of the SID provides revenue assurance controls, revenue assurance violations, revenue assurance key performance indicators (KPIs), revenue assurance objectives, and rules that map revenue assurance KPIs and threshold violations to revenue assurance trouble tickets. Additionally, the scope of Revenue Assurance includes revenue assurance actions/responses that reconcile revenue assurance trouble tickets and bring the trouble tickets to closure.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA3_EA496" ;
    skos:prefLabel "Revenue Assurance ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA579> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA563> ;
    skos:definition "The Policy Domain consists of a set of layered ABEs that define specifications (e.g., templates) and definitions of Policy entities that can be used in managing the behavior and definition of entities in other Domains. Policy takes three primary forms. The first is the definition of how policy is used to manage the definition, change, and configuration of other entities. The second is the definition of how policy itself is managed. The third is how applications use policies to manage entities.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA579" ;
    skos:prefLabel "Policy ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA601> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA579> ;
    skos:definition "The Policy ABE contains entities that are used to represent the various components of a Policy. These components center around the concept of a PolicyRule, which is a triplet defined as:<br/><br/> {event, condition, action}<br/><br/>This has the semantics of: \"ON receipt of an event, IF the condition clause is TRUE, THEN execute a set of actions. A novel feature of this ABE is that the same triplet can be used to form condition and action clauses. This ABE also contains the ability to group and nest PolicyRules and their components.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA601" ;
    skos:prefLabel "Policy Structure ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA666> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA661> ;
    skos:definition "The Product Offering ABE describes tangible and intangible goods made available for a certain price to the market in the form of product catalogs. This ABE is also responsible for targeting market segments based on the appropriate market strategy. <br/><ul><li>.\\doc\\Figure Tax.02 - Tax ProductOfferingPriceAlteration and ProductPriceAlteration.docx </li><li>.\\doc\\Figure Tax.03 - Tax Exemption.docx </li><li>.\\doc\\Figure Pr.21 - Complete Product Price Rule Model.docx </li><li>.\\doc\\Figure Pr.25 - PolicySet Association with Business Interaction.docx</li></ul><p/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA6_EA666" ;
    skos:prefLabel "Product Offering Specification ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA11_EA5_EA2_EA5458> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA11_EA5_EA5440> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA11_EA5_EA2_EA5458" ;
    skos:prefLabel "Policy Condition ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA11_EA5_EA5440> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA11_EA5356> ;
    skos:definition "The Policy Structure ABE contains entities that are used to represent the various components of a Policy. These components center around the concept of a PolicyRule, which is a triplet defined as:<br/> {event, condition, action}<br/>This has the semantics of: \"ON receipt of an event, IF the condition clause is TRUE, THEN execute a set of actions. A novel feature of this ABE is that the same triplet can be used to form condition and action clauses. This ABE also contains the ability to group and nest PolicyRules and their components.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA11_EA5_EA5440" ;
    skos:prefLabel "Policy Structure ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA14_EA1_EA5784> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA14_EA5770> ;
    skos:definition "<span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);font-family:Arial;font-size:13px;\"><span style=\"-webkit-text-stroke-width:0px;display:inline !important;float:none;font-style:normal;font-variant-caps:normal;font-variant-ligatures:normal;font-weight:400;letter-spacing:normal;orphans:2;text-align:start;text-decoration-color:initial;text-decoration-style:initial;text-decoration-thickness:initial;text-indent:0px;text-transform:none;white-space:normal;widows:2;word-spacing:0px;\">The Usage Entity ABE collects consumption information, and generates Usage according to UsageSpecification for use by other business entities.</span></span><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA14_EA1_EA5784" ;
    skos:prefLabel "Usage Entity ABE"@en .

