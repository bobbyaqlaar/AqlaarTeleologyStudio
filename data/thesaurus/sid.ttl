<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA4_EA2634> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA2456> ;
    skos:definition "The Physical Resource Specification ABE describes the invariant characteristics and behavior (attributes, methods, constraints, and relationships) of a PhysicalResource.<br/>"@en ;
