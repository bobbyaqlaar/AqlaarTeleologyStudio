<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1_EA2_EA1844> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1_EA2_EA1843> ;
    skos:definition "A ConsumptionSummary give measures about the usage quantity consumed.<br/><br/>It might concern UsageVolumeBalances and / or UsageVolumeProducts and / or NetworkProducts and / or ProductUsers.<br/><br/>A ConsumptionSummary aggregates UsageVolumeBalanceCredits and / or UsageVolumeBalanceDebits and / or AppliedCustomerBillingProductUsageRates.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA1_EA2_EA1844" ;
    skos:prefLabel "ConsumptionSummary"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1_EA2_EA1845> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1_EA2_EA1843> ;
    skos:definition "A NetworkProduct is a type of ProductComponent described by a NetworkProductSpec.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA1_EA2_EA1845" ;
    skos:prefLabel "NetworkProduct"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1_EA3_EA1846> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1_EA3_EA1848> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Usage Volume Product</b> Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA1_EA3_EA1846" ;
    skos:prefLabel "Figure UVP.01 - Usage Volume Product ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1_EA3_EA1849> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1_EA3_EA1848> ;
    skos:definition "The UsageVolumeBalance carries for a time period the results of credits and debits related to a UsageVolumeProduct.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA1_EA3_EA1849" ;
    skos:prefLabel "UsageVolumeBalance"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1_EA3_EA1850> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1_EA3_EA1848> ;
    skos:definition "The UsageVolumeBalanceCredit represents an amount in a certain unit that credits the UsageVolumeBalance.<br/><br/>The UsageVolumeBalanceCredit is the result of applying a particular UsageVolumeChargingRule specifying the way to credit the balance (it can be a on-time or recurrent credit) and increments the balance of the UsageVolumeProduct (UsageVolumeBalance).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA1_EA3_EA1850" ;
    skos:prefLabel "UsageVolumeBalanceCredit"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1_EA3_EA1851> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1_EA3_EA1848> ;
    skos:definition "The UsageVolumeBalanceDebit represents an amount in a certain unit that decrements the UsageVolumeBalance.<br/><br/>The UsageVolumeBalanceDebit is the result of applying a particular UsageVolumeChargingRule for a ProductUsage and decrements the balance of the UsageVolumeProduct (UsageVolumeBalance).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA1_EA3_EA1851" ;
    skos:prefLabel "UsageVolumeBalanceDebit"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1_EA3_EA1852> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1_EA3_EA1848> ;
    skos:definition "The UsageVolumeBalanceEntry represents an amount in a certain unit that either credits or decrements the UsageVolumeBalance.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA1_EA3_EA1852" ;
    skos:prefLabel "UsageVolumeBalanceEntry"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1_EA3_EA1853> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1_EA3_EA1848> ;
    skos:definition "A UsageVolumeProduct is a type of ProductComponent described by a UsageVolumeProductSpec that carries UsageVolumeBalances.<br/><br/>A UsageVolumeProduct relies on one or many NetworkProducts.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA1_EA3_EA1853" ;
    skos:prefLabel "UsageVolumeProduct"@en .

