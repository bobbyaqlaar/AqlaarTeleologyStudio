<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1687> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1676> ;
