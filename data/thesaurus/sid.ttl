<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA833> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA830> ;
    skos:definition "The Resource Facing Service Role ABE defines ResourceServiceRoles that are used to represent the variable characteristics of a ResourceFacingService in terms of roles that this type of Service plays.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA833" ;
    skos:prefLabel "Resource Facing Service Role ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA834> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA811> ;
    skos:definition "The Service Specification ABE contains entities that define the invariant characteristics and behavior of both types of Service entities. This enables multiple instances to be derived from a single specification entity. In this derivation, each instance will use the invariant characteristics and behavior defined in its associated template.<br/><br/>This ABE includes a third type of Service Specification entity: that of a ServiceLevelSpecification. This type of specification templatizes Services that are bound to a Service Level Agreement.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA834" ;
    skos:prefLabel "Service Level Spec ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA835> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA811> ;
    skos:definition "The Service Performance Specification ABE defines measure of the manner in which a Service is functioning.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA835" ;
    skos:prefLabel "Service Performance Specification ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA836> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA840> ;
    skos:definition "The Service Package Spec Examples ABE contains example subclasses of ServicePackageSpecs.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA836" ;
    skos:prefLabel "Service Package Spec Examples ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA837> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA826> ;
    skos:definition "The Customer Facing Service Spec Examples ABE contains example subclasses of CustomerFacingServiceSpecs.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA837" ;
    skos:prefLabel "Customer Facing Service Spec Examples ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA838> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA826> ;
    skos:definition "The Customer Facing Service Spec Role ABE defines a ServiceSpecification, in terms of a set of ServiceSpecificationRoles, for a CustomerFacingService. It is used to represent the shared characteristics of a CustomerFacingService. This enables the CustomerFacingService to be managed abstractly using ServiceSpecificationRoles. It also helps define a CustomerFacingServiceSpecification in terms of the functions that it has or provides.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA838" ;
    skos:prefLabel "Customer Facing Service Spec Role ABE"@en .

