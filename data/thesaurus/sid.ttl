<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA2_EA6780> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA2_EA6777> ;
    skos:definition "CashPM is an example of payment method, through which payment can be made by cash.<br/>"@en ;
