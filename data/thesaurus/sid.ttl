<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA3_EA1_EA2907> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA3_EA1_EA2906> ;
    skos:definition "An API, an abbreviation of application program interface, is a set of routines, protocols, and tools for building software applications.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA3_EA1_EA2907" ;
    skos:prefLabel "API"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA3_EA1_EA2908> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA3_EA1_EA2906> ;
    skos:definition "This is an abstract class for representing atomic units of Software that are individually manageable and do NOT form composite, or nested, software units.<br/><br/><br/><br/>From a finite state machine view, each AtomicInstalledSoftware element is not just individually manageable, but is also installable, executable, and runnable. In addition, each AtomicInstalledSoftware element can be a FRU.<br/><br/><br/><br/>This is the super-class for creating concrete subclasses that define particular functionality (e.g., a device driver, or software that implements MPLS as part of a larger routing software package).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA3_EA1_EA2908" ;
    skos:prefLabel "AtomicInstalledSoftware"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA3_EA1_EA2909> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA3_EA1_EA2906> ;
    skos:definition "A CompositeInstalledSoftware represents software units that are made up of other software units (i.e., instances of this class as well as the AtomicInstalledSoftware). This provides the semantics of collecting a set of components, each of which is individually manageable, and being able to manage the set of objects as a whole. An example is an operating system - this is manageable as a unit, but consists of individually manageable components. This containment is modeled using the CompositeInstalledSoftwareComprisedOf composition.<br/><br/><br/><br/>From a finite state machine view, each CompositeInstalledSoftware element is manageable, installable, executable, and runnable. In addition, each CompositeInstalledSoftware element can be a FRU.<br/><br/><br/><br/>This is the super-class for creating concrete subclasses that define groups of functionality (e.g., set of features that work together to provide application-level functionality to the end-user).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA3_EA1_EA2909" ;
    skos:prefLabel "CompositeInstalledSoftware"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA3_EA1_EA2910> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA3_EA1_EA2906> ;
    skos:definition "A ConfigurationFeature is a type of Entity described by a ConfigurationFeatureSpec.<br/>It is used to expose one or several ResourceFunctions to a consumer in such a way that it is easier to configure these RFunctions from a consumer view point.<br/>A ConfigurationFeature may have characteristics configured according to the possible configurations specified by the ConfigurationFeatureSpec.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA3_EA1_EA2910" ;
    skos:prefLabel "ConfigurationFeature"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA3_EA1_EA2911> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA3_EA1_EA2906> ;
    skos:definition "A HostingPlatformRequirement implements a HostingPlatformRequirementSpec for a specific InstalledSoftware.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA3_EA1_EA2911" ;
    skos:prefLabel "HostingPlatformRequirement"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA3_EA1_EA2912> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA3_EA1_EA2906> ;
    skos:definition "An InstalledSoftware (renaming the Software concept from previous releases) consists of encoded information or computer instructions deployed on a machine such that it can be executed. An InstalledSoftware is a SoftwareSpecification deployed using the SoftwareSupportPackage on platform which meets the HostingPlatformRequirements.<br/><br/>Each InstalledSoftware specifies their input and output respectively with SoftConnectionPoints.<br/><br/><br/><br/>Software may be nested within other software, thereby creating a containment relationship.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA3_EA1_EA2912" ;
    skos:prefLabel "InstalledSoftware"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA3_EA1_EA2913> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA3_EA1_EA2906> ;
    skos:definition "This class defines the semantics of the PartyRoleSoftwareLicenses association. Its attributes help specify the licensing details for this particular SoftwareResource instance. This association defines the semantics of how a given PartyRole legally uses particular SoftwareResource Features.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA3_EA1_EA2913" ;
    skos:prefLabel "PartyRoleSoftwareLicenseDetails"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA3_EA1_EA2914> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA3_EA1_EA2906> ;
    skos:definition "This class defines the semantics of the PartyRoleUsesProcesses association. Since different PartyRoles have different privileges for working on and running the SoftwareResource, an association class is needed to accurately model these details. This association defines the semantics of how a particular PartyRole uses this SoftwareResource instance.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA3_EA1_EA2914" ;
    skos:prefLabel "PartyRoleUsesProcessesDetails"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA3_EA1_EA2915> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA3_EA1_EA2906> ;
    skos:definition "A statisitic that documents the use of a Resource by Software that is running.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA3_EA1_EA2915" ;
    skos:prefLabel "RunningSoftwareStatistic"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA3_EA1_EA2916> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA3_EA1_EA2906> ;
    skos:definition "A SoftConnectionPoint realizes a ConnectionPoint and implements a SoftConnectionPointSpec.<br/>"@en ;
