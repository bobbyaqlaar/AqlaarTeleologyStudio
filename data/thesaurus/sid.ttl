<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA14_EA2_EA5792> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA14_EA5770> ;
    skos:definition "The Usage Specification ABE specifies usage in a generic way and its related characteristics.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA14_EA2_EA5792" ;
    skos:prefLabel "Usage Specification ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA16_EA3_EA5976> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA16_EA3_EA5971> ;
    skos:definition "Abstract class that represents the management plan for Anomaly. The plan may be used by an Anomaly Management component to configure the management tasks. Specific plan for each stage of anomaly management may be reprented using the inherited classes of the AnomalyManagementPlan such as AnomalyPredictionManagementPlan, AnomayDetectionManagementPlan, AnomalyMitigationManagementPlan etc.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA16_EA3_EA5976" ;
    skos:prefLabel "AnomalyManagementPlan"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA23_EA6422> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA23_EA6398> ;
    skos:definition "A list of Projected Cost Items items which<br/>are part of the overall projected cost.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA23_EA6422" ;
    skos:prefLabel "ProjectedCostItem"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA1_EA4672> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4_EA4643> ;
    skos:definition "A request by an external party (Customer or other Engaged Party) to change the amount it is required to pay the enterprise.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA4_EA1_EA4672" ;
    skos:prefLabel "Disputed Amount ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA1_EA6588> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA6546> ;
    skos:definition "The Contact Medium ABE describes various means by which a PartyRole or PartyAccount/BillingAccountContact can be reached, such as by telephone, fax, email.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA1_EA6588" ;
    skos:prefLabel "Contact Medium ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA1_EA3_EA1_EA986> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA1_EA3_EA974> ;
    skos:definition "Competitor Intelligence ABE contains facts gathered about a Competitor's plans and activities. These facts can be used to perform Competitor SWOT analysis in order to better understand a Competitor.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA1_EA3_EA1_EA986" ;
    skos:prefLabel "Competitor Intelligence ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA11_EA1444> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA11_EA1441> ;
    skos:definition "A CustomerBillingDispute materializes the fact that a Customer disagrees with one or several invoices (CustomerBill) or one or several charges (AppliedCustomerBillingCharge).<br/>CustomerBillingDispute has a lifecyle. This lifecycle describes the different steps of its processing.<br/>CustomerBillingDispute is a result of a CommunicationInteraction. It can be associated to a CustomerBillInquiry.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA4_EA11_EA1444" ;
    skos:prefLabel "CustomerBillingDispute"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA10_EA2014> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA1458> ;
    skos:definition "<b>Product Capacity ABE</b> represents specific ability of Products measured in quantity and units of quantity over an extended period.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA10_EA2014" ;
    skos:prefLabel "Product Capacity ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA7_EA1_EA1956> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA7_EA1948> ;
    skos:definition "The Loyalty Program ABE contains all entities needed to instantiate a loyalty program for a specific customer such as LoyaltyProgram and LoyaltyAccount.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA7_EA1_EA1956" ;
    skos:prefLabel "Loyalty Program ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA3_EA2_EA2158> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA3_EA2092> ;
    skos:definition "The Resource Facing Service Spec ABE defines the common characteristics for a set of ResourceFacingServices. This scales by enabling multiple ResourceFacingServiceSpecs to be defined to model the common characteristics of different groups of ResourceFacingServices.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA6_EA3_EA2_EA2158" ;
    skos:prefLabel "Resource Facing Service Spec ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA4_EA2_EA2250> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA4_EA2208> ;
    skos:definition "The Service ABE contains entities that are used to represent two fundamentally different types of Services, called CustomerFacingServices and ResourceFacingServices.<br/>A CustomerFacingService defines the characteristics of a particular Service that represents a realization of a Product within an organization's infrastructure. In contrast, a ResourceFacingService is an abstraction that defines the characteristics of a particular Service which support the network/infrastructure facing part of the service. For example, a VPN is an example of a CustomerFacingService, while the sub-services that perform different types of routing between network devices making up the VPN are examples of ResourceFacingServices. ResourceFacingServices are \"internal\" Services that are required to support a CustomerFacingService.<br/>Entities in this ABE provide different views to examine, analyze, configure, monitor and repair Services of all types. Entities in this ABE are derived from Service Specification entities.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA6_EA4_EA2_EA2250" ;
    skos:prefLabel "Resource Facing Service ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA5_EA2275> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA2023> ;
    skos:definition "The <b>Service Configuration ABE</b> represents the specification of the different possible Service configurations as well as the Service Configurations instantiated for a Service.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA6_EA5_EA2275" ;
    skos:prefLabel "Service Configuration ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA7_EA2296> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA2023> ;
    skos:definition "The <b>Service Usage ABE</b> represents the specification of Service Usage types and collects Service Usage records with their characteristics (a.k.a. consumption data).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA6_EA7_EA2296" ;
    skos:prefLabel "Service Usage ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA3_EA4_EA2_EA2624> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA3_EA4_EA2610> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA2_EA3_EA4_EA2_EA2624" ;
    skos:prefLabel "Software Specification ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA2_EA3119> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA3107> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA4_EA3_EA2_EA3119" ;
