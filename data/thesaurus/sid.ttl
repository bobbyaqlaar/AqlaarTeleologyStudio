    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA1_EA1_EA7107" ;
    skos:prefLabel "JapanesePropertyAddress"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA1_EA7108> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA1_EA7100> ;
    skos:definition "An address that allows sending something (tangible or intangible) to a central point where it can be retrieved.<br/><br/><br/><br/>For example, with email, a message is sent to the recipient’s ISP mail server. The recipient can then connect to the server from anywhere in the world and retrieve the message. The intermediate location is not of interest to the message sender.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA1_EA1_EA7108" ;
    skos:prefLabel "LogicalAddress"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA1_EA7109> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA1_EA7100> ;
    skos:definition "An optional component of a PostalDeliveryAddress that reprsents a post office box number.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA1_EA1_EA7109" ;
    skos:prefLabel "PoBoxAddress"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA1_EA7110> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA1_EA7100> ;
    skos:definition "The address to which posts (mail) are delivered.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA1_EA1_EA7110" ;
    skos:prefLabel "PostalDeliveryAddress"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA1_EA7111> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA1_EA7100> ;
    skos:definition "An association between Property and UrbanPropertyAddress that provides the address of the Property.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA1_EA1_EA7111" ;
    skos:prefLabel "PropertyAddressAssociation"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA1_EA7112> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA1_EA7100> ;
    skos:definition "An type of address used for addressing within a property. It may refer to a building, a building cluster, or a floor of a multistory building.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA1_EA1_EA7112" ;
    skos:prefLabel "PropertySubAddress"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA1_EA7113> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA1_EA7100> ;
    skos:definition "An UrbanPropertyAddress is a structured textual way of describing how to find a Property in an urban area (country properties are often defined differently). It is usually composed of an ordered list of Location names based on context specific rulesThis is an example of a concrete Geographic Location entity.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA1_EA1_EA7113" ;
    skos:prefLabel "UrbanPropertyAddress"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA1_EA7114> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA1_EA7100> ;
    skos:definition "An UrbanPropertySubAddress is used for addressing within a property in an urban area (country properties are often defined differently).. It may refer to a building, a building cluster, or a floor of a multistory building.This is an example of a concrete Geographic Location entity.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA1_EA1_EA7114" ;
    skos:prefLabel "UrbanPropertySubAddress"@en .

