<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA11_EA5371> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA11_EA5356> ;
    skos:definition "{must have 1..n PDPs}<br/>{1..n PEPs}<br/>{and 1..n PXPs}<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA11_EA5371" ;
    skos:prefLabel "EARoot_EA4_EA2_EA10_EA11_EA5371"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA11_EA5372> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA11_EA5356> ;
    skos:definition "{must have 1..n PDPS}<br/>{1..n PEPs}<br/>{and 1..n PXPs}<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA11_EA5372" ;
    skos:prefLabel "EARoot_EA4_EA2_EA10_EA11_EA5372"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA11_EA5373> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA11_EA5356> ;
