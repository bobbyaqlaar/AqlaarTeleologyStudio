<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA549> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA563> ;
    skos:definition "ClosedLoopWorkflow represents all the information needed to capture a workflow that realizes a specific objective in support of a ClosedLoop goal. <br/><br/>Two or more workflows constitute a ClosedLoop - the control or decision workflow(s), and the feedback workflow(s). Any these workflows that support the mandate of a ClosedLoop is identified as a ClosedLoopWorkflow. These ClosedLoop workflows are managed entities. Workflows in general may contain more than one activity necessary to realize an objective or an atomic goal.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA549" ;
    skos:prefLabel "Patterns Domain Level 1"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA551> a skos:Concept ;
