<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1_EA1817> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1_EA1816> ;
    skos:definition "An AtomicProduct is an instantiation of an AtomicProductSpecification which keeps the place where the product is in use, as well as configuration characteristics, such as assigned telephone numbers and internet addresses.<br/><font color=\"#29313b\">An AtomicProduct might be contained in one or many CompositeProducts.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA1_EA1817" ;
    skos:prefLabel "AtomicProduct"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1_EA1818> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA1_EA1816> ;
    skos:definition "A CompositeProduct is an instantiation of CompositeProductSpecification which keeps the place where the product is in use, as well as configuration characteristics, such as assigned telephone numbers and internet addresses.<br/>A CompositeProduct contains at least one Product itself Composite or Atomic.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA4_EA1_EA1818" ;
    skos:prefLabel "CompositeProduct"@en .

