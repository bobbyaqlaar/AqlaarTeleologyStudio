<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7216> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA9_EA7195> ;
    skos:definition "If a paper document is scanned, by the current model, the paper document and the scan/pdf are two different documents, but from the business perspective, they are two representations of the same document. The model needs to differentiate between the business document, and the representation/instantiation. Perhaps document Copy is what has the form/file type, and Document might be the anchor that ties document copies together?<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA9_EA7216" ;
    skos:prefLabel "EARoot_EA4_EA2_EA11_EA9_EA7216"@en .

