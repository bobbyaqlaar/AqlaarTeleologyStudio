    skos:prefLabel "BusinessRulePartyRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6153> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6105> ;
    skos:definition "BusinessRuleSpecification specifies the details descriiption of a business rule. It includes details such as the specification's ID, name, description, creation date, validity period, associated business rule specification relationship ID, business rule group ID, business rule type ID, business rule ID, and rule application.<br/><br/>BusinessRuleSpecification defines, zero or one `BusinessRule`, classifies zero or more `BusinessRuleTypes`, identifies grouping characteristics of zero or more `BusinessRuleGroups`, and sets relationships between zero or more `BusinessRuleSpecificationRelationships`.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA18_EA1_EA6153" ;
    skos:prefLabel "BusinessRuleSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6154> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6105> ;
    skos:definition "Identifies associations or linkages between business rule specifications.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA18_EA1_EA6154" ;
    skos:prefLabel "BusinessRuleSpecificationRelationship"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6155> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6105> ;
    skos:definition "BusinessRuleSpecificationRelationshipCharacteristic defines the unique trait, quality or property that sets a business rule specification apart. It includes the characteristic's ID, name, description, creation date, and validity period. This class could represent the characteristics of the relationships between different business rule specifications.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA18_EA1_EA6155" ;
    skos:prefLabel "BusinessRuleSpecificationRelationshipCharacteristics"@en .

