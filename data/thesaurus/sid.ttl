<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA1_EA5_EA1062> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA1_EA5_EA1054> ;
    skos:definition "A type of MarketingCampaignCharacteristic that does not have any subordinate MarketingCampaignCharacteristics, that is, an AtomicMarketingCampaignCharacteristic is a leaf-level MarketingCampaignCharacteristic.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA1_EA5_EA1062" ;
    skos:prefLabel "AtomicMarketingCampaignCharacteristic"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA1_EA5_EA1063> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA1_EA5_EA1054> ;
    skos:definition "A type of MarketingCampaignCharacteristic that is formed by aggregating other MarketingCampaignCharacteristic, which may be Composite or Atomic MarketingCampaignCharacteristic.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA1_EA5_EA1063" ;
    skos:prefLabel "CompositeMarketingCampaignCharacteristic"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA1_EA5_EA1064> a skos:Concept ;
