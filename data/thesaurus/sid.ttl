    skos:notation "sid:EARoot_EA4_EA2_EA11_EA4_EA2_EA6778" ;
    skos:prefLabel "AccountBalancePM"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA4_EA2_EA6779> a skos:Concept ;
