<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA21_EA1_EA6275> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA21_EA1_EA6279> ;
    skos:definition "The figure illustrates the blueprint of a maturity model framework, with the MaturityModelSpecification defining one or more MaturityModel details. This specification pattern is applied to outline how MaturityModels can be evaluated using MaturityModelEvaluationMethodology and assessed using MaturityModelAssessmentMethodology. Methodologies rely on specific MaturityModelSpecChars, which represent the characteristics being evaluated. A MaturityModel itself operates within a defined MaturityModelContext, progresses through MaturityModelLifecyclePhases, and might have recommended MaturityModelAdoptionStrategies associated with it.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA21_EA1_EA6275" ;
    skos:prefLabel "Figure MMdlS.01 - Maturity Model Specification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA21_EA1_EA6277> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA21_EA1_EA6279> ;
    skos:definition "The Characteristic Pattern is applied to the Maturity Model concept per the following figure.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA21_EA1_EA6277" ;
    skos:prefLabel "Figure MMdlS.02 - Maturity Model Characteristics"@en .

