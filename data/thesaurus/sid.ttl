    skos:notation "sid:EARoot_EA4_EA2_EA11_EA3_EA1_EA6740" ;
    skos:prefLabel "Party Privacy Profile ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA1_EA8_EA1081> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA1_EA925> ;
    skos:definition "The <b>Market Statistics ABE</b> maintains market key performance indicators about Marketing revenue.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA1_EA8_EA1081" ;
