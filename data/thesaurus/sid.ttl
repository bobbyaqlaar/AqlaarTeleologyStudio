    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA4_EA2_EA1858> ;
    skos:definition "<font color=\"#29313b\">An AtomicProductOfferingInstance represents the instantiation of an AtomicProductOfferingSpecification for a specific Customer. An AtomicProductOfferingInstance contains a unique Product provided to a customer.</font><br/>"@en ;
