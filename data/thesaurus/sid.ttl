<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA8_EA1_EA1994> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA8_EA1_EA1987> ;
    skos:definition "A ProductActionType specifies the type of action such as create, update…<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA8_EA1_EA1994" ;
    skos:prefLabel "ProductActionType"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA8_EA1_EA1995> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA8_EA1_EA1987> ;
    skos:definition "A ProductConfigSpecAction specifies changes from one ProductConfigSpec to one or many ProductConfigSpec. It is described by a ProductActionType such as create, update, remove... It might be implied by one or many AllowedProductActions.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA8_EA1_EA1995" ;
    skos:prefLabel "ProductConfigSpecAction"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA8_EA1_EA1996> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA8_EA1_EA1987> ;
    skos:definition "ProductOfferingSpecificationMerge is a type of AllowedProductAction used to specify which merge action (or move) from a minimum of two source ProductOfferingSpecification to a destination ProductOfferingSpecification can be performed. As example, it can specify that the merge from a Mobile ProductOfferingSpecification and a triple play (Internet, fixed voice, TV) ProductOfferingSpecification to a four play (Mobile, Internet, fixed voice, TV) ProductOfferingSpecification is allowed.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA8_EA1_EA1996" ;
    skos:prefLabel "ProductOfferingSpecificationMerge"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA8_EA1_EA1997> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA8_EA1_EA1987> ;
    skos:definition "ProductOfferingSpecificationMigration is a type of AllowedProductAction used to specify which Migration action (or move) from one source ProductOfferingSpecification to one or several destination ProductOfferingSpecification can be performed. As example, it can specify that the migration from a Low Cost Mobile ProductOfferingSpecification to a Standard Mobile ProductOfferingSpecification or to a Premium Mobile ProductOfferingSpecification is possible.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA8_EA1_EA1997" ;
    skos:prefLabel "ProductOfferingSpecificationMigration"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA8_EA1_EA1998> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA8_EA1_EA1987> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA8_EA1_EA1998" ;
    skos:prefLabel "Quad Play Offer Merge: ProductOfferingSpecificationMerge"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA8_EA1_EA1999> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA8_EA1_EA1987> ;
    skos:inScheme thes:sid ;
