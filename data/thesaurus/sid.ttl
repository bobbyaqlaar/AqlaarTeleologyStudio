<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4814> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4808> ;
