<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA1_EA6740> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA3_EA6727> ;
    skos:definition "The Party Privacy Profile ABE contains all entities used by the Party Privacy Management process for specifying the choices made by Parties for their own Privacy.<br/>"@en ;
