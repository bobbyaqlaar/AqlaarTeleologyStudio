<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA1_EA3762> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA1_EA3764> ;
    skos:definition "The Enterprise Domain party roles presently identified are:<br/><ul><li><b>ServiceProvider</b>: An organization or individual which offers products to others in exchange for payment in some form.</li><li><b>ComplementaryProvider</b>: A type of ServiceProvider that complements another provider.</li><li><b>ThirdPartyProvider</b>: A ServiceProvider besides the two primarily involved in a situation.</li><li><b>ServiceProviderEmployee</b>: A Service ProviderEmployee is an Individual who is employed by the Service Provider for wages or salary. This is modeled as an Individual playing the role of ServiceProviderEmployee . A ServiceProviderEmployee is a type of PartyRole.</li><li><b>Regulator</b>: A party that supervises a particular industry or business activity</li></ul><p/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA1_EA3762" ;
    skos:prefLabel "Figure E.00 - Enterprise Party Roles"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA1_EA3765> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA1_EA3764> ;
    skos:definition "A type of ServiceProvider that complements another provider.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA1_EA3765" ;
    skos:prefLabel "ComplementaryProvider"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA1_EA3766> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA1_EA3764> ;
    skos:definition "A party that supervises a particular industry or business activity<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA1_EA3766" ;
    skos:prefLabel "Regulator"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA1_EA3767> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA1_EA3764> ;
    skos:definition "An organization or individual which offers products to others in exchange for payment in some form.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA1_EA3767" ;
    skos:prefLabel "ServiceProvider"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA1_EA3768> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA1_EA3764> ;
    skos:definition "A Service ProviderEmployee is an Individual who is employed by the Service Provider for wages or salary. This is modeled as an Individual playing the role of ServiceProviderEmployee . A ServiceProviderEmployee is a type of PartyRole.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA1_EA3768" ;
    skos:prefLabel "ServiceProviderEmployee"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA1_EA3769> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA1_EA3764> ;
    skos:definition "A ServiceProvider besides the two primarily involved in a situation.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA1_EA3769" ;
    skos:prefLabel "ThirdPartyServiceProvider"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA1_EA3826> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA1_EA3828> ;
    skos:definition "Following are the business entities aggregated under the <b>Employee Pay</b> ABE<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA1_EA3826" ;
    skos:prefLabel "Figure EP.01 - Employee Pay ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA1_EA3829> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA1_EA3828> ;
    skos:definition "EmployeePay describes pay information for an Employee such as salary, bonus or any other monetary benefits.<br/>This is useful reading all changes over a period of time. This is further defined with the frequency amount pay group.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA1_EA3829" ;
    skos:prefLabel "EmployeePay"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA1_EA3830> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA1_EA3828> ;
    skos:definition "EmployeePayComponent is where an Employee's components of pay is defined. Each section of their pay is defined as an individual line item and can have different frequencies or currencies.<br/>This entity includes effective dated history. Pay Component object stores all elements that are paid to employees like: base salary bonus target car allowance. <br/>For each pay component you need to define <br/>• If the component is recurring or a one time payment <br/>• If recurring the frequency <br/>• If it is paid as an absolute amount or percentage <br/><font color=\"#ff0000\">• If percentage what is it a percentage of (other Pay Component or Pay Component Group </font><br/>• If it is an earning or a deduction <br/>• If it is actual pay or target <br/>• If it is taxable or non-taxable <br/>• If it should be visible in Self Service <br/>• If it is used by compensation planning Recurring pay components such as base salary should be defined with recurring attribute set to “Yes” and target attribute set to “No”.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA1_EA3830" ;
    skos:prefLabel "EmployeePayComponent"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA1_EA3831> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA1_EA3828> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA1_EA3831" ;
    skos:prefLabel "Figure WFM.14-I01"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA1_EA3832> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA1_EA3828> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA1_EA3832" ;
    skos:prefLabel "Figure WFM.14-I02"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA1_EA3833> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA1_EA3828> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA1_EA3833" ;
    skos:prefLabel "Figure WFM.14-I03"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA1_EA3834> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA1_EA3828> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA1_EA3834" ;
    skos:prefLabel "Figure WFM.14-I04"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA1_EA3835> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA1_EA3828> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA1_EA3835" ;
    skos:prefLabel "Figure WFM.14-I05"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA1_EA3836> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA1_EA3828> ;
    skos:definition "PayComponentSpecification specifies components of a pay that might correspond to fixed salary, bonus...<br/>Some of them have fixed amount and other amount might not be pre-defined when it can be specific to an employee while respecting PayRange threshold (minimum and maximum pay).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA1_EA3836" ;
    skos:prefLabel "PayComponentSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA1_EA3837> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA1_EA3828> ;
    skos:definition "A pay grade is a step that defines the amount of pay an employee will receive. The pay grade may or may not be defined by the level of the responsibilities performed within the job description of the position the authority exercised by the position and the length of time the employee has performed the job. This is generally associated with the Pay Range providing further details of the grades steps and validity.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA1_EA3837" ;
    skos:prefLabel "PayGrade"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA1_EA3838> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA1_EA3828> ;
    skos:definition "Pay Group entity provides the capability to hold the information around the group of the employees/individuals which falls under the same category.<br/>This is further extended with the agency which executes the payroll as well as the frequency of the payment.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA1_EA3838" ;
    skos:prefLabel "PayGroup"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA1_EA3839> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA1_EA3828> ;
    skos:definition "PayRange defines a pay range for Employees. It specifies minimum, average and maximum amounts in the range.<br/>It provides information which is primarily used for the calculation of Compensation Ratio and Range Penetration. <br/>Usually Pay Range is linked to Pay Grade. <br/>By default Pay Range is defined by Geographical Zone, Pay Grade and Legal Entity. e.g. Organisation may define the PayRange associated with specific PayGrade. <br/>PayGrade G-1 - Sequence-1 can have Max Pay 70KGBP Avg Pay 60K GBP and Min Pay 50K GBP<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA1_EA3839" ;
    skos:prefLabel "PayRange"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA1_EA3840> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA1_EA3828> ;
    skos:definition "PayRollAgency is a PartyRole played by a Party being an equitable partner in a business interaction with other parties, playing the Agency involved in the PayRoll Execution for the Organisation.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA1_EA3840" ;
    skos:prefLabel "PayRollAgency"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA1_EA3841> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA1_EA3828> ;
    skos:definition "PaySpecification specifies PayComponents that are part of a Pay in a PayRange.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA1_EA3841" ;
    skos:prefLabel "PaySpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA2_EA3842> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA2_EA3844> ;
    skos:definition "Following are the business entities aggregated under the Work Specification Aggregate Business Entity.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA2_EA3842" ;
    skos:prefLabel "Figure WS.01 - Work Specification ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA2_EA3845> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA2_EA3844> ;
    skos:definition "Entity that is used in Planning and WorkSpecification configuration. Represents a rate that shows how many particular work tasks (quantity attribute) can be performed by a given organization in a given location (or serving areas) with a given capacity (Consumption Capacity attribute). For example, with 100 man hours of Fiber layout skills, 200 works of “Dig a trench for Underground Cable, 200m length” can be performed in an urban area by an organization.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA2_EA3845" ;
    skos:prefLabel "WorkSpecFulfillmentRate"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA2_EA3846> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA2_EA3844> ;
    skos:definition "WorkSpecification describes the characteristics of a type of (manual) work. The characteristic/characteristic value pattern may be applied for WorkSpecification (and work as an instance). For example, WorkSpecification could be “Assembly of server blade in a shelf”.<br/>A WorkSpecification can either be Atomic (in case of a basic WorkSpecification) or Composite (in the case of a complex WorkSpecification that may agregate several WorkSpecification).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA2_EA3846" ;
    skos:prefLabel "WorkSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA2_EA3847> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA2_EA3844> ;
    skos:definition "A monetary amount assigned to a WorkSpecification that represents the cost to the business to plan, develop, and implement the WorkSpecification.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA2_EA3847" ;
    skos:prefLabel "WorkSpecificationCost"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA2_EA3848> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA2_EA3844> ;
    skos:definition "This is an abstract base class that defines a WorkSpecification in terms of a set of roles which are then used to characterize the invariant functionality of the Work. For example, a specification of cable layout work can have the role of network build, or the role of a service fulfillment task.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA2_EA3848" ;
    skos:prefLabel "WorkSpecificationRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA2_EA3849> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA2_EA3844> ;
    skos:definition "A classification that groups WorkSpecifications that share common characteristics. For example, Equipment maintenance work type, or network trouble shooting type. This class can be used to present a “Catalog” of work specifications.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA2_EA3849" ;
    skos:prefLabel "WorkSpecificationType"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA2_EA3850> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA2_EA3844> ;
    skos:definition "A particular form or variety of a WorkSpecification that is different from others or from the original. The form represents differences in properties that characterize a WorkSpecification that are not enough to justify the creation of a new WorkSpecification.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA2_EA3850" ;
    skos:prefLabel "WorkSpecificationVersion"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA2_EA3851> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA2_EA3844> ;
    skos:definition "This association class specifies the relationship between WorkSpecifications. For example, an equipment maintenance work task requires a service re-routing work task. Note: this Relationship will affect the Relationship between corresponding WorkItems, i.e. WorkOrderFulfillment (start-to-start, start-to-finish, etc.) in Project ABE, as well as the Scheduling mechanism.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA2_EA3851" ;
    skos:prefLabel "WorkSpecRelationship"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3770> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3810> ;
    skos:definition "WorkSpecification entity describes works that can be executed, their associated characteristics and possible values.<br/>It allows the definition of a catalogue of works.<br/>A WorkSpecification can correspond to work that could be performed by field technicians to connect a customer, repair an equipment, deploy a new resource in the network...<br/>A WorkSpecification can correspond to a basic / simple task (AtomicWorkSpecification) or to a complex task that corresponds to the execution of several works (CompositeWorkSpecification). <br/>A Work is an instance of WorkSpecification entity. If there are characteristics defined for the WorkSpecification, the work instance has a distinct value assigned for those characteristics.<br/>The concept of Work makes use of both the Specification Pattern and the Composite/Atomic Pattern.<br/>WorkSpecification is further defined by an ActivitySpecification (to add more information on the works to perform).<br/>Work is further defined by an Activity.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3770" ;
    skos:prefLabel "Figure WFM.00 - Basic Work Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3772> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3810> ;
    skos:definition "WorkSpecification and its related specification entities provide the definition of a work task to be performed manually, such as instructions and requirements to do fiber installation or equipment repair. Like a template with invariant characteristics of a work task, WorkSpecification is used to instantiate a particular instance of Work description (for example, the repair of a router at a particular location). <br/>Some work requires an Appointment to be agreed on with a customer or location owner; some work does not (for example, work required for an internal network build). The need for an Appointment is indicated by the isAppointmentRequired attribute. The standardDuration attribute is the approximate time the Work is to be performed. The standardCapacityRequired attribute is the effort required to do the Work. These attributes are used as input for Scheduling.<br/>WorkSpecifications have a relationship with each other. The relationship can be dependency, mutual exclusion, being performed at the same time, etc. Work specification requires skills (for example, GPON service installation requires drop cable running, patch panel connection, ONT set up, activation, and test skills). One WorkSpecification can play one or more WorkSpecificationRoles. For example, Cable layout work can have the role of Installation for a new network infrastructure build, or the role of Installation for a service delivery.<br/>The other entities define other typical data about the work. WorkSpecificationType is used to classify WorkSpecification. Work Specifications can then be grouped into categories to make a Work Catalog. WorkSpecificationCost specifies the multiple monetary cost of doing the work (not including the human cost of using a technician’s time). WorkSpecificationVersion specifies the versions after changes.<br/><i>Note: Project ABE can interact with Workforce ABE via Work Order. Work Order Item involves WorkSpecification. </i><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3772" ;
    skos:prefLabel "Figure WFM.01 - Work Specification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3774> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3810> ;
    skos:definition "WorkFufillmentRate is used in planning and WorkSpecification configuration. It represents a particular effort (“consumptionCapacity” attribute) to do a given amount of particular work (“quantity” attribute) in a given location which can be done by a given organization. For example, a fiber installation team for the New York serving area (having a capacity, say, of 100 man days per week) can fulfill 200 fiber layouts.<br/>Note: the rate of work that can be performed may not be linear with the quantity of work. It is calculated based on many inputs. For example:<br/><ul><li>The skill qualification of the Pools that the Organization has (senior engineers, interns, testers, etc.) </li><li> The specification of the Work (such as its standard duration) </li><li> The Specification of the Place or Serving Area (e.g. installation in Rural areas consumes 50% more effort than in Urban areas) and the standardDriving time</li><li> The same location grouping effect (e.g. it takes 2 hours to install the first 10 fibers, but for the next 20, it would take only one hour. Or, it costs the same effort to install two phone lines instead of one.)</li></ul><i>Note: Via WorkSpecFulfillmentRate, the relationship between WorkSpecification, WorkforceOrganizationRole, and Place is M–M, given that there are many variants in fulfillment rates.</i><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3774" ;
    skos:prefLabel "Figure WFM.02 - Fulfillment Rate"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3776> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3810> ;
    skos:definition "Following the Entity/EntitySpecification pattern, with WorkSpecification we also introduce the Work ABE. It contains the entities of Work and WorkRole.<br/>Work is instantiated from WorkSpecification, with template invariant characteristics, and the addition of specific attributes with values of the work for a specific context.<br/>This Figure depicts the Work and WorkSpecification entities, along with their related instance entities, WorkRole and WorkSpecificationRole. They represent an application of the SID EntitySpecification/Entity pattern, CharacteristicUse, etc.<br/><i>Note: Instead of modeling WorkSpecificationCharacteristic, WorkSpecCharacteristicValue, and WorkCharacteristicValue as new classes, we relate WorkSpecification to EntitySpecCharUse, and relate Work with CharacteristicValue.</i><br/>Role class model can be used to simplify the modeling of different types of WorkSpecification and Work, to make the model inherently more extensible.<br/>Instead of trying to define many subclasses (one for each different type of Work) or introduce multiple inheritances (so that a new Work would derive from a set of existing Works), we can instead define a set of roles that a Work is meant to play. For example, a Work of fiber rollout at a location on a date can be a build task in an infrastructure project, or a role of installation task in a service fulfillment project. So the specification of these variants of the work can be a bit different. Instead of making sub-classes of this work to cover these cases, two roles of fiber rollout for network build, and fiber rollout for service delivery, can be introduced.<br/>The Cardinality is 1-* because Work can have more than one role with different characteristics in different contexts.<br/>Similarly, WorkSpecficationRole can extend the invariant characteristics of a WorkSpecification (a set of roles is used to characterize different sets of functionalities of the WorkSpecification) in different contexts. For example, a CPE installation work specification may have in addition, via WorkSpecificationRoles, the specifications of ONT installation, Cable modem installation, or DSL modem installation.<br/><i>Note: Project ABE can interact with Workforce ABE via Work Order. WorkOrderItem is associated with Work. </i><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3776" ;
    skos:prefLabel "Figure WFM.03 - Work / Work Specification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3778> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3810> ;
    skos:definition "WorkforceResource ABE represents the employees and other non-human resources involved in field operations.<br/>The following Figure represents the WorkforceEmployeeRole and WorkforceOrganizationRole entities and their relation with PartyRole. Using the role model, it is possible to describe more details of the entities without creating more sub-classes.<br/>The WorkforceEmployeeRole class represents an individual field technician. Or, more exactly, because of the use of Role instead of Entity, a person or employee, which can be a field technician in addition to his/her other responsibility (like manager, network engineer, etc.), presented by other designated Roles. As with any other PartyRole, WorkforceEmployeeRole has a Calendar of working days/hours, as well as a link to Skill sets, which need to be considered to create availability Pool(s) and WorkSchedule(s) for the Organization.<br/>The class of WorkforceOrganizationRole represents an organization or team, like a department, in a Service Provider company, or a 3rd-party contractor team, involved in field operations. This class is extended from ValueNetworkRole. Through this extension, WorkforceOrganizationRole is involved in the value chain of service supply–consumption. WorkforceOrganizationRole also contains one or more pools of employees, ready to provide field services with particular skill sets for a service area.<br/>Similarly, WorkforceOrganizationRole has a Calendar of working availability, which needs to be considered to create availability Pool(s) and WorkSchedule(s) for the Organization.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3778" ;
    skos:prefLabel "Figure WFM.04 - Workforce Party Roles"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3780> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3810> ;
    skos:definition "In the following Figure, the class of WorkforceResourceRole represents other non-human resources that are involved in field work. Tool is an example class. Other examples are truck, accessories, materials, etc.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3780" ;
    skos:prefLabel "Figure WFM.05 - Workforce Resource Role"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3782> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3810> ;
    skos:definition "To be assignable to work, technicians must have certain skills. In SID, the Skill and SkillSpecification are modeled in Party ABE. They are modeled using the atomic/composite pattern, and categorized using SkillCatalog. Refer to Party ABE for more details.<br/>Its association to Party and PartyRole, which generalizes Workforce roles, is explained in the following Figure.<br/>The association between a PartyRole and Skill(s) implies requirement. For example, to be classified as a fiber repair technician, for planning or training purposes, the role must have the following skills: signal strength test or measurement, equipment diagnostics, equipment reconfiguration, and equipment installation.<br/>The association between Party and Skill(s) means a particular person or group/organization already has a particular skill(s).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3782" ;
    skos:prefLabel "Figure WFM.06 - Skill Model"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3784> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3810> ;
    skos:definition "For workforce planning and scheduling purposes, the capacity of individual human and non-human resources must be organized in Pools. A Pool is a group of people or resources, grouped by some criteria, such as Skills or Location, for a period of time. Pool also facilitates the assignment of a group of people to a work task. Pools may not always be equal to a physical organization, but rather a logical holder of workforce capacity. In fact, a Workforce organization can have more than one Pool, and vice versa, a pool can contain technicians from more than one organization.<br/>For this SID release, the capacity represented by or associated with a Pool is high-level — just the count of people with certain skills for locations. In a future release, we will consider defining more details on capacity down to a time slot (of a day), the capacity unit (man hours, maximal number of orders of certain Work types that can be processed), time granularity (like 1 hour, 2 hours, etc. — i.e. the unit time period the workforce organization can give resources for), and others. For example, an EmployeePool’s Capacity, on a particular working day, from 8 am to 12 pm, with Fiber installation skills can be 40 man hours (available capacity).<br/>The WorkforceEmployeePool has the flag of isWFSupplierEmployeePool, to distinguish whether the pool is managed by an external Supplier (3rd-party contractor). Such a pool may be transparent to the Service Provider in terms of particular employee booking and assignment; as such functions are outsourced to the contractor company. Nevertheless, the Service Provider may want to know the capacity of the pool, for its own planning purposes.<br/>An example of a WorkforceResourcePool is the group of trucks and tools (like network testers) that the field force department for the New York area can use to serve a Fiber installation project.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3784" ;
    skos:prefLabel "Figure WFM.07 - Workforce Pool"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3786> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3810> ;
    skos:definition "The assignment of Employee and Resource to a pool is recorded in an assignment class — WorkforcePoolAssignment. Its subclasses are WorkforceEmployeePoolAssignment and WorkforceResourcePoolAssignment. The parent class of WorkforcePoolAssignment has the attributes for the validity period, as well as the restriction of this assignment. The restriction is any rule that keeps the assignment valid other than time period. For example, this employee to Pool assignment can be 50% of his capacity during that period only.<br/>The assignment of employees to an organization’s Pool must correspondingly update the WorkFulfillmentRate of the organization.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3786" ;
    skos:prefLabel "Figure WFM.08 - Workforce Assignment to Pool"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3788> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3810> ;
    skos:definition "Work Order is a request for manual work that can be sent to a workforce management solution to process. WorkOrder ABE is modeled in Project ABE of the Enterprise domain. Here we describe the association between Word Order ABE and the Work/WorkSpecification Entities.<br/>WorkOrder comprises one or more work items. To be recognized properly by the work force management solution, a work item must refer to the same WorkSpecification that the WFM solution can accept. Correspondingly, the work order item is to describe the work.<br/>WorkOrderFulfillment specifies the execution dependency between WorkOrderItem, like start-to-finish, start-to-start, etc.<br/><i>Note: The association between Project Element and WorkOrder or WorkOrderItem is 0..1 to M. The cardinality 0..1 means that it is not necessary to have a project, to issue or associate a WorkOrder.</i><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3788" ;
    skos:prefLabel "Figure WFM.09- Workforce Work Order"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3790> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3810> ;
    skos:definition "The scheduling process involves planning available workforce capacity, handling the appointment request (booking), and reservation and assignment (dispatch) of the workforce. These processes are supported by the workforce business calendar, appointment, workforce pool, reservation, and assignment entities.<br/>Correspondingly, we introduce the Appointment, Reservation (Booking), and Assignment (Dispatch) entities along with WorkSchedule. Though Appointment is defined in Project ABE, we present its association with WF entities here too.<br/><br/>To deliver a service, a specific Work Order, with its WorkItems and the associated Work tasks, is generated. Some work is to be performed onsite and needs an agreement about time and other terms (e.g. in the form of a letter of authorization). Appointment is an agreement between service representatives and the customer about the time and terms to do the work.<br/>In SID, the Appointment entity is modeled in the Time ABE of the Common Business Entity domain. It results from an Agreement between the service provider and the customer, about terms of the services to be ordered. The Appointment is associated with a Calendar Entry of a WorkSchedule (described below), to model the start–end time of the visit.<br/>The following Figure represents Appointment and its association to Work and Calendar Entry (refer to Common guide book section Calendar ABE).<br/>The appointment of a Work task to be done in a certain time period is defined by considering the available capacity of a WorkforceEmployeePool, which shows the availability of the work force. Various other criteria can be also considered for making an appointment, like the WorkSpecFulfillmentRate of an organization, priority of the work order, etc.<br/>In real life, the appointment times, when agreed on with the customer by a call, can be flexible (at a date, in the morning, afternoon, evening, etc.). The exact time of the visit will be defined during a particular technician reservation and then dispatched, considering many optimization factors or preferences of the technician (for example, driving distance to the site).<br/><i>Note: In some cases, a particular technician is assigned to an Appointment. That is done either on request from a customer, or because of a CSP’s approach to simplify the reservation and assignment rules. In this case, the Reservation and Assignment records can be created at the same time as the creation of the Appointment.</i><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3790" ;
    skos:prefLabel "UPDATED Figure WFM.10 - Workforce Appointment"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3792> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3810> ;
    skos:definition "During the investigation of resource availability and agreement with the customer about the appointment (time of visit), the WFM solution needs to reserve the technician and other resources for the Work. <br/>The WorkforceEmployeeReservation records associate a whole Pool or an individual Employee with a Work. Reservation for the time to perform the work is reflected in the association with a Calendar Entry of a WorkSchedule (described below), which can be synchronized with the Appointment’s Calendar Entry.<br/>With or without an appointment, the employee or pool can generally be reserved for future work tasks for an approximate time period. This is modeled by the validFor attribute.<br/>When it comes to the moment of dispatch, the dispatcher will decide the order of the work tasks assigned to the technician, like optimization of the driving time to enhance the fulfillment rate or the dependency between the work tasks. Then the particular time of the visit will be decided. This is represented by the WorkforceEmployeeAssignment entity, which realizes the WorkforceEmployeeReservation, associating the WorkforceEmployeeRole with Work and Calendar Entry for the exact time of the visit.<br/>Once the Work and its related WorkOrderItem are completed, the available capacity of the pool is updated.<br/>The cardinality of the associations here means an Employee (or Pool) can be reserved or assigned to multiple Works and Calendar Entries. The association from WorkforceEmployeeReservation to WorkforceEmployeePool has a cardinality of 0..1 because one or none of Workforce Employees or Pools can be reserved. In case none is reserved, the record just states that Work can have reservation with a Calendar Entry, meaning a general capacity is reserved for a time slot, without a specific employee or pool yet.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3792" ;
    skos:prefLabel "Figure WFM.11 - Workforce Employee Reservation&Assignment"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3794> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3810> ;
    skos:definition "The following Figure represents similar support for non-human resource reservation and assignment.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3794" ;
    skos:prefLabel "Figure WFM.12 - Workforce Resource Reservation&Assignment"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3796> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3810> ;
    skos:definition "There is a need to model an entity that can show the current schedules of an organization. The schedules are to show customer support agents, dispatchers, and managers what work requests with what skills, time, and location have been received, what employees or pools are reserved for the requests, and what employees are assigned to do the work tasks. Besides the Pools of available capacity, the schedules support CSR, Workforce managers, and dispatchers, allowing them to have an overall view of current assignments, to make decisions about further reservations and assignments, or the planning of future capacity.<br/>For this purpose we introduce WorkSchedule, which can hold Reservation (booking) and Assignment. An example of WorkSchedule is when a contractor team responsible for the New York market has been receiving 100 appointment requests for fiber installation during July and currently reserves employees to perform 80 of them in particular timeslots.<br/>The explicit modeling of WorkSchedule and its association with other entities like Pools, Reservation, and Assignment is a subject of a future revision of this Workforce Management addendum. In this version, following the model of ProjectSchedule, we propose that WorkSchedule is also to be a type of SimpleCalendar, defined in Common guide book section Calendar ABE.<br/>The following Figure represents the WorkSchedule entity.<br/>Being an extension of Simple Calendar, WorkSchedule inherently contains CalendarEntry (start–end time, or time slot). We can use CalendarEntry to associate it with the Appointment, Reservation, and Assignment records.<br/>An organization can have more than one WorkSchedule for various purposes (e.g. for a time period, some work types, or serving areas).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3796" ;
    skos:prefLabel "Figure WFM.13 - Workforce Organization Role"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3798> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3810> ;
    skos:definition "PaySpecification specifies PayComponents that are part of a Pay in a PayRange. <br/>PayRange defines a pay range for Employees. It specifies minimum, average and maximum amounts in the range.<br/>Each PaySpecification is grouped in a PayGroup specifying the frequency of Payroll and related to the PayRollAgency in charge of executing payrolls.<br/>A PaySpecification is composed of PayComponentSpecification.<br/>PayComponentSpecification specifies components of a pay that might correspond to fixed salary, bonus...<br/>When a PayComponentSpecification corresponds to a rate (e.g. 10%), it specifies on which other PayComponentSpecification it applies on.<br/>In a company, each employee (WorforceEmployeeRole) benefits from an EmployeePay.<br/>The EmployeePay is composed of EmployeePayComponent.<br/>The EmployeePayComponent specifies the validity period of the component and the amount (unit -any currency- and the value such as $10) for the employee.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3798" ;
    skos:prefLabel "Figure WFM.14 - Employee Pay"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3800> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3810> ;
    skos:definition "A Company has three PayGroups:<br/><ul><li>one for UK Regular Employees</li><li>one for UK Contract Employees</li><li>and one for External Employees</li></ul><br/>Each PayGroup has different frequency for executing PayRoll.<br/>UK Regular Employees is managed by VF-Internal PayRollAgency and the two others by Megasoft.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3800" ;
    skos:prefLabel "Figure WFM.14-I01 - PayGroup and Pay Agency"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3802> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3810> ;
    skos:definition "PayGroup UK-Regular is in charge of two PaySpecification:<br/><ul><li>PaySpecification for Pay Range 123</li><li>and PaySpecification for Pay Range 234</li></ul><br/>Pay Range 123 has a minimum of 1000$, an average of 1200$ and a maximum of 1400$. It is related to two PayGrades.<br/><br/>Pay Range 234 has a minimum of 2000$, an average of 2200$ and a maximum of 2400$. It is related to one PayGrade.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3802" ;
    skos:prefLabel "Figure WFM.14-I02 - PaySpecification and PayRange"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3804> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3810> ;
    skos:definition "PaySpecification for Pay Range 123 and PaySpecification for Pay Range 234 have one component in common, the PC-Mobile-1.<br/>PC-Mobile-1 specifies an amount of 100$ per year that is paid monthly.<br/><br/>PaySpecification for Pay Range 123 has two other components:<br/><ul><li>PC-Basic-1 that represents a basic pay for employees from PaySpecification of Range 123. This component is defined yearly and paid monthly to the employee. There is no amount as it is chosen for each Employee respecting the minimum and maximum total amount defined by the PayRange.</li><li>PC-Variable-1 that represents the Variable pay for employees from PaySpecification of Range 123. This component is defined yearly and paid yearly. It represents 10% of the Basic Pay.</li></ul><br/>PaySpecification for Pay Range 23' has two other components:<br/><ul><li>PC-Basic-2 that represents a basic pay for employees from PaySpecification of Range 234. This component is defined yearly and paid monthly to the employee. There is no amount as it is chosen for each Employee respecting the minimum and maximum total amount defined by the PayRange.</li></ul><ul><li>PC-Variable-1 that represents the Variable pay for employees from PaySpecification of Range 234. This component is defined yearly and paid yearly. It represents 15% of the Basic Pay.</li></ul><p/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3804" ;
    skos:prefLabel "Figure WFM.14-I03 - PaySpecification and its components"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3806> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3810> ;
    skos:definition "Mr. Tom is an employee of the company.<br/>At the beginning, from January the 1st 2021 to December the 31st 2021 he has a pay corresponding to the PaySpec of Pay Range123 with a basic pay of 1000$.<br/><br/>Mr. John Smith is another employee of the company.<br/>From March the 15th 2020 he has a pay corresponding to the PaySpec of Pay Range123 with a basic pay of 1200$.<br/>Note: relationships between John Smith' EmployeePayCompononents and PayComponontSpec are not represented on the diagram.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3806" ;
    skos:prefLabel "Figure WFM.14-I04 - Employee Pay and its components first step"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3808> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3810> ;
    skos:definition "At the beginning of 2022, Mr. Tom has been promoted and is granted with a Pay of Range 234 with a basic pay of 2000$.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3808" ;
    skos:prefLabel "Figure WFM.14-I05 - Employee Pay and its components second step"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3811> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3810> ;
    skos:definition "Proposed add based on Specification Pattern<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3811" ;
    skos:prefLabel "EARoot_EA4_EA2_EA9_EA2_EA3811"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3812> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3810> ;
    skos:definition "Proposal: Make WOrkSPec and WOrk abstract, and apply composite/atomic to both, given also proposing to apply the specification pattern to work.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3812" ;
    skos:prefLabel "EARoot_EA4_EA2_EA9_EA2_EA3812"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3813> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3810> ;
    skos:definition "standardDuration is redundant with expectedDuration from ProjectEelementSpec - Delete<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3813" ;
    skos:prefLabel "EARoot_EA4_EA2_EA9_EA2_EA3813"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3814> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3810> ;
    skos:definition "Is standardCapacityRequired already covered somewhere?<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3814" ;
    skos:prefLabel "EARoot_EA4_EA2_EA9_EA2_EA3814"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3815> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3810> ;
    skos:definition "Note Cecile: standardCapacityRequired is redundant with ProjectResourceSpec (att unitCost) related to ActivitySpec. cf. Proj.13<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3815" ;
    skos:prefLabel "EARoot_EA4_EA2_EA9_EA2_EA3815"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3816> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3810> ;
    skos:definition "Work and WorkSpec to become abstract<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3816" ;
    skos:prefLabel "EARoot_EA4_EA2_EA9_EA2_EA3816"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3817> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3810> ;
    skos:definition "WorkSpecification should be an Abstract Class<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3817" ;
    skos:prefLabel "EARoot_EA4_EA2_EA9_EA2_EA3817"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3818> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3810> ;
    skos:definition "An AtomicWork represents the instantiation of an AtomicWorkSpecification. An AtomicWork might be contained in 0 or many CompositeWork.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3818" ;
    skos:prefLabel "AtomicWork"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3819> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3810> ;
    skos:definition "A type of WorkSpecification that does not have any subordinate WorkSpecification. An AtomicWorkSpecification is a leaf-level WorkSpecification.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3819" ;
    skos:prefLabel "AtomicWorkSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3820> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3810> ;
    skos:definition "A CompositeWork is an instantiation of CompositeWorkSpecification which keeps configuration characteristics.<br/>A CompositeWork contains at least one Work itself Composite or Atomic.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3820" ;
    skos:prefLabel "CompositeWork"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3821> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3810> ;
    skos:definition "A type of WorkSpecification that is formed by aggregating other WorkSpecifications, which may be Composite or Atomic WorkSpecification.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3821" ;
    skos:prefLabel "CompositeWorkSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3_EA1_EA3865> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3_EA1_EA3867> ;
    skos:definition "Following are the business entities aggregated under the Work Aggregate Business Entity.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3_EA1_EA3865" ;
    skos:prefLabel "Figure WRK.01 - Work ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3_EA1_EA3868> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3_EA1_EA3867> ;
    skos:definition "The Work entity is used to record actual executed work, i.e. an instance of that entity is created for the actual work described by the WorkSpecification. If there are characteristics defined for the WorkSpecification, the work instance has a distinct value assigned for those characteristics. Instances of Work are associated to the WorkOrderItem. The quantity attribute can be used if the same work has been done more than once identically (based on the similar attribute in WorkOrderItem).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3_EA1_EA3868" ;
    skos:prefLabel "Work"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3_EA1_EA3869> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3_EA1_EA3867> ;
    skos:definition "This is an abstract base class that defines a Work task in terms of a set of roles which are then used to characterize the functionality of the Work. For example, a particular work of fiber rollout at a location at a certain date can play the role of a build task of an infrastructure project or the role of an installation task in a service fulfillment project.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3_EA1_EA3869" ;
    skos:prefLabel "WorkRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3_EA3852> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3_EA3854> ;
    skos:definition "Following are the business entities aggregated under the Workforce Resource Aggregate Business Entity.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3_EA3852" ;
    skos:prefLabel "Figure WR.01 - Workforce Resource ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3_EA3856> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3_EA3854> ;
    skos:definition "Represents an employee pool, as a set or group of employees available for assignment to work tasks. A WorkforceOrganizationRole can have many workforce pools, and vice versa, a pool can contain employees from more than one organization. Examples of a Pool are Fiber installation team, service repair team, etc. A Pool contains people/resources with particular skills, availability, location, other restrictions, and preferences. Pool is associated with Capacity. For example, a WorkForceEmpolyeePool shows that on July 1, from 8 am to 12 pm there are 100 man hours available with the skill of fiber layout for the New York area. A detailed model of the capacity of the pool down to timeslot, skill/work level is a subject for a future SID release.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3_EA3856" ;
    skos:prefLabel "WorkforceEmployeePool"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3_EA3857> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3_EA3854> ;
    skos:definition "Represents an association class and defines specific characteristics for the assignment of an employee to a pool. For example, assignment of fiber technicians to the Installation and Repair team pools, serving the New York Area in the first quarter.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3_EA3857" ;
    skos:prefLabel "WorkforceEmployeePoolAssignment"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3_EA3858> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3_EA3854> ;
    skos:definition "This is a PartyRole that represents individuals who are involved in the workforce process as employees with particular skills. For example, Field Technician, Network Engineer, Supervisor, etc.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3_EA3858" ;
    skos:prefLabel "WorkforceEmployeeRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3_EA3859> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3_EA3854> ;
    skos:definition "This is a PartyRole that represents organizations involved in field operations. It can be the CSP Field Technician department itself, or a 3rd-party contractor company. Note that OrganizationRole has Calendar, inherited from Calendar of PartyRole.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3_EA3859" ;
    skos:prefLabel "WorkforceOrganizationRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3_EA3860> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3_EA3854> ;
    skos:definition "An abstract class representing assignment of an employee or other resource to a pool. An employee can be assigned to more than one pool. The attribute poolAssignmentRestriction is a place holder that represents any limitation of the assignment other than time period. Pool assignment will update available capacity WorkSchedule of some organization.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3_EA3860" ;
    skos:prefLabel "WorkforcePoolAssignment"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3_EA3861> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3_EA3854> ;
    skos:definition "Represents a resource pool as a set of resources (both physical and logical) available for assignment to work tasks. For example, the Dallas pool for fiber rollout for a weekday contains X number of trucks, Y number of test kits, etc.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3_EA3861" ;
    skos:prefLabel "WorkforceResourcePool"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3_EA3862> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3_EA3854> ;
    skos:definition "Represents an association class and defines specific characteristics for the assignment of a resource to a pool. For example, assign a fiber test kit to the Dallas Pool for July.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3_EA3862" ;
    skos:prefLabel "WorkforceResourcePoolAssignment"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3_EA3863> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3_EA3854> ;
    skos:definition "Defines the concept of various types of roles associated with WorkforceResources (both physical and logical). For example, tools (meter, ladder), Truck, GPS, Handheld, etc.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3_EA3863" ;
    skos:prefLabel "WorkforceResourceRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3_EA3864> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA3_EA3854> ;
    skos:definition "An example class that represents the specific role of workforce resources. Examples are tester kits, GPS, Trucks, etc.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA3_EA3864" ;
    skos:prefLabel "WorkforceResourceTool"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA4_EA3870> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA4_EA3872> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the Work Schedule Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA4_EA3870" ;
    skos:prefLabel "Figure WSc.01 - Workforce Schedule ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA4_EA3873> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA4_EA3872> ;
    skos:definition "Represents an assignment of a particular WorforceEmployeeRole for a particular work task in a specific timeframe. For example, assignment of a person in a network engineer role to a trouble shooting work task for at least 2 hours. The assignment is associated with a CalendarEntry of an Assignment WorkSchedule.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA4_EA3873" ;
    skos:prefLabel "WorkforceEmployeeAssignment"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA4_EA3874> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA4_EA3872> ;
    skos:definition "Represents an implementation of a request for reservation of work time in some human resource pool. It is also possible to reserve the work time of an individual employee. Note: the reservation, or booking according to appointment, is associated to Calendar Entry. The CalendarEntry here can belong to a reservation WorkSchedule. This Calendar entry may be floating. Once the Reservation becomes an Assignment (to be dispatched), a particular time slot (Calendar Entry) can be fixed in the WorkSchedule.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA4_EA3874" ;
    skos:prefLabel "WorkforceEmployeeReservation"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA4_EA3875> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA4_EA3872> ;
    skos:definition "Represents an assignment of a particular resource for particular work in a specific timeframe. For example, assignment of a fiber test kit (or, additional example, a role of a test kit) to a fiber rollout work for a date.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA4_EA3875" ;
    skos:prefLabel "WorkforceResourceAssignment"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA4_EA3876> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA4_EA3872> ;
    skos:definition "Represents an implementation of a request for the reservation of usage time in some resource pool (tools, trucks, materials, etc.). It is also possible to reserve usage time of a particular resource.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA4_EA3876" ;
    skos:prefLabel "WorkforceResourceReservation"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA4_EA3877> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA2_EA4_EA3872> ;
    skos:definition "Being a subclass of SimpleCalendar, WorkSchedule and its variants describes various appointment, reservation, and assignment schedules of an organization. For example, a WorkSchedule shows that a contractor team responsible for the New York area has been receiving 100 requests for fiber installation during July and is currently scheduled to perform 80 of them.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA2_EA4_EA3877" ;
    skos:prefLabel "WorkSchedule"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3751> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3755> ;
    skos:definition "The Enterprise Domain roles presently identified are:<br/><b>Enterprise Party Roles ABE</b><br/> • Enterprise Party Roles ABE contains all PartyRoles related to the Enterprise such as Employee, Employer, Regulator...<br/><b>Workforce ABE</b><br/> • The Workforce ABE models the human and other field resources with their roles, skills, calendar, and other characteristics. It also models the work description and reservation and assignment of a technician to a task. It contains Work, Work Specification, WorkforceResource, and WorkforceSchedule. <br/><b>Enterprise Risk ABE</b><br/> • Enterprise Risk ABE represents all items that relate to risk of an enterprise. It also concerns security vulnerabilities and related events as well as information related to Revenue Assurance such as areas of revenues leakage risk and operational capability to resolve any detected degradations and violations.<br/><b>Enterprise Effectiveness ABE</b><br/> • Enterprise Effectiveness ABE represents all information used to evaluate the enterprise effectiveness, such as Business Objectives and Processes.<br/><b>Finance ABE (not fully developed)</b><br/> • The Finance ABE aims to describe all that is related to the Enterprise finance such as financial accounts, and general ledger.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3751" ;
    skos:prefLabel "[EntD-01] Enterprise ABEs Level 1"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3753> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3755> ;
    skos:definition "The diagram below lists the Enterprise Domain's ABEs Level 1 and 2.<br/><b>Workforce Resource ABE</b><br/><ul><li>WorkforceResource ABE represents the employees and other non-human resources involved in field operations.</li></ul><b>Workforce Schedule ABE</b><br/><ul><li>The Workforce Schedule ABE defines reservation and assignment of a technician or resource to a task.</li></ul><b>Work Specification ABE</b><br/><ul><li>The Work Specification ABE specifies a kind of work that can be performed manually by a technician. Two key entities that comprise the WorkSpecification ABE are WorkSpecification and WorkSpecFulfillmentRate.</li></ul><b>Employee Pay ABE</b><br/><ul><li>The Employee Pay ABE provides the details of the Employee Pay and related components , Pay Group, Pay Range and Pay Grade which is the core structure for any organisation’s Pay Structure .</li></ul><b>Enterprise Security ABE</b><br/><ul><li>Represents all items that relate to security vulnerabilities and related events.</li></ul><b>Revenue Assurance ABE</b><br/><ul><li>The Revenue Assurance area of the SID provides revenue assurance controls, revenue assurance violations, revenue assurance key performance indicators (KPIs), revenue assurance objectives, and rules that map revenue assurance KPIs and threshold violations to revenue assurance trouble tickets. Additionally, the scope of Revenue Assurance includes revenue assurance actions/responses that reconcile revenue assurance trouble tickets and bring the trouble tickets to closure.</li></ul><b>RA Action_Response ABE</b><br/><ul><li>A step towards developing a RevenueAssuranceResponse.</li></ul><b>RA Assessment ABE</b><br/><ul><li>A measure of the effectiveness of RAControls, RAObjectives, and RA KPIs. RAAssessment also includes recommendations for refining RAControls, RAObjectives, and RAKPIs.</li></ul><b>RA Control ABE</b><br/><ul><li>Policy-based rules that represent the logical definition of comparisons performed on entities, such as CustomerBills and CallDetailRecords, to identify RAViolations.</li></ul><b>RA Key Performance Indicator ABE</b><br/><ul><li>KeyPerformanceIndicators and RAObjectives that may trigger the creation of a RATroubleTicket. KeyPerformanceIndicator are defined on RAViolations, and on other Revenue Assurance related entities, such as CustomerBills and CallDetailRecords.</li></ul><b>RA Trouble Ticket ABE</b><br/><ul><li>A TroubleTicket opened to resolve one or several causes (for example, RA Violations) that resulted in a RAKeyPerformanceIndicator exceeding one or more RAObjective thresholds.</li></ul><b>RA Violation ABE</b><br/><ul><li>A discrepancy identified based on applying Policies associated with RAControl(s) to Revenue Assurance related entities, such as Products and ResourceUsage.</li></ul><b>Cost ABE</b><br/><ul><li>The <b>Cost ABE</b> represents a set of information that captures the expense needed to be spent by the service provider to acquire, execute, produce, activate, operate or qualify any entity (project, service, product, resource etc). It encompasses the amount of money needed in various aspects of a telco's business processes.</li></ul><b>Budget ABE</b><br/><ul><li>The Budget ABE contains all Business Entities needed to describe the different budgets allocated to at least one Party. The Party might be an Organization.</li></ul><b>Financial Account ABE</b><br/><ul><li>The Financial Account ABE describes part of the sub-ledger accounting that aggregates the amounts of one or more party accounts owned by a given party. It’s an internal view of the CSP to manage incomes and outcomes.</li></ul><p/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3753" ;
    skos:prefLabel "[EntD-02] Enterprise ABEs Level 2 & 3"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3761> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3755> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3761" ;
    skos:prefLabel "Engaged Party DUPLICATE UNUSED Addendum Figures"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA1_EA3920> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA1_EA3922> ;
    skos:definition "Following are the business entities aggregated under the RA Action Response Aggregate Business Entity.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA1_EA3920" ;
    skos:prefLabel "Figure RAAR.01 - RA Action_Response Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA1_EA3923> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA1_EA3922> ;
    skos:definition "Could just move RA.15 to here<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA1_EA3923" ;
    skos:prefLabel "EARoot_EA4_EA2_EA9_EA3_EA1_EA1_EA3923"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA1_EA3924> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA1_EA3922> ;
    skos:definition "A step towards developing a RevenueAssuranceResponse.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA1_EA3924" ;
    skos:prefLabel "RevenueAssuranceAction"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA1_EA3925> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA1_EA3922> ;
    skos:definition "The invariant characteristics of a RevenueAssuranceAction. Each related RevenueAssuranceAction instance will have the same invariant characteristics. However, the values associated with other characteristics of the instantiated RevenueAssuranceAction are specific to each instance.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA1_EA3925" ;
    skos:prefLabel "RevenueAssuranceActionSpec"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA1_EA3926> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA1_EA3922> ;
    skos:definition "The result of reconciling a RATroubleTicket represented by a series of one or more activities being initiated and performed. The RAResponse can also determine the root cause for RATroubleTickets based on rules that trigger the analysis.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA1_EA3926" ;
    skos:prefLabel "RevenueAssuranceResponse"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA1_EA3927> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA1_EA3922> ;
    skos:definition "The invariant characteristics of a RevenueAssuranceResponse. Each related RevenueAssuranceResponse instance will have the same invariant characteristics. However, the values associated with other characteristics of the instantiated RevenueAssuranceResponse are specific to each instance.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA1_EA3927" ;
    skos:prefLabel "RevenueAssuranceResponseSpec"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA2_EA3928> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA2_EA3930> ;
    skos:definition "Following are the business entities aggregated under the RA Assessment Aggregate Business Entity.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA2_EA3928" ;
    skos:prefLabel "Figure RAAs.01 - RA Assessment Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA2_EA3931> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA2_EA3930> ;
    skos:definition "A measure of the effectiveness of RevenueAssuranceControls, RevenueAssuranceObjectives, and RevenueAssuranceKPIs. RevenueAssuranceAssessment include recommendations for refining RevenueAssuranceControls, RevenueAssuranceObjectives and RevenueAssuranceKPIs.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA2_EA3931" ;
    skos:prefLabel "RevenueAssuranceAssessment"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA2_EA3932> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA2_EA3930> ;
    skos:definition "The purpose of a RevenueAssuranceAssessment expressed in terms of one or more RevenueAssuranceParameters, RevenueAssuranceObjectives, RevenueAssuranceConsequences, RevenueAssuranceApplicability.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA2_EA3932" ;
    skos:prefLabel "RevenueAssuranceAssessmentItem"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA2_EA3933> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA2_EA3930> ;
    skos:definition "The outcome of a RevenueAssuranceAssessment. The outcome may be a recommendation to refine a RevenueAssuranceParameter, a RevenueAssuranceObjective, RevenueAssuranceConsequence, RevenueAssuranceApplicability or the identification of a RevenueAssuranceTrend.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA2_EA3933" ;
    skos:prefLabel "RevenueAssuranceAssessmentResult"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA2_EA3934> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA2_EA3930> ;
    skos:definition "A type of RevenueAssuranceAssessmentResult that represents a suggestion to refine a RevenueAssuranceParameter, RevenueAssuranceObjective, Revenue AssuranceConsequence, or RevenueAssuranceApplicability.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA2_EA3934" ;
    skos:prefLabel "RevenueAssuranceRecommendation"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA2_EA3935> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA2_EA3930> ;
    skos:definition "A type of RevenueAssuranceAssessment Result that represents a general tendency, movement, or direction of a Revenue Assurance KPI or Revenue Assurance KPI. For example, a variance from week to week of the number of unbilled customers.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA2_EA3935" ;
    skos:prefLabel "RevenueAssuranceTrend"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3881> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3913> ;
    skos:definition "The Revenue Assurance Control ABE defines rules that represent the logical definition of comparisons, validations, reconciliation’s, and so forth performed on entities, such as bills and call detail records (CDRs), to identify Revenue Assurance Violations. Simple rules can be stated using RevenueAssuranceObjectives; complex rules can be stated using PolicySets. Revenue Assurance KPI ABE models KPIs and Revenue Assurance Objectives whose violation trigger Revenue Assurance Trouble Tickets.<br/>Revenue Assurance Controls and Revenue Assurance KPIs serve similar purposes; violating thresholds or other rules associated with them create a discrepancy. In the case of a Revenue Assurance Control, the discrepancy is a Revenue Assurance Violation; in the case of a Revenue Assurance KPI the discrepancy is a Revenue Assurance Trouble Ticket. The identification of discrepancies begins with calculating a value for the control or KPI.<br/>An example of a simple rule expressed as a RevenueAssuranceObjectiive is a value (true [1] or false [0]) determined every day for each customer to be billed that day, that has services and associated usage, but the usage has not been rated and will therefore not appear on the bill. The values are calculated by a defined algorithm, at a specified frequency, and are valid for a certain period of time. In this case the parameter is a RevenueAssuranceControl. If the value is true a RevenueAssuranceViolation is created that identifies the customer as not being billed for services used.<br/>An example of a complex rule expressed as a PolicySet is billing for a higher or lower bandwidth than provided on a circuit. This rule requires an “or” condition not available via RevenueAssuranceObjective.<br/>From a SID perspective controls and KPIs can be viewed as types of RevenueAssuranceParameters as shown in the following Figure.<br/>The following Figure also reveals that RevenueAssuranceControls can also serve as a base for RevenueAssuranceKPIs. For example, if a control exceeds a certain threshold, the action taken may be that the control is considered to be a KPI also.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA3881" ;
    skos:prefLabel "Figure RA.03 - RA Parameter"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3883> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3913> ;
    skos:definition "Thresholds for the RevenueAssuranceParameters are characteristics of RevenueAssuranceObjectives as shown in the following Figure.<br/>At times the simple rules defined by the attributes of RevenueAssuranceObjectives are not sufficient to determine if a discrepancy should be created based on the RevenueAssuranceParameterValue. In these cases, the rules would be defined by a PolicySet, which could be a PolicyRule or a PolicyGroup.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA3883" ;
    skos:prefLabel "Figure RA.04 - RA Objective"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3885> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3913> ;
    skos:definition "A PolicyGroup is a collection of rules used to define a related set of PolicyRules or other PolicyGroups. The PolicyRule entity acts as the heart of the Policy model and is shown in Figure RA.05. The rule is triggered by an event and comprised of one or more PolicyConditions and one or more PolicyActions. If a PolicyCondition(s) is met then one or more PolicyActions result. The PolicyRule is characterized further by a PolicyRuleSpec.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA3885" ;
    skos:prefLabel "Figure RA.05 - RA and Policy Rule"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3887> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3913> ;
    skos:definition "Each PolicyCondition and PolicyAction is defined by a PolicyStatement. A PolicyStatement is structured like a conventional “IF” statement, with a variable, operator, and value.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA3887" ;
    skos:prefLabel "Figure RA.06 - RA and Policy Statement"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3889> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3913> ;
    skos:definition "In the complex rule example, where a bill was generated for higher or lower bandwidth than provided, there would be a complex condition composed as “IF BilledBandwidth #gt; ProvidedBandwidth” “OR” “IF BilledBandwidth#lt; ProvidedBandwidth”. These three attributes would be derived using a derivation algorithm defined in an existing subclass (ProdOfferPricePolicyVariable) of PolicyVariable. The action would be composed as “SET BandwidthBilledError to true”.<br/>See GB922 Common Domain section Policy ABE for detail.<br/>If the RevenueAssurranceObjective is not met then a consequence results as shown in figure RA.07. The RevenueAssuranceConsequence is characterized by a prescribedAction attribute. This simple attribute may not be sufficient to specify the consequence. If so, then the association to PolicyAction allows for a more complex action to be specified. For example, …Note that the prescribed action may also result in the creation of a RevenueAssuranceViolation or a RevenueAssuranceTroubleTicket as shown in Figure RA.08.<br/>Additionally, parameters, objectives and consequences may be applicable, or not, at certain times. For example, if objectives may be checked during the week, but not on the weekend; consequences may be less severe during the day than during the evening. These scenarios are handled by the RevenueAssuranceApplicability business entity, also shown in Figure RA.07.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA3889" ;
    skos:prefLabel "Figure RA.07 - RA Consequence"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3891> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3913> ;
    skos:definition "Some type (modeled as a specification) of RevenueAssuranceViolation or some type (modeled as a specification) of RevenueAssuranceTroubleTicket is created if a RevenueAssuranceObjective is not met. This is based on whether the RevenueAssuranceParameter is a RevenueAssuranceControl or a RevenueAssuranceKPI. Figure RA.08 depicts RevenueAssuranceConsequence subclasses that trigger the creation of a RevenueAssuranceViolation or a RevenueAssuranceTroubleTIcket.<br/>The actual RevenueAssuranceViolation or RevenueAssuranceTroubleTicket is created based on the specification related to the consequence. For example, in previous example, if a customer is not to be billed for services used, then the consequence is related to a RevenueAssuranceViolationSpec instance that classifies and characterizes the RevenueAssuanceViolation as one for unbilled customer services.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA3891" ;
    skos:prefLabel "Figure RA.08 - RA Consequence Subclasses"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3893> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3913> ;
    skos:definition "The Revenue Assurance Violation ABE models’ discrepancies identified based on applying the rules defined by Revenue Assurance Control entities as described in the section on Revenue Assurance Controls.<br/>Figure RA.09 depicts how a RevenueAssuranceParameterValue that does not meet a RevenueAssuranceObjective results in a RevenueAssuranceConsequence. The consequence influences the selection of a RevenueAssuranceViolationSpec that results in a RevenueAssuranceViolation, which is also associated to the parameter value that triggered its creation.<br/>In the customer billing control, the value of true (1) means that the objective has not been met and results in a consequence named “Customer Service Not Billed”. The consequence is related to a RevenueAssuranceViolationSpec named “Discrepancy in Customer Services Billed”. The consequence describes the RevenueAssuranceViolation named “Customer X Billing Violation”, which is also related to the control value of true.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA3893" ;
    skos:prefLabel "Figure RA.09 - RA Violation"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3895> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3913> ;
    skos:definition "A RevenueAssuranceViolation is a type of Notification, which in turn is a type of BusinessInteraction. As such it inherits a number of characteristics from BusinessInteraction, such as the date, description, status, and association with Location and association with PartyRole, for example, to whom the violation is assigned. Figure RA.10 shows the key entities that make up the BusinessInteraction ABE. Addendum Common Domain section Business Interaction ABE fully describes the BusinessInteraction ABE.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA3895" ;
    skos:prefLabel "Figure RA.10 - RA and Business Interaction"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3897> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3913> ;
    skos:definition "Revenue Assurance Trouble Ticket ABE entities represent trouble tickets opened to resolve one or several causes (for example, Revenue Assurance Violations) that resulted in a Revenue Assurance KPI not meeting a Revenue Assurance Objective.<br/>Just as the model for controls and KPIs were similar, so are the models for RevenueAssuranceViolations and RevenueAssuranceTroubleTickets as shown in figure RA.11. There are two primary differences in the two models.<br/>First, a RevenueAssuranceTroubleTicket is a type of TroubleTicket, which in turn is a type of BusinessInteraction. Therefore, the TroubleTicket inherits the same characteristics from BusinessInteraction as RevenueAssuranceViolation.<br/>Second, RevenueAssurranceViolations may be used in the derivation of a RevenueAssuranceKPI, which then may trigger a RevenueAssuranceTroubleTicket. For example, if more than “X” number of customers are not billed in a given billing cycle for services used, a trouble ticket is generated. This KPI is a sum of all the “true” parameters that were RevenueAssuranceControl parameter values representing a single unbilled customer. For this reason, the RevenueAssuranceViolationSpec may influence the creation of a RevenueAssuranceTroubleTicket via the specification’s association with a RevenueAssuranceTroubleTicketSpec.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA3897" ;
    skos:prefLabel "Figure RA.11 - RA Trouble Ticket"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3899> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3913> ;
    skos:definition "The example presented up to this point references a business entity (ServiceUsage) for which the RevenueAssuranceParameter is calculated and the business entity instance (voice mail service for customer X). This implies that associations should be created from the parameter and parameter values to some other entities. The corresponding entities in the SID are RootBusinessEntityType and RootBusinessEntity.<br/>A RootEntityType represents each occurrence of a business entity within the SID. For example, Customer, Service, Product, Service Usage are all instances of RootEntityType. The RevenueAssuranceParameter is associated with this entity as shown in Figure RA.12. In the example the “service billed” instance of parameter would be related to the “ServiceUsage” instance of RootEntityType. <br/>A RootEntity represents each occurrence of a business entity instance in the SID. In the example, the “1” instance of parameter value would be related to the ServiceUsage instance of Customer X’s voice mail usage. This association puts the parameter value into context.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA3899" ;
    skos:prefLabel "Figure RA.12 - RA Parameters and Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3901> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3913> ;
    skos:definition "Revenue Assurance Action/Response ABE entities represent the result of reconciling Revenue Assurance Trouble Tickets by initiating and performing a series of one or more activities. Revenue Assurance Action/Response ABE entities also model the root cause for Revenue Assurance Trouble Tickets based on rules that trigger root cause analysis.<br/>The actions taken as a result of a RevenueAssuranceTroubleTicket being created are shown in Figure RA.13. Both the RevenueAssuranceActionSpec and the RevenueAssuranceAction entities inherit from existing activity entities that are part of the Project ABE in the Common Business Entities domain. RevenueAssuranceActionSpec and RevenueAssuranceAction represent an application of the EntitySpecification/Entity pattern used throughout the SID.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA3901" ;
    skos:prefLabel "Figure RA.13 - RA Action"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3903> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3913> ;
    skos:definition "<i>Note that there is no explicit association shown between RevenueAssuranceActionSpec and RevenueAssuranceAction. Since RevenueAssuranceActivitySpec is a subclass of ActivitySpec and RevenueAssuranceAction is a subclass of Activitythe the association between ActivitySpec and Activity is inherited.</i><br/>The set of actions that may be performed to resolve a RevenueAssuranceTroubleTicket are modeled using the association between a RevenueAssuranceTroubleTicketSpec and RevenueAssuranceActionSpec. The association is shown in Figure RA.14.<br/>The RevenueAssuranceTroubleTicketSpec enables one or more RevenueAssuranceActionSpecs to be selected for which instances of RevenueAssuranceAction are created and associated to the applicable RevenueAssuranceTroubleTicket. In the service usage example, the types of activities may include reviewing the customer account, checking the rating software, requesting a bug fix, close out the trouble ticket, and so forth.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA3903" ;
    skos:prefLabel "Figure RA.14 - RA Action and TroubleTickets"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3905> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3913> ;
    skos:definition "Once the RevenueAssuranceTroubleTicket is resolved, or during the course of taking one or more actions, a RevenueAssuranceResponse may be created. Figure RA.15 depicts the model for RevenueAssuranceResponseSpec and RevenueAssuranceResponse.<br/>The RevenueAssuranceRepsonseSpec represents the different types of responses that can be created as part of a RevenueAssuranceAction. The type of responses is governed by the association between RevenueAssuranceActionSpec and RevenueAssuranceResponseSpec. The RevenueAssuranceResponseSpec describes the invariant characteristics of a RevenueAssuranceResponse. The response is a subclass of BusinessInteraction, and as such, inherits the characteristics of BusinessInteraction, including the ability to relate one response to another.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA3905" ;
    skos:prefLabel "Figure RA.15 - RA Action and Response"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3907> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3913> ;
    skos:definition "As the RevenueAssuranceTroubleTicket is being investigated or after it is closed, a root cause for it and other trouble tickets may be found. The root causes can be created as an instance of RevenueAssuranceTroubleTicket and related, using the BusinessInteractionRelationship entity, to the associated RevenueAssuranceTroubleTIckets for which it is the root cause. This is shown in figure RA.16.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA3907" ;
    skos:prefLabel "Figure RA.16 - RA Trouble Ticket Root Cause"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3909> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3913> ;
    skos:definition "Revenue Assurance Assessment ABE entities measure the effectiveness of Revenue Assurance Controls, Revenue Assurance Objectives, and Revenue Assurance KPIs. Revenue Assurance Assessment ABE entities include recommendations of refining controls, objectives, and KPIs.<br/>The RevenueAssuranceAssessement entity and its related entities support periodic assessments of a Revenue Assurance program as shown in Figure RA.17. One or more individuals and/or organizations (SID Party entity) playing a PartyRole, such as employee, can be involved in an assessment as shown in the figure. A RevenueAssuranceAssessment may target a number of different aspects of a Revenue Assurance program, such as KPIs, objective, consequences, and applicability. The RevenueAssuranceAssessmentItem enables this. Additionally, one or more KPIs, objectives, consequences, and/or applicability can be associated with a single item as shown in the figure.<br/>Both RevenueAssuranceAssessment and RevenueAssuranceAssessmentItem are characterized by a basic set of attributes which include a description, date started, and date completed.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA3909" ;
    skos:prefLabel "Figure RA.17 - RA Assessment"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3911> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3913> ;
    skos:definition "The outcome of an assessment is defined by the RevenueAssuranceAssessmentResult business entity as shown in Figure RA.18. A result may be a RevenueAssuranceRecommendation or may be an identified RevenueAssuranceTrend. A trend is defined by its associated RevenueAssuranceParmValues and a RevenueAssuranceParameter as shown in the figure. For example, a recommendation may be to expand the time period during with a KPI is applicable; a trend may show an increasing number of customers not billed over a month-long period.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA3911" ;
    skos:prefLabel "Figure RA.18 - RA Assessment Result"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3_EA3936> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3_EA3938> ;
    skos:definition "Following are the business entities aggregated under the RA Control Aggregate Business Entity.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA3_EA3936" ;
    skos:prefLabel "Figure RAC.01 - RA Control Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3_EA3939> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3_EA3938> ;
    skos:definition "The time of day or days during which a RevenueAssuranceObjective or RevenueAssuranceConsequence is relevant or not.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA3_EA3939" ;
    skos:prefLabel "RevenueAssuranceApplicability"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3_EA3940> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3_EA3938> ;
    skos:definition "An action taken if a RevenueAssuranceObjective is not met.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA3_EA3940" ;
    skos:prefLabel "RevenueAssuranceConsequence"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3_EA3941> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3_EA3938> ;
    skos:definition "A Policy-based rule that represents the logical definition of comparisons performed on entities, such as CustomerBills and CallDetailRecords, to identify RevenueAssuranceViolations.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA3_EA3941" ;
    skos:prefLabel "RevenueAssuranceControl"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3_EA3942> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3_EA3938> ;
    skos:definition "An action taken if a RevenueAssuranceObjective is not met for a RevenueAssuranceControl.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA3_EA3942" ;
    skos:prefLabel "RevenueAssuranceControlConsequence"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3_EA3943> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3_EA3938> ;
    skos:definition "Goal for a RevenueAssuranceParameter defined in terms of metrics, thresholds, and tolerances.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA3_EA3943" ;
    skos:prefLabel "RevenueAssuranceObjective"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3_EA3944> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3_EA3938> ;
    skos:definition "A variable whose value is used to determine compliance with a RevenueAssuranceObjective.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA3_EA3944" ;
    skos:prefLabel "RevenueAssuranceParameter"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3_EA3945> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA3_EA3938> ;
    skos:definition "A numerical value or text determined for a RevenueAssuranceParameter. For example, a value of 10 determined for the number of Customers not billed in a given day.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA3_EA3945" ;
    skos:prefLabel "RevenueAssuranceParmValue"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA4_EA3946> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA4_EA3948> ;
    skos:definition "Following are the business entities aggregated under the RA Key Performance Indicator Aggregate Business Entity.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA4_EA3946" ;
    skos:prefLabel "Figure RAKPI.01 - RA Key Performance Indicator Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA4_EA3949> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA4_EA3948> ;
    skos:definition "A measure of a specific aspect of the Revenue Assurance performance of an entity, such as a CustomerBill or CallDetailRecord, defined on a RevenueAssuranceViolation that may trigger the creation of a RevenueAssuranceTroubleTicket.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA4_EA3949" ;
    skos:prefLabel "RevenueAssuranceKPI"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA4_EA3950> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA4_EA3948> ;
    skos:definition "An action taken if a RevenueAssuranceObjective is not met for a RevenueAssuranceKPI.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA4_EA3950" ;
    skos:prefLabel "RevenueAssuranceKPIConsequence"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA5_EA3951> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA5_EA3953> ;
    skos:definition "Following are the business entities aggregated under the RA Trouble Ticket Aggregate Business Entity.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA5_EA3951" ;
    skos:prefLabel "Figure RATT.01 - RA Trouble Ticket Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA5_EA3954> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA5_EA3953> ;
    skos:definition "A trouble ticket opened to resolve one or serveral causes (for example, RevenueAssuranceViolations) that resulted in a RevenueAssuranceKPI exceeding one or more Revenue AssuranceObjective thresholds.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA5_EA3954" ;
    skos:prefLabel "RevenueAssuranceTroubleTicket"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA5_EA3955> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA5_EA3953> ;
    skos:definition "The invariant characteristics of a RevenueAssuranceTroubleTicket. Each of these instances will have the same invariant characteristics. However, the values associated with other characteristics of the instantiated RevenueAssuranceTroubleTicket will be specific to each instance.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA5_EA3955" ;
    skos:prefLabel "RevenueAssuranceTroubleTicketSpec"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA6_EA3956> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA6_EA3958> ;
    skos:definition "Following are the business entities aggregated under the RA Violation Aggregate Business Entity.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA6_EA3956" ;
    skos:prefLabel "Figure RAV.01 - RA Violation Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA6_EA3959> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA6_EA3958> ;
    skos:definition "A descrepency identified by applying RevenueAssuranceObjectives and/or Policies to Revenue Assurance related entities, such as Products and ResourecUsage.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA6_EA3959" ;
    skos:prefLabel "RevenueAssuranceViolation"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA6_EA3960> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA1_EA6_EA3958> ;
    skos:definition "The invariant characteristics of a RevenueAssuranceViolation. Each related RevenueAssuranceViolation instance will have the same invariant characteristics. However, the values associated with other characteristics of the instantiated RevenueAssuranceViolation are specific to each instance.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA1_EA6_EA3960" ;
    skos:prefLabel "RevenueAssuranceViolationSpec"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA1_EA4035> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA1_EA4037> ;
