    skos:prefLabel "EARoot_EA4_EA2_EA5_EA8_EA1_EA1989"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA8_EA1_EA1990> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA8_EA1_EA1987> ;
    skos:definition "The model should enable to specify that a migration at a contract level for example is decomposed in actions at a lower level such as Migrate Offer 1 to offer 2, remove offer C, create offer D...<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA8_EA1_EA1990" ;
    skos:prefLabel "EARoot_EA4_EA2_EA5_EA8_EA1_EA1990"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA8_EA1_EA1991> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA8_EA1_EA1987> ;
    skos:definition "The model should enable to specify that a migration at a contract level for example is decomposed in actions at a lower level such as Migrate Offer 1 to offer 2, remove offer C, create offer D...<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA8_EA1_EA1991" ;
