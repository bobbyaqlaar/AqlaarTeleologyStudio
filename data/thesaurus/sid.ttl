    skos:definition "These three entities inherit from Hardware through additional entities. The real inheritance will be shown in subsequent diagrams.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA2752" ;
