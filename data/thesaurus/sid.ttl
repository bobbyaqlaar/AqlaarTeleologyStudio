<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA6_EA2973> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA6_EA2971> ;
    skos:definition "Values: true,falseDefault: False"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA6_EA2973" ;
    skos:prefLabel "AuthenticationEntity"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA6_EA2974> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA6_EA2971> ;
    skos:definition "Values: true,falseDefault: False"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA6_EA2974" ;
    skos:prefLabel "AuthorizationEntity"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA6_EA2975> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA6_EA2971> ;
    skos:definition "SecurityInfo is the base class for all security classes. Different types of security settings and semantics are associated with a particular Resource or Service using the DescribedByMgmtInfo aggregation. Subclasses of this class define the detailed characteristics and behavior of this class. Examples of security subclasses include AuthenticationEntity, AuthorizationEntity, and AuditingEntity.<br/><br/>Security settings are implemented and reported on by associating the parent of this class, ManagementInfo, with the ManagementMethodEntity class through a combination of the DescribedByMgmtInfo and the MgmtInfoObtainedBy aggregation.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA6_EA2975" ;
    skos:prefLabel "SecurityInfo"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA7_EA2976> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA7_EA2978> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Service State </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA7_EA2976" ;
    skos:prefLabel "Figure SvsSt.01 - Serviice State ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA7_EA2979> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA7_EA2978> ;
    skos:definition "ServiceStateInfo is an abstract base class for representing different types of management information that describes the state of a particular Service. This can be a CustomerFacingService or a ResourceFacingService.<br/><br/>Subclasses of this class include classes to represent Faults, Outages, Alarms, the usage of this Resource, and its current operational state.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA7_EA2979" ;
    skos:prefLabel "ServiceStateInfo"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA8_EA2980> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA8_EA2982> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Service Statistical Info </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA8_EA2980" ;
    skos:prefLabel "Figure SvStat.01 - Service Statistical Info ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA8_EA2983> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA8_EA2982> ;
    skos:definition "Values: true,falseDefault: False"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA5_EA8_EA2983" ;
    skos:prefLabel "ServiceStatisticalInfo"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA1_EA2996> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA1_EA2998> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Bridging Protocols </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA1_EA2996" ;
    skos:prefLabel "Figure BP.01 - Bridging Protocols ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA1_EA2999> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA1_EA2998> ;
    skos:definition "Bridging Protocols operate at the data link layer of the OSI model, and are used to define communications over different types of homogeneous and heterogeneous local area networks.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA1_EA2999" ;
    skos:prefLabel "BridgingProtocol"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA1_EA3000> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA1_EA2998> ;
    skos:definition "Values: true,falseDefault: False"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA1_EA3000" ;
    skos:prefLabel "RSRBridging"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA1_EA3001> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA1_EA2998> ;
    skos:definition "Source-route bridges are used almost exclusively in Token Ring networks. In a SRB network, the source device prescribes the route to the destination and indicates its desired path. SRBs store and forward the frames as indicated by the route appearing in the appropriate frame field.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA1_EA3001" ;
    skos:prefLabel "SRBridging"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA1_EA3002> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA1_EA2998> ;
    skos:definition "Source-route transparent (SRT) bridges are a hybrid of translational bridges and source-route bridges, as they are able to forward traffic from both transparent and source-route end nodes.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA1_EA3002" ;
    skos:prefLabel "SRTBridging"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA1_EA3003> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA1_EA2998> ;
    skos:definition "Transparent bridges are used almost exclusively in Ethernet networks. They are so named because their presence and operation are transparent to the network hosts. This type of bridge learns host locations by analyzing the source address of incoming frames from all attached networks, and then uses this information to forward traffic. If a bridge receives a frame to which no association is found, it floods all ports except the inbound port.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA1_EA3003" ;
    skos:prefLabel "TransparentBridging"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA2984> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA2986> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Protocol Service </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA2984" ;
    skos:prefLabel "Figure PS.01 - Protocol Service ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA2990> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA2986> ;
    skos:definition "A Protocol is a formal set of rules and conventions that governs how two entities exchange information (usually over one or more types of network media).<br/><br/><br/><br/>This is an abstract base class for representing Protocols that can be managed. This class represents a convenient aggregation point for defining how Protocols are managed and used.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA2990" ;
    skos:prefLabel "Protocol"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA2_EA3004> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA2_EA3006> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>LAN Protocols </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA2_EA3004" ;
    skos:prefLabel "Figure LP.01 - LAN Protocols ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA2_EA3007> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA2_EA3006> ;
    skos:definition "Values: true,falseDefault: False"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA2_EA3007" ;
    skos:prefLabel "Ethernet"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA6_EA2_EA3008> a skos:Concept ;
