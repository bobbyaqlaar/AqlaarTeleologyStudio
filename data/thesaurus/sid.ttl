<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA22_EA6356> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA22_EA6347> ;
    skos:definition "A Graph expressing an adjacency requirement or property, independently from how this is realized.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA22_EA6356" ;
    skos:prefLabel "AdjacencyGraph"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA22_EA6357> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA22_EA6347> ;
    skos:definition "A Graph expressing the realization of adjacency.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA22_EA6357" ;
    skos:prefLabel "ConnectivityGraph"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA22_EA6358> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA22_EA6347> ;
    skos:definition "Directed edge specify relationships between Vertices in a graph . They usually have a type -such as port contained within a slide-in-unit, powered by , etc. Practical use of Directed Edge in graph are to provide restricted (subset ) views of all the multiple relationships between vertices. . In the TMF920A Topology Discovery Service API Component Suite and the TMF686 Topology API these edges can be derived for information in multiple dissimilar inventories but normalized to a standard set of types to support many common processes such as anomaly detection , establishing availability of equipment at specific locations to support provisioning<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA22_EA6358" ;
    skos:prefLabel "DirectedEdge"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA22_EA6359> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA22_EA6347> ;
    skos:definition "This is an abstract base class that is used to define the common characteristics (attributes, constraints, and relationships) of a Directed Edge.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA22_EA6359" ;
    skos:prefLabel "DirectedEdgeSpecfication"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA22_EA6360> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA22_EA6347> ;
    skos:definition "Entity representing a mathematical graph using directed edges. A topology graph can be used to define relationship between Vertices to support many operational processes . For example in preventative maintenance having a topology graph that record the dependency relationships between Customers, their Products, the Services and the logical and physical resources that support them can be used to make predictions such as 'if this manhole is predicted to flood in the next 2 hours which customers are affected and what can be done to minimize disruption to that customer.'<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA22_EA6360" ;
    skos:prefLabel "Graph"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA22_EA6361> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA22_EA6347> ;
    skos:definition "This is an abstract base class that is used to define the common characteristics (attributes, constraints, and relationships) of a Graph.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA22_EA6361" ;
    skos:prefLabel "GraphSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA22_EA6362> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA22_EA6347> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA22_EA6362" ;
    skos:prefLabel "ImageAsset"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA22_EA6363> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA22_EA6347> ;
    skos:definition "A type of knowledge base that uses a graph-structured data model to integrate data and store interlinked descriptions of entities. It is made up of nodes, edges, and labels, and is often used to represent real-world entities and their relationship- Wikipedia.<br/>As OSS and BSS start to incorporate AI, Knowledge graphs are created for capturing the relationships between customers’ products, services, and resources including network. Knowledge Graphs can be modelled as a specialization of mathematical graph but with a broader set of relationship types than is typical in network topology graphs.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA22_EA6363" ;
    skos:prefLabel "KnowledgeGraph"@en .

