<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA8_EA2312> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA2023> ;
    skos:definition "The <b>Service Test ABE</b> defines measurement including units and values and how the values are determined. It also includes thresholds used to evaluate the measure and the consequences of violating the thresholds as well as the Service Test measures that reflect the functioning of the Service under test.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA6_EA8_EA2312" ;
