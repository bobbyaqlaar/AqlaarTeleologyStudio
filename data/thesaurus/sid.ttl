    skos:definition "The definition of an SoftwareResourceSpecification whose attribute values are shared by every instance of an SoftwareResource related to it. This entity is a super-class for<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA2_EA3_EA4_EA1_EA2615" ;
