    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "Figure Ch.04 shows how characteristics can be added for an entity whether the entity has an associated specification or not. In the figure two characteristics have been added to the Service Entity in general, independent of those that may be added to instances of ServiceSpecifications. The RootEntityType in the SID is populated with a list of all business entities contained in the SID. The Characteristic model shown in Figure Ch.04 shows how CharactersticSpecifications are be associated with the RootEntityType.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4512" ;
    skos:prefLabel "Figure R.28 - Characteristic Spec Instance - Example 2_Collaboration"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4808> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4759> ;
