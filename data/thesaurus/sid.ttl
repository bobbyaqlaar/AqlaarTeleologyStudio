<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA2_EA1_EA3531> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA2_EA1_EA3530> ;
    skos:definition "A SalesProductSpecification specifies the role of CSP for a ProductSpecification sold or rented by the Service Provider.<br/><br/>FulfilledSalesProdSpec is a SalesProductSpecification for which the Service Provider take the order and fulfill the product.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA2_EA1_EA3531" ;
    skos:prefLabel "FulfilledSalesProdSpec"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA2_EA1_EA3532> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA2_EA1_EA3530> ;
    skos:definition "A SalesProductSpecification specifies the role of CSP for a ProductSpecification sold or rented by the Service Provider.<br/><br/>OrderedOnlySalesProdSpec is a SalesProductSpecification for which the Service Provider only take the order on behalf of another Party.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA2_EA1_EA3532" ;
    skos:prefLabel "OrderedOnlySalesProdSpec"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA2_EA1_EA3533> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA2_EA1_EA3530> ;
    skos:definition "A SalesProductSpecification specifies the role of CSP for a ProductSpecification bought by the Service Provider.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA2_EA1_EA3533" ;
    skos:prefLabel "PurchaseProductSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA2_EA1_EA3534> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA2_EA1_EA3530> ;
    skos:definition "A SalesProductSpecification specifies the role of CSP for a ProductSpecification sold or rented by the Service Provider.<br/><br/>For a SalesProductSpecification the Service Provider might:<br/><br/>• Either only take the order on behalf of another Party (OrderedOnlySalesProdSpec),<br/><br/>• Or take the order and fulfill the product (FulfilledSalesProdSpec).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA2_EA1_EA3534" ;
    skos:prefLabel "SalesProductSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA2_EA3522> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA2_EA3524> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Party Role Product Specification </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA2_EA3522" ;
    skos:prefLabel "Figure PRPS.01 - Party Role Product Specification ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA2_EA3526> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA2_EA3524> ;
    skos:definition "A relationship, such as purchase for resell, broker as-is for resale, between PartyRoleProductSpecifications.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA2_EA3526" ;
    skos:prefLabel "PartyRoleProdSpecRelationship"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA2_EA3527> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA2_EA3524> ;
    skos:definition "A ProductSpecification made available by a PartyRole.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA2_EA3527" ;
    skos:prefLabel "PartyRoleProductSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3452> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3492> ;
    skos:definition "The following Figure shows the current model. Associations from them to entities in Party Product Specification and Offering ABEs have been added. The new ABEs and associations to existing entities will be shown later in this document.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA3452" ;
    skos:prefLabel "Figure PPSO.00 - Key Product Domain Business Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3454> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3492> ;
    skos:definition "<font color=\"#e0121d\"><b>Examples to Illustrate the New ABEs</b></font><br/><font color=\"#29313b\">Shown here are examples that illustrate the various ways a PartyRole is involved with ProductSpecifications and ProductOfferingSpecifications. These will be used to explain the need for new ABEs. They will be used later in this document to show instances of the entities in the new ABEs.</font><br/><font color=\"#29313b\">Note 1: The examples presented below are based on two different kinds of marketplace illustrating various types of roles between the various business partners. The reader should interpret these examples in the context of a Telecom Service Provider who has created its own marketplace with different business partners exposing various digital product offering such as telecom devices, alarm, IoT systems, music or movies distribution services, etc...</font><br/><font color=\"#29313b\">Note 2: All the illustrations express the views of the Service Provider.</font><br/><font color=\"#29313b\"><b>Amazon Example</b></font><br/><font color=\"#29313b\">There are various ways in which an offering can be made to the market. Amazon was chosen as an example because of the variety of ways it does so. These and other ways offerings are made available in today’s digital world should be supported by the Information Framework.</font><br/><font color=\"#29313b\">The Amazon example shows the various ways Amazon offers a Thermo-Kitty Heated cat bed, one of which is offered by Amazon, and offered on behalf of other vendors.</font><br/><font color=\"#29313b\">Three offers are proposed by Amazon.</font><br/><font color=\"#29313b\">The first offer is Amazon’s offer for which Amazon is in charge of all the processes (order handling, purchasing, fulfillment,..). The price for this offer is $38.95.</font><br/><font color=\"#29313b\">The second offer is Quidsi’s offer for which Quidsi is the provider and has delegated several processes to Amazon (order handling, fulfillment, collecting payment..). The price for this offer is $44.79.</font><br/><font color=\"#29313b\">The third offer is GlobalPets’ offer for which GlobalPets is the provider and has delegated only the order handling to Amazon. The price for this offer is $48.</font><br/><font color=\"#29313b\"><b>Etsy Example</b></font><br/><font color=\"#29313b\">There is another marketplace that makes offers, such as jewelry, furniture, and mobile accessories, available to the market. Etsy is a marketplace where people around the world connect, both online and offline, to make, sell and buy unique goods. The heart and soul of Etsy is our global community: the creative entrepreneurs who use Etsy to sell what they make or curate, the shoppers looking for things they can’t find anywhere else, the manufacturers who partner with Etsy sellers to help them grow, and the Etsy employees who maintain and nurture our marketplace.</font><br/><font color=\"#29313b\">One thing different about this marketplace is that purchases from multiple vendors on a single order are sometimes paid for directly to each vendor when the order is placed with Etsy.</font><br/><font color=\"#e0121d\"><b><br/></b></font><font color=\"#e0121d\"><b>Party Role Product Specification and Offering ABEs</b></font><br/><font color=\"#29313b\">Described here are two new level 2 ABEs that have been added to support the variety of roles played by parties associated with ProductSpecifications and ProductOfferingSpecifications.</font><br/><font color=\"#29313b\">The Party Role Product Specification ABE has been added as a level 2 ABE within the level 1 Product Specification ABE.</font><br/><font color=\"#29313b\">There may be a question as to why this ABE was added in addition to Party Role Product Offering ABE. The answer is:</font><br/><font color=\"#29313b\">The different PartyRoles’ involvement with a ProductSpecification may require different levels of service as defined by ServiceLevelSpecifications. ServiceLevelSpecifications are used by ServiceLevelAgreements and are comprised of parameters that are measured, thresholds, and consequences if a threshold is crossed.</font><br/>The following Figure shows the PartyRoleProductSpecification entity and its related entities.<br/>The PartyRoleProdSpecRelationship entity defines relationships between/among PartyRoleProductSpecification entities.<br/>For example, for a ProductSpecification sold / rented by the Service Provider and bought to a Supplier, it could be useful to have two instances of ProductSpecification in order to be able to either extend its description or restrict the possible configurations of the purchased ProductSpecification. In this case, the PartyRoleProdSpecRelationship would be used to qualify the relation between these two instances.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA3454" ;
    skos:prefLabel "Figure PPSO.01 - Party Role Product Specification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3456> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3492> ;
    skos:definition "The Party Role Product Offering Specification ABE has been added as a level 2 ABE within the level 1 Party Product Specification and Offering ABE. Figure PPSO.01 Party Role Product Offering Specification shows the PartyRoleProductOfferingSpec entity and its related entities.<br/>Below is a description of each Boolean attribute:<br/> • marketedBy is an indicator that specifies if the PartyRoleProductOfferingSpec is marketed by the related PartyRole. For example a Competitor PartyRole may only have this attribute set to true and the other boolean attributes set to false.<br/> • orderTakenBy is an indicator that specifies that the associated PartyRole takes an order for the ProductOfferingSpecification.<br/> • paymentAcceptedBy is an indicator that specifies that the associated PartyRole accepts payment for the ProductOfferingSpecification.<br/> • paymentMadeTo is an indicator that specifies that payment is made to the associated PartyRole for the ProductOfferingSpecification. For example, an entrprise may accept payment on behalf of PartyRole and then send the payment to the PartyRole.<br/> • billedBy is an indicator that specifies that the associated PartyRole submits a bill for the ProductOfferingSpecification.<br/> • postOrderFulfilledBy is used to indicate which PartyRole fulfills the order after it is taken by a PartyRole. <br/> • afterSalesServiceProvidedBy is an indicator that specifies which PartyRole provides the after-sales service.<br/>Originally the orderTakenBy attribute was contained in the PartyRoleProductSpecification entity. However it has been moved to PartyRoleProductOfferingSpec. This was done because CompositeProductOfferingSpecifications do not have to have a related ProductSpecification so there would be no way to indicate who takes an order for a CompositeProductOfferingSpecification.<br/>Additional attributes could be added to specify other processes responsibilities such as warehousedBy, manufacturedBy, etc.<br/><br/>Another way of specifying the processes responsibilities, instead of using Boolean attributes, would be to use a relationship with Process.<br/>Some examples:<br/> • Amazon takes an order on behalf of Quidsi and also fulfills the order. In this case the attribute postOrderFulfilledBy is set to true for Amazon and false for Quidsi<br/> • Amazon takes on order on behalf of Global Pets, sends the order to Global Pets who finishes the fulfillment of the order. In this case the attribute postOrderFulfilledBy is set to false for Amazon and true for Global Pets.<br/>The PartyRoleProdOffSpecRelationship entity defines relationships between/among PartyRoleProductOfferingSpec entities, such as purchase for resell, broker as-is for resale, or ordered from (For example, an enterprise orders resources for its infrastructure from an equipment manufacturer).<br/>There can be many PartyRoleProductOfferingsSpec for one ProductOfferingSpecification, therefore the relationship between PartyRoleProductOfferingSpec and ContractualAgreementItem specializations (FrameworkAgreementItem, ImplementationAgreementItem, SLAItem) is needed to specify which party’s ProductOfferingSpecification applies to the ContractualAgreementItem specializations such as FrameworkAgreementItem, ImplementationAgreementItem or SLAItem.<br/>An example of how an SLA can be either with the re-seller or with the \"underlying\" whole seller/manufacturer in a multi-party sell:<br/> • When a tourist from Europe walks into an electronics shop in Hongkong, and buys a Sony camera, she/he is typically given the choice of either taking the standard \"warranty agreement\" (a kind of SLA), which is an agreement with the shop (the reseller) or exchange it for an \"international warranty\" that is offered by the original manufacturer, Sony, through its international representatives.<br/> • The two agreements have different Terms & Conditions for the end customer of course, and are with two different parties... Tourists will typically choose the international one, as the local one would require them to bring/send the camera back to the shop for inspection.<br/>There is also the need to specify a ProductOfferingPrice with each party’s ProductOfferingSpecification.<br/>There are two options to support this need, which can be chosen by an implementer of this part of the SID model:<br/> 1. Using the association between PartyRoleProductOfferingSpec and ProductOfferingPrice<br/> 2. Creating an instance of a ProductOfferingSpecification for each PartyRole.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA3456" ;
    skos:prefLabel "Figure PPSO.02 - Party Role Product Offering Specification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3458> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3492> ;
    skos:definition "<font color=\"#e0121d\"><b>Example 1</b></font><br/><font color=\"#29313b\">K&H is a vendor who offers the cat bed to Amazon so that Amazon can buy it and sell it. K&H sells it to Amazon for $20.</font><br/><font color=\"#29313b\">K&H’s is a retailer whose cat bed is also for sale on the Amazon site as K&H’s offer. K&H sells it to the public for $25.</font><br/><font color=\"#29313b\">So, the K&H cat bed Product Offering Specification has two prices $20 and $25.</font><br/><font color=\"#29313b\">The first option would include a PartyRoleProductOfferingSpec for K&H the vendor and another PartyRoleProductOfferingSpec for K&H the retailer that is related to the K&H cat bed ProductOfferingSpecification. The relationship between PartyRoleProductOfferingSpec and ProductOfferingPrice provides a way to distinguish which price ($20 or $25) is charged to Amazon or to Amazon’s customers.</font><br/><font color=\"#29313b\">The second option would include a cat bed ProductOfferingSpecification for K&H the vendor and another one for K&H the retailer. The first ProductOfferingSpecification carries the price of 20$ and is dedicated to Amazon, and the second one carries the price of 25$.</font><br/><font color=\"#29313b\">One concern may be that if there is only one ProductOfferingSpecification with the price related to PartyRoleProductOfferingSpec there is a need for two PartyRoleProductOfferingSpecs for Amazon. This is because the processes undertaken by Amazon might be different based on when they buy it from K&H and when they sell it on behalf of K&H). And same concern for K&H. With only one ProductOfferingSpecification there is not a way to determine which price should be used. This is not the case since K&H plays two roles, one of vendor and one of retailer. Amazon would access the vendor PartyRoleProductOfferingSpec and the ProductOfferingPrice ($20) associated with it.</font><br/><font color=\"#e0121d\"><b>Example 2</b></font><br/><font color=\"#29313b\">An enterprise offers a WiFi enable thermostat and as part of a bundle offers an installation service ProductOfferingSpecification. This ProductOfferingSpecification can be provided by one or more other PartyRoles if a customer does not want to do a self-installation.</font><br/><font color=\"#29313b\">Using the first option there is one ProductOfferingSpecification, but each PartyRole that offers the installation service may charge different prices that are displayed on an enterprise’s web pages. In this case there would be PartyRoleProductOfferingSpec for each PartyRole that offers the installation service. Each PartyRoleProductOfferingSpec is related to a ProductOfferingPrice that represents a party’s installation price.</font><br/><font color=\"#29313b\">Using the second option there is one ProductOfferingSpecification and a related ProductOfferingPriceSpecification for each party that offers the installation service. Each ProductOfferingSpecification would be included in the bundle and would have a “mutually exclusive” ProductOfferingRelationshipSpec among them.</font><br/>The following Figure shows the association between PartyRoleProductSpecification and PartyRoleProductOfferingSpec. The association is similar to that between ProductSpecification and ProductOffering<font color=\"#29313b\">Specification</font>. The association’s 0..1 multiplicity allows for offerings, such as CompositeProductOfferingSpecifications, to not have an associated specification.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA3458" ;
    skos:prefLabel "Figure PPSO.03 - Party Role Product Offering Specification and Product Specification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3460> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3492> ;
    skos:definition "<font color=\"#29313b\">The following table synthesizes which PartyRole is in charge of each process.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA3460" ;
    skos:prefLabel "Instance Examples of New Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3462> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3492> ;
    skos:definition "<font color=\"#29313b\">In the example, the same Kitty Heated Cat Bed is available through three offers.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA3462" ;
    skos:prefLabel "Figure PrPo.01 – Illustration.01: Heated Cat Bed ProductOfferingSpecifications"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3464> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3492> ;
    skos:definition "<font color=\"#29313b\">The first offer is Amazon’s offer for which Amazon is in charge of all the processes (order handling, purchasing, fulfillment,…). The price for this offer is $38.95.</font><br/><font color=\"#29313b\">Amazon isn’t a manufacturer of Heated Cat Bed; therefore, Amazon purchases them through a supplier: K&H.</font><br/><font color=\"#29313b\">The first Figure depicts Amazon’s offer of the cat bed. All the involvement related attributes that deal with taking, fulfilling, and revenue generation, such as taking, fulfilling, and billing for the offering, are set to “true”. Amazon’s ordering of the cat bed will be described next.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA3464" ;
    skos:prefLabel "Figure PrPo.01 – Illustration.02: Amazon’s Heated Cat Bed"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3466> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3492> ;
    skos:definition "<font color=\"#29313b\">The second Figure depicts from which PartyRole Amazon orders the cat bed.</font><br/><font color=\"#29313b\">The bed’s manufacturer is K&H as shown. The “K&H Heated Cat Bed” ProductOfferingSpecificaton is a wholesale offer.</font><br/><font color=\"#29313b\">In this illustration the same instance of ProductSpecification is used to describe the Kitty Cat Bed and used by both ProductOfferingSpecification “Amazon Heated Cat Bed” and “K&H Heated Cat Bed”.</font><br/><font color=\"#29313b\">But it could be useful to have two instances of ProductSpecification in order to be able to either extend its description or restrict the possible configurations of the purchased ProductSpecification (K&H may propose it in blue, red or orange, and Amazon may decide to propose only blue or red). In this case, the PartyRoleProdSpecRelationship would be used to qualify the relation between these two instances.</font><br/><font color=\"#29313b\">There is no instance of a PartyRoleProductOfferingSpec entity that relates Amazon playing the reseller PartyRole to the K&H ProductOfferingSpecification because Amazon does not offer the K&H bed on its web site.</font><br/><font color=\"#29313b\">Amazon orders the cat bed that it lists for sale as shown in Figure 1 from K&H.</font><br/><font color=\"#29313b\">K&H’s PartyRoleProductOfferingSpec orderTakenBy is set to true as the “K&H Kitty Cat Bed” ProductOfferingSpecification is taken by K&H.</font><br/><font color=\"#29313b\">The other attributes are also set to true to indicate that K&H has full involvement in fulfilling, revenue, and servicing orders that it receives from Amazon.</font><br/><font color=\"#29313b\">This face is further re-enforced by the instance of PartyRoleProdOfferSpecRelationship between the Amazon PartRoleProductOfferingSpec and the K&H PartyRoleProductOfferingSpec for the cat beds. In this case the partyRoleProdOfferSpecRelType is set to “ordered From” that indicates that Amazon orders the cat bed offering from K&H.</font><br/><i>Note: the arrows on the links express the orientation of the relationships.</i><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA3466" ;
    skos:prefLabel "Figure PrPo.01 – Illustration.03: K&H’s Heated Cat Bed"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3468> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3492> ;
    skos:definition "<font color=\"#29313b\">The second offer is Quidsi’s offer for which Quidsi is the provider and has delegated several processes to Amazon (order handling, fulfillment, collecting payment..). The price for this offer is $44.79.</font><br/><font color=\"#29313b\">Quidsi </font><br/><ul><li><font color=\"#29313b\">markets the ProductOfferingSpecification,</font></li><li><font color=\"#29313b\">receives the payment from Amazon,</font></li><li><font color=\"#29313b\">is in charge of the after-sale service,</font></li><li><font color=\"#29313b\">sends products to Amazon’s warehouse so that Amazon can ship the product to the customers (postOrderFulfilledBy Amazon)</font></li></ul><p/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA3468" ;
    skos:prefLabel "Figure PrPo.01 – Illustration.04: Quidsi’s Heated Cat Bed"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3470> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3492> ;
    skos:definition "<font color=\"#29313b\">The third offer is GlobalPets’ offer for which GlobalPets is the provider and has delegated only the order handling to Amazon. The price for this offer is $48.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA3470" ;
    skos:prefLabel "Figure PrPo.01 – Illustration.05: GlobalPet’s Heated Cat Bed"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3472> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3492> ;
    skos:definition "The PartyRoleProductSpecification might be further specialized in order to detail the role played by the ProductSpecification seen by the ServiceProvider.<br/>The following Figure depicts the different types of PartyRoleProductSpecification that could be used.<br/>A ProductSpecification may sold / rented by the Service Provider (SalesProductSpecification) or bought by the Service Provider (PruchaseProductSpecification).<br/>For a SalesProductSpecification the Service Provider might:<br/> • Either only take the order on behalf of another Party (OrderedOnlySalesProdSpec),<br/> • Or take the order and fulfill the product (FulfilledSalesProdSpec).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA3472" ;
    skos:prefLabel "Figure PPSO.04 - Party Role Prod Spec Subclasses"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3474> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3492> ;
    skos:definition "<font color=\"#29313b\">In the Amazon’s example,the GlobalPets’ offer makes available an OrderedOnlySalesProdSpec,the Amazon’s offer makes available a FulfilledSalesProdSpec, and the K&H offer makes available a PurchaseProductSpecification</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA3474" ;
    skos:prefLabel "Figure PPSO.04 – Illustration.06: GlobalPet’s ProductSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3476> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3492> ;
    skos:definition "<font color=\"#29313b\">Here for the Amazon’s and K&H example we assume that Amazon proposes less possible colors for the Heated Cat Bed than K&H proposes. That’s why there is one instance of ProductSpecification for Amazon and one for K&H.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA3476" ;
    skos:prefLabel "Figure PrPs.02 – Illustration.07: Amazon’s and K&H’s ProductSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3478> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3492> ;
    skos:definition "A SalesProductSpecification may be sold / rented by the Service Provider, therefore CustomerOrders might be placed to order it.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA3478" ;
    skos:prefLabel "Figure PPSO.05 - Sales Product Specification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3480> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3492> ;
    skos:definition "Several possibilities may exist for the fulfillment of a FulfilledSalesProdSpec:<br/> • Either the Service Provider is able to realize the non-tangible product (realized as a CFServiceSpec),<br/> • either the Service Provider is able to realize the tangible product (realized as a ResourceSpecification),<br/> • Or the ServiceProvider is not able to realize the product and has to buy it to another Party (realized as a PurchaseProductSpecification)<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA3480" ;
    skos:prefLabel "Figure PPSO.06 - Fulfilled Sales Product Specification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3482> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3492> ;
    skos:definition "<font color=\"#29313b\">In the Amazon’s example the FulfilledProdSpecRealizedAsPPSpec would be used as presented in the following illustration, but only if Amazon don’t have a warehouse with Heated Cat Bed and purchase to K&H a K&H Heated Cat Bed ProductOfferingSpecification for each customer buying an Amazon Heated Cat Bed ProductOfferingSpecification.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA3482" ;
    skos:prefLabel "Figure PPSO.06 – Illustration.08: Amazon’s and K&H’s RealizedAs relationship"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3484> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3492> ;
    skos:definition "<font color=\"#29313b\">If Amazon buys in advance the K&H Heated Cat Bed ProductOfferingSpecification and stock them in a warehouse to ship a product from the warehouse for each customer buying an Amazon Heated Cat Bed ProductOfferingSpecification, then this is the ProdSpecRealizedAsResourceSpec relationship that would be used as depicted in the following illustration.</font><br/><font color=\"#29313b\">An example for the ProdSpecRealizedAsCFServiceSpec relationship would be a MobileLine ProductSpecification realized as a Mobile Access CustomerFacingSpec.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA3484" ;
    skos:prefLabel "Figure PPSO.06 – Illustration.09: Amazon’s and Product RealizedAs relationship"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3486> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3492> ;
    skos:definition "Several reasons may induce the acquisition of a PurchaseProductSpecification.<br/>It can be:<br/>• Either to realize completely a FulfilledSalesProdSpec,<br/>• Either to realize a CustomerFacingServiceSpec as part of the needs for a FulfilledSalesProdSpec,<br/>• Either to realize a ResourceFacingServiceSpec as part of the needs for a FulfilledSalesProdSpec,<br/>• or to realize a ResourceSpecification whatever it is needed as part of a FulfilledSalesProdSpec, as part of the Service Provider network, etc.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA3486" ;
    skos:prefLabel "Figure PPSO.07 - Purchase Product Specification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3488> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3492> ;
    skos:definition "The following Figure gives an overview of all the relationships the different types of PartRoleProductSpecification.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA3488" ;
    skos:prefLabel "Figure PPSO.08 - Party Role Product Spec Relationships Overview"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3490> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA3492> ;
    skos:definition "The following Figure depicts the different types of PartyRoleProductOfferingSpec that could be used.<br/>A ProductOffering<font color=\"#29313b\">Specification</font> may be sold / rented by the Service Provider (SalesProductOfferingSpec) or bought by the Service Provider (PurchaseProductOfferingSpec).<br/>A CustomerOrderItem involves a SalesProductOfferingSpec and a PartyOrderItem involves a PurchaseProductOfferingSpec.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA3490" ;
    skos:prefLabel "Figure PPSO.09 - Party Role Product Offering Specification sub-classes"@en .

