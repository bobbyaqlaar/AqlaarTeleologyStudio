<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA7_EA1404> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA4_EA1186> ;
    skos:definition "The <b>Customer Problem ABE </b>focuses on technical assistance and problem handling for customers.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA4_EA7_EA1404" ;
