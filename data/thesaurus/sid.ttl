<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA9_EA3361> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA9_EA3330> ;
    skos:definition "ResourceFromStockItemChoice is managed by PolicyRule defining without ambiguity among several possible Resources, which one must be used for a StockItem.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA9_EA3361" ;
    skos:prefLabel "ResourceFromStockItemChoice"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA9_EA3362> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA9_EA3330> ;
    skos:definition "A ShipmentCheckPoint tracks information related to a step of StockItemShipment.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA9_EA3362" ;
    skos:prefLabel "ShipmentCheckPoint"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA9_EA3363> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA9_EA3330> ;
    skos:definition "A ShipmentTracking tracks the progress of a StockItemShipment.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA9_EA3363" ;
    skos:prefLabel "ShipmentTracking"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA9_EA3364> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA9_EA3330> ;
    skos:definition "A StockItem represents items used by Supply Chain for Stock and Shipping Management.<br/><br/>The codeModel specifies the type of codification used for the stockItemCode.<br/><br/>Two main types exist: EAN (European Article Numbering) or GTIN (Global Trade Item Numbering). A GTIN consists of a GS1 Company Prefix, an Item Reference Number and a Check Digit. <br/><br/>Each of them is further defined by the length of the number such as EAN 13, GTIN-12 (USA / Canada for individual products), GTIN-13 (Rest of World for Individual products), GTIN-14 (Worldwide for Product groupings).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA9_EA3364" ;
    skos:prefLabel "StockItem"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA9_EA3365> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA9_EA3330> ;
    skos:definition "The StockItemCharacteristic represents parameters describing StockItems such as Color, Height, Weight...<br/><br/>Note: A StockItem has only one value for each StockItemCharacteristic describing the StockItem.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA9_EA3365" ;
    skos:prefLabel "StockItemCharacteristic"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA9_EA3366> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA9_EA3330> ;
    skos:definition "Specifies StockItemCharacteristic used by a StockItem as a StockItemCharacteristic might be reused by several StockItems.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA9_EA3366" ;
    skos:prefLabel "StockItemCharUse"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA9_EA3367> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA9_EA3330> ;
    skos:definition "A StockItemCharValue corresponds to possible values of a StockItemCharacteristic.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA9_EA3367" ;
    skos:prefLabel "StockItemCharValue"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA9_EA3368> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA9_EA3330> ;
    skos:definition "Specifies StockItemCharValue used by a StockItem as a StockItemCharValue might be reused by several StockItems.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA9_EA3368" ;
    skos:prefLabel "StockItemCharValueUse"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA9_EA3369> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA9_EA3330> ;
    skos:definition "A StockItemRequest asks for Booking or Replenishment concerning a StockItemStockLevel:<br/><br/> • Booking request: a booking request might come from a CustomerOrder in progress or simply from a salesperson that plan to place a huge quantity to a Customer. It carries a valid period to avoid freezing the stock.<br/><br/> • Replenishment: a replenishment request is triggered when the quantity is under the reorderLevel. The status is In progress and the end date (from validPeriod) is specified when a corresponding purchase or movement from one StockLocation to another has been triggered.<br/><br/>These requests might be cancelled (for example if the Customer abort his order).<br/><br/>A StockItemRequest might be Received if the corresponding StockItemShipment is completed and the content has not yet been checked.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA9_EA3369" ;
    skos:prefLabel "StockItemRequest"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA9_EA3370> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA9_EA3330> ;
    skos:definition "A StockItemShipment answers StockItemRequests or a ProductOrderItem of ShippingProductSpec. It specifies the place to deliver, the StockLocation from which StockItems have to be moved and PartyRole to be informed of progress.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA9_EA3370" ;
    skos:prefLabel "StockItemShipment"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA9_EA3371> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA9_EA3330> ;
    skos:definition "A StockItemShipmentItem specifies the StockItem that must be shipped and the StockItemStockLevel from which StockItem(s) must be destocked.<br/><br/>When StockItemShipment comes from a ProductOrderItem its StockItemShipmentItems references a GoodsProductSpec ProductOrderItem.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA9_EA3371" ;
    skos:prefLabel "StockItemShipmentItem"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA9_EA3372> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA9_EA3330> ;
    skos:definition "A StockItemStockLevel represents the Stock Level of a StockItem stored in a StockLocation and available for SalesChannels.<br/><br/>A StockItemStockLevel might be<br/><br/> • Available for sale to customers limited to SalesChannels<br/><br/> • Available for use to build the Network or to provide furniture to employees<br/><br/> • Returned: StockItems received back from the Customer that must be checked before being available such as rented material returned<br/><br/> • Damaged: StockItems identified as damaged during a reception from a supplier or returned as damaged by a Customer or Employee<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA9_EA3372" ;
    skos:prefLabel "StockItemStockLevel"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA9_EA3373> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA9_EA3330> ;
    skos:definition "A StockLocation is a place where Resources corresponding to StockItems are stored.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA9_EA3373" ;
    skos:prefLabel "StockLocation"@en .

