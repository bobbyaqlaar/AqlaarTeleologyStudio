<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA21_EA6256> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA21_EA6258> ;
    skos:definition "MaturityModel, a specialized type of Entity, is designed to assess the capability maturity of one ore more Entities, forming a one-to-many relationship where a single MaturityModel can evaluate many Entities. Each MaturityModel is uniquely linked to a MaturityModelSpec where every MaturityModel is described by exactly one MaturityModelSpec, which provides its detailed specification. MaturityModelSpec is a specialization of EntitySpec, inheriting its characteristics in aligns with the broader entity-entuty specification pattern.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA21_EA6256" ;
    skos:prefLabel "Figure MMdl.01 - Basic Maturity Model"@en .

