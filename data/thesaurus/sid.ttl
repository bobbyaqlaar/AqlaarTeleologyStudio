    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA3_EA3_EA2603> ;
    skos:definition "An ComputeRequirementSpec is an example of type of HostingPlatformRequirementSpec. It describes Compute requirements for SoftwareSpecification.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA2_EA3_EA3_EA2604" ;
    skos:prefLabel "ComputeRequirementSpec"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA3_EA3_EA2605> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA3_EA3_EA2603> ;
    skos:definition "An ConnectivityRequirementSpec is an example of type of HostingPlatformRequirementSpec. It describes Connectivity requirements for SoftwareSpecification.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA2_EA3_EA3_EA2605" ;
    skos:prefLabel "ConnectivityRequirementSpec"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA3_EA3_EA2606> a skos:Concept ;
