    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA2_EA1_EA4039" ;
    skos:prefLabel "PartyRoleSecurityEntity"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA1_EA4040> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA2_EA1_EA4037> ;
