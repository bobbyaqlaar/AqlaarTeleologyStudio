<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA8_EA782> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA8_EA788> ;
