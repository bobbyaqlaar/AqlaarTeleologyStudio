<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA23_EA6412> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA23_EA6398> ;
    skos:definition "Actual costs represent the real, verified expenses that have been incurred and recorded.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA23_EA6412" ;
    skos:prefLabel "ActualCost"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA23_EA6421> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA23_EA6398> ;
    skos:definition "Projected costs refer to estimated or forecasted expenses that are anticipated to be incurred in the future<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA23_EA6421" ;
    skos:prefLabel "ProjectedCost"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA6_EA4596> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "The Root Entity Group ABE enables groups of Root Entities to be related as an alternate to using the RootEntityRelationship entity in order to reduce the number of instances of RootEntityRelationship. It also enables choices of Root Entities to be made from the group. For example, choose 3 out of 7 channel packs. And, to define expressions that constrain Root Entity members of a group. For example, either channel pack 3 or channel pack 4 can be chosen, but not both.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA6_EA4596" ;
    skos:prefLabel "Root Entity Group ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA1_EA4817> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA5_EA4740> ;
    skos:definition "The Commitment ABE, derived from the Agreement ABE, reflects the mutual agreement between parties about services, products, resources or some other kind of deliverable that has to be provided by the party playing the role of a Commitment fulfiller to the party, playing the role of a Commitment procurer.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA5_EA1_EA4817" ;
    skos:prefLabel "Commitment ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA5_EA5142> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA5032> ;
    skos:definition "The Metric Measure ABE contains entities describing measures according to a MetricDefMeasure such as MetricMeasure.<br/>"@en ;
