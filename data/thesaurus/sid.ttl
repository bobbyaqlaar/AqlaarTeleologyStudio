<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA2_EA2885> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA2_EA2871> ;
    skos:definition "The state identifies a model that has passed the validation stage, and is ready for cataloging (with specifications) and further on deployment.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA2_EA2885" ;
    skos:prefLabel "Trained"@en .

