<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6136> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6105> ;
    skos:definition "Business Rule Action represents an action that is taken when a business rule condition is applied. It includes details such as the action's ID, name, description, creation date, validity period, associated business rule constraint ID, business rule condition ID, activity ID, sequence number, condition logic ID, business rule action event ID, business rule ID, action unit, and priority.<br/><br/>BusinessRuleAction could be a \"policy\" or regulation that outlines or restricts the actions of an associated entity. This could be guidelines about other expected behaviors or how to carry out an activity / workflow / closed loop.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA18_EA1_EA6136" ;
    skos:prefLabel "BusinessRuleAction"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6137> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6105> ;
    skos:definition "BusinessRuleActionSpecification class specifies repeatable characteristics details that specify a business rule action. It includes details such as the specification's ID, name, description, creation date, and validity period.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA18_EA1_EA6137" ;
    skos:prefLabel "BusinessRuleActionSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6138> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6105> ;
    skos:definition "Represents information about operating unit type of business rules. E.g. Currency, Temperature, Bandwidth Speed etc.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA18_EA1_EA6138" ;
    skos:prefLabel "BusinessRuleActionsUnitType"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6140> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6105> ;
    skos:definition "BusinessRuleCondition represents information about the condition(s) that must be met for a business rule. It captures scenarios where the business rule encompasses more than one condition and includes details such as the condition's ID, name, description, creation date, validity period, expression, associated business rule ID, sequence number, condition type, operation type, and priority.<br/>This class captures information to represent the conditions associated with a specific business rule.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA18_EA1_EA6140" ;
    skos:prefLabel "BusinessRuleCondition"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6141> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6105> ;
    skos:definition "Sets the limitation or boundary within which a Business Rule may apply.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA18_EA1_EA6141" ;
    skos:prefLabel "BusinessRuleConditionConstraint"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6142> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6105> ;
    skos:definition "Notes: The date and time when the BusinessRuleConditionConstraintSpecification was created.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA18_EA1_EA6142" ;
    skos:prefLabel "BusinessRuleConditionConstraintSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6143> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6105> ;
    skos:definition "BusinessRuleConditionConstraintType defines the type of a business rule condition constraint. It includes the type's ID, name, description, validity period, and creation date.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA18_EA1_EA6143" ;
    skos:prefLabel "BusinessRuleConditionConstraintType"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6144> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6105> ;
    skos:definition "BusinessRuleConditionGroup represents a set of information of about clustering or pitting business rule conditions together. It includes details such as the group's ID, name, description, validity period, and creation date.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA18_EA1_EA6144" ;
    skos:prefLabel "BusinessRuleConditionGroup"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6145> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6105> ;
    skos:definition "BusinessRuleConditionSpecification specifies details of a business rule condition that can be reused. It includes details such as the specification's ID, name, description, validity period, creation date, associated condition ID, business rule condition ID, business rule condition group ID, and business rule condition specification relationship ID.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA18_EA1_EA6145" ;
    skos:prefLabel "BusinessRuleConditionSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6146> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6105> ;
    skos:definition "BusinessRuleConditionSpecificationRelationship represents the relationship between different business rule condition specifications.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA18_EA1_EA6146" ;
    skos:prefLabel "BusinessRuleConditionSpecificationRelationship"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6147> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6105> ;
    skos:definition "The BusinessRuleGroup describes the grouping of BusinessRules. It identifies the area of zero or more `BusinessRuleArea` groups.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA18_EA1_EA6147" ;
    skos:prefLabel "BusinessRuleGroup"@en .

