    skos:prefLabel "MetDefDescExtension"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA3_EA5098> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA3_EA5094> ;
    skos:definition "The type of the collection such as: gauge, commulative, status inspection. Indicators can be produced using these methods.<br/>"@en ;
