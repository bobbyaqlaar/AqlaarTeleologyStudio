<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA12_EA5587> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA12_EA5563> ;
    skos:definition "A Project achieves a business goal and is a discrete unit of work<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA12_EA5587" ;
    skos:prefLabel "Project"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA12_EA5593> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA12_EA5563> ;
    skos:definition "A ProjectDeliverable is the agreed output of a project. A ProjectDeliverable enables Service-, Ressource- and ProductSpecifications or ProductOfferings.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA12_EA5593" ;
    skos:prefLabel "ProjectDeliverable"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA12_EA5594> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA12_EA5563> ;
    skos:definition "A ProjectDeliverableVersion is the recorded version of a ProjectDeliverable<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA12_EA5594" ;
    skos:prefLabel "ProjectDeliverableVersion"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA12_EA5595> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA12_EA5563> ;
    skos:definition "Fowler provides a good overview of the business problem that requires a calendar [Fowler-Calendar]. A good starting point for our discussion is shown in the following Figure. <br/><br/>Note that here we are using the term Calendar rather than Schedule.<br/><br/>A Calendar has an owner who can control updates to it. The Calendar could also be associated with Assets like a Site or a Workgroup.<br/><br/>A Calendar contains Calendar Entries. These entries are related to events and have a temporal expression that indicates the Time Periods for the entry. Note that an entry may have repeating Time Periods in the temporal expression.<br/><br/>In the following Figure, the slashes on the associations denote that the association is derived. This is because the entities are logically associated, but the actual association is done via subclasses of the entities.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA12_EA5595" ;
    skos:prefLabel "ProjectEvent"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA12_EA5596> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA12_EA5563> ;
    skos:definition "The ProjectScope defines the \"functional area\" impacted by a project that can be expressed by eTOM process elements, SID entities and/or TAM application which might be effected by the project. In a multi-project environment (or a program) the scopes of those projects might be structured in a (composite) hierarchy.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA12_EA5596" ;
    skos:prefLabel "ProjectScope"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA12_EA5597> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA12_EA5563> ;
    skos:definition "Specifies characteristics that apply to types of Projects<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA12_EA5597" ;
    skos:prefLabel "ProjectSpec"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA12_EA5599> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA12_EA5563> ;
    skos:definition "Values: true,falseDefault: False"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA12_EA5599" ;
    skos:prefLabel "SimpleProject"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA12_EA5600> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA12_EA5563> ;
    skos:definition "The Vision is the common understanding of all parties involved in a project (either directly or as a stakeholder) about the goals of a project, the key success criteria, timeline and impact of not doing the project. The Vision is associated to a business objective.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA12_EA5600" ;
    skos:prefLabel "Vision"@en .

