    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA2765" ;
    skos:prefLabel "ResourceRelationship"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA2766> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA2749> ;
    skos:definition "A ResourceRole defines the concept of various types of roles associated with Resources (both physical and logical) in the model.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA2766" ;
    skos:prefLabel "ResourceRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2799> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2825> ;
    skos:definition "<font color=\"#29313b\">This section presents a number of scenarios that show how the changes introduced in this document support current Resources as well as Resources needed to support digital services, such as WpaaS, virtual network elements, and data centers of the future.</font><br/><font color=\"#29313b\"><b>Software Compatibility and Running Software</b></font><br/><font color=\"#29313b\">This first scenario is divided into two parts. The first part depicts Software Inventory. The second part depicts the use of other Resources by running Software.</font><br/><font color=\"#e0121d\"><b>Software Inventory</b></font><br/><font color=\"#29313b\">Management System to scan devices, retrieve installed software versions and report any out of date versions.</font><br/><font color=\"#29313b\">Device1 of type RTR123</font><br/><font color=\"#29313b\"> ACME_OS version 2.1 INSTALLED</font><br/><font color=\"#29313b\"> Security_hlpr version 6.11 INSTALLED</font><br/><font color=\"#29313b\">Device2 of type RTR124</font><br/><font color=\"#29313b\"> ACME_OS version 2.3 INSTALLED </font><br/><font color=\"#29313b\">Software (relating CompoundResourceSpecifications and CompoundResources to SoftwareSpecifications and Software)</font><br/><font color=\"#29313b\">Software</font><br/><font color=\"#29313b\"> ACME_OS 1.0 Initial release 257 MB</font><br/><font color=\"#29313b\"> ACME_OS 2.1 Next Generation 562 MB</font><br/><font color=\"#29313b\"> ACME_OS 2.1.1 NG Minor enhancement 583 MB</font><br/><font color=\"#29313b\">RTR123 can run</font><br/><font color=\"#29313b\"> ACME_OS 1.0 OBSOLETE</font><br/><font color=\"#29313b\"> ACME_OS 2.1</font><br/><font color=\"#29313b\"> ACME_OS 2.1.1 CURRENT</font><br/><font color=\"#29313b\">RTR124 can run</font><br/><font color=\"#29313b\"> ACME_OS 2.1</font><br/><font color=\"#29313b\"> ACME_OS 2.3 CURRENT</font><br/><ul><li><font color=\"#29313b\"><i>Note: Only selected instances from the example above will be shown in the instance diagrams that follow.</i></font></li></ul><font color=\"#29313b\">The following Figure shows the instances of the ACME OS Operating System.</font><br/><font color=\"#29313b\">The instances are considered CompositeSoftwareSpecfications so that the components of them can be shown as AtomicSoftwareSpecifications.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2799" ;
    skos:prefLabel "Figure 1. CAI.01 – Software Specifications"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2801> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2825> ;
    skos:definition "<font color=\"#29313b\">The following Figure shows the operating systems that can run on router 123 along with their status.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2801" ;
    skos:prefLabel "Figure 2. CAI.02 – Software Specifications and Compound Resource Spec RTR123"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2803> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2825> ;
    skos:definition "<font color=\"#29313b\">The following Figure shows two instances of Software being used by a CompoundResource.</font><br/><br/><font color=\"#29313b\">The lrStatus of 1 indicates the Software is “OK”, or installed and ready for use.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2803" ;
    skos:prefLabel "Figure 3. CAI.03 – Software Inventory and Compound Resource Device 1"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2805> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2825> ;
    skos:definition "<font color=\"#e0121d\"><b>Running Software</b></font><br/><font color=\"#29313b\">Management System is managing compute capacity, it will report any CompoundResource with CPU#gt;70% or Memory#gt;80% or storage#gt;90% used. The device is then accessed to see what running Software is using the CPU or memory and what installed Software is using the storage.</font><br/><font color=\"#29313b\">Device1 of type RTR123</font><br/><font color=\"#29313b\">Process 1157 abc.exe using 100Mhz CPU, 200MB memory</font><br/><font color=\"#29313b\">File abc.exe using 126,384 bytes on flash drive</font><br/><font color=\"#29313b\">(note that abc.exe is part of the Security_hlpr installed package)</font><br/><font color=\"#29313b\">Process 6824 abc.exe using 80Mhz CPU, 185MB memory</font><br/><font color=\"#29313b\">File abc.exe using 126,384 bytes on flash drive (this is the same file as used in process 1157)</font><br/><font color=\"#29313b\">(note that abc.exe is part of the Security_hlpr installed package)</font><br/><font color=\"#29313b\">Process 1287 abc_ui.exe using 10Mhz CPU, 20MB memory</font><br/><font color=\"#29313b\">File abc_ui.exe using 12,38 bytes on flash drive</font><br/><font color=\"#29313b\">(note that abc_ui.exe is part of the Security_hlpr installed package)</font><br/><font color=\"#29313b\">Process 6314 os11krnl.exe using 200Mhz CPU, 400MB memory</font><br/><font color=\"#29313b\">File os11krnl.exe using 465,412 bytes on flash drive</font><br/><font color=\"#29313b\">(note that os11krnl.exe is part of the ACME_OS installed package)</font><br/><font color=\"#29313b\"><br/></font><font color=\"#29313b\">The following Figure shows the use of a FlashDisk by running Software. Note the only selected instances from the example above are shown in the instance diagram.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2805" ;
    skos:prefLabel "Figure 4. CAI.04 – Running Software and Compound Resource Device 1"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2807> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2825> ;
    skos:definition "<font color=\"#e0121d\"><b>Virtual Desktop – Work Place as a Service (WpaaS)</b></font><br/><font color=\"#29313b\">This scenario consists of two parts and shows the Resource domain aspects of a Work Place as a Service (WpaaS) offering to the market. The first demonstrates the model’s support for software associated with a virtual desktop. The second demonstrates support for the virtual network elements on which the desktops and their software run. Figure WP.01 – Virtual Desktop WpaaS shows the Resources involved to provide the service.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2807" ;
    skos:prefLabel "Figure 5. WP.01 – Virtual Desktop WpaaS"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2809> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2825> ;
    skos:definition "<font color=\"#e0121d\"><b>Virtual Desktop Software</b></font><br/><font color=\"#29313b\">The virtual desktop can be viewed as a virtual element, the Operating System (OS) as software, and a desktop productivity package is composite software consisting of word processer, presentation developer, spreadsheet, and email. The virtual desktop and OS with the productivity package will be shown in a later figure.</font><br/><font color=\"#29313b\">Figure CAI.05 – Desktop Software Productivity Package shows an instance of the Desktop Productivity Package as a SoftwareComposite entity.</font><br/><font color=\"#29313b\"><br/></font><font color=\"#29313b\">The applications that make up the package are shown as instances of SoftwareAtomic. If the “internals” of these applications should also be instantiated, then the applications would also be instances of SoftwareComposite. The internals would be either instances of SoftwareComposite or SoftwareAtomic based on the level of detail that is desired to be instantiated.</font><br/><font color=\"#29313b\">Note that the instances of the specifications for these would parallel the composite/atomic instantiation. For example, the specification for the Desktop Productivity Package would be an instance of CompositeSoftwareSpecification.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2809" ;
    skos:prefLabel "Figure 6. CAI.05 – Desktop Software Productivity Package"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2811> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2825> ;
    skos:definition "<font color=\"#29313b\">The following Figure shows the licensing and using details of the desktop productivity package by a PartyRole, such as a Customer.</font><br/><br/><ul><li><font color=\"#29313b\"><i>Note that this scenario only shows the Resource aspects of WpaaS. There are also a Product aspect and a Service aspect which are outside the scope of this document. However, a simple explanation of what these aspects would resemble is provided here.</i></font></li></ul><font color=\"#29313b\">There would be instances of ProductSpecification (Composite and Atomic) and ProductOfferingSpecification (Composite and Atomic) and Product (Composite and Atomic) for the desktop productivity package. Similarly, there would be instances of CustomerFacingServiceSpecs and ResourceFacingServiceSpecs as well as CustomerFacingService and ResourceFacingService (composites and atomics of all instances) that represent how the Product domain entities are configured and activated within a provider/operator’s technical infrastructure.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2811" ;
    skos:prefLabel "Figure 7. CAI.06 – Subscription to Productivity Package"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2813> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2825> ;
    skos:definition "<font color=\"#e0121d\"><b>Virtual Desktop and Operating System (OS)</b></font><br/><font color=\"#29313b\">This part of the scenario shows the virtual desktop as an instance of a CompoundResource, the Operating System (OS) as an instance of SoftwareComposite that comprises part of the virtual desktop, and the desktop productivity package running on the OS.</font><br/><font color=\"#29313b\">Figure CAI.07 – Productivity Package Running on Virtual Desktop shows the instances of the entities and associations between them.</font><br/><font color=\"#29313b\"><br/></font><font color=\"#29313b\">In the figure the SoftwareRuns instance represents the Desktop OS instance running the Desktop Productivity Package instance.</font><br/><font color=\"#29313b\">Support for additional types of virtual network elements and their relationships with other types of Resources will be shown in the next scenario.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2813" ;
    skos:prefLabel "Figure 8. CAI.07 – Productivity Package Running on Virtual Desktop"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2815> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2825> ;
    skos:definition "<font color=\"#29313b\"><b>Computer, Virtual Network Elements, and Software Scenario</b></font><br/><font color=\"#29313b\">This scenario consists of a number of parts. Figure CVS.01 – Computer, Virtual Elements, and Software de depicts the entire scenario. It demonstrates support for computing, virtual machines realized by software, and software.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2815" ;
    skos:prefLabel "Figure 9. CVS.01 – Computer, Virtual Elements, and Software"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2817> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2825> ;
    skos:definition "<font color=\"#29313b\">Instance diagrams will show the:</font><br/><ul><li><font color=\"#29313b\">Computing Cluster</font></li><li><font color=\"#29313b\">Computer ABCD</font></li><li><font color=\"#29313b\">Virtual Elements</font></li><li><font color=\"#29313b\">Software running on Software</font></li></ul><font color=\"#29313b\">The computing cluster is show in Figure CAI.08 – Computing Cluster as an instance of ResourceCollection (subclass of CompoundResource) composed of three instances of ResourceElement (subclass of CompoundResource) representing the three computers in the cluster.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2817" ;
    skos:prefLabel "Figure 10. CAI.08 – Computing Cluster"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2819> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2825> ;
    skos:definition "<font color=\"#29313b\">Computer ABCD is shown in the following Figure. It shows the three instances of Virtual Machines (VMs) as well as the Linux operating system running on the computer. Note that the PhysicalResources that comprise the computer are not shown. An instance of a PhysicalDevice could be used since it serves as a point of aggregation for all hardware that makes up the device. </font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2819" ;
    skos:prefLabel "Figure 11. CAI.09 – Computer ABCD"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2821> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2825> ;
    skos:definition "<font color=\"#29313b\">An alternative is to use LogicalDevice instances for the VM’s and associate them to the VM software instances. This would provide the ability to take advantage of LogicalDevice’s associations to other entities, such as TerminationPoints and DeviceInterfaces.</font><br/><font color=\"#29313b\">The following Figure shows Computer ABCD and VMs with the addition of the two instances of virtual routers and VM1 running Java virtual machine software.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2821" ;
    skos:prefLabel "Figure 12. CAI.10 – Computer ABCD Network Elements"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2823> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2825> ;
    skos:definition "<font color=\"#29313b\">The final instance diagram shows the JVM cluster composed of three Java virtual machines and JVM1 running a J2EE Server.</font><br/><br/><font color=\"#e0121d\"><b>API as a digital service</b></font><br/><font color=\"#29313b\">An API can be offered as a digital service product with charging, billing assurance, policy and fulfilment capabilities. Please refer to Root guidebook for an example of how an API can be offered as a digital service.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA2_EA1_EA2823" ;
    skos:prefLabel "Figure 13. CAI.11 – JVM Cluster"@en .

