    skos:notation "sid:EARoot_EA4_EA2_EA6_EA3_EA1_EA5_EA2151" ;
    skos:prefLabel "Usage Volume Service Spec ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA3_EA2_EA2_EA1_EA2180> a skos:Concept ;
