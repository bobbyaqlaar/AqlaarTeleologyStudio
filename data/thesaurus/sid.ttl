<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA7_EA772> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA7_EA706> ;
    skos:definition "The Compound Resource ABE contains entities that are used to represent the various aspects of a CompoundResource.<br/><br/>CompoundResource is a set of entities that shows how to aggregate PhysicalResources and LogicalResources into aggregate entities that has physical and/or logical characteristics and behavior.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA7_EA772" ;
    skos:prefLabel "Compound Resource ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA7_EA776> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA7_EA712> ;
    skos:definition "The CompoundResource Specification ABE used to define the invariant characteristics and behavior (attributes, methods, constraints, and relationships) of a CompoundResource.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA7_EA776" ;
    skos:prefLabel "CompoundResource Specification ABE"@en .

