<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA5_EA1_EA3180> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA5_EA3177> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA5_EA1_EA3180" ;
