<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA8_EA785> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA8_EA784> ;
    skos:definition "<b>Sales Channel ABE</b> keeps track of distribution channels and sales activities, sales quotas, sales, contests, commission/bonus plans, commissions/bonuses, and maintain groups of individuals that make up the sales force.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA8_EA785" ;
    skos:prefLabel "Sales Channel ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA8_EA786> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA8_EA784> ;
    skos:definition "The <b>Sales Commission ABE</b> contains all Business Entities used to specify commissions for Sales Agent, Employees... including commission rules and commissions applied.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA8_EA786" ;
    skos:prefLabel "Sales Commission ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA8_EA787> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA8_EA784> ;
    skos:definition "<b>Sales Forecast ABE </b>maintains sales forecasts, new service requirements, customer needs, and customer education.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA8_EA787" ;
    skos:prefLabel "Sales Forecast ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA8_EA789> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA8_EA784> ;
    skos:definition "<b>Sales Party Roles ABE </b>contains all PartyRoles related to the Sales Domain such as SalesAgent and Prospect.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA8_EA789" ;
    skos:prefLabel "Sales Party Roles ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA8_EA790> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA8_EA784> ;
    skos:definition "The <b>Sales Statistics ABE</b> maintains sales key performance indicators about Sales revenue and sales channel performance.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA8_EA790" ;
    skos:prefLabel "Sales Statistic ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA8_EA791> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA8_EA784> ;
    skos:definition "<b>Sales Strategy Plan ABE</b> supports the business plans and strategies within the Sales domain.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA8_EA791" ;
    skos:prefLabel "Sales Strategy Plan ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA8_EA792> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA8_EA788> ;
    skos:definition "Sales Lead ABE provides the ability to track sales leads through their lifecycle up until the time the prospect becomes a customer.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA8_EA792" ;
    skos:prefLabel "Sales Lead ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA8_EA793> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA8_EA788> ;
    skos:definition "Sales Opportunity ABE provides the ability to track pending deals and the amount of potential revenue the leads represent in the form of a sales pipeline including proposals made to potential customers.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA8_EA793" ;
    skos:prefLabel "Sales Opportunity ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA1_EA842> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA804> ;
