<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA1_EA2774> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA2749> ;
    skos:definition "The Compound Resource ABE contains entities that are used to represent the various aspects of a CompoundResource.<br/>CompoundResource is a set of entities that shows how to aggregate PhysicalResources and LogicalResources into aggregate entities that has physical and/or logical characteristics and behavior.<br/>"@en ;
