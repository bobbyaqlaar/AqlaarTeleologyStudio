    skos:notation "sid:EARoot_EA4_EA2_EA7_EA1_EA2408" ;
    skos:prefLabel "Resource Party Roles ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA2_EA2870> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA3_EA2841> ;
    skos:definition "AI model, also known Artificial Intelligence Model or as a machine learning algorithm, is a software resource representing specific instances of predictive algorithms based on training on particular datasets to perform specific or generalized activities. It is a software \"component\" that can be used to make predictions, classify data, or generate new data/information.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA3_EA2_EA2870" ;
    skos:prefLabel "AI Model ABE"@en .

