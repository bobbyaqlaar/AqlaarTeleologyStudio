    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA1_EA6588> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Contact Medium</b> Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA1_EA6586" ;
    skos:prefLabel "Figure CMd.01 - Contact Medium ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA1_EA6589> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA1_EA6588> ;
    skos:definition "A means by which communication may be established with a party (individual or organization).Contact Medium is an abstract concept that should be subclassed as required.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA1_EA6589" ;
    skos:prefLabel "ContactMedium"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA1_EA6590> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA1_EA6588> ;
    skos:definition "The ContactMediumSpecification describes the type of the ContactMedium.<br/>It corresponds to the specializations of ContactMedium and therefore can be a phone number (mobile, fixed), an email address, a geographical / postal contact address...<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA1_EA6590" ;
    skos:prefLabel "ContactMediumSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA1_EA6591> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA1_EA6588> ;
    skos:definition "The eMail address to use when contacting a given PartyRole. An eMailContact is a type of ContactMedium.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA1_EA6591" ;
    skos:prefLabel "EmailContact"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA1_EA6592> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA1_EA6588> ;
    skos:definition "A number used to communicate information with a printer or other output device.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA1_EA6592" ;
    skos:prefLabel "FaxNumber"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA1_EA6593> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA1_EA6588> ;
    skos:definition "A mechanism by which processes such as “Marketing Campaign Management” and “Marketing Communications and Advertising” advertise broadly parties. It describes such mechanisms as the press, radio, trade shows, internet, and so forth.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA1_EA6593" ;
    skos:prefLabel "Media"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA1_EA6594> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA1_EA6588> ;
    skos:definition "An address where a mail can be addressed to a person or organization.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA1_EA6594" ;
    skos:prefLabel "PostalContact"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA1_EA6595> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA1_EA6588> ;
    skos:definition "A number and type of number assigned to a particular telephone and used in making connections to it.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA1_EA6595" ;
    skos:prefLabel "TelephoneNumber"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA2_EA6596> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA2_EA6598> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Currency</b> Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA2_EA6596" ;
    skos:prefLabel "Figure Cur.01 - Currency ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA2_EA6599> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA2_EA6598> ;
    skos:definition "Represent the currency in reality. Currency uses 1 or more CurrencyUnits. For example, Currency (code=CNY, symbol= ￥) use three CurrencyUnits (Yuan, Jiao, Fen). Currency is associated to CurrencyExchangeRate with CurrencyUsedAsSource and CurrencyUsedAsDestination. Currency can be used in different Countrys.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA2_EA6599" ;
    skos:prefLabel "Currency"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA2_EA6600> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA2_EA6598> ;
    skos:definition "Exchange rate between currencies.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA2_EA6600" ;
    skos:prefLabel "CurrencyExchangeRate"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA2_EA6601> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA2_EA6598> ;
    skos:definition "Name of a currency. Under different languages, a currency has differnent names, e.g. Renminbi Yuan in English and 人民币元 in Chinese to express the same Chinese currency.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA2_EA6601" ;
    skos:prefLabel "CurrencyName"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA2_EA6602> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA2_EA6598> ;
    skos:definition "Measurement unit of a currency. For CurrencyUnitName Yuan associated to Chinese, rate =1, isStdUnit = True, isMinUnit = False.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA2_EA6602" ;
    skos:prefLabel "CurrencyUnit"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA2_EA6603> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA2_EA6598> ;
    skos:definition "Name of a currency unit. Under different languages, a currency unit has differnent names, e.g. Yuan in English and 元 in Chinese to express the same basic currency unit in Chinese currency.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA2_EA6603" ;
    skos:prefLabel "CurrencyUnitName"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA3_EA6604> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA3_EA6606> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Party Community </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA3_EA6604" ;
    skos:prefLabel "Figure PyC.01 - Party Community ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA3_EA6607> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA3_EA6606> ;
    skos:definition "An AssetConsumerRole is a BusinessInteractionRole a party (identified by a CommunityMember) plays when consuming assets from a Community.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA3_EA6607" ;
    skos:prefLabel "AssetConsumerRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA3_EA6608> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA3_EA6606> ;
    skos:definition "An AssetConsumption is a BusinessInteraction, containing items, associated to a Product, that is consumed from a Community as an Asset, by a CommunityMember.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA3_EA6608" ;
    skos:prefLabel "AssetConsumption"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA3_EA6609> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA3_EA6606> ;
    skos:definition "An AssetProviderRole is a BusinessInteractionRole a party (identified by a Community) plays when providing assets to a CommunityMember.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA3_EA6609" ;
    skos:prefLabel "AssetProviderRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA3_EA6610> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA3_EA6606> ;
    skos:definition "A Community is a PartyRole, played by an Organization. CommunityMembers can commit to a Community, contribute Contributions to the Community and consume Assets from a Community.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA3_EA6610" ;
    skos:prefLabel "Community"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA3_EA6611> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA3_EA6606> ;
    skos:definition "A CommunityAdministrator is a PartyRole, played by a Party, who administers a Community.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA3_EA6611" ;
    skos:prefLabel "CommunityAdministrator"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA3_EA6612> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA3_EA6606> ;
    skos:definition "A CommunityMember is a PartyRole, played by an Individual, who is committing to a Community, contributes to it and consumed Assets from the Community.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA3_EA6612" ;
    skos:prefLabel "CommunityMember"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA3_EA6613> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA3_EA6606> ;
    skos:definition "A Contribution is a BusinessInteraction, containing items, associated to Resource, Service or Product that is contributed to a Community by a CommunityMember.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA3_EA6613" ;
    skos:prefLabel "Contribution"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA3_EA6614> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA3_EA6606> ;
    skos:definition "A ContributionProviderRole is a BusinessInteractionRole a party (identified by a CommunityMember) plays when contributing to a Community.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA3_EA6614" ;
    skos:prefLabel "ContributionProviderRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA3_EA6615> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA3_EA6606> ;
    skos:definition "A ContributioReceiverRole is a BusinessInteractionRole a party (identified by a Community) plays when receiving a contribution from a CommunityMember.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA3_EA6615" ;
    skos:prefLabel "ContributionReceiverRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA4_EA6616> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA4_EA6618> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Party Demographic </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA4_EA6616" ;
    skos:prefLabel "Figure PD.01 - Party Demographic ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA4_EA6619> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA4_EA6618> ;
    skos:definition "A type of PartyDemographic that does not have any subordinate PartyDemographics, that is, an AtomicPartyDemographic is a leaf-level PartyDemographic.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA4_EA6619" ;
    skos:prefLabel "AtomicPartyDemographic"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA4_EA6620> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA4_EA6618> ;
    skos:definition "A type of PartyDemographic that is formed by aggregating other PartyDemographics, which may be Composite or Atomic PartyDemographics.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA4_EA6620" ;
    skos:prefLabel "CompositePartyDemographic"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA4_EA6621> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA4_EA6618> ;
    skos:definition "A single value or range of values that can be used to define a DemographicCharacteristic.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA4_EA6621" ;
    skos:prefLabel "DemoCharacteristicValue"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA4_EA6622> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA4_EA6618> ;
    skos:definition "A feature or quality used to make recognizable or to define somebody or something, such as age, income, education, revenue, and so forth.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA4_EA6622" ;
    skos:prefLabel "DemographicCharacteristic"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA4_EA6623> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA4_EA6618> ;
    skos:definition "A feature or quality used to make recognizable or to define a Party playing a PartyRole, such as age, income, education, revenue, and so forth.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA4_EA6623" ;
    skos:prefLabel "PartyDemographic"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA4_EA6624> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA4_EA6618> ;
    skos:definition "A value or text that further defines a Party Demographic, for example household income value of $100,000.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA1_EA4_EA6624" ;
    skos:prefLabel "PartyDemographicValue"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA5_EA6625> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA1_EA5_EA6627> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Identification </b>Aggregate Business Entity.</font><br/>"@en ;
