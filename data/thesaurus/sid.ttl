    skos:prefLabel "Figure LP.03 - Local Place ABE Entities Related to Representation"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7129> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7128> ;
    skos:definition "A LocalLocation that is defined using Cartesian coordinates that relate back to a LocalCoordinateSystem.<br/><br/>The coordinate units are defined in the LocalCoordinateSystem.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA2_EA7129" ;
    skos:prefLabel "AbsoluteLocalLocation"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7130> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7128> ;
    skos:definition "The relative position of something measured independently and not in relation to something else.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA2_EA7130" ;
    skos:prefLabel "AbsoluteLocalOrientation"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7131> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7128> ;
    skos:definition "A geometric representation that includes a minimum bounding volume and also allow for two dimensional representations (each face of the minimum bounding volume) and provide reference point(s) for the shape (for placement).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA2_EA7131" ;
    skos:prefLabel "BoundingVolumeRepresentation"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7132> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7128> ;
    skos:definition "A group of measurements and relationships of lines, angles, surfaces, solids and points used to display internal locations.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA2_EA7132" ;
    skos:prefLabel "CompoundInternalLocation"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7133> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7128> ;
    skos:definition "A group of LocalAddresses.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA2_EA7133" ;
    skos:prefLabel "CompoundLocalAddress"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7134> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7128> ;
    skos:definition "A LocalLocation that is defined using Grid coordinates that relate back to a LocalGridCoordinateSystem<br/><br/>This would be used when locations are not defined in inches or millimeters but rather in terms of things like floor tile positions. <br/><br/>The grid units are defined in the LocalCoordinateSystem.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA2_EA7134" ;
    skos:prefLabel "GridLocalLocation"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7135> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7128> ;
    skos:definition "A method of spatial referencing, in which the locations of features are described in terms of measurements along a linear element, from a defined starting point, for example a milestone along a road. Each feature is located by either a point (e.g. a signpost) or a line (e.g. a no-passing zone).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA2_EA7135" ;
    skos:prefLabel "LinearReferenceSystem"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7136> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7128> ;
    skos:definition "A coordinate system for LocalLocations that are defined using floating point Cartesian coordinates<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA2_EA7136" ;
    skos:prefLabel "LocalContinuativeCoordSystem"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7138> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7128> ;
    skos:definition "A local coordinate system allows us to position things in a small area where the curvature of the Earth can be ignored. It would commonly be used to define placement in an Exchange building (Central Office)<br/><br/>It is an abstract entity that holds common attributes and relationships. <br/><br/>For continuative locations, the Units will usually be unity for a given measure (e.g. 1 metre). For grid coordinate systems, the unit will often be a non unity measure (e.g. 600mm)<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA2_EA7138" ;
    skos:prefLabel "LocalCoordinateSystem"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7139> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7128> ;
    skos:definition "A measurement and relationship of lines, angles, surfaces, solids and points used for the display of LocalLocations.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA2_EA7139" ;
    skos:prefLabel "LocalGeometry"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7140> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7128> ;
    skos:definition "A coordinate system for LocalLocations that are defined using Grid coordinates<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA2_EA7140" ;
    skos:prefLabel "LocalGridCoordinateSystem"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7141> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7128> ;
    skos:definition "A set of coordinate points and the lines that join them for LocalLocations<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA2_EA7141" ;
    skos:prefLabel "LocalLineString"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7142> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7128> ;
    skos:definition "A defined place defined by a local coordinate system. It is an abstract modeling concept that provides a linking point to other parts of the SID model. It holds attributes common to all Local Location subclasses.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA2_EA7142" ;
    skos:prefLabel "LocalLocation"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7143> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7128> ;
    skos:definition "An association between two LocalLocations.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA2_EA7143" ;
    skos:prefLabel "LocalLocationRelationship"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7144> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7128> ;
    skos:definition "Allows us to determine where things are in relation to a local coordinate system.It is an abstract modeling concept that provides a linking point to other parts of the SID model.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA2_EA7144" ;
    skos:prefLabel "LocalPlace"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7145> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7128> ;
    skos:definition "A particular spot, place, or position in an area or on a map, object, or surface used for LocalPlaces.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA2_EA7145" ;
    skos:prefLabel "LocalPoint"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7146> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA2_EA7128> ;
    skos:definition "A plane figure with at least three straight sides and angles, and typically five or more used for LocalPlaces.<br/>"@en ;
