    skos:definition "Goods and Shipping Product Spec ABE describe specificity of Goods and Shipping Product Spec and their relationships.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA2_EA2_EA1587" ;
    skos:prefLabel "Goods and Shipping Product Spec ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA2_EA1731> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA3_EA1676> ;
    skos:definition "<font color=\"#29313b\">Product Catalog ABE is a collection of entities that represent the specification of ProductCatalogs and catalogs described by them that contain ProductOfferingSpecifications and their associated ProductOfferingPrices.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA3_EA2_EA1731" ;
    skos:prefLabel "Product Catalog ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA6_EA1_EA1924> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA6_EA1919> ;
    skos:definition "The Product Usage Entity ABE collects product consumption information, and generates ProductUsage according to ProductUsageSpecification for use by other business entities.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA6_EA1_EA1924" ;
    skos:prefLabel "Product Usage Entity ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA6_EA2_EA1930> a skos:Concept ;
