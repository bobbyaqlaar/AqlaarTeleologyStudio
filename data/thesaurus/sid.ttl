    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA3_EA4572" ;
    skos:prefLabel "ComponentEntityIdentification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA3_EA4573> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA3_EA4571> ;
    skos:definition "A type of EntityIdentificationSpec that does not have any subordinate EntityIdentificationSpecs, that is, an ComponentEntityIdentificationSpec is a leaf-level EntityIdentificationSpec.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA3_EA4573" ;
    skos:prefLabel "ComponentEntityIdentificationSpec"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA3_EA4574> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA3_EA4571> ;
    skos:definition "A type of EntityIdentification that is formed by aggregating other EntityIdentifications, which may be Composite or Atomic EntityIdentifications.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA3_EA4574" ;
    skos:prefLabel "CompositeEntityIdentification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA3_EA4575> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA3_EA4571> ;
    skos:definition "A type of EntityIdentificationSpec that is formed by aggregating other EntityIdentificationsSpecs, which may be Composite or Atomic EntityIdentificationSpecs.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA3_EA4575" ;
    skos:prefLabel "CompositeEntityIdentificationSpec"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA3_EA4576> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA3_EA4571> ;
    skos:definition "Essential characteristics that uniquely identifies somebody or something.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA3_EA4576" ;
    skos:prefLabel "EntityIdentification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA3_EA4577> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA3_EA4571> ;
    skos:definition "The sequence in which the EntityIdentificationSpecs that comprise a CompositeEntityIdentificationSpec appear in a CompositeEntityIdentificationSpec, along with its formatting attributes. For example, the format of a phone number contains dashes, such as 972-477-8401.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA3_EA4577" ;
    skos:prefLabel "EntityIdentificationSpecFormat"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA3_EA4578> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA3_EA4571> ;
    skos:definition "One or more attributes (not attribute values) used to recognize (identify) an instance of an entity.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA3_EA4578" ;
    skos:prefLabel "EntityIdentificationSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA3_EA4579> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA3_EA4571> ;
    skos:definition "A specification that indicates if the EntityIdentification described by the EntityIdentificationSpec is used as the primary or as a secondary identifier.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA3_EA4579" ;
    skos:prefLabel "RootEntityTypeIdentificationSpec"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4268> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "This is the top of the SID class hierarchy. The purpose of the RootEntity is to define a set of attributes that are common to select SID entities in the Product, Service and Resource domains, such as Service, Service Specification, Resource, and Resource Specification, as well as Policy entities in the Common Business Entities domain. These properties enable us to name and describe all objects (manageable and unmanageable) in the environment.<br/><i>Note that six classes shown in the following Figure are abstract. This is because they are all conceptual in nature, and exist in order to organize information and concepts. The name attribute is a generic attribute that enables users of the SID to refer to an object using terminology defined by their application-specific needs. The description attribute is an optional attribute that enables users of the SID to customize the description of a SID object. The ID attribute provides a unique identity to each entity.</i><br/>A RootEntity might be categorized by a RootEntityType that represents a SID Entity such as Product, ProductSpecification…<br/>A RootEntity might be described by one or many Attachments that may refers to a Document or exclusively a DocumentSet such as brochure or manual that can be provided by the Service Provider to Customers when they buy a Product. For example, a contract scan Document might be attached to a ProductOfferingInstance or a manual Document provided by the CSP to the customer during a call might be attached to the CommunicationInteraction.<br/><font color=\"#29313b\"><br/></font><font color=\"#29313b\">The following subsections will expand on each of the subclasses of RootEntity, except for Collection. Collection represents collections of ManagedEntity objects. This enables common attributes and relationships and other semantics to be applied to different types of Collections of ManagedEntity objects. These can then be refined in the subclasses of Collection. It is currently only used in the Policy ABE (PolicyRepository and PolicyEventBase) and the Logical Resource ABE (ReplacementSet)</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4268" ;
    skos:prefLabel "Figure R.01 - View of the RootEntity Class"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4270> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "The Information Framework employs “relationship” entities, such as ProductOfferingRelationship, to support different types of relationships between two entities. For example, one ProductOfferingSpecification is an alternate for another.<br/>To generalize this capacity to all the RootEntity sub-classes and enhance its capacities, the RootEntityRelationship is introduced.<br/>A RootEntitiyRelationship describes a relationship between two instances of RootEntities. The type of relationship might be very different such as requires, incompatibility, equivalent…<br/>In addition, minimum, maximum and default numbers can be specified for the relationship. <br/>Each RootEntity might reference many relationships (RootEntityRelationship) but each relationship is referenced by only one RootEntity.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4270" ;
    skos:prefLabel "Figure R.01a - RootEntityRelationship"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4272> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "<font color=\"#29313b\"><i>Note that since SID 24.0 ProductOffering Entity has been renamed ProductOfferingSpecification to highlight that it is a catalog concept. We didn’t change the name of it in the following examples.</i></font><br/><font color=\"#29313b\"><br/></font><font color=\"#29313b\">For example, you may want to specify that ProductOffering “C” requires minimum 1, maximum 5 ProductOffering “A” and that by default 2 ProductOffering “A” will be proposed.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4272" ;
    skos:prefLabel "Figure R.01a.I01: RootEntityRelationship requirement description"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4274> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "<font color=\"#29313b\">This use case would be represented as follows.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4274" ;
    skos:prefLabel "Figure R.01a.I02: RootEntityRelationship requirement illustration"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4276> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "<font color=\"#29313b\">But for more complex relationships the RootEntityRelationship isn’t enough.</font><br/><font color=\"#29313b\">And this also presents a challenge when there are more than three entities that are interrelated for a certain reason, such as those that are mutually exclusive with one another. For example, if three entities are interrelated the number of relationship entities that must be created is three, but the number grows exponentially based on the number of entities that are interrelated as shown in the table below.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4276" ;
    skos:prefLabel "Figure R.01a.I03: Complex RootEntityRelationship requirements"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4278> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "The following diagram represents how it can be managed defining groups of RootEntities.<br/>RootEntityGroup is a collection of all the RootEntities in the group as defined by RootEntityGroupMember. <br/>Each RootEntityGroupMember specifies the period for which the RootEntity is valid in the RootEntityGroup.<br/>The RootEntityGroupRelationship’s type attribute is a categorization of the relationship, such as migration, substitution, dependency, exclusivity. The validFor attributes is the period for which the RootEntityGroupRelationship and RootEntityGroup are valid.<br/>In addition, minimum, maximum and default numbers can be specified for the relationship.<br/>The 0..1 RootEntityRepresentsPrimaryEntity association member supports “and” and “or” associations among members of a group.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4278" ;
    skos:prefLabel "Figure R.01b - RootEntityGroupRelationship"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4280> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "For example, you may want to specify that ProductOfferingSpecification “A” combined with ProductOfferingSpecification “B” is incompatible with ProductOfferingSpecification “C” as well as with ProductOfferingSpecification “D”. In this case for example, if you have only ProductOfferingSpecification “A” ProductOfferingSpecifications “C” and “D” are compatible.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4280" ;
    skos:prefLabel "Figure R.01b.I01: RootEntityGroupRelationship incompatibility Description"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4282> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "<font color=\"#29313b\">For example, you may want to specify that ProductOfferingSpecification “A” combined with ProductOfferingSpecification “B” is incompatible with ProductOfferingSpecification “C” as well as with ProductOfferingSpecification “D”. In this case for example, if you have only ProductOfferingSpecification “A” ProductOfferingSpecifications “C” and “D” are compatible.</font><br/><font color=\"#29313b\">This use case would be represented as follows:</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4282" ;
    skos:prefLabel "Figure R.01b.I02: RootEntityGroupRelationship incompatibility illustration"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4284> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "<font color=\"#29313b\">Another example, would be to specify that ProductOfferingSpecification “A” as well as ProductOfferingSpecification “B” are both incompatible with ProductOfferingSpecification “C” as well as with ProductOfferingSpecification “D”.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4284" ;
    skos:prefLabel "Figure R.01b.I03: RootEntityGroupRelationship incompatibility description"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4286> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "<font color=\"#29313b\">This use case would be represented as follows:</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4286" ;
    skos:prefLabel "Figure R.01b.I04: RootEntityGroupRelationship incompatibility illustration"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4288> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "<font color=\"#29313b\">Another example would be to specify mutually exclusive relationship between 4 ProductOfferingSpecifications.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4288" ;
    skos:prefLabel "Figure R.01b.I05: RootEntityGroupRelationship mutually exclusive description"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4290> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "<font color=\"#29313b\">Another example would be to specify mutually exclusive relationship between 4 ProductOfferingSpecifications.</font><br/><font color=\"#29313b\">This use case would be represented as follows:</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4290" ;
    skos:prefLabel "Figure R.01b.I06: RootEntityGroupRelationship mutually exclusive illustration"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4292> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "<font color=\"#29313b\">For example, you may want to specify that ProductOfferingSpecification “C” as well as ProductOfferingSpecification “D” requires minimum 1 and maximum 5 ProductOfferingSpecification “A” or ProductOfferingSpecification “B”.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4292" ;
    skos:prefLabel "Figure R.01b.I07: RootEntityGroupRelationship incompatibility description"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4294> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "<font color=\"#29313b\">For example, you may want to specify that ProductOfferingSpecification “C” as well as ProductOfferingSpecification “D” requires minimum 1 and maximum 5 ProductOfferingSpecification “A” or ProductOfferingSpecification “B”.</font><br/><font color=\"#29313b\">This use case would be represented as follows:</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4294" ;
    skos:prefLabel "Figure R.01b.I08: RootEntityGroupRelationship incompatibility illustration"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4296> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "<font color=\"#29313b\">For example, you may want to specify that ProductOfferingSpecification “C” as well as ProductOfferingSpecification “D” requires ProductOfferingSpecification “A” and ProductOfferingSpecification “B”.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4296" ;
    skos:prefLabel "Figure R.01b.I09: RootEntityGroupRelationship incompatibility description"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4298> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "<font color=\"#29313b\">For example, you may want to specify that ProductOfferingSpecification “C” as well as ProductOfferingSpecification “D” requires ProductOfferingSpecification “A” and ProductOfferingSpecification “B”.</font><br/><font color=\"#29313b\">This use case would be represented as follows:</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4298" ;
    skos:prefLabel "Figure R.01b.I10: RootEntityGroupRelationship incompatibility illustration"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4300> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "For example, you may want to specify that a ProductOfferingSpecification “TV offering” requires minimum 3, maximum 4 Channel Packs between 5 Channel Packs (A, B, C, D1, D2) and that D1 is incompatible with D2.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4300" ;
    skos:prefLabel "Figure R.01b.I11: RootEntityGroupRelationship complex incompatibility description"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4302> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "This use case would be represented as follow:<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4302" ;
    skos:prefLabel "Figure R.01b.I12: RootEntityGroupRelationship complex incompatibility illustration"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4304> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "Another way of describing complex relationships between groups of RootEntitiy’s instances is to use expressions.<br/>In this case we use the sub-class of RootEntityGroupChoice to carry attributes usually carried by RootEntityGroupRelationship (min, max and default) and theRootEntityGroupMemeberExpression sub-class for defining the expression.<br/>Like this you can specify mathematical expressions composed of variables (represented by the members), operators and delimiters.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4304" ;
    skos:prefLabel "Figure R.01c - RootEntityGroup Relationship with Expression"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4306> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "<font color=\"#29313b\">The other way to describe that ProductOfferingSpecification “A” combined with ProductOfferingSpecification “B” is incompatible with ProductOfferingSpecification “C” as well as with ProductOfferingSpecification “D”. In this case for example, if you have only ProductOfferingSpecification “A”, ProductOfferingSpecifications “C” and “D” are compatible.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4306" ;
    skos:prefLabel "Figure R.01c.I01: RootEntityGroupRelationship incompatibility"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4308> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "This section describes the two main Entity classes (Entity and ManagedEntity).<br/>This is an abstract class that extends the RootEntity class in order to represent classes of objects that play a business function and that may be managed. The top-level Entity class hierarchy is shown in following Figure below.<br/>ManagedEntity further defines Entity by providing the two attributes and the associations ManagedEntity has with other entities. This allows an instance of any entity that inherits from Entity to be defined as a being managed by creating an instance of an association to an instance of ManagedEntity.<br/>ManagedEntity does not itself inherit from RootEntity for the following reasons:<br/><ul><li>If it inherits from RootEntity then it further defines Entity by duplicating the three attributes that are already in Entity (that it inherits from RootEntity).</li></ul><ul><li>The composition association between Entity and ManagedEntity with its 0,1 multiplicity is what is often called an “IsA” association, which is much like sub-classing. So if ManagedEntity inherits from RootEntity then it is inheriting attributes it already “inherits” from Entity via the “IsA”.</li></ul>ManagedEntity is further described in the next section.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4308" ;
    skos:prefLabel "Figure R.02 – View of the Entity Class Hierarchy"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4310> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "ManagedEntity is shown in following Figure. It is an abstract class defined in order to represent entities in a managed environment that have all the following semantics in common: (1) a business entity owns or is otherwise responsible for them, (2) management of the entity is critical for maintaining the environment, and (3) the entity is “important” from both a business as well as a management point-of-view. As such, ManagedEntity is a point at which semantically important relationships can be created.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4310" ;
    skos:prefLabel "Figure R.03 - View of ManagedEntities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4312> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "ManagedEntity defines two attributes. The set of different management methods (e.g., using CLI or SNMP, or even using REST API) that can be used to manage an Entity is contained in the managementMethodSupported attribute, while the current management method that is being used is contained in the managementMethodCurrent enumerated attribute. This is shown in Figure below.<br/>A fundamental characteristic of a ManagedEntity is that it can perform management functions and/or collect management information. ManagementMethodEntity represents the means in which management information is obtained, and ManagementInfo represents the specific type of management data obtained.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4312" ;
    skos:prefLabel "Figure R.04 - ManagementInformation and Methods for Obtaining Management Data"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4314> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "This section describes the main EntitySpecification classes in the SID.<br/>An EntitySpecification is an abstract class that extends the RootEntity class in order to define shared characteristics for any type of specification entity. EntitySpecifications has many sub-classes. This is illustrated in Figure R.05 – View of the EntitySpecification Class Hierarchy below.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4314" ;
    skos:prefLabel "Figure R.05 - View of the EntitySpecification Class Hierarchy"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4316> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "The EntitySpecification – Entity pattern, shown in Figure below, enables all Entities to be abstracted such that their shared attributes are captured in the EntitySpecification via inheritance from RootEntity and their shared associations inherited from those that Entity has with other entities, such as EntityIdentification. This enables each Entity to define its own distinguishing attributes in addition to the common attributes and associations defined by EntitySpecification.<br/><i>Note that in the figure the association between EntitySpecification and Entity is implied and not a UML association. This was done so that the association between EntitySpecification and Entity is not inherited by all their subclasses. This would cause a problem, because any instance of an EntitySpecification could be associated to any instance of an Entity. For example, an instance of ProductSpecification could be associated to an instance of Service. The 0,1 association multiplicity on the association means that not every entity has to have an associated EntitySpecification. For example, an instance of a discovered Resource may not have a known instance of ResourceSpecification associated to it.</i><br/>Also shown in the figure are an EntitySpecificationType and an EntitySpecificationTypeRelationship. This provides a consistence way to define relationships among entities that inherit from EntitySpecification.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4316" ;
    skos:prefLabel "Figure R.06 - The EntitySpecification – Entity Pattern"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4318> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "EntitySpecificationType and EntitySpecificationTypeRelationship provide a consistence way to define relationships among entities that inherit from EntitySpecification. <br/>This is further demonstrated in the next figure.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4318" ;
    skos:prefLabel "Figure R.07 - EntitySpecificationType Inheritance"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4320> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "The relationships between the subclasses of EntitySpecification and Entity are shown in Figure below. <br/>The figure shows explicit associations between the specification entities and their respective entities. For example, ProductSpecification has an explicit association with Product.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4320" ;
    skos:prefLabel "Figure R.08 - Interaction Between EntitySpecification and Entity Classes"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4322> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "Roles represent a fundamental way to provide extensibility in the model. The Role Object pattern [ROLEOBJ] is used to extend the use and application of an object. For example, by modeling the different functions that a device can play as a set of objects.<br/>A role characterizes the function that a particular object plays. In the SID, the characterization may be to specify attributes and relationships.<br/>Roles provide an extensible means of abstraction that enables the user to model the functions played by an entity as separate objects (instead of embedding that functionality in the entity itself). For example, suppose that you are modeling the business functions that your employees have. Basic organizational boundaries define some behavior (e.g., marketing vs. sales vs. engineering), but often employees play multiple roles (e.g., an engineer that has sales support functions). This phenomenon doesn’t just occur for people – other managed objects exhibit it as well. For example, in a VPN, some DeviceInterfaces talk to a customer, while others never touch a customer.<br/>In general, managed objects don’t all have the same behavior, but different managed objects may have some common behavior. Worse, an object might exhibit more than one set of common behaviors, or may take on and remove different behaviors during its lifetime. Thus, we need a means to capture these and related cases. A set of role patterns provide an extensible and straightforward means of accomplishing this goal.<br/>Before these different role patterns are discussed, it is important to differentiate between an instance or a type. Asking an object if it is an instance of type is something different than asking it if it is an instance of a class, since the types (interfaces) and the classes (implementations) can be different. (Note that there are patterns to accomplish this function.)<br/>The SID is concerned with types, not implementation.<br/>There are five types of role patterns that are extensions of [ROLEOBJ], described as follows:<br/><ul><li>Single Role Type. This pattern combines all of the features of different roles into a single type, and is most useful for modeling objects having a few variations on the same basic behavior.</li></ul><ul><li>Separate Role Type. This pattern models each role as its own separate type, and is most useful for modeling objects that have little if any common behavior.</li></ul><ul><li>Role Subtype. This pattern models each role that exhibits different behavior as a subtype. Note that this does NOT mean that sub-classing is used, as this is an analysis pattern and is thus concerned with interfaces, not implementation. This pattern is all about maintaining the illusion that clients are dealing with a single object that has multiple, changeable types.</li></ul><ul><li>Role Object. This pattern models each role that exhibits different behavior as a separate object. The separate role objects are then related to a single base object that ties the different behaviors together. This pattern is used when maintaining the illusions of a single object is too difficult, or doesn’t supply the correct semantics.</li></ul><ul><li>Role Relationship. This pattern models each role as a relationship with an appropriate object.</li></ul>Of these five patterns, the SID uses the fourth – Role Object – almost exclusively. Single Role Type and Role Type aren’t used because they best deal with behavior which is not included in the SID.<br/>This leaves Role Subtype and Role Relationship. The problem with the Role Subtype pattern (in the context of the SID) is that this pattern cannot be used if there are multiple and/or changing roles.<br/>The Role Relationship pattern is not used in the SID due to its complexity. This pattern is very well suited when the role itself embodies a relationship between a base object and some other object (usually a group). For example, consider an organization which requires new employees to spend an equal amount of time working for multiple departments. In this case, the role binds the person to the particular organization that he or she is currently working for. Thus, it is best modeled as a relationship between the person and the organization that the person is working for.<br/>Figure below shows a simplified view of the concepts of using the Role Object pattern.<br/>The figure shows that an Individual (or an Organization) can be assigned zero or more roles. Thus, an Employee can take on the roles of ServiceProvider and Partner.<br/>The idea is to define the functionality that a business entity can play as a set of subclasses of EntityRole, and then associate the specific functionality that is desired using the EntityHasRoles aggregation. This enables the functionality and behavior of the business entity to be easily customized. For example, consider two different people working in the same department – both interact with a customer, but Bob is a manager and Joe isn’t. Rather than add employee-specific attributes to the definition of a Person, a Person can be kept general, and employee-specific attributes can be added to an appropriate role.<br/>More formally, roles recognize the fact that different entities may have different roles that it can play when it collaborates with other entities in the system. Separating this into different roles enables behavior to be defined that involves just the role, as opposed to all of the attributes of the entity. This enables the communication to become more specific and thus easier to generalize.<br/><b>Different Types of Roles in SID</b><br/>The SID is unique, in that roles are used in the vast majority of its domains, to ensure that the above philosophy is applied wherever it makes sense. Three different examples that show the diversity of roles in the SID are as follows:<br/><ul><li>Party and PartyRole (Party addendum). Party is a superclass for modeling people and organizations, and PartyRole is a superclass for modeling the different jobs that people can have.</li></ul><ul><li>Resource and ResourceRole (Physical Resource addendum and Logical and Compound Resource addendum). Resources are physical, logical, and compound resource entities that represent the definition, development, and operational aspects of the information computing and processing infrastructure of a system. There are PhysicalResourceRoles as well as LogicalResourceRoles, which enable functions associated with the physical and logical aspects, respectively, of a resource to be modelled independent of that resource. There are also CompoundResourceRoles, which enable roles to be assigned to CompoundResources (Resources that contain one or more PhysicalResources and LogicalResources).</li></ul><ul><li>Service and ServiceRole (Service Overview addendum and Quality of Service addendum). Services represent intangible functionality that is provided by the information computing and processing infrastructure of a system. CustomerFacingServiceRoles represent abstracted functionality that represent how a Product is realized, while ResourceFacingServiceRoles represent abstracted functionality that are required in order for the CustomerFacingService to function correctly.</li></ul>All of these are currently defined in various GB922 Addenda as noted above.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4322" ;
    skos:prefLabel "Figure R.09 - The Basics of Roles – An Example"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4324> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "An EntityRole is an abstract class that extends the Role class to define the concept of various types of roles for Entities. Following Figure shows the relationships between an Entity, an EntitySpecification, a RoleSpecification, and an EntityRole.<br/>RoleSpecifications can be used to assign different types of Roles to an Entity. This is done using the SpecifiesRoles association.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4324" ;
    skos:prefLabel "Figure R.10 - Associating EntityRoles with an Entity"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4326> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "ManagementDomain represents a special grouping of ManagedEntities that has two important properties. First, it is used to partition managed objects into a meaningful logical grouping. One important use of such a grouping is to provide a means to define which EMS (as well as which NMS) manages, monitors, etc. which set of devices. Another important use of such a grouping is to provide a means to show how management functions are distributed and scaled.<br/>Second, this grouping defines a common administrative domain that is used to administer the managed objects that it contains. This implies that all of the managed objects contained in this ManagementDomain are administered similarly – either by the same user, group of users or policy.<br/>A ManagementDomain is the superclass of several important entities in the SID. One of the most important of these is the PolicyDomain class. A PolicyDomain is a collection of entities and services that are administered in a coordinated fashion using a set of policies. The policies are used to control the set of services and entities according to a common methodology, such as a finite state machine. This is defined in Policy addendum.<br/>The ManagementDomain class also enables relationships to be defined that convey various semantics, such as containment, scoping, administration, and more generic management functions.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4326" ;
    skos:prefLabel "Figure R.11 - ManagementDomain"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4328> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "ManagementInfo is an abstract class that is used to represent entities that represent management information obtained in a managed environment. Specifically, in the process of managing an entity, information of various forms is created. This class is the superclass for defining different types of management information. Its main subclasses are shown in the Figure below.<br/>The design of how management information is obtained uses this class to gather specific types of information, and the ManagementMethodEntity class to obtain the desired data using an appropriate method. This combination of class hierarchies enables different management methods (e.g., CLI vs. SNMP) to be used to gather different types of management data, and is unique to the SID information model.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4328" ;
    skos:prefLabel "Figure R.12 - ManagementInfo Class Hierarchy"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4330> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "ManagementMethodEntity is an abstract class for representing the different types of management methods that can be used to gather a particular type of management information. For example, this enables configuration setting classes to be defined as using CLI, while configuration monitoring classes could be defined as using a different method, such as SNMP. Its main subclasses are shown in the Figure below.<br/>The design of how management information is obtained uses this class to gather specific types of information, and the ManagementMethodEntity class to obtain the desired data using an appropriate method. This combination of class hierarchies enables different management methods (e.g., CLI vs. SNMP) to be used to gather different types of management data, and is unique to the SID information model.<br/>Figure R.04 – ManagementInformation and Methods for Obtaining Management Data showed how ManagementInfo and ManagementMethodEntity work together to provide a single, scalable solution for gathering different types of management information that describe a management entity. This is especially important for some types of network devices, where different protocols and approaches are used to configure vs. monitor the device.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4330" ;
    skos:prefLabel "Figure R.13 - ManagementMethodEntity Class Hierarchy"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4332> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "<b>Identification</b><br/>Business entities consist of two types – those that are simple values, such as a quantity of money or a period of time, and those that have identity. For these latter entities, the concept of an identity is used to distinguish different instances of the same object.<br/>Identity is flexibly and extensibly defined using the group of objects defined in this chapter.<br/>Individual people, places, and things, such as customer orders, equipment, network elements and so forth, can be recognized (identified) by different attributes. The business will define (usually through a policy) what particular set of attributes or concepts is appropriate for a given entity. For example, an individual person may be identified using a passport number, a driver’s license number, or a national identification number. Similarly, a network location may be identified by a network node ID or a Location Entity Identification Code (as defined in American National Standard T1.253). <br/>It should be noted that policy does not have to be used. However, the use of policy provides an elegant and extensible means to define the semantics of using an identity. This is done by modeling associations between PolicyRules and the identification entities that it relates to.<br/>Figure EI.01 – PartyIdentification Excerpt (taken from Party addendum) below shows an excerpt for identifying different types of Parties (e.g., Individuals and Organizations).<br/>The manner in which each key business entity in the SID model is identified could be modeled in a way similar to Party. However, each business entity can be identified in a number of ways, as shown in the example above for individuals. Modeling the identity in this way means that each key entity would have a set of classes similar to those used to model the identities of Party. This introduces redundancy into the SID model for every entity that requires identification. In addition, using explicit subclasses to model the different types of identification attributes for an entity results in a model that cannot be easily extended. This is because as new ways to identify an entity are defined or discovered, a new subclass must be introduced into the SID model. Having to introduce new subclasses implies that the parts of the SID model that represent entity identifications are not very stable. It also makes it difficult for other teams and I to adopt the SID, since its baseline is always changing.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4332" ;
    skos:prefLabel "Figure R.14 - PartyIdentification Excerpt (taken from Party Diagrams)"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4334> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "To eliminate the redundancy and instability within the model caused by the repeated modeling of similar identification structures and by introducing subclasses for each way that an entity can be identified, the EntitySpecification – Entity pattern is used. Here, the “EntitySpecification” part of the pattern will take the form of a specification for identifying Entities, and the “Entity” part of the pattern will take the form of an object that can be used to identify entities.<br/>Therefore, applying this pattern yields the beginning of a model for Entity identification, as shown in Figure EI.02 – Beginning of the Entity Identification ABE Model below.<br/>An EntityIdentificationSpec defines the attributes that are shared by every instance of a related EntityIdentification. (and methods, constraints, relationships and behavior in the system view) of an EntityIdentification object. Note that methods and constraints (as specified in OCL) are useful for specifying “static” behavior (e.g., functionality that can be defined at design time). Thus, “behavior” refers to dynamic functionality and runtime considerations that are not easy to represent in a class model. For example, the directive to instantiate an object only in response to a run-time exception is easy to conceptualize as a constraint, but is difficult to model in UML. Other examples include the specification of pre- and post-conditions and other contract related data.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4334" ;
    skos:prefLabel "Figure R.15 - Beginning of the Entity Identification ABE Model"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4336> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "An EntityIdentificationSpec defines the attributes that are shared by every instance of a related EntityIdentification. (and methods, constraints, relationships and behavior in the system view) of an EntityIdentification object. Note that methods and constraints (as specified in OCL) are useful for specifying “static” behavior (e.g., functionality that can be defined at design time). Thus, “behavior” refers to dynamic functionality and runtime considerations that are not easy to represent in a class model. For example, the directive to instantiate an object only in response to a run-time exception is easy to conceptualize as a constraint, but is difficult to model in UML. Other examples include the specification of pre- and post-conditions and other contract related data.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4336" ;
    skos:prefLabel "Figure R.16 - The Composite Pattern Applied to EntityIdentificationSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4338> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "<font color=\"#29313b\">An EntityIdentificationSpecification represents one or more attributes (not attribute values) used to recognize (identify) an instance of an Entity. Figure EI.04 – EntityIdentificationSpecification Examples below shows an 8-byte Network Site Format using ANS T1.253. </font><br/><font color=\"#29313b\"><i>Note that the various component specifications (Geographical Code, Geopolitical Code, and Network Site Code) that make up a complete Network Node ID, which is represented as an CompositeEntityIdentificationSpec object, are represented as instances of the ComponentEntityIdentificationSpec, and are aggregated by the CompositeEntityIdentificationSpec.</i></font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4338" ;
    skos:prefLabel "Figure EI.04 – EntityIdentificationSpecification Examples"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4340> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "The component specification must be able to occur in a certain sequence to define the composite. And, they may be preceded and/or followed by certain characters. For example, the format of a phone number could contain dashes, such as 972-477-8401. Figure EI.05 – The EntityIdentificationSpecificationFormat Association Class below shows an association class added to hold the sequence in which the components appear in a composite object, along with its formatting attributes.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4340" ;
    skos:prefLabel "Figure R.17 - The EntityIdentificationSpecificationFormat Association Class"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4342> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "The next thing that must be known about an EntityIdentitySpecification is what type of business Entity the EntityIdentitySpecification applies to. There are two different means of doing this. The difference is whether the Entity being identified has an associated EntitySpecification or not. For example, a Market Entity has no associated Specification, whereas a Resource Entity or a Service Entity often do have an associated EntitySpecification.<br/>The first option is shown in Figure EI.06 – Identifying Entities Using an Associated EntitySpecification. In this option, an EntitySpecification defines a Entity as well as a set of EntityIdentificationSpecs. Any of these EntityIdentitySpecs may be used to identify the EntityIdentification object that is used to identify the associated Entity. Looking at Figure EI.06 – Identifying Entities Using an Associated EntitySpecification below, we see that the EntitySpecification that characterizes the Entity contains, in addition to its invariant attributes, zero or more EntityIdentificationSpecs. The EntityIdentitySpecification in turn specifies the set of EntityIdentification objects that can be used to identify the Entity that the EntitySpecification applies to. This enables the EntitySpecification to in effect direct the usage of a subordinate specification (the EntityIdentitySpecification) to indirectly define EntityIdentification objects that can be used to identify the Entity to which the EntitySpecification applies to, providing a great deal of inherent flexibility in determining how the Entity will be identified.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4342" ;
    skos:prefLabel "Figure R.18 - Identifying Entities Using an Associated EntitySpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4344> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "The second option is shown in Figure EI.07 – Identifying Entities Using the RootEntityType Entity below. This option is used for Entities that don’t have an associated EntitySpecification, and can also be used in the first case if desired. This option introduces an entity (called RootEntityType) into the model whose instance is the business entity that is to be identified. Examples of business entities that use this approach include Location (identified by the 8-byte Network Site Format), Individual, Organization, Customer, Supplier, Market Segment and so forth.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4344" ;
    skos:prefLabel "Figure R.19 - Identifying Entities Using the RootEntityType Entity"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4346> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "Two association classes are introduced in the Entity identification model as shown in Figure EI.08 – Use of an Entity Identification Specification below. The EntityIdentificationSpecFormat association class, which was first shown in Figure EI.07 – Identifying Entities Using the RootEntityType Entity above, is used to define the formatting and sequencing of EntityIdentificationSpec objects that are aggregated by a particular EntityIdentificationSpecComposite object. The RootEntityTypeIdentificationSpec association class, shown in Figure EI.08 – Use of an Entity Identification Specification below, is used to indicate, via its use attribute, whether the entity identification specification is used as the primary or as a secondary identifier.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4346" ;
    skos:prefLabel "Figure R.20 - Use of an Entity Identification Specification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4348> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "The following example shows where both approaches may be used. In some cases, for example if a manufacturer has a special identification scheme for a certain type of equipment, it may be necessary to associate an EntityIdentificationSpecification to a specific EntitySpecification. This type of association would specify that the EntityIdentificationSpecification is only applicable for equipment Entity instances related to the instance of the equipment EntitySpecification and not for equipment Entity instances related to other EquipmentSpecifications below shows the association between an EntityIdentificationSpecification and an EntitySpecification.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4348" ;
    skos:prefLabel "Figure R.21 - EntitySpecification Association With EntityIdentificationSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4350> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "Every instance of an entity has a unique identifier. Simple identifiers can be defined as attributes of an entity. In cases where one or more complex identifiers are required, an object is required. This is implemented using an entity identification specification and its associated entity identification objects. For example, ANS T1.253 specifies a complex identifier for a network location Figure EI.10 – Entity and Entity Identification below shows an example of the EntityIdentificationSpecification, the EntityIdentification, and the RootEntity instance identified using this specification. (Note that the multiplicity of the RootEntityRecognizedUsing association is 0..1 on the RootEntity side, and not 1, because our first option doesn’t use this approach; therefore, RootEntity and RootEntityType must be kept optional.)<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4350" ;
    skos:prefLabel "Figure R.22 - Entity and Entity Identification Example"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4352> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "<font color=\"#29313b\">This section contains additional examples that depict the use of the Entity Identification Specification and Entity Identification. The examples are taken from the American National Standard T1.253-1999.</font><br/><br/><font color=\"#29313b\">This is a standardized code that uniquely identifies a customer’s presence at a location at which network elements or network systems equipment exist</font><br/><font color=\"#29313b\"><b>Geographical Code</b></font><br/><font color=\"#29313b\">The designation for a single geographical locality within a state, province, territory, country, or distinct region of the world (e.g., municipality). This data element shall consist of four alphabetic characters. New codes assigned shall contain exactly four characters and shall not contain spaces. For previously assigned codes of less than four characters, the unused character positions after the code shall be filled with spaces to make up four character positions.</font><br/><font color=\"#29313b\"><b>Geopolitical Code</b></font><br/><font color=\"#29313b\">The designation of a state or territory of the United States, a province or territory of Canada, another country having a national federal government, or a unique designation (e.g., the oceans). This data element shall consist of two alphabetic characters.</font><br/><font color=\"#29313b\"><b>Customer Site Code</b></font><br/><font color=\"#29313b\">The designation of a customer that utilizes telecommunications equipment at a specific location where there is a requirement to uniquely identify that customer’s presence for the purpose of inventory and facility management.</font><br/><font color=\"#29313b\">This data element shall consist of five characters having one numeric character in the first position followed by one alphabetic and three alphabetic or numeric characters in that sequence.</font><br/><font color=\"#29313b\"><b>Customer Site Format Table</b></font><br/><font color=\"#29313b\">This format shall consist of a sequence of Geographical Code and Geopolitical Code data elements plus a Customer Site Code data element, resulting in a code that totals eleven characters in the format shown in the table below.</font><br/><ul><li></li></ul><p/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4352" ;
    skos:prefLabel "1. Customer Site Format"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4354> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "<font color=\"#29313b\">A standardized code that uniquely identifies a type of manufactured telecommunications network equipment or an assignable entity within a type of equipment. The Equipment Entity Identification Format shall consist of a sequence of Family Code, Sub-Family Code, Features Code, Reference Code and Complemental Code data elements, resulting in a code that totals ten characters in the following format.</font><br/><font color=\"#29313b\"><b>Components</b></font><br/><font color=\"#29313b\"><b>Family Code</b></font><br/><font color=\"#29313b\">A label to denote a functional category of manufactured telecommunications equipment. This data element shall consist of two characters, either of which may be alphabetic or numeric. An example is D4, representing a D4 channel bank. </font><br/><font color=\"#29313b\"><b>Sub-Family Code</b></font><br/><font color=\"#29313b\">A label to denote a functional category of manufactured telecommunications equipment within a family. This data element shall consist of two characters, either of which may be alphabetic or numeric. An example is CE, representing an E&M signaling channel unit.</font><br/><font color=\"#29313b\"><b>Features Code</b></font><br/><font color=\"#29313b\">A standardized code to denote a distinctive service-providing design capability available within a sub-family of manufactured telecommunication equipment when compared to other similar equipment of the same or other manufacturers. This data element shall consist of three characters, each of which may be alphabetic or numeric. Manufacturers’ examples are:</font><br/><ul><li><font color=\"#29313b\">18B, where</font></li><li><font color=\"#29313b\">1 signifies E&M signaling, 4 wire</font></li><li><font color=\"#29313b\">8 signifies E with M lead applique, M lead resistor 510 ohm</font></li><li><font color=\"#29313b\">B signifies with busy switch and level adjust attenuator</font></li><li><font color=\"#29313b\">424, where</font></li><li><font color=\"#29313b\">4 signifies DX signaling, 4 wire with post equalization</font></li><li><font color=\"#29313b\">2 signifies adjustable balance capacitance and resistance</font></li><li><font color=\"#29313b\">4 signifies impedance 150/600/1200 ohm</font></li><li><font color=\"#29313b\">363, where</font></li><li><font color=\"#29313b\">3 signifies DX signaling, 2 wire with gain transfer</font></li><li><font color=\"#29313b\">6 signifies eliminate signaling condition, fixed balance capacitance</font></li></ul><ul><li><font color=\"#29313b\">3 signifies receive enable circuit</font></li></ul><font color=\"#29313b\"><b>Reference Code</b></font><br/><font color=\"#29313b\">This is a label to denote the manufacturer’s information used to describe the design capability encoded in the equipment entity identification code. This data element shall consist of one character, which may be alphabetic or numeric. Examples are:</font><br/><ul><li><font color=\"#29313b\">7, signifying NNTM</font></li><li><font color=\"#29313b\">8, signifying LEAR</font></li><li><font color=\"#29313b\">P, signifying SD-7C026-02</font></li></ul><font color=\"#29313b\"><b>Complemental Code</b></font><br/><font color=\"#29313b\">This is a standardized code to provide uniqueness to an equipment entity identification code. This data element shall consist of two characters, either of which may be alphabetic or numeric. (Examples of typical information are manufacturing vintage, version data, circuit wiring, or equipment data.) Examples are:</font><br/><ul><li><font color=\"#29313b\">AA, for Northern Telecom, signifying NNTM QPP357B</font></li><li><font color=\"#29313b\">AA, for LEAR, signifying LEAR D4DX-4010-11</font></li></ul><ul><li><font color=\"#29313b\">AB, for Lucent Technologies, signifying J98726SD-2Composites</font></li></ul><font color=\"#29313b\"><b>Basic Code</b></font><br/><font color=\"#29313b\">A Basic Code is comprised of the Family Code and Sub-Family Code data elements taken together, represented in the following format</font>.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4354" ;
    skos:prefLabel "2. Equipment Entity Identification Format"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4356> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "<font color=\"#29313b\">The next two figures show examples of CustomerSiteFormat and EquipmentEntityIdentityFormat within the context of the EntityIdentificationSpecification and EntityIdentification entities.</font><br/><font color=\"#29313b\">Figure E.11 – EntityIdentificationSpec Example below shows this format overlaid on the EntityIdentitySpecification ABE previously discussed. First, we need to define some more components from ANS T1.253-1999.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4356" ;
    skos:prefLabel "Figure EI.11 – EntityIdentificationSpec Example"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4358> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4358" ;
    skos:prefLabel "Figure EI.12 – Additional EntityIdentification Examples"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4360> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "<font color=\"#29313b\">Figure Ch.01 – Characteristic Specification depicts the basic CharacteristicSpecification pattern. The pattern enables attributes unique to a type of entity to be created via its association to EntitySpecification and enables attributes unique to a certain entity to be created via its association to RootEntityType. A RootEntityType is an entity in the SID. For example, characteristics could be defined for entities (instances of RootEntityType) such as Product, Customer, and ProductSpecification that apply to all instances of those entities. Instance diagrams are shown in Figure Ch.03 – Characteristic Spec Instance – Example 1 and Figure Ch.04 – Characteristic Spec Instance – Example 2. Definitions of entities and attributes are provided in the data dictionary at the end of this document.</font><br/><font color=\"#29313b\">An example of the use of the pattern will also be illustrated using the following figure.</font><br/><font color=\"#29313b\">The EntitySpecification, which could be a ProductSpecification, instance is for a Linksys USB Ethernet Cable Modem DOCSIS. Each tab, Features, Description, Additional Info, and Shipping Info is an instance of CharacteristicSpecification. The Features CharacteristicSpec is a composite that is comprised of an instance of CharacteristicSpec for each feature line. Instances of the CharacteristicSpecRelationship are used to compose the Features of the instances of feature line. </font><br/><font color=\"#29313b\">In this example, the CharacteristicSpecValue and CharSpecValueRelationship entities are not used. An example of their use could be for a set of coordinated colors for the modem. For example, if a choice for a faceplate color (CharacteristicSpec) is blue (CharacteristicSpecValue), then the only color for the case color is black. This rule would be implemented by an instance of CharSpecValueRelationship that relates the color blue with the color black with a value for charValueRelationshipType of “inclusive”. </font><br/><font color=\"#29313b\">See an example in Annex: More Details on Characteristics.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4360" ;
    skos:prefLabel "Root Business Entities/Characteristic ABE Illustration"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4362> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "The minCardinality and maxCardinality attributes are used to specify the number of values that can be associated with an instance of a RootEntity. In the example the faceplate color would have a minCardinality of 1 and a maxCardinality of 1. A minCardinality of 0 implies that a value does not have to be assigned to a characteristic.<br/>A valueType attribute exists for both CharacteristicSpecifications and CharacteristicSpecValue in order to have a mixture of value types for values. For example, a CharacteristicSpecification may be enumerated by a combination of strings and integers. The valueType of the CharacteristicSpecification is used if the valueType is the same for all CharacteristicSpecValue instances.<br/>An instance CharacteristicSpecValue can represent discrete value or a range of values: <br/><ul><li>An example of a discrete value is the values that the CharacteristicSpecification “color” can take on. </li><li>An example of a range of values is the range of operating temperatures under which the cable modem can operate. A rangeInterval attribute for CharacteristicSpecValue defines whether the valueFrom and valueTo attributes are inclusive or not. This is equivalent to adding an “operator” attribute for valueFrom and an “operator” attribute for valueTo, such as “#lt;=” or “#lt;”. The rangeStep attribute specifies that a range of values increases in steps, such as a range from 0 to 100 in steps of 5 with the resulting permitted values being 0, 5, 10, 15,…100. This complements the valueFrom, valueTo, and rangeInterval attributes. Previously there was no way to do so, and individual CharacteristicSpecValues had to be created.</li></ul>In some models the value attribute and the range attributes are contained within separate subclasses of the CharacteristicSpecValue entity. This was not done in the Characteristic model in order to simplify it. Also, some models may contain unit of measure as a separate entity with a recursive association and an association class that is used to define conversion factors between various units of measure. This was not done in the Characteristic model. However, both the subclasses and unit of measure entity and association class could be modelled as extensions to the SID if desired.<br/>Some CharacteristicSpecifications are enumerated by a fixed value or set of values that remain constant for every instance of an Entity. For example, the operating temperature range for the cable modem remains constant. The attribute canBeOverridden is used to indicate this. Additionally, the set of CharacteristicSpecValues may be open to extension as values are assigned to instances of EntityCharacteristics. For example, there may be a desire to keep a list of userIDs as instances of CharacteristicSpecValues in addition to their existence as instances of CharacteristicValues. The extensible attribute is used to indicate that new instances of CharacteristicSpecValues can be added as instances of CharacteristicValues are created.<br/>More precisely:<br/><i>Values associated with CharSpecs can never be changed when an entity's CharValue instances are created. They are fixed but can be extended if the \"extensible\" attribute is true.</i><br/><b>example 1:</b><br/>In the case the xxxSpeccharUse is a temperature range #lt;-20, +50#gt;<br/><ul><li>If extensible = FALSE =#gt; the range cannot be changed for any instance</li><li>If extensible = TRUE =#gt; the range can be changed for a given instance into (as example) #lt;-10, +40#gt;</li></ul><b>example 2:</b><br/>In the case the xxxSpeccharUse is a list of enum: e.g. Color with values Black and Blue <br/><ul><li>canBeOverriden = FALSE =#gt; nothing can be changed, and instances will have both values Black and Blue </li></ul><ul><li>canBeOverriden = TRUE =#gt; one can chose Black OR Blue either for a given instance</li></ul><b>example 3:</b><br/>In the case the xxxSpecCharUse is a bandwidth range from 10 to 100 with a step of 10<br/><ul><li>If canBeOverridden = FALSE =#gt; the range cannot be changed for any instance</li><li>If canBeOverridden = TRUE =#gt; the range still cannot be changed for any instance (e.g. we cannot select a subrange, like from 40 to 70 with same step of 10) but we can pick up one value (like 20) or we can select a set of values (like 30 and 60) from the range. The number of choices depends on the Min and Max attributes (in this case, the Min is 1 and the Max is 2.</li></ul>CharacteristicSpecification does not use the composite/atomic pattern. Instead there is the recursive CharacteristicSpecRelationship association that can be used to associate several CharacteristicSpecification.<br/>The CharacteristicSpecRelationship association can be used to represent/emulate a composite CharacteristicSpecification associated with several other CharacteristicSpecification. If used that way, the model does not restrict the possibility for the composite CharacteristicSpecification to have its own set of CharacteristicSpecValue, although it is not recommended.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4362" ;
    skos:prefLabel "Figure R.23 - CharacteristicSpecification and Values"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4364> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "CharacteristicSpecifications can be shared by a number of RootEntityType instances. The “use” entity contains attributes that may be specific to a use of the CharacteristicSpecification by an instance of a RootEntityType. <br/>For example, a CharacteristicSpec with “bandwidth” value for the name attribute could be named “download speed” in one use and “upload speed” in another use. <br/>The values assigned to these attributes override the values assigned to an instance of a CharacteristicSpecification. For example, the minCardinality attribute assigned to an instance of CharacteristicSpecification may be zero, indicating that a value does not have to be assigned for an instance of a CharacteristicValue; however, for a particular use of the CharacteristicSpecification, the attribute must be assigned a value. In this case the minCardinality attribute in the “use” entity would be assigned a value of one.<br/>The package attribute, also a “use” entity attribute, indicates that the attribute represents a composite attribute, similar to the composite/atomic pattern without the explicit sub-classing. When this attributes value is set to “true” a number of attributes do not apply, such as min and maxCardinality, unique, canBeOverridden, and extensible.<br/>The use of an attribute by a RootEntityType may also require a further restriction on the values that a Characteristic can be assigned. The associations between CharacteristicSpecValue and the “use” entities can be used to define the further restriction. For example, the instances of CharacteristicSpecValue for the instance of the “color” CharacteristicSpecification may contain the entire rainbow of colors, but only a subset of colors is available for the cable modem.<br/>Similarly, the two “SpecValueUse” entities enable different default values to be specified for the use of values associated with the use of a CharacteristicSpecification by a RootEntityType.<br/><i>CharacteristicSpecification can be related to specification entities in a number of ways. The relationship can be inherited if a specification entity is a subclass of EntitySpecification or via a direct association between the CharacteristicSpecification and the specification entity.</i><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4364" ;
    skos:prefLabel "Figure R.24 - CharacteristicSpecification for RootEntity RootEntityType"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4366> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "The Entity / EntitySpecification characteristic model is works in the same way as the RootEntity / RootEntityType characteristic model.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4366" ;
    skos:prefLabel "Figure R.25 - CharacteristicSpecification for Entity EntitySpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4368> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "<font color=\"#e0121d\"><b>More Details on Characteristics</b></font><br/><font color=\"#29313b\">As stated in the introduction, the CharacteristicSpecification/CharacteristicSpecValue pattern is intended to be used to dynamically define attributes for any business entity. This pattern is very powerful but not easy to understand. Section 1.13 presents it to some level of details that may not be sufficient to understand all aspects of its expressive power. In particular, Figure Ch.01 Characteristic Specification is very complex.</font><br/><font color=\"#29313b\">The purpose of this section is to try explain this pattern and the related artefacts in Figure Ch.01 in a simple and progressive way.</font><br/><font color=\"#29313b\">We will illustrate our presentation with the example of Cars and CarSpecifications. While it is deliberately away from the Telecom domain, we expect that it is simple to understand, not controversial and general enough to be easily adaptable to our Telecom domain.</font><br/><font color=\"#29313b\">What does “ dynamically define attributes for any business entity” mean ?</font><br/><font color=\"#29313b\">The usual way to define specific attributes for a given business entity is to add these attributes in the class of the model that represents this entity. Based on this modification of the model, the implementation of the corresponding class (data base or source code) must be modified, recompiled and the corresponding run time need to be re-executed to take into consideration the modifications introduced. </font><br/><font color=\"#29313b\">The approach proposed by the CharacteristicSpecification/CharacteristicSpecValue pattern is, at run time, to create instances of CharacteristicSpecification (or simply called characteristics) and instances of associated CharacteristicSpecValues. </font><br/><font color=\"#29313b\">Once this is done, there are two ways these characteristics can be used:</font><br/><ul><li><font color=\"#29313b\">Either associate an instance of a CharacteristicSpecification to an instance of a business entity that need to be extended</font></li><li><font color=\"#29313b\">Or use the RootEntityType meta approach. In this case, characteristics can be added to an instance of RootEntityType, meaning that these added characteristics will apply to the SID Entity (SID class) corresponding to the instance of the RootEntityType (remember that The RootEntityType in the SID is populated with a list of all business entities contained in the SID). </font><br/><font color=\"#29313b\">Figure Ch.04 illustrates this approach with the SID Entity “Service” that is extended with two characteristics “LastStatusChange” and “StatusUpdatedBy”. </font><br/><font color=\"#29313b\">It then means that any instance of this extended class will be extended with these two characteristics.</font><br/><font color=\"#29313b\">From an implementation view point it can be interpreted as adding two new columns to the data base table representing this SID class. </font></li></ul><font color=\"#29313b\"><br/></font><font color=\"#29313b\">Below we will further illustrate the first way.</font><br/><font color=\"#29313b\"><b>Use Case 1:</b></font><br/><font color=\"#29313b\">Let’s assume that the model already contains a static class “CarSpec” inheriting from EntitySpec.</font><br/><font color=\"#29313b\">This class “CarSpec” will be used to create instances of models of cars that will populate a catalog (for example, the catalog of all the models of a given constructor).</font><br/><font color=\"#29313b\">This class “CarSpec” has its own set of attributes that will characterize each car model instance, such as the possible energy, the possible engine power and the possible colors, among many others.</font><br/><font color=\"#29313b\">Now let’s assume that for a given instance of CarSpec (representing the car model Toyota Yaris as an example) we want to differentiate the color of the roof and the color of the body. The valid values for the roof or the body will be a subset of the valid values for the general Color characteristic that is used in general for all car models of this constructor which we assume to be: Black, Blue, Green, Pink and Yellow.</font><br/><font color=\"#29313b\">The general Color characteristic is represented as an instance of CharacteristicSpecification aggregating a set of instances of CharacteristicSpecValue representing the various valid colors.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4368" ;
    skos:prefLabel "Figure A 1 - Instances of valid color values"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4370> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "<font color=\"#29313b\">Now we want, at run time, to extend the instance of CarSpec representing the car model Toyota Yaris by adding two new characteristics, one for the color of the roof and another one for the color of the body. We will use instances of EntitySpecCharUse associated with instances of EntitySpecCharValueUse for this purpose. See below.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4370" ;
    skos:prefLabel "Figure A 2 - EntitySpecCharUse and EntitySpecCharValueUse"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4372> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4372" ;
    skos:prefLabel "Figure A 3 – Instances of car body and car roof colors"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4374> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "<font color=\"#29313b\"><b>Use Case 2:</b></font><br/><font color=\"#29313b\">Now, we complicate our case by assuming that a limited set of combinations are valid for the respective colors of the roof and the body for this Yaris car model: Black / Blue, Blue / Green, Black / Pink.</font><br/><font color=\"#29313b\">To do this we use the association class EntitySpecCharValueUseRelationship by assigning “compatible” to the three instances of this relation.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4374" ;
    skos:prefLabel "Figure A 4 - EntitySpecCharValueUseRelationship"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4376> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4376" ;
    skos:prefLabel "Figure A 5 – Creating “compatible” relationship instances"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4378> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "Following Figure depicts CharacteristicValues and their associations to Entities, in the figure a RootEntity. A CharacteristicValue is one chosen or entered for an Entity for a specific CharacteristicSpecification. In the example above the instances would be “blue” for the face plate and black for the case. The values would be related to the respective CharacteristicSpecValue.<br/>When values are not specified in CharacteristicSpecValue or the other “spec value” entities shown in the figure, but are entered for a CharacteristicSpecification, then CharacteristicValue is related to CharacteristicSpecification or one of the other “spec” entities shown in the figure. For example, a startTime is a CharacteristicSpecification for a Video on Demand, an entered value of 6 Aug 2007 would be related to startTime. This one of the two cases when a CharacteristicValue would be related to a CharacteristicSpecification and when the value attribute of CharacteristicValue would have to be populated. The other case is when a value is chosen from a range of values defined by the CharacteristicSpecValue. When a CharacteristicSpecValue is chosen from a list of discrete values or it is unchangeable (via the canBeOverridden attribute set to “false”), there is no need to populate the value attribute, unless performance considerations required this from an implementation perspective. In these cases the instance of CharacteristicValue is related to the instance of CharacteristicSpecValue and not the instance of CharacteristicSpecification.<br/><i>Note: CharacteristicValue can also be directly related to an entity, such as ServicePerformance or Customer if they do not inherit from the RootEntity</i><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4378" ;
    skos:prefLabel "Figure R.26 - Characteristic Value"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4380> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "The following figure shows an example of an IPTV EntitySpecification with three associated CharacteristicSpecifications.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4380" ;
    skos:prefLabel "Figure R.27 - Characteristic Spec Instance - Example 1"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4382> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "The following Figure shows how characteristics can be added for an entity whether the entity has an associated specification or not. In the figure two characteristics have been added to the Service Entity in general, independent of those that may be added to instances of ServiceSpecifications. The RootEntityType in the SID is populated with a list of all business entities contained in the SID. The Characteristic model shown in the following Figure shows how CharactersticSpecifications are be associated with the RootEntityType.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4382" ;
    skos:prefLabel "Figure R.28 - Characteristic Spec Instance - Example 2"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4384> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "<b>Characteristic-Based Pricing and Charging</b><br/>In the not-so-distant past factors influencing the price of a product were based on the usage of network resources and other resources, measured by such factors as amount of time, or some other unit, a resource was used or the amount of bandwidth consumed. But once the usage of other types of resources, such as content, is included, many other characteristics influence the price.<br/>This model was originally envisioned to support content pricing and charging, but it can be used for any type of pricing and charging that is based on characteristics and their values. As will be seen it can also be used for usage-based pricing d charging also.<br/><b>Policy versus Simplicity</b><br/>When rules for pricing (and charging) were first being developed in the Information Framework (SID) many years ago, Reliance on the policy model was not total. An additional set of entities were under development to support simple rules, such as quantity-based pricing and tiered-based pricing. However, this additional set was not introduced in the released version of the SID. Rather, all rules relied on policy. Many members believe that using only policy is a bit extreme. A balance can be achieved between simplicity and complexity.<br/>This balance was introduced into the SID in release 6.0 with the addition of an association between ProductSpecCharacteristicValue and ProductOfferingPrice. This provided a simple rule that enabled a price to be dependent on value(s) of one or more characteristics.<br/>This balance continued in SID in release 9.0 with the arrival of a new Level 2 ABE (Aggregate Business Entity, a cohesive group of entities) named Pricing Logic Algorithm within the Product Offering Level 1 ABE. This ABE used Product Specification Characteristics to provide support for pricing that involves parameters which are multi-dimensional matrices, in which each dimension is defined by the valid values for a specific characteristic. For example, a PLA which rates events based on customer type, there is one instantiation in which customer type is either residential or commercial (and in which case the size of the dimension of the matrix is 2) and in other instantiation the customer type can be student, normal and senior citizen (in this case the size of the dimension is 3).<br/>And, the use of a simple approach is used here.<br/><ul><li>The Characteristic Model</li><li> The generalized application of the CharacteristicSpecification/CharacteristicValue pattern will be used to demonstrate this. </li><li> The Pricing and Charging Scenario</li></ul>A typical and simple scenario will be used to demonstrate the model. Pay per view Video on Demand (VoD) product depends on the format, standard (STD) or high definition (HD) with a special price given for certain movies viewed in HD during a Saturday and Sunday period.<br/>Shown in the following Figure is an Object Diagram that shows how the current model supports movies. There are other attributes associated with a movie, such as run time, director, and so forth that are not shown in this example.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4384" ;
    skos:prefLabel "Figure R.29 - Content Characteristic Specs"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4386> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "The use of the EntitySpecification/Entity pattern was considered to support the requirements. However, this would proliferate the number of EntitySpecifications and Entities from an implementation perspective. In this example, there would have to be a separate instance of EntitySpecification for each movie and a separate instance of an Entity for each chosen movie. Using the generalized CharacteristicSpecification/Characteristic model eliminates this. In this example there could be a single instance of an EntitySpecification that represents Pay Per View and a single instance of and Entity that represents a Pay Per View subscription.<br/>Enhancements to the Characteristic Model<br/><ul><li>Add two new entities to the characteristic model</li><li>Add associations to ProductOfferingPrice and ComponentProductPrice.</li></ul>Also, catalogs of movies can be created by adding a composite CharacteristicSpecification named Video Catalog and associating the Movie Title composite with it. Since this is dependent on the “use” of the values, a recursive association on EntitySpecCharValueUse is required. A similar association and association class is also added to EntitySpecCharUse as shown in Figure Ch.06 – Updated Characteristic Use Entities.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4386" ;
    skos:prefLabel "Figure R.30 - Updated Characteristic Use Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4388> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "Shown in the following Figure Characteristic Specs and Pricing is one of the promoted “use” association classes and two new price dependency entities. These two entities enable a single or multiple attributes (assuming a simple “and” association between the attributes) to govern a price. In the figure the price is represented as ComponentProdOfferPrice, an existing entity in the Product Offering Price ABE.<br/>More comprehensive requirements, such as and’s and or’s, are supported by adding appropriate attributes to the member entity. An Object diagram follows to show an example.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4388" ;
    skos:prefLabel "Figure R.31 - Characteristic Specs and Pricing"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4390> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "Shown in the following Figure is an example where the high definition (HD) format for the movie 2012 has one price, while the same movie has a different price for standard (STD) format.<br/>The STD and HD values do not have to be repeated as instances of CharacteristicSpecValues. The Format instance of CharacteristicSpecification can be shared among all movie titles. The names of the objects in the diagram are illustrative only. If the price varied only by HD and STD and not by title then dependencies could be created that were only related to the format values.<br/>If the pay per view price was the same for every movie, then there would be no need for this type of pricing. The current Product Offering to Product Offering Price association would be support this. Also, the ProductOfferingPrice name is illustrative only; the price can be shared by multiple CharacteristicPriceDependencies.<br/>Note that an attribute may be required in Product Offering and/or Product Specification to indicate that choices can be made when accessing an associated Product.<br/>By relating price dependencies to the “use” entities:<br/><ul><li>A VoD subscription offering with unlimited free viewing with a fixed subscription price can be created by not associating use attributes with price dependencies and associating a ProductOfferingPrice to the VoD subscription offering</li><li>A VoD subscription offering with unlimited free viewing except for “special” movies can be created by associating only the specials uses with price dependencies and associating a ProductOfferingPrice to the VoD subscription offering</li><li>A VoD pay per view offering can be created by associating appropriate use attributes, such as title and format, with price dependencies.</li></ul><p/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4390" ;
    skos:prefLabel "Figure R.32 - Content Charging Offer Price"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4392> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "In the Product domain this could be done for Offering, Specs, or some combination.<br/>Shown in the following Figure is a more involved price dependency. The 2012 movie in high definition (HD) format is available for Saturday or Sunday night viewing at a special price. The dependency can be interpreted as “2012 and HD and (Saturday Viewing or Sunday Viewing)”.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4392" ;
    skos:prefLabel "Figure R.33 – Complex Content Charging Offer Price"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4394> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "Shown in the following Figure is an example of associating the characteristics with a Product Offering. There are no associated EntitySpecCharValueUses, which implies that all movie titles are available in all formats. The choices can be limited by associating values with the Pay Per View Offering.<br/>By using the generalized characteristic pattern other variations, such as usage-based pricing that is dependent on values associated with usage characteristics or resource characteristics, is also supported.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4394" ;
    skos:prefLabel "Figure R.34 – Content Charging Product Offer Example"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4396> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "Support for charging is shown in Figure below. A new association added to Component Product Price that indicates that the price was based on one or more characteristic values. The CharacteristicValue entity in the figure is shown describing RootEntity. But, any entity that does not inherit from RootEntity, such as Product, could be related to CharacteristicValue. An Object diagram follows to show an example.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4396" ;
    skos:prefLabel "Figure R.35 – Characteristic Value and Pricing"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4398> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "Shown in the following Figure is an example of viewing of the HD version of 2012, and the price that was determined based on the characteristic values that represent the chosen movie.<br/>Domain Options – Product and/or Resource<br/>The changes is only made to the Characteristic Spec ABE. All other ABEs where this pattern is duplicated are not updated. By promoting the use entities, any entity that does not inherit from the EntitySpecification, or is an entity (RootyEntityType) that does not have a specification, can be related to the use entities.<br/>The choice using this model in the Product and/or Resource domain may be based upon a company’s business model. In the content example presented here, a company may treat each request for content as an order associated with a ProductOfferingSpecification. Or, a company may treat each request as some form of usage. Or a company may use a hybrid model that combines the treatment of requests.<br/>This model supports all three of these business models, because it can be used for<br/><ul><li>Product Spec/Offer Pricing/Charging (as shown in the diagrams in this section)</li><li>Usage Pricing/Charging</li><li>Resource Spec Pricing/Charging.</li></ul>One other factor needs to be considered when making the choice. The information may have to be duplicated because of application boundaries. A CRM application may need this information as well as Provisioning and Inventory applications.<br/>There are also some application/database implementation considerations<br/><ul><li>The use of one set of shared characteristic tables (if the applications are cooperative enough to do this!)</li><li>If the data is only contained in one application then other applications have to request characteristic data from it.</li></ul><p/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4398" ;
    skos:prefLabel "Figure R.36 – Content Charging Product Price"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4400> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "The following Figure shows an example of usage-based pricing/charging.<br/>Notice that the only difference between this example and the Product Offering example in Figure 40 is that UsageSpecification is related to the Pay Per View Use instance of EntitySpecCharUse. To handle charging the Usage entity would be related to CharacteristicValue, just as Product was related to CharacteristicValue in the Product domain example in this section.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4400" ;
    skos:prefLabel "Figure R.37 – Content Charging Usage Specification Example"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4402> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "Entire books have been written on meta-modeling. This section does not attempt to do complete justice to this topic. However, it does overview some initial modeling thoughts on extending an implementation of the SID to include the dynamic addition of entities, meta-concepts (subclasses and attributes currently supported by the SID), associations, and association classes.<br/>A SID implementer can implement the models described in this section to rapidly adapt a database to changed information requirements without the need to make substantial changes to the database. At some point in time, the meta-data instances may be converted to explicitly modeled and implemented entities, subclasses, associations, association classes, and attributes.<br/>Some SID implementers may view meta-modeling associations as more an implementation view than an information view of entities and their associations. If the choice is that this is an implementation view then the model contained in this section can be placed in an implementation model rather than an information model.<br/><i>Note that Object (Instance) diagrams shown in this part of the guide book were not added to the SID model. They are included here for illustrative purposes only.</i><br/>Meta-modeling entities serve as the starting point that enables the dynamic addition of entities (classes and subclasses), eliminating the need to add them explicitly to an implementation of the SID. These entities can then be extended via the dynamic addition of attributes and associations. The existing SID RootEntityType, which has been enhanced to support this capability, is shown the following Figure.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4402" ;
    skos:prefLabel "Figure R.38 - Entity Meta-Model"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4404> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "<font color=\"#29313b\">Figure As.01a – Root Entity Instances and Associations shows an Object diagram that contains all the examples of RootEntityType instances described to this point.</font><br/><font color=\"#29313b\">Note that in the figure, the Customer instance is an explicit subclass of PartyRole, but the instance of this association is not shown in the figure. Also, this model can support the dynamic addition of entities and subclasses not contained in the SID model. Examples of this are not shown in the figure either.</font><br/><font color=\"#29313b\">The meta-model is only part of the solution to support dynamic extensibility. Application functionality, including user interfaces, must also be developed. A representative set of insights into functionality, excluding user interfaces, will be described next.</font><br/><font color=\"#29313b\">When creating/updating an instance of an EntitySpecification in a database, such as a CompoundResourceSpecAtomic, the application can ask if it is to be dynamically extended. If the answer is yes, an instance of RootEntityType is created. Once the extensions have been created/updated, then the value of the attribute “dynamicAttrAssoc” can be set to indicate whether attributes or associations or both have been added. The database for the meta-model, including implementation considerations for it, will be shown later after all meta-modeling concepts have been described.</font><br/><font color=\"#29313b\">When adding an instance of a specification, the application could ask if a corresponding entity should be created. Adding the corresponding entity will enable the creation of dynamic associations between the entity and other entities. This follows from the fact that an association between specifications is often mirrored for the entities described by the specification. This will also assist the application to automatically create instances of RootEntity, which may participate in instances of the associations.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4404" ;
    skos:prefLabel "Figure As.01a – Root Entity Instances and Associations"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4406> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "<font color=\"#e0121d\"><b>Meta-Modeling – Existing Support for Subclasses and Attributes</b></font><br/><font color=\"#29313b\">The dynamic addition of attributes and subclasses is already supported in the SID via two patterns, EntitySpecification/Entity and the CharacteristicSpecification/CharacteristicValue, sometimes referred to as the Dynamic Object pattern. They will be briefly revisited in the section Error: Reference source not found in this part of the guide book, where inheriting attributes (and associations) will be described.</font><br/><font color=\"#29313b\">The use of these two SID patterns is also often referred to as dynamic sub-classing. But what does this mean? It means that a subclass of the applicable EntitySpecification and/or a subclass of the applicable Entity are implied, rather than explicitly modeled. The and/or is based on the instances of CharacteristicSpecifications related to the instance of the EntitySpecification.</font><br/><font color=\"#29313b\">If all the CharacteristicSpecValue instances are fixed (cannot be configured), then there is only an implied subclass of the EntitySpecification. If all the CharacteristicSpecValue instances are configurable, then there is only an implied subclass of the Entity. If the CharacteristicSpecValue instances are fixed and configurable, then there are implied subclasses of the EntitySpecification and the Entity.</font><br/><font color=\"#29313b\">An application could provide the capability (user interface and logic) to add instances of CharacteristicValue when adding an instance of a RootEntity. This capability would determine if the RootEntityType that describes the RootEntity has any related instances of CharacteristicSpecification. The dynamicAttrAssoc attribute of RootEntityType would be used to determine this.</font><br/><font color=\"#29313b\">Implementing the meta-model to support the dynamic addition of classes and subclasses, both implicit and explicit, means that inheriting attributes must be supported. Existing SID entities should be handled by transformation of the information model to the data model by rolling down the super-classes. A representative set of application logic that supports inheritance for dynamically added classes and subclasses is described next.</font><br/><font color=\"#29313b\">Application logic can be employed to support inheriting attributes by copying instances of CharacteristicSpecifications and CharacteristicSpecValues to subclasses for dynamically added classes and subclasses, both implicit and explicit. The application would create instances of RootEntityTypeCharUse and RootEntityTypeCharValueUse. If copying, rather than true inheritance, is done, then the ability to change the properties (attributes) of the Characteristic entities of the subclasses should be prevented by the application to avoid inconsistencies. The application could also ask if selected instances of RootEntityTypeCharValueUse should also be created.</font><br/><font color=\"#29313b\">For those SID implementer’s who decide to use a meta-model like the one described here, there is an important point to keep in mind. Existing associations between entities that represent specifications and applications of the characteristics or directly to characteristics are no longer necessary. The section Error: Reference source not found in part of the guide book will further explain this.</font><br/><font color=\"#29313b\"><br/></font><font color=\"#e0121d\"><b>Meta-Modeling Associations</b></font><br/><font color=\"#29313b\">Requirements for meta-modeling associations, like those for entities and attributes, can be gathered by looking at the properties of an association and its roles in a UML tool. Figure As.02a – Properties of an Association shows properties of an association.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4406" ;
    skos:prefLabel "Figure As.02a – Properties of an Association"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4408> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "The following Figure shows the meta-model based on a subset of these requirements.<br/>The AssociationSpecification “validFor” attribute was intentionally left without a data type to make implementation in a database simpler. Also, the multiplicity of the “AssociationSpecificationDefinedBy” multiplicity for the “AssociationRoleSpecification” role was set to 2. This only permits binary (two entities involved) associations.<br/>The requirements could be used to identify more attributes that further define the association entities. In fact, there are more entities that could be added to the model to support stereotypes, constraints, and so forth, as shown in the following Figure. That is why the introduction to these meta-modeling sections mentioned that the models/thoughts described here are just initial.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4408" ;
    skos:prefLabel "Figure R.39 - Association Specification Meta-Model"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4410> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "<font color=\"#29313b\">Figure As.02b – Explicitly Modeled Association Example shows an explicitly modeled association between two entities that represent explicit extensions to the SID UML model.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4410" ;
    skos:prefLabel "Figure As.02b – Explicitly Modeled Association Example"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4412> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "<font color=\"#29313b\">Figure As.02c – Association Specification Instances shows how this association would be instantiated using the meta-model for AssociationSpecifications shown in Figure As.02 – Associate Specification Meta-Model.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4412" ;
    skos:prefLabel "Figure As.02c – Association Specification Instances"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4414> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "The meta-model that represents instances of associations is shown in the following Figure. This model parallels the Association Specification model.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4414" ;
    skos:prefLabel "Figure R.40 - Association Instance Meta-Model"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4416> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "<font color=\"#29313b\">The following Figure shows an instance example using instances of Mobile Switching Center and Base Station Controller entities that have been used throughout this meta-modeling section.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4416" ;
    skos:prefLabel "Figure R.40 – Illustration 01 – Association Role Instances"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4418> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "The specification of this association is simple, because it assumes no history when an instance of a Base Station Controller’s association (SupportedBy) to a Mobile Switching Center is changed from one instance of a Mobile Switching Center to another. Otherwise the specification for the association would be an *-*, which means the specification for an association class (entity) should be introduced into the meta-model, as shown in Figure As.04 – Association Class Specification.<br/>The model shown in the figure provides the capability to define a specification for an association class or not. The 0,1 multiplicity from AssociationSpecification to RootEntityType defines this capability.<br/>It should be kept in mind that another meta-modeling option is to not add the association between AssociationSpecification and RootEntityType. The equivalent support could be provided by adding an instance of RootEntityType that represents a class, rather than an association class. This instance would be related to the two instances of the RootEntityTypes involved in the *-* association by creating two instances of AssocationSpecification. In modeling, this represent what is often referred to as an intersection or link entity, which represents the resolution of a *-* association.<br/>The association meta-model is only part of the solution to support the dynamic addition of associations. Application functionality, including user interfaces, must also be developed. A representative set of insights into functionality, excluding user interface details, will be described next.<br/>An application could provide the capability (user interface and logic) to add instances of associations when adding an instance of a RootEntity. This capability would determine if the RootEntityType that describes the RootEntity has any related instances of AssociationSpecification. The dynamicAttrAssoc attribute of RootEntityType would be used to determine this.<br/>Implementing the meta-model to support the dynamic addition of classes and subclasses, both implicit and explicit, means that inheriting associations must be supported. For existing SID entities, this should be handled by transformation of the information model to the data model by rolling down the super-classes.<br/>Application logic can be employed to support inheriting associations by copying instances of AssociationSpecifications and AssociationRoleSpecifications to subclasses for dynamically added classes and subclasses, both implicit and explicit. If copying, rather than true inheritance, is provided, then the ability to change the properties (attributes) of the specifications (Association and AssociationRole) of the subclasses should be prevented by the application to avoid inconsistencies. When an instance of an entity is created/updated the application can ask if an instance of an association must/may be added/updated.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4418" ;
    skos:prefLabel "Figure R.41 - Association Class Specification Meta-Model"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4420> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "<font color=\"#e0121d\"><b>Meta-Modeling Behavior</b></font><br/><font color=\"#29313b\">The last component of the meta-model is the model for behavior, or operations/methods. This is beyond the scope of what is described here, as there are quite a few variations on how this could be modelled. And, any model presented here may not be a suitable representation in many cases. However, a starting point would be to use the properties of operations in the UML model as a set of requirements. </font><br/><font color=\"#29313b\">Besides these, there would also have to be provisions in the meta-model on how to invoke the behavior. One other implementation consideration is that there should be a separate library for the code, since this code would typically be developed outside of a solution. For example, if a solution vendor provides this capability as part of a solution, the responsibility for this additional code should not be theirs.</font><br/><font color=\"#e0121d\"><b>The Meta-Model Database</b></font><br/><font color=\"#29313b\">The meta-model database described in this section represents a simplification of the UML model. It was designed with performance considerations in mind. There are certainly other implementations of the meta-model that may or may not perform better.</font><br/><font color=\"#29313b\">The model of the database supporting the UML model includes two associations that can be added to the information model or the physical data model. The model that is shown here is based on associations added to the UML model shown in Figure As.04a – UML Association Implementation Model.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4420" ;
    skos:prefLabel "Figure As.04a – UML Association Implementation Model"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4422> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "<font color=\"#29313b\">An association has been added between the association role entities and their related root entities. Each association entity now references the entity that represents the role AND the related entity. This should improve performance by providing the ability to access both entities involved in an association in a single database record (row). For example, consider the instance of the Base Station Controller AssociationRoleSpecification; this role is an AssociationRoleSpecification instance for the Mobile Switching Center “supports” Base Station Controller instance of AssociationSpecification; this instance of AssociationRoleSpecification would include the foreign key referencing the Base Station Controller RootEntityType instance, as well as secondary reference to the Mobile Switching Center RootEntityType instance. The associations were added to the UML model so that the applicable foreign keys would be automatically generated.</font><br/><font color=\"#29313b\">Figure As.04b – Association Meta-Model Logical Data Model shows the logical data model with the associations labeled primary and secondary to reflect this.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4422" ;
    skos:prefLabel "Figure As.04b – Association Meta-Model Logical Data Model"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4424> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "<font color=\"#29313b\">This model, combined with the database implementation of the Characteristic model, and its entities’ associations with RootEntityType and RootEntity, can represent the complete meta-model. The full model is show in Figure As.04c Full Meta-Model Including Characteristics.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4424" ;
    skos:prefLabel "Figure As.04c Full Meta-Model Including Characteristics"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4426> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "<font color=\"#29313b\">In the section on meta-modeling subclasses and attributes, an important point was made for SID implementer’s who choose to take this approach. It is no longer necessary to use the repeated applications of the Characteristic pattern in the existing SID model or directly relating existing SID entities to characteristic “use” entities. This is demonstrated in Figure As.04d – Full Meta-Model Including Characteristics. For example, the Base Station Controller instance of CompoundResourceSpecification can be stored as an instance of RootEntityType; instances of CharacteristicSpecifications can be related to it by creating instances of RootEntityTypeCharUse.</font><br/><font color=\"#29313b\">Figure As.04d – Association Meta-Model Physical Database shows the database.</font><br/><font color=\"#29313b\">The transformation from the information model to the data model rolled down the two association specification entities. Therefore they are not included in the data model, but their attributes are. An additional database consideration is that an index could be added on the “name” attribute. This would provide a way to search for association specifications for an instance of a RootEntityType. If necessary, an index on “name” could also be added to the AssociationRole table, if the “name” column from the AssocationRoleSpecification table is added to it.</font><br/><font color=\"#29313b\">A non-unique index on the “name” attribute of RootEntityType could be added. By doing this, instances of RootEntityType can be easily accessed when adding new attributes and/or associations to it.</font><br/><font color=\"#29313b\">An attribute most likely also should be added to RootEntityType, and possibly RootEntity, and would indicate if an instance is a “true” dynamic entity. These entities are not contained in the database generated from SID entities or that contains implied subclasses in the database. The attribute(s) could be added to the information model, rather than the data model. The addition would make finding instances of these dynamically added entities easier, particularly when dealing with (adding/updating/deleting/retrieving) instances of RootEntity.</font><br/><font color=\"#29313b\">The keys of the Root entities should be stored in instances of SID entities. This would provide an indication that the entities have been extended. The keys of both RootEntityType and RootEntity should be stored in instances of SID implied subclasses. This is done because both the implied subclass and its superclass may have both been dynamically extended. For example, the ProductSpecification entity itself may have been dynamically extended, from which the implied subclasses of it inherit.</font><br/><font color=\"#29313b\">The meta-model database can be deployed by application or domain to avoid any possible performance issues. However, dynamically added cross domain associations need to be considered when doing this.</font><br/><font color=\"#29313b\">One final point about implementing a meta-model is that dynamically added entities and their subtypes, associations, and attributes should be considered for explicit modeling at some point in time. Their stability should be a consideration for determining when this should be done.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4426" ;
    skos:prefLabel "Figure As.04d – Association Meta-Model Physical Database"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4428> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "Attachment represents a group of classes that support an attachment like image, video and document for any RootEntity. The following Figure shows the UML diagram of the objects in this fragment.<br/><b>Attachment</b><br/>This is the class to represent an attachment like document, image or video to any RootEntity or other Business Entity in the model.<br/>This class is concrete and it can be used without a sub-class. However, one can extend this class to add more specific behavior of an entity attachment. The AttachmentDocumentation and AttachmentImage are examples of such extension. <br/><b>AttachmentDocumentation </b><br/>This is the extended class representing a documentation attachment.<br/><b>AttachmentImage </b><br/>This is the extended class representing an image attachment.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4428" ;
    skos:prefLabel "Figure R.42 - View of Entity Specification Attachment"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4430> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "Entity Specification Action represents a logical grouping of classes that together support fulfillment of the associated entity. The following Figure shows the UML diagram of the objects in this fragment.<br/><b>EntitySpecificationAction</b><br/>This is the class representing an action like Add, Disconnect and Modify for an entity specification.<br/><b>EntitySpecificationActionWorkflow</b><br/>This is the class representing a workflow supporting an action for an entity specification.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4430" ;
    skos:prefLabel "Figure R.43 - View of Entity Specification Action"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4432> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
    skos:definition "External System Capability represents a logical grouping of capabilities that exposed by one system to another system. For example, a catalog modeler can build a product or service by composing these capabilities. The following Example demonstrates how these capabilities can be used together to build a location API product. These group of logical capabilities are representing a system capability model as seen by its interfaces for given capability so they can facilitate a catalog-driven integration approach. For example, what charging capabilities offered by an online charging system, or what policy model supported by a PCRF system. <br/><b>ExternalSystemCapability</b><br/>This is an abstract class, and is the root of the External system capabilities. It extends EntitySpecification to define common attributes, relationships and behavior that all external system capability subclasses use and take part in.<br/>The ExternalSystemCapability model has four main purposes:<br/>To represent different types of capability, <br/>To represent which system offers the capability <br/>To represent how different entity specification like PS, CFSS, RFSS can use these capabilities and<br/>To represent (optionally) how these capabilities can be accessed by a system like an ordering system thru one or more APIs<br/>There are many different types of capabilities. A system like a charging system can offer multiple capabilities like pre-paid and post-paid charging and a capability can be offered by multiple external system instances.<br/>The following Figure shows the UML diagram of the objects in this fragment. <br/><b>FulfilmentCapabilitySpecification</b><br/>This is the class representing a fulfilment capability specification as supported by a fulfilment/ordering system<br/><b>ChargingCapabilitySpecification</b><br/>This is the class representing a charging capability specification as supported by a charging system like OCS.<br/><b>BillingCapabilitySpecification</b><br/>This is the class representing a billing capability specification as supported by a billing system.<br/><b>PolicyCapabilitySpecification</b><br/>This is the class representing a policy capability specification as supported by a policy management system like PCRF.<br/><b>AssuranceCapabilitySpecification</b><br/>This is the class representing an assurance capability specification as supported by an assurance system.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA4432" ;
    skos:prefLabel "Figure R.44 - External System Capability"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4435> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA4434> ;
