    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6105> ;
    skos:definition "BusinessRuleTriggerEventSpecification describes details of a business rule trigger event. It includes details such as the specification's ID, name, source, associated type ID, unit ID, and window ID.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA18_EA1_EA6157" ;
    skos:prefLabel "BusinessRuleTriggerEventSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA18_EA1_EA6158> a skos:Concept ;
