<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA6_EA1_EA3250> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA6_EA3242> ;
    skos:definition "<span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);font-family:Arial;font-size:13px;\"><span style=\"-webkit-text-stroke-width:0px;display:inline !important;float:none;font-style:normal;font-variant-caps:normal;font-variant-ligatures:normal;font-weight:400;letter-spacing:normal;orphans:2;text-align:start;text-decoration-color:initial;text-decoration-style:initial;text-decoration-thickness:initial;text-indent:0px;text-transform:none;white-space:normal;widows:2;word-spacing:0px;\">The Resource Usage Entity ABE collects resourceconsumption information, and generates ResourceUsage according to ResourceUsageSpecification for use by other business entities.</span></span><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA6_EA1_EA3250" ;
    skos:prefLabel "Resource Usage Entity ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA6_EA2_EA3254> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA6_EA3242> ;
    skos:definition "<span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);font-family:Arial;font-size:13px;\"><span style=\"-webkit-text-stroke-width:0px;display:inline !important;float:none;font-style:normal;font-variant-caps:normal;font-variant-ligatures:normal;font-weight:400;letter-spacing:normal;orphans:2;text-align:start;text-decoration-color:initial;text-decoration-style:initial;text-decoration-thickness:initial;text-indent:0px;text-transform:none;white-space:normal;widows:2;word-spacing:0px;\">The Resource Usage Specification ABE specifies types and characteristics of usage of ResourceSpecifications.</span></span><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA6_EA2_EA3254" ;
    skos:prefLabel "Resource Usage Specification ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA10_EA3727> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3411> ;
    skos:definition "<b>Party Service Level Agreement ABE</b> represents an SLA with one or more other parties. See the Agreement ABE for additional details.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA10_EA3727" ;
    skos:prefLabel "Party Service Level Agreement ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA12_EA3748> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3411> ;
    skos:definition "<b>Business Partner Statistic ABE</b> represents the analysis of Business Partner relationships such as the number and total amount of invoices or the number of payments.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA12_EA3748" ;
    skos:prefLabel "Business Partner Statistic ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA5_EA3541> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3411> ;
    skos:definition "<b>Party Revenue & Settlement ABE</b> is composed of revenue sharing and settlements.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA5_EA3541" ;
    skos:prefLabel "Party Revenue & Settlement ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA7_EA3686> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3411> ;
    skos:definition "The <b>Party Bill Collection ABE</b> handles credit violations, actions for overdue debts (Dunning), and all what is related to BusinessPartnerPayment. This ABE is still preliminary but the sub-ABE Business Partner Payment is validated. Business Partner Payment is a sub-type of PartyPayment.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA7_EA3686" ;
    skos:prefLabel "Party Bill Collection ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3_EA3878> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3755> ;
    skos:definition "<b>Enterprise Risk ABE</b> represents all items that relate to risk of an enterprise. It also concerns security vulnerabilities and related events as well as information related to Revenue Assurance such as areas of revenues leakage risk and operational capability to resolve any detected degradations and violations.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA3_EA3878" ;
    skos:prefLabel "Enterprise Risk ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA2_EA6_EA4181> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA2_EA4164> ;
    skos:definition "The <b>Expense ABE</b> aggregates all outflows of economic benefits during a period resulting in a decrease in equity (other than distributions to owners). It primarily comprises costs and operating expenses incurred in the course of delivering telecommunication services and products, including Cost of Goods Sold (COGS such as interconnection fees, content royalties, device costs), Operating Expenses (Opex such as network maintenance, salaries, marketing, customer care, rent, utilities), depreciation and amortization of assets used in operations, and other period costs. Expenses are recognized when incurred (accrual basis) and are used to calculate operational profitability and net financial results.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA5_EA2_EA6_EA4181" ;
    skos:prefLabel "Expense ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA2_EA7_EA4186> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA2_EA4164> ;
    skos:definition "<b>Income ABE</b> aggregates all inflows of economic benefits during a period resulting in an increase in equity (other than contributions from owners). It primarily comprises recognized Revenue from core operations plus non-operating income such as interest received, dividends, gains on asset disposal, foreign exchange gains, and other miscellaneous income items.<br/>To summarize: Income = Operating Income (EBIT) +/− Other Income/Expenses(non-operating items)<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA5_EA2_EA7_EA4186" ;
    skos:prefLabel "Income ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA5_EA4153> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA9_EA3755> ;
    skos:definition "The <b>Finance ABE</b> aims to describe all that is related to the Enterprise finance such as financial accounts, and general ledger.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA9_EA5_EA4153" ;
    skos:prefLabel "Finance ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA865> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA857> ;
    skos:definition "The Party Payment ABE contains all Entities required to describe a payment such as PaymentMethod and BankAccount.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA10_EA865" ;
    skos:prefLabel "Party Payment ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA866> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA10_EA857> ;
    skos:definition "The Party Privacy Profile ABE contains all entities used by the Party Privacy Management process for specifying <br/><br/> • the information concerned by Privacy rules,<br/><br/> • the Privacy rules themselves,<br/><br/> • and the choices made by Parties for their own Privacy.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA10_EA866" ;
    skos:prefLabel "Party Privacy ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA1_EA409> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA1_EA406> ;
    skos:definition "The Business Partner Bill contains entities related to a total amount due from a CSP to a Business Partner for all products during the billing period either precalculated by the CSP or by the business partner. <br/>Note: This ABE is preliminary.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA1_EA409" ;
    skos:prefLabel "Business Partner Bill ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA1_EA412> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA1_EA406> ;
    skos:definition "The Party Bill Collection ABE handles credit violations, actions for overdue debts (Dunning), and all what is related to BusinessPartnerPayment. This ABE is still preliminary but the sub-ABE Business Partner Payment is validated For more detail about PartyPayment and related Business Entities refer to the Common Guide book.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA1_EA412" ;
    skos:prefLabel "Party Bill Collection ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA1_EA415> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA1_EA406> ;
    skos:definition "The Party Product Specification and Offering ABE represents the involvement parties playing roles have with ProductSpecifications and Product Offerings, such as ordered from and billed by. The sub-ABEs represent the intersection of entities in the two domains. For example, PartyRoleProductOffering is the intersection between the ProductOffering and the PartyRole entities. <br/>• These ABEs are only needed when a ProductSpecification and ProductOffering are on-boarded and offered to the market by an enterprise or when an offering is procured from another party. <br/>• The ABEs should reside in the domain that contains the processes that manage their life cycles. The processes that manage the life cycle of the ABEs (create/update/delete the entities versus those that use the entities) are in the Business Partner domain, such as On-board and Off-board Product Offering from another party. .\\doc\\Figure PPSO.00 - Key Product Domain Business Entities.docx <br/>.\\doc\\Figure PPSO.02 - Party Role Product Offering.docx <br/>.\\doc\\Figure PPSO.03 - Party Role Product Offering and Product Specification.docx <br/>.\\doc\\Figure PPSO.04 - Party Role Prod Spec Subclasses.docx <br/>.\\doc\\Figure PPSO.06 - Fulfilled Sales Product Specification.docx<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA1_EA415" ;
    skos:prefLabel "Party Product Specification and Offering ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA1_EA416> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA1_EA406> ;
    skos:definition "Party Revenue & Settlement ABE is composed of revenue sharing and settlements. <br/><i>The sub-ABE Party Settlement is still preliminary.</i><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA1_EA416" ;
    skos:prefLabel "Party Revenue & Settlement ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA2_EA447> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA2_EA444> ;
    skos:definition "The Customer Bill Collection ABE handles credit violations, actions for overdue debts, and facility billing audits. <br/>.\\doc\\Figure C.22 - Dunning Scenario and Case.doc <br/>.\\doc\\Figure C.23 - Dunning Result.doc<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA2_EA447" ;
    skos:prefLabel "Customer Bill Collection ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA477> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA3_EA474> ;
    skos:definition "Represents all items that relate to risk of an enterprise. It also concerns security vulnerabilities and related events as well as information related to Revenue Assurance such as areas of revenues leakage risk and operational capability to resolve any detected degradations and violations.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA3_EA477" ;
    skos:prefLabel "Enterprise Risk ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA4_EA527> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA4_EA526> ;
    skos:definition "The Competitor ABE identifies other providers who compete in the same market segments, accumulates intelligence about the competitors, including products (price, Key Performance Indicators and so forth).<br/><br/>The Competitor ABE provides information relative to the analysis of intelligence pertaining to an enterprise’s competitors. It is crucial to understand who the competitors are, what their products are, what the target markets for their products are, and how successful their products are.<br/><br/>The Competitor ABE and Competitor entities also comprise the following level-two ABEs<br/><br/> • Competitor Intelligence<br/><br/> • A variety of Product domain ABEs relative to Competitors<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA4_EA527" ;
    skos:prefLabel "Competitor ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA567> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA5_EA563> ;
    skos:definition "Anomaly ABE represents any unusual or unexpected event, observation, or item that is significantly different from the norm that an organization wishes to detect, analyze, assess and mitigate within an autonomous environment. In order for the autonomous operations environment to behave within the calibrated operational level, anomalies may require administrative and operational guidance. Anomaly ABE entities provide a means of defining boundary conditions and lifecycle behavior for Anomalies, as well as providing control over the end-to-end management process for Anomalies.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA5_EA567" ;
    skos:prefLabel "Anomaly ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA662> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA661> ;
    skos:definition "A loyalty program is one of the tools used by the loyalty process to retain customers. The Loyalty ABE contains all entities useful to specify and instantiate loyalty programs. A LoyaltyProgramProdSpec defines the LoyaltyRules that have to be checked in order to identify the actions to apply. Depending on the type of LoyaltyRules a LoyaltyAccount might be needed to collect gains or not. A LoyaltyProgramProduct is a type of ProductComponent and described by a LoyaltyProgramProdSpec.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA6_EA662" ;
    skos:prefLabel "Loyalty ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA663> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA661> ;
    skos:definition "<font color=\"#29313b\">Product and ProductOfferingInstance represent, in the product inventory, respectively an instance of a ProductSpecification and ProductOfferindSpecification subscribed or not yet subscribed to by a Customer to the CSP or by the CSP to a BusinessParnter. The Product carries the place where the product is in use, as well as configuration characteristics, such as assigned telephone numbers and internet addresses. The Product and Offering Instance ABE also tracks the links to services and/or resources through which the Product is realized.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA6_EA663" ;
    skos:prefLabel "Product and Offering Instance ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA672> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA6_EA661> ;
    skos:definition "Represents usage of products associated with Customers used for charging that may appear on a Customer Bill.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA6_EA672" ;
    skos:prefLabel "Product Usage ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA7_EA709> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA7_EA705> ;
    skos:definition "The Resource Order ABE contains entities related to a request to provide / update / remove Resources.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA7_EA709" ;
    skos:prefLabel "Resource Order ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA7_EA716> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA7_EA705> ;
    skos:definition "The Resource Trouble ABE manages problems found in allocated resource instances, regardless of whether the problem is physical or logical. Entities in this ABE detect these problems, act to determine their root cause, resolve these problems and maintain a history of the activities involved in diagnosing and solving the problem. Detecting problems can be done via software (e.g. responding to an alarm) and/or by hardware (e.g. a measurement or probe) and/or manually (e.g. visual inspection). This includes tracking, reporting, assigning people to fix the problem, testing and verification, and overall administration of repair activities.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA7_EA716" ;
    skos:prefLabel "Resource Trouble ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA8_EA788> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA8_EA784> ;
    skos:definition "Sales Lead and Opportunity ABE provides the ability to track sales leads through their life cycle up until the time the prospect become customers, including proposals made to potential customers, and the amount of potential revenue the leads represent in the form of a sales pipeline.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA8_EA788" ;
    skos:prefLabel "Sales Lead and Opportunity ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA806> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA804> ;
    skos:definition "The Service ABE contains entities that are used to represent both customer-facing and resource-facing types of services. Entities in this ABE provide different views to examine, analyze, configure, monitor and repair Services of all types. Entities in this ABE are derived from Service Specification entities.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA806" ;
    skos:prefLabel "Service ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA811> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA9_EA804> ;
    skos:definition "The Service Performance ABE collects, correlates, consolidates, and validates various performance statistics and other operational characteristics of customer and resource facing service entities. It provides a set of entities that can monitor and report on performance. Each of these entities also conducts network performance assessment against planned goals, performs various aspects of trend analysis, including error rate and cause analysis and Service degradation.<br/><br/>Entities in this ABE also manage the traffic generated by a Service, as well as traffic trend analysis. This is important for newer technologies that separate data, control and management functions for a given Service.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA9_EA811" ;
    skos:prefLabel "Service Performance ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA10_EA1_EA1_EA5231> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA10_EA1_EA5224> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA10_EA1_EA1_EA5231" ;
    skos:prefLabel "Performance Category Specification ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA11_EA4_EA5437> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA11_EA5356> ;
    skos:definition "The Policy Management ABE contains entities that are used to manage other entities in other Domains. This includes entities from other Common Business Entities sub-domains (e.g., Location and Party) as well as other sibling Domains (e.g., Product, Service and Resource).<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA11_EA4_EA5437" ;
    skos:prefLabel "Policy Management ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA24_EA6453> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA4200> ;
    skos:definition "<b>Trouble Ticket ABE</b> represents a record used for reporting and managing the resolution of Trouble or Problem.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA24_EA6453" ;
    skos:prefLabel "Trouble Ticket ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA2_EA1_EA4566> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA2_EA2_EA4549> ;
    skos:definition "Enables pricing to be based on a combination of CharacteristicSpecifcations and their related CharacteristicSpecValues.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA2_EA2_EA1_EA4566" ;
    skos:prefLabel "Characteristic Pricing ABE"@en .

