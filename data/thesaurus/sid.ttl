<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA10_EA3_EA5258> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA10_EA3_EA5257> ;
    skos:definition "The invariant characteristics that define a communication (notification) that occurs as part of a PerformanceConsquence. A Notification is typically one-sided, in that no Response is expected. For example, an alarm may be raised as the result of a PerformanceThreshold being violated.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA10_EA3_EA5258" ;
    skos:prefLabel "ConsequencePerformanceNotificationSpec"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA10_EA3_EA5259> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA10_EA3_EA5257> ;
    skos:definition "A parameter used in the calculation of a PerformanceIndicator. A CharacteristicSpecification can be used as a parameter or another PerformanceIndicatorSpecification can be used.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA10_EA3_EA5259" ;
    skos:prefLabel "PerformanceIndicatorDerivationParameter"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA10_EA3_EA5260> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA10_EA3_EA5257> ;
    skos:definition "A group of indicators, usually reported in the same message by the equipment or the EMS.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA10_EA3_EA5260" ;
    skos:prefLabel "PerformanceIndicatorGroupSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA10_EA3_EA5261> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA10_EA3_EA5257> ;
    skos:definition "A measure of a specific aspect of the performance of an entity, such as a lost packets or average jitter, defined for a PeformanceSpecification that may trigger the creation of a PerformanceConsequence.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA10_EA3_EA5261" ;
    skos:prefLabel "PerformanceIndicatorSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA10_EA3_EA5262> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA10_EA3_EA5257> ;
    skos:definition "An association between two PerformanceIndicatorSpecifications, such as one indicator derived from another.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA10_EA3_EA5262" ;
    skos:prefLabel "PerformanceIndicatorSpecRelationship"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA10_EA3_EA5263> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA10_EA3_EA5257> ;
    skos:definition "The invariant characteristics that define a communication (notification) that occurs as part of performance measurement. A Notification is typically one-sided, in that no Response is expected.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA10_EA3_EA5263" ;
    skos:prefLabel "PerformanceNotificationSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA10_EA3_EA5264> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA10_EA3_EA5257> ;
    skos:definition "The invariant characteristics that define a measure that deterimines how a Service and/or Resource is functioning. Each related Performance instance will have the same invariant characteristics. However, the values associated with other characteristics of the instantiated Performance entity are specific to each instance.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA10_EA3_EA5264" ;
    skos:prefLabel "PerformanceSpecification"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA10_EA3_EA5265> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA10_EA3_EA5257> ;
    skos:definition "The interval of time for represented by the PerformanceSpecification.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA10_EA3_EA5265" ;
    skos:prefLabel "PerformanceSpecificationInterval"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA10_EA3_EA5266> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA10_EA3_EA5257> ;
    skos:definition "The conversion factor that defines how many instances of one PerformanceSpecificationIntervals are contained in the related PerformanceSpecificationInterval.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA10_EA3_EA5266" ;
    skos:prefLabel "PerformanceSpecIntervalConversion"@en .

