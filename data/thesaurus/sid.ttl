<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA6_EA2287> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA2023> ;
    skos:definition "The<b> Service Order ABE</b> contains all entities that represent a type of Request of one or several services for any type of Service Specification. A Service Order decomposes a Product Order's products into the services associated with a ServiceOrder through which the products are realized.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA6_EA6_EA2287" ;
    skos:prefLabel "Service Order ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA5_EA2648> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA2_EA2456> ;
    skos:definition "A collection of entities that represent the specification of ResourceCatalogs and catalogs described by them that contain ResourceSpecifications.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA2_EA5_EA2648" ;
    skos:prefLabel "Resource Catalog ABE"@en .

