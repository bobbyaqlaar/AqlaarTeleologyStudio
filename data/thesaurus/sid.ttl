    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA6_EA5150> ;
    skos:definition "The Metric Collection ABE is initialized but has to be further studied during iteration 3.<br/>"@en ;
