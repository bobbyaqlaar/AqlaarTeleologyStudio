<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA2751> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA2749> ;
    skos:definition "These entities can be used to manage both resource and service domains entities<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA7_EA3_EA2751" ;
    skos:prefLabel "EARoot_EA4_EA2_EA7_EA3_EA2751"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA7_EA3_EA2752> a skos:Concept ;
