    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA6_EA3_EA1_EA2110> ;
    skos:definition "The Customer Facing Service Spec Examples ABE contains example subclasses of CustomerFacingServiceSpecs.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA6_EA3_EA1_EA1_EA2123" ;
