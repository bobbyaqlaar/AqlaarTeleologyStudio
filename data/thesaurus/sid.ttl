    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA3_EA7161" ;
    skos:prefLabel "LineString"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA3_EA7162> a skos:Concept ;
