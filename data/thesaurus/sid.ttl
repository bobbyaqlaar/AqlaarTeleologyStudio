<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA1_EA1474> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA5_EA1458> ;
    skos:definition "<b>Product Party Roles ABE</b> contains all PartyRoles related to the Product Domain such as ProductManager or ProductUser.<br/>Note: <i>Roles related to Customer such as Payer are located in Customer Domain</i><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA5_EA1_EA1474" ;
    skos:prefLabel "Product Party Roles ABE"@en .

