<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA7_EA770> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA1_EA7_EA777> ;
    skos:definition "The LogicalResourceSpec Examples ABE contains examples of more explicit modeling for LogicalResourceSpecs.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA1_EA7_EA770" ;
