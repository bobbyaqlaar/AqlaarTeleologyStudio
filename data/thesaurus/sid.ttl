    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA11_EA3731> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under or related to the <b>Applied Party Bill Rate </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA11_EA3729" ;
    skos:prefLabel "Figure APBR.01 - Applied Party Billing Rate ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA11_EA3732> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA11_EA3731> ;
    skos:definition "An amount, usually of money, for which a person or organization is financially liable.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA11_EA3732" ;
    skos:prefLabel "AppliedPartyBillingCharge"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA11_EA3733> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA11_EA3731> ;
    skos:definition "A credit assigned to the party's account in the course or for the purpose of the billing process<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA11_EA3733" ;
    skos:prefLabel "AppliedPartyBillingCredit"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA11_EA3734> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA11_EA3731> ;
    skos:definition "AppliedPartyBillingDiscount<br/>A reduction in the price of a Product that is applied to reduce the associated charge.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA11_EA3734" ;
    skos:prefLabel "AppliedPartyBillingDiscount"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA11_EA3735> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA11_EA3731> ;
    skos:definition "A credit that is applied in order to reduce the associated charge.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA11_EA3735" ;
    skos:prefLabel "AppliedPartyBillingProductAlteration"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA11_EA3736> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA11_EA3731> ;
    skos:definition "A charge applied to a product.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA11_EA3736" ;
    skos:prefLabel "AppliedPartyBillingProductCharge"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA11_EA3737> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA11_EA3731> ;
    skos:definition "A rated usage event typically produced by a rating engine.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA11_EA3737" ;
    skos:prefLabel "AppliedPartyBillingProductUsageRate"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA11_EA3738> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA11_EA3731> ;
    skos:definition "A charge or a credit assigned to the party's account in the course or for the purpose of the billing process. Subclasses further define these elements.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA11_EA3738" ;
    skos:prefLabel "AppliedPartyBillingRate"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA11_EA3739> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA11_EA3731> ;
    skos:definition "A detailed description of AppliedPartyBillingRate entity. This business entity holds the definition of all the characteristics (variant attributes) of AppliedPartyBillingRate<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA11_EA3739" ;
    skos:prefLabel "AppliedPartyBillingRateSpec"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA11_EA3740> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA11_EA3731> ;
    skos:definition "An amount, usually of money, which is paid back to a party's account, for example, because a party is entitled to a refund.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA11_EA3740" ;
    skos:prefLabel "AppliedPartyBillingRebate"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA11_EA3741> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA11_EA3731> ;
    skos:definition "An amount of money levied on the price of a Product by a legislative body.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA11_EA3741" ;
    skos:prefLabel "AppliedPartyBillingTaxRate"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA11_EA3742> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA11_EA3731> ;
    skos:definition "The AppliedPartyPenaltyCharge is a type of AppliedPartyBillingCharge.<br/><br/>It represents penalty charges such as late fees, payment rejection fees, interests, that could be applied, linked to dunning of a due amount, in order to bill the party according to contractual terms and conditions.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA11_EA3742" ;
    skos:prefLabel "AppliedPartyPenaltyCharge"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA11_EA3743> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA11_EA3731> ;
    skos:definition "A single charge or a credit.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA11_EA3743" ;
    skos:prefLabel "AtomicAppliedPartyBillingRate"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA11_EA3744> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA11_EA3731> ;
    skos:definition "A sum of one or more other AppliedPartyBillingRates formed by aggregating other AppliedPartyBillingRates, which may be either Composite or Atomic AppliedPartyBillingRates.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA11_EA3744" ;
    skos:prefLabel "CompositeAppliedPartyBillingRate"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA11_EA3745> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA11_EA3731> ;
    skos:definition "FinancialCharge represent a normalized aggregation of AtomicAppliedPartyBillingRate so every AtomicAppliedPartyBillingRate appears in exactly one FinancialCharge. This is critical for financial reporting.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA11_EA3745" ;
    skos:prefLabel "PartyFinancialCharge"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA12_EA3746> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA12_EA3748> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under or related to the <b>Party Statistic </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA12_EA3746" ;
    skos:prefLabel "Figure PS.01 - Party Statistic ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA12_EA3749> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA12_EA3748> ;
    skos:definition "A meaure of Party churn (turnover of Partys) or Party retention (keeping Partys).<br/><br/>Renamed to avoid duplicate class with Customer Domain.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA12_EA3749" ;
    skos:prefLabel "PartyChurnRetentionStatistic"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA13_EA3750> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3411> ;
    skos:definition "<b>Business Partner Strategy & Plan ABE</b> supports the strategies and the planning of the business relation with Business Partners as well as on how to choose and manage Business Partners.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA13_EA3750" ;
    skos:prefLabel "Business Partner Strategy & Plan ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA1_EA3426> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA1_EA3430> ;
    skos:definition "The Business Partner Domain party roles presently identified are:<br/> • Partner: A PartyRole, played by a Party being an equitable partner in a business interaction with other parties, playing the Partner role. Usually all Partner have the same (or even compatible) business objectives.<br/> • Supplier: A PartyRole played by a Party, who commits to provide a deliverable to a Buyer by a formal Agreement (Commitment)<br/>Partner and Supplier are further subclassed as depicted in the diagram below.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA1_EA3426" ;
    skos:prefLabel "Figure BP.00 - Business Partner Party Roles"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA1_EA3428> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA1_EA3430> ;
    skos:definition "The following Figure shows the new Entities added to describe further PartyRoles.<br/>A Party may possess one or many PartyAccounts through PartyRoles. <br/>A PartyAccount is an arrangement that a Party has with an enterprise (such as a communication service provider) through which the enterprise collects AppliedPartyBillingRate (i.e. charges) to structure bills. It also collects payments for Products that are supplied by the enterprise to the Party. The AppliedPartyBillingRates are invoiced to the PartyAccount via PartyBills.<br/>A PartyRole might be evaluated for its worthiness (PartyCreditProfile) and this evaluation might be based on external information (PartyCreditProfileReference).<br/>The AccountContact qualifies for a PartyAccount a contact point (PartyRole and ContactMedium) such as primary, secondary, and emergency contact.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA1_EA3428" ;
    skos:prefLabel "Figure BP.01 - Party Business Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA1_EA3431> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA1_EA3430> ;
    skos:definition "The Channel Partner that helps the enterprise to reach some specific customers. Example : An international service provider works with a local agent in Gabon to win a contract with Gabon Post Services. The agent does not manage the relationship with the final customers. He facilitates the sale.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA1_EA3431" ;
    skos:prefLabel "Agent"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA1_EA3432> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA1_EA3430> ;
    skos:definition "Sales and marketing partners (otherwise known as channel partners) with which the Service Provider establishes partnership relations with the goal of increasing sales and achieving the target market.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA1_EA3432" ;
    skos:prefLabel "ChannelPartner"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA1_EA3433> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA1_EA3430> ;
    skos:definition "The Channel Partner that sells the service provider offers under the enterprises' brand. The distributor is responsible for the sale. Once the sale is performed, the relationship with the customer is transferred to the service provider.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA1_EA3433" ;
    skos:prefLabel "Distributor"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA1_EA3434> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA1_EA3430> ;
    skos:definition "A PartyRole, played by a Party being an equitable partner in a business interaction with other parties, playing the Partner role. Usually all Partner have the same (or even compatible) business objectives.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA1_EA3434" ;
    skos:prefLabel "Partner"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA1_EA3435> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA1_EA3430> ;
    skos:definition "The Channel Partner that sells the service provider offers under its brand or not. Depending on the contract, the reseller can partially (for example sale, invoicing) or fully (all operations including support, own eCare…) manage the relationship with its customers.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA1_EA3435" ;
    skos:prefLabel "Reseller"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA1_EA3436> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA1_EA3430> ;
    skos:definition "A Shipping Carrier is a type of Supplier played by a Company in charge of shipping material goods.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA1_EA3436" ;
    skos:prefLabel "ShippingCarrier"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA1_EA3437> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA1_EA3430> ;
    skos:definition "A PartyRole played by a Party, who commits to provide a deliverable to a Buyer by a formal Agreement (Commitment)<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA1_EA3437" ;
    skos:prefLabel "Supplier"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA2_EA3438> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA2_EA3444> ;
    skos:definition "A Service Provider might place orders with Suppliers, Partners, etc. This is represented by the BusinessPartnerProductOrder.<br/>BusinessPartnerProductOrder / BusinessProductOfferingOrderItem / BusinessPartnerProductOrderItem are sub-classes from the pattern ProductOrder / ProductOfferingOrderItem / ProductOrderItem. For further details about ProductOrder / ProductOfferingOrderItem / ProductOrderItem refer to the Product Domain guide book section Product Order ABE.<br/>A ProductOrder represents a request used to procure, update or remove one or many ProductOfferingInstances in the context of a ProductOfferingSpecification through all its ProductOfferingItems. The particularity of the BusinessPartnerProductOrder is to procure, update or remove ProductOfferingInstances for the Service Provider even if, for example, the BusinessPartnerProductOrder might be placed by the Business Partner when applying precautionary measures in case of bad debt.<br/>At least one CommunicationInteraction is the source of a BusinessPartnerProductOrder. Then, additional interactions might happen such as the Service Provider asking why his order isn’t yet delivered or the Business Partner informing the the Service Provider his order is completed.<br/><i>CommunicationInteractions related to BusinessPartnerProductOrder might not be tracked by the Service Provider.</i><br/>A BusinessPartnerProductOrder might refer to an ImplementationAgreement specifying all what has been approved by the PartyRoles involved in the BusinessPartnerProductOrder.<br/>One or many PartyRoles might be involved in a BusinessPartnerProductOrder / BusinessPartnerProductOfferingOrderItem / BusinessPartnerProductOrderItem such as Distributor, Holder, Buyer or Product User.<br/>The BusinessPartnerProductOrder, BusinessPartnerProductOfferingOrderItem and BusinessPartnerProductOrderItems may specify the BusinessPartnerAccount to which the ProductOfferingInstances’ are charged to.<br/>When BusinessPartnerProductOrder / BusinessPartnerProductOfferingOrderItem are not charged to a BusinessPartnerAccount and carry one-time charges, they might be directly paid through one or many BusinessPartnerPayments.<br/>A BusinessPartnerProductOfferingOrderItem might refer to an ImplementationAgreementItem. <br/>A BusinessPartnerProductOfferingOrderItem may need other BusinessPartnerProductOfferingOrderItems to be completed; this dependency is represented through the \"/BPProductOfferingOrderItemRefrencesReferencedBy\" relationship.<br/>A BusinessPartnerProductOrderItem may need other BusinessPartnerProductOrderItems to be completed; this dependency is represented through the \"/BPProductOrderItemRefrencesReferencedBy\" relationship.<br/>A BusinessPartnerProductOrder, BusinessPartnerProductOfferingOrderItem and BusinessPartnerProductOrderItems might be further described by Attachments.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA2_EA3438" ;
    skos:prefLabel "Figure BPPO.01 - Business Partner Product Order Business Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA2_EA3440> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA2_EA3444> ;
    skos:definition "One or many PartyRoles might be involved in a BusinessPartnerProductOrder / BusinessPartnerProductOfferingOrderItem / BusinessPartnerProductOrderItem such as Distributor, Holder, Buyer or Product User.<br/>Each BusinessPartnerProductOrderItem requires an action (AllowedProductAction) on a ProductSpecification.<br/>The configuration required is described by the related Product even if it isn’t delivered yet.<br/>To deliver the corresponding Product, the Place to deliver and Appointment(s) might be needed. An Appointment is an arrangement to do something or meet someone at a particular time and location.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA2_EA3440" ;
    skos:prefLabel "Figure BPPO.02 - Business Partner Product Order Item Business Entities overview"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA2_EA3442> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA2_EA3444> ;
    skos:definition "One or many PartyRoles might be involved in a BusinessPartnerProductOrder / BusinessPartnerProductOfferingOrderItem / BusinessPartnerProductOrderItem such as Distributor, Holder, Buyer or Product User.<br/>Each BusinessPartnerProductOfferingOrderItem requires an action (AllowedProductAction) on a ProductOfferingSpecification.<br/>The configuration required is described by the related ProductOfferingInstance even if it isn’t delivered yet. The prices applicable are related to the ProductOfferingInstance (ProductPrice).<br/>A BusinessPartnerProductOfferingOrderItem may also specify the commitment chosen by the Service Provider (i.e. CommitmentTermOrCondition).<br/>The BusinessPartnerProductOfferingOrderItems may specify the BusinessPartnerAccount to which the ProductOfferingInstances’ are charged to.<br/>When BusinessPartnerProductOfferingOrderItems are not charged to a BusinessPartnerAccount and carry one-time charges, they might be directly paid through one or many BusinessPartnerPayments.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA2_EA3442" ;
    skos:prefLabel "Figure BPPO.03 - Business Partner Product Offering Order Item Business Entities overview"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA2_EA3445> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA2_EA3444> ;
    skos:definition "{XOR}<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA2_EA3445" ;
    skos:prefLabel "EARoot_EA4_EA2_EA8_EA2_EA3445"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA2_EA3446> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA2_EA3444> ;
    skos:definition "{XOR}<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA2_EA3446" ;
    skos:prefLabel "EARoot_EA4_EA2_EA8_EA2_EA3446"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA2_EA3447> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA2_EA3444> ;
    skos:definition "ProductPrice should be removed from this diagram<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA2_EA3447" ;
    skos:prefLabel "EARoot_EA4_EA2_EA8_EA2_EA3447"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA2_EA3448> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA2_EA3444> ;
    skos:definition "Remove ProductOfferingSpecification from this Diagram<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA2_EA3448" ;
    skos:prefLabel "EARoot_EA4_EA2_EA8_EA2_EA3448"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA2_EA3449> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA2_EA3444> ;
    skos:definition "A BusinessPartnerProductOfferingOrderItem is a type of ProductOfferingOrderItem.<br/>Each BusinessPartnerProductOfferingOrderItem requires an action (AllowedProductAction) on a ProductOffering.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA2_EA3449" ;
    skos:prefLabel "BusinessPartnerProductOfferingOrderItem"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA2_EA3450> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA2_EA3444> ;
    skos:definition "A BusinessPartnerProductOrder specifies a communication used to procure, update or remove one or many Product Offering Instances in the context of a ProductOfferingSpecification for the Service Provider.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA2_EA3450" ;
    skos:prefLabel "BusinessPartnerProductOrder"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA2_EA3451> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA2_EA3444> ;
    skos:definition "A BusinessPartnerProductOrderItem is a type of ProductOrderItem.<br/>Each BusinessPartnerProductOrderItem requires an action (AllowedProductAction) on a ProductSpecification.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA2_EA3451" ;
    skos:prefLabel "BusinessPartnerProductOrderItem"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3407> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3411> ;
    skos:definition "The diagram below lists the Business Partner Domain's ABEs.<br/><br/><b>Business Partner Party Roles ABE</b><br/> • The Business Partner Party Roles ABE manages Partner roles and related information.<br/><b>Business Partner Product Order ABE</b><br/> • The Business Partner Product Order ABE contains all entities required to specify a communication used to procure, update or remove one or many ProductOfferingInstances in the context of a ProductOfferingSpeciication for the Service Provider.<br/><b>Business Partner Account ABE</b><br/> • Business Partner Account ABE inherits from Account ABE and contains all entities needed for specifying basic attributes and relationships that describe an account. It also represents specificities in the context of a BusinessPartner.<br/><b>Party Product Specification and Offering ABE</b><br/> • The Party Product Specification and Offering ABE contains the entities required to specify the involved parties are playing in business processes related to ProductSpecifications and Product Offerings, such as ordered from and billed by.<br/><b>Party Revenue & Settlement ABE</b><br/> • Party Revenue & Settlement ABE is composed of revenue sharing and settlements.<br/><b>Business Partner Problem ABE (preliminary)</b><br/> • The Business Partner Problem ABE focuses on technical assistance and problem handling reported by the CSP to other parties. <br/><b>Applied Business Partner Billing Rate ABE (preliminary)</b><br/> • The Applied Business Partner Billing Rate ABE contains business entities involved with charges/credits from the business partner assigned with respect to a business partner billing account.<br/><b>Party Bill Collection ABE (preliminary)</b><br/> • The Party Bill Collection ABE handles credit violations, actions for overdue debts (Dunning), and all what is related to BusinessPartnerPayment.<br/><b>Business Partner Bill ABE (preliminary)</b><br/> • The Business Partner Bill ABE contains entities related to a total amount due from a CSP to a Business Partner for all products during the billing period either precalculated by the CSP or by the business partner. <br/><b>Party Service Level Agreement ABE (preliminary)</b><br/> • Party Service Level Agreement ABE represents an SLA with one or more other parties. See the Agreement ABE for additional details.<br/><b>Party Interaction ABE (preliminary)</b><br/> • Party Interaction ABE represents communications with parties, and the translation of requests and inquiries into appropriate \"events\" such as the creation of an order, the creation of a bill inquiry, or the creation of a problem.<br/><b>Business Partner Statistic ABE (not fully developed)</b><br/> • Business Partner Statistic ABE represents the analysis of Business Partner relationships such as the number and total amount of invoices or the number of payments.<br/><b>Business Partner Strategy & Plan ABE (not fully developed)</b><br/> • Business Partner Strategy & Plan ABE supports the strategies and the planning of the business relation with Business Partners as well as on how to choose and manage Business Partners.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3407" ;
    skos:prefLabel "[BPD-01] Business Partner ABEs Level 1"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3409> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3411> ;
    skos:definition "The diagram below lists the Business Partner Domain's ABEs Level 1 and 2.<br/><br/><b>Party Billing Statistic ABE (preliminary)</b><br/> • This ABE is preliminary.<br/><b>Party Role Product Offering Specification ABE</b><br/> • The Party Role Product Offering Specification ABE represents the involvement parties playing roles have with ProductOfferingSpecifications.<br/><b>Party Role Product Specification ABE</b><br/> • The Party Role Product Specification ABE represents the involvement parties playing roles have with ProductSpecifications.<br/><b>Business Partner Dunning ABE (preliminary)</b><br/> • To be checked if a CSP follows Dunning cases from Suppliers<br/><b>Business Partner Payment ABE</b><br/> • The Business Partner Payment ABE contains description of transfer of wealth between the CSP and a Business Partner.<br/><b>Party Settlement ABE (preliminary)</b><br/> • Party Settlement ABE is a group of entities that represent a monetary value that will be paid to a party by the enterprise or a party will pay to the enterprise as a result of the usage/recurring fee of a product/service/resource provided. Party Settlement is managed by agreements and can be created between an enterprise and other MVNOs, dealers, retailers, content providers, etc.<br/><b>Party Revenue Sharing ABE</b><br/> • The Party Revenue Sharing ABE contains party revenue sharing models, party revenue sharing agreements, party revenue shares, and party revenue sharing reconciliations.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3409" ;
    skos:prefLabel "[BPD-02] Business Partner ABEs Level 1 and 2"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3425> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3411> ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3425" ;
    skos:prefLabel "UNUSED Business Partner Addendum Figures"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA1_EA1_EA3517> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA1_EA1_EA3519> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Example Party Role Product Offering Specification Entities </b>Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA1_EA1_EA3517" ;
    skos:prefLabel "Figure EPRPO.01 - Example Party Role Product Offering Specification Entities ABE"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA1_EA1_EA3520> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA1_EA1_EA3519> ;
    skos:definition "A PartyRoleProductOfferingSpec describes a ProductOfferingSpecification made available by a PartyRole and the involvement the PartyRole has with the ProductOfferingSpecification.<br/><br/>A PurchaseProductOfferingSpec is a type of PartyRoleProductOfferingSpec where the ProductOfferingSpecification is bought by the Service Provider.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA1_EA1_EA3520" ;
    skos:prefLabel "PurchaseProductOfferingSpec"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA1_EA1_EA3521> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA1_EA1_EA3519> ;
    skos:definition "A PartyRoleProductOfferingSpec describes a ProductOfferingSpecification made available by a PartyRole and the involvement the PartyRole has with the ProductOfferingSpecification.<br/><br/>A SalesProductOfferingSpec is a type of PartyRoleProductOfferingSpec where the ProductOfferingSpecification is sold / rented by the Service Provider.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA1_EA1_EA3521" ;
    skos:prefLabel "SalesProductOfferingSpec"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA1_EA3511> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA1_EA3513> ;
    skos:definition "<font color=\"#29313b\">Following are the business entities aggregated under the <b>Party Role Product Offering Specification</b> Aggregate Business Entity.</font><br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA1_EA3511" ;
    skos:prefLabel "Figure PRPO.01 - Party Role Product Offering Specification ABE Related Entities"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA1_EA3515> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA1_EA3513> ;
    skos:definition "A relationship, such as purchase for resell, broker as-is for resale, between PartyRoleProductOfferingSpecs.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA1_EA3515" ;
    skos:prefLabel "PartyRoleProdOffSpecRelationship"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA1_EA3516> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA8_EA3_EA1_EA3513> ;
    skos:definition "A PartyRoleProductOfferingSpec describes a ProductOfferingSpecification made available by a PartyRole and the involvement the PartyRole has with the ProductOfferingSpecification.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA8_EA3_EA1_EA3516" ;
    skos:prefLabel "PartyRoleProductOfferingSpec"@en .

