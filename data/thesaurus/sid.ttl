    skos:notation "sid:EARoot_EA4_EA2_EA11_EA8_EA1_EA7085" ;
    skos:prefLabel "GeographicSiteRole"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA11_EA8_EA1_EA7086> a skos:Concept ;
