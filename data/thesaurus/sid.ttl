    skos:notation "sid:EARoot_EA4_EA2_EA10_EA9_EA3_EA5098" ;
    skos:prefLabel "MetricCollectionType"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA3_EA5099> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA3_EA5094> ;
    skos:definition "A set of basic facts that defines, or specifies, what a metric is, such as its name, description, and so forth.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA9_EA3_EA5099" ;
    skos:prefLabel "MetricDefinition"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA3_EA5100> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA3_EA5094> ;
    skos:definition "A group or set of MetricDefinition qualities that are classified together because of common characteristics. For example, a business metric or performance metric. Categories can be further divided into sub-categories.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA9_EA3_EA5100" ;
    skos:prefLabel "MetricDefinitionCategory"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA3_EA5101> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA3_EA5094> ;
    skos:definition "The definition of a hierarchy of MetricDefinitions, such as a calculation hierarchy of MetricDefinitions.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA9_EA3_EA5101" ;
    skos:prefLabel "MetricDefinitionHierarchy"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA3_EA5102> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA3_EA5094> ;
    skos:definition "The relationship between two MetricDefinitions in a hierarchy.<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA9_EA3_EA5102" ;
    skos:prefLabel "MetricDefinitionHierarchyMember"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA3_EA5103> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA3_EA5094> ;
    skos:definition "Captures how MetricDefinition is involved with other entites in the Information Framework (such as Party and PartyRole)<br/>"@en ;
    skos:inScheme thes:sid ;
    skos:notation "sid:EARoot_EA4_EA2_EA10_EA9_EA3_EA5103" ;
    skos:prefLabel "MetricDefinitionInvolvement"@en .

<http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA3_EA5104> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/sid/sid_EARoot_EA4_EA2_EA10_EA9_EA3_EA5094> ;
    skos:definition "A significant connection or similarity between two MetricDefinitions.<br/>"@en ;
