    skos:prefLabel "Convert Resource Usage Records"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA6_EA9312> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA6_EA9289> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA6_EA9312" ;
    skos:prefLabel "Correlate Resource Usage Records"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA6_EA9313> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA6_EA9289> ;
