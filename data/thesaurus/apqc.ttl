<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA7_EA9604> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA7_EA9732> ;
    skos:inScheme thes:apqc ;
