<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA7_EA9606> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA7_EA9709> ;
    skos:inScheme thes:apqc ;
