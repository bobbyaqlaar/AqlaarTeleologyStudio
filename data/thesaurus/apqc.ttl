    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7734" ;
    skos:prefLabel "Undertake Customer Contacts Trend Analysis"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7735> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7910> ;
    skos:definition "Ensure that there is capability (for example, information, materials, systems and resources) so that the Order Management processes can operate effectively. Examples are materials needed to confirm customer order requests and systems needed to validate product offering availability.<br/>"@en ;
    skos:inScheme thes:apqc ;
