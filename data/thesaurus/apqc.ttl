    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA1_EA7372> ;
    skos:definition "Select Marketing Communication Delivery Channels selects the appropriate channel or channels to support delivery of a marketing message associated with a communication. A particular product offering or marketing campaign may require selection of one or several delivery channels.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7379" ;
    skos:prefLabel "Select Marketing Communication Delivery Channels"@en .

