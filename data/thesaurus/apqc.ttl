    skos:inScheme thes:apqc ;
    skos:notation "9.6.1.1" ;
    skos:prefLabel "Verify AP pay file with purchase order vendor master file"@en .

<http://ots.local/thesaurus/apqc/9_6_1_10> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_6_1> ;
    skos:definition "Keeping bills of every transaction for future reference."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.6.1.10" ;
    skos:prefLabel "Retain records"@en .

<http://ots.local/thesaurus/apqc/9_6_1_11> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_6_1> ;
    skos:definition "Rectifying for alterations occurred in accounts while recording."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.6.1.11" ;
    skos:prefLabel "Adjust accounting records"@en .

<http://ots.local/thesaurus/apqc/9_6_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_6_1> ;
    skos:definition "Tracking all online transactions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.6.1.2" ;
    skos:prefLabel "Maintain/Manage electronic commerce"@en .

<http://ots.local/thesaurus/apqc/9_6_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_6_1> ;
    skos:definition "Monitoring and evaluating bills registered in accounts books. Check all invoices. Maintain records."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.6.1.3" ;
    skos:prefLabel "Audit invoices and key data in AP system"@en .

<http://ots.local/thesaurus/apqc/9_6_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_6_1> ;
    skos:definition "Processing payments for products/services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.6.1.4" ;
    skos:prefLabel "Approve payments"@en .

<http://ots.local/thesaurus/apqc/9_6_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_6_1> ;
    skos:definition "Handling transactions for accruals and reversals. Record transactions in the books of accounts on an accrual basis (irrespective of the actual cash flow) and reversals basis (cancel out the adjusting entries) for balancing accounts."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.6.1.5" ;
    skos:prefLabel "Process financial accruals and reversals"@en .

<http://ots.local/thesaurus/apqc/9_6_1_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_6_1> ;
    skos:definition "Filing the amount of taxes that a company owes as of the balance sheet date. Prepare tax returns, including the income tax filing for an individual or business entity from earnings."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.6.1.6" ;
    skos:prefLabel "Process payables taxes"@en .

<http://ots.local/thesaurus/apqc/9_6_1_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_6_1> ;
