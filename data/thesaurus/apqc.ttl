<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10663> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10480> ;
    skos:definition "Execute Data Integration task is responsible for combining data from different sources into a unified view.<br/><br/>Execute Data Integration is performed for various purposes, such as data analysis, data warehousing, data migration, data quality improvement, or data synchronization. The task includes identifying the data sources and the target systems, defining data integration rules and mappings, extracting the data from the sources, transforming the data according to the rules and mappings, loading data into the target systems, and verifying data integrity and quality.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10663" ;
    skos:prefLabel "Execute Data Integration"@en .

