<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA4_EA8208> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA4_EA8567> ;
    skos:definition "Define Product Problem Solution business activity is in charge of finding and describing solutions and solution goals to the product problem.<br/><br/>This business activity acts to identify a set of solutions to a product problem each with well-described goals. Goals may be strategic or tactical.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8208" ;
    skos:prefLabel "Define Product Problem Solution"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA4_EA8209> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA4_EA8567> ;
    skos:definition "Implement Product Problem Solution business activity is in charge of executing the set of tasks identified to address or correct product problem.<br/><br/>Implement Product Problem Solution ensures that plans and their goals match business expectations.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8209" ;
    skos:prefLabel "Implement Product Problem Solution"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA4_EA8210> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA4_EA8567> ;
    skos:definition "Plan Product Problem Solution business activity is in charge of identifying tasks and actions that enable implement answers or correction to a product problem.<br/><br/>This business activity ensures that the set of actions and tasks to resolve or solve a product problem solution meet the solution goals. <br/>a set of solutions to a product problem. evidence of the investigation of the product problem.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8210" ;
    skos:prefLabel "Plan Product Problem Solution"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA4_EA8212> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA4_EA8567> ;
    skos:definition "Report Product Problem Solution business activity is in charge of documenting (written or verbal) the answer or corrective actions applied to resolve or mediate a product problem.<br/><br/>This business activity includes tasks that design product problem handling status reports, collecting information relevant to report product problem solutions, development of the product problem solution report, review of the product problem reports fit-for-purpose, and distributing product problem reports.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8212" ;
    skos:prefLabel "Report Product Problem Solution"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA4_EA8213> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA4_EA8199> ;
    skos:definition "Product Design Catalog Plan business activity understands requirements and capabilities demanded from the business to establish the Catalog plan based on the Product strategy for Product Catalog Planning Management.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8213" ;
    skos:prefLabel "Design Product Catalog Plan"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA4_EA8214> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA4_EA8199> ;
    skos:definition "Define Catalog Specification business activity establishes the Catalog specifications based on the product/service/resource strategy to support Catalog Planning Management.<br/>Define Catalog Specification leverages Specification Management business activities to establish the mandatory and optional design requirements, as well as catalog entry fields according to product/service/resource management needs. This process will be governed by the Enterprise Business Process for Catalog Management.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8214" ;
    skos:prefLabel "Define Product Catalog Specification"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA4_EA8215> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA4_EA8382> ;
    skos:definition "Develop Product Offering Procedures develops the procedures for the specific fulfillment, assurance and revenue generation processes for a new or enhanced product offering as well as keeping them up to date.<br/><br/>Develop policy support and decision support knowledge for these product offering processes and procedures.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8215" ;
    skos:prefLabel "Develop Product Offering Procedures"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA4_EA8216> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA4_EA8382> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8216" ;
    skos:prefLabel "Support Product Offering Operational Introduction"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA4_EA8217> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA4_EA8382> ;
