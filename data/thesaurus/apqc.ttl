<http://ots.local/thesaurus/apqc/9_7_5_5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_5_5> ;
    skos:definition "Determining which hedge options to execute."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.5.5.2" ;
    skos:prefLabel "Establish hedges"@en .

<http://ots.local/thesaurus/apqc/9_7_5_5_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_5_5> ;
    skos:definition "Closing out a position or cashing in derivatives early."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.5.5.3" ;
    skos:prefLabel "Unwind hedges"@en .

<http://ots.local/thesaurus/apqc/9_7_5_5_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_5_5> ;
    skos:definition "Examining options in the market for hedging investments. Select an option."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.5.5.4" ;
    skos:prefLabel "Evaluate and refine hedging positions"@en .

<http://ots.local/thesaurus/apqc/9_7_5_5_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_5_5> ;
    skos:definition "Revising credit reports periodically for accurateness and changes that could be suggestive of duplicitous activity."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.5.5.5" ;
    skos:prefLabel "Monitor credit"@en .

<http://ots.local/thesaurus/apqc/9_7_5_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_5> ;
    skos:definition "Preparing and documenting accounts and records of all hedging investment transactions to reduce risks due to change in markets."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.5.6" ;
    skos:prefLabel "Produce hedge accounting transactions and reports"@en .

<http://ots.local/thesaurus/apqc/9_7_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7> ;
    skos:definition "Handling cases that involve financial fraud. Resolve disputes."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.6" ;
    skos:prefLabel "Manage financial fraud/dispute cases"@en .

<http://ots.local/thesaurus/apqc/9_8_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_8_1> ;
    skos:definition "Establishing board of directors and auditing committee in order to assign roles and responsibilities for internal controls."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.8.1.1" ;
    skos:prefLabel "Establish board of directors and audit committee"@en .

<http://ots.local/thesaurus/apqc/9_8_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_8_1> ;
    skos:definition "Outlining and communicating a code of ethics act responsibly."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.8.1.2" ;
    skos:prefLabel "Define and communicate code of ethics"@en .

<http://ots.local/thesaurus/apqc/9_8_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_8_1> ;
    skos:definition "Defining roles, responsibilities, and accountabilities for effectiveness and proficiency of operations and reliability of financial reporting."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.8.1.3" ;
    skos:prefLabel "Assign roles and responsibility for internal controls"@en .

<http://ots.local/thesaurus/apqc/9_8_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_8_1> ;
    skos:definition "Outlining the objectives and risks associated with a process. Delineate process goals. Determine the risks attached to it. Determine what the process is meant to accomplish, potential issues, a timeline of potential risks, the scope and potential impact of risks, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.8.1.4" ;
    skos:prefLabel "Define business process objectives and risks"@en .

<http://ots.local/thesaurus/apqc/9_8_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_8_1> ;
    skos:definition "Outlining the risk tolerance levels of individual units, as well as the organization as a whole. Determine the specific maximum risk to take in quantitative terms for each relevant risk subcategory, including strategic, operational, financial, and compliance risks."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.8.1.5" ;
    skos:prefLabel "Define entity/unit risk tolerances"@en .

<http://ots.local/thesaurus/apqc/9_8_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_8_2> ;
    skos:definition "Overseeing the activities for internal controls. Observe the effectiveness of policies, procedures, techniques, and mechanisms actions taken to minimize risk."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.8.2.1" ;
    skos:prefLabel "Monitor control effectiveness"@en .

<http://ots.local/thesaurus/apqc/9_8_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_8_2> ;
    skos:definition "Taking corrective measures for policies, procedures, techniques, and mechanisms actions taken to minimize risk. (Conduct in accordance with Monitor control effectiveness [10918] in order to determine and rectify the control deficiencies.)"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.8.2.2" ;
    skos:prefLabel "Remediate control deficiencies"@en .

<http://ots.local/thesaurus/apqc/9_8_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_8_3> ;
    skos:definition "Reporting to external auditors. This process requires the organization to report to external auditors about the regulations for any critical data that the organization is holding."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.8.3.1" ;
    skos:prefLabel "Report to external auditors"@en .

<http://ots.local/thesaurus/apqc/9_8_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_8_3> ;
    skos:definition "Reporting to regulators, shareholders, debt holders, securities exchanges, etc. about IT regulations and pertinent data."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.8.3.2" ;
    skos:prefLabel "Report to regulators, share-/debt-holders, securities exchanges, etc."@en .

<http://ots.local/thesaurus/apqc/9_8_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_8_3> ;
    skos:definition "Reporting to suppliers, customers, and partners that are doing business with the company about IT regulations and pertinent data."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.8.3.3" ;
    skos:prefLabel "Report to third parties"@en .

<http://ots.local/thesaurus/apqc/9_8_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_8_3> ;
    skos:definition "Reporting to internal management (all employees, directors, and management) about IT regulations and pertinent data."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.8.3.4" ;
    skos:prefLabel "Report to internal management"@en .

<http://ots.local/thesaurus/apqc/9_9_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_9_1> ;
    skos:definition "Developing a tax strategy for foreign, national, state, local administration. Set up tax strategies for foreign trade in imports and exports and at national, state, and local level."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.9.1.1" ;
    skos:prefLabel "Develop foreign, national, state, and local tax strategy"@en .

<http://ots.local/thesaurus/apqc/9_9_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_9_1> ;
    skos:definition "Combining and enhancing a rational analysis of a financial condition or plan from a tax perspective in order to align financial goals through efficient tax planning."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.9.1.2" ;
    skos:prefLabel "Consolidate and optimize total tax plan"@en .

<http://ots.local/thesaurus/apqc/9_9_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_9_1> ;
    skos:definition "Maintaining a master file about the rational analysis of a financial condition or plan from a tax perspective in order to align financial goals through efficient tax planning."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.9.1.3" ;
    skos:prefLabel "Maintain tax master data"@en .

<http://ots.local/thesaurus/apqc/9_9_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_9_2> ;
    skos:definition "Creating and implementing strategies for taxes to be paid or collected by the business."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.9.2.1" ;
    skos:prefLabel "Perform tax planning/strategy"@en .

<http://ots.local/thesaurus/apqc/9_9_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_9_2> ;
    skos:definition "Preparing and submitting tax reports for every employee to the tax department in order to show the tax paid and deducted from their salaries in the year."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.9.2.2" ;
    skos:prefLabel "Prepare tax returns"@en .

<http://ots.local/thesaurus/apqc/9_9_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_9_2> ;
    skos:definition "Preparing reports about paid or accrued foreign taxes to an overseas country."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.9.2.3" ;
    skos:prefLabel "Prepare foreign taxes"@en .

<http://ots.local/thesaurus/apqc/9_9_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_9_2> ;
    skos:definition "Calculating the income that has been realized when the tax on that income has not."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.9.2.4" ;
    skos:prefLabel "Calculate deferred taxes"@en .

<http://ots.local/thesaurus/apqc/9_9_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_9_2> ;
    skos:definition "Managing the organization's financial accounts for the purpose of taxation. Prepare and maintain the tax paid by the organization to the country they have business in."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.9.2.5" ;
    skos:prefLabel "Account for taxes"@en .

<http://ots.local/thesaurus/apqc/9_9_2_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_9_2> ;
    skos:definition "Checking and correcting the tax policies according to the rules and regulations set by the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.9.2.6" ;
    skos:prefLabel "Monitor tax compliance"@en .

<http://ots.local/thesaurus/apqc/9_9_2_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_9_2> ;
    skos:definition "Addressing any tax queries by any regulatory or government authorities. Review historical records related to taxation within the organization in order to respond to queries."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.9.2.7" ;
    skos:prefLabel "Address tax inquiries"@en .

<http://ots.local/thesaurus/apqc/11_1_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_1_3> ;
    skos:definition "Developing possibilities and arrangements to improve opportunities and reduce deviations to project objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.1.3.3" ;
    skos:prefLabel "Develop mitigation plans for risks"@en .

<http://ots.local/thesaurus/apqc/13_1_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_1_3> ;
    skos:definition "Assessing and examining the set of activities and tasks that, once completed, will accomplish an organizational goal. Create a business process model that captures how a business process works and how individuals from different groups work together to achieve a business goal."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.1.3.2" ;
    skos:prefLabel "Analyze processes"@en .

<http://ots.local/thesaurus/apqc/13_1_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_1_4> ;
    skos:definition "Defining and using performance indicators to consider the financial perspective, customer perspective, internal process perspective, and learning perspective of the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.1.4.3" ;
    skos:prefLabel "Measure and report process performance"@en .

<http://ots.local/thesaurus/apqc/1_2_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_2> ;
    skos:definition "Defining the various options available to achieve the goals highlighted in the mission statement. Delineate (in accordance with a predefined criteria) the various permutations of strategic decisions that would help the organization achieve the objectives outlined in Develop overall mission statement [10037]. Involve senior management and key strategy personnel, with timely help from professional services providers."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.2.1" ;
    skos:prefLabel "Define strategic options"@en .

<http://ots.local/thesaurus/apqc/2_3_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_1> ;
    skos:definition "Allocating resources to the design, development, and evaluation of product/service concepts. Allocate funds, personnel, and time for developing the new and/or revised products/services. Begin to design the potential new product/service concepts that have been prioritized and selected for further development."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.1.1" ;
    skos:prefLabel "Assign resources to product/service project"@en .

<http://ots.local/thesaurus/apqc/2_3_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_3> ;
    skos:definition "Finalizing production process or methodology. Install and initiate the production process to manufacture the new products, using the equipment and machinery already assembled. In the case of new services, implement delivery processes and methodologies. Validate processes for the accuracy of their operation and proper functioning."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.3.4" ;
    skos:prefLabel "Install and validate production/service delivery process"@en .

<http://ots.local/thesaurus/apqc/3_1_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_1_1> ;
    skos:definition "Identifying a section of the customer population to target for marketing products/services. Create segments within the customer population for targeted marketing campaigns, which increase the efficacy of marketing outlay. Determine the right customer segments, craft effective marketing messages, and efficiently communicate them. Determine the optimal pricing mix. Consider assistance from professional services for market segmentation studies, with coordination and oversight from the marketing/sales functions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.1.1.2" ;
    skos:prefLabel "Identify market segments"@en .

<http://ots.local/thesaurus/apqc/3_1_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_1_2> ;
    skos:definition "Identifying the targeted segment of customers. Deduce those particular customer segments that are to be targeted from among the market segments."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.1.2.2" ;
    skos:prefLabel "Determine target segments"@en .

<http://ots.local/thesaurus/apqc/7_2_5_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_2_5> ;
    skos:definition "Keeping track of all the information about the candidates who apply for jobs. Use applicant-tracking systems that can be accessed online as a central location and database for recruitment efforts."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.2.5.3" ;
    skos:prefLabel "Manage/Track applicant data"@en .

<http://ots.local/thesaurus/apqc/7_6_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_6> ;
    skos:definition "Managing the relocation of employees in order to carry out assignments. Manage internal business processes to transfer employees, their families, and/or entire departments of a business to a new location."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.6.3" ;
    skos:prefLabel "Relocate employees and manage assignments"@en .

<http://ots.local/thesaurus/apqc/8_5_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5> ;
    skos:definition "Understanding customer requirements. Design the IT services and solutions based on the requirements. Develop components for providing the requirements. Train resources to provide support. Test the IT services and solutions in advance. Confirm the customer experience post-sale."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.4" ;
    skos:prefLabel "Execute IT service/solution creation and testing"@en .

<http://ots.local/thesaurus/apqc/8_5_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5> ;
    skos:definition "Engaging in all aspects of service/solution maintenance and testing includes all preventative, routine, and corrective activates. Ensure that IT service/solution are functioning properly and regulations where applicable."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.5" ;
    skos:prefLabel "Perform service/solution maintenance and testing"@en .

<http://ots.local/thesaurus/apqc/8_7_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7> ;
    skos:definition "Determine and manage service delivery flow across different business functions. Understand the level of services needed by different stakeholders. Identify major service delivery touch points and criticality associated. Ensure timely communication with users."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.3" ;
    skos:prefLabel "Plan and manage service delivery control"@en .

<http://ots.local/thesaurus/apqc/10_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_1> ;
    skos:definition "Managing the provision of the workspace and its assets. Arrange an office space with all assets (tables, chairs, computers, admin staff, etc.) according to requirements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.1.3" ;
    skos:prefLabel "Provide workspace and facilities"@en .

<http://ots.local/thesaurus/apqc/10_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_4> ;
    skos:definition "Creating a strategy for managing asset exits."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.4.1" ;
    skos:prefLabel "Develop exit strategy"@en .

<http://ots.local/thesaurus/apqc/11_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_0> ;
    skos:definition "Managing steps to confirm enduring compliance to industry regulations and government legislation."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.2" ;
    skos:prefLabel "Manage compliance"@en .

<http://ots.local/thesaurus/apqc/12_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_0> ;
    skos:definition "Maintaining relations with representatives of the stockholders. Establish corporate management-related policies and to make decisions on major company issues. Implement practices designed to engender communication, trust, and cooperation."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.3" ;
    skos:prefLabel "Manage relations with board of directors"@en .

<http://ots.local/thesaurus/apqc/12_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_4> ;
    skos:definition "Ensuring the organization's compliance position. Validate compliance with different statutes, regulatory directions, and legal principles (using Establish compliance framework and policies [17468]). Coordinate with compliance and risk management personnel."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.4.4" ;
    skos:prefLabel "Ensure compliance"@en .

<http://ots.local/thesaurus/apqc/13_10> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_0> ;
    skos:definition "Developing and managing sustainability practices for the organization. Ensure proper understanding and communication of ESG standards, requirements, capabilities, and future trends. Promote awareness, alignment, and continuity."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.10" ;
    skos:prefLabel "Manage sustainability"@en .

<http://ots.local/thesaurus/apqc/13_10_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_10_2> ;
    skos:definition "Conducting and supporting sustainability reporting. Collect, analyze, and report sustainability performance to requirements. Align reporting across functional units and support teams."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.10.2.3" ;
    skos:prefLabel "Perform sustainability reporting"@en .

<http://ots.local/thesaurus/apqc/13_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_1> ;
    skos:definition "Determining and organizing the structural composition of business processes. Design, establish, and administer the framework. Identify any cross-functional processes that are mandatory for achieving business excellence."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.1.2" ;
    skos:prefLabel "Define and manage process frameworks"@en .

<http://ots.local/thesaurus/apqc/13_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3> ;
    skos:definition "Analyzing if the performance of the quality plan has achieved the estimated and desired requirements. Conduct tests against the quality plan. Assess the results of these tests."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.2" ;
    skos:prefLabel "Evaluate performance to requirements"@en .

<http://ots.local/thesaurus/apqc/13_6_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6> ;
    skos:definition "Defining requirements for systems of record and storage locations to ensure content is securely stored, retrievable, retained appropriately, and aligned with governance and compliance needs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.3" ;
    skos:prefLabel "Define content systems of record and storage requirements"@en .

<http://ots.local/thesaurus/apqc/13_7_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_7> ;
    skos:definition "Creating and implementing a strategy for managing organizational performance. The strategy should include approaches for measuring, tracking, streamlining, and improving internal performance. It encompasses a blueprint for the tactical measurement of internal processes and work force improvement, in alignment with Employee Metrics Developed and Managed [10526]."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.7.1" ;
    skos:prefLabel "Define and manage organizational performance strategy"@en .

<http://ots.local/thesaurus/apqc/13_9_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_9> ;
    skos:definition "Determining the impact of EHS offering--and the procedures it employs to process them--on the environment at large, as well as the health and safety of employees. Evaluate the environmental impact of the organization's products, services, and operations. Conduct health, safety, and environmental audits."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.9.1" ;
    skos:prefLabel "Determine environmental health and safety impacts"@en .

<http://ots.local/thesaurus/apqc/1_2_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_2> ;
    skos:definition "Scoping and probing to study the impact of strategic options for fulfilling the organization's objectives. Estimate a measure of the impact effectuated by each set of strategic decisions, which comprise Define strategic options [10047]. Closely examine the consequences of each option."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.2.2" ;
    skos:prefLabel "Assess and analyze impact of each option"@en .

<http://ots.local/thesaurus/apqc/1_2_8_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_8> ;
    skos:definition "Creating a roadmap for customer experience support with an overall approach, process flow, and impact timeframe."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.8.3" ;
    skos:prefLabel "Design customer experience support structure"@en .

<http://ots.local/thesaurus/apqc/1_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_3> ;
    skos:definition "Examining projects of strategic significance that lie outside the purview of the organization's routine operations. Closely analyze strategic initiatives for their applicability and feasibility, given the organization's vision."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.3.2" ;
    skos:prefLabel "Evaluate strategic initiatives"@en .

<http://ots.local/thesaurus/apqc/1_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_3> ;
    skos:definition "Selecting relevant projects of strategic significance that create opportunities for the organization to realize its long-term objectives, on the basis of their suitability to the organization's constraints and reality. Select from the process Evaluate strategic initiatives [10058], based on their applicability and feasibility for the organization. Enlist senior management, especially strategy personnel."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.3.3" ;
    skos:prefLabel "Select strategic initiatives"@en .

<http://ots.local/thesaurus/apqc/3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_0> ;
    skos:definition "Making sense of the market and customers to identify the right opportunities to be capitalized, given the organization's competencies. Discern trends and shift in the market and customers. Identify the right market opportunities that fit closely with the organization's capabilities and strategy by gathering intelligence on various attributes of different market/customer segments."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.1" ;
    skos:prefLabel "Understand markets, customers, and capabilities"@en .

<http://ots.local/thesaurus/apqc/3_1_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_1_1> ;
    skos:definition "Carrying out research studies to understand the behavior of customers and the realities of the market. Undertake research to understand the market conditions as well as the characteristics, drives, and desires of prospective customers. Gather highly contextualized intelligence through primary and secondary research methods, with the objective of gaining insights over how to best seize a market opportunity. Consider assistance from professional research services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.1.1.1" ;
    skos:prefLabel "Conduct customer and market research"@en .

<http://ots.local/thesaurus/apqc/3_1_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_1_2> ;
    skos:definition "Confirming the practicability and reasonableness of the market opportunities that have been identified. Give substance to the real-time feasibility of the market opportunities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.1.2.4" ;
    skos:prefLabel "Validate opportunities"@en .

<http://ots.local/thesaurus/apqc/3_3_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3> ;
    skos:definition "Creating descriptions of products that are promotional and informative in content in order to initiate and increase sales. Marketing content consists of text, and optionally, images."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.9" ;
    skos:prefLabel "Manage product marketing material"@en .

<http://ots.local/thesaurus/apqc/3_5_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_2> ;
    skos:definition "Managing the corpus of data relating all customers acquired over time. Manage the storage, maintenance, access, revision, and usage of all data on customers. Ensure its security, and determine legitimate use cases that are beneficial to the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.2.5" ;
    skos:prefLabel "Manage customer master data"@en .

<http://ots.local/thesaurus/apqc/4_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_3> ;
    skos:definition "Perpetuating the production records by systematically documenting and using it to ensure the effective management of lots. Determine the lot numbering system and its use. (The lot number enables tracking of the constituent parts, as well as labor and equipment records involved in the manufacturing of a product. It enables manufacturers and to perform quality control checks, calculate expiration dates, and issue corrections of their production output.)"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.3.4" ;
    skos:prefLabel "Maintain production records and manage lot traceability"@en .

<http://ots.local/thesaurus/apqc/4_4_5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_5> ;
    skos:definition "Determining and scheduling the resources required to fulfill customer service requirements. Create a detailed schedule about the service orders and development of these service orders."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.5.2" ;
    skos:prefLabel "Identify and schedule resources to meet last mile delivery requirements"@en .

<http://ots.local/thesaurus/apqc/5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_0> ;
    skos:definition "Creating rules and regulations for service delivery to the customer. Establish a system to manage performance, delivery, and direction of service delivery. Engage with the customer for satisfaction feedback. Define goals, policies, processes, and workplace layout and infrastructure as a part of the service delivery strategy."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.1" ;
    skos:prefLabel "Establish service delivery governance and strategies"@en .

<http://ots.local/thesaurus/apqc/5_4_1_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_4_1> ;
    skos:definition "Identifying, selecting, and assigning resources required to deliver service to the customer. Ensure that all objectives are established and met, and the all rules of engagement have been identified and communicated."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.4.1.6" ;
    skos:prefLabel "Identify, select, and assign resources"@en .

<http://ots.local/thesaurus/apqc/6_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_2> ;
    skos:definition "Acquiring returns and identify if the returns are scraped or salvaged."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.2.4" ;
    skos:prefLabel "Process returns"@en .

<http://ots.local/thesaurus/apqc/6_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3> ;
    skos:definition "Managing the recovery of costs from suppliers for individual claims."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.3" ;
    skos:prefLabel "Manage supplier recovery"@en .

<http://ots.local/thesaurus/apqc/6_3_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3_4> ;
    skos:definition "Determining and scheduling the resources required to fulfill customer service requirements. Create a detailed schedule about the service orders and development of these service orders."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.4.2" ;
    skos:prefLabel "Identify and schedule resources to meet service requirements"@en .

<http://ots.local/thesaurus/apqc/7_5_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_5> ;
    skos:definition "Managing activities centered around delivering programs to support work/life balance for employees; developing family support systems; reviewing retention and motivation indicators; and reviewing compensation plans."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.5.3" ;
    skos:prefLabel "Manage employee assistance and retention"@en .

<http://ots.local/thesaurus/apqc/7_5_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_5_3> ;
    skos:definition "Designing programs that prompt proper balance between work (i.e., career and ambition) and lifestyle (i.e., health, pleasure, leisure, family, and spiritual development/meditation). Account for dependent care, flexible working arrangements, leaves of absence, on-the-job training, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.5.3.1" ;
    skos:prefLabel "Deliver programs to support work/life balance for employees"@en .

<http://ots.local/thesaurus/apqc/8_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1> ;
    skos:definition "Assessing the customer communities along with current IT operational capabilities and usage."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.1" ;
    skos:prefLabel "Understand IT customer needs"@en .

<http://ots.local/thesaurus/apqc/8_3_1_10> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_1> ;
    skos:definition "Developing activities to improve performance opportunities and lessen threats in IT. Evolve strategies and policies to attain organizational objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.1.10" ;
    skos:prefLabel "Create IT risk mitigation strategies and approaches"@en .

<http://ots.local/thesaurus/apqc/8_3_8_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_8> ;
    skos:definition "Create and manage the process to authenticate IT users from user directory based on the internal policies."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.8.4" ;
    skos:prefLabel "Manage IT user authentication mechanisms"@en .

<http://ots.local/thesaurus/apqc/8_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_4> ;
    skos:definition "Develop and implement strategies to plan and manage the flow of an information system's data from creation and initial storage to the time when it becomes obsolete and deleted."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.4.3" ;
    skos:prefLabel "Define and execute business information lifecycle planning and control"@en .

<http://ots.local/thesaurus/apqc/9_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_0> ;
    skos:definition "Managing accounts for large funds-invested projects. Manage and account for fixed assets projects (capital projects), which required significant capital investments over many years."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.4" ;
    skos:prefLabel "Manage fixed-asset project accounting"@en .

<http://ots.local/thesaurus/apqc/9_8_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_8> ;
    skos:definition "Performing planning, management, operations, and monitoring of internal control mechanism policies and procedures in order to manage internal controls."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.8.2" ;
    skos:prefLabel "Operate controls and monitor compliance with internal controls policies and procedures"@en .

<http://ots.local/thesaurus/apqc/9_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_0> ;
    skos:definition "Estimating the organization's periodic tax liabilities. Ensure that appropriate taxing authorities receive tax return filings and payments when due."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.9" ;
    skos:prefLabel "Manage taxes"@en .

<http://ots.local/thesaurus/apqc/10_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_1> ;
    skos:definition "Strategizing a long-term vision for managing properties. Prepare strategies and a long-term vision for managing purchased/retained properties."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.1.1" ;
    skos:prefLabel "Develop property strategy and long term vision"@en .

<http://ots.local/thesaurus/apqc/10_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_1> ;
    skos:definition "Managing all operational activities of the facility. Manage how each function/business unit works. Support the manufacturing facility to attain organizational goals."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.1.4" ;
    skos:prefLabel "Manage facilities operations"@en .

<http://ots.local/thesaurus/apqc/10_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_2> ;
    skos:definition "Producing and maintaining a planning schedule and a financial plan to purchase or manufacture assets. Determine the investment plan, monitor capital, and secure the necessary financing in order to realize completion of the program."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.2.1" ;
    skos:prefLabel "Manage capital program for assets"@en .

<http://ots.local/thesaurus/apqc/10_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_0> ;
    skos:definition "Preserving assets through the planning, managing, and performance of preventative, routine, and critical maintenance work."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.3" ;
    skos:prefLabel "Maintain assets"@en .

<http://ots.local/thesaurus/apqc/11_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_0> ;
    skos:definition "Creating requisite frameworks and coordinating all risk management activities for the entire organization and each function. Manage the enterprise risk by outlining the risk policies and procedures. Monitor and communicate all risk management activities. Encourage correspondence among the business units. Manage the risk of all business units and functions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.1" ;
    skos:prefLabel "Manage enterprise risk"@en .

<http://ots.local/thesaurus/apqc/12_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_0> ;
    skos:definition "Creating a strategic management responsibility for integrating finance, communication, marketing, and securities law compliance. Allow the most effective two-way communication among the organization, the financial community, and other constituencies. Enlist the investor relations function to provide market intelligence to corporate management."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.1" ;
    skos:prefLabel "Build investor relationships"@en .

<http://ots.local/thesaurus/apqc/12_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_2> ;
    skos:definition "Managing relations with organizations established and financed by businesses that operate in a specific industry. Participate in public relations actions such as lobbying and publishing, advertising, education, and political donations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.2.3" ;
    skos:prefLabel "Manage relations with trade or industry groups"@en .

<http://ots.local/thesaurus/apqc/13_10_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_10_1> ;
    skos:definition "Identifying, documenting, and communicating sustainability requirements. Closely examine all standards and matters of compliance relating to ESG. Determine protocols or standards to comply with, set by regulatory agencies or the organizations stakeholders."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.10.1.1" ;
    skos:prefLabel "Identify sustainability requirements"@en .

<http://ots.local/thesaurus/apqc/13_10_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_10> ;
    skos:definition "Managing sustainability across the organization. Provide training, support, reporting, and oversight to the distributed sustainability efforts across functional units and support services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.10.2" ;
    skos:prefLabel "Manage sustainability capability"@en .

<http://ots.local/thesaurus/apqc/13_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_1> ;
    skos:definition "Evaluating and handling the performance of business processes. Provide training to process owners. Support the execution of business processes. Measure and report the performance of the business processes."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.1.4" ;
    skos:prefLabel "Manage process performance"@en .

<http://ots.local/thesaurus/apqc/13_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_0> ;
    skos:definition "Managing investments, holdings, products, businesses, and brands, along with the related projects that together constitute a program."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2" ;
    skos:prefLabel "Manage portfolio, program, and project"@en .

<http://ots.local/thesaurus/apqc/13_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2> ;
    skos:definition "Managing the business portfolio of the organization, including investments, holdings, products, businesses, and brands. Establish a portfolio strategy. Define portfolio governance. Monitor and control the portfolio."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.1" ;
    skos:prefLabel "Manage portfolio"@en .

<http://ots.local/thesaurus/apqc/13_3_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_2> ;
    skos:definition "Examining the quality of organizational processes. Conduct tests. Collect information and data. Record the results of these tests. Determine the dispositions of the test results."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.2.1" ;
    skos:prefLabel "Test against quality plan"@en .

<http://ots.local/thesaurus/apqc/13_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4> ;
    skos:definition "Sustaining the impact of the change process in order to enact continual process improvement. Monitor the performance of re-engineered business processes. Identify best practices and potential issues. Effectuate remedial steps."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.4" ;
    skos:prefLabel "Sustain improvement"@en .

<http://ots.local/thesaurus/apqc/13_5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_5> ;
    skos:definition "Assessing the maturity of the existing initiatives in knowledge management, and evaluating existing KM approaches. Identify the gaps and needs in order to enhance the existing KM approaches. Develop and implement new KM approaches."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.5.2" ;
    skos:prefLabel "Assess KM capabilities"@en .

<http://ots.local/thesaurus/apqc/13_5_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_5> ;
    skos:definition "Developing resources for improved knowledge management and knowledge engineering."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.5.4" ;
    skos:prefLabel "Evolve and sustain KM capabilities"@en .

<http://ots.local/thesaurus/apqc/13_6_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6> ;
    skos:definition "Developing and managing taxonomies, ontologies, and related semantic structures to classify, enrich, and relate enterprise content and knowledge assets, supporting consistent interpretation, discoverability, reuse, and advanced capabilities such as automated classification and semantic processing."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.2" ;
    skos:prefLabel "Develop and manage taxonomies"@en .

<http://ots.local/thesaurus/apqc/13_6_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6> ;
    skos:definition "Delivering approved content to intended audiences through appropriate channels, repositories, or platforms in accordance with defined standards and controls."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.6" ;
    skos:prefLabel "Deliver approved content"@en .

<http://ots.local/thesaurus/apqc/13_6_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6> ;
    skos:definition "Controlling the use, evaluation, retention, and disposition of delivered content to ensure continued relevance, compliance, and value over time. Includes monitoring content quality and semantic coherence."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.7" ;
    skos:prefLabel "Control delivered content"@en .

<http://ots.local/thesaurus/apqc/13_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_0> ;
    skos:definition "Defining and managing measurement and benchmarking. Measure and benchmark the performance of internal processes, as well as the organization as a whole."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.7" ;
    skos:prefLabel "Measure and benchmark"@en .

<http://ots.local/thesaurus/apqc/13_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_0> ;
    skos:definition "Determining the impacts of environmental health and safety. Create and implement the EHS program. Train and educate employees of the EHS function. Oversee and manage the EHS program."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.9" ;
    skos:prefLabel "Manage Environmental Health and Safety (EHS)"@en .

<http://ots.local/thesaurus/apqc/1_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_1> ;
    skos:definition "Examining the market to identify customer required solutions. Assess the relevant market(s) to determine the products/services that are needed or wanted by customers. Carry out quantitative and qualitative analyses to capture and investigate products/services. Employ creative techniques that allow for a closer appreciation of the customer, and design relevant solutions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1.2" ;
    skos:prefLabel "Survey market and determine customer needs and wants"@en .

<http://ots.local/thesaurus/apqc/1_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_1> ;
    skos:definition "Establishing the organization's long-term vision as a strategic positioning and engagement of stakeholders. Institute the vision by creating strategic orientations of all stakeholders. Understand the strategy development frameworks in this context."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1.4" ;
    skos:prefLabel "Establish strategic vision"@en .

<http://ots.local/thesaurus/apqc/1_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_1> ;
    skos:definition "Examining the scope and contingencies for restructuring based on market situation and internal realities. Map the market forces over which any and all probabilities can be probed for utility and viability. Once the restructuring options have been analyzed and the due-diligence performed, execute the deal. Consider seeking professional services for assistance in formalizing these opportunities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1.5" ;
    skos:prefLabel "Conduct organization restructuring opportunities"@en .

<http://ots.local/thesaurus/apqc/1_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2> ;
    skos:definition "Establishing an overarching, compact statement that concisely underscores the mission of the organization. Define and communicate a clear and succinct mission statement, which encapsulates how the organization aims to proceed in order to Establish a strategic vision [10020]. Solicit critical inputs from senior management and strategy executives, and collaborate with marketing or personnel from allied functions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.1" ;
    skos:prefLabel "Develop overall mission statement"@en .

<http://ots.local/thesaurus/apqc/1_2_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2> ;
    skos:definition "Developing overall goals for the organization that help in accomplishing its mission. Formulate organization-wide targets in the near to middle term, which will accumulate and propel the organization to realize its long-term objectives, as outlined in Develop an overall mission statement [10037]. Enlist business unit heads or equivalent personnel, in close collaboration with senior management executives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.6" ;
    skos:prefLabel "Develop and set organizational objectives"@en .

<http://ots.local/thesaurus/apqc/1_2_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2> ;
    skos:definition "Charting a strategic course for business units in order to leverage opportunities, sidestep hurdles, and create synergies among each other. Create strategic road maps for the organization's units--in light of their individual resources and requirements, as well as their relationships with other business units--to achieve organizational goals."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.7" ;
    skos:prefLabel "Formulate business unit strategies"@en .

<http://ots.local/thesaurus/apqc/1_2_8_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_8> ;
    skos:definition "Measuring customer feedback in regard to product and services effectiveness based on overall satisfaction. The data to be analyzed is collected through surveys, customer responses, and feedbacks based on the delivered products/services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.8.1" ;
    skos:prefLabel "Assess customer experience"@en .

<http://ots.local/thesaurus/apqc/1_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_3> ;
    skos:definition "Developing strategic projects that help fulfill long-term goals. Develop time-bound projects that are discretionary in nature and lie beyond the scope of the organization's routine operations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.3.1" ;
    skos:prefLabel "Develop strategic initiatives"@en .

<http://ots.local/thesaurus/apqc/1_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_3> ;
    skos:definition "Devising measures to examine strategic projects. Formulate evaluation criteria to assess the strategic initiatives for the level of impact."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.3.4" ;
    skos:prefLabel "Establish high-level measures"@en .

<http://ots.local/thesaurus/apqc/1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_0> ;
    skos:definition "Establishing how an organization creates, delivers and captures value or makes profit. Identify the products or services that a business will sell, its target market, anticipated expenses, and other core aspects of its modus operandi. Revise the plan as required to reflect changing circumstances."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.4" ;
    skos:prefLabel "Develop and maintain business models"@en .

<http://ots.local/thesaurus/apqc/2_1_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_3> ;
    skos:definition "Aligning regulatory activities related to managing industry requirements. Train employees on regulatory requirements. Records for the appropriate regulatory agencies must be maintained and the new product process must be approved by the appropriate regulatory body before it is published to the organization. The submission lifecycle - i.e. creation, review, and approval of the submission and its components must be managed in a collaborative fashion."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.3.5" ;
    skos:prefLabel "Manage regulatory requirements"@en .

<http://ots.local/thesaurus/apqc/2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_0> ;
    skos:definition "Identifying and describing new product or service thoughts based on organizational objectives/targets."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.2" ;
    skos:prefLabel "Generate and define new product/service ideas"@en .

<http://ots.local/thesaurus/apqc/2_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_2> ;
    skos:definition "Coordinating R&D activity to identify new technologies to integrate into the revamped portfolio of products/services. This is inclusive of all forms of new and evolving technology such as artificial intelligence (AI). Conduct early-stage R&D activity to close gaps between existing solution offerings and changing market expectations. Triangulate appropriate technologies that can support the development of a revised product/service portfolio."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.2.1" ;
    skos:prefLabel "Perform discovery research"@en .

<http://ots.local/thesaurus/apqc/2_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_2> ;
    skos:definition "Encompassing the identification and capture of new product/service requirements or potential improvements to current products/services. Collaborating with members of the supply chain to ensure the feasibility of what is being defined in the requirements. For example, a product with manufacturing requirements that supply chain cannot currently fulfill requires a corporate decision to either upgrade manufacturing capabilities or abandon the new product. Enterprise-level effects and needs must be considered. Depending on the nature of the final product or service, these requirements are often defined as a set of abilities, such as availability or reliability, that influence product development decisions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.2.3" ;
    skos:prefLabel "Define product/service development requirements"@en .

<http://ots.local/thesaurus/apqc/3_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2> ;
    skos:definition "Refining the attributes of organizational offerings to define their value proposition for the customer. Clearly define the suite of offerings in terms of the value delivered, from the perspective of what the customer desires. Validate the benefits delivered to the customers against target market segments, using techniques such as minimum viable product. Position brands for the respective products/services, in line with their unique value proposition and aligned with customers needs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.1" ;
    skos:prefLabel "Define offering and customer value proposition"@en .

<http://ots.local/thesaurus/apqc/3_2_4_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_4> ;
    skos:definition "Coordinating marketing and distribution efforts across different channels that integrate well with each other, are in conformance with company values, visual identity and branding, and offer uniform customer service experience that drives customer loyalty and repeat business."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.4.7" ;
    skos:prefLabel "Orchestrate seamless customer experience across supported channels"@en .

<http://ots.local/thesaurus/apqc/3_5_5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_5> ;
    skos:definition "Imparting guidance and instruction to sales partners/alliances concerning products/services. Distribute literature about the organization's products/services. Conduct workshops. Disseminate useful media content to engage and enlighten partners. Create communities through group engagements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.5.1" ;
    skos:prefLabel "Provide sales and product/service training to sales partners/alliances"@en .

<http://ots.local/thesaurus/apqc/4_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1> ;
    skos:definition "Taking care of the master production plan. The master production includes creation and implementation of the site-level production plan, as well as management of the inventory that is currently in the production process."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.4" ;
    skos:prefLabel "Create and manage master production schedule"@en .

<http://ots.local/thesaurus/apqc/4_1_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1> ;
    skos:definition "Revisiting and refurbishing the policies for planning the distribution process. Asses the distribution strategies, including how the products are to be made available and sent to different distributors. Set guidelines regarding relationships between the sources and the distribution centers."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.7" ;
    skos:prefLabel "Review distribution planning policies"@en .

<http://ots.local/thesaurus/apqc/4_1_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1> ;
    skos:definition "Developing standards and procedures for maintaining the quality of products/services. Establish desired quality targets. Create standardized procedures for the quality. Ensure quality specifications are effectively communicated."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.8" ;
    skos:prefLabel "Develop quality standards and procedures"@en .

<http://ots.local/thesaurus/apqc/4_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_2> ;
    skos:definition "Defining sourcing strategies and plans for categories of materials or services to optimize cost, supply continuity, value, and alignment with organizational requirements and market conditions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.2.2" ;
    skos:prefLabel "Develop category plan"@en .

<http://ots.local/thesaurus/apqc/4_4_5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_5> ;
    skos:definition "Acquiring or soliciting information about specific service requirements for individual customers through the customer service function. Obtain information about customer specific requests, process these requests, and create customer profiles to generate a service order."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.5.1" ;
    skos:prefLabel "Confirm specific last mile delivery service requirements for individual customer"@en .

<http://ots.local/thesaurus/apqc/4_4_5_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_5> ;
    skos:definition "Dispatching resources for managing and fulfilling daily service requirements. Manage the progress of order fulfillment. Complete order blocks."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.5.3" ;
    skos:prefLabel "Provide last mile delivery service to specific customers"@en .

<http://ots.local/thesaurus/apqc/5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_0> ;
    skos:definition "Understanding the demands on resources and creating a plan to enable the delivery of services via those resources."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.2" ;
    skos:prefLabel "Manage service delivery resources"@en .

<http://ots.local/thesaurus/apqc/5_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_0> ;
    skos:definition "Rendering service to the customer by initiating, executing, and completing tasks associated with service delivery."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.4" ;
    skos:prefLabel "Deliver service to customer"@en .

<http://ots.local/thesaurus/apqc/6_3_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3_4> ;
    skos:definition "Acquiring or soliciting information about specific service requirements for individual customers through the customer service function. Obtain information about customer specific requests, process these requests, and create customer profiles to generate a service order."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.4.1" ;
    skos:prefLabel "Confirm specific service requirements for individual customer"@en .

<http://ots.local/thesaurus/apqc/6_3_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3_4> ;
    skos:definition "Dispatching resources for managing and fulfilling daily service requirements. Manage the progress of order fulfillment. Complete order blocks."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.4.3" ;
    skos:prefLabel "Provide service to specific customers"@en .

<http://ots.local/thesaurus/apqc/6_5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_5> ;
    skos:definition "Calculating satisfaction levels of customers by effectively evaluating the process of handling requests/inquiries of customers. Effectively calculate the performance of customer-requests/inquiries handling and resolution. Obtain information regarding requests/inquiries handling and resolution through customer feedback. Use it to explore new ideas and opportunities for enhanced customer requests/inquiries handling and resolution process."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.5.1" ;
    skos:prefLabel "Measure customer satisfaction with customer problems, requests, and inquiries handling"@en .

<http://ots.local/thesaurus/apqc/6_5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_5> ;
    skos:definition "Measuring the satisfaction level of customers as pertains to how their complaints are handled and resolved. This process element requires the organization to estimate the customers level of fulfillment with the process reconciling their complaints and towards the objective of ensuring customer retention. The feedback received can be used to develop concepts for new opportunities to boost the level of customer satisfaction."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.5.2" ;
    skos:prefLabel "Measure customer satisfaction with customer- complaint handling and resolution"@en .

<http://ots.local/thesaurus/apqc/7_1_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_2> ;
    skos:definition "Designing a plan that specifies the combination of wages, salaries, and benefits the employees receive in exchange for work. Define the total amount of compensation, in addition to the manner in which the compensation is paid and the purposes for which employees can receive bonuses, salary increases, incentives and non-monetary rewards."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.2.2" ;
    skos:prefLabel "Develop total compensation and rewards strategy"@en .

<http://ots.local/thesaurus/apqc/7_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_2> ;
    skos:definition "Creating and making job offers to the selected candidates. Fairly negotiate the job offers. Agree on terms with the candidate to complete the hiring process."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.2.4" ;
    skos:prefLabel "Manage new hire/re-hire"@en .

<http://ots.local/thesaurus/apqc/7_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_3> ;
    skos:definition "Creating and maintaining various employee on-boarding programs typically known as induction programs in order to ensure that the new employees are effectively introduced to the organization and its existing employees. Examine and evaluate the performance of these induction programs. Execute these programs on the ground level."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.3.1" ;
    skos:prefLabel "Manage employee onboarding"@en .

<http://ots.local/thesaurus/apqc/7_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_0> ;
    skos:definition "Managing employee mobility and retirement. Manage the process of employee promotion and demotion. Administer separation, retirement, and leaves of absence. Outplace employees. Deploy personnel. Relocate employees in order to manage assignments."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.6" ;
    skos:prefLabel "Redeploy and retire employees"@en .

<http://ots.local/thesaurus/apqc/7_7_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_7> ;
    skos:definition "Transform, develop, and communicate workforce data into analytics in support of organizational requirements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.7.8" ;
    skos:prefLabel "Implement workforce analytics"@en .

<http://ots.local/thesaurus/apqc/7_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_0> ;
    skos:definition "Creating an effective plan that initiates and promotes communication and engagement among the employees and between employees and management."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.8" ;
    skos:prefLabel "Manage employee communication"@en .

<http://ots.local/thesaurus/apqc/8_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3> ;
    skos:definition "Planning and managing the organization’s ability to recover from exposure to internal and external threats, with a focus on IT and cybersecurity. Ensure that continuity plans address cyber-specific scenarios, including ransomware attacks and other evolving threats, while maintaining uninterrupted operations of critical IT and OT services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.4" ;
    skos:prefLabel "Plan and manage IT continuity"@en .

<http://ots.local/thesaurus/apqc/8_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_4> ;
    skos:definition "Create an organization-wide strategy for the IT function by combining skills, technologies, applications, and processes in order to attain organizations objectives. This is inclusive of all forms of new and evolving technology such as artificial intelligence (AI)."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.4.1" ;
    skos:prefLabel "Define business information and analytics strategy"@en .

<http://ots.local/thesaurus/apqc/9_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_0> ;
    skos:definition "Handling reporting time, managing pay, and processing taxes from salaries. Pay employees. Withhold taxes. Confirm the correct funds are paid to the correct government agency."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.5" ;
    skos:prefLabel "Process payroll"@en .

<http://ots.local/thesaurus/apqc/9_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_0> ;
    skos:definition "Handling bills and reimbursements to be made. Make payments for goods or services taken or used on behalf of the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.6" ;
    skos:prefLabel "Process accounts payable and expense reimbursements"@en .

<http://ots.local/thesaurus/apqc/9_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_0> ;
    skos:definition "Administering internal controls. This process requires the organization to manage entity's board of trustees, management, and other personnel in order to offer judicious assurance about the achievement of effectiveness, proficiency of operations, and reliability of financial reporting."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.8" ;
    skos:prefLabel "Manage internal controls"@en .

<http://ots.local/thesaurus/apqc/9_9_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_9> ;
    skos:definition "Setting targets for periodic tax liabilities. Assess the tax impact of various activities such as the acquisition or disposal of fixed assets or a deliberate change in number of employee."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.9.1" ;
    skos:prefLabel "Develop tax strategy and plan"@en .

<http://ots.local/thesaurus/apqc/10_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_0> ;
    skos:definition "Planning, acquiring, and managing facilities, workspaces, and supporting assets. Acquire, configure, and manage facilities and workspaces, to include supporting equipment and materials."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.1" ;
    skos:prefLabel "Plan and acquire assets"@en .

<http://ots.local/thesaurus/apqc/10_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_0> ;
    skos:definition "Designing and constructing assets such as machines, tools, factories, etc. Manage steps to acquire assets including managing capital, as well as planning, scheduling, and overseeing acquisition/construction."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.2" ;
    skos:prefLabel "Design and construct assets"@en .

<http://ots.local/thesaurus/apqc/10_4_10> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_4> ;
    skos:definition "Planning and performing abandonment activities. Whether facilities  or equipment, ensure assets to be abandoned are safe, secure, and meet all legal, regulatory, and social/environmental responsibilities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.4.10" ;
    skos:prefLabel "Perform abandonment"@en .

<http://ots.local/thesaurus/apqc/11_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_2> ;
    skos:definition "Developing a set of procedures detailing an organization's progress in complying with established guidelines, provisions, and legislation."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.2.1" ;
    skos:prefLabel "Establish compliance framework and policies"@en .

<http://ots.local/thesaurus/apqc/12_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_0> ;
    skos:definition "Creating and maintaining relationships with government and industry representatives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.2" ;
    skos:prefLabel "Manage government and industry relationships"@en .

<http://ots.local/thesaurus/apqc/12_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_2> ;
    skos:definition "Managing relations with quasi-governmental organizations, corporations, businesses, or any other agency that is treated by national laws and principles to be under the supervision of the government but also distinct and self-directed from the government."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.2.2" ;
    skos:prefLabel "Manage relations with quasi-government bodies"@en .

<http://ots.local/thesaurus/apqc/12_4_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_4> ;
    skos:definition "Safeguarding the intellectual property of the organization. This process requires the organization to protect a wide variety of intellectual property created by it. This includes leveraging artificial intelligence(AI) to identify potential infringement of intellectual property and making sure employees are adhering to company policies around use of artificial intelligence(AI). It involves creating and managing non-disclosure agreements (NDAs), following up on current developments in the areas where the organization holds patents, tracking the use of the organization's copyrighted material, creating and upholding licensing terms, and administering policies for safeguarding intellectual property."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.4.6" ;
    skos:prefLabel "Protect intellectual property"@en .

<http://ots.local/thesaurus/apqc/13_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_1> ;
    skos:definition "Defining and managing the organization's approach to governing business process management. Establish and manage tools to support the governance process. Assign ownership for all business processes. Perform activities to administer the governing process."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.1.1" ;
    skos:prefLabel "Establish and maintain process management governance"@en .

<http://ots.local/thesaurus/apqc/13_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_1> ;
    skos:definition "Identifying, selecting, and managing improvements. Based on the type and scope of the improvement, determination of the appropriate improvement methodology (e.g., Lean, Six Sigma, etc.) should guide the effort. This includes continuous improvement, process redesign, process reengineering, and application of the organizations approaches for Manage projects."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.1.5" ;
    skos:prefLabel "Improve processes"@en .

<http://ots.local/thesaurus/apqc/13_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2> ;
    skos:definition "Establishing, implementing, and managing business programs. Successfully handle related projects that together constitute a program. Establish the program structure and approach. Coordinate with stakeholders and partners. Execute the program. Assess and report the performance of the program. Coordinate and prioritize resources across projects. Manage links between the projects and the overall costs and risks of the program."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.2" ;
    skos:prefLabel "Manage programs"@en .

<http://ots.local/thesaurus/apqc/13_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_0> ;
    skos:definition "Managing organizational attributes that are closely associated with the quality of output. Determine the quality requirements. Evaluate the correspondence between the quality performance and requirements. Manage non-conformance activities. Ensure implementation and maintenance of the enterprise quality management system."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3" ;
    skos:prefLabel "Manage enterprise quality"@en .

<http://ots.local/thesaurus/apqc/13_3_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_1> ;
    skos:definition "Developing controls for managing the quality of enterprise. Define the process steps for quality controls and the sampling plan. Identify the tools and methods to measure quality. Define the competencies required."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.1.3" ;
    skos:prefLabel "Develop quality controls"@en .

<http://ots.local/thesaurus/apqc/13_3_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_2> ;
    skos:definition "Assessing the significance of the sample. Summarize the results of the test. Recommend improvement actions. Decide what steps to take next."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.2.2" ;
    skos:prefLabel "Assess results of tests"@en .

<http://ots.local/thesaurus/apqc/13_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_0> ;
    skos:definition "Planning, designing, and implementing the change. Ensure improvement in the change process."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4" ;
    skos:prefLabel "Manage change"@en .

<http://ots.local/thesaurus/apqc/13_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_0> ;
    skos:definition "Creating and administering the capability of the organization's knowledge management function. Develop a strategy for knowledge management. Assess capabilities of the knowledge management function."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.5" ;
    skos:prefLabel "Develop and manage enterprise-wide knowledge management (KM) capability"@en .

<http://ots.local/thesaurus/apqc/13_9_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_9> ;
    skos:definition "Identify the requirements for regulation and shareholders. Assess future risks and opportunities. Develop a policy for the EHS program. Record and manage EHS program events."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.9.2" ;
    skos:prefLabel "Develop EHS program"@en .

<http://ots.local/thesaurus/apqc/1_1_5_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_1_5> ;
    skos:definition "Examining various options shortlisted for assimilating new entities into the organization or dissociating from it. Undertake a piecemeal and comprehensive consideration of each option identified for acquisition, merger, de-merger, and divestment. Consider intangible and non-material aspects of the entities involved and synergic aspects. Consider the assistance of specialist professional services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1.5.3" ;
    skos:prefLabel "Analyze deal options"@en .

<http://ots.local/thesaurus/apqc/1_2_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2> ;
    skos:definition "Defining a roadmap to meet customer expectations while considering how it will affect the business."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.8" ;
    skos:prefLabel "Develop customer experience strategy"@en .

<http://ots.local/thesaurus/apqc/1_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_4> ;
    skos:definition "Creating an economic model that describes the goals of an organization and the business processes needed to achieve those goals. This involves information gathering, securing necessary approvals and authorizations, integrating with preexisting models, including the general business concept [10002] and business strategy [10015], and formally accepting the model as the basis for organization's day-to-day operations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.4.1" ;
    skos:prefLabel "Develop business models"@en .

<http://ots.local/thesaurus/apqc/1_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_4> ;
    skos:definition "Revising and updating business models to reflect the changes in the marketed services, product inventory, market behavior, available resources or accrued expenses. Determine how and when to modify the accepted business model in response to incoming feedback."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.4.2" ;
    skos:prefLabel "Maintain business models"@en .

<http://ots.local/thesaurus/apqc/2_0> a skos:Concept ;
    skos:definition "Detailing practices and procedures related to the concept of developing and managing products and services. These are reflected in the process groups Govern and manage product/service development program [19696], Generate and define new product/service ideas [19698], and Develop products and services [10062]."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.0" ;
    skos:prefLabel "Develop and Manage Products and Services"@en .

<http://ots.local/thesaurus/apqc/2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_0> ;
    skos:definition "Supervising the complete product/service program from innovation until its commercial success. Meeting the customer demand and expectations. Conduct further development and innovation pertaining to business goals."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1" ;
    skos:prefLabel "Govern and manage product/service development program"@en .

<http://ots.local/thesaurus/apqc/2_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3> ;
    skos:definition "Expanding on the marketplace analysis that took place earlier in the product development lifecycle by testing the market against offerings. The results from this in-depth analysis will help the organization finalize product/service characteristics and technical requirements and also identify any needed changes in the manufacturing and delivery processes that support market delivery. To prepare a detailed market study that accounts for any changes in the global environment, the organization may want to conduct a series of interviews, workshops, and focus groups with potential and existing customers."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.2" ;
    skos:prefLabel "Test market for new or revised products and services"@en .

<http://ots.local/thesaurus/apqc/3_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_1> ;
    skos:definition "Appraising market opportunities by quantifying and subjecting them to prioritization, as well as validation tests. Closely examine the market opportunities that have been identified by Perform customer and market intelligence analysis [10106]. Triangulate those opportunities to capitalize by finding a fit between identified opportunities and the composite of organizational capabilities and business strategy."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.1.2" ;
    skos:prefLabel "Evaluate and prioritize market opportunities"@en .

<http://ots.local/thesaurus/apqc/3_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2> ;
    skos:definition "Defining and overseeing the positioning, value proposition, and governance of brands to ensure a consistent identity, clear differentiation, and alignment with overall marketing direction and business objectives across markets and offerings."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.2" ;
    skos:prefLabel "Develop and manage brands"@en .

<http://ots.local/thesaurus/apqc/3_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2> ;
    skos:definition "Creating a pricing strategy and mechanism that aligns with the benefits of the products/services, as perceived by customers. Chart a strategic course and a methodology that can guide the pricing of products/services. Draw heavily from the customer value proposition, and balance the expectations of different divisions inside the organization, while delivering the maximum ROI."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.3" ;
    skos:prefLabel "Define pricing strategy"@en .

<http://ots.local/thesaurus/apqc/3_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3> ;
    skos:definition "Creating a budget for the organization's marketing efforts, in line with the business-wide strategic outlook. Create a plan to distribute resources for achieving the marketing strategy in light of the overall business strategy. Make cost assumptions; calculate the estimated total revenue from the marketing activities against the costs/expenses of these activities. Forecast the return on investment. Attribute costs to the appropriate marketing activities such as promotional campaigns, advertising, marketing communications, PR campaigns, personnel, and office space. Enlist the financial and marketing functions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.2" ;
    skos:prefLabel "Establish marketing budgets"@en .

<http://ots.local/thesaurus/apqc/3_3_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3> ;
    skos:definition "Creating, executing, and administering a strategic road map for packaging products/services. Determine how to package products/services into finished offerings that can be directly marketed to prospective customers. Consider physicality, perishability, and shelf-life. Develop a strategy for packaging products/services. Test alternatives. Collect feedback. Refine the option chosen for execution. Have marketing, product development, and supply chain functions work together to develop sound packaging."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.7" ;
    skos:prefLabel "Develop and manage packaging strategy"@en .

<http://ots.local/thesaurus/apqc/3_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_4> ;
    skos:definition "Developing a sales forecast for the organization's portfolio of offerings, bearing in mind the effect of promotional events, and fine-tuning these in the context of the new forecast. Estimate the future demand for the organization's products/services by analyzing historical information and any promotional activity."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.4.1" ;
    skos:prefLabel "Develop sales forecast"@en .

<http://ots.local/thesaurus/apqc/3_5_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5> ;
    skos:definition "Managing the organization's partners and alliances, with the objective of maximizing revenue. Train partners regarding the organization's portfolio of products/services. Craft sales forecasts. Examine their performance. Manage all data held by the organization on these partners."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.5" ;
    skos:prefLabel "Manage sales partners and alliances"@en .

<http://ots.local/thesaurus/apqc/4_1_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1> ;
    skos:definition "Instituting the constraints for planning of distribution process. Create a plan that specifies every element in the distribution process from the blueprint of the distribution centers to how and when the inventory would reach the distribution centers."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.6" ;
    skos:prefLabel "Establish distribution planning constraints"@en .

<http://ots.local/thesaurus/apqc/4_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_2> ;
    skos:definition "Evaluating supplier options to select the most effective and efficient suppliers. Validate selected suppliers. Establish and manage supplier contracts."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.2.3" ;
    skos:prefLabel "Select suppliers and develop/maintain contracts"@en .

<http://ots.local/thesaurus/apqc/4_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_2> ;
    skos:definition "Collecting and analyzing new information in order to track and rate suppliers and build relationships."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.2.5" ;
    skos:prefLabel "Manage suppliers"@en .

<http://ots.local/thesaurus/apqc/4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_0> ;
    skos:definition "Processing and delivering the finished goods manufactured by the organization. Schedule the production of products. Execute the product production activities. Perform tests to oversee and ensure quality of production. Maintain records of the production process. Track lots."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.3" ;
    skos:prefLabel "Produce/Assemble/Test product"@en .

<http://ots.local/thesaurus/apqc/4_3_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_3_2> ;
    skos:definition "Integrating different resources in the production process: material, personnel, equipment, robotics, etc. Includes automating and controlling the plant, performing advanced process control and real-time optimization. This activity also includes managing plant alarms and alerts."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.3.2.5" ;
    skos:prefLabel "Monitor and optimize production process"@en .

<http://ots.local/thesaurus/apqc/4_4_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_2> ;
    skos:definition "Determining if a returned product can be salvaged or repaired. Salvage or repair is dependent upon the product, the condition of the product, or the availability of a like item."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.2.5" ;
    skos:prefLabel "Manage disposition of returned products"@en .

<http://ots.local/thesaurus/apqc/4_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4> ;
    skos:definition "Creating a plan that specifies the schedule and system for transportation and delivery of the outbound products, as well as tracking the performance of the carrier delivery system. Conduct vehicle management and processing of all carrier-related documents."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.4" ;
    skos:prefLabel "Operate outbound transportation"@en .

<http://ots.local/thesaurus/apqc/4_4_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4> ;
    skos:definition "Validating specific service requirements for individual customers. Determine and schedule resource to fulfill these requirements. Provide service to specific individual customers. Ensure the quality of service delivery."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.5" ;
    skos:prefLabel "Deliver last mile delivery services"@en .

<http://ots.local/thesaurus/apqc/4_4_5_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_5> ;
    skos:definition "Guaranteeing the quality of service provided to customers. Identify the successful and unsuccessful orders along with the service failures. Collect customer feedback. Process the feedback to ensure the quality of service in the future."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.5.4" ;
    skos:prefLabel "Ensure quality of last mile delivery"@en .

<http://ots.local/thesaurus/apqc/5_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_1> ;
    skos:definition "Establishing service delivery governance through a system that manages performance, development, and direction. Allow for customer feedback on delivery satisfaction."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.1.1" ;
    skos:prefLabel "Establish service delivery governance"@en .

<http://ots.local/thesaurus/apqc/5_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_0> ;
    skos:definition "Managing and operating the systems, resources, and processes used to deliver services to customers, including planning, startup, ongoing operations, and service assurance."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.3" ;
    skos:prefLabel "Manage and Operate Service Delivery System"@en .

<http://ots.local/thesaurus/apqc/6_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_2> ;
    skos:definition "Creating and administering the workforce deployed for the customer service process. Forecast the customer workforce needs to correctly schedule the workforce. Track the utility of the workforce deployed. Examine the interactions between the customer and customer service representatives to achieve high quality."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.2.1" ;
    skos:prefLabel "Plan and manage customer service workforce"@en .

<http://ots.local/thesaurus/apqc/6_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_0> ;
    skos:definition "Assigning post-sales policies and paying claims on purchased products.  This is a process that is an administrative function focused on creating rules (claim codes). This group ensures that claims are valid and are processed quickly.  As well as to quickly determine responsibility for claim settlement."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3" ;
    skos:prefLabel "Service products after sales"@en .

<http://ots.local/thesaurus/apqc/6_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3> ;
    skos:definition "Validating specific service requirements for individual customers. Determine and schedule resource to fulfill these requirements. Provide service to specific individual customers. Ensure the quality of service delivery."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.4" ;
    skos:prefLabel "Service products"@en .

<http://ots.local/thesaurus/apqc/6_3_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3_4> ;
    skos:definition "Guaranteeing the quality of service provided to customers. Identify the successful and unsuccessful orders along with the service failures. Collect customer feedback. Process the feedback to ensure the quality of service in the future."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.4.4" ;
    skos:prefLabel "Ensure quality of service"@en .

<http://ots.local/thesaurus/apqc/7_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_0> ;
    skos:definition "Creating strategies for the HR function. Create and implement strategies for managing the work force. Supervise and enhance the strategies, plans, and policies supporting the HR function. Developing models for managing competency levels of the HR of the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1" ;
    skos:prefLabel "Develop and manage human resources (HR) planning, policies, and strategies"@en .

<http://ots.local/thesaurus/apqc/7_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1> ;
    skos:definition "Supervising the HR and workforce strategy, plans, and policies in order to refurbish them whenever needed. Determine the performance of HR and workforce plans and policies by measuring the objective achievement rate and its contribution to the overall business strategy. Ensure that information about these plans and strategies is effectively communicated to various stakeholders. Incorporate any suggestions by these stakeholders when revising HR and workforce plans and policies."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.3" ;
    skos:prefLabel "Monitor and update HR strategies, plans, and policies"@en .

<http://ots.local/thesaurus/apqc/7_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_2> ;
    skos:definition "Evaluating and selecting potential employees through interviews, tests, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.2.3" ;
    skos:prefLabel "Screen and select candidates"@en .

<http://ots.local/thesaurus/apqc/7_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_2> ;
    skos:definition "Creating and maintaining a system for managing the information of applicants. Create records for all candidates who apply. Maintain and track information through the use applicant-tracking systems."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.2.5" ;
    skos:prefLabel "Manage applicant information"@en .

<http://ots.local/thesaurus/apqc/7_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_0> ;
    skos:definition "Assisting employees in developing their capabilities, and providing them counseling services. Handle the orientation and deployment of the employees. Administer the performance of employees. Administer the development and enhancement of the employees. Provide training and development programs for employees."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.3" ;
    skos:prefLabel "Manage employee onboarding, training, and development"@en .

<http://ots.local/thesaurus/apqc/7_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_3> ;
    skos:definition "Defining individual performance objectives. Review performance in order to provide appraisals. Evaluate the efficiency and effectiveness of the current performance program. Update it regularly."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.3.2" ;
    skos:prefLabel "Manage employee performance"@en .

<http://ots.local/thesaurus/apqc/7_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_3> ;
    skos:definition "Establishing employee development guidelines. Lay out career paths and plans for individual employees. Manage the development of their skills to enhance their skills, ability, and knowledge."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.3.3" ;
    skos:prefLabel "Manage employee career development"@en .

<http://ots.local/thesaurus/apqc/7_3_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_3_3> ;
    skos:definition "Establishing plans to ensure continuity in critical roles by identifying potential successors and preparing them for future leadership or specialist positions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.3.3.4" ;
    skos:prefLabel "Establish succession plans"@en .

<http://ots.local/thesaurus/apqc/7_3_4_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_3_4> ;
    skos:definition "Managing identified training programs for employees. Engage with industries to provide certifications, administer certification test, and maintain active certification."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.3.4.6" ;
    skos:prefLabel "Manage examinations and certifications"@en .

<http://ots.local/thesaurus/apqc/7_5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_5> ;
    skos:definition "Managing and ensuring benefits enrollment by the employees. Process any benefit claims made by the employees. Balance the estimated amount and entitled amount of benefits."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.5.2" ;
    skos:prefLabel "Manage and administer benefits"@en .

<http://ots.local/thesaurus/apqc/7_6_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_6> ;
    skos:definition "Managing the process of employee separation, including leaves of absence, resignations, discharges, and layoffs. Inform the employee of the termination. Complete paperwork for continuation of benefits. Enter employment status change into system."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.6.2" ;
    skos:prefLabel "Manage separation"@en .

<http://ots.local/thesaurus/apqc/8_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1> ;
    skos:definition "Identifying changing needs of staff dependent on information technology based on continuous improvement to deliver results according to organizational goals. This is inclusive of all forms of new and evolving technology such as artificial intelligence (AI)."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.2" ;
    skos:prefLabel "Identify IT customer transformation needs"@en .

<http://ots.local/thesaurus/apqc/8_1_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1> ;
    skos:definition "Proactively manage IT service levels against IT customer requirements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.7" ;
    skos:prefLabel "Analyze service performance"@en .

<http://ots.local/thesaurus/apqc/8_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2> ;
    skos:definition "Outlining and maintaining the organization's IT architecture. Establish the IT architecture definition and framework. Ensure the relevance of IT. Create and confirm the approach for IT maintenance. Create rules and regulations to guide IT architecture. Authenticate and finalize all IT related research and innovation that takes place within the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.3" ;
    skos:prefLabel "Define and maintain enterprise architecture"@en .

<http://ots.local/thesaurus/apqc/8_2_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2> ;
    skos:definition "Creating and establishing the value portfolio. Defining, analyzing, and examining the value of projects, investments, and activities of the IT function."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.6" ;
    skos:prefLabel "Manage IT value portfolio"@en .

<http://ots.local/thesaurus/apqc/8_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3> ;
    skos:definition "Developing resilience strategies across IT and cybersecurity functions to proactively avoid risks and disruptions. Identify critical risks, prioritize them based on business needs, and establish mitigation approaches to ensure the organization’s ability to adapt and recover from cyber and IT-related threats."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.2" ;
    skos:prefLabel "Develop IT resilience strategy"@en .

<http://ots.local/thesaurus/apqc/8_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_0> ;
    skos:definition "Creating strategies to manage the organization's information and content. Outline the architecture for information. Administer information resources. Administer the management of data and content."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.4" ;
    skos:prefLabel "Manage information"@en .

<http://ots.local/thesaurus/apqc/8_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_4> ;
    skos:definition "Creating strategies to administer information and content. Understand the needs of the organization for information and content management. Realize the role of IT services for implementing the overall business strategy. Assess the implications of new technologies for managing information and content. Identify and prioritize the most effective and efficient actions for managing information and content."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.4.4" ;
    skos:prefLabel "Manage business information"@en .

<http://ots.local/thesaurus/apqc/9_10> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_0> ;
    skos:definition "Managing cash collections and disbursements made by operating units across the enterprise. When appropriate, transfer cash from the operating units to parent-level bank accounts managed by the organization's treasury team."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.10" ;
    skos:prefLabel "Manage international funds/consolidation"@en .

<http://ots.local/thesaurus/apqc/9_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_1> ;
    skos:definition "Deciding which expenses can be avoided to reduce some costs and increase revenues. Plan and control the organization's budget to forecast future expenditures."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.1.4" ;
    skos:prefLabel "Perform cost management"@en .

<http://ots.local/thesaurus/apqc/9_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_0> ;
    skos:definition "Making statements about business activities and functions. Prepare financial statements (balance sheet, income statement, statement of cash flows, and statement of stockholders' equity) according to accounting concepts and principles."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3" ;
    skos:prefLabel "Perform general accounting and reporting"@en .

<http://ots.local/thesaurus/apqc/9_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_4> ;
    skos:definition "Preparing a project finance report to solicit approvals in capital projects. Prepare budgets for projects that require heavy investments. Report on project finances to solicit approvals from management."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.4.1" ;
    skos:prefLabel "Perform capital planning and project approval"@en .

<http://ots.local/thesaurus/apqc/9_7_5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_5> ;
    skos:definition "Handling risks arising from changes in the interest rate."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.5.2" ;
    skos:prefLabel "Manage interest rate risk"@en .

<http://ots.local/thesaurus/apqc/9_7_5_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_5> ;
    skos:definition "Taking care of exposure risks. Maintain financial investments in particular investments or a portfolios that could be risky for the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.5.4" ;
    skos:prefLabel "Manage exposure risk"@en .

<http://ots.local/thesaurus/apqc/9_8_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_8> ;
    skos:definition "Reporting on internal controls compliance to the appropriate authority, including IT regulations and pertinent data."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.8.3" ;
    skos:prefLabel "Report on internal controls compliance"@en .

<http://ots.local/thesaurus/apqc/10_0> a skos:Concept ;
    skos:definition "Relating to the design, construction, acquisition, and management of both productive and non-productive assets."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.0" ;
    skos:prefLabel "Acquire, Construct, and Manage Assets"@en .

<http://ots.local/thesaurus/apqc/10_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_1> ;
    skos:definition "Recognizing the needs of facility users in order to construct a project proposal that meets those needs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.1.2" ;
    skos:prefLabel "Plan facility"@en .

<http://ots.local/thesaurus/apqc/10_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_2> ;
    skos:definition "Outlining the steps and strategies needed to construct assets. Verify that all regulations are adhered to and that all permissions have been granted. Organize and plan for resources to complete construction."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.2.2" ;
    skos:prefLabel "Design and plan asset construction"@en .

<http://ots.local/thesaurus/apqc/10_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_2> ;
    skos:definition "Arranging a timetable for which to perform construction work. Schedule resources to contract assets for new or replacement assets. Reschedule or redesign assets if needed."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.2.3" ;
    skos:prefLabel "Schedule and perform construction work"@en .

<http://ots.local/thesaurus/apqc/10_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_2> ;
    skos:definition "Overseeing the performance and quality of work. Assure that records are maintained throughout the construction process. Adhere to all safety, security, and access regulations set forth by the organization and all government standards."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.2.4" ;
    skos:prefLabel "Manage asset construction"@en .

<http://ots.local/thesaurus/apqc/10_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_3> ;
    skos:definition "Engaging in all aspects of asset maintenance. Ensure that all assets are functioning properly and to all specified codes and regulations where applicable. Maintenance includes all preventative, routine, and corrective activates."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.3.3" ;
    skos:prefLabel "Perform asset maintenance"@en .

<http://ots.local/thesaurus/apqc/11_0> a skos:Concept ;
    skos:definition "Ensuring that an organization effectively manages its risk. Process groups are aligned with traditional risk management activities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.0" ;
    skos:prefLabel "Manage Enterprise Risk, Compliance, Remediation, and Resiliency"@en .

<http://ots.local/thesaurus/apqc/11_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_1> ;
    skos:definition "Creating an agenda for the rules and regulations of enterprise risk that deal with hazardous, financial, operational, and strategic risks. This is inclusive of all forms of new and evolving technology such as artificial intelligence (AI)."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.1.1" ;
    skos:prefLabel "Establish the enterprise risk framework and policies"@en .

<http://ots.local/thesaurus/apqc/11_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_0> ;
    skos:definition "Including the processes required to rapidly adapt and respond to any internal or external opportunity, demand, disruption, or threat. Develop a more dynamic, strategic, and integrated approach to managing compliance obligations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.4" ;
    skos:prefLabel "Manage business resiliency"@en .

<http://ots.local/thesaurus/apqc/12_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_0> ;
    skos:definition "Managing a public relations programs through business and communications skills."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.5" ;
    skos:prefLabel "Manage public relations program"@en .

<http://ots.local/thesaurus/apqc/13_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_0> ;
    skos:definition "Establishing and administering governance for management of the processes. Outline and manage the frameworks for management of the processes. Define the business processes. Administer the performance of the processes. Enhance the business processes."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.1" ;
    skos:prefLabel "Manage business processes"@en .

<http://ots.local/thesaurus/apqc/13_10_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_10> ;
    skos:definition "Developing sustainability (ESG) capabilities for the organization. Understand and communicate legal, regulatory, and social/environmental requirements. Establish policies, objectives, guidelines and approaches for ESG efforts and reporting."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.10.1" ;
    skos:prefLabel "Develop sustainability capability"@en .

<http://ots.local/thesaurus/apqc/13_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_1> ;
    skos:definition "Outlining and establishing the business processes of the organization. Scope, analyze, map, and publish processes for the employees who may require it."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.1.3" ;
    skos:prefLabel "Define processes"@en .

<http://ots.local/thesaurus/apqc/13_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3> ;
    skos:definition "Determining essential activities, processes, and attributes for securing enterprise quality. Outline critical characteristics for quality. Outline activities encouraging the preservation of quality. Create quality controls. Confirm capabilities in accordance with quality requirements. Finalize the plan for quality maintenance."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.1" ;
    skos:prefLabel "Establish quality requirements"@en .

<http://ots.local/thesaurus/apqc/13_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3> ;
    skos:definition "Handling any nonconformance activities or events. Assess the potential impact of the nonconformity. Decide the immediate actions to take. Identify the root causes. Take corrective or preventive action. Ensure future conformance."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.3" ;
    skos:prefLabel "Manage non-conformance"@en .

<http://ots.local/thesaurus/apqc/13_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4> ;
    skos:definition "Effectuating the change within the desired impact areas of the organization. Ensure adequate commitment from all corners of the organization for the desired change. Create support structures. Refashion all processes deemed necessary. Observe the progress."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.3" ;
    skos:prefLabel "Implement change"@en .

<http://ots.local/thesaurus/apqc/13_5_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_5> ;
    skos:definition "Creating knowledge bases and other repositories to preserve and develop company expertise, and to train new employees."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.5.3" ;
    skos:prefLabel "Design and implement KM capabilities"@en .

<http://ots.local/thesaurus/apqc/13_7_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_7> ;
    skos:definition "Comparing organizational performance internally or externally with other organizations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.7.2" ;
    skos:prefLabel "Benchmark performance"@en .

<http://ots.local/thesaurus/apqc/1_0> a skos:Concept ;
    skos:definition "Establishing a direction and vision for an organization. This involves defining the business concept and long-term vision, as well as developing the business strategy and managing strategic initiatives. Processes in this category focus on creating a vision, a mission, and strategic objectives, and culminate in creating measures to ensure that the organization is moving in the desired direction."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.0" ;
    skos:prefLabel "Develop Vision and Strategy"@en .

<http://ots.local/thesaurus/apqc/1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_0> ;
    skos:definition "Creating a conceptual framework of the organization's business activity and strategic vision with long-term applicability. Scout the organization's internal capabilities, as well as the customer's needs and desires, to identify a fit that can be used to advance a conceptual structure of the organization's business activity. Conduct analysis in light of relevant externalities and large-scale shifts in the market landscape."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1" ;
    skos:prefLabel "Define the business concept and long-term vision"@en .

<http://ots.local/thesaurus/apqc/2_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1> ;
    skos:definition "Manage the introduction and withdrawal of products/services. Administer associated changes, namely measuring the performance of new solution offerings and the revision of master files in the archives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.2" ;
    skos:prefLabel "Manage product and service life cycle"@en .

<http://ots.local/thesaurus/apqc/2_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1> ;
    skos:definition "Determining the attributes necessary to protect and safeguard intellectual assets, maximize the value of IP assets through streamlined process, and collaboration between departments. Focus on needs to safeguard, critical assets, and assets' value."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.3" ;
    skos:prefLabel "Manage patents, copyrights, and regulatory requirements"@en .

<http://ots.local/thesaurus/apqc/2_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_2> ;
    skos:definition "Producing and defining ideologies for new product/service offerings."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.2.2" ;
    skos:prefLabel "Generate new product/service concepts"@en .

<http://ots.local/thesaurus/apqc/2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_0> ;
    skos:definition "Developing new products/services from scratch, including all activities associated with the design, prototyping, evaluation, and market testing of these planned offerings."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3" ;
    skos:prefLabel "Develop products and services"@en .

<http://ots.local/thesaurus/apqc/2_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3> ;
    skos:definition "Devising business plans and procedures for manufacturing/operations/production and delivery of services offered by the organization. Further in general terms the total amount of output that the manufacturing department is responsible to produce for each period."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.3" ;
    skos:prefLabel "Prepare for production/service delivery"@en .

<http://ots.local/thesaurus/apqc/2_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3> ;
    skos:definition "Determining the exact terms and conditions under which specific warranties apply to certain goods or services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.4" ;
    skos:prefLabel "Define warranty claims"@en .

<http://ots.local/thesaurus/apqc/3_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2> ;
    skos:definition "Monitoring marketing and distribution efforts of all channels individually and as a network. Re-distribute or add resources to channels that perform better than expected. Purge or consolidate under-performing channels, and find more promising replacements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.5" ;
    skos:prefLabel "Analyze and manage channel performance"@en .

<http://ots.local/thesaurus/apqc/3_2_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2> ;
    skos:definition "Creating and managing a customer loyalty program. The loyalty program is a key part of marketing, with an elaborate strategy and process for acquiring, retaining, and engaging with members. Members are engaged and acquainted to the loyalty program, thus growing relationship and adding value through the program."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.7" ;
    skos:prefLabel "Design and manage customer loyalty program"@en .

<http://ots.local/thesaurus/apqc/3_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3> ;
    skos:definition "Collating all customer-centered metrics. The objective is to create a big-picture view of the customers' mindset and their behavior pertaining to the organization's offerings."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.5" ;
    skos:prefLabel "Track customer management measures"@en .

<http://ots.local/thesaurus/apqc/3_3_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3> ;
    skos:definition "Reviewing and responding to customer feedback. Create tickets to initiate bug fixes or to propose feature updates. Monitor and track progress."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.6" ;
    skos:prefLabel "Analyze and respond to customer insight"@en .

<http://ots.local/thesaurus/apqc/3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_0> ;
    skos:definition "Developing concrete plans for guiding and providing support to the sales function. Chart a road map for the sales function, including an analysis of historical sales data to create forecasts for anticipated sales, forming sales targets, forging partnerships with other economic agents to boost sales, devising a budget for this function, and determining metrics to measure customer management activities as well as progress in achieving sales targets."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.4" ;
    skos:prefLabel "Develop sales strategy"@en .

<http://ots.local/thesaurus/apqc/3_5_1_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_1> ;
    skos:definition "Managing the entire sales process, from using leads to open sales to closing sales and creating records. Govern all sales activities. Make sales calls based on leads and preparatory work (drafting terms of the sale, creating proposals, suggesting prices, etc.). Close the sale, along with any administrative activities related to data entry and the processing of the sale."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.1.8" ;
    skos:prefLabel "Manage customer sales calls"@en .

<http://ots.local/thesaurus/apqc/3_5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5> ;
    skos:definition "Managing the customer's expectations, with the intent of responsibly increasing the sale of the organization's products/services. Create a systematic method for governing sales, using sales forecasts and customer management measures. Develop a blueprint to manage relationships with customers and the data it holds on them, as well as the sale of its products/services to these customers. Devise a recipe for handling the organization's key customers in order to manage their expectations with tact and responsibility while maximizing revenue."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.2" ;
    skos:prefLabel "Manage customers and accounts"@en .

<http://ots.local/thesaurus/apqc/4_0> a skos:Concept ;
    skos:definition "Performing supply chain activities include planning supply chain, procuring materials and services, and managing logistics."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.0" ;
    skos:prefLabel "Manage Supply Chain for Physical Products"@en .

<http://ots.local/thesaurus/apqc/4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_0> ;
    skos:definition "Creating a plan for procuring materials and services. Develop strategies for sourcing materials and services. Choose the most appropriate suppliers, and develop contracts with them. Order the materials and services as per the requirements. Manage relationships with suppliers."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.2" ;
    skos:prefLabel "Procure materials and services"@en .

<http://ots.local/thesaurus/apqc/4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_0> ;
    skos:definition "Administering and overseeing all activities related to logistics and warehousing. Outline and establish a strategy for the logistics function. Plan and administer the flow of inbound materials. Administer the operational activities of warehousing and outbound transportation. Manage reverse logistics including returns and exchanges."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4" ;
    skos:prefLabel "Manage logistics and warehousing"@en .

<http://ots.local/thesaurus/apqc/4_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4> ;
    skos:definition "Creating and executing a strategy for all the internal activities related to the flow/transfer of inbound materials. This process includes planning inbound material receipts, managing inbound material flow, monitoring inbound delivery performance, managing the flow of returned products, controlling the quality of returned parts, and salvaging or repairing returned products."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.2" ;
    skos:prefLabel "Plan and manage inbound material flow"@en .

<http://ots.local/thesaurus/apqc/5_0> a skos:Concept ;
    skos:definition "Offering services to customers. This is the act of providing service delivery as a core business practice and covers identifying strategies for performing service delivery, managing resources, and delivering services to the customer."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.0" ;
    skos:prefLabel "Deliver Services"@en .

<http://ots.local/thesaurus/apqc/6_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_0> ;
    skos:definition "Planning and administering workforce operations for customer service provision by taking care of customer services requests/inquiries, as well as the complaints."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.2" ;
    skos:prefLabel "Plan and manage customer service contacts"@en .

<http://ots.local/thesaurus/apqc/6_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_2> ;
    skos:definition "Obtaining customer complaints online or by phone. Direct these complaints to higher-level representatives as appropriate. Resolve them. Respond to customers."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.2.3" ;
    skos:prefLabel "Manage customer complaints"@en .

<http://ots.local/thesaurus/apqc/6_3_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3_2> ;
    skos:definition "Executing investigational and analysis of warranty claims. This involves notification and definition of a warranty issue, includes the scheduling of a field service agent to perform further investigation; the request and receipt of defective parts; and diagnosis/root cause analysis. This concludes with the receipt of the result and recommendation for corrective action."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.2.3" ;
    skos:prefLabel "Investigate warranty issues"@en .

<http://ots.local/thesaurus/apqc/6_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_0> ;
    skos:definition "Calculating and assessing the operational activities of the customer service function. Evaluation is achieved through the customer requests/inquiries handling process, the customer complaint handling process, and product and services quality. Examine activities to ensure high levels of customer service."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.5" ;
    skos:prefLabel "Evaluate customer service operations and customer satisfaction"@en .

<http://ots.local/thesaurus/apqc/6_5_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_5> ;
    skos:definition "Calculating satisfaction levels of customers with products/services. Obtain customer feedback on products/services, as well as the effectiveness of the advertising campaigns. Examine this information to reach meaningful conclusions, which could then be used to enhance the customer service operations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.5.3" ;
    skos:prefLabel "Measure customer satisfaction with products and services"@en .

<http://ots.local/thesaurus/apqc/6_5_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_5> ;
    skos:definition "Assessing the cost and effectiveness of warranties."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.5.4" ;
    skos:prefLabel "Evaluate and manage warranty performance"@en .

<http://ots.local/thesaurus/apqc/7_1_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_2> ;
    skos:definition "Evaluating the current and future skill requirements of the organization with regard to the overall corporate strategy of the organization and market conditions. Identify and establish the minimum skills needed for the requisite HR needs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.2.1" ;
    skos:prefLabel "Perform strategic workforce planning"@en .

<http://ots.local/thesaurus/apqc/7_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_0> ;
    skos:definition "Determining and handling employee requirements. Recruit or source the candidates as per the requirements. Screen and select the most appropriate candidates. Take care of the newly hired and re-hired employees. Maintain records of information for all applicants."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.2" ;
    skos:prefLabel "Recruit, source, and select employees"@en .

<http://ots.local/thesaurus/apqc/7_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_0> ;
    skos:definition "Assisting general management in developing, maintaining, and improving employee relationships. This is accomplished through communication, performance management, processing grievances, and/or dispute. Interpret and convey organizational policies."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.4" ;
    skos:prefLabel "Manage employee relations"@en .

<http://ots.local/thesaurus/apqc/7_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_0> ;
    skos:definition "Creating frameworks for rewarding and recognizing employees with the objective of retaining them. Create and manage programs for provision of rewards, recognition, and motivation. Manage and administer the benefits for employees. Help assist and retain employees. Administer payroll to employees."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.5" ;
    skos:prefLabel "Reward and retain employees"@en .

<http://ots.local/thesaurus/apqc/7_7_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_7> ;
    skos:definition "Understand, develop, and gather workforce data in support of stakeholder requirements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.7.7" ;
    skos:prefLabel "Develop workforce analytics"@en .

<http://ots.local/thesaurus/apqc/8_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1> ;
    skos:definition "Create and design an organized and curated collection of all IT-related services that can be performed by, for, or within the organization. Maintain and convey information about deliverables, prices, contact points, and processes for requesting an information technology service."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.3" ;
    skos:prefLabel "Plan and communicate IT services"@en .

<http://ots.local/thesaurus/apqc/8_1_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1> ;
    skos:definition "Managing the IT relationship with its customers by systematically coordinating interactions over multiple touch points on a regular basis. Coordinate the IT's efforts to reach out to its customers, which include emails, social-media interactions, newsletters, and direct conversations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.6" ;
    skos:prefLabel "Manage IT customer relationships"@en .

<http://ots.local/thesaurus/apqc/8_3_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3> ;
    skos:definition "Evaluate and analyze the IT environment for the compliance of industry regulations and government legislation. Ensure that IT capability and resources meet the set standards."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.6" ;
    skos:prefLabel "Conduct and analyze IT compliance assessments"@en .

<http://ots.local/thesaurus/apqc/8_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_4> ;
    skos:definition "Creating strategies to manage the organization's information and content. Outline the architecture for information collection and communication. Administer information resources, data management and content."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.4.2" ;
    skos:prefLabel "Define and maintain business information architecture"@en .

<http://ots.local/thesaurus/apqc/8_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_0> ;
    skos:definition "Designing and maintaining the IT services/solutions catalogue. Evaluate the performance of IT services/solutions. Communicate the results to the management."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5" ;
    skos:prefLabel "Develop and manage services/solutions"@en .

<http://ots.local/thesaurus/apqc/8_5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5> ;
    skos:definition "Executing life-cycle planning for IT services and solutions. Develop new requirements and feature-function enhancements. Create and design a life cycle plan that addresses the current and future state of IT services and solutions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.2" ;
    skos:prefLabel "Manage service/solution lifecycle planning"@en .

<http://ots.local/thesaurus/apqc/8_5_5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5_5> ;
    skos:definition "Executing IT service/solution maintenance lifecycle in order to reduce maintenance costs and increase reliability of IT infrastructure concerning service/solution related problems."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.5.1" ;
    skos:prefLabel "Execute IT service/solution maintenance lifecycle"@en .

<http://ots.local/thesaurus/apqc/8_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_0> ;
    skos:definition "Executing IT services/solutions by creating a strategy for deployment. Plan and execute the changes. Plan and administer the release of its IT services and solutions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6" ;
    skos:prefLabel "Deploy services/solutions"@en .

<http://ots.local/thesaurus/apqc/8_7_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7> ;
    skos:definition "Defining and establishing strategy for delivering IT services and solutions to the users. Design an IT service delivery model that defines the processes and procedures needed to deliver the IT services and solutions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.1" ;
    skos:prefLabel "Define and establish service delivery strategy"@en .

<http://ots.local/thesaurus/apqc/8_7_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7> ;
    skos:definition "Developing and managing the resources required for administration of infrastructure. Manage the IT inventory and assets to meet organization's IT resource capacity."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.4" ;
    skos:prefLabel "Develop and manage infrastructure resource planning"@en .

<http://ots.local/thesaurus/apqc/9_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_0> ;
    skos:definition "Determining different stages of the planning process and accounting. Classify, determine, analyze, interpret, and communicate information to make up-to-date business decisions for better management and control functions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.1" ;
    skos:prefLabel "Perform planning and management accounting"@en .

<http://ots.local/thesaurus/apqc/9_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_1> ;
    skos:definition "Allocating funds to meet future and current financial goals. Led by the chief financial officer, have the finance function plan, budget, and forecast in order to determine and describe long and short-term financial goals."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.1.2" ;
    skos:prefLabel "Perform planning/budgeting/forecasting"@en .

<http://ots.local/thesaurus/apqc/9_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_0> ;
    skos:definition "Comparing revenue targets to reality. Review all transactions and entries passed in final accounts in a year in order to examine profits."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2" ;
    skos:prefLabel "Perform revenue accounting"@en .

<http://ots.local/thesaurus/apqc/9_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2> ;
    skos:definition "Preparing detailed reports of customer purchases. Prepare a commercial document between the seller and customer with details about transaction. Detail the quantity purchased, price of products/services, date, parties involved, unique invoice number, and tax information."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.2" ;
    skos:prefLabel "Invoice customer"@en .

<http://ots.local/thesaurus/apqc/9_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2> ;
    skos:definition "Processing payments due from customers. This includes all processing of funds received, whether by check or electronically. This does not include the generation of invoices."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.3" ;
    skos:prefLabel "Process accounts receivable (AR)"@en .

<http://ots.local/thesaurus/apqc/9_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3> ;
    skos:definition "Creating procedures to perform general accounting and reporting. Follow the rules and regulations made for a particular process in the business. Publish accounting policies."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.1" ;
    skos:prefLabel "Manage financial policies and procedures"@en .

<http://ots.local/thesaurus/apqc/9_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_4> ;
    skos:definition "Accounting for large-scale and large-cost investments. Manage and account for ongoing activities related to capital projects, including setting up new projects, recording project transactions, monitoring and tracking spending, closing and capitalizing projects, and measuring the financial returns on completed projects."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.4.2" ;
    skos:prefLabel "Perform capital project accounting"@en .

<http://ots.local/thesaurus/apqc/9_5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_5> ;
    skos:definition "Recording the reporting time of employees on-site. Track working days, salary calculations, holidays taken, number of hours spend in the office, billing hours, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.5.1" ;
    skos:prefLabel "Report time"@en .

<http://ots.local/thesaurus/apqc/9_5_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_5> ;
    skos:definition "Deducting and paying taxes from employees' salaries."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.5.3" ;
    skos:prefLabel "Manage and process payroll taxes"@en .

<http://ots.local/thesaurus/apqc/9_6_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_6> ;
    skos:definition "Processing reimbursements to employees for the expenses incurred during the course of business. Approve and process advancements and reimbursements for employee expenses on the organization's behalf. Capture and report relevant tax data and manage personal accounts."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.6.2" ;
    skos:prefLabel "Process expense reimbursements"@en .

<http://ots.local/thesaurus/apqc/9_7_5_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_5> ;
    skos:definition "Taking care of foreign-exchange risks."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.5.3" ;
    skos:prefLabel "Manage foreign exchange risk"@en .

<http://ots.local/thesaurus/apqc/9_7_5_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_5> ;
    skos:definition "Implementing hedging strategy in attempt to alleviate risk. This will include all options, depravities, and futures contracts agreed upon in Develop risk management/hedging strategy [12974]."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.5.5" ;
    skos:prefLabel "Execute hedging transactions"@en .

<http://ots.local/thesaurus/apqc/9_8_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_8> ;
    skos:definition "Forming rules and regulations to ensure the achievement of effectiveness, proficiency of operations, and reliability of financial reporting."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.8.1" ;
    skos:prefLabel "Establish internal controls, policies, and procedures"@en .

<http://ots.local/thesaurus/apqc/11_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_0> ;
    skos:definition "Administering the efforts and activities for remediation. This process element requires the organization to create plans for corrective action in collaboration with government agencies and pertinent professional services agencies which specialize in remediation efforts relevant to the organization's operations. Additionally, the organization needs to consult experts to validate the plan, determine resources allocation, resolve any legal concerns, and formulate a company-wide policy for remediation."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.3" ;
    skos:prefLabel "Manage remediation efforts"@en .

<http://ots.local/thesaurus/apqc/12_0> a skos:Concept ;
    skos:definition "Fostering external relationships with stakeholders of the entity, including investors, government and industry, the board of directors, and the general public. This is not related to customer management."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.0" ;
    skos:prefLabel "Manage External Relationships"@en .

<http://ots.local/thesaurus/apqc/12_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_2> ;
    skos:definition "Persuading public and government policy at the local, regional, national, and global level (subject to government regulations)."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.2.1" ;
    skos:prefLabel "Manage government relations"@en .

<http://ots.local/thesaurus/apqc/12_4_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_4> ;
    skos:definition "Managing professionals, sought externally for assistance over legal and ethical concerns. Administer and oversee assistance from subject matter experts and professionals for sourcing expert opinion and counseling over legal and ethical matters."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.4.5" ;
    skos:prefLabel "Manage outside counsel"@en .

<http://ots.local/thesaurus/apqc/13_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2> ;
    skos:definition "Establishing the scope of the projects. Create plans for implementing the projects. Initiate projects. Review and report project performance to management. Close projects."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.3" ;
    skos:prefLabel "Manage projects"@en .

<http://ots.local/thesaurus/apqc/13_2_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2_3> ;
    skos:definition "Establishing the horizons of business projects. Identify the objectives of the program, along with the resource requirements. Assess the readiness for the project management approach. Identify methodologies for project management. Obtain funding. Develop performance measures and indicators."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.3.1" ;
    skos:prefLabel "Establish project scope"@en .

<http://ots.local/thesaurus/apqc/13_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3> ;
    skos:definition "Establishing and administering the software that manages content and business processes for quality and compliance across the value chain. Define the quality strategy. Plan and deploy the EQMS scope, targets, and goals. Identify core process controls and metric. Develop EQMS governance. Assess the performance of EQMS. Encourage improvements in EQMS."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.4" ;
    skos:prefLabel "Implement and maintain the enterprise quality management system (EQMS)"@en .

<http://ots.local/thesaurus/apqc/13_3_4_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_4> ;
    skos:definition "Rewarding excellence in quality. Create and maintain quality partnerships. Maintain talent capabilities and competencies. Incorporate EQMS messaging into communication channels. Transfer proven EQMS methods. Consider factors such as EQMS reviews and gap assessments and the alignment and compatibility of business processes and quality. Adopt Lean principles."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.4.6" ;
    skos:prefLabel "Create environment and capability for EQMS improvement(s)"@en .

<http://ots.local/thesaurus/apqc/13_6_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6> ;
    skos:definition "Managing the systems, tools, and repositories that support content storage, access, administration, and control across the content lifecycle. Consider AI supported content services (e.g., auto classification, semantic enrichment, embeddings stores, and knowledge graph infrastructure)."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.4" ;
    skos:prefLabel "Manage content infrastructure"@en .

<http://ots.local/thesaurus/apqc/13_9_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_9> ;
    skos:definition "Managing the performance, costs and benefits of EHS. Measure and report the performance of EHS. Implement plans for emergency response and pollution prevention. Train and educate employees. Provide EHS support."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.9.3" ;
    skos:prefLabel "Monitor and manage EHS program"@en .

<http://ots.local/thesaurus/apqc/1_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_1> ;
    skos:definition "Undertaking a review of the organization's in-house skills and resources in order to create a big-picture understanding of internal capacities. Assess the organization's capabilities in order to advance the advantageous and weed out the detrimental aspects. Identify synergic associations within the backdrop of the forces and players active in the market, and take into account all externalities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1.3" ;
    skos:prefLabel "Assess the internal environment"@en .

<http://ots.local/thesaurus/apqc/2_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1> ;
    skos:definition "Managing a portfolio of product/service offerings to take advantage of shifts in the market expectations, all the while coordinating with the overall business strategy. Revisit the product/service portfolio in light of market opportunities, and overhaul it to capture value created by these opportunities. Identify gaps between current offerings and the market expectations to direct the organization's R&D activity. Create new solutions, and revise or retire existing ones so that the revamped portfolio aligns with Develop a business strategy [10015]."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.1" ;
    skos:prefLabel "Manage product and service portfolio"@en .

<http://ots.local/thesaurus/apqc/2_3_1_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_1> ;
    skos:definition "Creating a sketch of the customer focused product/service in Develop and Manage Products and Services [10003]."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.1.8" ;
    skos:prefLabel "Design products/services"@en .

<http://ots.local/thesaurus/apqc/3_0> a skos:Concept ;
    skos:definition "Outlining process groups related to understanding markets, customers, and capabilities; developing marketing strategies; executing marketing plans; developing sales strategies; developing and managing marketing plans; and managing sales partners and alliances."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.0" ;
    skos:prefLabel "Market and Sell Products and Services"@en .

<http://ots.local/thesaurus/apqc/3_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_1> ;
    skos:definition "Gathering intelligence on the market and customers. Closely examine the inherent attributes and collective behavior of the various market and customer segments. Track trends in the market. Determine what drives the customers to make purchasing decisions in order to identify opportunities in the market."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.1.1" ;
    skos:prefLabel "Perform customer and market intelligence analysis"@en .

<http://ots.local/thesaurus/apqc/3_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_4> ;
    skos:definition "Setting up a financial plan for the sales function. Calculate the estimated sales revenue and costs, which helps in calculating the overall net profit. Create a sound plan for resource outlay by comparing the forecast with historical data."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.4.3" ;
    skos:prefLabel "Establish overall sales budgets"@en .

<http://ots.local/thesaurus/apqc/4_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1> ;
    skos:definition "Developing a scheme that allows for advance planning for the availability of raw materials and spares. Start with an unconstrained plan, and refine based on supply chain realities by identifying critical materials required for production, checking material specifications, and collaborating with all vendors over the supply."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.3" ;
    skos:prefLabel "Create materials plan"@en .

<http://ots.local/thesaurus/apqc/4_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_3> ;
    skos:definition "Manufacturing the product. Convert the raw materials to develop consumer-ready products. Manage the raw materials to implement the detailed production schedule. Reproduce defectives to establish and remediate cause. Ensure production optimization and benchmark performance."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.3.2" ;
    skos:prefLabel "Produce/Assemble product"@en .

<http://ots.local/thesaurus/apqc/4_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_3> ;
    skos:definition "Executing tests to evaluate the quality of the products manufactured. Calibrate the test equipment. Conduct the actual tests. Record the results and outcomes of the quality test conducted."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.3.3" ;
    skos:prefLabel "Perform quality testing"@en .

<http://ots.local/thesaurus/apqc/5_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_2> ;
    skos:definition "Identifying the need for and creating a resource plan. Understand resource demand and align with capacity, skills, and capabilities. Enlist suppliers and partners to supplement needed skills and capabilities. Monitor and manage capabilities and skills with an eye on critical resources and supplier capacity."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.2.2" ;
    skos:prefLabel "Create and manage resource plan"@en .

<http://ots.local/thesaurus/apqc/6_0> a skos:Concept ;
    skos:definition "Managing interactions with current customers after the delivery of products and services. This includes developing and planning customer service practices with a focus on handling inquiries after sales, feedback, warranties, recalls, and other related processes."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.0" ;
    skos:prefLabel "Manage Customer Service"@en .

<http://ots.local/thesaurus/apqc/6_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_0> ;
    skos:definition "Defining a plan that removes customer obstacles by gathering operational insight and competitive insight, as well as improving soft skills and forward resolution for employees. Develop customer segmentation. Define rules and regulations for customer service. Establish service levels for customers."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.1" ;
    skos:prefLabel "Develop customer service strategy"@en .

<http://ots.local/thesaurus/apqc/6_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_2> ;
    skos:definition "Handling the requests and inquiries from customers that seek information regarding the organization's products/services. Obtain the customer requests online and by phone. Direct these requests to higher-level representatives. Approve requests, and respond to customers."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.2.2" ;
    skos:prefLabel "Manage customer service problems, requests, and inquiries"@en .

<http://ots.local/thesaurus/apqc/6_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_0> ;
    skos:definition "Removing defective products from the distribution chain. Participate in audits from watchdog agencies."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.4" ;
    skos:prefLabel "Manage product recalls and regulatory audits"@en .

<http://ots.local/thesaurus/apqc/7_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_2> ;
    skos:definition "Recruiting new candidates for deployment across various functional areas inside the organization. Select methods for sourcing new employees. Manage relationships with third-party agencies. Stage recruitment fairs and drives. Manage employee referral programs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.2.2" ;
    skos:prefLabel "Recruit/Source candidates"@en .

<http://ots.local/thesaurus/apqc/8_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2> ;
    skos:definition "Defining the need of technology in business and systematic implementation of IT investments. This is inclusive of all forms of new and evolving technology such as artificial intelligence (AI). It comprises of assessing competitive technology components to ensure structural analysis, development, usage and security of technology for efficient business operations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.1" ;
    skos:prefLabel "Define business technology and governance strategy"@en .

<http://ots.local/thesaurus/apqc/8_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2> ;
    skos:definition "Strategy for systematic management of IT investments, projects, and activities. Analyze and examine the value of the IT portfolio and allocate resources based on business objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.2" ;
    skos:prefLabel "Manage IT portfolio strategy"@en .

<http://ots.local/thesaurus/apqc/8_3_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3> ;
    skos:definition "Create and execute a process to rapidly adapt and respond to any internal or external opportunity, demand, disruption, or threat in IT. Maintain continuous IT operations to protect employees, assets, and overall brand equity."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.7" ;
    skos:prefLabel "Develop and execute IT resilience and continuity operations"@en .

<http://ots.local/thesaurus/apqc/8_6_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6> ;
    skos:definition "Creating and implementing a strategy for the deployment of IT service/solution. Define all of the activities that make the IT function available for use. Establish the change policies for IT services and solutions. Define the deployment process, procedures, and tools. Select the most feasible and practical methodologies for the deployment process."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.1" ;
    skos:prefLabel "Develop and manage service/solution deployment strategy"@en .

<http://ots.local/thesaurus/apqc/8_7_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7> ;
    skos:definition "Defining and creating a strategy for provision of support to users of IT services and solutions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.2" ;
    skos:prefLabel "Define and develop service support strategy"@en .

<http://ots.local/thesaurus/apqc/8_7_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_3> ;
    skos:definition "Planning different delivery services for operational activities within the IT function. Use service delivery systems to manage the IT service delivery services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.3.1" ;
    skos:prefLabel "Plan operational activities for IT service delivery"@en .

<http://ots.local/thesaurus/apqc/8_7_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7> ;
    skos:definition "Managing the resources required for administration of IT infrastructure. Manage the IT inventory and assets. Take care of the organization's IT resource capacity."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.7" ;
    skos:prefLabel "Manage infrastructure resource administration"@en .

<http://ots.local/thesaurus/apqc/8_7_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7> ;
    skos:definition "Managing systematic user support functionality and capability through defined procedures. Determine, record, and monitor user requests. Execute issue/request resolution. Utilize escalation path when needed. Resolve issue/request."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.8" ;
    skos:prefLabel "Operate IT user support"@en .

<http://ots.local/thesaurus/apqc/9_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_1> ;
    skos:definition "Defining costs to be incurred and methods for optimum utilization. Determine the costs of products, processes, projects, etc. to compile in the financial statements, as well as to assist management in making decisions regarding planning and control. Control costs by managing and reducing business expenses."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.1.3" ;
    skos:prefLabel "Perform cost accounting and control"@en .

<http://ots.local/thesaurus/apqc/9_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2> ;
    skos:definition "Creating and providing funds for necessary adjustments and deductions, including all expenses that were required for the business at certain point in time."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.5" ;
    skos:prefLabel "Manage and process adjustments/deductions"@en .

<http://ots.local/thesaurus/apqc/9_6_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_6> ;
    skos:definition "Handling and authoring credit cards to business entities or for corporate purchases."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.6.3" ;
    skos:prefLabel "Manage corporate credit cards"@en .

<http://ots.local/thesaurus/apqc/9_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_0> ;
    skos:definition "Managing business's investments in trading in bonds, currencies, financial derivatives, etc. Manage the financial assets and holdings of the organization. Optimize the organization's liquidity. Invest excess cash. Reduce financial risks."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7" ;
    skos:prefLabel "Manage treasury operations"@en .

<http://ots.local/thesaurus/apqc/9_7_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7> ;
    skos:definition "Performing transactions that limit investment risk with the help of derivatives, such as options and futures contracts. Manage interest rates, foreign exchange, and exposure risks. Develop and execute hedging transactions. Evaluate and refine hedging positions. Produce hedge accounting transactions and reports. Monitor credit."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.5" ;
    skos:prefLabel "Monitor and execute risk and hedging transactions"@en .

<http://ots.local/thesaurus/apqc/10_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_3> ;
    skos:definition "Ensuring that necessary resources are available and tasks are prioritized accordingly through planning. Provide strategies and policies that identify tasks that need to be completed, and the resources necessary to fulfill those tasks."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.3.1" ;
    skos:prefLabel "Plan asset maintenance"@en .

<http://ots.local/thesaurus/apqc/10_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_3> ;
    skos:definition "Ensuring that asset maintenance is conducted in a timely manner and successfully. Schedule work with the required resources with an eye on quality control and safety. Verify that contracted maintenance meets performance targets."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.3.2" ;
    skos:prefLabel "Manage asset maintenance"@en .

<http://ots.local/thesaurus/apqc/11_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_1> ;
    skos:definition "Analyzing the threats a business unit/function faces to prioritize the controls it implements.."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.1.3" ;
    skos:prefLabel "Manage business unit and function risk"@en .

<http://ots.local/thesaurus/apqc/13_2_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2_3> ;
    skos:definition "Defining the resources and their roles. Identify IT requirements. Create plans for effective training and communication. Design reward approaches. Plan the launch of project. Deploy the project."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.3.3" ;
    skos:prefLabel "Develop project plans"@en .

<http://ots.local/thesaurus/apqc/13_2_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2_3> ;
    skos:definition "Implementing the business projects of the organization. Evaluate the impact of project management. Record and report the status of the project. Manage the project scope. Promote and sustain activities and involvement. Realign and revamp the project management strategy and approach."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.3.4" ;
    skos:prefLabel "Execute projects"@en .

<http://ots.local/thesaurus/apqc/13_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_0> ;
    skos:definition "Storing, managing, curating and delivering enterprise content and knowledge assets to enable consistent reuse and informed decision making.  Establish structures and governance that support classification, semantic enrichment, and lifecycle management of content across formats and repositories.  This includes all forms of emerging technologies such as artificial intelligence (AI), machine learning assisted tagging, automated classification, and semantic content processing."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6" ;
    skos:prefLabel "Manage Content"@en .

<http://ots.local/thesaurus/apqc/1_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2> ;
    skos:definition "Developing a strategy for the achievement of business goals over the distant future. Adopt one of the strategic options for realizing its mission over the long term. Enlist senior management executives, comprising strategy and/or business unit personnel."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.3" ;
    skos:prefLabel "Set/Develop long-term enterprise strategy"@en .

<http://ots.local/thesaurus/apqc/1_2_8_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_8> ;
    skos:definition "Creating a design of how customers interact with the business by analyzing data captured through various customer interaction and customer involvement. These will be captured through various channels such as customer satisfaction surveys, feedback forms, product reviews, targeted studies, observational studies, or voice of customer research."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.8.2" ;
    skos:prefLabel "Design customer experience"@en .

<http://ots.local/thesaurus/apqc/1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_0> ;
    skos:definition "Managing strategic initiatives, from development through selection, execution, and evaluation. Conduct and oversee strategic projects supporting long-term objectives. Administer programs of strategic significance by developing such initiatives, select the most appropriate projects, and formulate measures to assess their impact."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.3" ;
    skos:prefLabel "Develop and measure strategic initiatives"@en .

<http://ots.local/thesaurus/apqc/2_1_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_2> ;
    skos:definition "Learning from either a test or a full production run within the consumer market. Companies use this as an opportunity to both test and react to new products, ideas, or innovations based on the initial reaction of consumers on an individual level. Within this process, analytics are used to determine the relative success of a new product offering. Within this process, companies will launch key analytics to test a products acceptance. They will also review market performance and compare to similar products and against the business case or the financial plan. Companies can also measure the effectiveness of their supply chain network, and can apply what is learned from the post launch review to other new products, processes, and procedures to ensure and enhance the product quality."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.2.5" ;
    skos:prefLabel "Conduct post launch review"@en .

<http://ots.local/thesaurus/apqc/3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_0> ;
    skos:definition "Charting a strategic course for marketing products/services. This will include defining the value proposition, creating a mechanism for pricing, and determining the right mix of marketing channels. Create a specific positioning and branding for the organization's offerings. Enlist marketing head to lead, with inputs from the business development and sales functions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2" ;
    skos:prefLabel "Develop marketing strategy"@en .

<http://ots.local/thesaurus/apqc/3_5_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5> ;
    skos:definition "Taking, receiving, processing, and acknowledging new customer orders or amendments to outstanding customer orders. Monitoring status from order receipt to customer delivery/customer invoicing."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.4" ;
    skos:prefLabel "Manage sales orders"@en .

<http://ots.local/thesaurus/apqc/4_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1> ;
    skos:definition "Forecasting demand for products using secondary research and customer feedback. Refine these forecasts. Inspect the approach used in creating forecasts, and determine its accuracy."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.2" ;
    skos:prefLabel "Manage demand for products"@en .

<http://ots.local/thesaurus/apqc/4_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_2> ;
    skos:definition "Creating and approving requisitions and distributing purchase orders accordingly. Hasten the procurement process to satisfy internal needs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.2.4" ;
    skos:prefLabel "Order materials and services"@en .

<http://ots.local/thesaurus/apqc/4_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_3> ;
    skos:definition "Scheduling the production of final products. Generate a detailed schedule plan. Create and release production orders and lots. Schedule the planned and unplanned maintenance orders."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.3.1" ;
    skos:prefLabel "Schedule production"@en .

<http://ots.local/thesaurus/apqc/4_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4> ;
    skos:definition "Outlining the strategy for managing logistics. Translate customer requirements logistic requirements. Create an efficient logistic network and outsourcing portions of logistics activities. Design a logistics strategy that optimizes transportation costs and schedule. Define key performance indicators."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.1" ;
    skos:prefLabel "Provide logistics governance"@en .

<http://ots.local/thesaurus/apqc/5_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_1> ;
    skos:definition "Constructing strategies that identify goals, policies, processes, and procedures in relation to service delivery. Review and validate strategies. Define the workplace layout and infrastructure."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.1.2" ;
    skos:prefLabel "Develop service delivery strategies"@en .

<http://ots.local/thesaurus/apqc/5_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_2> ;
    skos:definition "Instituting training to enable resources to provide service delivery to the customer. Develop a training plan. Create materials that provide for operation and technical training. Schedule, perform, and evaluate training."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.2.3" ;
    skos:prefLabel "Enable service delivery resources"@en .

<http://ots.local/thesaurus/apqc/5_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_4> ;
    skos:definition "Collaborating with the customer to understand service needs. Review, understand, and modify the delivery scope with the organization needs of the customer in mind. Confirm readiness and identify, select, and assign resources. Plan for service delivery."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.4.1" ;
    skos:prefLabel "Initiate service delivery"@en .

<http://ots.local/thesaurus/apqc/5_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_4> ;
    skos:definition "Carrying out service delivery to the customer by creating and deploying the necessary solution. Analyze need and create a solution. Validate the solution and make changes if needed. Obtain approval to build/buy solution and then deploy solution to customer."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.4.2" ;
    skos:prefLabel "Execute service delivery"@en .

<http://ots.local/thesaurus/apqc/5_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_4> ;
    skos:definition "Implementing final steps to complete service delivery to the customer. Evaluate success through project review, complete finance activities, and confirm delivery. Release resources and manage completion by harvesting knowledge and systems by archiving records."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.4.3" ;
    skos:prefLabel "Complete service delivery"@en .

<http://ots.local/thesaurus/apqc/7_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_2> ;
    skos:definition "Handling the requirements for new employees. Create and open job requisitions by clearly defining the job descriptions. Post these requirements internally and externally, and modify them as appropriate. Manage the dates of the whole requisition process."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.2.1" ;
    skos:prefLabel "Manage employee requisitions"@en .

<http://ots.local/thesaurus/apqc/7_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_3> ;
    skos:definition "Establish organizational development needs for employees. Creating a link between employee and organizational development needs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.3.4" ;
    skos:prefLabel "Develop and train employees"@en .

<http://ots.local/thesaurus/apqc/8_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_0> ;
    skos:definition "Creating and administering relationships with IT customers. Understanding customer needs including high-level business requirements for IT transformation. Plan for and communicate IT services along with establishing IT service levels, providing transformation guidance, and performance analysis that foster IT customer relationships."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1" ;
    skos:prefLabel "Develop and manage IT customer relationships"@en .

<http://ots.local/thesaurus/apqc/8_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1> ;
    skos:definition "Establishing and maintaining service levels for the provision of IT services and solutions. Design and maintain the IT services and solution catalogue, as well as service level agreements. Evaluate the performance of IT service level agreements. Communicate the results to the management."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.5" ;
    skos:prefLabel "Develop and manage IT service levels"@en .

<http://ots.local/thesaurus/apqc/8_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_0> ;
    skos:definition "Handling the business of IT. Create a organization-wide strategy for the IT function. Define the organization's IT architecture. Manage the IT portfolio. Research and innovate in the field of IT. Assess and convey the performance and the value of the IT function."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2" ;
    skos:prefLabel "Develop and manage IT business strategy"@en .

<http://ots.local/thesaurus/apqc/8_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2> ;
    skos:definition "Defining perspective, position, plans, and patterns needed to execute designing, delivering, managing, and improving the way information technology is used within an organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.4" ;
    skos:prefLabel "Define IT service management strategy"@en .

<http://ots.local/thesaurus/apqc/8_2_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2> ;
    skos:definition "Outline and manage the innovation of technology within the organization. This is inclusive of all forms of new and evolving technology such as artificial intelligence (AI). Research and understand emerging future technological concepts and capabilities. Plan for IT innovation investments. Plan and execute viable innovation projects."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.7" ;
    skos:prefLabel "Define and manage technology innovation"@en .

<http://ots.local/thesaurus/apqc/8_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3> ;
    skos:definition "Creating and deploying an architecture for securing and ensuring the privacy of data flows throughout the organization. Develop and implement protocols and policies to protect IT and OT environments, aligned with global standards. Incorporate modern security paradigms, such as Zero Trust Architecture, to ensure the safe use of IT services and solutions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.5" ;
    skos:prefLabel "Develop and manage IT security, privacy, and data protection"@en .

<http://ots.local/thesaurus/apqc/8_5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5> ;
    skos:definition "Developing service/solution along with creating a strategy that provides a base for delivering service/solution aligned with overall business needs. This is inclusive of all forms of new and evolving technology such as artificial intelligence (AI). Conduct research within the services/solutions field for development and integration."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.1" ;
    skos:prefLabel "Develop service/solution and integration strategy"@en .

<http://ots.local/thesaurus/apqc/8_5_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5_4> ;
    skos:definition "Executing an information system, aiming to produce a high quality system that meets or exceeds customer expectations, reaches completion within time and cost estimates, and is inexpensive to maintain and cost-effective to enhance."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.4.1" ;
    skos:prefLabel "Execute IT service/solution development lifecycle"@en .

<http://ots.local/thesaurus/apqc/8_6_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6> ;
    skos:definition "Strategizing and executing changes in IT solutions and services. Create a plan for deploying the changes. Communicate with stakeholders about the changes. Administer and implement the changes. Train the resources who will be affected by these changes. Install changes and verify their effect."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.2" ;
    skos:prefLabel "Plan service and solution implementation"@en .

<http://ots.local/thesaurus/apqc/8_6_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6> ;
    skos:definition "Creating and deploying an architecture for securing the changes deployed in the organization. Create and develop protocols that ensure proper and efficient use of deployed IT services and solutions. Test, evaluate, and implement the policies and protocols."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.3" ;
    skos:prefLabel "Manage change deployment control"@en .

<http://ots.local/thesaurus/apqc/8_6_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6> ;
    skos:definition "Strategizing and executing changes in IT solutions and services. Create a plan for deploying the changes. Communicate with stakeholders about the changes. Administer and implement the changes. Train the resources who will be affected by these changes. Install changes and verify their effect."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.5" ;
    skos:prefLabel "Perform service and solution rollout"@en .

<http://ots.local/thesaurus/apqc/9_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_1> ;
    skos:definition "Checking and achieving predetermined financial targets and timelines. Assess and manage the profitability, feasibility, and consistency of a business or project. Study the revenues generated."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.1.5" ;
    skos:prefLabel "Evaluate and manage financial performance"@en .

<http://ots.local/thesaurus/apqc/9_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2> ;
    skos:definition "Evaluating and processing requests for advances. Evaluate credit requests by customers requiring loans to buy products/services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.1" ;
    skos:prefLabel "Process customer credit"@en .

<http://ots.local/thesaurus/apqc/9_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2> ;
    skos:definition "Posting entries to respective accounts, and preparing accounts for receivables. Manage the cash collected by the business from its debtors. Record it in the books of accounts to provide clear information about the availability of the cash."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.4" ;
    skos:prefLabel "Manage and process collections"@en .

<http://ots.local/thesaurus/apqc/9_7_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7> ;
    skos:definition "Managing financial services provided by an in-house bank structure in the corporation that is operating like a commercial bank."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.3" ;
    skos:prefLabel "Manage in-house bank accounts"@en .

<http://ots.local/thesaurus/apqc/9_9_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_9> ;
    skos:definition "Processing the taxes of the organization in line with the regional taxation structure, including corporate, property, excise, and service taxes."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.9.2" ;
    skos:prefLabel "Process taxes"@en .

<http://ots.local/thesaurus/apqc/10_4_11> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_4> ;
    skos:definition "Planning and performing waste and hazardous goods management. In compliance with all legal, regulatory, and social/environmental requirements, plan, document, and conduct hazardous material handling, disposal, and reporting."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.4.11" ;
    skos:prefLabel "Perform waste and hazardous goods management"@en .

<http://ots.local/thesaurus/apqc/13_6_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6> ;
    skos:definition "Establishing a foundational plan that guides how an organization manages its content through the content lifecycle. Outlining the strategy for organizing, delivering, and facilitating access to enterprise content."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.1" ;
    skos:prefLabel "Define content management strategy"@en .

<http://ots.local/thesaurus/apqc/13_6_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6> ;
    skos:definition "Creating, acquiring, refining, and maintaining content to ensure it is accurate, relevant, consistent, and aligned with organizational standards and intended use. This includes leveraging all forms of new and evolving technology such as artificial intelligence (AI). Apply metadata, tags, and semantic relationships to improve findability, compliance, and reuse."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.5" ;
    skos:prefLabel "Develop and manage content"@en .

<http://ots.local/thesaurus/apqc/13_7_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_7> ;
    skos:definition "Assessing process data, measures, and trends in an effort to evaluate process performance and identify possible improvements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.7.3" ;
    skos:prefLabel "Evaluate performance"@en .

<http://ots.local/thesaurus/apqc/1_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2> ;
    skos:definition "Formulating a design for the organization's resources that allow it to meet its objectives. Develop a new framework for molding the organization's various processes into a coherent and seamless whole."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.5" ;
    skos:prefLabel "Create organizational design"@en .

<http://ots.local/thesaurus/apqc/2_2_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_2_3> ;
    skos:definition "Determining requirements related to the creation of the product/service. Explain potential achievements that could be made."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.2.3.1" ;
    skos:prefLabel "Define product/service requirements"@en .

<http://ots.local/thesaurus/apqc/3_2_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2> ;
    skos:definition "Establishing marketing communications that deliver promotional messages, in a coordinated way, through multiple marketing channels, such as print, radio, television, direct mail, online or mobile advertising, email, social media or personal selling."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.6" ;
    skos:prefLabel "Develop marketing communication strategy"@en .

<http://ots.local/thesaurus/apqc/3_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3> ;
    skos:definition "Conceptualizing, testing, and executing product/service/brand promotions. Once a promotion has launched, this process continues as the organization tweaks parts of the promotion or chooses to use ideas or lessons learned during the promotion in future activities. The promotion's performance according to organizational measures is also evaluated in this process. Determine early on whether you need third party help with promotion. Purchase lists, consult with social media experts, hire seasonal staff, or pay for additional research."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.4" ;
    skos:prefLabel "Develop and manage promotional activities"@en .

<http://ots.local/thesaurus/apqc/3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_0> ;
    skos:definition "Selling products/services. Set appropriate customer expectations. Work with customers using the same schedule that product/service development, production, and customer service functions follow. Manage sales personnel and sales partnerships/alliances."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5" ;
    skos:prefLabel "Develop and manage sales plans"@en .

<http://ots.local/thesaurus/apqc/3_5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5> ;
    skos:definition "Generating leads of prospective customers to grow the organization's business. Identify viable customers based on customer and market research. Discover leads through IT applications, cold calling, reference/network development, or other sales and business development techniques. Employ a scoring model qualify the prospective customers into leads, and prioritize them."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.1" ;
    skos:prefLabel "Manage leads/opportunities"@en .

<http://ots.local/thesaurus/apqc/3_5_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_4> ;
    skos:definition "Collecting and maintaining all account information. Collect information about the purchase, servicing, return, and/or commitment of any products/services on part of the organization to its customers. Bring together information from various organizational divisions, and update periodically."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.4.2" ;
    skos:prefLabel "Collect and maintain account information"@en .

<http://ots.local/thesaurus/apqc/4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_0> ;
    skos:definition "Creating strategies for production and materials. Handle the demand for the products of the organization. Develop plans for handling materials. Develop and administer the schedule for master production. Plan for distribution requirements and its constraints by reviewing and assessing distribution policies and performance and by establishing quality standards and procedures."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1" ;
    skos:prefLabel "Plan for and align supply chain resources"@en .

<http://ots.local/thesaurus/apqc/4_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_2> ;
    skos:definition "Creating strategies for procuring materials and services from various sources, and for managing and evaluating categories. Establish a procurement process that describes the approach for obtaining products and purchasing activities. Evaluate the sources. Create sourcing relationships in order to continuously improve. Re-evaluate purchasing activities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.2.1" ;
    skos:prefLabel "Provide sourcing governance"@en .

<http://ots.local/thesaurus/apqc/4_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4> ;
    skos:definition "Tracking the inventory deployment. Accept and store products. Ship the products. Measure the accuracy of the inventory. Assess the performance of the outsourced logistics activities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.3" ;
    skos:prefLabel "Operate warehousing"@en .

<http://ots.local/thesaurus/apqc/5_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_2> ;
    skos:definition "Ensuring necessary resources are maintained through monitoring pipeline, developing forecasts, and collaborating with customers. Determine skills needed for service deliver and forecast customer orders. Monitor forecasted orders and modify if where needed. Measure forecast accuracy."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.2.1" ;
    skos:prefLabel "Manage service delivery resource demand"@en .

<http://ots.local/thesaurus/apqc/7_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_0> ;
    skos:definition "Managing the employee reporting processes, employee inquiry process, employee information and data, and the HR information systems. Create and administer the employee metrics. Develop and handle the time and attendance systems. Refurbish the indicators for employee retention and motivation."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.7" ;
    skos:prefLabel "Manage employee information and analytics"@en .

<http://ots.local/thesaurus/apqc/8_0> a skos:Concept ;
    skos:definition "Managing process groups relevant to the business of information technology within an organization. The process groups include \"Develop and manage IT customer relationships\", \"Develop and manage IT business strategy\", \" Develop and manage IT resilience and risk\", \" Manage information\", \" Develop and manage services/solutions\", \"Deploy services/solutions\", and \" Create and manage support services/solutions\"."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.0" ;
    skos:prefLabel "Manage Information Technology (IT)"@en .

<http://ots.local/thesaurus/apqc/8_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_0> ;
    skos:definition "Develop and include the processes required to rapidly adapt and respond to any internal or external opportunity, demand, disruption, or threat to IT and cybersecurity. Build a dynamic, strategic, and integrated approach to managing IT and cyber risks, compliance obligations, and resilience, while ensuring alignment with global standards and frameworks."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3" ;
    skos:prefLabel "Develop and manage IT resilience and risk"@en .

<http://ots.local/thesaurus/apqc/8_3_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3> ;
    skos:definition "The process of identifying, authenticating, and authorizing IT users to have access to applications, systems, IT components, or networks by associating user rights and restrictions with established identities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.8" ;
    skos:prefLabel "Manage IT user identity and authorization"@en .

<http://ots.local/thesaurus/apqc/8_5_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5> ;
    skos:definition "Creating the architecture for the IT services and solutions. Assess architecture and business constraints in order to understand integration requirements. Promote existing architecture. Manage exceptions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.3" ;
    skos:prefLabel "Develop and manage service/solution architecture"@en .

<http://ots.local/thesaurus/apqc/8_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_0> ;
    skos:definition "Establishing and managing services for providing support to users of IT services and solutions. Define the plethora of services by which the organization assists users of computers, software products, or other information technology products."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7" ;
    skos:prefLabel "Create and manage support services/solutions"@en .

<http://ots.local/thesaurus/apqc/8_7_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7> ;
    skos:definition "Developing and managing different delivery services using service delivery systems for operational activities within the IT function in order to achieve organizations goal."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.6" ;
    skos:prefLabel "Develop and manage service delivery operations"@en .

<http://ots.local/thesaurus/apqc/9_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3> ;
    skos:definition "Reporting on the organization's financial status to stakeholders. Include balance sheets, income statements, cash flow statements, and statements of shareholders' equity."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.4" ;
    skos:prefLabel "Perform financial reporting"@en .

<http://ots.local/thesaurus/apqc/9_5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_5> ;
    skos:definition "Managing the total payments made in employees payroll, including bonuses and compensation."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.5.2" ;
    skos:prefLabel "Manage pay"@en .

<http://ots.local/thesaurus/apqc/9_7_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7> ;
    skos:definition "Managing rules and regulations for investments in trading in bonds, currencies, financial derivatives, etc. Establish policies and procedures for investments made. Optimize liquidity in treasury operations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.1" ;
    skos:prefLabel "Manage treasury policies and procedures"@en .

<http://ots.local/thesaurus/apqc/9_7_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7> ;
    skos:definition "Taking care of all cash-related activities in the business. Manage and reconcile cash positions. Manage cash equivalents. Process and oversee electronic fund transfers. Develop cash flow forecasts. Manage cash flows. Produce cash management accounting transactions and reports. Manage and oversee banking relationships. Analyze, negotiate, resolve, and confirm bank fees."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.2" ;
    skos:prefLabel "Manage cash"@en .

<http://ots.local/thesaurus/apqc/9_7_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7> ;
    skos:definition "Taking care of the organization's financial position. Manage its loans or debts from different sources and investments. Leverage the most profitable options to balance the financial position in the market."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.4" ;
    skos:prefLabel "Manage debt and investment"@en .

<http://ots.local/thesaurus/apqc/11_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_1> ;
    skos:definition "Coordinating to plan, organize, lead, and control the activities of an organization in order to minimize the special effects of risk on capital and earnings."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.1.2" ;
    skos:prefLabel "Oversee and coordinate enterprise risk management activities"@en .

<http://ots.local/thesaurus/apqc/11_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_2> ;
    skos:definition "Obeying laws, guidelines, strategies, and stipulations related to the business."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.2.2" ;
    skos:prefLabel "Manage regulatory compliance"@en .

<http://ots.local/thesaurus/apqc/12_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_0> ;
    skos:definition "Managing legal practices to abide by the law, as well as ethical practices."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.4" ;
    skos:prefLabel "Manage legal and ethical issues"@en .

<http://ots.local/thesaurus/apqc/13_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4> ;
    skos:definition "Developing plans for change management, training, communication, and rewards/incentives. Establish metrics for measuring the change adoption. Clarify new roles for employees. Identify budgets."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.2" ;
    skos:prefLabel "Design the change"@en .

<http://ots.local/thesaurus/apqc/13_5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_5> ;
    skos:definition "Creating a plan for managing the organization's knowledge base. Determine what kind of specialized knowledge the organization possesses, which elements of this collective knowledge can prove beneficial, how to capture and maintain this knowledge, how to grant access to this library of information, and how the organization should proceed."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.5.1" ;
    skos:prefLabel "Develop KM strategy"@en .

<http://ots.local/thesaurus/apqc/1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_0> ;
    skos:definition "Developing an organization's mission statement, strategy, and business design. Create a concise statement that clearly articulates the mission of the organization, outlining practicable targets to Establish a strategic vision [10020]. Delineate strategic options by matching these alternatives with the organization's internal capabilities. Create an organizational design, and identify goals by developing strategies at the functional and process levels."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2" ;
    skos:prefLabel "Develop business strategy"@en .

<http://ots.local/thesaurus/apqc/3_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2> ;
    skos:definition "Establishing all the activities needed to identify the appropriate channels to market to different customer segments as defined in Determine target segments [10117]. This involves finding channel partners, ensuring that the channels align with organizational strategy for each segment, and the final channel selection process."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.4" ;
    skos:prefLabel "Define and manage channel strategy"@en .

<http://ots.local/thesaurus/apqc/3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_0> ;
    skos:definition "Creating specific plans to market offerings to customers. This process group includes processes for making budgets, identifying and developing media, pricing products and services, managing packaging, managing marketing content and promotional activities, tracking and responding to customer insight and monitoring measures established within \"develop marketing strategy\". Additionally, in this process group, organizations take action on plans made in earlier processes. Here, marketing and customers are managed and measured along with any supporting materials."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3" ;
    skos:prefLabel "Develop and manage marketing plans"@en .

<http://ots.local/thesaurus/apqc/4_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1> ;
    skos:definition "Creating strategies for production processes, as well as the process of managing materials. Define production and supply constraints. Design a blueprint of the workplace. Establish rules and regulations regarding the employees, outsourcing of services, and the expenditure to be incurred on the manufacturing capital."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.1" ;
    skos:prefLabel "Develop production and materials strategies"@en .

<http://ots.local/thesaurus/apqc/7_0> a skos:Concept ;
    skos:definition "Delivering processes traditionally defined as \"human resources\". Process groups include those related to developing and maintaining workforce strategy, recruiting employees, developing and counseling employees, managing employee relations, rewarding and retaining employees, redeploying and retiring employees, managing employee information, and managing employee communications."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.0" ;
    skos:prefLabel "Develop and Manage Human Resources"@en .

<http://ots.local/thesaurus/apqc/7_5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_5> ;
    skos:definition "Developing a salary/compensation structure and plan; developing a benefits and reward plan; develop commission plan; performing competitive analyses of benefits and rewards; identifying compensation requirements based on compensation, benefits, and HR policies; administering compensation, commission, and rewards to employees; and rewarding and motivating employees."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.5.1" ;
    skos:prefLabel "Develop and manage reward, recognition, and motivation programs"@en .

<http://ots.local/thesaurus/apqc/8_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1> ;
    skos:definition "Understanding the necessity of IT transformation for the business. This is inclusive of all forms of new and evolving technology such as artificial intelligence (AI). Collect and analyze customer requirements. Identify opportunities and prioritize outcomes. Develop and support business case for transformation. Develop transformation plan and roadmap."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.4" ;
    skos:prefLabel "Provide IT transformation guidance"@en .

<http://ots.local/thesaurus/apqc/8_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2> ;
    skos:definition "Regulating the IT management system through performance measures, governance, analysis, and monitoring through a variety of analytic tools. Evaluate IT finances, resource, services, projects, and value for report out."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.5" ;
    skos:prefLabel "Control IT management system"@en .

<http://ots.local/thesaurus/apqc/8_6_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6> ;
    skos:definition "Deploy the identified solutions for information technology important for healthy business operations. Confirm status and operational availability of IT resources. Perform testing and distribution of change. Execute roll-back protocol if necessary."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.4" ;
    skos:prefLabel "Implement technology solutions"@en .

<http://ots.local/thesaurus/apqc/9_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3> ;
    skos:definition "Applying basic principles, concepts, and accounting practices in recording and preparing final accounts, and using accounting information in management."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.2" ;
    skos:prefLabel "Perform general accounting"@en .

<http://ots.local/thesaurus/apqc/9_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3> ;
    skos:definition "Accounting for long-term and fixed assets. Record purchased, fixed assets that are not easily convertible into cash. Account for costs, useful life, resale value, depreciation, and amortization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.3" ;
    skos:prefLabel "Perform fixed-asset accounting"@en .

<http://ots.local/thesaurus/apqc/1_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_1> ;
    skos:definition "Assessing all forces, entities, and systems that are external to an organization but can affect its operation. Analyze far-reaching currents in the macroeconomic situation, assess the competition, evaluate technological changes, and identify societal as well as ecological issues of concern. Create a big-picture understanding of externalities, with sufficient depth across individual aspects."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1.1" ;
    skos:prefLabel "Assess the external environment"@en .

<http://ots.local/thesaurus/apqc/2_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1> ;
    skos:definition "Controlling/authorizing to enable services' and products' data and other critical data of these functions through a well secured storage and accessibility processes backed by siloed applications/IT systems."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.4" ;
    skos:prefLabel "Manage product and service master data"@en .

<http://ots.local/thesaurus/apqc/6_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3> ;
    skos:definition "Identifying, investigating, and processes warranty claims. This process includes: receipt and validation of a warranty claim; definition and diagnosis /root cause analysis of an issue and recommendation for corrective action; the determination of responsibility for settlement of the claim; the transaction being approved or denied; and the originator being notified and payment authorized. In the case of a recurring event, further investigation (definition and diagnosis or root cause analysis) is performed, and a recommendation for corrective action is made and implemented in production/design. It ends when the claim is closed."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.2" ;
    skos:prefLabel "Process warranty claims"@en .

<http://ots.local/thesaurus/apqc/7_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1> ;
    skos:definition "Creating a long-term plan that strategically aligns human resources with the company's goals. The HR function's focus is to ensure the organization has the necessary talent and capabilities to achieve its objectives, sustain its competitive advantage, and reduce employee turnover."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.1" ;
    skos:prefLabel "Develop human resources strategy"@en .

<http://ots.local/thesaurus/apqc/8_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3> ;
    skos:definition "Ensuring that the organization effectively manages IT and cybersecurity risks by developing rules, standards, and strategies that safeguard the confidentiality, integrity, and availability of IT and OT assets. Establish compliance objectives, align with recognized cybersecurity frameworks, and integrate IT and OT risk management to create a unified approach."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.1" ;
    skos:prefLabel "Develop IT compliance, risk, and security strategy"@en .

<http://ots.local/thesaurus/apqc/8_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3> ;
    skos:definition "Ensuring effective control over IT and cybersecurity risks, compliance obligations, and security measures. Formulate and execute guidelines in line with regulatory bodies and organizational security objectives. Implement proactive measures such as threat intelligence, vulnerability management, and OT-specific controls to safeguard the organization’s IT and OT environments. This is inclusive of all forms of new and evolving technology such as artificial intelligence (AI)."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.3" ;
    skos:prefLabel "Control IT risk, compliance, and security"@en .

<http://ots.local/thesaurus/apqc/8_7_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7> ;
    skos:definition "Develop strategies and methodologies to provide service support. Examine service levels, support complexity, stakeholder requirements to offer service support."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.5" ;
    skos:prefLabel "Define service support planning"@en .

<http://ots.local/thesaurus/apqc/9_11> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_0> ;
    skos:definition "Making and collecting payments for transactions in products/services, and transporting them to interested markets."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.11" ;
    skos:prefLabel "Perform global trade services"@en .

<http://ots.local/thesaurus/apqc/10_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_0> ;
    skos:definition "Managing the disposition of assets at their end-of-life. End-of-life for an asset may be due to obsolescence, replacement, excess capacity, or disrepair among other potential factors. Steps may include decommissioning, disassembly, recycling, etc. Tracking and reporting may also be appropriate for some or all asset types due to law, regulation, or social/environmental responsibility."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.4" ;
    skos:prefLabel "Manage asset end-of-life"@en .

<http://ots.local/thesaurus/apqc/13_0> a skos:Concept ;
    skos:definition "Performing activities by an organization that are fundamental to the successful operation of the organization, even across functions in a business. Capabilities defined in the PCF include business process management; portfolio, program, and project management; quality management; change management; benchmarking; environmental health and safety management; and knowledge management."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.0" ;
    skos:prefLabel "Develop and Manage Business Capabilities"@en .

<http://ots.local/thesaurus/apqc/13_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_0> ;
    skos:definition "Creating new and improving existing analytical capabilities to enhance data management pipeline."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.8" ;
    skos:prefLabel "Develop, Manage, and Deliver Analytics"@en .

<http://ots.local/thesaurus/apqc/1_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2> ;
    skos:definition "Assessing sets of strategic decisions designed to drive the organization's long-term objectives. Identify various strategies concerning core functional areas. Appraise strategic options in light of auxiliary decision frameworks that ensure smooth functioning, the advancement of functional efficiencies, and vitality. Involve senior management executives, especially strategy and/or business unit personnel, with need-based consultative assistance from professional services providers."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.2" ;
    skos:prefLabel "Define and evaluate strategic options to achieve the mission"@en .

<http://ots.local/thesaurus/apqc/9_6_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_6> ;
    skos:definition "Processing payments of operating expenses and other supplier charges. This includes the development of policies and procedures around processing of accounts payable and all operations. This process is often supported by key technology enablers."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.6.1" ;
    skos:prefLabel "Process accounts payable (AP)"@en .

<http://ots.local/thesaurus/apqc/3_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3> ;
    skos:definition "Determining and maintaining a pricing mechanism based on forecasted sales and that enables a pricing equilibrium for the lifecycles of products/services. Create a pricing mechanism, factoring in attributes relating to the market, customers, sales, and the cost of production. Implement this pricing mechanism over all products/services. Analyze its performance, and adjust accordingly."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.3" ;
    skos:prefLabel "Develop and manage pricing"@en .

<http://ots.local/thesaurus/apqc/3_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_4> ;
    skos:definition "Cultivating an alliance of partners by identifying, analyzing, negotiating, and managing partnerships with other economic agents."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.4.2" ;
    skos:prefLabel "Develop sales partner/alliance relationships"@en .

<http://ots.local/thesaurus/apqc/4_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1> ;
    skos:definition "Maintaining master data of finished products and inventory. Identify the requirements of finished products at the destination, as well as partner requirements. Calculate the consolidation at source. Manage replenishment planning. Create and administer a dispatch plan. Calculate load plans for destinations and partners. Manage the cost of supplying these products. Ensure effective utilization of capacity."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.5" ;
    skos:prefLabel "Plan distribution requirements"@en .

<http://ots.local/thesaurus/apqc/9_0> a skos:Concept ;
    skos:definition "Overseeing key back-office processes for organizations. This category includes process groups related to planning and management accounting, revenue accounting, general accounting and reporting, fixed-asset project accounting, payroll, accounts payable and expense reimbursements, treasury operations, internal controls, tax management, international funds/consolidation, and global trade services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.0" ;
    skos:prefLabel "Manage Financial Resources"@en .

<http://ots.local/thesaurus/apqc/2_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3> ;
    skos:definition "Sketching and standardizing product and service based on the market. Analyze the data market competitiveness and innovation attained for the product and service development."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.1" ;
    skos:prefLabel "Design and prototype products and services"@en .

<http://ots.local/thesaurus/apqc/13_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4> ;
    skos:definition "Evaluating impact and planning change activities. Spanning the lifecycle of change from initial concept, to designing, implementing, and sustaining the change, change planning identifies the activities to enage and enable the stakeholders and all impacted by the change. Change plans should address the interplay between people, process, technology, and knowledge to guide the transition, or tranformation, from current state to the future state."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.1" ;
    skos:prefLabel "Plan for change"@en .

<http://ots.local/thesaurus/apqc/3_5_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5> ;
    skos:definition "Understanding and refining the customer requirements as provided in a RFP (Request for Proposal) or RFI (Request for Information).  When compiling the response, they must take into consideration whether the requirements are a match with the strategic or tactical plans of the organization and whether they are able to submit a bid/proposal that is competitive based on an understanding of the offerings of other competing organizations. The next step will be to define the pricing and scheduling of the proposed solution and determine whether the proposal will be profitable for the company if accepted. The bid is then submitted and a notification of whether or not it was successful is received."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.3" ;
    skos:prefLabel "Develop and manage sales proposals, bids, and quotes"@en .

<http://ots.local/thesaurus/apqc/7_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1> ;
    skos:definition "Creating and executing strategies and policies for smooth administration of workforce. Determine and gather skill requirements. Plan the requirements for employee resourcing per unit. Create compensation, succession, HR program, and employee diversity plans. Develop and administer policies for HR. Develop benefits for employees. Create models for work force strategies."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.2" ;
    skos:prefLabel "Develop and implement workforce planning, policies, and strategies"@en .

