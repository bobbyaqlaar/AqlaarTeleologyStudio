    skos:definition "Conducting reviews to assess customer credit on a yearly basis. Introduce changes or make recommendations, if needed."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.5.4.4" ;
    skos:prefLabel "Perform annual customer credit reviews"@en .

<http://ots.local/thesaurus/apqc/9_7_5_5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_5_5> ;
