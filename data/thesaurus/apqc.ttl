    skos:definition "Link Market segments & available product families processes analyze the basic consumption profiles of market segments and associate these with the product families available.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7399" ;
    skos:prefLabel "Link consumption profiles & available product families"@en .

