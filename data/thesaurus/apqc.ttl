<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA1_EA7402> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA1_EA7364> ;
    skos:definition "Define Market Problem Research Objectives business activity is in charge of establishing objectives relevant and suitable for a market problem research plan. <br/><br/>This business activity includes tasks that ensure the market problem research objectives are instrumental to developing answers to a market problem.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7402" ;
    skos:prefLabel "Define Market Problem Research Objectives"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA1_EA7403> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA1_EA7364> ;
    skos:definition "Develop Market Problem Research Approach business activity is in charge of defining the manner by which to embark on the market problem research. <br/><br/>This business activity includes tasks that ensure the market problem research plan can apply an effective methodology to the research plan to achieve the research objectives.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7403" ;
    skos:prefLabel "Develop Market Problem Research Approach"@en .

