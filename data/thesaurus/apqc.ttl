<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10279> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10206> ;
    skos:definition "Collect Learner Feedback business activity supports 'Evaluate Learning Program' by managing activities that result in receiving information from learners about the learning program.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10279" ;
    skos:prefLabel "Collect Learner Feedback"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10280> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10206> ;
    skos:definition "Assess Learning Performance business activity analyzes the learning activities that support a learning program to evaluate levels of understanding of curriculum and content used in learning programs. Assess Learning Performance helps to acquire learning performance information from both the learning program, and individual learning plans using any or both of direct and indirect approach.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10280" ;
    skos:prefLabel "Assess Learning Performance"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10281> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10611> ;
    skos:definition "Design Enterprise Performance Assessment Plan business activity decides the tasks, details and the model for executing enterprise performance assessment.<br/><br/>This business activity will include tasks to articulate assessment inputs, outcome/goals to focus on, determines evidence/indicators to be gathered, and defines criteria to use in determining enterprise performance effectiveness and/or success.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10281" ;
    skos:prefLabel "Design Enterprise Performance Assessment Plan"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10282> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10611> ;
    skos:definition "Implement Enterprise Performance Assessment Plan business activity device and apply the tasks, details and models for enterprise performance assessment. Through 'Implement Enterprise Performance Assessment Plan', the enterprise is able to observe and evaluate performance according to the enterprise performance goals set.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10282" ;
    skos:prefLabel "Implement Enterprise Performance Assessment Plan"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10283> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10611> ;
    skos:definition "Collect Enterprise Performance Assessment Data business activity is responsible for gathering all data and information need to successfully support evaluating enterprise performance.<br/>This business activity will also include cleaning, storing, preparing and sharing enterprise performance assessment data.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10283" ;
    skos:prefLabel "Collect Enterprise Performance Assessment Data"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10284> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10611> ;
    skos:definition "Evaluate Enterprise Performance business activity is responsible for deducing/calculating performance results according to well-defined enterprise performance goals and objectives (quality, importance, amount, or value etc.). Evaluate Enterprise Performance business activity decides the overall performance results of the enterprise.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10284" ;
    skos:prefLabel "Evaluate Enterprise Performance"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10285> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10611> ;
    skos:definition "Identify Enterprise Performance Gap business activity is in charge of establishing the difference between intended and actual enterprise performance targets or performance standards based on performance goals and objectives.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10285" ;
    skos:prefLabel "Identify Enterprise Performance Gap"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10286> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10235> ;
    skos:definition "Develop Training Implementation Method business activity generate the details that support executing the training plan's chosen method.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10286" ;
    skos:prefLabel "Develop Training Implementation Method"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10287> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10235> ;
    skos:definition "Develop Training Evaluation Model business activity generate the appraisal and rating structure to support the training plan.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10287" ;
    skos:prefLabel "Develop Training Evaluation Model"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10288> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10235> ;
    skos:definition "Design Training Facility business activity defines the specification required to support a training Plan.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10288" ;
    skos:prefLabel "Design Training Facility"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10289> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10303> ;
    skos:definition "Design Program Vision & Goals business activity is in charge of setting the program vision, program goals and course of action for programs.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10289" ;
    skos:prefLabel "Design Program Vision & Goals"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10290> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10303> ;
    skos:definition "Formulate Program business activity is in charge of choosing the who, what, how, when, and where of pursuing program objectives according to program vision and goals.<br/><br/>Formulate Program business activity include tasks that define project specifications, provide framework for different projects to share similar overall objectives in coordinated manner.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10290" ;
    skos:prefLabel "Formulate Program"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10291> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10315> ;
    skos:definition "Create Stakeholder Privacy Policy Agreement process provides the organization the ability to create privacy agreements with members or groups without whose support the organization will not be successful. <br/>Stakeholders covered in here include governments, trade association, shareholders etc.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10291" ;
    skos:prefLabel "Create Stakeholder Privacy Policy Agreement"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10292> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10315> ;
    skos:definition "Assign Stakeholder Privacy Policy Agreement process provides the organization the ability to assign privacy agreements to stakeholders.<br/>Stakeholders covered in here include governments, trade association, shareholders etc.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10292" ;
    skos:prefLabel "Assign Stakeholder Privacy Policy Agreement"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10293> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10315> ;
    skos:definition "Administer Stakeholder Privacy Policy Agreement process provides the organization the ability to ensure performance privacy agreements by employees.<br/>Stakeholders covered in here include governments, trade association, shareholders etc.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10293" ;
    skos:prefLabel "Administer Stakeholder Privacy Policy Agreement"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10294> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10315> ;
    skos:definition "Renew Stakeholder Privacy Policy Agreement process provides the organization the ability to ensure privacy profile agreements are always in effect across tenures.<br/>Stakeholders covered in here include governments, trade association, shareholders etc.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10294" ;
    skos:prefLabel "Renew Stakeholder Privacy Policy Agreement"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10295> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10580> ;
    skos:definition "Planning and implementation of cross-business unit operation. These processes are responsible for planning and management of coordination across business units within the enterprise, and between the enterprise and its subsidiaries (note that similar interactions concerning outsourcing involving other parties is handled elsewhere, through processes located in the Engaged Party Domain). The focus is on processes concerned with the co-ordination within the enterprise's own organization, including subsidiaries, from an Enterprise-wide point of view.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10295" ;
    skos:prefLabel "Plan & Implement Cross-Business Unit Operation"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10296> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10580> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10296" ;
    skos:prefLabel "Harmonize Processes & Communication Systems across Business Units"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10297> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10580> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10297" ;
    skos:prefLabel "Manage Funding & Cross-Subsidies across Business Units"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10298> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10580> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10298" ;
    skos:prefLabel "Manage Investment for Business Development"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10299> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10580> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10299" ;
    skos:prefLabel "Co-ordinate Business Activities"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10300> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10605> ;
    skos:definition "Define Enterprise Performance Goal business activity state and describe the enterprise performance objectives and targets that express a commitment to achieve specified results in a certain period of time.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10300" ;
    skos:prefLabel "Define Enterprise Performance Goals"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10301> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10605> ;
    skos:definition "Map Enterprise Performance Goals business activity is in charge of plotting defined enterprise performance goals to enterprise goals in order to turn enterprise resources into desired outcome.<br/>Map Enterprise Performance Goals helps in applying systems thinking to the enterprise strategic management goals by identifying and linking enterprise performance inputs, processes and enterprise performance objectives.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10301" ;
    skos:prefLabel "Map Enterprise Performance Goals (to Strategy)"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10302> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10605> ;
    skos:definition "Establish Enterprise Performance Quality Management Policy sets up and institutionalizes policies for quality performance management that achieve organization-wide acceptance and recognition.<br/><br/>Establish Enterprise Performance Quality Management Policy business activities will also define the enterprise quality management policies and the enterprise model for quality management. They support all operations and lifecycle processes in the implementation and control of this model.<br/><br/>Note that quality is actually assessed within each area of the enterprise, but follows the guidelines defined by this process, which provides a template for specific applications of quality management in any areas of the Enterprise<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10302" ;
    skos:prefLabel "Establish Enterprise Performance Quality Management Policy"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10306> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10519> ;
    skos:definition "Manage Program Closure business activity is in charge of directing and controlling the steps to bring an active enterprise program to an end. <br/><br/>Manage Program Closure business activity helps to evaluate, transition, and improve the enterprises Manage Program capability over time. Manage Program Closure activity includes tasks that will capture lessons learned, opportunities for improvement and any other associated know-how.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10306" ;
    skos:prefLabel "Manage Program Closure"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10307> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10519> ;
    skos:definition "Analyze Program Performance business activity is in charge of examining and identifying Program Design vision and goals compared with actual Program results and outcome.<br/><br/>Analyze Program Performance business activity includes tasks that compare scope, cost, schedule, and other resources used in order to determine how well the program met its objectives. Without Analyze Program Performance business activity, the enterprise is not able to know the effectiveness of a Program and inputs to enable successful Program Closure.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10307" ;
    skos:prefLabel "Analyze Program Performance"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10308> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10465> ;
    skos:definition "Modify Employee Privacy Profile process is used to modify the rules of privacy profiles following an agreement of a privacy profile between a data processing entity and an employee.<br/>Such modifications may occur in the Dashboard and honored according to the requirements stipulated by a by privacy policy type.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10308" ;
    skos:prefLabel "Modify Employee Privacy Profile"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10309> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10465> ;
    skos:definition "Erase Employee Privacy Profile Information process ensures all employee information referenced in the Privacy Profile according to data processing entity rules are erased.<br/>It can be done according to employees' request, or retention rules.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10309" ;
    skos:prefLabel "Erase Employee Privacy Profile Information"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10310> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10465> ;
    skos:definition "Import Employee Privacy Profile process ingests the privacy profile pre-defined by an employee and integrates it into the privacy profile.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10310" ;
    skos:prefLabel "Import Employee Privacy Profile"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10311> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10465> ;
    skos:definition "Enforce Employee Privacy Profile process manages the application of the Employee privacy profile so that any third party processing such data can comply with mandatory legislation, and the agreed wish of the enterprise's employees.<br/>For each action performed by the third party processing personal identifiable information data of the employee, the third party processing such data must ensure their action is compliant with the rules set by default, and validated or amended by the employee.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10311" ;
    skos:prefLabel "Enforce Employee Privacy Profile"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10312> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10465> ;
    skos:definition "Send Employee Privacy Profile process manages the application of privacy policy rules when personal identifiable information must be sent to a data processing entity. <br/>It applies the external rules, then transforms the existing employee privacy profile external rules into internal rules, in order the Data Processor Party can import it into its Privacy Management.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10312" ;
    skos:prefLabel "Send Employee Privacy Profile"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10313> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10465> ;
    skos:definition "Receive Employee Privacy Profile process is used to receive an Employee Profile from a data processing entity.<br/>This process ensures that all the authorization required are agreed by the employee, else a request for changing it will be triggered.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10313" ;
    skos:prefLabel "Receive Employee Privacy Profile"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10316> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10421> ;
    skos:definition "Acquire Knowledge business activity handles gathering or collecting knowledge from various sources, including discovering knowledge based on value it brings to the organization. This business activity adds new knowledge to a knowledge base and support 'Refine Knowledge', 'Distribute Knowledge' and 'Apply Knowledge'.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10316" ;
    skos:prefLabel "Acquire Knowledge"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10317> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10421> ;
    skos:definition "Organize Knowledge business activity handles the classification, mapping, indexing, and categorization of knowledge to support activities that acquire, store and retrieve knowledge. The enterprise needs to make connections between different knowledge objects. With connections from knowledge objects, the enterprise structures knowledge in a way that accurately and meaningfully organizes knowledge for refinement, storage, distribution and application. Organize Knowledge uses \"systems\" and processes to generate, transform, manage, use, and transfer knowledge-based products and services to achieve enterprise business goals and objectives.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10317" ;
    skos:prefLabel "Organize Knowledge"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10318> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10421> ;
    skos:definition "Refine Knowledge business activity handles the evaluation, analysis and optimization of knowledge to be stored by the enterprise. Refine Knowledge enables the enterprise to iteratively improve its knowledge operations activities in an effort to improve the quality of the enterprises knowledge objects.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10318" ;
    skos:prefLabel "Refine Knowledge"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10319> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10421> ;
    skos:definition "Store Knowledge business activity handles the storage of knowledge objects to support the enterprises knowledge management goals. Store knowledge ensures the organization can formally account for knowledge it in its possession through well-defined storage medium/media.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10319" ;
    skos:prefLabel "Store Knowledge"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10320> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10421> ;
    skos:definition "Distribute Knowledge business activity handles tasks that assign and share knowledge among enterprise business functions through various defined techniques, people, and technologies.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10320" ;
    skos:prefLabel "Distribute Knowledge"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10321> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10578> ;
    skos:definition "Develop concepts for new revenue streams, and diversification of revenue streams. The focus is on broadening the scope of the enterprise activities through expansion, or sharpening the enterprise focus through divestment or outsourcing of non-critical activities. The Marketing & Offer Management processes are responsible for the development of markets and products within the existing scope of the enterprise. Business Development processes understand what processes are critical to the identity of the enterprise as priority processes and look for higher quality and lower cost solutions for these high priority processes. Business Development processes are closely related to Strategic Planning.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10321" ;
    skos:prefLabel "Develop Concepts for Revenue Streams"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10322> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10578> ;
    skos:definition "Focus or broaden the customer base via investigating new markets, as well as different products and services for the enterprise. The focus is on broadening the scope of the enterprise activities through expansion, or sharpening the enterprise focus through divestment or outsourcing of non-critical activities. The Marketing & Offer Management processes are responsible for the development of markets and products within the existing scope of the enterprise. Business Development processes understand what processes are critical to the identity of the enterprise as priority processes and look for higher quality and lower cost solutions for these high priority processes. Business Development processes are closely related to Strategic Planning.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10322" ;
    skos:prefLabel "Focus or Broaden Customer Base"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10323> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10578> ;
    skos:definition "Identify the opportunity for a surgical outsourcing of a function or process that is not a priority of the enterprise, or is a process the enterprise cannot deliver at competitive benchmarks. The focus is on broadening the scope of the enterprise activities through expansion, or sharpening the enterprise focus through divestment or outsourcing of non-critical activities. The Marketing & Offer Management processes are responsible for the development of markets and products within the existing scope of the enterprise. Business Development processes understand what processes are critical to the identity of the enterprise as priority processes and look for higher quality and lower cost solutions for these high priority processes. Business Development processes are closely related to Strategic Planning.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10323" ;
    skos:prefLabel "Identify Outsourcing Opportunities"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10324> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10578> ;
    skos:definition "Manage investigation of potential merger and acquisition options to realize certain enterprise strategies The focus is on broadening the scope of the enterprise activities through expansion, or sharpening the enterprise focus through divestment or outsourcing of non-critical activities. The Marketing & Offer Management processes are responsible for the development of markets and products within the existing scope of the enterprise. Business Development processes understand what processes are critical to the identity of the enterprise as priority processes and look for higher quality and lower cost solutions for these high priority processes. Business Development processes are closely related to Strategic Planning.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10324" ;
    skos:prefLabel "Investigate Potential Mergers & Acquisitions"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10325> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10578> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10325" ;
    skos:prefLabel "Facilitate Negotiation & Implementation of Potential Mergers & Acquisitions"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10326> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10442> ;
    skos:definition "Ensure Tax compliance refers to fulfilling legal obligations related to taxation imposed by the government. The primary objective is to ensure timely and accurate filing of tax returns in accordance with tax laws and regulations. It involves:<br/><br/>1. Accurate calculation and reporting of taxable income and deductions.<br/>2. Timely submission of tax returns and necessary documentation.<br/>3. Prompt payment of due taxes (including estimated taxes, employment taxes, and sales taxes).<br/>4. Maintaining accurate records for tax-related transactions.5. Honesty, transparency, and adherence to all legal tax obligations.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10326" ;
    skos:prefLabel "Ensure Tax Compliance"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10327> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10442> ;
    skos:definition "Plan Tax Strategy process involves analyzing and arranging the organization's financial situation to maximize tax breaks and minimize tax liabilities legally and efficiently. Following are some key concepts:<br/><br/>1. Understanding applicable Tax Brackets<br/>2. Using Tax Credits and Deductions<br/>3. Choosing between Standard Deduction and Itemizing<br/>4. Leveraging Tax-Advantaged Accounts<br/>5. Keeping Good Records<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10327" ;
    skos:prefLabel "Plan Tax Strategy"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10328> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10442> ;
    skos:definition "Conduct Internal Audits involves planning, auditing, reporting, and monitoring steps. By catching and correcting issues before external audits, internal audits enhance overall organizational effectiveness. An internal audit is a systematic and independent examination process conducted within an organization. Its purpose is to evaluate and improve internal controls, risk management practices, and compliance with applicable laws and regulations. Internal auditors assess various aspects, including financial processes, corporate governance, and operational efficiency. The process typically<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10328" ;
    skos:prefLabel "Conduct Internal Audits"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10329> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10603> ;
    skos:definition "Control Accountability business activity is in charge of overseeing and regulating lines of command and responsibility.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10329" ;
    skos:prefLabel "Control Accountability"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10330> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10603> ;
    skos:definition "Establish Accountability Framework business activity is in charge of defining and setting up the structure for lines of command, responsibility and communication of execution plans . <br/><br/>Establish Accountability Framework business activity ensure valid and integral representation of the chain of responsibilities that put decisions or implementation plans into effect.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10330" ;
    skos:prefLabel "Establish Accountability Framework"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10331> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10364> ;
    skos:definition "Initiate Project business activity handle tasks that are performed to define a new project according to an enterprises program vision and goals.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10331" ;
    skos:prefLabel "Initiate Project"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10332> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10364> ;
    skos:definition "Plan Project business activity handle tasks that are performed to establish the scope of a project, and define the course of action required to meet the objectives of the overarching enterprise program. <br/><br/>Plan Project business activity includes tasks that define monitoring and controlling activities required to successfully execute the project.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10332" ;
    skos:prefLabel "Plan Project"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10333> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10364> ;
    skos:definition "Execute Project business activity handle tasks that complete work or actions as defined in the project plan.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10333" ;
    skos:prefLabel "Execute Project"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10334> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10364> ;
    skos:definition "Report Project business activity handle tasks that provide account of status and progress of a project.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10334" ;
    skos:prefLabel "Report Project"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10335> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10364> ;
    skos:definition "Close Project business activity handle tasks that finalize all work and actions across all Manage Project activities to formally bring a project to an end.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10335" ;
    skos:prefLabel "Close Project"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10336> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10419> ;
    skos:definition "Define Knowledge Management Lifecycle business activity is responsible for describing all the stages that support knowledge management across the enterprise. Define Knowledge Management Lifecycle defines 'who', 'what', 'when', 'where' and 'how' of activities that support institutionalizing and operationalizing knowledge management. This includes description of expectation for the creation, sharing, auditing, organizing and storage of knowledge in support of the enterprises business goals.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10336" ;
    skos:prefLabel "Define Knowledge Management lifecycle"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10337> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10419> ;
    skos:definition "Implement Knowledge Management Capability business activity puts into effect the required capabilities (processes, people and technology) that support operationalizing knowledge management activities. Implement Knowledge Management Capability covers the processes and mechanisms that support the acquisition to dissemination of knowledge within the enterprises business functions, and with stakeholders.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10337" ;
    skos:prefLabel "Implement Knowledge Management capability"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10341> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10607> ;
    skos:definition "Define Performance Measurement Purpose business activity state and describe the exact scope and meaning of enterprise performance measures in accordance with the enterprise performance goals and plan for enterprise performance management as a whole.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10341" ;
    skos:prefLabel "Define Performance Measurement Purpose"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10342> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10607> ;
    skos:definition "Map Enterprise Performance Results business activity assign appropriate relations to connect performance measures with performance results.<br/>Map Enterprise Performance Results rely on enterprise performance models to provide a line of sight from the enterprise goals directly to recommended learning activities. Mapping performance results drives decisions when correlating strategies to enterprise activities.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10342" ;
    skos:prefLabel "Map Enterprise Performance Results"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10343> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10607> ;
    skos:definition "Design Enterprise Performance Measures & Metrics business activity is in charge of conceiving and defining enterprise performance measures and metrics in accordance with the enterprise performance measurement purpose.<br/><br/>This business activity ensures that the organization can define and determine the most appropriate performance measures based on the enterprises goals. The measures may be internally developed, or may be based on externally produced or collected measures.<br/><br/>Examples of external measures could be customer satisfaction surveys, within or across market segments, or benchmarking studies of particular aspects of the enterprise performance. Examples of internal performance measures can be based on financial performance (i.e. progress against budget), operational process performance based metrics, or employee related measures such as employee opinion surveys.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10343" ;
    skos:prefLabel "Design Enterprise Performance Measures & Metrics"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10344> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10607> ;
    skos:definition "Implement Enterprise Performance Measures & Metrics business activity is in charge of putting into effect enterprise performance measures and metrics.<br/>Implement Performance Measures and Metrics identify the organization unit/function/entity to be responsible for the performance measure in order to support the activity of performance reporting.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10344" ;
    skos:prefLabel "Implement Enterprise Performance Measures & Metrics"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10345> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10607> ;
    skos:definition "Collect Enterprise Performance Measures business activity is in charge of identifying and gathering the quantification of performance attributes of an enterprise according to performance objectives.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10345" ;
    skos:prefLabel "Collect Enterprise Performance Measures"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10346> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10607> ;
    skos:definition "Analyze Enterprise Performance Measures & Metrics business activity examine (or inspect) methodically details of enterprise performance measures and their correlated metrics in order to support explainability and interpretability.<br/>This business activity is responsible for scrutinizing and decomposing measures and metrics, resolving relationships between metrics and measures, and discovering or revealing relevance to the enterprise.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10346" ;
    skos:prefLabel "Analyze Enterprise Performance Measures & Metrics"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10347> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10607> ;
    skos:definition "Report Enterprise Performance Measures business activity provide observed account of enterprise performance according the enterprises' requirement.<br/><br/>Report Performance Measures business activity presents to management and decision makers (including executive managers, boards of directors, etc.) well-defined and described detail of performance metrics on a regular basis.<br/><br/>This business activity checks that the goals defined for the enterprise are on track and being met. These processes produce the enterprise Balanced Scorecard. Also produce summary reports.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10347" ;
    skos:prefLabel "Report Enterprise Performance Measures"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10349> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10192> ;
    skos:definition "Communicate Procedure business activity is in charge of sharing or exchanging information on the existence and 'how to' of well-defined course/plan of performing activities (e.g. workflows) with parties concerned or having interest in a procedure.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10349" ;
    skos:prefLabel "Communicate Procedure"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10350> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10192> ;
    skos:definition "Create Procedure business activity is in charge of establishing and developing ways to accomplish activities and tasks in the enterprise.<br/><br/>This business activity includes tasks to identify and integrate required enterprise policies into activities, identifies all user involvement, sets accuracy expectations, and control (checkpoints and feedback) points.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10350" ;
    skos:prefLabel "Create Procedure"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10351> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10192> ;
    skos:definition "Implement Procedure business activity is in charge of putting into effect 'how to's' for well-defined course/plans for performing activities.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10351" ;
    skos:prefLabel "Implement Procedure"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10352> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10192> ;
    skos:definition "Maintain Procedure business activity is in charge of keeping procedures effective and running. <br/><br/>Maintain Procedure business activity includes task that ensure procedures are supported with the right associated policies and resources and that they effectively do no lead to bottlenecks to achieving the goals they're setup to achieve.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10352" ;
    skos:prefLabel "Maintain Procedure"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10353> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10192> ;
    skos:definition "Terminate Procedure business activity is in charge of ending or stopping and decommissioning a procedure from being operational.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10353" ;
    skos:prefLabel "Terminate Procedure"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10354> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10230> ;
    skos:definition "The objective of the Develop Asset Assurance Policies & Controls process is to establish and manage a framework of policies and measurable controls that are used to manage the risk associated with asset assurance, and to optimize the enterprise’s appetite for asset related risks. Asset Assurance provides a framework to establish processes and data flows to enable DSPs to manage network assets across all dimensions of the asset life cycle to reduce stranded and underutilized assets.<br/>These processes are responsible for, but not limited to: <br/>•Establishing and managing an asset assurance policy framework which is aligned with the overall enterprise goals and objectives<br/>•Developing a framework of controls and KPIs which achieves the defined asset assurance goals and objectives <br/>•Gaining enterprise-wide commitment to and knowledge of the framework <br/>•Regularly reviewing the asset assurance framework to ensure that its outcomes remain aligned with the enterprise’s objectives<br/><br/>The Manage Asset Assurance Framework process has a specific responsibility in developing and defining controls and Key Performance Indicators (KPIs) used for Asset Assurance, in conjunction with operational and other processes elsewhere in the enterprise.<br/><br/>Manage Asset Assurance Policy Framework<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10354" ;
    skos:prefLabel "Develop Asset Assurance Policies and Controls"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10355> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10230> ;
    skos:definition "The objective of the Implement Asset Assurance Policies & Controls process is to perform a conception of how to implement the controls identified within the Manage Asset Assurance Policy Framework, to meet the requested objectives used to identify the minimum level of satisfactory performance required for a given control point or a process.<br/>It's aim is to analyze the business process of a given control point, identify the data sources and their formats, set up and perform an ETL process and develop an Asset Assurance Artifact and configure its alarming, most preferably by delivering automated results. <br/><br/>The responsibilities of the processes include, but are not limited to:<br/>•Conception of Asset Assurance artifacts like KPIs, controls and metrics<br/>•Ad hoc analysis and results of low level investigations driven by request of stakeholders, triggered alarms or expert judgement<br/>•End-to-end implementation of artifacts, starting with ETL procedure of source data and configuration in mid-layer systems to enable monitoring <br/>•Testing and fine-tuning of the artifacts<br/>•Implemented artifacts (control, metric)<br/>•Documentation (control / metric attributes, dataflow)<br/>•Updated repositories<br/><br/><br/>This process was renamed in 24.0 Old process name was Implement Asset Assurance Operations<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10355" ;
    skos:prefLabel "Implement Asset Assurance Policies and Controls"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10356> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10230> ;
    skos:definition "The Analyze Asset Assurance Policies & Controls processes should deliver continual monitoring and controls at each phase of the asset lifecycle to provide the stakeholders with a holistic, network wide view of all network assets from procurement through disposition, including all asset states (spare parts, on-air, project reserved, etc.). Asset Assurance provides the enterprise insights and processes to optimize the network performance and capacity including the establishment of tools and data collection capabilities to capture details of operational activity supporting the discovery, recapture, and redeployment of stranded or underutilized assets. The operational capabilities should support analysis and creating of cases based on identified under performance, monitoring and tracking the open cases, quantification and reporting.<br/><br/><br/><br/>This process was renamed in 24.0 Old process name was Manage Asset Assurance Operations<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10356" ;
    skos:prefLabel "Analyze Asset Assurance Policies and Controls"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10357> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10230> ;
    skos:definition "The objectives of the Monitor Performance of Asset Assurance Operations processes are twofold: <br/>•support the Manage Margin Assurance Operations processes by managing requirements for infrastructure to support the operational processes, and<br/>•monitoring, managing and reporting on the capability of the Manage Margin Assurance Operations processes<br/><br/><br/>This process was renamed in 24.0 Old process name was Support Asset Assurance Operations<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10357" ;
    skos:prefLabel "Monitor Performance of Asset Assurance Operations and Processes"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10358> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10526> ;
    skos:definition "Establish Trust business activity sets up an environment in the enterprise that foster positive relationships, good judgement with expertise, and maintaining consistency in exchanges across all interactions and experiences.<br/><br/>Establish Trust business activity supports the enterprise to Manage Transparency by facilitating consistent and open exchanges with customers, business partners, employees and all other stakeholders.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10358" ;
    skos:prefLabel "Establish Trust"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10359> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10526> ;
    skos:definition "Manage Disclosure business activity is in charge of directing and controlling the release and publication of facts or information known customers, business partners, employees and other stakeholders (such as investors). <br/><br/>Manage Disclosure business activity includes tasks that consolidate data and information, maintains repository of documents and reports required for statutory reporting (e.g. regulatory filings). Manage Disclosure by enterprises makes customers, investors, and stakeholders involved in doing business with the company aware of pertinent information.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10359" ;
    skos:prefLabel "Manage Disclosure"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10360> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10511> ;
    skos:definition "Handle Goods Acceptance business activity control the acceptance of goods from suppliers and any transport arrangements to deliver the goods to either warehouses or site.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10360" ;
    skos:prefLabel "Handle Goods Acceptance"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10361> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10511> ;
    skos:definition "Manage Purchase Order business activity selects, creates and sends purchase orders in accordance to the mission of supply chain management.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10361" ;
    skos:prefLabel "Manage Purchase Order"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10362> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10511> ;
    skos:definition "Verify Supplier Invoices business activity check supplier invoice accuracy, invoice information and confirms delivery of supplies according to the purchase order.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10362" ;
    skos:prefLabel "Verify Supplier Invoices"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10365> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10304> ;
    skos:definition "Transition Project business activity handle tasks that manage the change of one project to another.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10365" ;
    skos:prefLabel "Transition Project"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10366> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10304> ;
    skos:definition "Coordinate Projects business activity handle activities that oversee the day-to-day management of inter-related projects. <br/><br/>Coordinate Projects business activity is responsible for coordinating projects in order to streamline the workflow of tasks that span multiple projects.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10366" ;
    skos:prefLabel "Coordinate Projects"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10367> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10204> ;
    skos:definition "Develop Learning Plan establishes a the activity schedule that defines how to achieve desired outcomes for a learning objective. Develop Learning Plan ensures clarity so that the progress is orderly and efficient. It includes steps to leverage learning goals as input to identify how individual learning plans may achieve one or several learning goals/objectives. It includes conducting learner assessment, applying learning styles, and when to initiate learning activities to support the goals.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10367" ;
    skos:prefLabel "Develop Learning Plan"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10368> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10204> ;
    skos:definition "Model Learning Program business activity establish a cohesive and integrated learning process for learners with input from defined learning outcome. Model Learning Program use learning outcomes or the learning objectives (derived from the competency standards or other criteria) and outline the content, sequence and structure of learning and the delivery and assessment method/s to be used.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10368" ;
    skos:prefLabel "Model Learning Program"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10369> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10608> ;
    skos:definition "Manage Business Rules Performance business activity is in charge of directing and controlling effect of business rules on enterprise performance.<br/>Managing Business Rules performance ensure that business rules are framed as a precise statement defining a term, fact, and a constraint. Manage Business Rules Performance support enterprise performance management formats are as declarative as possible.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10369" ;
    skos:prefLabel "Manage Enterprise Business Rules Performance"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10370> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10608> ;
    skos:definition "Manage Performance Policy & Procedure business activity is in charge of directing and controlling performance fairness (equity and/equitability) and procedure consistency across all areas defined for enterprise performance management.<br/>This business activity provide management with tasks and guides that enable clear communication on the standards of activities, tasks and performance expectation to ensure performance standards are met.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10370" ;
    skos:prefLabel "Manage Enterprise Performance Policy & Procedure"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10371> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10608> ;
    skos:definition "Manage Business Process Performance business activity is in charge of directing controlling how efficient or effective business processes in the enterprise are defined and operationalized.<br/><br/>Manage Business Process Performance business activity supports checking the achievement of strategic and operational goals, as well as decision-making for the continuous optimization of business processes.<br/><br/>This business activity will also define the methodology to be employed in process design, process change management or process re-engineering activities across the enterprise. Cost and performance of individual business process activities is the accountability of core areas using the business process. This business activity will as part of controlling, monitor the value of the overall process management activities to ensure that the enterprise continues to achieve performance objects established. Appropriate reports on business process performance at the enterprise level are produced in line with Manage Performance Reporting business activities.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10371" ;
    skos:prefLabel "Manage Business Process Performance"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10373> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10314> ;
    skos:definition "Create Employee Profile Agreement Creation process provides the organization the ability to create privacy agreements for employees.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10373" ;
    skos:prefLabel "Create Employee Profile Agreement"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10374> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10314> ;
    skos:definition "Assign Employee Profile Agreement t Assignment process provides the organization the ability to assign privacy agreements to employees.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10374" ;
    skos:prefLabel "Assign Employee Profile Agreement"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10375> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10314> ;
    skos:definition "Administer Employee Profile Agreement process provides the organization the ability to ensure performance privacy agreements by employees.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10375" ;
    skos:prefLabel "Administer Employee Profile Agreement"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10376> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10314> ;
    skos:definition "Manage Employee Profile Agreement Renew process provides the organization the ability to ensure privacy profile agreements are always in effect across tenures.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10376" ;
    skos:prefLabel "Manage Employee Profile Agreement Renew"@en .

