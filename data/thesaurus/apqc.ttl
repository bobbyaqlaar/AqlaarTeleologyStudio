    skos:broader <http://ots.local/thesaurus/apqc/9_6_2> ;
    skos:definition "Permitting expense reimbursement requests from employees."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.6.2.3" ;
    skos:prefLabel "Approve reimbursements and advances"@en .

