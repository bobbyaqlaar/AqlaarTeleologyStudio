    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7818" ;
    skos:prefLabel "Apply Pricing, Discounting, Adjustments & Rebates to Customer Account"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7819> a skos:Concept ;
