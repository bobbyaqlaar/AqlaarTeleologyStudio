<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA6_EA9311> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA6_EA9289> ;
