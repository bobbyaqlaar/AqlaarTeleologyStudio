    skos:definition "Browse Product Orders business activity is responsible for making product order available based on general or multiple information.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8629" ;
    skos:prefLabel "Browse Product Orders"@en .

