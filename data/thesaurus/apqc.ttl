<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10380> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10532> ;
