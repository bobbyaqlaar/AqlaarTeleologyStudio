    skos:inScheme thes:apqc ;
    skos:notation "9.7.5.3.5" ;
    skos:prefLabel "Manage foreign exchange balance sheet risk"@en .

<http://ots.local/thesaurus/apqc/9_7_5_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_5_4> ;
    skos:definition "Establishing ongoing risks that the customers face, and the exceptions to exceeded limits."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.5.4.1" ;
    skos:prefLabel "Determine current customer exposures and limit exceptions"@en .

<http://ots.local/thesaurus/apqc/9_7_5_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_5_4> ;
