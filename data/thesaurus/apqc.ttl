    skos:broader <http://ots.local/thesaurus/apqc/9_7_4> ;
    skos:definition "Tracking loans taken and money invested in different options. Arrange and supervise loans from banks and individuals and investments in different available and profitable options."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.4.5" ;
    skos:prefLabel "Process and oversee debt and investment transactions"@en .

<http://ots.local/thesaurus/apqc/9_7_4_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_4> ;
    skos:definition "Arranging and supervising foreign exchange rate changes to avoid loss on foreign-currency transactions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.4.6" ;
    skos:prefLabel "Process and oversee foreign currency transactions"@en .

<http://ots.local/thesaurus/apqc/9_7_4_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_4> ;
    skos:definition "Creating transactions report of loans and investments. Prepare and maintain records of loans and investment transactions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.4.7" ;
    skos:prefLabel "Produce debt and investment accounting transaction reports"@en .

<http://ots.local/thesaurus/apqc/9_7_4_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_4> ;
    skos:definition "Supervising the interest paid or received by the organization. Arrange and supervise interest rate swap transactions to manage exposure to fluctuations in interest rates. Or attain a marginally lower rate of interest than could be gained through a swap."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.4.8" ;
    skos:prefLabel "Process and oversee interest rate transactions"@en .

<http://ots.local/thesaurus/apqc/9_7_5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_5> ;
    skos:definition "Taking an investment position to offset exposure to certain risks. This may include purchasing opposite of the organization's position in the marketplace, using derivatives transactions, or futures contracts."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.5.1" ;
    skos:prefLabel "Develop risk management/hedging strategy"@en .

<http://ots.local/thesaurus/apqc/9_7_5_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_5_2> ;
    skos:definition "Collecting and storing data that pertains to interest rate markets."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.5.2.1" ;
    skos:prefLabel "Manage interest rate market data"@en .

<http://ots.local/thesaurus/apqc/9_7_5_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_5_2> ;
    skos:definition "Identifying potential interest rate risks for all markets."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.5.2.2" ;
    skos:prefLabel "Determine interest rate exposure for all markets"@en .

<http://ots.local/thesaurus/apqc/9_7_5_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_5_2> ;
    skos:definition "Deciding the requirements on interest rate investments that are made by trading in futures or options market, on the basis of the accepted risk policy."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.5.2.3" ;
    skos:prefLabel "Determine interest rate hedge requirements in accordance with risk policy"@en .

<http://ots.local/thesaurus/apqc/9_7_5_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_5_2> ;
    skos:definition "Performing trading on interest rates."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.5.2.4" ;
    skos:prefLabel "Execute interest rate trades"@en .

<http://ots.local/thesaurus/apqc/9_7_5_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_5_3> ;
    skos:definition "Handling and processing information about changes in foreign exchange rates."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.5.3.1" ;
    skos:prefLabel "Manage foreign exchange market data"@en .

<http://ots.local/thesaurus/apqc/9_7_5_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_5_3> ;
    skos:definition "Establishing potential foreign exchange risks for all currencies."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.5.3.2" ;
    skos:prefLabel "Determine foreign exchange exposure for all currencies"@en .

<http://ots.local/thesaurus/apqc/9_7_5_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_5_3> ;
    skos:definition "Deciding the requirements on investments in foreign exchange made by trading in futures or options market, on the basis of current risk policy."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.5.3.3" ;
    skos:prefLabel "Determine foreign exchange hedge requirements in accordance with risk policy"@en .

<http://ots.local/thesaurus/apqc/9_7_5_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_5_3> ;
    skos:definition "Executing all aspects for foreign exchange trade within foreign exchange market. This includes buying, selling, and exchanging currencies at the current or expressed price point."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.5.3.4" ;
    skos:prefLabel "Execute foreign exchange trades"@en .

<http://ots.local/thesaurus/apqc/9_7_5_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_5_3> ;
