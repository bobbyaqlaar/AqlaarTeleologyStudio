    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7761" ;
    skos:prefLabel "Undertake Retention & Loyalty Trend Analysis"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7762> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7928> ;
    skos:definition "Verify Customer Product Configuration involves verifying the customer is using the product correctly and is aimed at ruling out any configuration issues that might be cause of the problem.<br/>This process was renamed. old name was Verify Product Configuration<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7762" ;
    skos:prefLabel "Verify Customer Product Configuration"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7763> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7928> ;
    skos:definition "Diagnose Customer Problem will identify what’s causing the customer problem so that it can be fixed. It includes tasks to determine what the root cause of the customer problem is linked to.<br/>this process was renamed in 23.5 old name was: Perform Specific Customer Problem Diagnostics<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7763" ;
    skos:prefLabel "Diagnose Customer Problem"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7764> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7928> ;
    skos:definition "Conduct Customer Problem Test will gather more information about the issue and confirm the diagnosis through tests conducted on related products, services and/or resources. Not used for this process element<br/>This process was renamed in 23.5 old name was: Perform Specific Customer Problem Tests<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7764" ;
    skos:prefLabel "Conduct Customer Problem Test"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7765> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7928> ;
    skos:definition "Notify Customer Problem Root Cause will ensure everyone is aware of the issue and can work towards a solution. It includes tasks to communicate the root cause and its impact to the stakeholders.<br/>This process was renamed in 23.5. old name was Notify T&M Root Cause Customer Problem<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7765" ;
    skos:prefLabel "Notify Customer Root Cause"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7766> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7928> ;
    skos:definition "Categorize Problem will prioritize and manage problems effectively. It includes tasks to assign the problem to a category and a subcategory based on predefined criteria.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7766" ;
    skos:prefLabel "Categorize Customer Problem"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7767> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7928> ;
    skos:definition "Identify Customer Problem Root Cause will address the root cause and prevent the problem from recurring. It includes tasks to analyze the customer problem and its symptoms and identify the source of the issue.<br/>This process was renamed in 23.5. old name was: Identify Root Cause / Check for Workarounds<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7767" ;
    skos:prefLabel "Identify Customer Problem Root Cause"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7768> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7928> ;
    skos:definition "Obtain Customer Problem Fix will resolve the issue and restore normal service for the customer. It includes tasks to search for a known solution, develop a new solution, or apply a workaround.<br/>This process was renamed in 23.5. old process name was Obtain permanent fix or workarounds<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7768" ;
    skos:prefLabel "Obtain permanent fix or workarounds"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7769> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7928> ;
    skos:definition "Create Restoration Customer Problem Restoration Plan will ensure the problem is resolved in a timely and efficient manner. It includes tasks to define the steps, resources, and timeline for the restoration process.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7769" ;
    skos:prefLabel "Create customer problem restoration plan"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7770> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7928> ;
    skos:definition "Create Customer Problem Known Record will help resolve similar issues in the future. It includes tasks to create and update a record that contains the problem description, root cause, and solution.<br/>This process was renamed in 23.5 old name was Create Known record<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7770" ;
    skos:prefLabel "Create Customer Problem Known Record"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7771> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7776> ;
    skos:definition "Deliver Customer Journey Mapping and Processing Capability <br/>process creates the capability to map customer engagements to customer journey templates and determining the next step in customer journey.<br/>The journey path from trigger event to outcome is determined during the execution based on the choices made by the autonomous customer and the mapped template.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7771" ;
    skos:prefLabel "Deliver Customer Journey Mapping and Processing Capability"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7772> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7776> ;
    skos:definition "Deliver Customer Journey Template Capability<br/>processes focus on creating the journey phase templates linked with the concept of engagement events that are created and designed together by the business and IT.<br/>The business determines the journey phases and the design of the engagement events of those phases. The engagement events are linked to a business story script that describes the journey phases and path.<br/>The process of managing customer journey path and phases focuses mainly on the creation and management of the individual journey phases.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7772" ;
    skos:prefLabel "Deliver Customer Journey Template Capability"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7777> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7716> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7777" ;
    skos:prefLabel "Identify Relevant Customer Inventory Information"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7778> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7716> ;
