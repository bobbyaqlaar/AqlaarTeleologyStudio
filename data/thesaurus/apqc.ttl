<http://ots.local/thesaurus/apqc/9_7_5_5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_5_5> ;
    skos:definition "Determining which hedge options to execute."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.5.5.2" ;
    skos:prefLabel "Establish hedges"@en .

<http://ots.local/thesaurus/apqc/9_7_5_5_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_5_5> ;
    skos:definition "Closing out a position or cashing in derivatives early."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.5.5.3" ;
    skos:prefLabel "Unwind hedges"@en .

<http://ots.local/thesaurus/apqc/9_7_5_5_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_5_5> ;
    skos:definition "Examining options in the market for hedging investments. Select an option."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.5.5.4" ;
    skos:prefLabel "Evaluate and refine hedging positions"@en .

<http://ots.local/thesaurus/apqc/9_7_5_5_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_5_5> ;
    skos:definition "Revising credit reports periodically for accurateness and changes that could be suggestive of duplicitous activity."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.5.5.5" ;
    skos:prefLabel "Monitor credit"@en .

<http://ots.local/thesaurus/apqc/9_7_5_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_5> ;
    skos:definition "Preparing and documenting accounts and records of all hedging investment transactions to reduce risks due to change in markets."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.5.6" ;
    skos:prefLabel "Produce hedge accounting transactions and reports"@en .

<http://ots.local/thesaurus/apqc/9_7_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7> ;
    skos:definition "Handling cases that involve financial fraud. Resolve disputes."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.6" ;
    skos:prefLabel "Manage financial fraud/dispute cases"@en .

<http://ots.local/thesaurus/apqc/9_8_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_8_1> ;
    skos:definition "Establishing board of directors and auditing committee in order to assign roles and responsibilities for internal controls."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.8.1.1" ;
    skos:prefLabel "Establish board of directors and audit committee"@en .

<http://ots.local/thesaurus/apqc/9_8_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_8_1> ;
    skos:definition "Outlining and communicating a code of ethics act responsibly."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.8.1.2" ;
    skos:prefLabel "Define and communicate code of ethics"@en .

<http://ots.local/thesaurus/apqc/9_8_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_8_1> ;
    skos:definition "Defining roles, responsibilities, and accountabilities for effectiveness and proficiency of operations and reliability of financial reporting."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.8.1.3" ;
    skos:prefLabel "Assign roles and responsibility for internal controls"@en .

<http://ots.local/thesaurus/apqc/9_8_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_8_1> ;
    skos:definition "Outlining the objectives and risks associated with a process. Delineate process goals. Determine the risks attached to it. Determine what the process is meant to accomplish, potential issues, a timeline of potential risks, the scope and potential impact of risks, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.8.1.4" ;
    skos:prefLabel "Define business process objectives and risks"@en .

<http://ots.local/thesaurus/apqc/9_8_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_8_1> ;
    skos:definition "Outlining the risk tolerance levels of individual units, as well as the organization as a whole. Determine the specific maximum risk to take in quantitative terms for each relevant risk subcategory, including strategic, operational, financial, and compliance risks."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.8.1.5" ;
    skos:prefLabel "Define entity/unit risk tolerances"@en .

<http://ots.local/thesaurus/apqc/9_8_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_8_2> ;
    skos:definition "Overseeing the activities for internal controls. Observe the effectiveness of policies, procedures, techniques, and mechanisms actions taken to minimize risk."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.8.2.1" ;
    skos:prefLabel "Monitor control effectiveness"@en .

<http://ots.local/thesaurus/apqc/9_8_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_8_2> ;
    skos:definition "Taking corrective measures for policies, procedures, techniques, and mechanisms actions taken to minimize risk. (Conduct in accordance with Monitor control effectiveness [10918] in order to determine and rectify the control deficiencies.)"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.8.2.2" ;
    skos:prefLabel "Remediate control deficiencies"@en .

<http://ots.local/thesaurus/apqc/9_8_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_8_3> ;
    skos:definition "Reporting to external auditors. This process requires the organization to report to external auditors about the regulations for any critical data that the organization is holding."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.8.3.1" ;
    skos:prefLabel "Report to external auditors"@en .

<http://ots.local/thesaurus/apqc/9_8_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_8_3> ;
    skos:definition "Reporting to regulators, shareholders, debt holders, securities exchanges, etc. about IT regulations and pertinent data."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.8.3.2" ;
    skos:prefLabel "Report to regulators, share-/debt-holders, securities exchanges, etc."@en .

<http://ots.local/thesaurus/apqc/9_8_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_8_3> ;
    skos:definition "Reporting to suppliers, customers, and partners that are doing business with the company about IT regulations and pertinent data."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.8.3.3" ;
    skos:prefLabel "Report to third parties"@en .

<http://ots.local/thesaurus/apqc/9_8_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_8_3> ;
    skos:definition "Reporting to internal management (all employees, directors, and management) about IT regulations and pertinent data."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.8.3.4" ;
    skos:prefLabel "Report to internal management"@en .

<http://ots.local/thesaurus/apqc/9_9_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_9_1> ;
    skos:definition "Developing a tax strategy for foreign, national, state, local administration. Set up tax strategies for foreign trade in imports and exports and at national, state, and local level."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.9.1.1" ;
    skos:prefLabel "Develop foreign, national, state, and local tax strategy"@en .

<http://ots.local/thesaurus/apqc/9_9_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_9_1> ;
    skos:definition "Combining and enhancing a rational analysis of a financial condition or plan from a tax perspective in order to align financial goals through efficient tax planning."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.9.1.2" ;
    skos:prefLabel "Consolidate and optimize total tax plan"@en .

<http://ots.local/thesaurus/apqc/9_9_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_9_1> ;
    skos:definition "Maintaining a master file about the rational analysis of a financial condition or plan from a tax perspective in order to align financial goals through efficient tax planning."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.9.1.3" ;
    skos:prefLabel "Maintain tax master data"@en .

<http://ots.local/thesaurus/apqc/9_9_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_9_2> ;
    skos:definition "Creating and implementing strategies for taxes to be paid or collected by the business."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.9.2.1" ;
    skos:prefLabel "Perform tax planning/strategy"@en .

<http://ots.local/thesaurus/apqc/9_9_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_9_2> ;
    skos:definition "Preparing and submitting tax reports for every employee to the tax department in order to show the tax paid and deducted from their salaries in the year."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.9.2.2" ;
    skos:prefLabel "Prepare tax returns"@en .

<http://ots.local/thesaurus/apqc/9_9_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_9_2> ;
    skos:definition "Preparing reports about paid or accrued foreign taxes to an overseas country."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.9.2.3" ;
    skos:prefLabel "Prepare foreign taxes"@en .

<http://ots.local/thesaurus/apqc/9_9_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_9_2> ;
    skos:definition "Calculating the income that has been realized when the tax on that income has not."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.9.2.4" ;
    skos:prefLabel "Calculate deferred taxes"@en .

<http://ots.local/thesaurus/apqc/9_9_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_9_2> ;
    skos:definition "Managing the organization's financial accounts for the purpose of taxation. Prepare and maintain the tax paid by the organization to the country they have business in."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.9.2.5" ;
    skos:prefLabel "Account for taxes"@en .

<http://ots.local/thesaurus/apqc/9_9_2_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_9_2> ;
    skos:definition "Checking and correcting the tax policies according to the rules and regulations set by the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.9.2.6" ;
    skos:prefLabel "Monitor tax compliance"@en .

<http://ots.local/thesaurus/apqc/9_9_2_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_9_2> ;
    skos:definition "Addressing any tax queries by any regulatory or government authorities. Review historical records related to taxation within the organization in order to respond to queries."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.9.2.7" ;
    skos:prefLabel "Address tax inquiries"@en .

