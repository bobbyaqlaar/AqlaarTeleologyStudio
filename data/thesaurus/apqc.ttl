    skos:broader <http://ots.local/thesaurus/apqc/9_7_5_4> ;
    skos:definition "Handling customer securities to recover loans that are not paid back."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.5.4.3" ;
    skos:prefLabel "Manage customer collateral"@en .

<http://ots.local/thesaurus/apqc/9_7_5_4_4> a skos:Concept ;
