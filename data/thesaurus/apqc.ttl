<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10384> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10532> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10384" ;
    skos:prefLabel "Apply Employee Recruitment"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10385> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10531> ;
    skos:definition "Define the competencies and skills required of the human resources; create the strategies needed to ensure that the correct type, quantity and quality of employees will be available in right locations for future business. and define the competencies and skills required of the human resources<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10385" ;
    skos:prefLabel "Create Workforce Strategy"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10386> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10531> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10386" ;
    skos:prefLabel "Define Workforce Strategy Requirements"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10387> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10531> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10387" ;
    skos:prefLabel "Manage Workforce Change"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10388> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10231> ;
    skos:definition "Define Technology Migration Risks- As part of the implementation of Migration Assurance Processes a set of KPIs are defined based on potential risks associated with the revenue leakage and customer experience of provisioning and billing errors before, during the testing and after the technology migration.<br/>The revenue assurance tool should be able to use automated control-monitoring mechanisms to ensure that the KPIs meet the defined objectives as well as whenever deviations are detected; the cases are escalated for an immediate resolution to achieve operational control objectives.<br/><br/>The responsibilities of the processes include, but are not limited to:<br/>• Definition of the key risks associated with technology migration form the revenue and customer experience perspective<br/>• Definition of the Business Assurance automated auditing indicators by defining KPIs, controls, and metrics to feed into the Business Assurance tools<br/>• Define the data sources and the data integration procedures in the business assurance tool to monitor risks, if possible in real-time, to feed business assurance KPIs<br/>• Definition of segregation of duties and responsibilities for case escalation and resolution<br/>• Allow the ad hoc analysis of low-level investigations driven by request of stakeholders based on triggered alarms and developed by expert judgment outside of the designed KPIs<br/>• Testing and fine-tuning of the controls in place<br/>• Measure and quantify the impacts of the controls in place during the detection, prevention, and recovery for business <br/>• Implement automatic reporting capabilities for business and operational items previously mentioned<br/>• Documentation (control / metric attributes, dataflow)<br/>• Updated repositories<br/>This process was renamed in 24.0 Old process name Manage Migration Assurance Framework<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10388" ;
    skos:prefLabel "Define Technology Migration Risks"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10389> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10231> ;
    skos:definition "The Define Migration Assurance Controls and Metrics establishes principles that guide the migration process and sets out controls and metrics recommendations for Communication Service Providers (CSPs) that look for a seamless transition for the technology that supports the services provided to consumers and businesses.<br/>The primary goal the migration assurance framework is to guarantee an accurate, timely and consistent information between the legacy and the new system in place, in order to avoid revenue assurance or customer experience issues.<br/><br/>The responsibilities of the processes include, but are not limited to:<br/>• Definition of the Business Assurance automated auditing indicators by defining KPIs, controls, and metrics to feed into the Business Assurance tools<br/>• Testing and fine-tuning of the controls in place<br/>• Measure and quantify the impacts of the controls in place during the detection, prevention, and recovery for business <br/>• Documentation (control / metric attributes, dataflow)<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10389" ;
    skos:prefLabel "Define Migration Assurance Controls and Metrics"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10390> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10509> ;
    skos:definition "Plan Logistics activity handles the transportation plan, storage plan to support the core (product, service, resource) processes according to the Supply Chain Strategic Management plan.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10390" ;
    skos:prefLabel "Plan Logistics"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10391> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10509> ;
    skos:definition "Plan Sourcing business activity support procurement business activities by providing the blueprint to assess and manage changes so that the benefits of procurement strategies are realized.<br/>Sourcing plan must be created in a way that ensures the benefits identified in the strategy are delivered in full and on time.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10391" ;
    skos:prefLabel "Plan Sourcing Execution"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10392> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10509> ;
    skos:definition "Handle Demand Planning business activity is in charge of forecasting, or predicting, the demand for \"products\" to ensure the enterprise they can be delivered, and that they satisfy customers.<br/>This business activity has a goal of attaining a balance between having sufficient inventory levels to meet customer needs without having a surplus.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10392" ;
    skos:prefLabel "Handle Demand Planning"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10393> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10509> ;
    skos:definition "Plan Supply Network business activity is in charge of integrating purchasing, production, distribution, and transportation so that comprehensive tactical planning and sourcing decisions can be simulated and implemented on the basis of a single, global consistent model.<br/>Plan Supply Network business activity uses advanced optimization activities, based on constraints and penalties, to plan product flow along the supply chain in order to facilitate optimal purchasing, production, and distribution decisions; reduced order fulfillment times and inventory levels; and improved customer service.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10393" ;
    skos:prefLabel "Plan Supply Network"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10394> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10509> ;
    skos:definition "Pan Distribution business activity is in charge of determining the right quality of products to be availed to the enterprises' distribution network in order to meet customer demand.<br/>Plan Distribution ensures that customer and forecasted demand are translated into purchase orders. This process depends on actual demand signals such as customer orders, as those orders are used to plan the gross requirements of the supply source.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10394" ;
    skos:prefLabel "Plan Distribution"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10395> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10441> ;
    skos:definition "Manage Cash Flow process consists of monitoring, analyzing, and optimizing the inflows and outflows of cash in the organization. It involves understanding the organization's financial situation to more accurately budget and forecast its cash flow needs. Essentially, it's about having the right amount of money in the right places at the right times. Effective cash flow management empowers organizations to anticipate challenges, seize opportunities, and lay the groundwork for sustainable growth and profitability.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10395" ;
    skos:prefLabel "Manage Cash Flow"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10396> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10441> ;
    skos:definition "Forecasting Financing Requirements process involves estimating the financial needs of the organization. It helps determine sales, costs of customer acquisition, capital for specific projects, and other expenses necessary for effective business management. This pre-emptive forecast enables sound decision-making and ensures that the organization is well-prepared for its financial obligations.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10396" ;
    skos:prefLabel "Forecast Financing Requirements"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10397> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10441> ;
    skos:definition "#lt;div#gt;The Arranging Finance process refers to securing funds or capital for a specific purpose. It involves organizing and structuring financial resources to meet specific requirements.#lt;/div#gt;<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10397" ;
    skos:prefLabel "Arrange Finance"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10398> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10441> ;
    skos:definition "Managing Short-Term Investments process involves handling financial assets that can be easily converted to cash within a relatively short period, typically within five years. Managing Short-term Investments involves the following key decisions:<br/><br/>1. Types of Short-Term Investments <br/>2. Company Perspective <br/>3. Benefits (liquidity, flexibility, etc)<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10398" ;
    skos:prefLabel "Manage Short Term Investment"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10399> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10441> ;
    skos:definition "Making and receiving foreign exchange payments involves handling cross-border transactions that require currency exchange. Various payment methods can be used, including wire transfers, global ACH, PayPal, prepaid debit cards, credit cards, and checks.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10399" ;
    skos:prefLabel "Make/Receive Foreign Exchange Payments"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10400> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10441> ;
    skos:definition "Reconciling bank statements involves comparing the organization's financial records with its monthly bank statements. By checking all deposits and withdrawals helps ensure accuracy and gain a clearer picture of the organization's finances. This process is essential for budgeting and identifying any discrepancies between the organization's records and the bank's statement.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10400" ;
    skos:prefLabel "Reconcile Bank & Financial Institution Statements"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10401> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10565> ;
    skos:definition "Formulate Enterprise Privacy Policy process provides the organization the ability to formulate Privacy Policies in a way that assures it business interests with the understanding and consideration of all statutory and regulatory mandates.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10401" ;
    skos:prefLabel "Formulate Enterprise Privacy Policy"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10402> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10565> ;
    skos:definition "Implement Enterprise Privacy Policy process provides the organization the ability to put into effect Privacy Policies in a way that assures it business interests with the understanding and consideration of all statutory and regulatory mandates.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10402" ;
    skos:prefLabel "Implement Enterprise Privacy Policy"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10403> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10565> ;
    skos:definition "Evaluate Enterprise Privacy Policy process provides the organization the ability to collect and analyze information needed to make judgements about contexts, activities, characteristics, or outcomes of privacy policies by virtue of ongoing business needs, and / or impact of external regulations in markets it operates or intends to operate in.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10403" ;
    skos:prefLabel "Evaluate Enterprise Privacy Policy"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10404> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10565> ;
    skos:definition "Change Enterprise Privacy Policy process provides the organization the ability to make changes to its privacy policies on an ongoing basis in order to effectively address its business concerns<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10404" ;
    skos:prefLabel "Change Enterprise Privacy Policy"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10405> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10499> ;
    skos:definition "Administer Asset business activity handles the day-to-day administrative support services for assets.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10405" ;
    skos:prefLabel "Administer Assets"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10406> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10499> ;
    skos:definition "Maintain Asset business activity handles routine and periodic activities that preserve the value of assets. <br/><br/>This business activity will also record and maintain up-to-date information on maintenance and service of assets.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10406" ;
    skos:prefLabel "Maintain Assets"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10407> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10499> ;
    skos:definition "Operate Asset business activity handles the day-to-day running of assets used to conduct ongoing operations of the enterprise.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10407" ;
    skos:prefLabel "Operate Assets"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10408> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10514> ;
    skos:definition "Support Fulfillment business activity guides all order entries, decomposition, workflow tracking and fallout resolution.<br/>Support Fulfillment ensure cross domain and inter vertical orchestration of fulfillment activities, such as between products and services and resources in the enterprise and for reach of its operating markets. It defines how fulfillment is established and completed for requesting customers and entities. This indicates the channels (mutlichannel focused) the organization utilizes, and the levels of support it offers to any engaged party (customers and entities).<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10408" ;
    skos:prefLabel "Support Fulfillment"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10409> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10424> ;
    skos:definition "Define Employee Personal Identifiable Information Privacy Standards processes ensure that privacy standards are applied to Personal Identifiable Information of employees and/or stakeholders during retention, storage and processing.<br/><br/>This includes all employee roles, stakeholder roles, 3rd party roles and responsibilities, obligations and privileges associated.<br/><br/>This process ensures definition of Personal Identifiable Information Privacy Standards of:<br/>Employees and their responsibilities<br/>Obligations of all employees<br/>Privileges of all employees<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10409" ;
    skos:prefLabel "Define Employee Personal Identifiable Information Privacy Standards"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10410> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10424> ;
    skos:definition "Define Stakeholder Personal Identifiable Information Privacy Standards processes ensure that privacy standards are applied to Personal Identifiable Information of employees and/or stakeholders during retention, storage and processing.<br/>This includes all stakeholder roles and responsibilities, obligations and privileges associated. This process ensures definition of Personal Identifiable Information Privacy Standards of:<br/>Stakeholders and their responsibilities<br/>Obligations of all stakeholders<br/>Privileges of all stakeholders<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10410" ;
    skos:prefLabel "Define Stakeholder Personal Identifiable Information Privacy Standards"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10411> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10459> ;
    skos:definition "Monitor Training business activity observes and tracks the enterprises training plans and programs. <br/> Monitor Training business activity allows the enterprise to maintain control of the training processes, while ensuring proactive adaptive response to the business.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10411" ;
    skos:prefLabel "Monitor Training"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10412> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10459> ;
    skos:definition "Evaluate Training Program business activity assess the enterprises training program support its business goals. Evaluate Training Program is the systematic process of collecting information and using that information to improve the enterprises training. Evaluate Training provides feedback to help identify if training programs achieve desired outcomes, and help make decisions about future training programs.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10412" ;
    skos:prefLabel "Evaluate Training Program"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10413> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10575> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10413" ;
    skos:prefLabel "Ensure Legal Compliance"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10414> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10575> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10414" ;
    skos:prefLabel "Carry out Legal requests"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10415> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10575> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10415" ;
    skos:prefLabel "Provide Legal Advice"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10416> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10575> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10416" ;
    skos:prefLabel "Notify Legal Environment Changes"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10417> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10575> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10417" ;
    skos:prefLabel "Manage Legal Actions"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10418> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10172> ;
    skos:definition "Assess Knowledge Management needs business activity analyzes to understand the knowledge needs of enterprise functions, translated the business needs into knowledge management targets and identify knowledge management activities to address the needs. Assess Knowledge Management Needs ensures that assessment of the process and capabilities for knowledge management capture current state of knowledge management activities across enterprise functions. The assessment process solicits input from enterprise functions and 'Evaluate Knowledge Management Performance' to identify improvements for knowledge management.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10418" ;
    skos:prefLabel "Assess Knowledge Management Needs"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10420> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10172> ;
    skos:definition "Evaluate Knowledge Management Performance business activity assesses performance of knowledge management outcomes based on how knowledge management lifecycle and knowledge management operations support the achievement of business goals. Evaluate Knowledge Management Performance supports 'assess knowledge management needs', 'establish knowledge management', and 'knowledge management operations' by preventing repeated missteps, guiding development, and sharing of knowledge to give the enterprise and its business functions a competitive edge.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10420" ;
    skos:prefLabel "Evaluate Knowledge Management Performance"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10422> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10561> ;
    skos:definition "Define Enterprise Privacy Location and Regulation process establish how the relevant privacy regulations must be followed with regards to employees and/or stakeholders. This will include the geographical regions where employees/stakeholders operate from/to; and the location of the Data processing entities.<br/>Define Enterprise Privacy Location and Regulation process is used to:<br/>Identify locations (regulatory jurisdiction) impacted by employee and/or stakeholder privacy concerns.<br/>Define the locations where entities processing information related to employees and/or stakeholders will be located<br/>Define the employee and/or stakeholder privacy regulations that apply to locations<br/>Define the dominant regulation<br/>Define the highest standards that apply for multiple legislative locations<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10422" ;
    skos:prefLabel "Define Enterprise Privacy Jurisdiction"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10423> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10561> ;
    skos:definition "Define Enterprise Privacy Regulation process is used to establish strategic and operating rules that will typically accompany authoritative mechanism for monitoring and enforcing compliance. This will cover the need to:<br/>Identify legislative boundaries and their impact on business/operations.<br/>Define locations for processing of information<br/>Define privacy regulations that apply to locations<br/>Define the dominant regulation<br/>Define the highest standards that apply for multiple legislative locations.<br/>etc.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10423" ;
    skos:prefLabel "Define Enterprise Privacy Regulation"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10425> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10183> ;
    skos:definition "Defines the audit policies and procedures. It will depend on the type of audit like but not limited to Risk audit, Data Management, Data Governance Audit etc.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10425" ;
    skos:prefLabel "Define Audit Policy"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10426> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10183> ;
    skos:definition "Define the audit approach to be used depending on the circumstances, as well as the assessment methodology and scoring approach to be used. identify, prioritize and manage audit program .<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10426" ;
    skos:prefLabel "Define Audit Mechanism"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10427> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10183> ;
    skos:definition "Assess operational activities to ensure necessary or mandated control structures are in place.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10427" ;
    skos:prefLabel "Assess Operational Activities"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10428> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10183> ;
    skos:definition "Provide an estimate to the extent to which the procedures are followed and are effective.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10428" ;
    skos:prefLabel "Evaluate Operational Activities"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10429> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10183> ;
    skos:definition "Provide assurance to senior management and the enterprise Board that the enterprise operational processes and controls are effective and conform to relevant adopted standards (which may be externally imposed or internally adopted). Audit Management processes may be managed by external independent organizations, or by internal groups within the enterprise, but in either case are designed to support senior management/Board assurance. However, the assurance role of the processes is more related to reactive assessment. The processes ensure that appropriate reports relating to compliance and capability are provided to senior management/Board within appropriate defined timeframes.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10429" ;
    skos:prefLabel "Report Audits"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10430> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10183> ;
    skos:definition "Use audit mechanisms proactively to develop assessment methodologies, scoring systems, and advice to operational groups who are responsible for the operations processes.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10430" ;
    skos:prefLabel "Apply Audit Mechanisms Proactively"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10431> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10576> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10431" ;
    skos:prefLabel "Manage Board Related Activities"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10432> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10576> ;
    skos:definition "Manage activities associated with securities/shares of the enterprise and any securities/company regulations impacting on the company, including the administration and management of continuous disclosure/announcements to the securities exchange and/or securities/company regulator.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10432" ;
    skos:prefLabel "Manage Shares/Securities"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10433> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10576> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10433" ;
    skos:prefLabel "Manage Capital/Equity Activities"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10434> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10576> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10434" ;
    skos:prefLabel "Manage Share/Stock Registry"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10435> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10440> ;
    skos:definition "Provide External Financial Information task is responsible for compiling and communicating financial records, including specific financial activities and performance, to convey meaningful financial insights to external stakeholders. It includes tasks such as collecting financial data/information, organizing financial data/information, preparing financial information according to requirements or requests, and communicating or filing financial information to external stakeholders.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10435" ;
    skos:prefLabel "Provide External Financial Information"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10436> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10440> ;
    skos:definition "Provide Internal Financial Information task is responsible for compiling and communicating financial records, including specific financial activities and performance, to convey meaningful financial insights for internal stakeholders. Provide Internal Financial Information includes tasks such as collecting financial data/information, organizing financial data/information, preparing financial information according to requirements or requests, and communicating or delivering financial information within the enterprise.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10436" ;
    skos:prefLabel "Provide Internal Financial Information"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10444> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10521> ;
    skos:definition "Plan Change business activity is in charge of establishing the course of action to making a change effective based on the conditions established by Manage Change Approval.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10444" ;
    skos:prefLabel "Plan Change"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10445> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10521> ;
    skos:definition "Report Change business activity is in charge of communicating verbally or written planned changes and the impact identified.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10445" ;
    skos:prefLabel "Report Change"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10446> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10521> ;
    skos:definition "Review Change business activity is responsible for examining a change to ensure that it is ready for release for implementation.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10446" ;
    skos:prefLabel "Review Change"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10447> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10203> ;
    skos:definition "Define Desired Outcomes business activity support 'Define Learning Objectives; by establishing the specific performance statement to describe the results after a learning cycle. Define Desired Outcomes business activity establish performance conditions and criteria that describe what the learner will know or be able to do in specific, measurable terms. Example of a Learning Objective is \"Be able to felicitate customer requirements correctly.\"<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10447" ;
    skos:prefLabel "Define Desired Outcomes"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10448> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10510> ;
    skos:definition "Define Warehousing Policies business activity define the warehousing structure (centralized and/or distributed) and the associated management policies to be applied to purchased goods.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10448" ;
    skos:prefLabel "Define Warehousing Policy"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10449> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10510> ;
    skos:definition "Develop Logistics/Transport Policies business activity develop the policies for Transporting or moving supplies between locations.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10449" ;
    skos:prefLabel "Develop Logistics/Transport Policy"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10450> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10510> ;
    skos:definition "Develop Stock/Inventory Management Policy business activity develop the corporate policies, in conjunction with Asset Management processes which provide the inventory information resource, relating to locations of, and levels of, stock/inventory holdings.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10450" ;
    skos:prefLabel "Develop Stock/Inventory Management Policy"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10451> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10571> ;
    skos:definition "Promote the desired corporate image for the enterprise and its general business and products. Areas such as sponsorship, corporate-level advertising and general contact with industry bodies, and government and regulatory agencies, are addressed here. Responsible for communicating the required messages to the market and industry about the overall enterprise<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10451" ;
    skos:prefLabel "Promote Desired Corporate Image"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10452> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10571> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10452" ;
    skos:prefLabel "Manage Spokespeople"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10453> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10571> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10453" ;
    skos:prefLabel "Manage Messaging"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10454> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10182> ;
    skos:definition "Assess Training Needs business activity evaluates training gaps and needs, sets training objectives, evaluates roles, prepares plans and identifies place, people, process and technology capacity required to conduct and achieve a specified training objective.<br/>Assess Training Needs lays the necessary groundwork for determining the enterprises needs and how participants in the training will best receive the required training. <br/>Assess Training Needs captures skills proficiency of participants, frequency of skill usage and level of participants skill value to performance. <br/>Output of an Assess Training Need business activity include a map of participant (who) and type of training approach that will be most impactful (how, what, when).<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10454" ;
    skos:prefLabel "Assess Training Needs"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10456> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10182> ;
    skos:definition "Acquire Training Capability business activity establishes and makes ready the capability required to support a training plan.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10456" ;
    skos:prefLabel "Acquire Training Capability"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10457> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10182> ;
    skos:definition "Acquire Training Capability business activity establishes and makes ready the capability required to support a training plan.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10457" ;
    skos:prefLabel "Schedule Training Program"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10460> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10372> ;
    skos:definition "Verify Performance Data business activity handles all tasks that make sure or demonstrate that enterprise performance data are true, accurate or justified. <br/>The tasks here include verifying consistency of independent records of information related to all core processes altogether i.e. market, customer, product, service, business partner and resources within. It works with Manage Performance Consolidation, Reconciliation and Close and undertakes synchronization performance data across all core and enterprise activities for consistency.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10460" ;
    skos:prefLabel "Verify Performance Data"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10461> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10518> ;
    skos:definition "Define Information & Data Governance Plan business activity is in charge of tasks that oversee the establishment of the blueprint and courses of action for the execution and enforcement of authority over the management of information and data and their related assets.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10461" ;
    skos:prefLabel "Define Information & Data Governance Plan"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10462> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10606> ;
    skos:definition "Forecast Enterprise Performance business activity is in charge of calculating or estimating, based on data from previous performance results combined with recent trends, future enterprise performance.<br/>Forecast Enterprise Performance makes use of forecasting techniques that use samples of enterprise performance observations to predict future enterprise performance.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10462" ;
    skos:prefLabel "Forecast Enterprise Performance"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10463> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10606> ;
    skos:definition "Manage Enterprise Performance Plan business activity is in charge of controlling and directing the enterprise performance blueprint based on all activities that are required to achieve performance goals and objectives. <br/>In Manage Enterprise Performance Plan business activity, reference is made to the overall purpose/mission of the enterprise based on its desired results by taking stock of outside and inside activities, understanding the enterprises' situation, understanding performance goals and the strategic management goals, along with the objectives that help to achieve the goals.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10463" ;
    skos:prefLabel "Manage Enterprise Performance Plan"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10464> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10606> ;
    skos:definition "Manage Enterprise Performance Budgeting business activity is in charge of directing and controlling performance information for the allocation, spending, and management of enterprise resources.<br/>An enterprise resource is enterprise stock, or supply of money, materials, staff and other assets that can be drawn on by the enterprise in order to function effectively. Manage Enterprise Performance Budgeting activities improve investment and spend prioritization for enterprise resources in order to increase the efficiency and effectiveness of all enterprise expenditure.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10464" ;
    skos:prefLabel "Manage Enterprise Performance Budgeting"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10466> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10563> ;
    skos:definition "Manage Stakeholder Privacy Profile process is used to handle the life cycle of employee privacy profiles.<br/>It helps to administer processes that ensure that all entities processing data do conform with the organization's privacy policies and the laws & regulation under which it operates.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10466" ;
    skos:prefLabel "Manage Stakeholder Privacy Profile"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10467> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10246> ;
    skos:definition "Identify Relevant Research Information business activity find and discern the right research information to support analyzing for research findings.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10467" ;
    skos:prefLabel "Identify Relevant Research Information"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10468> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10246> ;
    skos:definition "Identify Research Reports & References business activity capture reports and references that support analyzing research findings.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10468" ;
    skos:prefLabel "Identify Research Reports & References"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10469> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10246> ;
    skos:definition "Clarify Unclear Research Points business activity provide comprehensible information around research points that are need explanation to resolve answers to points around research topics.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10469" ;
    skos:prefLabel "Clarify Unclear Research Points"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10470> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10246> ;
    skos:definition "Explain Research Findings business activity describe in detail findings from research topics.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10470" ;
    skos:prefLabel "Explain Research Findings"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10471> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10305> ;
    skos:definition "Analyze Program Benefits business activity handles tasks that examine the enterprises program benefits are aligned according to the designed program vision and goals.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10471" ;
    skos:prefLabel "Analyze Program Benefits"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10472> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10305> ;
    skos:definition "Measure Program Benefits business activity handle tasks that appraise 'how' Programs add value to the enterprise, and contribute to corporate and shared business objectives. <br/><br/>Manage Program Benefits business activities include identifying benefit assumptions, all necessary changes and tasks to achieve the intended benefits (e.g. procedures and metrics, including key performance indicators (KPIs) that need to be in place to measure benefits achievement progress - Benefits Dependency Maps, performance of roles and responsibilities required to meet benefits etc.), and planning that sustains or increases program benefits.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10472" ;
    skos:prefLabel "Measure Program Benefits"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10473> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10573> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10473" ;
    skos:prefLabel "Manage Employee Share Plans"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10474> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10573> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10474" ;
    skos:prefLabel "Manage Shareholder Relations"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10483> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10609> ;
    skos:definition "Define Enterprise Performance Report business activity provides the description of the representation of outcomes of any, and all business activities or business functions.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10483" ;
    skos:prefLabel "Define Enterprise Performance Report"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10484> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10609> ;
    skos:definition "Correlate Enterprise Performance Reports business activity provides the relationships between multiple performance measures and insights.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10484" ;
    skos:prefLabel "Correlate Enterprise Performance Reports"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10485> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10609> ;
    skos:definition "Manage Enterprise Performance Feedback business activity ensures that information necessary or relevant to be received by subjects are received through appropriate communication channels.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10485" ;
    skos:prefLabel "Manage Enterprise Performance Feedback"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10486> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10227> ;
    skos:definition "The objective of this process is to Define Revenue and Cost Assurance Policies and Controls process and to establish and manage a framework of policies and measurable controls that are used to manage the risk associated with revenue and cost assurance, and to optimize the enterprise’s appetite for revenue and cost assurance risk. <br/>These processes are responsible for, but not limited to: <br/>•Establishing and managing a revenue and cost assurance policy framework which is aligned with the overall enterprise goals and objectives<br/>•Developing a framework of controls and KPIs which achieves the defined revenue and cost assurance goals and objectives <br/>•Gaining enterprise-wide commitment to and knowledge of the framework <br/>•Regularly reviewing the revenue and cost assurance framework to ensure that its outcomes remain aligned with the enterprise’s objectives<br/><br/>The Define Revenue and Cost Assurance Policies and Controls has a specific responsibility in developing and defining controls and Key Performance Indicators (KPIs) used for RA, <br/>in conjunction with operational and other processes elsewhere in the enterprise. <br/>Where processes elsewhere in the enterprise have an intrinsic capability to instrument their own performance and behavior (as an aspect of operating effectively within the business), <br/>the Manage Revenue and Cost Assurance Framework process makes use of this capability, but can also provide guidance to these processes in the form of modified, or additional, KPIs, <br/>required to support the overall role of Revenue and Cost Assurance . This can involve individual process elements throughout the enterprise (as appropriate for the various aspects of Revenue and Cost Assurance that apply), or may involve co-ordination across a number of process elements where Revenue and Cost Assurance acts to provide an integrated or coordinated view of the overall situation. <br/>With regard to KPI definition, the Manage Revenue and Cost Assurance Framework process establishes the objectives used to identify the minimum level of satisfactory performance required for a given control point or a process from an RA perspective, and works with other process element in the enterprise to effect this. <br/>With regard to development of Revenue and Cost Assurance controls, the Manage Revenue and Cost Assurance Framework process applies policy-based rules that represent the logical definition of comparisons performed on entities, such as bills and call detail records. <br/>These are used together with Revenue and Cost Assurance KPIs, to identify discrepancies from an RA perspective.<br/><br/><br/>This process was renamed in 24.0 old process name was Manage Revenue and Cost Assurance Policy Framework<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10486" ;
    skos:prefLabel "Define Revenue and Cost Assurance Policies and Controls"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10487> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10227> ;
    skos:definition "While the Manage Revenue and Cost Assurance Policy Frameworks Process ensures what activities and measures shall be applied and how and the Manage Revenue and Cost Assurance Operations Process tracks their outcome, the objective of the Implement Revenue Policies Processes are the detailed implementation steps of the defined KPIs, according to their respective and before-hand evaluated priority, in the manner stated by the RA policy framework, within the technical RA solution tool, considering the evolution of the environment which's probable leak shall sought to be covered. <br/><br/>The process objective is to perform a conception of how to implement a control to meet the requested objectives used to identify the minimum level of satisfactory performance required for a given control point or a process from an RA perspective.<br/>It's aim is to analyze the business process of a given control point, set up and perform an ETL process and develop a Revenue and Cost Assurance Artifact and configure its alarming, most preferably by delivering automated results. <br/><br/>The responsibilities of the processes include, but are not limited to:<br/>•Conception of Business Assurance artifacts like KPIs, controls and metrics<br/>•Ad hoc analysis and results of low level investigations driven by request of stakeholders, triggered alarms or expert judgement<br/>•End-to-end implementation of artifacts, starting with ETL procedure of source data and configuration in mid-layer systems to enable monitoring <br/>•Testing and fine-tuning of the artifacts<br/>•Implemented artifacts (control, metric)<br/>•Documentation (control / metric attributes, dataflow)<br/>•Updated repositories<br/><br/>This process was renamed in 24.0 Old process name was Implement Revenue and Cost Assurance Operations<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10487" ;
    skos:prefLabel "Implement Revenue and Cost Assurance Policies and Controls"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10488> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10227> ;
    skos:definition "This process measures the actual revenue and cost assurance performance at defined control points against the expected performance, report anomalies and manage resolution. <br/>Manage Revenue and Cost Assurance Operations processes encompass managing, tracking, monitoring, analyzing, controlling and reporting on revenue and cost assurance performance as determined by assessing defined KPIs measured against revenue and cost assurance control points. <br/>If the analysis identifies that a revenue and cost assurance KPI violation has occurred, this causes a Revenue and Cost Assurance violation to be raised, that may in turn raise a Revenue and Cost Assurance Trouble Report. Following on from this, processes are put in place to manage the resolution of the performance violation The Manage Revenue and Cost Assurance Operations processes will continue to track the revenue and cost assurance trouble report, ensuring that performance is restored to a level required as defined by the acceptable range for the KPIs.<br/>This process was renamed in 24.0 Old process name was Manage Revenue and Cost Assurance Operations and then back to Manage Revenue and Cost Assurance Operations in 25.0<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10488" ;
    skos:prefLabel "Manage Revenue and Cost Assurance Operations"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10489> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10227> ;
    skos:definition "The objectives of the Support Revenue and Cost Assurance Operations processes are twofold: <br/>•support the Manage Revenue and Cost Assurance Operations processes by managing requirements for infrastructure to support the operational processes, and<br/>•monitoring, managing and reporting on the capability of the Manage Revenue and Cost Assurance Operations processes <br/><br/>The responsibilities of the processes include, but are not limited to: <br/>•Developing and maintaining a repository of revenue and cost assurance KPIs to support the Manage Revenue and Cost Assurance Operations processes<br/>•Monitoring and analyzing the report produced by Operations processes to identify potential revenue and cost assurance problems that may be arising across operational processes as a whole<br/>•Establishing and managing revenue and cost assurance data collection schedules, including managing the collection of the necessary information from the Resource Data Collection & Distribution processes, to support proactive monitoring and analysis activity, and requests from <br/>Manage Revenue and Cost Assurance Operations processes Implement Revenue and Cost Assurance Operations processes for additional data to support revenue and cost assurance performance analysis<br/>•Monitoring of the Manage Revenue and Cost Assurance Operations processes and associated costs (including to where the processes extend to infrastructure, deployed and managed by third parties), and reporting on the capability of the Manage Revenue and Cost Assurance Operations processes<br/>•Establishing and managing resource performance notification facilities and lists to support the Manage Revenue and Cost Assurance Operations notification and reporting processes and the Implement Revenue and Cost Assurance Operations processes <br/>•Creating, deploying, modifying and/or upgrading of revenue and cost assurance infrastructure deployment support tools and processes for new and/or modified revenue and cost assurance infrastructure <br/>•Authoring, reviewing and approving operational procedures developed by Resource Development & processes prior to resource infrastructure deployment<br/>•Testing and acceptance of new and/or modified revenue and cost assurance infrastructure support tools as part of the handover procedure from the Resource Development & processes <br/>•Detecting revenue and cost assurance infrastructure operational limitations and/or deployment incompatibilities and providing requirements to address these aspects to Resource Development & processes<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10489" ;
    skos:prefLabel "Support Revenue and Cost Assurance Operations"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10495> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10581> ;
    skos:definition "Enterprise Capacity Planning business process activity handle the tasks of balancing available \"resources\" against value streams need in order to meet the enterprises' demand management program.<br/>Enterprise Capacity Planning maintains a holistic view across the enterprise to ensure a match of supply with demand given all the resources available to the enterprise. It receives reports from all value streams (product/service and resource), and supports the overarching capacity management policies.<br/>Enterprise Capacity Planning impacts on all the enterprise, it's projects, and measures and tracks the allocation and use of capacity based on well defined capacity management strategy.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10495" ;
    skos:prefLabel "Enterprise Capacity Planning"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10496> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10581> ;
    skos:definition "Enterprise Capacity Management Requirement business activity help to identify and deal with the Enterprises demand program to support any and all of the value streams, including products, service and resources altogether.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10496" ;
    skos:prefLabel "Enterprise Capacity Management Requirement"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10503> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10185> ;
    skos:definition "Manage Capital Investment business activity directs and controls corporate expenditure of money to fund the enterprises long-term growth. <br/><br/>Manage Capital Investment can facilitate enterprises acquisition of permanent fixed assets such as real estate and equipment, or provide diversification leveraging Manage Capital Investment business activity. This includes diversification strategies like replacements and modernization.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10503" ;
    skos:prefLabel "Manage Capital Investment"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10505> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10185> ;
    skos:definition "Manage Liquidity business activity directs and controls corporate visibility into the enterprise cash position. <br/><br/>Manage Liquidity can be long-term, but for short-term it enables the enterprise to improve decision-making. Visibility into a firm's cash and liquidity position allows corporate treasurers to analyze surplus funds to make better investment and borrowing decisions.<br/><br/>This business activity handles tasks make decisions around working capital and operating cashflows (current assets and current liabilities) in order to avoid disrupting the enterprises business operations. These activities can extend to getting additional credit lines or activating liquidity backups.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10505" ;
    skos:prefLabel "Manage Liquidity"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10506> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10185> ;
    skos:definition "Manage Managerial Accounting business activity directs, analyzes and communicates financial data to corporate managers who use the information to make business decisions.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10506" ;
    skos:prefLabel "Manage Managerial Accounting"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10507> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10338> ;
    skos:definition "Metric Dimension Specification defines and maintains for each Metric: categories (organizational or technical classifications), dimensions (time, space, user groups, priority levels, …), cross-references, dependencies, and tree hierarchies which characterize the Metric with respect to other Metrics.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10507" ;
    skos:prefLabel "Define & Maintain Metric Dimension Specifications"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10508> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10338> ;
    skos:definition "Metric Definition Specification defines and maintains the following for each Metric: one or multiple IDs (for different repositories or identification schemes), one or multiple names (for different naming schemes), high-level description, business value, comments, and status data (entry date, last-used date, active/inactive, maturity level, validity period, etc.).<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10508" ;
    skos:prefLabel "Specify Metric Definition"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10516> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10443> ;
    skos:definition "Analyze Change business activity examine changes planned based on enterprise needs, risks and benefits.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10516" ;
    skos:prefLabel "Analyze Change"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10517> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10443> ;
    skos:definition "Authorize Change business activity endorse and permit a planned change for implementation based on enterprise needs in line with risk plans.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10517" ;
    skos:prefLabel "Authorize Change"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10530> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10173> ;
    skos:definition "Develop the Workforce processes support the definition of the organization of the enterprise and coordinate its reorganizations. These processes can apply for the overall organization, can define the organization of single business units, or at least can ensure coherency and/or guarantee support to specific processes defining<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10530" ;
    skos:prefLabel "Develop the Workforce"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10534> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10173> ;
    skos:definition "Report Workforce process is responsible for preparing the statistical data on quality, productivity, and efficiency for the services performed by the involved employees and/or third parties. These processes record, analyze, and assess the workforce in order to provide specialized summaries of the efficiency and effectiveness of the overall Workforce processes. These specialized summaries can be specific reports required by specific audiences, as well as reporting on associated costs of the Manage Workforce processes.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10534" ;
    skos:prefLabel "Report Workforce"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10535> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10497> ;
    skos:definition "Establish Asset Catalog business activity defines and organizes different assets into classes and their properties for effective control, operations and valuation.<br/><br/>Establish Asset Catalog will identify types of assets, asset properties, asset access need etc.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10535" ;
    skos:prefLabel "Establish Asset Catalog"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10536> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10497> ;
    skos:definition "Establish Asset Lifecycle Management business activity support optimizing the value derived from assets through their lifetime. <br/><br/>Establish Asset Lifecycle Management business activity ensures that each asset, based on the catalog type, has a lifecycle that covers planning, acquisition, operation & maintenance, and disposal/decommissioning.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10536" ;
    skos:prefLabel "Establish Asset Management LCM"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10537> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10497> ;
    skos:definition "Establish Asset Management Policy defines the key principles, responsibilities and approach to all asset catalog management types and categories.<br/><br/>Effectively executing Establish Asset Management Policy address: scope and purpose, definitions of policies, capitalization thresholds, additions, transfers, disposals and losses, inventory and periodic audits/assessment of conditions and maintenance and repair.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10537" ;
    skos:prefLabel "Establish Asset Management Policy"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10538> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10497> ;
    skos:definition "Budget Asset business activity enables the organization to capture new assets into the organizations budget. <br/><br/>Budget Asset business activity establish dimensions to use in asset budgeting and the relationship to business line activities; support Cataloging Assets and Capital acquisition planning.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10538" ;
    skos:prefLabel "Budget Assets"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10539> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10245> ;
    skos:definition "Define Research Topic business activity describes the subject or issue that a researcher must focus on when conducting research. Define Research Topic provides a well-defined research topic as starting point of every successful research project. The choice of a topic is an ongoing process by which researchers explore, define, and refine ideas.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10539" ;
    skos:prefLabel "Define Research Topic"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10540> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10245> ;
    skos:definition "Identify Research Objectives business activity pinpoint and research goals and targets and discern the focus of research. This business activity includes breaking down the research focus into research targets and defining criteria to evaluate research objectives.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10540" ;
    skos:prefLabel "Identify Research objectives"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10541> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10245> ;
    skos:definition "Select Research Method business activity match the best research method to research objectives. Select Research Method activity may take input from 'Identify Research Topic' and 'Identify Research Objectives' to understand the best research analysis option (qualitative research, quantitative research a mix of both) to support the research methodology.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10541" ;
    skos:prefLabel "Select Research Method"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10542> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10245> ;
    skos:definition "Build Research Capacity business activity develops the abilities and skills enabling the enterprise to perform research. Build Research Capacity addresses individual and enterprise-wide research capacity development which leads to higher levels of skills and greater ability to perform research.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10542" ;
    skos:prefLabel "Build Research Capacity"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10543> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10245> ;
    skos:definition "Develop Research Brief business activity builds out the research briefings to provide a concise summary of research knowledge on a particular topic. Develop Research Brief business activity will summarize research evidence in an accessible form to the research audience.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10543" ;
    skos:prefLabel "Develop Research Brief"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10544> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10245> ;
    skos:definition "Establish Research timeline business activity define clear schedules, start and end dates/times for a research plan.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10544" ;
    skos:prefLabel "Establish Research timeline"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10545> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10245> ;
    skos:definition "Define Research Report Requirement business activity describe the written or formal outcome of findings and observation of the research.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10545" ;
    skos:prefLabel "Define Research Report Requirement"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10546> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10520> ;
    skos:definition "Establish Compliance Policy business activity develops and oversees implementation of compliance policy that apply to all activities of the enterprise to prevent, detect, monitor and report any compliance program in terms of the organization and its management. <br/><br/>Establish Compliance Policy activity interact with Managing Legal and Regulatory Requirements, Managing Risks and Managing Internal Controls. This business activity uses knowledge of legal regulations and obligations under which an enterprise is established, and operates.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10546" ;
    skos:prefLabel "Establish Compliance Policy"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10547> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10520> ;
    skos:definition "Monitor Compliance business activity is in charge of identifying, observing and keeping tracking of quality assurance tests that check how well the enterprises' business operations meet regulatory and internal process and procedural obligations.<br/><br/>Monitor Compliance business activity include tasks that develop compliance testing, also known as conformance testing for periodic, independent, and objective assessment of compliance-related processes and/or controls. Monitor Compliance plays a major role in helping to detect vulnerabilities in existing compliance risk management controls.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10547" ;
    skos:prefLabel "Monitor Compliance"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10548> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10520> ;
    skos:definition "Detect Compliance Changes business activity is in charge of discovering differences between Established Compliance Policies and ongoing enterprise operations.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10548" ;
    skos:prefLabel "Detect Compliance Changes"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10549> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10520> ;
    skos:definition "Report Compliance State business activity is in charge of providing documented evidence to show the enterprise and its business is compliant with established compliance policy requirements put in place.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10549" ;
    skos:prefLabel "Report Compliance State"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10550> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10579> ;
    skos:definition "Define/select, develop and deploy the enterprise architecture methodology, which is a framework that identifies the reference models, their relationships to each other, and the architecture management processes used to establish and maintain the enterprise architecture. The framework contains the policies, guidelines, documentation templates and approaches to be used throughout the enterprise. Enterprise Architecture Management processes define, develop, manage and maintain the enterprise architecture, which is the model describing the enterprise in all its facets.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10550" ;
    skos:prefLabel "Manage Enterprise Architecture Methodology"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10551> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10579> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10551" ;
    skos:prefLabel "Co-ordinate Enterprise Architecture"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10552> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10579> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10552" ;
    skos:prefLabel "Manage Enterprise Architecture Toolsets and Associated Standards"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10553> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10579> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10553" ;
    skos:prefLabel "Manage & Administer Architecture Repositories"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10554> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10579> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10554" ;
    skos:prefLabel "Manage Architecture Skillsets"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10555> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10579> ;
    skos:definition "Provides the reference source for the enterprise Standard Operating Environment that is the collection of applications, hardware, software and network components that have been standardized for use across the enterprise. The business strategies and plans provide a key starting point for the development and direction provided. Note that enterprise architecture management covers both IT and network technologies, and the processes impact other areas within the eTOM model, such as Knowledge Management and Process Architecture Management.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10555" ;
    skos:prefLabel "Provide Reference Source for Standard Operating Environment"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10556> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10579> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10556" ;
    skos:prefLabel "Co-ordinate Architecture Review"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10557> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10339> ;
    skos:definition "Metric Definition Measure Specification specifies details for measuring a Metric: prose-style and spreadsheet-style calculation formulas and equations (possibly including other Metrics), raw data sources, raw data capture methods (including APIs), measurement units.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10557" ;
    skos:prefLabel "Specify Metric Definition Measure"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10558> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10339> ;
    skos:definition "Metric Definition Measure Threshold Specification defines threshold values and intervals, with comparators for direction of threshold-crossing, applicable to a given Metric. Metric Definition Measure Threshold Specification also specifies threshold-crossing rules and consequences (actions to be performed, notifications to be sent).<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10558" ;
    skos:prefLabel "Specify Metric Definition Measure Threshold"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10559> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10604> ;
    skos:definition "Manage Enterprise Activity Results business activity is in charge of directing and controlling expected outcome of implementation of enterprise assets or resources.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10559" ;
    skos:prefLabel "Manage Enterprise Activity Results"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10560> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10604> ;
    skos:definition "Manage Enterprise Resource Allocation business activity is in charge of directing and controlling the distribution of resources aimed at delivering planned results.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10560" ;
    skos:prefLabel "Manage Enterprise Resource Allocation"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10566> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10458> ;
    skos:definition "Administer Training Program business activity manages the responsibility for the implementation of the training program. Administer Training Program is responsible for the coordination of trainers with training capability and facility. It administers the recordkeeping that tracks training capability, training facility, training participation progress, as well as administrating and budgeting tasks associated with training programs.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10566" ;
    skos:prefLabel "Administer Training Program"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10567> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10458> ;
    skos:definition "Select Training Method business activity makes a choice of the method of training to be used in a training program. Select Training Method is responsible for guiding selection of the most appropriate training method(s). It takes input from the training assessment activity based on requirements identified between needs and gaps, and recommendations made during the Needs Analysis or training design activities.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10567" ;
    skos:prefLabel "Select Training Method"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10569> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10522> ;
    skos:definition "Execute Contract business activity is in charge of ensuring an enterprise business contract is fully signed by the contracting parties in order to formalize the contractual relationship.<br/>To “execute a contract” means to perform the actions necessary to complete the contract’s terms or to sign a contract, making it legally binding. In legal terms.<br/> An executed contract refers to:<br/>• Signing: When all parties involved in the contract have agreed upon the terms and have signed the document, it is considered executed. <br/>• Fulfillment: An executed contract can also mean that all obligations outlined in the contract have been met by the parties involved.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10569" ;
    skos:prefLabel "Execute Contract"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10570> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10522> ;
    skos:definition "Analyze Contract business activity is in charge of examining and tracking all information within a contract over its lifecycle and the impact or implications on the enterprises ongoing concerns. <br/>Analyze Contract business activity is effectively used throughout the contract lifecycle to address the enterprises’ need to track implications at any point in time (financial or related to the status of the contract) to ensure that the clauses remain consistent and in line with any changes in the enterprises’ operating policy.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10570" ;
    skos:prefLabel "Analyze Contract"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10583> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10438> ;
    skos:definition "The Develop Budgets activity involves creating financial plans for a specific period to ensure the enterprise’s financial resources are used effectively and efficiently. This includes setting financial goals, estimating revenues and expenses, and allocating financial resources to various departments and projects. The main objectives are to align the budget with the enterprise’s strategic goals, control expenditures, and measure financial performance to achieve business objectives.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10583" ;
    skos:prefLabel "Develop Budgets"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10584> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10438> ;
    skos:definition "Allocate Financial Resources process involves distributing the enterprise’s financial resources to various departments, projects, or activities. The key steps include identifying financial needs, allocating the budget based on priorities, and continuously monitoring and adjusting the allocations. The main goals are to ensure optimal financial resource utilization, align financial allocations with strategic goals, and maintain financial control.<br/><br/>This process was renamed in 24.5 old name was Manage Resource Allocation<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10584" ;
    skos:prefLabel "Allocate Financial Resources"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10585> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10438> ;
    skos:definition "<span style=\"background-color:rgb(255,255,255);color:rgb(0,0,0);font-family:Lato, \"Helvetica Neue\", Helvetica, Arial, sans-serif;font-size:15px;\"><span style=\"-webkit-text-stroke-width:0px;display:inline !important;float:none;font-style:normal;font-variant-caps:normal;font-variant-ligatures:normal;font-weight:400;letter-spacing:normal;orphans:2;text-align:start;text-decoration-color:initial;text-decoration-style:initial;text-decoration-thickness:initial;text-indent:0px;text-transform:none;white-space:normal;widows:2;word-spacing:0px;\">The Design Capital Structure process involves determining the best mix of debt, equity, and other financial instruments to fund an enterprise’s operations and growth. The key steps include assessing financial needs, identifying funding sources, analyzing costs and risks, and optimizing the capital mix. The main goals are to minimize the cost of capital, manage risks, and align the capital structure with the enterprise’s long-term financial goals.</span></span><br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10585" ;
    skos:prefLabel "Design Capital Structure"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10586> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10438> ;
    skos:definition "Manage Financial Risk includes tasks to identify existing and potential financial risks that could negatively impact the organization’s financial profile, assess and quantify financial risks to prioritize them based on their impact, define and implement strategies to control financial threats, and continuously monitor the effectiveness of strategies that reduce financial risk. This enables the enterprise to clearly understand its financial risk profile, and develop approach to de-risk financial risks.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10586" ;
    skos:prefLabel "Manage Financial Risk"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10597> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10515> ;
    skos:definition "Manage Supply Chain Storage business activity handles the allocation and safe keeping of supplies.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10597" ;
    skos:prefLabel "Manage Supply Chain Storage"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10598> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10515> ;
    skos:definition "Manage Supply Chain Transport business activity handles the allocation and safe transport of supplies.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10598" ;
    skos:prefLabel "Manage Supply Chain Transport"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10599> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10513> ;
    skos:definition "Manage Inbound Supplies activity support receiving inbound supplies.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10599" ;
    skos:prefLabel "Manage Inbound Supplies"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10600> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10513> ;
    skos:definition "Manage Inventory supports activities for planning and executing inventory to support core business process inventory management activities.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10600" ;
    skos:prefLabel "Manage Inventory"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10601> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10513> ;
    skos:definition "Manage Outbound Suppliers'' activity support preparing and shipping supplies to their intended destinations.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10601" ;
    skos:prefLabel "Manage Outbound Supplies"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10602> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10513> ;
    skos:definition "Manage Supply Routing or (Cross Docking) handle the direct crossing of supplies received with supplies issuing.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10602" ;
    skos:prefLabel "Manage Supply Routing"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10612> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10568> ;
    skos:definition "Consolidate Contract business activity is in charge of combining contracts for similar products and/or services to form one single, all encompassing contract. <br/><br/>Consolidate Contract business activity supports Prepare Contract business activity by helping to reduce contract administration (executing, analyzing) and associated enterprise costs.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10612" ;
    skos:prefLabel "Consolidate Contracts"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10613> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10568> ;
    skos:definition "Negotiate Contract business activity is in charge of arranging for or bring about by discussion and settlement of contract terms.<br/>Negotiate Contract involves several key steps to ensure the involved parties reach a mutually beneficial agreement. <br/>It involves the following tasks: <br/>• Setting the right tone from the beginning with a positive and professional attitude. <br/>• Discussion and bargaining by exchange of offers and counteroffers. <br/>• Problem solving addressing any disagreements or obstacles.<br/>• Finalizing the contract ensuring that all negotiated points are clearly stated.<br/>After the contract is signed, following up on the implementation of the contract terms to ensure compliance and address any issues promptly is important.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10613" ;
    skos:prefLabel "Negotiate Contract"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10614> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10572> ;
    skos:definition "Responsible for ensuring the enterprise's position within the community, or communities, within which it operates. This includes local activities with, and financial and other support for, schools, libraries, hospitals, emergency services, etc.; concern for the immediate environment; visibility at local events; etc.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10614" ;
    skos:prefLabel "Ensure Community Visibility"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10615> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10572> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10615" ;
    skos:prefLabel "Communicate Community Messaging"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10616> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10572> ;
    skos:definition "Handle contact with customer interest groups and customer representatives, as well as dealing with public relations and community relations contacts made to the enterprise. These processes also influence the privacy policy for the enterprise.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10616" ;
    skos:prefLabel "Handle Community Contacts"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10617> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10475> ;
    skos:definition "Manage Master Data Integration business activity direct and control tasks to syndicate master data for a harmonized view across all business applications. Manage Master Data Integration ensure that master data is consistently integrated across various systems in an organization with the aim of achieving a coherent enterprise data model with common semantics that can be used to exchange data between business applications. This business activity involves data mapping, transformation, and loading (ETL), data synchronization, conflict resolution, and distributing master data based on a common model for end-to-end process integration.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10617" ;
    skos:prefLabel "Manage Master Data Integration"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10618> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10475> ;
    skos:definition "Manage Master Data Quality business activity direct and control tasks to ensure and improve the accuracy, completeness, and consistency of master data.<br/><br/>Manage Master Data Quality ensure the reliability of business decisions made based on the information/data, comply with regulations, and increase operational efficiency. It involves activities such as data profiling, data cleansing, data enrichment, and ongoing data quality monitoring.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10618" ;
    skos:prefLabel "Manage Master Data Quality"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10620> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10619> ;
    skos:definition "Create Master Data business activity is responsible for initiating a new set of master data, and ensuring that new master data is accurate, consistent, and relevant to the business.<br/> <br/>Create Master Data involves identifying master data, evaluating data sources, analyzing metadata, and analyzing underlying master data lifecycle(s) according to business goals.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10620" ;
    skos:prefLabel "Create Master Data"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10621> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10619> ;
    skos:definition "Update Master Data business activity is responsible for making changes to existing master data to ensure it remains accurate and up-to-date.<br/> <br/>Update Master Data maintains the integrity of the master data, ensuring it reflects current business realities, and improves business activities and events.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10621" ;
    skos:prefLabel "Update Master Data"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10622> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10619> ;
    skos:definition "Collect Master Data business activity is responsible for gathering master data from various sources.<br/><br/>Collect Master Data ensures data's accuracy, completeness, and relevance to the organization based on a well-defined scope. It involves defining the role of the master data, choosing the data collection method, planning data collection procedures, and collecting the data.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10622" ;
    skos:prefLabel "Collect Master Data"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10623> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10619> ;
    skos:definition "Remove Master Data business activity is responsible for deleting or deactivating master data that is no longer needed in order to maintain the relevancy of master data, comply with data retention policies, and optimize storage resources.<br/> <br/>Remove Master Data business activity involves cleaning up to remove or deactivate master data records and disassociating mastership of such data.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10623" ;
    skos:prefLabel "Remove Master Data"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10624> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10476> ;
    skos:definition "Manage Transactional Data Integration business activity directs and controls tasks to ensure transactional data is consistently integrated across various systems in an organization.<br/> <br/>Manage Transactional Data Integration improves data consistency, reduce redundancy, and ensure that all systems are using the same, most up-to-date version of data.<br/>It includes activities that do data mapping, data transformation, data loading (ETL), data synchronization, and data conflict resolution.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10624" ;
    skos:prefLabel "Manage Transactional Data Integration"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10625> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10476> ;
    skos:definition "Manage Transactional Data Quality business activity direct and control tasks to ensure the accuracy, completeness, and consistency of transactional data.<br/><br/>Manage Transactional Data Quality improve the reliability of business decisions made based on the data, comply with regulations, and increase operational efficiency. It includes activities that perform transactional data profiling, transactional data cleansing, transactional data enrichment, and ongoing transactional data quality monitoring.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10625" ;
    skos:prefLabel "Manage Transactional Data Quality"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10627> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10626> ;
    skos:definition "Create Transactional Data business activity is responsible for generating and data entry of new transactional data for storage accurately and in a timely fashion.<br/><br/>Create Transactional Data includes creating new business records, create data for a sales transaction, or any event that needs to be recorded.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10627" ;
    skos:prefLabel "Create Transactional Data"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10628> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10626> ;
    skos:definition "Update Transactional Data ensure changes or corrections in the transaction data.<br/><br/>Update Transactional Data ensure that changes to transaction data can maintain accuracy and relevance of the underlying transaction.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10628" ;
    skos:prefLabel "Update Transactional Data"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10629> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10626> ;
    skos:definition "Collect Transactional Data business activity is responsible for gathering transactional data for onward processing (analysis and reporting).<br/><br/>Collect Transactional Data involves extracting transactional data from various sources, transforming it into a suitable format, and loading it into appropriate storage to support decision-making with timely and reliable information.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10629" ;
    skos:prefLabel "Collect Transactional Data"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10630> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10626> ;
    skos:definition "Remove Transactional Data business activity is responsible for deleting transactional data that is no longer needed, in compliance with data retention policies and regulations.<br/><br/>Remove Transactional Data includes optimization of transactional data management performance, and ensuring compliance with data security, retention, and privacy regulations and laws.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10630" ;
    skos:prefLabel "Remove Transactional Data"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10631> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10477> ;
    skos:definition "Manage Reference Data Integration business activity directs and controls the seamless integration of reference data (such as location, currency, transaction codes, units, etc) across various systems and platforms within an organization.<br/><br/>Manage Reference Data Integration ensures that reference data is consistently and accurately represented across all systems, thereby reducing discrepancies and improving data integrity. Manage Reference Data Integration facilitates efficient data sharing and synchronization across different business units and includes activities that map reference data, consolidate reference data, and establish reference data integration protocols.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10631" ;
    skos:prefLabel "Manage Reference Data Integration"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10632> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10477> ;
    skos:definition "Manage Reference Data Quality business activity directs and controls tasks to maintain and enhance the quality of reference data and information.<br/><br/>Manage Reference Data Quality ensures reference data is accurate, complete, timely, and relevant for the business operations. It improves reference data usage, reduces reference data errors, and enhances operational efficiency through tasks such as reference data validation, reference data cleansing, reference data enrichment, and the implementation of reference data quality metrics and controls.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10632" ;
    skos:prefLabel "Manage Reference Data Quality"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10634> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10633> ;
    skos:definition "Create Reference Data business task is responsible for generating new reference data that can be used across various systems and applications within an organization.<br/> <br/>Create Reference Data ensures that the new reference data is accurate, consistent, and relevant to the business. This involves defining the reference data elements, setting up the reference data structure, and populating reference data.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10634" ;
    skos:prefLabel "Create Reference Data"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10635> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10633> ;
    skos:definition "Update Reference Data business task is responsible for making changes to existing reference data to ensure it remains accurate and up-to-date.<br/><br/>Update Reference Data ensures that reference data maintains the integrity of the data, ensure reference data reflects current business realities, and improves the business operations. This includes transactions or developing actions to update reference data.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10635" ;
    skos:prefLabel "Update Reference Data"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10636> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10633> ;
    skos:definition "Collect Reference Data business task is responsible for gathering reference data from various sources to be used in the organization.<br/> <br/>Collect Reference Data ensures that reference data is accurate, complete, and relevant to the organization and its operations. This involves defining the aim of collecting reference data, choosing the reference data collection method, planning reference data collection procedures, and collecting the reference data.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10636" ;
    skos:prefLabel "Collect Reference Data"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10637> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10633> ;
    skos:definition "Remove Reference Data business task is responsible for deleting or remove reference data that is no longer needed.<br/><br/>Remove Reference Data supports the need to maintain the relevancy of the reference data, comply with data retention policies, and optimize data storage resources. This includes reference data cleanup to remove or unlink reference data.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10637" ;
    skos:prefLabel "Remove Reference Data"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10638> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10478> ;
    skos:definition "Manage Unstructured Data Integration business activity directs and control tasks to connect to many different sources of unstructured business/operational data, extract that data, and store it in a suitable destination, such as a data lake or data warehouse.<br/><br/>Manage Unstructured Data Integration improve the consistency of unstructured data, provide comprehensive unstructured data access, and deliver timely, accurate unstructured data for decision support. This includes extracting reference data from sources, transforming unstructured data to fit operational needs, and loading unstructured data into target (database, data mart, or data warehouse) storage systems.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10638" ;
    skos:prefLabel "Manage Unstructured Data Integration"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10639> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10478> ;
    skos:definition "Manage Unstructured Data Quality is responsible for ensuring high quality and trust of unstructured data across the enterprise.<br/> <br/>Manage Unstructured Data Quality tasks include unstructured data cleansing, unstructured data transformation, and unstructured data integration.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10639" ;
    skos:prefLabel "Manage Unstructured Data Quality"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10641> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10640> ;
    skos:definition "Create Unstructured Data task is responsible for generating new unstructured data, and ensuring that new unstructured data is accurate and consistent.<br/> <br/>Create Unstructured Data involves defining the unstructured data elements, setting up the unstructured data structure, and populating the data.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10641" ;
    skos:prefLabel "Create Unstructured Data"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10642> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10640> ;
    skos:definition "Update Unstructured Data task is responsible for making changes to existing unstructured data to ensure it remains accurate and up-to-date.<br/> <br/>Update Unstructured Data maintains the integrity of unstructured data, ensuring it reflects current realities, and improves the businesses operations. It involves using transactions or developing custom initiatives to update unstructured data.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10642" ;
    skos:prefLabel "Update Unstructured Data"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10643> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10640> ;
    skos:definition "Collect Unstructured Data task is responsible for gathering unstructured data from various sources to be used in the organization.<br/> <br/>Collect Unstructured Data ensures unstructured data is accurate, complete, and relevant to the organization. It includes tasks to define the aim of the collecting unstructured data, choosing the unstructured data collection method, planning unstructured data collection procedures, and collecting the unstructured data.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10643" ;
    skos:prefLabel "Collect Unstructured Data"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10644> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10640> ;
    skos:definition "Remove Unstructured Data task is responsible for deleting or removing unstructured data that is no longer needed according to the enterprise's data management policies.<br/><br/>Remove Unstructured Data supports activities to maintain the relevancy of data, comply with data retention policies, and optimize storage resources. This includes unstructured data removal.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10644" ;
    skos:prefLabel "Remove Unstructured Data"@en .

