    skos:prefLabel "Develop Marketing Campaign Metrics"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA1_EA7332> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA1_EA7351> ;
