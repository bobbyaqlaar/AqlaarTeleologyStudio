    skos:prefLabel "Gain Enterprise Commitment to Market Strategy"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA1_EA7341> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA1_EA7394> ;
    skos:definition "Gather Market information processes focus on establishment and Management of relationships with external providers of market information, and management of internal resources used for providing market information.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7341" ;
    skos:prefLabel "Gather Market Information"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA1_EA7342> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA1_EA7394> ;
    skos:definition "Analyze Market information processes focus on developing enterprise and business views of the market, based on the analysis of the external and internal information sources. Methodologies used for developing market forecasts, as well as the development of forecasts is managed by this process.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7342" ;
    skos:prefLabel "Analyze Market Information"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA1_EA7343> a skos:Concept ;
