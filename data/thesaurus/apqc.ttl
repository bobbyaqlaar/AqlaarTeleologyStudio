<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA1_EA7365> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA1_EA7408> ;
    skos:definition "Analyze Market Problem Information business activity is in charge of performing the detailed investigation based on the market problem information collected.<br/>"@en ;
