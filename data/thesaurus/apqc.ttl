<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7832> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7899> ;
    skos:definition "Validate that predicted/expected value is delivered by the solution. It validates that the customer is capable of realizing maximum value from the operation or use of the solution and that intense Provider involvement is no longer needed to manage the solution.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7832" ;
    skos:prefLabel "Validate Solution Predicted/Expected Value"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7833> a skos:Concept ;
