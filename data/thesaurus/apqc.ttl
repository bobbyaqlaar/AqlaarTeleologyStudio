<http://ots.local/thesaurus/apqc/9_6_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_6_2> ;
    skos:definition "Collecting and reporting all pertinent information regarding the taxes paid by the organization's employees."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.6.2.2" ;
    skos:prefLabel "Capture and report relevant tax data"@en .

