    skos:inScheme thes:apqc ;
    skos:notation "9.7.3.1" ;
    skos:prefLabel "Manage in-house bank accounts for subsidiaries"@en .

<http://ots.local/thesaurus/apqc/9_7_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_3> ;
    skos:definition "Arranging loans for subsidiaries from in-house banks."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.3.2" ;
    skos:prefLabel "Manage and facilitate inter-company borrowing transactions"@en .

<http://ots.local/thesaurus/apqc/9_7_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_3> ;
    skos:definition "Handling payments made for subsidiaries by parent company."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.3.3" ;
    skos:prefLabel "Manage centralized outgoing payments on behalf of subsidiaries"@en .

<http://ots.local/thesaurus/apqc/9_7_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_3> ;
    skos:definition "Handling payments received by parent company for subsidiaries."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.3.4" ;
    skos:prefLabel "Manage central incoming payments on behalf of subsidiaries"@en .

<http://ots.local/thesaurus/apqc/9_7_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_3> ;
    skos:definition "Taking care of all business outflows and recording as whole. Manage making all payments for the organization and its units or subsidiaries. Track in books of accounts of parent company."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.3.5" ;
    skos:prefLabel "Manage internal payments and netting transactions"@en .

<http://ots.local/thesaurus/apqc/9_7_3_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_3> ;
    skos:definition "Computing all expenses paid to and receivables collected over the organization's banking activity. Calculate all charges and receivables, towards interest, fees, and any other payments over its own bank accounts. Record transactions in the books of accounts."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.3.6" ;
    skos:prefLabel "Calculate interest and fees for in-house bank accounts"@en .

<http://ots.local/thesaurus/apqc/9_7_3_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_3> ;
    skos:definition "Facilitating account statements for all in-house banking activity."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.3.7" ;
    skos:prefLabel "Provide account statements for in-house bank accounts"@en .

<http://ots.local/thesaurus/apqc/9_7_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_4> ;
    skos:definition "Developing and instituting principles that the organization ill use in making investments."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.4.1" ;
    skos:prefLabel "Establish investment policy"@en .

<http://ots.local/thesaurus/apqc/9_7_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_4> ;
    skos:definition "Maintaining smooth relations with financial investment banks that help availing loans and services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.4.2" ;
    skos:prefLabel "Manage financial intermediary relationships"@en .

<http://ots.local/thesaurus/apqc/9_7_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_4> ;
    skos:definition "Managing and maintaining enough liquidity in form of cash and cash equivalents in the business to meet urgent and timely requirements"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.4.3" ;
    skos:prefLabel "Manage liquidity"@en .

<http://ots.local/thesaurus/apqc/9_7_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_4> ;
    skos:definition "Managing the exposure incurred by the issuer for providing credit to the borrower."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.4.4" ;
    skos:prefLabel "Manage issuer exposure"@en .

