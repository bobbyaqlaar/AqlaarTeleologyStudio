    skos:definition "Paying for expense reimbursement requests from employees. (Follow Approve reimbursements and advances [10882] according to policies and conditions.)"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.6.2.4" ;
    skos:prefLabel "Process reimbursements and advances"@en .

<http://ots.local/thesaurus/apqc/9_6_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_6_2> ;
    skos:definition "Maintaining accounts of individuals who are connected with business."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.6.2.5" ;
    skos:prefLabel "Manage personnel accounts"@en .

<http://ots.local/thesaurus/apqc/9_6_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_6_3> ;
    skos:definition "Developing procedures for using company credit cards. Set or approve credit limits."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.6.3.1" ;
    skos:prefLabel "Establish corporate credit card policies and approval limits"@en .

<http://ots.local/thesaurus/apqc/9_6_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_6_3> ;
    skos:definition "Handling applications credit card applications for business expenses."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.6.3.2" ;
    skos:prefLabel "Process corporate credit card requests"@en .

<http://ots.local/thesaurus/apqc/9_6_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_6_3> ;
    skos:definition "Obtaining credit cards for business-related expenses."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.6.3.3" ;
    skos:prefLabel "Order corporate credit cards"@en .

<http://ots.local/thesaurus/apqc/9_6_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_6_3> ;
    skos:definition "Handling credit card accounts of business customers."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.6.3.4" ;
    skos:prefLabel "Manage corporate credit card accounts"@en .

<http://ots.local/thesaurus/apqc/9_6_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_6_3> ;
    skos:definition "Authorizing changes to the available credit advances."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.6.3.5" ;
    skos:prefLabel "Approve/Change credit limits"@en .

<http://ots.local/thesaurus/apqc/9_6_3_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_6_3> ;
    skos:definition "Blocking an existing credit card to disable all future transactions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.6.3.6" ;
    skos:prefLabel "Cancel/Deactivate credit card"@en .

<http://ots.local/thesaurus/apqc/9_7_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_1> ;
    skos:definition "Selecting opportunities and the authoritative body for investments in trading in bonds, currencies, financial derivatives, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.1.1" ;
    skos:prefLabel "Establish scope and governance of treasury operations"@en .

<http://ots.local/thesaurus/apqc/9_7_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_1> ;
    skos:definition "Creating and providing investment regulations for the organization. Establish policies and procedures for investments to optimize liquidity in treasury operations. Create a written copy of it."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.1.2" ;
    skos:prefLabel "Establish and publish treasury policies"@en .

<http://ots.local/thesaurus/apqc/9_7_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_1> ;
    skos:definition "Making processes for investing. Create steps for investments in bonds, currencies, and financial derivatives in order to optimize company's liquidity, invest excess cash, and reduce its financial risks."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.1.3" ;
    skos:prefLabel "Develop treasury procedures"@en .

<http://ots.local/thesaurus/apqc/9_7_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_1> ;
    skos:definition "Checking treasury processes in order to optimize company's liquidity, invest excess cash, and reduce its financial risks."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.1.4" ;
    skos:prefLabel "Monitor treasury procedures"@en .

<http://ots.local/thesaurus/apqc/9_7_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_1> ;
    skos:definition "Auditing the treasury function."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.1.5" ;
    skos:prefLabel "Audit treasury procedures"@en .

<http://ots.local/thesaurus/apqc/9_7_1_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_1> ;
    skos:definition "Reassessing all treasury procedures based on audit findings."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.1.6" ;
    skos:prefLabel "Revise treasury procedures"@en .

<http://ots.local/thesaurus/apqc/9_7_1_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_1> ;
    skos:definition "Creating and managing the internal control systems for investments in bonds, currencies, and financial derivatives to verify procedures."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.1.7" ;
    skos:prefLabel "Develop and confirm internal controls for treasury"@en .

<http://ots.local/thesaurus/apqc/9_7_1_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_1> ;
    skos:definition "Describing the need of treasury security requirements for controlling access, reliability of information, accountability, and availability of information in the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.1.8" ;
    skos:prefLabel "Define treasury security requirements"@en .

<http://ots.local/thesaurus/apqc/9_7_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_2> ;
    skos:definition "Correcting cash differences in the books of accounts. Make optimum utilization of funds available in the business. Check for differences to rectify."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.2.1" ;
    skos:prefLabel "Manage and reconcile cash positions"@en .

<http://ots.local/thesaurus/apqc/9_7_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_2> ;
    skos:definition "Taking care of all cash-related activities in the business. Utilize short-term assets that can be easily convertible into cash, such as marketable securities, commercial paper and short-term government bonds, and treasury bills."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.2.2" ;
    skos:prefLabel "Manage cash equivalents"@en .

<http://ots.local/thesaurus/apqc/9_7_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_2> ;
    skos:definition "Supervising all online transactions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.2.3" ;
    skos:prefLabel "Process and oversee electronic fund transfers (EFTs)"@en .

<http://ots.local/thesaurus/apqc/9_7_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_2> ;
    skos:definition "Preparing forecasts for the cash generated or used by the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.2.4" ;
    skos:prefLabel "Develop cash flow forecasts"@en .

<http://ots.local/thesaurus/apqc/9_7_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_2> ;
    skos:definition "Delaying the outflow of funds as long as possible, but encourage the inflow of as fast as possible."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.2.5" ;
    skos:prefLabel "Manage cash flows"@en .

<http://ots.local/thesaurus/apqc/9_7_2_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_2> ;
    skos:definition "Presenting reports on all cash-related activities. Collect and manage short-term investing activities. Prepare reports of all transactions done."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.2.6" ;
    skos:prefLabel "Produce cash management accounting transactions and reports"@en .

<http://ots.local/thesaurus/apqc/9_7_2_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_2> ;
    skos:definition "Maintaining and directing the course of relationships with banking partners."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.2.7" ;
    skos:prefLabel "Manage and oversee banking relationships"@en .

<http://ots.local/thesaurus/apqc/9_7_2_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_2> ;
    skos:definition "Studying and finalizing bank fees for services provided by banks. Negotiate and finalize nominal fees that bank charges for various services, such as requesting a deposit slip or counter check or certifying papers."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.7.2.8" ;
    skos:prefLabel "Analyze, negotiate, resolve, and confirm bank fees"@en .

<http://ots.local/thesaurus/apqc/9_7_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_7_3> ;
