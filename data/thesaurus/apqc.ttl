    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7406" ;
    skos:prefLabel "Report Marketing Performance Assessment"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA1_EA7407> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA1_EA7324> ;
    skos:definition "Identify Market Problem business activity is in charge of discovering an issue, challenge or concern related to the organizations exchanges and commercial engagement with parties. <br/><br/>Identify Market Problem includes activities that define market problem, and collect market problem information (and data).<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7407" ;
    skos:prefLabel "Identify Market Problem"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA1_EA7409> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA1_EA7324> ;
    skos:definition "Develop Market Problem Solution business activity is in charge of establishing mediatory activities or solutions to market problems. <br/><br/>Develop Market Problem Solution will include activities that cover, but are not limited to addressing competitiveness, value proposition, brand index, and business models.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7409" ;
    skos:prefLabel "Develop Market Problem Solution"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA1_EA7410> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA1_EA7324> ;
    skos:definition "Execute Market Problem Solution business activity is in charge of implementing and administering answers to market problems. <br/><br/>This business activity leverages 'Develop Market Problem Solution' to inform the optimal approach to use in implementing answers to market problem.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7410" ;
    skos:prefLabel "Execute Market Problem Solution"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA1_EA7411> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA1_EA7319> ;
    skos:definition "Define Marketing Performance Areas business activity identifies all the areas that require marketing performance management, such as channel coverage, market growth, competitive health etc.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7411" ;
    skos:prefLabel "Define Marketing Performance Areas"@en .

