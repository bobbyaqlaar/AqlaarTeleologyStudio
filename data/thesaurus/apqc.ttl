    skos:prefLabel "Gain Enterprise Commitment to resource strategy and resource plans"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA6_EA9309> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA6_EA9289> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:apqc ;
