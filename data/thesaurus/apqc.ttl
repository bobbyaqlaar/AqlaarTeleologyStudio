    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7405" ;
    skos:prefLabel "Evaluate Marketing Performance"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA1_EA7406> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA1_EA7413> ;
