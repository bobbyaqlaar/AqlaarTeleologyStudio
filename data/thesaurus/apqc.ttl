    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA4_EA8217" ;
    skos:prefLabel "Conduct Operational Readiness Testing"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA4_EA8218> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA4_EA8382> ;
    skos:definition "Not used for this process element<br/>"@en ;
