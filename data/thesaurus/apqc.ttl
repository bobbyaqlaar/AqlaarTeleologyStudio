    skos:inScheme thes:apqc ;
    skos:notation "9.6.1.7" ;
    skos:prefLabel "Research/Resolve payable exceptions"@en .

<http://ots.local/thesaurus/apqc/9_6_1_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_6_1> ;
    skos:definition "Making payments for products/services on due dates (payment cycle) decided by parties involved."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.6.1.8" ;
    skos:prefLabel "Process payments"@en .

<http://ots.local/thesaurus/apqc/9_6_1_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_6_1> ;
    skos:definition "Clarifying or address queries relating to the particulars of AP such as date, discounts, amount, and installments. Coordinate with concerned parties about the fulfillment of bills payable."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.6.1.9" ;
    skos:prefLabel "Respond to AP inquiries"@en .

<http://ots.local/thesaurus/apqc/9_6_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_6_2> ;
    skos:definition "Explaining policies and procedures related to reimbursements requests by employees. Set policies regarding reimbursement process and amount limits etc. Inform employees."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.6.2.1" ;
