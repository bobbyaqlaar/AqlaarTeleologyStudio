@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix thes: <http://ots.local/thesaurus/> .

<http://ots.local/thesaurus/apqc/10_1_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_1_1> ;
    skos:definition "Creating alignment between the requirement of properties and the overall business strategy. This process requires the organization to align the requirement of properties in accordance with its business strategies of the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.1.1.1" ;
    skos:prefLabel "Confirm alignment of property requirements with business strategy"@en .

<http://ots.local/thesaurus/apqc/10_1_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_1_1> ;
    skos:definition "Evaluating the impact of the external environment. Evaluate the circumstances, objects, events, and aspects surrounding an organization that affects its actions and selections and that recognizes its opportunities and risks."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.1.1.2" ;
    skos:prefLabel "Appraise the external environment"@en .

<http://ots.local/thesaurus/apqc/10_1_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_1_1> ;
    skos:definition "Deciding whether to buy or build properties. Study the market forces about property prices and cost of construction in order to take decisions based on the market research."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.1.1.3" ;
    skos:prefLabel "Determine build, buy, or lease decision"@en .

<http://ots.local/thesaurus/apqc/10_1_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_1_2> ;
    skos:definition "Preparing and analyzing different designs for a facility in order to finalize which design will be the most suitable option."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.1.2.1" ;
    skos:prefLabel "Design facility"@en .

<http://ots.local/thesaurus/apqc/10_1_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_1_2> ;
    skos:definition "Evaluating the feasibility of budgets prepared for the construction of facilities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.1.2.2" ;
    skos:prefLabel "Analyze budget"@en .

<http://ots.local/thesaurus/apqc/10_1_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_1_2> ;
    skos:definition "Assessing and choosing the appropriate property. Analyze the property requirements. Review the available property options. Finalize the most suitable option."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.1.2.3" ;
    skos:prefLabel "Select property"@en .

<http://ots.local/thesaurus/apqc/10_1_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_1_2> ;
    skos:definition "Discussing the terms and conditions of facilities to be occupied according to the business requirements and availability of budgets."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.1.2.4" ;
    skos:prefLabel "Negotiate terms for facility"@en .

<http://ots.local/thesaurus/apqc/10_1_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_1_2> ;
    skos:definition "Constructing the buildings. Manage renovations according to requirements and demands."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.1.2.5" ;
    skos:prefLabel "Manage construction or modification to building"@en .

<http://ots.local/thesaurus/apqc/10_1_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_1_3> ;
    skos:definition "Attaining the office space with all assets (tables, chairs, computers, admin staff, etc.) according to requirements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.1.3.1" ;
    skos:prefLabel "Acquire workspace and facilities"@en .

<http://ots.local/thesaurus/apqc/10_1_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_1_3> ;
    skos:definition "Modifying the formation of the workspace and its assets. Make necessary changes in an office space with all assets (tables, chairs, computers, admin staff, interior designing, etc.) according to requirements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.1.3.2" ;
    skos:prefLabel "Change fit/form/function of workspace and facilities"@en .

<http://ots.local/thesaurus/apqc/10_1_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_1_4> ;
    skos:definition "Shifting staff or employees from one place to another place according to changes in business requirements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.1.4.1" ;
    skos:prefLabel "Relocate people"@en .

<http://ots.local/thesaurus/apqc/10_1_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_1_4> ;
    skos:definition "Relocating the tools and raw materials. Shift raw or finished material and machines of company from one place to another place according to changes in business requirements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.1.4.2" ;
    skos:prefLabel "Relocate material and tools"@en .

<http://ots.local/thesaurus/apqc/10_1_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_1_4> ;
    skos:definition "Ensuring safe, controlled access to organizational facilities by implementing and maintaining physical security protocols, systems, and procedures. This includes issuing and managing access credentials; monitoring entry points; coordinating visitor access; and operating security technologies such as surveillance, alarms, and access-control systems. Establish and enforce policies to protect employees, visitors, assets, and information; respond to security incidents or breaches; and routinely assess the effectiveness of security measures."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.1.4.3" ;
    skos:prefLabel "Provide facility access and security"@en .

<http://ots.local/thesaurus/apqc/10_2_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_2_1> ;
    skos:definition "Establishing what funds will be invested in the construction of assets for the advancement of established business objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.2.1.1" ;
    skos:prefLabel "Define capital investment plan"@en .

<http://ots.local/thesaurus/apqc/10_2_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_2_1> ;
    skos:definition "Monitoring plans on capital projects. Capital projects can be purchasing buildings, lands, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.2.1.2" ;
    skos:prefLabel "Monitor capital program"@en .

<http://ots.local/thesaurus/apqc/10_2_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_2_1> ;
    skos:definition "Acquiring the loans needed to construct necessary assets."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.2.1.3" ;
    skos:prefLabel "Secure construction financing"@en .

<http://ots.local/thesaurus/apqc/10_2_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_2_2> ;
    skos:definition "Developing a strategy to perform asset construction. Assure that timelines, regulations, and resources are on task and on budget."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.2.2.1" ;
    skos:prefLabel "Develop construction strategy"@en .

<http://ots.local/thesaurus/apqc/10_2_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_2_2> ;
    skos:definition "Managing the construction process to ensure that activates are on task, on budget, and are being performed with safety and quality in mind."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.2.2.2" ;
    skos:prefLabel "Perform construction performance management"@en .

<http://ots.local/thesaurus/apqc/10_2_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_2_2> ;
    skos:definition "Gathering the required permits for construction from the proper jurisdiction. This may include inspections during and after construction to verify that the new asset meets all national, regional, and local codes."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.2.2.3" ;
    skos:prefLabel "Obtain construction permissions"@en .

<http://ots.local/thesaurus/apqc/10_2_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_2_2> ;
    skos:definition "Designing assets to meet organizational needs as well as ensuring that the asset adheres to all national, regional, and local construction codes."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.2.2.4" ;
    skos:prefLabel "Design assets"@en .

<http://ots.local/thesaurus/apqc/10_2_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_2_2> ;
    skos:definition "Determining what resources will need to be acquired in order to carry out construction. Plan when, where, and how resources will be used. Determine the length of time resources will be utilized."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.2.2.5" ;
    skos:prefLabel "Plan construction resources"@en .

<http://ots.local/thesaurus/apqc/10_2_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_2_3> ;
    skos:definition "Defining a timetable for which to execute the construction of the asset."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.2.3.1" ;
    skos:prefLabel "Schedule construction work"@en .

<http://ots.local/thesaurus/apqc/10_2_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_2_3> ;
    skos:definition "Gathering resources needed to complete all construction work. Verify that all resources have the proper training and skills to perform the work."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.2.3.2" ;
    skos:prefLabel "Obtain resources"@en .

<http://ots.local/thesaurus/apqc/10_2_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_2_3> ;
    skos:definition "Building new assets necessary for the organization. Be aware of any construction codes and permits that need to be addressed."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.2.3.3" ;
    skos:prefLabel "Construct new assets"@en .

<http://ots.local/thesaurus/apqc/10_2_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_2_3> ;
    skos:definition "Modifying existing assets to align with the changing needs of the organization. Be aware of any construction codes and permits that need to be addressed."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.2.3.4" ;
    skos:prefLabel "Augment existing assets"@en .

<http://ots.local/thesaurus/apqc/10_2_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_2_3> ;
    skos:definition "Determining the need to replace existing assets. Be aware of any construction codes and permits that need to be addressed."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.2.3.5" ;
    skos:prefLabel "Renew/Replace assets"@en .

<http://ots.local/thesaurus/apqc/10_2_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_2_4> ;
    skos:definition "Monitoring construction to insure that all regulatory laws are being adhered to, that all work is being performed in a timely manner, and that quality assurance is met at all steps of the construction process."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.2.4.1" ;
    skos:prefLabel "Monitor work performance"@en .

<http://ots.local/thesaurus/apqc/10_2_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_2_4> ;
    skos:definition "Implementing a checks and balances system to verify that the construction was performed correctly. Rework when errors are found."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.2.4.2" ;
    skos:prefLabel "Undertake construction quality control"@en .

<http://ots.local/thesaurus/apqc/10_2_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_2_4> ;
    skos:definition "Implementing records to include all construction work that has been performed. Include all new or modified construction, and any construction or regulatory issues that might have occurred."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.2.4.3" ;
    skos:prefLabel "Create work and asset records"@en .

<http://ots.local/thesaurus/apqc/10_2_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_2_4> ;
    skos:definition "Ensuring that safety, security, and access is maintained. Provide a workplace that meets and exceeds all local, state, and federal guidelines. Provide security and access to the building site as set forth by safety and organizational guidelines."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.2.4.4" ;
    skos:prefLabel "Manage safety, security, and access to sites"@en .

<http://ots.local/thesaurus/apqc/10_2_4_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_2_4> ;
    skos:definition "Scheduling and performing commissioning activities to verify that constructed assets operate as intended, meet specified requirements, and are ready for handover, use, or operational acceptance."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.2.4.5" ;
    skos:prefLabel "Schedule and perform commissioning"@en .

<http://ots.local/thesaurus/apqc/10_3_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_3_1> ;
    skos:definition "Creating goals and agendas to better realize the success of the maintenance policies that have been put into place."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.3.1.1" ;
    skos:prefLabel "Develop maintenance strategies"@en .

<http://ots.local/thesaurus/apqc/10_3_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_3_1> ;
    skos:definition "Evaluating assets in order to project future requirements for maintenance. Evaluate the present working condition of assets. Determine the future maintenance requirements of assets."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.3.1.2" ;
    skos:prefLabel "Analyze assets and predict maintenance requirements"@en .

<http://ots.local/thesaurus/apqc/10_3_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_3_1> ;
    skos:definition "Communicating policies in regards to asset maintenance. Provide a clear set of procedures and policies that outline what will be involved in the maintenance process."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.3.1.3" ;
    skos:prefLabel "Specify maintenance policies"@en .

<http://ots.local/thesaurus/apqc/10_3_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_3_1> ;
    skos:definition "Devising a methodology and procedure for assimilating the works of planned maintenance into the schedule scheme for the processing of finished products that utilizes the same machinery."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.3.1.4" ;
    skos:prefLabel "Integrate preventive maintenance into operations schedule"@en .

<http://ots.local/thesaurus/apqc/10_3_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_3_1> ;
    skos:definition "Identifying the steps needed for asset maintenance. List out the those tasks that are involved in completing this process. Prioritize the tasks that are created."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.3.1.5" ;
    skos:prefLabel "Identify work management tasks & priorities"@en .

<http://ots.local/thesaurus/apqc/10_3_1_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_3_1> ;
    skos:definition "Analyzing workload needs in relation to asset maintenance and plan resources around those needs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.3.1.6" ;
    skos:prefLabel "Conduct resource planning"@en .

<http://ots.local/thesaurus/apqc/10_3_1_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_3_1> ;
    skos:definition "Creating procedures on how to maintain assets."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.3.1.7" ;
    skos:prefLabel "Create asset work plans"@en .

<http://ots.local/thesaurus/apqc/10_3_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_3_2> ;
    skos:definition "Defining a timetable for which to execute the maintenance of the asset."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.3.2.1" ;
    skos:prefLabel "Schedule maintenance work"@en .

<http://ots.local/thesaurus/apqc/10_3_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_3_2> ;
    skos:definition "Gathering resources needed to complete all maintenance work. Verify that all resources have the proper training and skills to perform the work."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.3.2.2" ;
    skos:prefLabel "Obtain required resources"@en .

<http://ots.local/thesaurus/apqc/10_3_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_3_2> ;
    skos:definition "Implementing a checks and balances system to verify that the maintenance was performed correctly. Rework when errors are found."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.3.2.3" ;
    skos:prefLabel "Undertake quality control"@en .

<http://ots.local/thesaurus/apqc/10_3_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_3_2> ;
    skos:definition "Modifying existing maintenance records to include all new work that has been performed, what assets were serviced, and any issues that might have arisen."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.3.2.4" ;
    skos:prefLabel "Update work and asset records"@en .

<http://ots.local/thesaurus/apqc/10_3_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_3_2> ;
    skos:definition "Assuring that all safety laws and regulations are being implemented and followed. Align practices with regulatory bureaus such as OSHA , EHS, and ISO."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.3.2.5" ;
    skos:prefLabel "Manage maintenance work safety"@en .

<http://ots.local/thesaurus/apqc/10_3_2_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_3_2> ;
    skos:definition "Outlining what should be achieved through predictive indicators with regard to performing maintenance. This could include the length of time it takes to perform routine maintenance or how often unplanned maintenance feasibly occur."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.3.2.6" ;
    skos:prefLabel "Define maintenance performance targets"@en .

<http://ots.local/thesaurus/apqc/10_3_2_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_3_2> ;
    skos:definition "Following set performance targets, monitor and gage the success of the organization in meeting those targets."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.3.2.7" ;
    skos:prefLabel "Monitor maintenance performance against targets/contracts"@en .

<http://ots.local/thesaurus/apqc/10_3_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_3_3> ;
    skos:definition "Performing prophylactic maintenance in an effort to avoid corrective or unplanned repairs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.3.3.1" ;
    skos:prefLabel "Perform preventative asset maintenance"@en .

<http://ots.local/thesaurus/apqc/10_3_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_3_3> ;
    skos:definition "Carrying out required maintenance to continue upkeep of equipment or assets."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.3.3.2" ;
    skos:prefLabel "Perform routine asset maintenance"@en .

<http://ots.local/thesaurus/apqc/10_3_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_3_3> ;
    skos:definition "Repairing or correcting faults that occur with an asset. This could be a break or other repairable damage."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.3.3.3" ;
    skos:prefLabel "Perform corrective asset maintenance and repairs"@en .

<http://ots.local/thesaurus/apqc/10_3_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_3_3> ;
    skos:definition "Realizing potential or current problems with assets that would require unplanned maintenance. Unplanned maintenance is a repair or change that needs to be made that is not preventative or routine."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.3.3.4" ;
    skos:prefLabel "Identify unplanned maintenance requirements"@en .

<http://ots.local/thesaurus/apqc/10_3_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_3_3> ;
    skos:definition "Performing repairs that occur outside of normal routine or preventative maintenance."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.3.3.5" ;
    skos:prefLabel "Perform unplanned maintenance and repairs"@en .

<http://ots.local/thesaurus/apqc/10_4_10_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_4_10> ;
    skos:definition "Demolishing and securing asset and resulting parts/debris."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.4.10.1" ;
    skos:prefLabel "Demolish and secure"@en .

<http://ots.local/thesaurus/apqc/10_4_10_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_4_10> ;
    skos:definition "Performing remediation or restoration activities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.4.10.2" ;
    skos:prefLabel "Restore site"@en .

<http://ots.local/thesaurus/apqc/10_4_10_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_4_10> ;
    skos:definition "Managing and reporting site status. Align efforts to all legal, regulatory and social/environmental responsibilities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.4.10.3" ;
    skos:prefLabel "Monitor site for duration of time required by regulators"@en .

<http://ots.local/thesaurus/apqc/10_4_10_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_4_10> ;
    skos:definition "Supporting handover to new operator or landowner. Include proper documentation on asset history and current state to enable orderly transition."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.4.10.4" ;
    skos:prefLabel "Prepare handover to new operator or landowner"@en .

<http://ots.local/thesaurus/apqc/10_4_11_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_4_11> ;
    skos:definition "Preparing material safety sheets. Capture material safety records to properly apply handling and disposal requirements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.4.11.1" ;
    skos:prefLabel "Maintain material safety data sheets"@en .

<http://ots.local/thesaurus/apqc/10_4_11_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_4_11> ;
    skos:definition "Understanding and communicating hazardous material regulatory requirements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.4.11.2" ;
    skos:prefLabel "Maintain awareness of and communicate regulatory requirements"@en .

<http://ots.local/thesaurus/apqc/10_4_11_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_4_11> ;
    skos:definition "Planning, overseeing, and tracking hazardous material handling and disposal."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.4.11.3" ;
    skos:prefLabel "Maintain hazardous material handling and disposal"@en .

<http://ots.local/thesaurus/apqc/10_4_11_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_4_11> ;
    skos:definition "Planning, supporting, and documenting hazardous material audits."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.4.11.4" ;
    skos:prefLabel "Manage compliance audits"@en .

<http://ots.local/thesaurus/apqc/10_4_11_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_4_11> ;
    skos:definition "Identifying and establishing approaches to dispose of hazardous materials/waste."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.4.11.5" ;
    skos:prefLabel "Recognize need to disposition hazardous materials/waste"@en .

<http://ots.local/thesaurus/apqc/10_4_11_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_4_11> ;
    skos:definition "Evaluating hazardous materials and waste for appropriate disposition. Apply requirements and initiate disposition activities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.4.11.6" ;
    skos:prefLabel "Determine disposition and associated processing"@en .

<http://ots.local/thesaurus/apqc/10_4_11_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_4_11> ;
    skos:definition "Performing disposition, disposal, and reprocessing activities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.4.11.7" ;
    skos:prefLabel "Manage disposition, disposal, reprocessing activities"@en .

<http://ots.local/thesaurus/apqc/10_4_11_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_4_11> ;
    skos:definition "Documenting and reporting disposition, disposal, and reprocessing activities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.4.11.8" ;
    skos:prefLabel "Manage documentation and reporting"@en .

<http://ots.local/thesaurus/apqc/10_4_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_4_1> ;
    skos:definition "Monitoring assets against their planned useful life. Each asset may have specific criteria that indicate their usability. This may include time-based, maintenance history, capacity planning, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.4.1.1" ;
    skos:prefLabel "Monitor useful life of assets"@en .

<http://ots.local/thesaurus/apqc/10_4_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_4_1> ;
    skos:definition "Cost/benefit analysis of assets to determine retention or end-of-life. Evaluating asset total lifecycle cost against other factors such as repair/refurbishment, replacement, and alternate solutions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.4.1.2" ;
    skos:prefLabel "Perform cost vs. benefit analysis for replacement"@en .

<http://ots.local/thesaurus/apqc/10_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_4> ;
    skos:definition "Retiring assets that are no longer viable to the business. Decommission assets that are no longer in working order, are out of date, or whose maintenance exceeds the cost of replacement."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.4.2" ;
    skos:prefLabel "Decommission productive assets"@en .

<http://ots.local/thesaurus/apqc/10_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_4> ;
    skos:definition "Performing the sale of assets. Achieve and complete the sale process. Deliver the end product to the customers."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.4.3" ;
    skos:prefLabel "Perform sale or trade"@en .

<http://ots.local/thesaurus/apqc/10_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_4> ;
    skos:definition "Managing locations where end-of-life assets are evaluated for decommissioning, disassembly, recycling, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.4.4" ;
    skos:prefLabel "Manage take-back centers"@en .

<http://ots.local/thesaurus/apqc/10_4_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_4> ;
    skos:definition "Dismantling an asset into manageable parts. The parts may follow different dispositions, such as resale, reuse, recycle, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.4.5" ;
    skos:prefLabel "Dismantle assets"@en .

<http://ots.local/thesaurus/apqc/10_4_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_4> ;
    skos:definition "Tracking the disposition of all parts from end-of-life assets. Tracking should provide an audit trail to include source, rational for disposition, and destination."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.4.6" ;
    skos:prefLabel "Track parts"@en .

<http://ots.local/thesaurus/apqc/10_4_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_4> ;
    skos:definition "Recycling parts in accordance with legal, regulatory, and social/environmental responsibilities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.4.7" ;
    skos:prefLabel "Recycle parts"@en .

<http://ots.local/thesaurus/apqc/10_4_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_4> ;
    skos:definition "Planning, conducting, and tracking shipment of hazardous materials."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.4.8" ;
    skos:prefLabel "Ship hazardous material"@en .

<http://ots.local/thesaurus/apqc/10_4_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/10_4> ;
    skos:definition "Preparing and distributing government reports."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "10.4.9" ;
    skos:prefLabel "Provide government reporting"@en .

<http://ots.local/thesaurus/apqc/11_1_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_1_1> ;
    skos:definition "Recognizing the organization's tolerance for risk, given risk-return trade-offs for one or more anticipated and predictable consequences."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.1.1.1" ;
    skos:prefLabel "Determine risk tolerance for organization"@en .

<http://ots.local/thesaurus/apqc/11_1_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_1_1> ;
    skos:definition "Establishing and maintaining the policies and procedures for managing risk. Create rules and regulations for enterprise risk dealing with hazardous, financial, operational, and strategic risks."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.1.1.2" ;
    skos:prefLabel "Develop and maintain enterprise risk policies and procedures"@en .

<http://ots.local/thesaurus/apqc/11_1_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_1_1> ;
    skos:definition "Recognizing and implementing tools for managing risk. Identify and apply enterprise risk management tools. Leverage methods and processes to manage risks and opportunities associated with business objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.1.1.3" ;
    skos:prefLabel "Identify and implement enterprise risk management tools"@en .

<http://ots.local/thesaurus/apqc/11_1_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_1_1> ;
    skos:definition "Communicating the knowledge about risk within the organization. Identify operational risks. Share risk information within the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.1.1.4" ;
    skos:prefLabel "Coordinate the sharing of risk knowledge across the organization"@en .

<http://ots.local/thesaurus/apqc/11_1_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_1_1> ;
    skos:definition "Preparing and presenting reports about enterprise risk to the management of the organization. Create reports for management on hazard risks (e.g., property damage and liability torts), financial risks (e.g., currency and liquidity risks), and operational risks (e.g., product failure, customer satisfaction, social trends, and competition)."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.1.1.5" ;
    skos:prefLabel "Prepare and report enterprise risk to executive management and board"@en .

<http://ots.local/thesaurus/apqc/11_1_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_1_2> ;
    skos:definition "Determining risks that could thwart objectives, including crises that may impact customer service such as data breaches or significant product issues. Document and communicate the concern."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.1.2.1" ;
    skos:prefLabel "Identify enterprise level risks"@en .

<http://ots.local/thesaurus/apqc/11_1_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_1_2> ;
    skos:definition "Identifying options/actions to enhance opportunities and reduce threats. Recognize the root reasons of the identified risks."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.1.2.2" ;
    skos:prefLabel "Assess risks to determine which to mitigate"@en .

<http://ots.local/thesaurus/apqc/11_1_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_1_2> ;
    skos:definition "Developing activities to improve opportunities and lessen threats. Specify the organization's objectives. Evolve strategies and policies to attain these objectives. Assign resources to project objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.1.2.3" ;
    skos:prefLabel "Develop risk mitigation and management strategy and integrate with existing performance management processes"@en .

<http://ots.local/thesaurus/apqc/11_1_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_1_2> ;
    skos:definition "Checking that the blueprint created for managing risk in individual business units and divisions is correctly effectuated. Validate the implementation of all activities geared to mitigate risks."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.1.2.4" ;
    skos:prefLabel "Verify business unit and functional risk mitigation plans are implemented"@en .

<http://ots.local/thesaurus/apqc/11_1_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_1_2> ;
    skos:definition "Ensuring risk monitoring and mitigation activities. Monitor actions to enhance opportunities and reduce threats to project objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.1.2.5" ;
    skos:prefLabel "Ensure risks and risk mitigation actions are monitored"@en .

<http://ots.local/thesaurus/apqc/11_1_2_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_1_2> ;
    skos:definition "Creating a report of activities to address hazard risks, liability torts, financial risks, operational risks, social trends, competition, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.1.2.6" ;
    skos:prefLabel "Report on enterprise risk activities"@en .

<http://ots.local/thesaurus/apqc/11_1_2_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_1_2> ;
    skos:definition "Coordinating risk management activities to improve opportunities and lessen threats. Specify the organization's objectives. Assign resources to project objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.1.2.7" ;
    skos:prefLabel "Coordinate business unit and functional risk management activities"@en .

<http://ots.local/thesaurus/apqc/11_1_2_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_1_2> ;
    skos:definition "Checking each business unit's/function's options and activities to improve opportunities and lessen threats."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.1.2.8" ;
    skos:prefLabel "Ensure that each business unit/function follows the enterprise risk management process"@en .

<http://ots.local/thesaurus/apqc/11_1_2_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_1_2> ;
    skos:definition "Checking the reporting process of each business unit's/function's options and activities to improve opportunities and lessen threats."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.1.2.9" ;
    skos:prefLabel "Ensure that each business unit/function follows the enterprise risk reporting process"@en .

<http://ots.local/thesaurus/apqc/11_1_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_1_3> ;
    skos:definition "Developing a timely and continuous process to identify activities that might hinder a project's goals."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.1.3.1" ;
    skos:prefLabel "Identify risks"@en .

<http://ots.local/thesaurus/apqc/11_1_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_1_3> ;
    skos:definition "Determining the possibility that a specified undesirable event will occur using established tools, implements, and frameworks. Use risk assessments to determine, for example, whether to undertake a particular venture, what rate of return a particular investment requires, and how to mitigate an activity's potential losses."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.1.3.2" ;
    skos:prefLabel "Assess risks using enterprise risk framework policies and procedures"@en .

<http://ots.local/thesaurus/apqc/11_1_3_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_1_3_3> ;
    skos:definition "Evaluating the changing needs for insurance coverage. Research available insurance providers and offerings."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.1.3.3.1" ;
    skos:prefLabel "Assess adequacy of insurance coverage"@en .

<http://ots.local/thesaurus/apqc/11_1_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_1_3> ;
    skos:definition "Executing mitigation plans to improve opportunities and reduce deviations to project objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.1.3.4" ;
    skos:prefLabel "Implement mitigation plans for risks"@en .

<http://ots.local/thesaurus/apqc/11_1_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_1_3> ;
    skos:definition "Identifying, examining, and recognizing/justifying any improbability in investment decision making."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.1.3.5" ;
    skos:prefLabel "Monitor risks"@en .

<http://ots.local/thesaurus/apqc/11_1_3_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_1_3> ;
    skos:definition "Examining the impact of risk activities in order to update the existing scheme of risk management. Analyze and substantiate the potential for adverse consequences to occur. Consider the risks associated with the activity and the methods available to manage those risks."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.1.3.6" ;
    skos:prefLabel "Analyze risk activities and update plans"@en .

<http://ots.local/thesaurus/apqc/11_1_3_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_1_3> ;
    skos:definition "Creating reports on risk activities, and communicating them to management. Prepare reports on the potential for adverse safety consequences."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.1.3.7" ;
    skos:prefLabel "Report on risk activities"@en .

<http://ots.local/thesaurus/apqc/11_2_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_2_1> ;
    skos:definition "Creating a standardized approach to ethics and compliance. Have a programmatic approach for compliance that focuses on the definite risks the organization faces."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.2.1.1" ;
    skos:prefLabel "Develop enterprise compliance policies and procedures"@en .

<http://ots.local/thesaurus/apqc/11_2_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_2_1> ;
    skos:definition "Implementing standardized for ethics and compliance. Have a programmatic approach, built from the top down, to enterprise compliance that focuses on the definite risks the organization faces."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.2.1.2" ;
    skos:prefLabel "Implement enterprise compliance activities"@en .

<http://ots.local/thesaurus/apqc/11_2_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_2_1> ;
    skos:definition "Managing accounts and prepare regular reports on financial performance."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.2.1.3" ;
    skos:prefLabel "Manage internal audits"@en .

<http://ots.local/thesaurus/apqc/11_2_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_2_1> ;
    skos:definition "Managing technologies and tools related to the confidentiality, integrity, and availability of data in order to ensure the security of the organization's information. This is inclusive of all forms of new and evolving technology such as artificial intelligence (AI)."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.2.1.4" ;
    skos:prefLabel "Maintain controls-related technologies and tools"@en .

<http://ots.local/thesaurus/apqc/11_2_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_2_2> ;
    skos:definition "Developing procedures and methodologies to comply with relevant laws and regulations of an organization's obedience to laws, guidelines, strategies and stipulations related to business."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.2.2.1" ;
    skos:prefLabel "Develop regulatory compliance procedures"@en .

<http://ots.local/thesaurus/apqc/11_2_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_2_2> ;
    skos:definition "Determining the regulatory requirements that are most appropriate for the organization. Identify goals in order to follow the appropriate rules and regulations, guidelines, and strategies."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.2.2.2" ;
    skos:prefLabel "Identify applicable regulatory requirements"@en .

<http://ots.local/thesaurus/apqc/11_2_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_2_2> ;
    skos:definition "Analyzing and overseeing the regulatory environment in order to spot any changing or emerging regulations. This process element calls upon the organization to monitor the regulatory environment for any new statutes, policies, and enactments issued by the respective government authorities or those which have been updated."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.2.2.3" ;
    skos:prefLabel "Monitor the regulatory environment for changing or emerging regulations"@en .

<http://ots.local/thesaurus/apqc/11_2_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_2_2> ;
    skos:definition "Evaluating current regulatory policies and regulations. Assess their performance. Make necessary changes."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.2.2.4" ;
    skos:prefLabel "Assess current compliance position and identify weaknesses or shortfalls therein"@en .

<http://ots.local/thesaurus/apqc/11_2_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_2_2> ;
    skos:definition "Assessing the current policies and policies. Implement missing and necessary changes environmental changes, political changes, technological changes, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.2.2.5" ;
    skos:prefLabel "Implement missing or stronger regulatory compliance controls and policies"@en .

<http://ots.local/thesaurus/apqc/11_2_2_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_2_2> ;
    skos:definition "Monitoring, appraising, and evaluating the compliance position of the organization in order to fine-tune for effective remediation. Track efforts for handling regulatory and compliance requirements necessitated by law. Test the robustness of internal frameworks, procedures, and approaches for dealing with these requirements, in order to clearly identify any necessary changes."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.2.2.6" ;
    skos:prefLabel "Monitor and test regulatory compliance position and existing controls"@en .

<http://ots.local/thesaurus/apqc/11_2_2_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_2_2> ;
    skos:definition "Creating a graphical representation of metrics in order to communicate the general health of the organization in relation to risk and compliancy."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.2.2.7" ;
    skos:prefLabel "Compile and communicate compliance scorecard(s)"@en .

<http://ots.local/thesaurus/apqc/11_2_2_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_2_2> ;
    skos:definition "Submitting compliance reports to regulatory agencies. These reports can be made to environmental, securities, or human resources agencies as stipulated by the local governing body."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.2.2.8" ;
    skos:prefLabel "Compile and communicate internal and regulatory compliance reports"@en .

<http://ots.local/thesaurus/apqc/11_2_2_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_2_2> ;
    skos:definition "Developing and preserving relationships with the regulators, without compromising the legal basis of the relationship."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.2.2.9" ;
    skos:prefLabel "Maintain relationships with regulators as appropriate"@en .

<http://ots.local/thesaurus/apqc/11_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_3> ;
    skos:definition "Creating plans for remediation efforts. Make a plan to address a case of environmental adulteration. Identify and treat the adulteration so that the area will become operational again."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.3.1" ;
    skos:prefLabel "Create remediation plans"@en .

<http://ots.local/thesaurus/apqc/11_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_3> ;
    skos:definition "Discussing and soliciting advice from experts for in order to incorporate their suggestion (regarding Create remediation plans [11201])."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.3.2" ;
    skos:prefLabel "Contact and confer with experts"@en .

<http://ots.local/thesaurus/apqc/11_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_3> ;
    skos:definition "Identifying and dedicating the resources for managing remediation efforts. Discern the resources needed for remediation efforts. Dispense with resources in a sound and well-reasoned manner."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.3.3" ;
    skos:prefLabel "Identify/Dedicate resources"@en .

<http://ots.local/thesaurus/apqc/11_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_3> ;
    skos:definition "Examining regulatory and legislative frameworks. Obligate the organization to remediate any damages through compensations, fines, and any other remedial efforts necessitated to correct the situations. Analyze local environmental laws, binding international covenants, etc. in order to examine legal accuracy about the rules and procedures."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.3.4" ;
    skos:prefLabel "Investigate legal aspects"@en .

<http://ots.local/thesaurus/apqc/11_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_3> ;
    skos:definition "Studying the causes of damage, which could be environmental, physical, social, etc. at country level in order to institute better policies and regulations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.3.5" ;
    skos:prefLabel "Investigate damage cause"@en .

<http://ots.local/thesaurus/apqc/11_3_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_3> ;
    skos:definition "Crafting a new framework of policies and procedures for deploying remediation efforts, or change existing policies and procedures. Adapt the policy structure to the context of the apposite national and international regulatory frameworks."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.3.6" ;
    skos:prefLabel "Amend or create policy"@en .

<http://ots.local/thesaurus/apqc/11_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_4> ;
    skos:definition "Creating a strategy for rapidly adapting to disturbances. Maintain continuous business processes and protecting employees, assets, and overall brand equity. This is inclusive of all forms of new and evolving technology such as artificial intelligence (AI)."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.4.1" ;
    skos:prefLabel "Develop the business resilience strategy"@en .

<http://ots.local/thesaurus/apqc/11_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_4> ;
    skos:definition "Developing plans to ensure continuous business operations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.4.2" ;
    skos:prefLabel "Perform continuous business operations planning"@en .

<http://ots.local/thesaurus/apqc/11_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_4> ;
    skos:definition "Assessing ongoing activities within the organization that are not intended to stop except for in an emergency."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.4.3" ;
    skos:prefLabel "Test continuous business operations"@en .

<http://ots.local/thesaurus/apqc/11_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_4> ;
    skos:definition "Evaluating business operations. Determine which activities generate revenues, perform best, and provide good returns."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.4.4" ;
    skos:prefLabel "Maintain continuous business operations"@en .

<http://ots.local/thesaurus/apqc/11_4_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/11_4> ;
    skos:definition "Sharing information about risks and resilience strategies of business operations across the organization so that prospective risks can be avoided."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "11.4.5" ;
    skos:prefLabel "Share knowledge of specific risks across other parts of the organization"@en .

<http://ots.local/thesaurus/apqc/12_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_1> ;
    skos:definition "Building and managing relations with bankers or lenders through strong products/services strategies that bankers would want to invest in. Foster a receptive environment for low rates of interest, easy access to loans, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.1.1" ;
    skos:prefLabel "Plan, build, and manage lender relations"@en .

<http://ots.local/thesaurus/apqc/12_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_1> ;
    skos:definition "Creating and maintaining long-term relations with analysts. Involve analysts in strategy and product decisions in order to elicit valuable information."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.1.2" ;
    skos:prefLabel "Plan, build, and manage analyst relations"@en .

<http://ots.local/thesaurus/apqc/12_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_1> ;
    skos:definition "Practicing regular, transparent communication with shareholders through annual shareholders' meetings, quarterly earnings calls, shareholders letters, one-on-one emails or calls, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.1.3" ;
    skos:prefLabel "Communicate with shareholders"@en .

<http://ots.local/thesaurus/apqc/12_2_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_2_1> ;
    skos:definition "Ascertaining how the business entity relates to all levels of government. Identify areas that needs further growth and resources to foster those relationships."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.2.1.1" ;
    skos:prefLabel "Assess relationships"@en .

<http://ots.local/thesaurus/apqc/12_2_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_2_1> ;
    skos:definition "Assigning executive level resources to manage, grow, and drive relationships with government bodies."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.2.1.2" ;
    skos:prefLabel "Appoint responsible executives"@en .

<http://ots.local/thesaurus/apqc/12_2_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_2_1> ;
    skos:definition "Analyzing current relationships with government bodies and entities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.2.1.3" ;
    skos:prefLabel "Monitor relationships"@en .

<http://ots.local/thesaurus/apqc/12_2_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_2_1> ;
    skos:definition "Garnering internal advice from an informal group in order to successfully maintain and advance relationships."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.2.1.4" ;
    skos:prefLabel "Receive input from internal advisors"@en .

<http://ots.local/thesaurus/apqc/12_2_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_2_1> ;
    skos:definition "Garnering third party advice from an informal group in order to successfully maintain and advance relationships."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.2.1.5" ;
    skos:prefLabel "Receive input from external advisors"@en .

<http://ots.local/thesaurus/apqc/12_2_1_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_2_1> ;
    skos:definition "Meeting with government heads and representatives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.2.1.6" ;
    skos:prefLabel "Liaise with authorities"@en .

<http://ots.local/thesaurus/apqc/12_2_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_2_2> ;
    skos:definition "Engaging government, regulatory, or industry agencies to establish relationships. Analyze steps and requirements necessary for inclusion, if needed."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.2.2.1" ;
    skos:prefLabel "Establish relationships with agencies"@en .

<http://ots.local/thesaurus/apqc/12_2_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_2_2> ;
    skos:definition "Cooperating with auditors regarding potential or ongoing inquiries."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.2.2.2" ;
    skos:prefLabel "Respond to audit inquiries"@en .

<http://ots.local/thesaurus/apqc/12_2_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_2_2> ;
    skos:definition "Keeping a repository of documents that contain information about the network of partners, prospects and customers. Keep records up-to-date with routine reviews and modify as needed."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.2.2.3" ;
    skos:prefLabel "Maintain documentation of contacts"@en .

<http://ots.local/thesaurus/apqc/12_2_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_2_2> ;
    skos:definition "Ensuring regular interaction between business entity and quasi-government bodies in order to maintain established relationships. Collect and record meeting data for further analysis and use."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.2.2.4" ;
    skos:prefLabel "Plan and manage meetings"@en .

<http://ots.local/thesaurus/apqc/12_2_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_2_3> ;
    skos:definition "Determining the requirements to enter in to an agreement with trade or industry agencies. Discover what activities or processes can be conducted to provide the best mutual outcome."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.2.3.1" ;
    skos:prefLabel "Evaluate the requirements for strategic relationships"@en .

<http://ots.local/thesaurus/apqc/12_2_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_2_3> ;
    skos:definition "Analyzing current relationships with trade and industry groups. Ensure that the partnership in successful and make modifications where needed."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.2.3.2" ;
    skos:prefLabel "Monitor the success of the partnerships"@en .

<http://ots.local/thesaurus/apqc/12_2_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_2_3> ;
    skos:definition "Providing additional information or inclusion for third party trade or industry entities; or changing existing parameters to modify the current relationship. Communicate and execute changes."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.2.3.3" ;
    skos:prefLabel "Extend or change the relationships"@en .

<http://ots.local/thesaurus/apqc/12_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_2> ;
    skos:definition "Managing lobbying activities to affect government policies."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.2.4" ;
    skos:prefLabel "Manage lobby activities"@en .

<http://ots.local/thesaurus/apqc/12_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_3> ;
    skos:definition "Reporting financial results to management, and releasing results to the public. Report financial statements, including the income statement, balance sheet, and statement of cash flows."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.3.1" ;
    skos:prefLabel "Report financial results"@en .

<http://ots.local/thesaurus/apqc/12_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_3> ;
    skos:definition "Reporting audit findings to management. Practice an internal audit with criteria for confirming a problem, a description of the situation, and the root cause of the problem. Make recommendations that resolve the issue."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.3.2" ;
    skos:prefLabel "Report audit findings"@en .

<http://ots.local/thesaurus/apqc/12_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_4> ;
    skos:definition "Creating a code of ethics that communicate the organization's philosophy to employees, vendors, customers, clients, and the public."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.4.1" ;
    skos:prefLabel "Create ethics policies"@en .

<http://ots.local/thesaurus/apqc/12_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_4> ;
    skos:definition "Administering the system of rules, practices, and processes through which a company is directed and controlled. Balance stakeholder interests including shareholders, management, customers, suppliers, financiers, government, and the community. Outline a strategy for achieving organizational goals, from action plans and internal controls to performance measurement and corporate disclosure."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.4.2" ;
    skos:prefLabel "Manage corporate governance policies"@en .

<http://ots.local/thesaurus/apqc/12_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_4> ;
    skos:definition "Creating and applying programs and activities. Encourage the adherence preventive laws, such as environmental law, sex discrimination, computer law, estate planning, corporate compliance, business planning, and property transactions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.4.3" ;
    skos:prefLabel "Develop and perform preventive law programs"@en .

<http://ots.local/thesaurus/apqc/12_4_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_4_4> ;
    skos:definition "Employing an internal system or process to identify and reduce the risk of breaching the Competition and Consumer Act 2010. Remedy any breach. Create a culture of compliance. Design compliance programs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.4.4.1" ;
    skos:prefLabel "Plan and initiate compliance program"@en .

<http://ots.local/thesaurus/apqc/12_4_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_4_4> ;
    skos:definition "Implementing the established compliance program in order to meet the government laws and regulations. Create a compliance team that scrutinizes the rules set out by government bodies such as the Securities and Exchange Commission."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.4.4.2" ;
    skos:prefLabel "Execute compliance program"@en .

<http://ots.local/thesaurus/apqc/12_4_5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_4_5> ;
    skos:definition "Examining the problems and deciding the action requirements for engaging outside counsel. This process element calls upon the organization to internally analyze the issues for which assistance from external counsel is needed. Additionally, the organization needs to break-down the issue, identifying the tasks and exercises where outside counsel can help."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.4.5.1" ;
    skos:prefLabel "Assess problem and determine work requirements"@en .

<http://ots.local/thesaurus/apqc/12_4_5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_4_5> ;
    skos:definition "Recruiting the assistance of outside counsel for any legal and/or ethical concerns. Engage and/or retain any external counsel sought from subject matter experts and professionals."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.4.5.2" ;
    skos:prefLabel "Engage/Retain outside counsel if necessary"@en .

<http://ots.local/thesaurus/apqc/12_4_5_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_4_5> ;
    skos:definition "Making a financial plan. This strategy sets out, using figures, an organization's expected future results. Enlist the finance function to support work generated by other business functions in order to build and secure their support for the budget."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.4.5.3" ;
    skos:prefLabel "Receive strategy/budget"@en .

<http://ots.local/thesaurus/apqc/12_4_5_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_4_5> ;
    skos:definition "Receiving deliverables from outside counsel, and monitoring the efforts committed by them. Track the progress of, collect, and validate the required work product from the subject matter experts and professionals engaged as external counsel. Verify the amount of effort dedicated by these counsels to the issue at hand, in order to confirm their fees."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.4.5.4" ;
    skos:prefLabel "Receive work product and manage/monitor case and work performed"@en .

<http://ots.local/thesaurus/apqc/12_4_5_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_4_5> ;
    skos:definition "Making payments to legal advisers for their services. Payments include addressing issues or suits by customers, suppliers, competitors, bankers, government agencies, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.4.5.5" ;
    skos:prefLabel "Process payment for legal services"@en .

<http://ots.local/thesaurus/apqc/12_4_5_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_4_5> ;
    skos:definition "Keeping track of the legal activities and performance of the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.4.5.6" ;
    skos:prefLabel "Track legal activity/performance"@en .

<http://ots.local/thesaurus/apqc/12_4_6_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_4_6> ;
    skos:definition "Managing the patents and copyrights already held or sought by the organization. Administer and oversee applying for, securing, and maintaining intellectual property rights in the form of patents and copyrights. Submit applications for such rights. Handle associated legal issues. Draft and communicate proper attributions. Collect royalties. Monitor any misuse of the intellectual property rights."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.4.6.1" ;
    skos:prefLabel "Manage copyrights, patents, and trademarks"@en .

<http://ots.local/thesaurus/apqc/12_4_6_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_4_6> ;
    skos:definition "Managing the upkeep of intellectual property rights by creating and managing a framework of rules, policies, procedures, and restrictions. Outline a clear policy for any possible scenario of their use by any external agent."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.4.6.2" ;
    skos:prefLabel "Maintain intellectual property rights and restrictions"@en .

<http://ots.local/thesaurus/apqc/12_4_6_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_4_6> ;
    skos:definition "Administering and overseeing the terms and policies associated with licensing the organization's intellectual property. Create and manage the policies and terms governing the possible granting of a license to any external agent. Demarcate a clear framework that governs the licensing of any patents or copyrights held by the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.4.6.3" ;
    skos:prefLabel "Administer licensing terms"@en .

<http://ots.local/thesaurus/apqc/12_4_6_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_4_6> ;
    skos:definition "Managing options regarding licensing agreements. Follow favorable terms and conditions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.4.6.4" ;
    skos:prefLabel "Administer options"@en .

<http://ots.local/thesaurus/apqc/12_4_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_4> ;
    skos:definition "Resolving disputes or civil lawsuits internally or externally."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.4.7" ;
    skos:prefLabel "Resolve disputes and litigations"@en .

<http://ots.local/thesaurus/apqc/12_4_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_4> ;
    skos:definition "Providing legal advice concerning the substance or procedure of a law in relation to a particular situation."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.4.8" ;
    skos:prefLabel "Provide legal advice/counseling"@en .

<http://ots.local/thesaurus/apqc/12_4_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_4> ;
    skos:definition "Negotiating terms to reach a final draft of a contract that is acceptable to all parties."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.4.9" ;
    skos:prefLabel "Negotiate and document agreements/contracts"@en .

<http://ots.local/thesaurus/apqc/12_5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_5> ;
    skos:definition "Developing and administering community relations. Establish business connections with the people constituting the environment the organization operates in and draws resources from in order to foster mutual understanding, trust, and support. Create programs that promote the organization's image in a positive and community-oriented way."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.5.1" ;
    skos:prefLabel "Manage community relations"@en .

<http://ots.local/thesaurus/apqc/12_5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_5> ;
    skos:definition "Developing and managing relations with media. Develop connections with journalists to solicit critical, third-party endorsements for a product, issue, service, or organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.5.2" ;
    skos:prefLabel "Manage media relations"@en .

<http://ots.local/thesaurus/apqc/12_5_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_5> ;
    skos:definition "Promoting political security and stability in the regions where the organization conducts business. Encourage political stability in the regions where the organization operates. Support civic programs, citizen engagement, connection platforms, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.5.3" ;
    skos:prefLabel "Promote political stability"@en .

<http://ots.local/thesaurus/apqc/12_5_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_5> ;
    skos:definition "Developing press releases to communicate developments and generate interest in the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.5.4" ;
    skos:prefLabel "Create press releases"@en .

<http://ots.local/thesaurus/apqc/12_5_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/12_5> ;
    skos:definition "Issuing press releases to carefully selected media in distribution channels such as the web, newspapers, and social media."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "12.5.5" ;
    skos:prefLabel "Issue press releases"@en .

<http://ots.local/thesaurus/apqc/13_10_1_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_10_1_1> ;
    skos:definition "Defining and communicating sustainability disclosure requirements. Clarify and align disclosure requirements to other organizational reporting requirements and needs. Integrate preparation and reporting activities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.10.1.1.1" ;
    skos:prefLabel "Define sustainability disclosure requirements"@en .

<http://ots.local/thesaurus/apqc/13_10_1_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_10_1_1> ;
    skos:definition "Defining governance requirements for sustainability. Include structure, roles, alignment to organization models, processes and standards to be applied."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.10.1.1.2" ;
    skos:prefLabel "Define sustainability governance requirements"@en .

<http://ots.local/thesaurus/apqc/13_10_1_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_10_1_1> ;
    skos:definition "Defining functional and performance requirements for sustainability. Align with ESG strategies, goals, and the implementation of sustainability efforts across the organization, provide a roadmap and visibility to shared and collective requirements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.10.1.1.3" ;
    skos:prefLabel "Define sustainability functional and performance requirements"@en .

<http://ots.local/thesaurus/apqc/13_10_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_10_1> ;
    skos:definition "Establishing organizational sustainability goals/objectives. Gather, align, and promote organization-wide sustainability goals that collectively address the overall sustainability requirements. Ensure the goals are measurable and have qualitative and quantitative targets."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.10.1.2" ;
    skos:prefLabel "Establish sustainability goals/objectives"@en .

<http://ots.local/thesaurus/apqc/13_10_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_10_1> ;
    skos:definition "Establishing, documenting, and communicating sustainability policies. Develop policies, written procedures, and supporting tools to dictate how the organization will meet policy requirements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.10.1.3" ;
    skos:prefLabel "Create sustainability policies"@en .

<http://ots.local/thesaurus/apqc/13_10_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_10_1> ;
    skos:definition "Defining sustainability measures. Provide organization-wide measures, to include data collection strategies, calculations, analytics, and reporting formats."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.10.1.4" ;
    skos:prefLabel "Define sustainability measures"@en .

<http://ots.local/thesaurus/apqc/13_10_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_10_1> ;
    skos:definition "Creating sustainability plans. Develop and socialize sustainability plans for the organization, functional units, and support services. Ensure alignment to sustainability requirements, goals, and governance."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.10.1.5" ;
    skos:prefLabel "Create sustainability plan(s)"@en .

<http://ots.local/thesaurus/apqc/13_10_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_10_2> ;
    skos:definition "Providing sustainability training and awareness. Plan, prepare, and oversee delivery of sustainability education and enablement activities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.10.2.1" ;
    skos:prefLabel "Provide sustainability training"@en .

<http://ots.local/thesaurus/apqc/13_10_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_10_2> ;
    skos:definition "Providing support for sustainability activities. Augment functional units and support teams with coaching, mentoring, and SME capacity to perform sustainability projects and activities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.10.2.2" ;
    skos:prefLabel "Provide sustainability support"@en .

<http://ots.local/thesaurus/apqc/13_10_2_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_10_2_3> ;
    skos:definition "Measuring sustainability performance. Setup, collect, and validate sustainability data. Conduct audits and inspections. Evaluate results to requirements and targets. Identify and track resolution of gaps and variances."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.10.2.3.1" ;
    skos:prefLabel "Measure sustainability performance"@en .

<http://ots.local/thesaurus/apqc/13_10_2_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_10_2_3> ;
    skos:definition "Preparing sustainability statements. Given the multitude of potential audiences for reporting, alignment and consistency of sustainability statements provides clarity and reusability for those audiences."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.10.2.3.2" ;
    skos:prefLabel "Prepare sustainability statements"@en .

<http://ots.local/thesaurus/apqc/13_1_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_1_1> ;
    skos:definition "Outlining and managing the methodology for administering business process management (BPM). Define the method for setting standards and priorities for BPM efforts. Identify BPM governance leaders. Define BPM project participants' roles."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.1.1.1" ;
    skos:prefLabel "Define and manage governance approach"@en .

<http://ots.local/thesaurus/apqc/13_1_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_1_1> ;
    skos:definition "Instituting, organizing, and maintaining the upkeep of the techniques used for business process management (BPM). Create and maintain templates of BPM tools that can be readily implemented, including process engine, business analytics, content management, and collaboration tools."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.1.1.2" ;
    skos:prefLabel "Establish and maintain process tools and templates"@en .

<http://ots.local/thesaurus/apqc/13_1_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_1_1> ;
    skos:definition "Assigning resources (employees) ownership of tasks. These include the responsibility of identifying, analyzing, and improving business processes in order to meet the goals and objectives such as increasing profits and performance, reducing costs, and accelerating schedules."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.1.1.3" ;
    skos:prefLabel "Assign and support process ownership"@en .

<http://ots.local/thesaurus/apqc/13_1_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_1_1> ;
    skos:definition "Implementing and executing activities for governing business processes. Execute activities that encourage participation, accountability, transparency, responsiveness, equity and inclusiveness, etc. within the business processes."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.1.1.4" ;
    skos:prefLabel "Perform process governance activities"@en .

<http://ots.local/thesaurus/apqc/13_1_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_1_2> ;
    skos:definition "Defining and managing the framework that outlines the required business processes of the organization, key elements, and how they should interact. Institute strategy infrastructure and product, operations, and enterprise management."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.1.2.1" ;
    skos:prefLabel "Establish and maintain process framework"@en .

<http://ots.local/thesaurus/apqc/13_1_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_1_2> ;
    skos:definition "Recognizing the different functional areas working on the same project or goal."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.1.2.2" ;
    skos:prefLabel "Identify cross-functional processes"@en .

<http://ots.local/thesaurus/apqc/13_1_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_1_3> ;
    skos:definition "Defining the extent and limits of business processes. Define the range and diversity of all the set of activities and tasks that, once completed, will accomplish an organizational goal."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.1.3.1" ;
    skos:prefLabel "Scope processes"@en .

<http://ots.local/thesaurus/apqc/13_1_3_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_1_3_2> ;
    skos:definition "Realizing those practices and procedures that are the most effective to the success of the business and making that information available."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.1.3.2.1" ;
    skos:prefLabel "Identify published best practices"@en .

<http://ots.local/thesaurus/apqc/13_1_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_1_3> ;
    skos:definition "Establishment of a \"checkpoint\" in a process that prevent the process from continuing unless all requirements are satisfied."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.1.3.3" ;
    skos:prefLabel "Identify and denote process control points"@en .

<http://ots.local/thesaurus/apqc/13_1_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_1_3> ;
    skos:definition "Defining what a business entity does, who is responsible, to what standard a business process should be completed, and how the success of a business process can be determined. Identify processes, gather information gathering, interview participants, map processes, and perform analysis."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.1.3.4" ;
    skos:prefLabel "Model and document processes"@en .

<http://ots.local/thesaurus/apqc/13_1_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_1_3> ;
    skos:definition "Disclosing the information available on business processes. Ensure the availability of the information regarding the business processes to all process team members, business stakeholders, and process owners. Use BPM software, as well as business process diagrams and documents that help depict the required information."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.1.3.5" ;
    skos:prefLabel "Publish processes"@en .

<http://ots.local/thesaurus/apqc/13_1_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_1_4> ;
    skos:definition "Providing training for the employees and process owners that administer the business processes. Design internal training programs or source third party agencies to provide the skills and training necessary."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.1.4.1" ;
    skos:prefLabel "Provide process training"@en .

<http://ots.local/thesaurus/apqc/13_1_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_1_4> ;
    skos:definition "Assisting and executing the business processes. Use business process execution language (BEPL), which is a standard, executable language for specifying actions within the business processes with the use of web services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.1.4.2" ;
    skos:prefLabel "Support process execution"@en .

<http://ots.local/thesaurus/apqc/13_1_4_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_1_4_3> ;
    skos:definition "Determining the need for additional performance indicators that would be necessary to successfully achieve the business goal."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.1.4.3.1" ;
    skos:prefLabel "Identify additional metrics as required"@en .

<http://ots.local/thesaurus/apqc/13_1_5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_1_5> ;
    skos:definition "Helping a process owner to identify, analyze, and improve existing business processes within an organization to meet new goals and objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.1.5.1" ;
    skos:prefLabel "Identify and select improvement opportunities"@en .

<http://ots.local/thesaurus/apqc/13_1_5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_1_5> ;
    skos:definition "Assessing and choosing methodologies to identify, analyze, and improve existing processes within an organization to meet new goals and objective. Assess the various methodologies available such as process mapping, statistical process control, and simulation. Choose the most appropriate and effective methodology."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.1.5.2" ;
    skos:prefLabel "Select process improvement methodology"@en .

<http://ots.local/thesaurus/apqc/13_1_5_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_1_5> ;
    skos:definition "Developing and implementing a systematic approach to help the organization optimize its underlying processes in order to achieve more efficient results. Systematically gather information to clarify issues or problems. Intervene for improvements. Restructure training programs as appropriate to increase effectiveness."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.1.5.3" ;
    skos:prefLabel "Manage improvement projects"@en .

<http://ots.local/thesaurus/apqc/13_1_5_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_1_5> ;
    skos:definition "Persistently implementing activities for improving business processes."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.1.5.4" ;
    skos:prefLabel "Perform continuous improvement activities"@en .

<http://ots.local/thesaurus/apqc/13_2_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2_1> ;
    skos:definition "Instituting the strategy for managing business portfolio. Create a systematic plan that defines the strategy for managing investments, holdings, products, businesses, and brands."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.1.1" ;
    skos:prefLabel "Establish portfolio strategy"@en .

<http://ots.local/thesaurus/apqc/13_2_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2_1> ;
    skos:definition "Outlining the administration of business portfolio of the organization. Create and manage the rules and regulations regarding the business processes in order to identify, select, prioritize, and monitor portfolio components. Include a set of metrics to indicate the health and progress of the portfolio in the most vital area."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.1.2" ;
    skos:prefLabel "Define portfolio governance"@en .

<http://ots.local/thesaurus/apqc/13_2_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2_1> ;
    skos:definition "Overseeing and administering the business portfolio of the organization. Monitor all activities related to investments, holdings, products, businesses, and brands by effectively monitoring and supervising these activities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.1.3" ;
    skos:prefLabel "Monitor and control portfolio"@en .

<http://ots.local/thesaurus/apqc/13_2_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2_2> ;
    skos:definition "Constructing and instituting the framework and approach to manage business programs. Monitor key factors such as governance, alignment with the overall business vision, assurance, and management."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.2.1" ;
    skos:prefLabel "Establish program structure and approach"@en .

<http://ots.local/thesaurus/apqc/13_2_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2_2> ;
    skos:definition "Managing relationships with stakeholders and partners of the business programs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.2.2" ;
    skos:prefLabel "Manage program stakeholders and partners"@en .

<http://ots.local/thesaurus/apqc/13_2_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2_2> ;
    skos:definition "Administering and implementing business programs. Implement and execute programs with the intention of improving an organization's performance. Execute all the individual projects of the program to ensure the desired success."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.2.3" ;
    skos:prefLabel "Manage program execution"@en .

<http://ots.local/thesaurus/apqc/13_2_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2_2> ;
    skos:definition "Evaluating and documenting the performance of business programs. Evaluate the performance of the programs. Create reports on the basis of the analysis. Use performance indicators and metrics such as desired/achieved goals, completion dates, issues and defects, and cost effectiveness."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.2.4" ;
    skos:prefLabel "Review and report program performance"@en .

<http://ots.local/thesaurus/apqc/13_2_3_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2_3_1> ;
    skos:definition "Recognizing and defining what the project is ultimately supposed to do. Specify the capabilities, features, or attributes of the project's deliverables, as well as any kind of formal documentation."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.3.1.1" ;
    skos:prefLabel "Identify project requirements and objectives"@en .

<http://ots.local/thesaurus/apqc/13_2_3_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2_3_1> ;
    skos:definition "Identifying the prerequisites of business projects. Identify the people with appropriate and applicable skills and competencies. Locate resources such as capital, facilities, equipment, material, and information required to accomplish the objectives of a specific project."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.3.1.2" ;
    skos:prefLabel "Identify project resource requirements"@en .

<http://ots.local/thesaurus/apqc/13_2_3_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2_3_1> ;
    skos:definition "Evaluating the culture and readiness of the organizational environment is order to implement the project management approach."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.3.1.3" ;
    skos:prefLabel "Assess culture and readiness for project management approach"@en .

<http://ots.local/thesaurus/apqc/13_2_3_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2_3_1> ;
    skos:definition "Creating a document that includes the current situation, proposed solution, financial analysis, conclusion, etc. Convince a decision maker and investors to approve the project. Obtain funding."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.3.1.4" ;
    skos:prefLabel "Create business case"@en .

<http://ots.local/thesaurus/apqc/13_2_3_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2_3_1> ;
    skos:definition "Developing procedures and indictors to assess performance of business projects. Design and develop metrics and indicators--such as cost, schedule, resources, risk, and quality--that exhibit the performance of the business projects."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.3.1.5" ;
    skos:prefLabel "Develop project measures and indicators"@en .

<http://ots.local/thesaurus/apqc/13_2_3_1_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2_3_1> ;
    skos:definition "Stack ranking of projects in the portfolio based upon preestablished criteria."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.3.1.6" ;
    skos:prefLabel "Prioritize and select projects for the portfolio"@en .

<http://ots.local/thesaurus/apqc/13_2_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2_3> ;
    skos:definition "Identifying and implementing the techniques and procedures for managing business projects. Identify the most appropriate models, which are to be employed by the project managers for the purpose of designing, planning, implementing, and achieving project objectives. Examine and assess various project management methodologies such as adaptive project framework, agile development, crystal methods, and feature-driven development."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.3.2" ;
    skos:prefLabel "Identify appropriate project management methodologies"@en .

<http://ots.local/thesaurus/apqc/13_2_3_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2_3_3> ;
    skos:definition "Outlining the resources and their roles in the business projects."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.3.3.1" ;
    skos:prefLabel "Define roles and resources"@en .

<http://ots.local/thesaurus/apqc/13_2_3_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2_3_3> ;
    skos:definition "Procuring the necessary resources outlined in Define roles and resources [11123]"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.3.3.2" ;
    skos:prefLabel "Acquire/secure project resources"@en .

<http://ots.local/thesaurus/apqc/13_2_3_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2_3_3> ;
    skos:definition "Determining the IT requirements for specific business projects. Identify the requirements of computers and telecommunications equipment to store, retrieve, transmit, and manipulate data related to the project. Consider factors such as functional requirements, design requirements, project phases, and project schedule."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.3.3.3" ;
    skos:prefLabel "Identify specific IT requirements"@en .

<http://ots.local/thesaurus/apqc/13_2_3_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2_3_3> ;
    skos:definition "Designing a plan for equipping the project team with the necessary skills and abilities to fulfill their roles and responsibilities in the project effectively and efficiently. Offer formal training, mentoring, or coaching. Initiate informal conversations. Communicate messages during the project."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.3.3.4" ;
    skos:prefLabel "Create training and communication plans"@en .

<http://ots.local/thesaurus/apqc/13_2_3_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2_3_3> ;
    skos:definition "Creating a plan for recognizing and rewarding extraordinary performances within the business projects. Use incentives, bonuses, and certificates for recognition and rewarding purposes."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.3.3.5" ;
    skos:prefLabel "Design recognition and reward approaches"@en .

<http://ots.local/thesaurus/apqc/13_2_3_3_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2_3_3> ;
    skos:definition "Creating a plan specifying when to initiate the project, and introducing it to the target audience. Clearly define the project team, objectives, timelines, and milestone."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.3.3.6" ;
    skos:prefLabel "Design and plan launch of project"@en .

<http://ots.local/thesaurus/apqc/13_2_3_3_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2_3_3> ;
    skos:definition "Putting the project into position by effectively bringing it into action."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.3.3.7" ;
    skos:prefLabel "Deploy the project"@en .

<http://ots.local/thesaurus/apqc/13_2_3_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2_3_4> ;
    skos:definition "Assessing the impact of business project management on the measures and outcomes of the projects. Gauge non-financial measures, frequency of measurement, action plan, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.3.4.1" ;
    skos:prefLabel "Evaluate impact of project management (strategy and projects) on measures and outcomes"@en .

<http://ots.local/thesaurus/apqc/13_2_3_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2_3_4> ;
    skos:definition "Recording and documenting the current status and position of the project. Record and report items such as completed tasks, incomplete tasks, planned tasks, and problems faced."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.3.4.2" ;
    skos:prefLabel "Report the status of project"@en .

<http://ots.local/thesaurus/apqc/13_2_3_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2_3_4> ;
    skos:definition "Determining and documenting a list of specific project goals, deliverables, tasks, costs, and deadlines. Use the scope statement to explain the boundaries of the project. Assign responsibilities for team members. Set up procedures for verifying and approving the completed tasks."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.3.4.3" ;
    skos:prefLabel "Manage project scope"@en .

<http://ots.local/thesaurus/apqc/13_2_3_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2_3_4> ;
    skos:definition "Encouraging and sustaining the activities and involvement while executing projects. Promote the execution activities of the projects. Encourage employee involvement in project implementation."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.3.4.4" ;
    skos:prefLabel "Promote and sustain activity and involvement"@en .

<http://ots.local/thesaurus/apqc/13_2_3_4_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2_3_4> ;
    skos:definition "Hold post project reviews, lessons learned, or After Action Reviews (AARs) at the end of each project to understand what could be improved during future projects."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.3.4.5" ;
    skos:prefLabel "Conduct Project Reviews with Program Managers and other stakeholders"@en .

<http://ots.local/thesaurus/apqc/13_2_3_4_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2_3_4> ;
    skos:definition "Reorganizing and stimulating the approach and strategy for managing business projects. Make improvements based on the project scope and on findings from Evaluate the impact of project management (strategy and projects) on measures and outcomes [11131]."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.3.4.6" ;
    skos:prefLabel "Realign and refresh project management strategy and approaches"@en .

<http://ots.local/thesaurus/apqc/13_2_3_4_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2_3_4> ;
    skos:definition "Changes to project plans based upon internal and or external influences on the project.  This would include the update to the project plan file, as well as the communication to the team."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.3.4.7" ;
    skos:prefLabel "Adjust project plan as needed"@en .

<http://ots.local/thesaurus/apqc/13_2_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2_3> ;
    skos:definition "Measuring the performance of a business project against key performance indicators including the project scope, schedule, quality, cost, and risk criteria. Identify any deviations from the plan. Assess the impact of these deviations on the project, as well as on the overall program. Report results to key stakeholders."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.3.5" ;
    skos:prefLabel "Review and report project performance"@en .

<http://ots.local/thesaurus/apqc/13_2_3_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_2_3> ;
    skos:definition "Settling each contract. Close each contract applicable to the project or project phase. Finalize all activities across all of the process groups in order to formally close the project or a project phase."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.2.3.6" ;
    skos:prefLabel "Close projects"@en .

<http://ots.local/thesaurus/apqc/13_3_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_1> ;
    skos:definition "Outlining characteristics crucial for managing enterprise quality. Translate broad customer needs into specific, actionable, measurable performance requirements. Define the key measurable characteristics of key products and processes."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.1.1" ;
    skos:prefLabel "Define critical-to-quality characteristics"@en .

<http://ots.local/thesaurus/apqc/13_3_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_1> ;
    skos:definition "Identifying gaps in customer requirements and determining whether the gap will be mitigated through preventive Quality activities or deemed as acceptable risk. The goal of any preventive quality activities is to create provisions to prevent, control, or reduce the risk of not meeting the CtQCs. In addition, any standard methodology that will be used to design or conduct preventive Quality activities are defined and documented."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.1.2" ;
    skos:prefLabel "Define preventive quality activities"@en .

<http://ots.local/thesaurus/apqc/13_3_1_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_1_3> ;
    skos:definition "Establishing the steps for developing quality controls. Conduct Alpha testing. Have the product team conduct rework. Send the product/service for Beta testing, and carry on rework as needed."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.1.3.1" ;
    skos:prefLabel "Define process steps for controls (or integration points)"@en .

<http://ots.local/thesaurus/apqc/13_3_1_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_1_3> ;
    skos:definition "Establishing a detailed summary including measures, on which material, in what manner, and by whom. Identify the parameters to be measured, the range of possible values, and the required resolution. Provide a sampling scheme that details how and when samples will be taken. Select sample sizes. Assign roles and responsibilities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.1.3.2" ;
    skos:prefLabel "Define sampling plan"@en .

<http://ots.local/thesaurus/apqc/13_3_1_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_1_3> ;
    skos:definition "Using tools to measure quality. Use tools such as quality improvement oversight system tool, performance measurement tools, consumer information models/guides, and validation tools to effectively determine the quality levels."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.1.3.3" ;
    skos:prefLabel "Identify measurement methods"@en .

<http://ots.local/thesaurus/apqc/13_3_1_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_1_3> ;
    skos:definition "Defining the competencies required for developing quality controls. Define the required competencies including compliance management, audit management, and document control and document management."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.1.3.4" ;
    skos:prefLabel "Define required competencies"@en .

<http://ots.local/thesaurus/apqc/13_3_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_1> ;
    skos:definition "Demonstrating the ability and capability to confirm and fulfill the quality requirements in front of customers, managers, employees, board members, associations, regulatory bodies, and creditors. Leverage tools and techniques such as process behavior or control charts, statistical process control, measurement system analysis, gage calibration management, and process capability analysis."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.1.4" ;
    skos:prefLabel "Prove capability to assess compliance with requirements"@en .

<http://ots.local/thesaurus/apqc/13_3_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_1> ;
    skos:definition "Establishing how the critical-to-quality characteristics will be achieved, controlled, ensured, and managed throughout the lifecycle of a product/service. Address quality requirements and critical-to-quality characteristics. Conduct a preventive quality assessment. Describe how to verify the product/service, verification criteria, and response to nonconformance. Keep records to demonstrate conformity."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.1.5" ;
    skos:prefLabel "Finalize quality plan"@en .

<http://ots.local/thesaurus/apqc/13_3_2_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_2_1> ;
    skos:definition "Evaluating quality performance through periodic or episodic testing against the established standards for quality characteristics. For periodic testing, design a schedule with sufficient time to make any required adjustments to the process or system to maintain the desired level of quality. For episodic testing, conduct a test whenever a known non-conformance or fault occurs, which results in outputs or outcomes known to be unsatisfactory to performance requirements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.2.1.1" ;
    skos:prefLabel "Conduct test and collect data"@en .

<http://ots.local/thesaurus/apqc/13_3_2_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_2_1> ;
    skos:definition "Maintaining and recording the results of Test against the quality plan [17483] electronically and in standard formats. Assign ownership to a designated function or role."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.2.1.2" ;
    skos:prefLabel "Record result(s)"@en .

<http://ots.local/thesaurus/apqc/13_3_2_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_2_1> ;
    skos:definition "Deciding whether to take any additional actions based on the results of quality tests. Initiate a quarantine disposition and relocated inventory, scrap workflow item and scrap transaction, rework operation, net-able and nonnet-able items, and the activity list."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.2.1.3" ;
    skos:prefLabel "Determine disposition of result(s)"@en .

<http://ots.local/thesaurus/apqc/13_3_2_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_2_2> ;
    skos:definition "Assessing the significance of the sample chosen for the test in order to determine whether or not the sample is representative of the larger output or outcome. Determine if the sample meets or does not meet the requirements. Identify the conditions for acceptance, rejection, remediation, and prevention."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.2.2.1" ;
    skos:prefLabel "Assess sample significance"@en .

<http://ots.local/thesaurus/apqc/13_3_2_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_2_2> ;
    skos:definition "Outlining the major facts and figures of the quality test results in order to provide insights and information. Use charts, tables, statistical test results, and written findings and conclusions in a summary of results."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.2.2.2" ;
    skos:prefLabel "Summarize result(s)"@en .

<http://ots.local/thesaurus/apqc/13_3_2_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_2_2> ;
    skos:definition "Recommending measures for improvement. Assess the summarized results to identify areas which can be improved. Suggest actions to management for improving the quality plan basis on the results of the tests."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.2.2.3" ;
    skos:prefLabel "Recommend actions"@en .

<http://ots.local/thesaurus/apqc/13_3_2_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_2_2> ;
    skos:definition "Selecting the subsequent actions that the organization can adopt for improving the enterprise quality. Select measures and recommended actions for managing the enterprise quality."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.2.2.4" ;
    skos:prefLabel "Decide next steps"@en .

<http://ots.local/thesaurus/apqc/13_3_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_3> ;
    skos:definition "Analyzing any nonconformance events. Determine the need for corrective and/or preventative action(s). Leverage root-cause analysis, risk exposure, and other evaluations to properly review and approve/reject subsequent actions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.3.1" ;
    skos:prefLabel "Assess potential impact"@en .

<http://ots.local/thesaurus/apqc/13_3_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_3> ;
    skos:definition "Initiating immediate corrective, preventative, or no action based upon the impact and likelihood of reoccurrence. Consider cost/benefit, risk exposure, timing, the assignment of responsibility, and other pertinent factors ."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.3.2" ;
    skos:prefLabel "Determine immediate action(s)"@en .

<http://ots.local/thesaurus/apqc/13_3_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_3> ;
    skos:definition "Recognizing the reasons that have triggered the nonconformance events or activities. Perform a root-cause analysis through documentary evidence and interviews. Involve the appropriate individuals. Leverage cause analysis and risk assessment."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.3.3" ;
    skos:prefLabel "Identify root cause(s)"@en .

<http://ots.local/thesaurus/apqc/13_3_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_3> ;
    skos:definition "Pursuing corrective and preventative activities to eliminate the cause of a detected nonconformity. Define the nonconformity. Communicate and assign responsibility. Identify the appropriate corrective and preventive action. Implement and monitor for reoccurrence."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.3.4" ;
    skos:prefLabel "Take corrective or preventative action"@en .

<http://ots.local/thesaurus/apqc/13_3_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_3> ;
    skos:definition "Closing nonconformance. Perform all the final processes related to the nonconformance, including documenting root causes. Document corrective and preventive actions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.3.5" ;
    skos:prefLabel "Close non-conformance"@en .

<http://ots.local/thesaurus/apqc/13_3_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_4> ;
    skos:definition "Outlining the strategy for managing enterprise quality. Define and formalize quality techniques and standards. Assign responsibilities for achieving the required quality levels. Standardize the quality maintenance procedure, tools and techniques, recording and reporting, the timing of quality maintenance activities, and the roles and responsibilities for the quality management team."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.4.1" ;
    skos:prefLabel "Define the quality strategy"@en .

<http://ots.local/thesaurus/apqc/13_3_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_4> ;
    skos:definition "Establishing and effectively deploying the scope, targets, and goals of EQMS. Define the role of EQMS through nonconformance/corrective and preventive action, compliance/audit management, risk management, failure mode and effects analysis, and statistical process control. Implement EQMS into operational activities. Define the goals and objectives that are to be achieved by the EQMS."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.4.2" ;
    skos:prefLabel "Plan and deploy the EQMS scope, targets, and goals"@en .

<http://ots.local/thesaurus/apqc/13_3_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_4> ;
    skos:definition "Recognizing and implementing the processes, controls, and metrics for maintenance of EQMS. Define the role of EQMS in failure mode and effects analysis, complaint handling, and advanced product quality planning. Establish the role of EQMS in evaluating metrics such as cost of quality, overall equipment effectiveness, on-time and complete shipments, percentage of products in compliance, and new product introductions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.4.3" ;
    skos:prefLabel "Identify core EQMS processes, controls, and metrics"@en .

<http://ots.local/thesaurus/apqc/13_3_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_4> ;
    skos:definition "Setting the process limits. Gather required information. Align with other documents and processes. Define the document structure."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.4.4" ;
    skos:prefLabel "Develop and document EQMS policies, procedures, standards, and measures"@en .

<http://ots.local/thesaurus/apqc/13_3_4_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_4> ;
    skos:definition "Benchmarking current performance in quality metrics that span across the value chain. Identify gaps in performance as compared to industry peers. Identify and implement complementary EQMS capabilities. Enable a continuous improvement environment."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.4.5" ;
    skos:prefLabel "Assess the EQMS performance"@en .

<http://ots.local/thesaurus/apqc/13_3_4_6_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_4_6> ;
    skos:definition "Provisioning rewards for achieving quality excellence. Provide monetary and nonmonetary rewards such as compensation, vacations, gift cards, and reimbursements to employees in in recognition of their services, efforts, and achievements in quality excellence."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.4.6.1" ;
    skos:prefLabel "Reward quality excellence"@en .

<http://ots.local/thesaurus/apqc/13_3_4_6_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_4_6> ;
    skos:definition "Establishing and maintaining partnerships with third-party sources to achieve quality excellence. Source and evaluate third-party sources both public and private to ensure that the most effective and efficient partnerships are formed."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.4.6.2" ;
    skos:prefLabel "Create and maintain quality partnerships"@en .

<http://ots.local/thesaurus/apqc/13_3_4_6_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_4_6> ;
    skos:definition "Maintaining a common denominator for the competency level within the organization's talent circle. Conduct training sessions, skill development activities, and quality excellence activities to ensure that the resources of the organization are competent enough and have the capabilities to achieve the required level of quality."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.4.6.3" ;
    skos:prefLabel "Maintain talent capabilities and competencies"@en .

<http://ots.local/thesaurus/apqc/13_3_4_6_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_4_6> ;
    skos:definition "Assimilating all the communication related to the EQMS into the organization's already established communication channels."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.4.6.4" ;
    skos:prefLabel "Incorporate EQMS messaging into communication channels"@en .

<http://ots.local/thesaurus/apqc/13_3_4_6_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_4_6> ;
    skos:definition "Ensuring EQMS access to the person in charge of the quality management process. Establish who has the authority to manage the EQMS. Ensure access of EQMS to only the person(s) in authority."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.4.6.5" ;
    skos:prefLabel "Assure independent EQMS management access to appropriate authority in the organization"@en .

<http://ots.local/thesaurus/apqc/13_3_4_6_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_3_4_6> ;
    skos:definition "Recording and transferring the best practices and proven methods associated with enterprise quality management systems (EQMS) that can be leveraged in improving the organization's framework. Record proven methodologies and approaches with the objective of communicating them for upgrading, refining, and enhancing the organization's systems."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.3.4.6.6" ;
    skos:prefLabel "Transfer proven EQMS methods"@en .

<http://ots.local/thesaurus/apqc/13_4_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4_1> ;
    skos:definition "Identifying and communicating with shareholders affected by the change. Consider internal and external stakeholders that will be affected by the change. Determine the amount of influence the change will have on them. Ensure the involvement of these stakeholders in the change process by effectively communicating with them."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.1.1" ;
    skos:prefLabel "Determine stakeholders"@en .

<http://ots.local/thesaurus/apqc/13_4_1_10> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4_1> ;
    skos:definition "Recognizing the impact of threats to critical assets. Determine what groups are impacted by this impact."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.1.10" ;
    skos:prefLabel "Identify impacted groups"@en .

<http://ots.local/thesaurus/apqc/13_4_1_11> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4_1> ;
    skos:definition "Evaluating the impact of threats to critical assets. Determine what assets will be impacted by the change."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.1.11" ;
    skos:prefLabel "Determine degree/extent of impact"@en .

<http://ots.local/thesaurus/apqc/13_4_1_12> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4_1> ;
    skos:definition "Identifying and assigning the people accountable for effective change management. Hold managers accountable for ensuring change happens systematically and rigorously. Ensure that certain behaviors are rewarded or reprimanded accordingly."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.1.12" ;
    skos:prefLabel "Establish accountability for change management"@en .

<http://ots.local/thesaurus/apqc/13_4_1_13> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4_1> ;
    skos:definition "Recognizing the circumstances or obstacles that keep the organization from progressing. Identify who and what are the resources resisting change. Identify integration failures, threats by competitive forces, and complexity failures."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.1.13" ;
    skos:prefLabel "Identify barriers to change"@en .

<http://ots.local/thesaurus/apqc/13_4_1_14> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4_1> ;
    skos:definition "Identifying the person(s) or thing(s)responsible for making the change possible. Consider factors such as interdependence of efforts, reward to the integrators, sharing of power and responsibility, and employee understanding of why change is essential."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.1.14" ;
    skos:prefLabel "Determine change enablers"@en .

<http://ots.local/thesaurus/apqc/13_4_1_15> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4_1> ;
    skos:definition "Recognizing the resource requirements, and developing measures for change. Identify the financial, material, human, and informational resources needed to successfully implement the change. Develop programs, campaigns, etc. for establishing the change within the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.1.15" ;
    skos:prefLabel "Identify resources and develop measures"@en .

<http://ots.local/thesaurus/apqc/13_4_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4_1> ;
    skos:definition "Determining the level of preparedness of the conditions, attitudes, and resources at all levels in the organization needed for change to happen successfully. Define scope of the proposed change. Select the tools for a change readiness assessment."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.1.2" ;
    skos:prefLabel "Assess readiness for change"@en .

<http://ots.local/thesaurus/apqc/13_4_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4_1> ;
    skos:definition "Identifying people exhibit an extraordinary interest in the adoption, implementation, and success of the change. Engage champions in each division or team. Define the roles and responsibilities for the change champions. Determine criteria for selecting change champions. Provide training sessions to champions. Reward and recognize champions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.1.3" ;
    skos:prefLabel "Identify change champion(s)"@en .

<http://ots.local/thesaurus/apqc/13_4_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4_1> ;
    skos:definition "Preparing a design team for implementing change throughout the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.1.4" ;
    skos:prefLabel "Form design team"@en .

<http://ots.local/thesaurus/apqc/13_4_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4_1> ;
    skos:definition "Defining the extent of the area or subject matter that the change process deals with or to which it is relevant. Establish a set of tools, processes, skills, and principles for managing the people side of change to achieve the required outcomes of the change process."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.1.5" ;
    skos:prefLabel "Define scope"@en .

<http://ots.local/thesaurus/apqc/13_4_1_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4_1> ;
    skos:definition "Using graphical and statistical tools such as pareto diagrams, process flow diagrams, cause-and-effect diagrams, check sheets, histograms, run charts, and scatter diagrams."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.1.6" ;
    skos:prefLabel "Understand current state"@en .

<http://ots.local/thesaurus/apqc/13_4_1_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4_1> ;
    skos:definition "Determining the state or position that the organization wants to be in after the implementation of the change. Gather necessary information about the processes, structures, and cultures. Define resource requirements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.1.7" ;
    skos:prefLabel "Define future state"@en .

<http://ots.local/thesaurus/apqc/13_4_1_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4_1> ;
    skos:definition "Looking beyond the immediate consequences of the threat to a critical asset and placing it in the context of what is important to the organization. Identify the impact of threats to critical assets. Create risk evaluation criteria. Evaluate the impact of threats to critical assets. Incorporate probability into the risk analysis."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.1.8" ;
    skos:prefLabel "Conduct organizational risk analysis"@en .

<http://ots.local/thesaurus/apqc/13_4_1_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4_1> ;
    skos:definition "Evaluating the culture within the organization. Adopt a quantitative, multidimensional measurement approach of an organization's culture and the aspirations for it. Diagnose cultural activities, enhance leadership sections. Integrate cultures."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.1.9" ;
    skos:prefLabel "Assess cultural context"@en .

<http://ots.local/thesaurus/apqc/13_4_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4_2> ;
    skos:definition "Correlating the change initiative with the other initiatives. Create an alignment between the goals and objectives of the change process and that of the other initiatives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.2.1" ;
    skos:prefLabel "Assess connection to other initiatives"@en .

<http://ots.local/thesaurus/apqc/13_4_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4_2> ;
    skos:definition "Creating a detailed structure summary for the purposes of managing the change. Demonstrate the reasons for the change. Define the type and scope of change. Form a change management team. Create a communication plan."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.2.2" ;
    skos:prefLabel "Develop change management plans"@en .

<http://ots.local/thesaurus/apqc/13_4_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4_2> ;
    skos:definition "Creating a detailed summary of all the actions relevant to teaching a person a particular skill or type of behavior. Determine who will deliver the training. Determine when and where the apprentice or trainee needs to go to receive the structured component of the training."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.2.3" ;
    skos:prefLabel "Develop training plan"@en .

<http://ots.local/thesaurus/apqc/13_4_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4_2> ;
    skos:definition "Developing a plan for imparting or exchanging information relevant the to change. Define goals, objectives, and audience. Gather tools for all communications."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.2.4" ;
    skos:prefLabel "Develop communication plan"@en .

<http://ots.local/thesaurus/apqc/13_4_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4_2> ;
    skos:definition "Utilizing champions that have been trained to carry out needed changes. Engage champions to communicate roles and responsibilities for the change."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.2.5" ;
    skos:prefLabel "Assign change champion(s)"@en .

<http://ots.local/thesaurus/apqc/13_4_2_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4_2> ;
    skos:definition "Creating and designing the plan for rewarding the employees exhibiting the desired behavior. Specify rewards in recognition of service, effort, or achievement regarding the change, including bonuses, compensation, stock options, profit sharing, vacations, and flexible time."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.2.6" ;
    skos:prefLabel "Develop rewards/incentives plan"@en .

<http://ots.local/thesaurus/apqc/13_4_2_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4_2> ;
    skos:definition "Establishing a system or standard of measurement for measuring the adoption of the change. Consider activities such as the number of people who have adopted the change, how quickly have they adopted, number of unique adopters, and adopters by teams/divisions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.2.7" ;
    skos:prefLabel "Establish change adoption measures"@en .

<http://ots.local/thesaurus/apqc/13_4_2_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4_2> ;
    skos:definition "Establishing and explaining the new roles to employees. Assign roles and responsibilities to resources."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.2.8" ;
    skos:prefLabel "Establish/Clarify new roles"@en .

<http://ots.local/thesaurus/apqc/13_4_2_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4_2> ;
    skos:definition "Creating a plan of financial outlay for the newly defined roles. Determine the amount of capital the organization is willing to invest in effectuating these new roles, how would the roles be financed, and what would comprise the ROI from these flows. Coordinate personnel responsible for change management and the finance division."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.2.9" ;
    skos:prefLabel "Identify budget/roles"@en .

<http://ots.local/thesaurus/apqc/13_4_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4_3> ;
    skos:definition "Kindling an organization wide commitment for effectuating the change. Effectively communicate the advantages of the desired change. Personalize the pitch for change."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.3.1" ;
    skos:prefLabel "Create commitment for improvement/change"@en .

<http://ots.local/thesaurus/apqc/13_4_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4_3> ;
    skos:definition "Restructuring, redesigning, repurposing, and/or retrofitting existing business processes, activities, and frameworks in order to effectuate the desired change. Review pertinent processes from the ground up by starting with the desired result. (Build on Select a process improvement methodology [11138] to create business processes that perfectly fit with the road map for change.)"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.3.2" ;
    skos:prefLabel "Reengineer business processes and systems"@en .

<http://ots.local/thesaurus/apqc/13_4_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4_3> ;
    skos:definition "Supporting the transition of personnel to new roles and the dismissal of any existing employees, necessitated for the desired change. Create an on-boarding process for seamlessly transitioning personnel to new roles. Offer orientation and training. Address any concerns. Create a structured procedure for the discharge of incumbents from their positions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.3.3" ;
    skos:prefLabel "Support transition to new roles or exit strategies for incumbents"@en .

<http://ots.local/thesaurus/apqc/13_4_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4_3> ;
    skos:definition "Monitoring activities in the change process in order to assess the performance of individual agents and the process as a whole. Oversee the implementation of activities needed for effectuating the change. Track the pace, impact, enthusiasm, reaction, and feedback over the change process."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.3.4" ;
    skos:prefLabel "Monitor change"@en .

<http://ots.local/thesaurus/apqc/13_4_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4_3> ;
    skos:definition "Reporting on the outcome of the change. Document changes and the impact those changes had on critical assets. Share findings with those within the target audience: those impacted by the change, change champions, stakeholders, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.3.5" ;
    skos:prefLabel "Report on change"@en .

<http://ots.local/thesaurus/apqc/13_4_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4_4> ;
    skos:definition "Monitoring the performance of improved business processes. Track the key performance indicators of the upgraded processes in order to gauge its contribution to the desired change. Expedite through the use of business process management software."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.4.1" ;
    skos:prefLabel "Monitor improved process performance"@en .

<http://ots.local/thesaurus/apqc/13_4_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4_4> ;
    skos:definition "Documenting and standardizing insights gleaned and the knowledge acquired from studying the change process already implemented. Create case studies/best practices guides from the process of implementing change. Include experienced personnel."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.4.2" ;
    skos:prefLabel "Capture and reuse lessons learned from change process"@en .

<http://ots.local/thesaurus/apqc/13_4_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_4_4> ;
    skos:definition "Implement corrective action to adjust the re-engineered processes for maximizing the desired impact. Adjust business processes and systems to implement the desired change."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.4.4.3" ;
    skos:prefLabel "Take corrective action as necessary"@en .

<http://ots.local/thesaurus/apqc/13_5_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_5_1> ;
    skos:definition "Developing a structure for the governance of the organization's collective knowledge. Gather, maintain, and make accessible the collective knowledge base. Develop a standard procedure for the conservation and perpetuation of the organization's knowledge. Create policies for the usage and maintenance of this knowledge. Establish specialized roles."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.5.1.1" ;
    skos:prefLabel "Develop governance model with roles and accountability"@en .

<http://ots.local/thesaurus/apqc/13_5_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_5_1> ;
    skos:definition "Clearly determining the roles and responsibilities of all personnel involved in the management of the organization's corpus of knowledge. Flesh out the roles and responsibilities of the KM core group, as well as the operational staff involved in the upkeep of the knowledge management program."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.5.1.2" ;
    skos:prefLabel "Define roles and accountability of core group versus operating units"@en .

<http://ots.local/thesaurus/apqc/13_5_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_5_1> ;
    skos:definition "Analyze the organization's current approach to funding. Learn from the funding approaches of peer organizations. Evaluate the revenue potential and costs of those short-list funding models. Select funding models to implement."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.5.1.3" ;
    skos:prefLabel "Develop funding models"@en .

<http://ots.local/thesaurus/apqc/13_5_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_5_1> ;
    skos:definition "Identifying any links that exist between the strategy for knowledge management and any other functional areas. Determine any correlations that exist between the strategic road map for the knowledge management and any other functional areas. Study each function's/unit's attributes."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.5.1.4" ;
    skos:prefLabel "Identify links to key initiatives"@en .

<http://ots.local/thesaurus/apqc/13_5_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_5_1> ;
    skos:definition "Creating core knowledge management procedures and methodologies. Initiate developing a strategy, planning, execution, and improvement."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.5.1.5" ;
    skos:prefLabel "Develop core KM methodologies"@en .

<http://ots.local/thesaurus/apqc/13_5_1_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_5_1> ;
    skos:definition "Determining the IT needs for developing the knowledge management strategy, and collaborating with the IT function to implement the strategy. Assess requirements for technologies such as computer hardware, software, electronics, semiconductors, internet, and telecommunications equipment in order to effectively build and implement the strategy for knowledge management."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.5.1.6" ;
    skos:prefLabel "Assess IT needs and engage IT function"@en .

<http://ots.local/thesaurus/apqc/13_5_1_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_5_1> ;
    skos:definition "Creating plans for KM training plans and conveying the knowledge management strategy within the organization. Create training programs, sessions, and activities in order to familiarize employees and management with the concept of knowledge management."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.5.1.7" ;
    skos:prefLabel "Develop training and communication plans"@en .

<http://ots.local/thesaurus/apqc/13_5_1_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_5_1> ;
    skos:definition "Creating approaches for effectively administering the changes in knowledge management. Design an approach that transforms individuals, teams, and the organization to a desired future state represented by the change."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.5.1.8" ;
    skos:prefLabel "Develop change management approaches"@en .

<http://ots.local/thesaurus/apqc/13_5_1_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_5_1> ;
    skos:definition "Establishing measures and indicators for evaluating the performance of the knowledge management function. Define key performance indicators such as the amount of knowledge assets created and number of knowledge projects undertaken."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.5.1.9" ;
    skos:prefLabel "Develop strategic measures and indicators"@en .

<http://ots.local/thesaurus/apqc/13_5_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_5_2> ;
    skos:definition "Evaluating if initiatives are effective or should be discarded. Design a framework for assessing maturity, typically from Level 1 (undefined), Level 2 (repeatable), Level 3 (defined), and Level 4 (managed) through Level 5 (optimized)."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.5.2.1" ;
    skos:prefLabel "Assess maturity of existing KM initiatives"@en .

<http://ots.local/thesaurus/apqc/13_5_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_5_2> ;
    skos:definition "Evaluating existing procedures, policies, and guidelines for knowledge management. Study and examine the organization's approach against industry best practices by benchmarking, competitive analysis, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.5.2.2" ;
    skos:prefLabel "Evaluate existing KM approaches"@en .

<http://ots.local/thesaurus/apqc/13_5_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_5_2> ;
    skos:definition "Assessing the KM approach evaluations in order to identify any gaps or needs. Compare the performance of the KM approach against the desired or expected performance, as well as against the standard knowledge management industry approach."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.5.2.3" ;
    skos:prefLabel "Identify gaps and needs"@en .

<http://ots.local/thesaurus/apqc/13_5_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_5_3> ;
    skos:definition "Designing new policies, procedures, and guidelines to support knowledge management."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.5.3.1" ;
    skos:prefLabel "Develop new KM approaches"@en .

<http://ots.local/thesaurus/apqc/13_5_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_5_3> ;
    skos:definition "Creating a model to describe resources and approaches to organization's knowledge management. Establish standards and guidelines to be followed."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.5.3.2" ;
    skos:prefLabel "Design resource model for KM approaches"@en .

<http://ots.local/thesaurus/apqc/13_5_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_5_3> ;
    skos:definition "Implementing new policies, procedures, and guidelines to support knowledge management."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.5.3.3" ;
    skos:prefLabel "Implement new KM approaches"@en .

<http://ots.local/thesaurus/apqc/13_5_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_5_3> ;
    skos:definition "Using existing technologies to improve organization's knowledge management processes. Research available third-party offerings. Develop proprietary solutions. Employ knowledge engineers, data scientists and other relevant personnel."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.5.3.4" ;
    skos:prefLabel "Leverage and enhance IT for KM approaches"@en .

<http://ots.local/thesaurus/apqc/13_5_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_5_3> ;
    skos:definition "Creating metrics that can be used to systematically describe KM approaches and capabilities. Choose applicable scales, benchmarks and units of measure. Determine required precision and error rates."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.5.3.5" ;
    skos:prefLabel "Develop measures"@en .

<http://ots.local/thesaurus/apqc/13_5_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_5_4> ;
    skos:definition "Leveraging KM evaluations and identified gap to enhance existing approaches."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.5.4.1" ;
    skos:prefLabel "Enhance/Modify existing KM approaches"@en .

<http://ots.local/thesaurus/apqc/13_5_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_5_4> ;
    skos:definition "Developing awareness about available knowledge bases and promoting their use to maximize their impact."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.5.4.2" ;
    skos:prefLabel "Sustain awareness and engagement"@en .

<http://ots.local/thesaurus/apqc/13_5_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_5_4> ;
    skos:definition "Augmenting available resources to better leverage the offerings of the organization to serve existing clients and to expand the client base."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.5.4.3" ;
    skos:prefLabel "Expand KM infrastructure to meet demand"@en .

<http://ots.local/thesaurus/apqc/13_6_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6_1> ;
    skos:definition "Establishing objectives for content management that enhance the organization and accessibility of enterprise content. Objectives can include curation, findability, consistency, user-centric design, lifecycle management, governance and roles, quality assurance, and measurement and evaluation."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.1.1" ;
    skos:prefLabel "Establish content management objectives"@en .

<http://ots.local/thesaurus/apqc/13_6_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6_1> ;
    skos:definition "Establishing a structured framework with roles and responsibilities to oversee and guide content management practices within an organization to ensure content is managed consistently, remains high-quality, meets the needs of users, and enhances the overall content management strategy."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.1.2" ;
    skos:prefLabel "Develop content management governance model"@en .

<http://ots.local/thesaurus/apqc/13_6_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6_1> ;
    skos:definition "Defining funding approaches for content management activities, capabilities, and infrastructure to support sustainable operations, investment prioritization, and alignment with organizational objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.1.3" ;
    skos:prefLabel "Develop content management funding models"@en .

<http://ots.local/thesaurus/apqc/13_6_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6_1> ;
    skos:definition "Identifying and implementing content management methodologies to effectively store, deliver, and facilitate access to enterprise content. Core methodologies may include prioritization of critical or high-value content, findability to ensure ease of locating relevant content, content lifecycle management, standardization of content creation, review and access, collaboration, and technology integration."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.1.4" ;
    skos:prefLabel "Develop core content management methodologies"@en .

<http://ots.local/thesaurus/apqc/13_6_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6_1> ;
    skos:definition "Assessing technology requirements for content management and collaborating with the IT function to align systems, integration, security, and support with content management needs. This includes leveraging all forms of new and evolving technology such as artificial intelligence (AI)."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.1.5" ;
    skos:prefLabel "Assess content management IT needs and engage IT function"@en .

<http://ots.local/thesaurus/apqc/13_6_1_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6_1> ;
    skos:definition "Developing training, change and communication plans to support the organization's content management practices. Define target audiences, required competencies, learning objectives, and delivery methods to ensure consistent understanding and adoption of content standards, tools, and workflows. Create communication strategies to promote awareness of content governance, reinforce expectations, and inform stakeholders of process updates, system changes, and best practices. Coordinate with internal partners to design training materials, schedule learning sessions, and disseminate communications that enable effective and compliant content creation, storage, use, and lifecycle management. Monitor participation, evaluate effectiveness, and continuously improve based on feedback and evolving organizational needs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.1.6" ;
    skos:prefLabel "Develop content management training and communication plans"@en .

<http://ots.local/thesaurus/apqc/13_6_1_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6_1> ;
    skos:definition "Defining and implementing performance measures to assess the effectiveness and strategic value of content management practices. Align indicators with organizational goals, governance requirements, and user needs. Specify data sources, measurement methods, and reporting cadences to provide reliable insight into content quality, accessibility, utilization, and lifecycle compliance. Collaborate with stakeholders to validate metric definitions, integrate measures into dashboards, and set expectations for monitoring and improvement. Periodically review and refine measures in response to changing priorities and requirements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.1.7" ;
    skos:prefLabel "Develop strategic measures and indicators for content management"@en .

<http://ots.local/thesaurus/apqc/13_6_1_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6_1> ;
    skos:definition "Monitor and analyze content ecosystem performance to understand search behavior, user intent, knowledge gaps, content effectiveness, and content lifecycle health. Use content usage patterns and derived insights to identify emerging needs, anticipate gaps, recommend updates or new content, and continuously optimize the relevance, quality, and accessibility of the content ecosystem. This includes leveraging all forms of new and evolving technology such as artificial intelligence (AI)"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.1.8" ;
    skos:prefLabel "Manage content intelligence and insights"@en .

<http://ots.local/thesaurus/apqc/13_6_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6_2> ;
    skos:definition "Identifying functional, operational, governance, and compliance requirements that content management practices and solutions must satisfy across the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.2.1" ;
    skos:prefLabel "Determine content management requirements"@en .

<http://ots.local/thesaurus/apqc/13_6_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6_2> ;
    skos:definition "Establishing content metadata structures that function as a common classification language by defining hierarchical categories and attributes used to organize and relate content, ensuring consistency across formats, business areas, and locations and supporting discoverability and semantic enrichment."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.2.2" ;
    skos:prefLabel "Define content taxonomies"@en .

<http://ots.local/thesaurus/apqc/13_6_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6_2> ;
    skos:definition "Defining standardized conventions for naming, versioning, and tagging digital files and content assets to support consistency, findability, and compliance across the organization. Establish required metadata elements and tagging structures aligned with enterprise taxonomies, information architecture, and regulatory or operational needs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.2.3" ;
    skos:prefLabel "Define file naming standards and tagging requirements"@en .

<http://ots.local/thesaurus/apqc/13_6_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6_3> ;
    skos:definition "Defining rules and permissions that govern who can create, view, modify, and distribute content to protect sensitive information and support appropriate access."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.3.1" ;
    skos:prefLabel "Define content access controls"@en .

<http://ots.local/thesaurus/apqc/13_6_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6_3> ;
    skos:definition "Establishing audit and retention requirements to ensure content is reviewed, retained, archived, or disposed of in accordance with governance, legal, and operational obligations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.3.2" ;
    skos:prefLabel "Develop content audit and retention requirements"@en .

<http://ots.local/thesaurus/apqc/13_6_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6_4> ;
    skos:definition "Establishing and maintaining content repositories and systems of record to support secure storage, organization, access, and lifecycle management."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.4.1" ;
    skos:prefLabel "Set up and maintain systems of record and storage locations"@en .

<http://ots.local/thesaurus/apqc/13_6_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6_4> ;
    skos:definition "Executing administrative activities required to manage content systems, permissions, structures, and configurations in accordance with defined standards and governance."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.4.2" ;
    skos:prefLabel "Implement and execute content administration responsibilities"@en .

<http://ots.local/thesaurus/apqc/13_6_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6_4> ;
    skos:definition "Overseeing activities to verify that content complies with established standards, policies, and requirements across its lifecycle."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.4.3" ;
    skos:prefLabel "Audit content compliance"@en .

<http://ots.local/thesaurus/apqc/13_6_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6_4> ;
    skos:definition "Planning content audits by defining scope, criteria, timing, and responsibilities to assess compliance and effectiveness of content management practices."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.4.4" ;
    skos:prefLabel "Plan content audits"@en .

<http://ots.local/thesaurus/apqc/13_6_4_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6_4> ;
    skos:definition "Conducting reviews of content to evaluate compliance with defined standards, controls, and retention requirements. Includes auditing for semantic accuracy, metadata completeness, and AI-readiness. Consider leveraging all forms of new and evolving technology such as artificial intelligence (AI)."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.4.5" ;
    skos:prefLabel "Perform content audits"@en .

<http://ots.local/thesaurus/apqc/13_6_4_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6_4> ;
    skos:definition "Tracking identified content non-compliance issues and monitoring corrective actions to ensure timely resolution and adherence to content standards."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.4.6" ;
    skos:prefLabel "Track content non-compliance resolution"@en .

<http://ots.local/thesaurus/apqc/13_6_5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6_5> ;
    skos:definition "Identifying content needs and existing content assets to support reuse, updates, and alignment with organizational requirements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.5.1" ;
    skos:prefLabel "Identify new and existing content"@en .

<http://ots.local/thesaurus/apqc/13_6_5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6_5> ;
    skos:definition "Identifying control requirements for content, including review, approval, access, and compliance needs across the content lifecycle."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.5.2" ;
    skos:prefLabel "Identify content control requirements"@en .

<http://ots.local/thesaurus/apqc/13_6_5_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6_5> ;
    skos:definition "Preparing newly created content for use by applying required standards, structure, and controls prior to review and approval."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.5.3" ;
    skos:prefLabel "Prepare created content"@en .

<http://ots.local/thesaurus/apqc/13_6_5_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6_5> ;
    skos:definition "Preparing externally sourced or acquired content for organizational use by validating quality, applying standards, and aligning it with governance requirements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.5.4" ;
    skos:prefLabel "Prepare acquired content"@en .

<http://ots.local/thesaurus/apqc/13_6_5_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6_5> ;
    skos:definition "Refining content to improve clarity, accuracy, consistency, and quality for its existing intended purpose and audience. This includes leveraging all forms of new and evolving technology such as artificial intelligence (AI)."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.5.5" ;
    skos:prefLabel "Refine content"@en .

<http://ots.local/thesaurus/apqc/13_6_5_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6_5> ;
    skos:definition "Enhancing and adapting content to support new or different audiences, formats, channels, or contexts while preserving core meaning and intent of the original content. This includes leveraging all forms of new and evolving technology such as artificial intelligence (AI)."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.5.6" ;
    skos:prefLabel "Enhance and adapt content"@en .

<http://ots.local/thesaurus/apqc/13_6_5_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6_5> ;
    skos:definition "Applying branding elements and standards to content to ensure consistent identity, presentation, and alignment with organizational guidelines."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.5.7" ;
    skos:prefLabel "Perform content branding"@en .

<http://ots.local/thesaurus/apqc/13_6_5_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6_5> ;
    skos:definition "Performing technical edits to ensure content meets formatting, accessibility, usability, and technical quality requirements. This includes leveraging all forms of new and evolving technology such as artificial intelligence (AI)."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.5.8" ;
    skos:prefLabel "Execute technical edits on content"@en .

<http://ots.local/thesaurus/apqc/13_6_6_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6_6> ;
    skos:definition "Reviewing content to confirm accuracy, quality, compliance, and readiness prior to approval for distribution or use."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.6.1" ;
    skos:prefLabel "Assess and approve content"@en .

<http://ots.local/thesaurus/apqc/13_6_6_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6_6> ;
    skos:definition "Publishing approved content to designated locations or channels to make it available to intended users."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.6.2" ;
    skos:prefLabel "Publish approved content"@en .

<http://ots.local/thesaurus/apqc/13_6_6_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6_6> ;
    skos:definition "Storing approved content in designated repositories to support controlled access, retrieval, and lifecycle management."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.6.3" ;
    skos:prefLabel "Store approved content"@en .

<http://ots.local/thesaurus/apqc/13_6_7_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6_7> ;
    skos:definition "Evaluating content usage, effectiveness, and relevance to inform updates, improvements, or retirement decisions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.7.1" ;
    skos:prefLabel "Evaluate content"@en .

<http://ots.local/thesaurus/apqc/13_6_7_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6_7> ;
    skos:definition "Archiving content that is no longer actively used but must be retained to meet governance, legal, or historical requirements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.7.2" ;
    skos:prefLabel "Archive content"@en .

<http://ots.local/thesaurus/apqc/13_6_7_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_6_7> ;
    skos:definition "Deleting content that has reached the end of its retention period and is no longer required, in accordance with defined policies and controls."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.6.7.3" ;
    skos:prefLabel "Delete content"@en .

<http://ots.local/thesaurus/apqc/13_7_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_7_1> ;
    skos:definition "Developing a model for organization's management systems. Develop a high-level measurement system to track performance across the enterprise or in specific functions or business units. Determine which processes to measure, which measures to use, how often to measure, and measurement targets. Review strategic decisions about how to best measure an organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.7.1.1" ;
    skos:prefLabel "Define enterprise measurement models"@en .

<http://ots.local/thesaurus/apqc/13_7_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_7_1> ;
    skos:definition "Reviewing, evaluating, and updating enterprise measurement models. Align measurement models to current and future goals and performance targets, and make adjustments to support visibility and reporting needs across the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.7.1.2" ;
    skos:prefLabel "Maintain enterprise measurement models"@en .

<http://ots.local/thesaurus/apqc/13_7_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_7_2> ;
    skos:definition "Measuring, researching, and recording the performance of people, processes, mechanisms, or other areas of the business that the organization wants to benchmark or track."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.7.2.1" ;
    skos:prefLabel "Conduct performance assessments"@en .

<http://ots.local/thesaurus/apqc/13_7_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_7_2> ;
    skos:definition "Improving an organization's ability to compare its performance internally or externally, and maintaining benchmarking relationships with other organizations. Train staff in benchmarking. Develop technological solutions or other materials to aid benchmarking efforts. Consult with external entities to gain knowledge or tools to help benchmark."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.7.2.2" ;
    skos:prefLabel "Develop benchmarking capabilities"@en .

<http://ots.local/thesaurus/apqc/13_7_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_7_2> ;
    skos:definition "Benchmarking internal processes and against external competitors."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.7.2.3" ;
    skos:prefLabel "Conduct internal and external benchmarking"@en .

<http://ots.local/thesaurus/apqc/13_7_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_7_2> ;
    skos:definition "Examining performance against benchmarked organizations or entities. Determine how much performance needs to change to meet expectations. Reach strategic goals."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.7.2.4" ;
    skos:prefLabel "Conduct gap analysis"@en .

<http://ots.local/thesaurus/apqc/13_7_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_7_2> ;
    skos:definition "Establishing a need for changing the performance of the organization. Make use of the gap analysis results in order to define the need for change."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.7.2.5" ;
    skos:prefLabel "Establish need for change"@en .

<http://ots.local/thesaurus/apqc/13_7_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_7_3> ;
    skos:definition "Designing key measures that analyze and interpret how effectively the business is achieving its objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.7.3.1" ;
    skos:prefLabel "Establish performance indicators (measures)"@en .

<http://ots.local/thesaurus/apqc/13_7_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_7_3> ;
    skos:definition "Deciding on the appropriate amount of supervisions that are needed to effectively assess the performance of business plans."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.7.3.2" ;
    skos:prefLabel "Establish monitoring frequency"@en .

<http://ots.local/thesaurus/apqc/13_7_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_7_3> ;
    skos:definition "Consolidating acquired metrics and trends. Provide data that can be benchmarked against historical data."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.7.3.3" ;
    skos:prefLabel "Collect performance data"@en .

<http://ots.local/thesaurus/apqc/13_7_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_7_3> ;
    skos:definition "Measuring the performance of process planning. Quantify the performance, record results of the performance tests, and report them to the appropriate authority."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.7.3.4" ;
    skos:prefLabel "Calculate performance measures"@en .

<http://ots.local/thesaurus/apqc/13_7_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_7_3> ;
    skos:definition "Recognizing the trends in performance. Carefully and strategically assess the results in order to effectively spot the trends."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.7.3.5" ;
    skos:prefLabel "Identify performance trends"@en .

<http://ots.local/thesaurus/apqc/13_7_3_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_7_3> ;
    skos:definition "Evaluating the gaps between achieved and benchmarked performance. Analyze how performance differs from the optimal or expected performance."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.7.3.6" ;
    skos:prefLabel "Analyze performance"@en .

<http://ots.local/thesaurus/apqc/13_7_3_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_7_3> ;
    skos:definition "Creating reports that systematically record and represent the performance planning. Construct a detailed report specifying the performance, and include indicators such as the performance gaps, performance trends, and analysis."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.7.3.7" ;
    skos:prefLabel "Prepare performance reports"@en .

<http://ots.local/thesaurus/apqc/13_7_3_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_7_3> ;
    skos:definition "Using performance indicators to report, analyze, and create a detailed performance improvement plan to bridge the performance gaps."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.7.3.8" ;
    skos:prefLabel "Develop performance improvement plan"@en .

<http://ots.local/thesaurus/apqc/13_8_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_8> ;
    skos:definition "Gathering information from stakeholders prior to conducting analytics."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.8.1" ;
    skos:prefLabel "Identify needs from stakeholders"@en .

<http://ots.local/thesaurus/apqc/13_8_10> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_8> ;
    skos:definition "Summarizing and documenting the results of data analysis. Create graphs and visualizations to illustrate numerical findings to make them more accessible to readers."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.8.10" ;
    skos:prefLabel "Report on analysis"@en .

<http://ots.local/thesaurus/apqc/13_8_11> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_8> ;
    skos:definition "Determining the steps that need to be taken to correct the shortcomings."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.8.11" ;
    skos:prefLabel "Identify remedial actions"@en .

<http://ots.local/thesaurus/apqc/13_8_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_8> ;
    skos:definition "Determining the size and scale of the project based upon the collected information and analytics."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.8.2" ;
    skos:prefLabel "Scope analytics project"@en .

<http://ots.local/thesaurus/apqc/13_8_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_8> ;
    skos:definition "Creating theories that explain empirical data. Use the hypotheses to guide feature selection in the process of data collection."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.8.3" ;
    skos:prefLabel "Develop and manage hypotheses"@en .

<http://ots.local/thesaurus/apqc/13_8_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_8> ;
    skos:definition "Gathering and harvesting structured and unstructured data from disparate sources. Clean and pre-process data. Remove duplicates. Convert to a uniform format to make records comparable."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.8.4" ;
    skos:prefLabel "Collect data"@en .

<http://ots.local/thesaurus/apqc/13_8_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_8> ;
    skos:definition "Creation and validation of data in order to initiate the process of analysis."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.8.5" ;
    skos:prefLabel "Prepare data"@en .

<http://ots.local/thesaurus/apqc/13_8_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_8> ;
    skos:definition "Conducting data analysis. Choose statistical algorithms that best reveal patterns and trends in the data. Compare with hypotheses and time series forecasts. Determine error rates and significant outliers."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.8.6" ;
    skos:prefLabel "Analyze data"@en .

<http://ots.local/thesaurus/apqc/13_8_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_8> ;
    skos:definition "Creation of conceptual and physical data models as an outline for data structure and storage."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.8.7" ;
    skos:prefLabel "Create data models"@en .

<http://ots.local/thesaurus/apqc/13_8_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_8> ;
    skos:definition "Confirm data models represent the hypothesis supporting the original research question"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.8.8" ;
    skos:prefLabel "Review data models with stakeholders"@en .

<http://ots.local/thesaurus/apqc/13_8_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_8> ;
    skos:definition "Make required changes to data model based upon review with stakeholders."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.8.9" ;
    skos:prefLabel "Refine data models"@en .

<http://ots.local/thesaurus/apqc/13_9_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_9_1> ;
    skos:definition "Evaluating the impact of offerings and the auxiliary operations required to process them on the immediate ecosystem and the environment at large. Study the lifecycle of the products/services offered by the organization. Estimate any affect on the environment through metrics such as a calculation of carbon footprint."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.9.1.1" ;
    skos:prefLabel "Evaluate environmental impact of products, services, and operations"@en .

<http://ots.local/thesaurus/apqc/13_9_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_9_1> ;
    skos:definition "Conducting an inspection to verify that the organization adequately complies with the environmental, health, and safety standards. Audit procedures and records regarding responsibility for the environment, health, and safety."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.9.1.2" ;
    skos:prefLabel "Conduct health and safety and environmental audits"@en .

<http://ots.local/thesaurus/apqc/13_9_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_9_2> ;
    skos:definition "Determining any protocols or standards to comply with, set by regulatory agencies or the organization's stakeholders. Closely examine all standards and matters of compliance relating to the environment, health, and safety."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.9.2.1" ;
    skos:prefLabel "Identify regulatory and stakeholder requirements"@en .

<http://ots.local/thesaurus/apqc/13_9_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_9_2> ;
    skos:definition "Evaluating any risks and opportunities that might affect the environmental, health, and safety of products/services. Leverage techniques such as cost-benefit analysis, trend extrapolation, systems analysis, social surveys, historical surveys, historical analogy, Delphi, conferences, workshops, briefings, hearings, advisory committees, moot courts, artistic judgment, on-site field investigation, scaling techniques, and scenario creation."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.9.2.2" ;
    skos:prefLabel "Assess future risks and opportunities"@en .

<http://ots.local/thesaurus/apqc/13_9_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_9_2> ;
    skos:definition "Creating a plan for managing the environmental, health, and safety impact of products/services. Establish minimum requirements for the organization regarding the environment at large and the health and safety of employees. Develop policies, written procedures, and supporting tools to dictate how the organization will meet policy requirements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.9.2.3" ;
    skos:prefLabel "Create EHS policy"@en .

<http://ots.local/thesaurus/apqc/13_9_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_9_2> ;
    skos:definition "Recording and managing all events and activities associated with complying with environmental, health and safety standards. Create event calendars. Assign funds. Educate employees. Conduct events."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.9.2.4" ;
    skos:prefLabel "Record and manage EHS events"@en .

<http://ots.local/thesaurus/apqc/13_9_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_9_3> ;
    skos:definition "Administering the costs and benefits of EHS management program. Evaluate program costs to ensure that the benefits of the program always outweigh its costs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.9.3.1" ;
    skos:prefLabel "Manage EHS costs and benefits"@en .

<http://ots.local/thesaurus/apqc/13_9_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_9_3> ;
    skos:definition "Using performance techniques and indicators. Utilize number of audits or inspections performed, safety committee meetings, the number and types of findings and observations, timely preventive maintenance tasks performed, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.9.3.2" ;
    skos:prefLabel "Measure and report EHS performance"@en .

<http://ots.local/thesaurus/apqc/13_9_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_9_3> ;
    skos:definition "Implementing a program for organizing, coordinating, and directing available resources to respond to the event. Conduct a risk assessment to identify potential emergency scenarios in order to create a program that ensures that resources are on hand--or quickly available--in case of emergencies."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.9.3.3" ;
    skos:prefLabel "Implement emergency response program"@en .

<http://ots.local/thesaurus/apqc/13_9_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_9_3> ;
    skos:definition "Implementing a program that reduces or eliminates the creation of pollutants through increased efficiency in the use of raw materials, energy, water, or other resources. Implement a program to inspect facilities that store, manufacture, or use hazardous, toxic, or polluting materials."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.9.3.4" ;
    skos:prefLabel "Implement pollution prevention program"@en .

<http://ots.local/thesaurus/apqc/13_9_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_9_3> ;
    skos:definition "Conducting programs such as on-the-job training sessions, group training workshops, and online training."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.9.3.5" ;
    skos:prefLabel "Train and educate functional employees"@en .

<http://ots.local/thesaurus/apqc/13_9_3_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/13_9_3> ;
    skos:definition "Supporting employees in light of the organization's environmental, health, and safety policies and standards. Provide medical insurance, maternity leave, environmental education, training over safety, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "13.9.3.6" ;
    skos:prefLabel "Provide EHS support"@en .

<http://ots.local/thesaurus/apqc/1_1_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_1_1> ;
    skos:definition "Identifying your competitors, their service and/or product. Evaluating competitors strategies to determine their strengths and weaknesses relative to those of your own product or service."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1.1.1" ;
    skos:prefLabel "Identify competitors"@en .

<http://ots.local/thesaurus/apqc/1_1_1_10> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_1_1> ;
    skos:definition "Establishing measures and procedures for identifying various intellectual property threats and concerns."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1.1.10" ;
    skos:prefLabel "Evaluate intellectual property"@en .

<http://ots.local/thesaurus/apqc/1_1_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_1_1> ;
    skos:definition "Assessing the competitive forces in the marketplace that could potentially affect the organization. Analyze various aspects of business competition including competing firms. Aggregate competitive intelligence, create benchmarks to juxtapose processes and performance metrics, and inject crucial information about the competition into management models to synthesize insights."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1.1.2" ;
    skos:prefLabel "Analyze and evaluate competition"@en .

<http://ots.local/thesaurus/apqc/1_1_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_1_1> ;
    skos:definition "Examining if there are other existing products or services in the marketplace, and building the business case to make a go/no go decision based upon substitutions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1.1.3" ;
    skos:prefLabel "Identify potential product or service alternatives"@en .

<http://ots.local/thesaurus/apqc/1_1_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_1_1> ;
    skos:definition "Determining large-scale macroeconomic shifts and trends, with medium to long-term relevance for the organization. Vet the immediate and the larger economic ecosystem to identify broad-based movements that affect the organization. In the immediate vicinity, for example, examine the stock price of key vendors/suppliers in the organizational value-chain. In the larger economic ecosystem, analyze according to geographical distribution where factors such as interest rates, taxation structures, oil prices, and unemployment rates are explored."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1.1.4" ;
    skos:prefLabel "Identify economic trends"@en .

<http://ots.local/thesaurus/apqc/1_1_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_1_1> ;
    skos:definition "Identifying areas of concern pertaining to public policy and regulation, established by sovereign or multinational authorities. Examine various regions and geopolitical formations to identify those political and regulatory issues-present or developing-that can potentially affect the organization. Plan for an iterative process, partitioned across regional and geopolitical entities that have a direct bearing on the organization's activities. Assess changes in environmental compliance, product standards, trade barriers, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1.1.5" ;
    skos:prefLabel "Identify political and regulatory factors"@en .

<http://ots.local/thesaurus/apqc/1_1_1_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_1_1> ;
    skos:definition "Identifying changes in ecological ecosystems that can be directly or indirectly detrimental to the organization. Analyze ecological factors within the immediate ecosystem for near to middle-term impact. Analyze the ecology, at large, to get a sense of long-term shifts and concerns. Gather analyses from research publications. Speak to subject matter experts. Engage with advocacy groups, lawyers, journalists, and the active populations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1.1.6" ;
    skos:prefLabel "Identify environmental factors"@en .

<http://ots.local/thesaurus/apqc/1_1_1_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_1_1> ;
    skos:definition "Distinguishing changes in societal makeup, as well as the cultural composite. Isolate shifts in the societal composition and distribution, as well as the value systems and attributes that bind the organization together. Analyze well-regarded publications--and gather the perspective of public intellectuals and opinion leaders--on relevant issues."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1.1.7" ;
    skos:prefLabel "Identify social and cultural changes"@en .

<http://ots.local/thesaurus/apqc/1_1_1_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_1_1> ;
    skos:definition "Assessing developments in technologies presently being used by the business, new technologies that have a potential for the business, and any disruptive innovations. This is inclusive of all forms of new and evolving technology such as artificial intelligence (AI).  Conduct a survey of advancement in technologies that are already deployed with inputs from the personnel closely working with them, tracking utility and feasibility for deployment. Arrange for mid- to senior-level management personnel who explore contingent uses to assess new and disruptive technologies. Follow up with desk research, involving physical scoping and viability assessment."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1.1.8" ;
    skos:prefLabel "Assess new technologies"@en .

<http://ots.local/thesaurus/apqc/1_1_1_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_1_1> ;
    skos:definition "Analyzing statistical data relating to the size, distribution, and composition of relevant populations, as well as their characteristics. Perform quantitative analysis over raw data-sets gathered from well-founded sources such as government census or large, private databases. Consider employing primary research in collecting required statistics. Use comprehensive studies (reports, briefs, and articles) to assist with the analysis, in place of raw data."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1.1.9" ;
    skos:prefLabel "Analyze demographics"@en .

<http://ots.local/thesaurus/apqc/1_1_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_1_2> ;
    skos:definition "Investigating key market features and customer characteristics, using qualitative and quantitative measures to capture relevant aspects. Distill key ingredients that allow the organization to Capture customer needs and wants [19946], and Assess customer needs and wants [19947]. Conduct standardized appraisals by defining selection parameters and setting quotas."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1.2.1" ;
    skos:prefLabel "Conduct qualitative/quantitative research and assessments"@en .

<http://ots.local/thesaurus/apqc/1_1_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_1_2> ;
    skos:definition "Identifying and collecting customers' wants and needs of a product and/or services from a marketing perspective. Identify which consumer needs are important and whether needs are being met by current products/services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1.2.2" ;
    skos:prefLabel "Capture customer needs and wants"@en .

<http://ots.local/thesaurus/apqc/1_1_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_1_2> ;
    skos:definition "Creating customer profiles to get a picture of customers and their needs. Identify particular groups of people/organizations that benefit from your product/services and then selling to them."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1.2.3" ;
    skos:prefLabel "Assess customer needs and wants"@en .

<http://ots.local/thesaurus/apqc/1_1_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_1_3> ;
    skos:definition "Identifying and examining key attributes that differentiate the organization in the market and those that underscore the core of its operations. Consider how the organization functions. Reflect over tangible and intangible aspects in order to spot critical correlations and the interplay between these attributes. Have senior executives conduct the analysis, with input from management and operational personnel."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1.3.1" ;
    skos:prefLabel "Analyze organizational characteristics"@en .

<http://ots.local/thesaurus/apqc/1_1_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_1_3> ;
    skos:definition "Identify key elements of operations and measure effectiveness of these elements within internal operations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1.3.2" ;
    skos:prefLabel "Analyze internal operations"@en .

<http://ots.local/thesaurus/apqc/1_1_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_1_3> ;
    skos:definition "Establishing baselines that provide standards for assessing performance levels and allow for a relational benchmarking of current processes. Undertake a survey of archival performance records, conducted in conjunction by the management and the operations personnel. Take into account the organization's internal objectives, particularly for process improvement and enhancement. Understand industry best practices."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1.3.3" ;
    skos:prefLabel "Create baselines for current processes"@en .

<http://ots.local/thesaurus/apqc/1_1_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_1_3> ;
    skos:definition "Analyzing the capabilities of technology and process automation systems deployed within the organization in order to direct future associated processes. This is inclusive of all forms of new and evolving technology such as artificial intelligence (AI). Conduct a broad-based survey to examine various aspects associated with such systems and technologies, with the objective of identifying key facets that are of interest. Investigate the intended purpose, purpose served, utility, longevity, remaining service-life, repair or service requirements, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1.3.4" ;
    skos:prefLabel "Analyze systems and technology"@en .

<http://ots.local/thesaurus/apqc/1_1_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_1_3> ;
    skos:definition "Appraising the financial state of the organization so that management can create resource allocation strategies. Scrutinize the organization's financials--including balance sheets, statements of income, cash-flows, equity holdings, and liquidity--with the objective of understanding the organization's financial health and capacities. (This analysis directly feeds into Conduct organizational restructuring opportunities [16792] and Define a business concept and long-term vision [17040].)"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1.3.5" ;
    skos:prefLabel "Analyze financial health"@en .

<http://ots.local/thesaurus/apqc/1_1_3_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_1_3> ;
    skos:definition "Determining a strategically significant aggregate of competence and capacities that differentiates the organization in the market. Identify distinguishing attributes including unique skills and resources and its brand and services in the marketplace. Have senior executives and management personnel assess competencies in order to further develop these capabilities into distinct commercial value propositions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1.3.6" ;
    skos:prefLabel "Identify core competencies"@en .

<http://ots.local/thesaurus/apqc/1_1_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_1_4> ;
    skos:definition "Developing goals to define organizations vision. Define and document ideas, direction, and activities which enable the organization to reach these goals."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1.4.1" ;
    skos:prefLabel "Define the strategic vision"@en .

<http://ots.local/thesaurus/apqc/1_1_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_1_4> ;
    skos:definition "Orienting those entities, associated with the organization that have a direct bearing on its operations and output, in a way that advances its strategic vision. Map all stakeholders in strategic configurations, within the architectural layout of the marketplace, and position the organization relative to them. (This exercise is undertaken by senior strategy personnel, drawing upon the process Define a business concept and long-term vision [17040].)"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1.4.2" ;
    skos:prefLabel "Align stakeholders around strategic vision"@en .

<http://ots.local/thesaurus/apqc/1_1_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_1_4> ;
    skos:definition "Developing and executing communication strategies to convey an alignment plan of all organizational stakeholders, which helps the organization realize its vision. Create custom communication strategies and delivery channels with the objective of orienting stakeholders according to the configuration maps created in the process Align stakeholders around a strategic vision [10035]. Have senior strategy personnel closely collaborate with the communications/marketing team."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1.4.3" ;
    skos:prefLabel "Communicate strategic vision to stakeholders"@en .

<http://ots.local/thesaurus/apqc/1_1_5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_1_5> ;
    skos:definition "Identifying opportunities for restructuring the organization, through an analysis of internal viability and external contingency. Conduct a broad-based survey of the market landscape, taking the large-scale trends and movements into account, to determine the necessity and possibility of restructuring the organization. Review the organization's internal capacities, the readiness of its process frameworks, the robustness of its financials, the capableness of its systems, the resourcefulness of its personnel, etc. for assimilating an extensive overhaul."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1.5.1" ;
    skos:prefLabel "Identify restructuring opportunities"@en .

<http://ots.local/thesaurus/apqc/1_1_5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_1_5> ;
    skos:definition "Auditing the status quo of the probabilities, before formalizing any restructuring of the organization with another entity. Systematically investigate all entities discerned to be of interest in Identify restructuring opportunities [16793], to verify all tangible and substantial facts. Consider engaging specialist professional services including legal, accounting, and consulting help."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1.5.2" ;
    skos:prefLabel "Perform due-diligence"@en .

<http://ots.local/thesaurus/apqc/1_1_5_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_1_5_3> ;
    skos:definition "Appraising entities identified as being suitable for acquisition, taking into account the restructuring opportunities in the internal and external context. Verify the appropriateness and viability of the short-listed options. Ensure these entities pertain to the state-of-affairs in the market, as well as fit with the resources and capabilities of the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1.5.3.1" ;
    skos:prefLabel "Evaluate acquisition options"@en .

<http://ots.local/thesaurus/apqc/1_1_5_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_1_5_3> ;
    skos:definition "Appraising entities identified as being suitable for a merger, taking stock of the restructuring opportunities within the firm and the market. Verify the appropriateness and viability of such options. Assess these entities to ensure their pertinence to the contextual state-of-affairs in the market, as well as a fit with the resources and capabilities of the organization itself. (This process can be carried out, in its entirety, by qualified in-house personnel or may be designated to specialist professional services providers.)"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1.5.3.2" ;
    skos:prefLabel "Evaluate merger options"@en .

<http://ots.local/thesaurus/apqc/1_1_5_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_1_5_3> ;
    skos:definition "Evaluating departments and subsidiaries within the organization, and/or previously merged entities, to assess the appropriateness of a de-merger, taking account of the fit between these entities as well as any relevant externalities. Examine the pertinence and soundness of a formalized dissociation."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1.5.3.3" ;
    skos:prefLabel "Evaluate de-merger options"@en .

<http://ots.local/thesaurus/apqc/1_1_5_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_1_5_3> ;
    skos:definition "Evaluating departments and/or subsidiaries within the organization to assess the appropriateness of a divestment, taking account of all market externalities. Examine any internal entities that have been identified to be suitable for dismemberment from the organization. Ensure the pertinence and soundness of such a move."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.1.5.3.4" ;
    skos:prefLabel "Evaluate divesture options"@en .

<http://ots.local/thesaurus/apqc/1_2_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_1> ;
    skos:definition "Defining the status quo relating to the de facto core of what the business is. Reflect over the fundamental essence of what the business accomplishes and the manner in which it operates. Look beyond the obvious solution capabilities to delineate capacities that form the basis of the business engine. Involve senior executives and management personnel and possibly professional services providers."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.1.1" ;
    skos:prefLabel "Define current business"@en .

<http://ots.local/thesaurus/apqc/1_2_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_1> ;
    skos:definition "Outlining actionable objectives that effectively set a course to fulfill the organization's vision. In this fundamental activity, articulate certain goals or targets in broad but practicable terms to reach long-term objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.1.2" ;
    skos:prefLabel "Formulate mission"@en .

<http://ots.local/thesaurus/apqc/1_2_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_1> ;
    skos:definition "Developing and executing a communication strategy to convey the mission statement. Create a universal communication strategy and appropriate delivery channels, with the objective of leveraging the latter to execute the former. Convey the inherent message of the mission to all stakeholders, including employees, customers, and the public. Ensure collaboration between senior strategy personnel and the communications/marketing team."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.1.3" ;
    skos:prefLabel "Communicate mission"@en .

<http://ots.local/thesaurus/apqc/1_2_2_10> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_2> ;
    skos:definition "Evaluating options for shared services and support functions. This should include structure, scale, adaptability to change, and alternative delivery models to balance cost, performance, and operational efficiencies."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.2.10" ;
    skos:prefLabel "Evaluate shared services options"@en .

<http://ots.local/thesaurus/apqc/1_2_2_11> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_2> ;
    skos:definition "Evaluating options to enhance and optimize processes and functional areas. Understand alternatives to strengthen business capabilities, enhance process efficiencies, and advance performance standards."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.2.11" ;
    skos:prefLabel "Evaluate lean/continuous improvement options"@en .

<http://ots.local/thesaurus/apqc/1_2_2_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_2_1> ;
    skos:definition "Supporting the design, manufacture and distribution of product and services through the extended enterprise model.  This is concerned with the strategic decisions on make vs buy, in house or out sourced.  Senior Executives map out how they want to run their business.  Make strategic choices as to whether to buy in components / sub-assemblies, run their own distribution fleet or contract out, own their dealerships or franchise out, etc.  Strategize with partnerships. Collaborate design consideration at strategy level for automotive and procurement act within the Target Operating Model set at strategy level."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.2.1.1" ;
    skos:prefLabel "Select partnerships and relationships to support the extended enterprise"@en .

<http://ots.local/thesaurus/apqc/1_2_2_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_2_2> ;
    skos:definition "Determine impacts of elements such as staffing, skills, training, new markets, technology, or policies within operating model which needs change."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.2.2.1" ;
    skos:prefLabel "Identify implications for key operating model business elements that require change"@en .

<http://ots.local/thesaurus/apqc/1_2_2_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_2_2> ;
    skos:definition "Determining key factors for technology ROI, benefits, architecture, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.2.2.2" ;
    skos:prefLabel "Identify implications for key technology aspects"@en .

<http://ots.local/thesaurus/apqc/1_2_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_2> ;
    skos:definition "Evaluating future business to business opportunities against past and current approaches and performance. Gather insights into what competitors and other similar organizations are doing and the needs, goals, and expectations of stakeholders and partners to understand potential future impact."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.2.3" ;
    skos:prefLabel "Evaluate B2B options"@en .

<http://ots.local/thesaurus/apqc/1_2_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_2> ;
    skos:definition "Evaluating future business to customer opportunities against past and current approaches and performance. Gather insights into what competitors and other similar organizations are doing and the needs, goals, and expectations of customers and partners to understand potential future impact."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.2.4" ;
    skos:prefLabel "Evaluate B2C options"@en .

<http://ots.local/thesaurus/apqc/1_2_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_2> ;
    skos:definition "Evaluating partnership and alliance opportunities to deliver products/services. Understand existing product and market models in use across the markets you serve, evolving trends, and the cost/benefit of potential new/updated partnership/alliance options."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.2.5" ;
    skos:prefLabel "Evaluate partner/alliance options"@en .

<http://ots.local/thesaurus/apqc/1_2_2_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_2> ;
    skos:definition "Evaluating intellectual property acquisition options available to scale, modernize, and/or extend product/service reach. Understand the cost, risk, timing and lifecycle value of candidate acquisitions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.2.6" ;
    skos:prefLabel "Evaluate IP acquisition options"@en .

<http://ots.local/thesaurus/apqc/1_2_2_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_2> ;
    skos:definition "Evaluating innovation options to advance technology, products/services, and/or operational performance."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.2.7" ;
    skos:prefLabel "Evaluate innovation options"@en .

<http://ots.local/thesaurus/apqc/1_2_2_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_2> ;
    skos:definition "Evaluating sustainability requirements, stakeholder expectations, and value proposition for options. Understand the potential activities and changes across environmental, social, and governance, the effort required, cost to implement, and benefits gained. The analysis should consider sustainable product/service lifecycles, operations, infrastructure, performance, and workforce."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.2.8" ;
    skos:prefLabel "Evaluate sustainability options"@en .

<http://ots.local/thesaurus/apqc/1_2_2_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_2> ;
    skos:definition "Evaluating options for global support services and functions. This should include structure, scale, adaptability to change, and alternative delivery models to balance cost, performance, and customer value."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.2.9" ;
    skos:prefLabel "Evaluate global support options"@en .

<http://ots.local/thesaurus/apqc/1_2_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_3> ;
    skos:definition "Defining direction and plan objectives for external relationships and partnering with other companies to deliver product/services. Focus on creating a vision and strategic objectives and culminate in creating measures for the strategic alliance or partnership."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.3.1" ;
    skos:prefLabel "Develop partner/alliance strategy"@en .

<http://ots.local/thesaurus/apqc/1_2_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_3> ;
    skos:definition "Formulating strategic options that create opportunities for the sustenance and prosperity of the business in the long run. Go beyond business longevity to consider alternate strategies that allow the organizations preservation of vitality over time. Earmark resources and target processes, the former of which are dedicated to the absorption of sustainable practices in the latter."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.3.2" ;
    skos:prefLabel "Develop sustainability strategy"@en .

<http://ots.local/thesaurus/apqc/1_2_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_3> ;
    skos:definition "Defining a strategy for corporate development. Include providing a framework for evaluating merger and acquisition candidates; and planning for a value creation through merging/demerging with a company, acquiring a company, or exiting from an already merged/acquired company."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.3.3" ;
    skos:prefLabel "Develop merger/demerger/acquisition/exit strategy"@en .

<http://ots.local/thesaurus/apqc/1_2_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_3> ;
    skos:definition "Developing a plan and vision to encourage advancements in technology or product/services. Create a roadmap for changing or innovating the business model to make business operations more competitive. Set up new R&D services for changing or bringing new value propositions, services, production processes, and invention of technology not previously used by competitors etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.3.4" ;
    skos:prefLabel "Develop innovation strategy"@en .

<http://ots.local/thesaurus/apqc/1_2_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_3> ;
    skos:definition "Developing a plan to deploy support services and support functions throughout the organization globally. Arrange the organizations functional support areas to create efficiencies of scale in the delivery of support services, globally."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.3.5" ;
    skos:prefLabel "Develop global support strategy"@en .

<http://ots.local/thesaurus/apqc/1_2_3_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_3> ;
    skos:definition "Charting a plan to leverage internal services and support functions throughout the organization. Delineate a framework of parameters and criteria to selectively filter service areas for inclusion among the organizations common resources. Arrange the organizations functional areas to create efficiencies of scale in the delivery of internal services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.3.6" ;
    skos:prefLabel "Develop shared services strategy"@en .

<http://ots.local/thesaurus/apqc/1_2_3_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_3> ;
    skos:definition "Developing strategies for the optimization of processes and the improvement of functional areas in order to improve the bottom line. Create a road map of decision choices that would allow the organization to continuously enhance process efficiencies and advance performance standards."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.3.7" ;
    skos:prefLabel "Develop Lean/continuous improvement strategy"@en .

<http://ots.local/thesaurus/apqc/1_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2> ;
    skos:definition "Aligning the approach and method of individual units, departments, systems, and operations within the organization, in accordance with the larger strategic course adopted. Employ the organization's strategic path to guide the functions, divisions, and operations. Calibrate the plan and method of each functional area, as well as the processes therein, to Select the long-term business strategy [10039]."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.4" ;
    skos:prefLabel "Coordinate and align cross-functional and process strategies"@en .

<http://ots.local/thesaurus/apqc/1_2_5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_5> ;
    skos:definition "Evaluating the structural makeup of the organization, including pertinent features of and associated synergies among constituent elements. Examine the organization's architectural framework, paying close attention to the individual elements, the relations among them, and the conjoint and co-acting forces therein. Analyze functions and processes, as well as work-related positions. Scrutinize various relevant characteristics associated with each of them, depending upon the scale, scope, and type of organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.5.1" ;
    skos:prefLabel "Evaluate breadth and depth of organizational structure"@en .

<http://ots.local/thesaurus/apqc/1_2_5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_5> ;
    skos:definition "Appraising job-specific roles within the organizational chart and their hierarchical architecture. Analyze a map of work-related roles within the organizational structure. Examine the value added by the positions associated with jobs to be performed and how they stack up within the organization's operations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.5.2" ;
    skos:prefLabel "Perform job-specific roles mapping and value-added analyses"@en .

<http://ots.local/thesaurus/apqc/1_2_5_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_5> ;
    skos:definition "Examining the constituent exercises and undertakings within a work-related position for the purpose of effective delegation. Deconstruct job-specific roles into activities and visualize the relations among them, with the objective of assigning responsibilities to the appropriate personnel."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.5.3" ;
    skos:prefLabel "Develop role activity diagrams to assess hand-off activity"@en .

<http://ots.local/thesaurus/apqc/1_2_5_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_5> ;
    skos:definition "Organizing workshop sessions to adopt organizational redesign. Communicate the organizational structure and mapping of responsibilities against job roles in order to facilitate an effective understanding among personnel. Use a collaborative process that may include participative workshop sessions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.5.4" ;
    skos:prefLabel "Perform organization redesign workshops"@en .

<http://ots.local/thesaurus/apqc/1_2_5_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_5> ;
    skos:definition "Fleshing out the connections and dependencies among the various units of the organization. Delineate the relationship among business units or process frameworks within the organization, in terms of activities, synergies, and shared resources and responsibilities. Formalize relationships among business units so that any mutual coherence is clearly understood and can be attended to."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.5.5" ;
    skos:prefLabel "Design the relationships between organizational units"@en .

<http://ots.local/thesaurus/apqc/1_2_5_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_5> ;
    skos:definition "Creating an understanding of the fit between job roles and organizational processes in order to properly place personnel. Deconstruct key processes into constituent activities, and examine job-related roles. Take cues from Develop role activity diagrams to assess hand-off activity [10051]. Map appropriate positions against these important processes, which in turn expedite the deployment of staff members."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.5.6" ;
    skos:prefLabel "Develop role analysis and activity diagrams for key processes"@en .

<http://ots.local/thesaurus/apqc/1_2_5_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_5> ;
    skos:definition "Probing the repercussions of all practicable organizational design options. Analyze the significance and impact of workable organizational structure options. Closely examine the long-term impact of these frameworks over the functioning of the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.5.7" ;
    skos:prefLabel "Assess organizational implication of feasible alternatives"@en .

<http://ots.local/thesaurus/apqc/1_2_5_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_5> ;
    skos:definition "Embracing and ratifying a new organizational structure. (Assume the new framework to be the best fit through Assess the organizational implications of feasible alternatives [10055].)"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.5.8" ;
    skos:prefLabel "Migrate to new organization"@en .

<http://ots.local/thesaurus/apqc/1_2_6_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_6> ;
    skos:definition "Creating and developing strategic objectives that establishes a process to outline expected outcomes and guide employees' efforts."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.6.1" ;
    skos:prefLabel "Identify organizational objectives"@en .

<http://ots.local/thesaurus/apqc/1_2_6_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_6> ;
    skos:definition "Establishing baselines that provide standards for assessing performance. Create metrics and KPI's for various functions/processes/activities based on organizational goals."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.6.2" ;
    skos:prefLabel "Establish baseline metrics"@en .

<http://ots.local/thesaurus/apqc/1_2_6_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_6> ;
    skos:definition "Defining methodology and frequency of assessment for measuring and monitoring performance of various functions/processes/activities against standard set goals."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.6.3" ;
    skos:prefLabel "Monitor performance against objective"@en .

<http://ots.local/thesaurus/apqc/1_2_7_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_7> ;
    skos:definition "Assessing the performance of a business unit against set organizational goals which are based on pre-defined metrics collected through various business unit operations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.7.1" ;
    skos:prefLabel "Analyze business unit strategies"@en .

<http://ots.local/thesaurus/apqc/1_2_7_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_7> ;
    skos:definition "Determining the resources and skills of each business unit based on knowledge and technical capacity. Enable business units to meet customer needs and grow in a competitive marketplace."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.7.2" ;
    skos:prefLabel "Identify core competency for each business unit"@en .

<http://ots.local/thesaurus/apqc/1_2_7_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_7> ;
    skos:definition "Evaluating existing business unit strategy based on the company's strategy and eliminate unwanted/unnecessary resources/elements and re-consider necessary resources to meet the overall company's strategy."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.7.3" ;
    skos:prefLabel "Refine business unit strategies in support of organizational strategy"@en .

<http://ots.local/thesaurus/apqc/1_2_8_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_8_1> ;
    skos:definition "Creating methods to gauge customer experiences, expectations, and suggestions. Review both liked and disliked areas of product/services to be delivered. Evaluate touchpoints based on the nature of product/service in the market e.g., billboards, web sites, direct mail, service calls, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.8.1.1" ;
    skos:prefLabel "Identify and review customer touchpoints"@en .

<http://ots.local/thesaurus/apqc/1_2_8_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_8_1> ;
    skos:definition "Evaluating customer experiences, expectations, and suggestions in both liked and disliked areas of the product or services. Analyze all modes of communication, human and physical interactions, or customers experience during the relationship lifecycle with your organization. Evaluate the gaps/further development/alterations to the existing product/service to attain better customer response."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.8.1.2" ;
    skos:prefLabel "Assess customer experience across touchpoints"@en .

<http://ots.local/thesaurus/apqc/1_2_8_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_8_1> ;
    skos:definition "Analyzing the core reason for the customer experience/feedback/response about the product/service to take considerable action for better customer experience."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.8.1.3" ;
    skos:prefLabel "Perform root cause analysis of problematic customer experiences"@en .

<http://ots.local/thesaurus/apqc/1_2_8_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_8_2> ;
    skos:definition "Identifying a set of characteristics that define the demographic and behavioral patterns of the customer. Further, use persona scoring to design your marketing strategies around personas, and measure and optimize your interactions with the contacts classified by a certain persona."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.8.2.1" ;
    skos:prefLabel "Define and manage personas"@en .

<http://ots.local/thesaurus/apqc/1_2_8_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_8_2> ;
    skos:definition "Creating a story of the customer's experience: from initial contact, through the process of engagement and into a long-term relationship. The goal is to teach organization about the customer."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.8.2.2" ;
    skos:prefLabel "Create customer journey maps"@en .

<http://ots.local/thesaurus/apqc/1_2_8_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_8_2> ;
    skos:definition "Defining parameters to show aggregated, consistent, and holistic representation of known data about customers. Define key parameters which enable the tracking of customers and communications across every channel."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.8.2.3" ;
    skos:prefLabel "Define single view of the customer for the organization"@en .

<http://ots.local/thesaurus/apqc/1_2_8_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_8_2> ;
    skos:definition "Establishing a direction and vision on how the organization behaves towards customers in a consistent, effective way. The key attributes for customer experience vision consists of emotional connection, commitments and expectations, compelling value proposition, and ease of understanding the organization's behavior."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.8.2.4" ;
    skos:prefLabel "Define a vision for the customer experience"@en .

<http://ots.local/thesaurus/apqc/1_2_8_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_8_2> ;
    skos:definition "Creating a process to validate the sales process and the assumptions that underpin the business model. Understand if the products/services have a repeatable, scalable business model around that product."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.8.2.5" ;
    skos:prefLabel "Validate with customers"@en .

<http://ots.local/thesaurus/apqc/1_2_8_2_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_8_2> ;
    skos:definition "Aligning and defining a relevant, differentiated, and credible value proposition for the brand. Align experience to ensure that the product and service quality is consistent with brand promise and business strategies."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.8.2.6" ;
    skos:prefLabel "Align experience with brand values and business strategies"@en .

<http://ots.local/thesaurus/apqc/1_2_8_2_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_8_2> ;
    skos:definition "Planning, development, and management of content-written or in other media. Getting the right content to the right user at the right time through strategic planning of content creation, delivery, and governance."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.8.2.7" ;
    skos:prefLabel "Develop content strategy"@en .

<http://ots.local/thesaurus/apqc/1_2_8_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_8_3> ;
    skos:definition "Determining the necessary skills and competencies required to efficiently collect customer experiences through the support structure."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.8.3.1" ;
    skos:prefLabel "Identify required capabilities"@en .

<http://ots.local/thesaurus/apqc/1_2_8_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_8_3> ;
    skos:definition "Identifying the affect of customer experience through customer experience support structure on other functions of customer services related to customer."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.8.3.2" ;
    skos:prefLabel "Identify impact on functional processes"@en .

<http://ots.local/thesaurus/apqc/1_2_8_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2_8> ;
    skos:definition "Defining a standard guideline to create and execute the capacities of registering customer experiences in a timely manner. Create a common understanding of what behaviors are required to implement the strategy. Define what talent/skills your organization needs to reach customer experience goals."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.8.4" ;
    skos:prefLabel "Develop customer experience roadmap to develop and implement defined capabilities"@en .

<http://ots.local/thesaurus/apqc/1_2_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_2> ;
    skos:definition "Conveying planned procedures and methods to both internal departments and external stakeholders like customers, suppliers, etc., in an effective manner based on organizational objective."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.2.9" ;
    skos:prefLabel "Communicate strategies internally and externally"@en .

<http://ots.local/thesaurus/apqc/1_3_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_3_1> ;
    skos:definition "Creating a statement of the organization's direction to guide decision making around the allocation of resources. Provide a focus on the organization's overarching goals to ensure coherent and considered action. Strategic objectives are ranked by their importance in achieving the strategic goals. All subsequent operational or tactical planning and resource allocation is based on strategic priorities"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.3.1.1" ;
    skos:prefLabel "Identify strategic priorities"@en .

<http://ots.local/thesaurus/apqc/1_3_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_3_1> ;
    skos:definition "Creating a statement of the organization's direction based on what is considered \"value\" to the customer or business."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.3.1.2" ;
    skos:prefLabel "Develop strategic initiatives based on business/customer value"@en .

<http://ots.local/thesaurus/apqc/1_3_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_3_1> ;
    skos:definition "Developing a process for stakeholder dialog that is integrated into the assessment of business strategies. Report on the evaluation of the business objectives, strategies, subject, or past events."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.3.1.3" ;
    skos:prefLabel "Review with stakeholders"@en .

<http://ots.local/thesaurus/apqc/1_3_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_3_2> ;
    skos:definition "Establishing a standard measure of value to determine the business worth for each of the Identify strategic priorities [19975]. List the effectiveness and utility for every important strategic element based on the benefit it adds to the business."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.3.2.1" ;
    skos:prefLabel "Determine business value for each strategic priority"@en .

<http://ots.local/thesaurus/apqc/1_3_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_3_2> ;
    skos:definition "Analyzing the value preposition; the value the customer gets from a product/services for each of your Identify strategic priorities [19975]. Customer value is the satisfaction a consumer feels after making a purchase for goods or services relative to what he/she must give up to receive them."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.3.2.2" ;
    skos:prefLabel "Determine the customer value for each strategic priority"@en .

<http://ots.local/thesaurus/apqc/1_3_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_3_3> ;
    skos:definition "Listing the most effective procedures in the order of most important to the least. Create measures or filter for determining which of many \"strategic initiatives\" is most important to the least important."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.3.3.1" ;
    skos:prefLabel "Prioritize strategic initiatives"@en .

<http://ots.local/thesaurus/apqc/1_3_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_3_3> ;
    skos:definition "Establishing procedures for communications within the organization which creates the road map for successful understanding of strategic initiatives for both business units and stakeholders (internal and external)."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.3.3.2" ;
    skos:prefLabel "Communicate strategic initiatives to business units and stakeholders"@en .

<http://ots.local/thesaurus/apqc/1_3_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_3_4> ;
    skos:definition "Determining key indicators or factors responsible for driving business value. Key business value drivers comprise of operational, financial, and sustainability drivers."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.3.4.1" ;
    skos:prefLabel "Identify business value drivers"@en .

<http://ots.local/thesaurus/apqc/1_3_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_3_4> ;
    skos:definition "Establishing baseline measures that provide standards for assessing performance of Identify business value drivers [19982]."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.3.4.2" ;
    skos:prefLabel "Establish baselines for business value drivers"@en .

<http://ots.local/thesaurus/apqc/1_3_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_3_4> ;
    skos:definition "Overseeing the progress of activities to ensure they are on-course and on-schedule in meeting the objectives and performance targets against Establish baselines for business value drivers [19983]."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.3.4.3" ;
    skos:prefLabel "Monitor performance against baselines"@en .

<http://ots.local/thesaurus/apqc/1_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_3> ;
    skos:definition "Successfully implement strategic initiatives. Execution of strategy is also defined as the process of implementing logical set of connected activities by an organization to make a strategy work."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.3.5" ;
    skos:prefLabel "Execute strategic initiatives"@en .

<http://ots.local/thesaurus/apqc/1_3_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_3> ;
    skos:definition "Periodic review of initiatives based performance, conditions, and marketplace response."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.3.6" ;
    skos:prefLabel "Review execution of strategic initiatives"@en .

<http://ots.local/thesaurus/apqc/1_3_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_3> ;
    skos:definition "Performing required updates to strategic initiatives based upon changes in the marketplace or performance."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.3.7" ;
    skos:prefLabel "Refine strategic initiatives and project plans as needed"@en .

<http://ots.local/thesaurus/apqc/1_4_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_4_1> ;
    skos:definition "Collecting all relevant materials needed to develop the business model, so that it can adequately model its processes."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.4.1.1" ;
    skos:prefLabel "Assemble business model information"@en .

<http://ots.local/thesaurus/apqc/1_4_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_4_1> ;
    skos:definition "Obtaining required permissions, licenses and authorizations that legitimize the business, help to mitigate associated risks and safeguard the operations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.4.1.2" ;
    skos:prefLabel "Secure appropriate approvals"@en .

<http://ots.local/thesaurus/apqc/1_4_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_4_1> ;
    skos:definition "Ensuring coherence with pre-exsiting models to avoid contradictions between models. Make sure that all models represent the same long-term vision."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.4.1.3" ;
    skos:prefLabel "Identify integration points with existing models"@en .

<http://ots.local/thesaurus/apqc/1_4_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_4_1> ;
    skos:definition "Consenting to a particular business model and formally accepting it to serve as the set of guiding principles in operating the company."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.4.1.4" ;
    skos:prefLabel "Adopt the business model"@en .

<http://ots.local/thesaurus/apqc/1_4_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_4_2> ;
    skos:definition "Determining the timeline, procedures and responsibilities for reviewing the business model and for updating it to best serve the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.4.2.1" ;
    skos:prefLabel "Establish business model maintenance parameters"@en .

<http://ots.local/thesaurus/apqc/1_4_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_4_2> ;
    skos:definition "Deciding the type of responses, reactions, sentiments and insights that are crucial to be taken into consideration with business model maintenance."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.4.2.2" ;
    skos:prefLabel "Accept business model feedback parameters"@en .

<http://ots.local/thesaurus/apqc/1_4_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_4_2> ;
    skos:definition "Evaluating the feedback regarding products, services, processes or resources. Determine which judgments are critical and mandate changes to the current business model to better deliver the desired value"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.4.2.3" ;
    skos:prefLabel "Prioritize and manage incoming feedback"@en .

<http://ots.local/thesaurus/apqc/1_4_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_4_2> ;
    skos:definition "Modifying the business models that are presently in use in response to incoming feedback or changing markets to achieve the enterprise business goals."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.4.2.4" ;
    skos:prefLabel "Update existing models"@en .

<http://ots.local/thesaurus/apqc/1_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/1_4> ;
    skos:definition "Creating and implementing a strategy, responsibilities and control mechanisms for managing business models that are timely, efficient and cost-effective."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "1.4.3" ;
    skos:prefLabel "Establish business model governance"@en .

<http://ots.local/thesaurus/apqc/2_1_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_1> ;
    skos:definition "Assessing the capabilities and performance of existing products/services, in light of market opportunities. Examine performance of the existing line of products/services, including measures of profitability, penetration, and value delivered. Identify gaps between existing solutions' portfolio or their performance levels, on the one hand, and the current market demand, available technologies, and/or customer expectations, on the other. Consider opportunities in the present market environment and any relation with the performance. Consider input from professional services providers."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.1.1" ;
    skos:prefLabel "Evaluate performance of existing products/services against market opportunities"@en .

<http://ots.local/thesaurus/apqc/2_1_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_1> ;
    skos:definition "Checking the alignment of product/service portfolio, and its individual offerings, with the organization's overall strategy and planning for the development of new or revised solutions. Conduct reality checks on new product/service concepts prior to committing significant investment to ensure that the revamped solutions' portfolio is in line with the overall business strategy, aligns organizational processes for their development, and creates a plan for assimilating these changes in the organization's offerings. Enlist senior management executives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.1.2" ;
    skos:prefLabel "Confirm alignment of product/service concepts with business strategy"@en .

<http://ots.local/thesaurus/apqc/2_1_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_1> ;
    skos:definition "Selecting from among the potential new/revised solutions and capitalizing on market opportunities so that they meet the cost and quality prerequisites. Create an index of product/service concepts, and arrange them in order of preference. Base prioritization on adherence to Plan and develop cost and quality targets [10073], and choose options that would comprise the revised solution portfolio."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.1.3" ;
    skos:prefLabel "Prioritize and select new product/service concepts"@en .

<http://ots.local/thesaurus/apqc/2_1_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_1> ;
    skos:definition "Setting prerequisites for the cost of development and quality standards for the new solutions' portfolio and/or its individual offerings. Set targets for the budget and quality standards for the revamped portfolio of solution offerings. Prepare a plan for the outlay required for revising and adding new product/services. Identify intended levels of quality for these, bearing in mind the existing standards of solutions offered by the organization and its competitors. Enlist senior management executives, particularly those responsible for finance and budgeting, product/service design, manufacturing/processing, delivery, and quality control."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.1.4" ;
    skos:prefLabel "Plan and develop cost and quality targets"@en .

<http://ots.local/thesaurus/apqc/2_1_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_1> ;
    skos:definition "Determining the individual and collective timeframe for realizing new/revised solutions. Create a schedule that clearly demarcates the timeframes designated for the development of every new solution and/or revising each of the existing ones. Create a timetable by setting deadlines for each step in overhauling the product/service portfolio."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.1.5" ;
    skos:prefLabel "Specify development timing targets"@en .

<http://ots.local/thesaurus/apqc/2_1_1_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_1> ;
    skos:definition "Developing a programmatic procedure for changing products/services while paying heed to all stakeholders involved and the prerequisites identified. Create a plan for changing the existing portfolio of solution offerings. Develop a systematic program for the design, processing, and delivery of the new product/service concepts. Construct project-flow diagrams. Identify the stakeholders involved and personnel responsible for each stage, as well as the necessary decisions. Earmark the budgetary outlay, and conduct any strategic planning required."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.1.6" ;
    skos:prefLabel "Plan for product/service offering modifications"@en .

<http://ots.local/thesaurus/apqc/2_1_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_2> ;
    skos:definition "Developing a program and managing a perspective for new product/service introduction and launch."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.2.1" ;
    skos:prefLabel "Develop plan for new product/service development and introduction/launch"@en .

<http://ots.local/thesaurus/apqc/2_1_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_2> ;
    skos:definition "Launching revamped product/service portfolio in to the market. Introduction in to the marketplace is done by deploying effective channels for marketing, sales, delivery, and after-sales servicing. Introduce new/revised solution offerings in a concerted effort. Coordinate a cross-functional effort."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.2.2" ;
    skos:prefLabel "Introduce new products/services"@en .

<http://ots.local/thesaurus/apqc/2_1_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_2> ;
    skos:definition "Removing nonconforming products and services. Withdraw those products/services that do not conform to market realities and are not positioned to take advantage of prevailing opportunities. Coordinate with processing/delivery teams within the organization and key stakeholders in the supply chain. Create mechanisms for continued after-sales servicing, as well as deploy effective public relations efforts in order to preserve the image and goodwill of the organization through the process."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.2.3" ;
    skos:prefLabel "Retire outdated products/services"@en .

<http://ots.local/thesaurus/apqc/2_1_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_2> ;
    skos:definition "Attuning the performance measures of products/services to better reflect the revamped portfolio of solution offerings. Revise the parameters used to measure performance, apropos the organization's product/service offerings. (Modify these standards in consideration of the changes made to the portfolio by Introduce new products/services [10077] and Retire outdated products/services [10078].)"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.2.4" ;
    skos:prefLabel "Identify and refine performance indicators"@en .

<http://ots.local/thesaurus/apqc/2_1_2_5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_2_5> ;
    skos:definition "Measuring the performance of marketing once the product/services are launched. This broadly covers measuring user engagement and product's/service's performance in the market."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.2.5.1" ;
    skos:prefLabel "Carry out post launch analytics to test the acceptability in the market"@en .

<http://ots.local/thesaurus/apqc/2_1_2_5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_2_5> ;
    skos:definition "Conducting customer and market analysis to review progress and identify opportunities for increasing market position. Track and review product/service response through sales reports, website statistics, direct response from customers, and survey reports."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.2.5.2" ;
    skos:prefLabel "Review market performance"@en .

<http://ots.local/thesaurus/apqc/2_1_2_5_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_2_5> ;
    skos:definition "Determining the performance of supply chain to all departments and logistics from input to shop floor. Seeking performance reviews at each intersection and communication channels. Review effectiveness of supply chain and distribution to check if it is meeting the demands of the various groups and organizations that are concerned with its activities (groups might include customers, partners, suppliers, and vendors)."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.2.5.3" ;
    skos:prefLabel "Review effectiveness of supply chain and distribution network"@en .

<http://ots.local/thesaurus/apqc/2_1_2_5_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_2_5> ;
    skos:definition "Collecting and examining raw data with the purpose of drawing conclusions about that information and correlate gaps and efficiencies to the existing supply chain channels. Apply the information to make better business decisions to the related supply chain methodologies to meet efficiency."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.2.5.4" ;
    skos:prefLabel "Apply data and analytics to review supply chain methodologies"@en .

<http://ots.local/thesaurus/apqc/2_1_2_5_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_2_5> ;
    skos:definition "Identifying the quality and performance of the product/service delivered to customers. Analyze data from the customer feedback, audits, measures of customer satisfaction (such as product quality complaints and recalls), and organizational policies on delivery."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.2.5.5" ;
    skos:prefLabel "Review quality and performance of the product/service"@en .

<http://ots.local/thesaurus/apqc/2_1_2_5_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_2_5> ;
    skos:definition "Evaluating organization's financial reports and financial reporting processes. Review and document the ROI catered by the product/service delivery to the customer in the market."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.2.5.6" ;
    skos:prefLabel "Conduct financial review"@en .

<http://ots.local/thesaurus/apqc/2_1_2_5_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_2_5> ;
    skos:definition "Analyzing the steps involved in the development of new product, its effect on existing product, resources, and functions related to the development of the new product until its sale in the competitive market place."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.2.5.7" ;
    skos:prefLabel "Conduct new product development process assessment"@en .

<http://ots.local/thesaurus/apqc/2_1_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_3> ;
    skos:definition "Conducting necessary performance reviews on enforcement of processes and steps to ensure protection. Determine policies and reviews for Manage patents, copyrights, and regulatory requirements [19985]."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.3.1" ;
    skos:prefLabel "Conduct mandatory and elective reviews"@en .

<http://ots.local/thesaurus/apqc/2_1_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_3> ;
    skos:definition "Reviewing activities in regards to patentability and infringement. The usage of Open Source in commercial product development will be reviewed in regard to licensing, community development, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.3.2" ;
    skos:prefLabel "Review infringement of patents and copyrights"@en .

<http://ots.local/thesaurus/apqc/2_1_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_3> ;
    skos:definition "Determining the business need for patents and copyrights. The patents and copyrights are managed by Manage copyrights and patents [11062]."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.3.3" ;
    skos:prefLabel "Determine patent and copyright needs"@en .

<http://ots.local/thesaurus/apqc/2_1_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_3> ;
    skos:definition "Defining sourcing and procurement requirements for new product technical documentation management. Make sourcing-based decisions that identify the capabilities that will be required in order to launch the new product. This documentation will be used to support the product following entry into service. It is compiled and managed in Manage product and process related data [12082], but the capability to manage and maintain this documentation must be defined and established."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.3.4" ;
    skos:prefLabel "Define product technical documentation management requirements"@en .

<http://ots.local/thesaurus/apqc/2_1_3_5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_3_5> ;
    skos:definition "Conducting training and impart learning to existing and new employees. Training will relate to the most recent/enforced regulations of the business to meet Manage regulatory requirements [12771]."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.3.5.1" ;
    skos:prefLabel "Train employees on appropriate regulatory requirements"@en .

<http://ots.local/thesaurus/apqc/2_1_3_5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_3_5> ;
    skos:definition "Identifying steps and procedures to manage and regularly update the records for regulatory agencies. Updates will be made to safety procedures, identity and access management, software tools and applications, internal accessibility policies, internal quality parameters, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.3.5.2" ;
    skos:prefLabel "Maintain records for regulatory agencies"@en .

<http://ots.local/thesaurus/apqc/2_1_3_5_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_3_5> ;
    skos:definition "Determine and follow the timely input and update of regulatory information by assessing reforms, regulatory policies, and guidelines."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.3.5.3" ;
    skos:prefLabel "Manage regulatory submission life cycle"@en .

<http://ots.local/thesaurus/apqc/2_1_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_4> ;
    skos:definition "Controlling the details of materials' storage and utilization, supplier details linked to materials, in a defined sequential manner and ensuring regular updates with permissible accessibility."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.4.1" ;
    skos:prefLabel "Manage materials master lists"@en .

<http://ots.local/thesaurus/apqc/2_1_4_10> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_4> ;
    skos:definition "Determining the requests pertaining to data accessibility. Review the requester details based on internal data security policies and permit data access only if internal policies and data access parameters are met."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.4.10" ;
    skos:prefLabel "Review and approve data access requests"@en .

<http://ots.local/thesaurus/apqc/2_1_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_4> ;
    skos:definition "Managing the purchase details/bills through regular and error free updates to applications. Create manual entries wherever necessary and ensure timely review of the laid processes and systems."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.4.2" ;
    skos:prefLabel "Manage bills of material"@en .

<http://ots.local/thesaurus/apqc/2_1_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_4> ;
    skos:definition "Controlling and executing the flow of operations from raw form to finished product in a defined format using industry applications/routing sheets for the specific product/service layout."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.4.3" ;
    skos:prefLabel "Manage routings"@en .

<http://ots.local/thesaurus/apqc/2_1_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_4> ;
    skos:definition "Direct, supervise, and control the product/service details necessary to execute the process. Adhere to details and descriptions for product/service through identified or guided parameters towards final outcome in the market with due critical analysis formed on organizational objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.4.4" ;
    skos:prefLabel "Manage specifications"@en .

<http://ots.local/thesaurus/apqc/2_1_4_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_4> ;
    skos:definition "Administering the specifications of the product/service and ensure accessibility for product alteration/new product development."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.4.5" ;
    skos:prefLabel "Manage drawings"@en .

<http://ots.local/thesaurus/apqc/2_1_4_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_4> ;
    skos:definition "Controlling the details of the product and the input materials. Manage classification throughout the production process, and for future accessibility to new product development or product enrichment."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.4.6" ;
    skos:prefLabel "Manage product/material classification"@en .

<http://ots.local/thesaurus/apqc/2_1_4_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_4> ;
    skos:definition "Determining procedures required to assess the sustainability of defined criterion for product/service delivery to customers. Retain results for further review as a procedural practice."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.4.7" ;
    skos:prefLabel "Develop and maintain quality/inspection documents"@en .

<http://ots.local/thesaurus/apqc/2_1_4_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_4> ;
    skos:definition "Directing and handling data with respect to the procedures followed across different functions and mission critical applications."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.4.8" ;
    skos:prefLabel "Maintain process specification data"@en .

<http://ots.local/thesaurus/apqc/2_1_4_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_1_4> ;
    skos:definition "Identifying and handling data accessed by the permitted touch points. Ensure that no data is accessible to any unnecessary recipient. Data flow should be controlled through secured access and free from unauthorized access."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.1.4.9" ;
    skos:prefLabel "Manage traceability data"@en .

<http://ots.local/thesaurus/apqc/2_2_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_2_1> ;
    skos:definition "Determining new technologies to revise the portfolio of solution offerings. Identify recently developed technological advances that can be leveraged in the development or advancement of the organization's product/service portfolio. Enlist senior management in conjunction with personnel responsible for the design, processing, and delivery of products/services. Have the organization's research division(s) carry out the process."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.2.1.1" ;
    skos:prefLabel "Identify new technologies"@en .

<http://ots.local/thesaurus/apqc/2_2_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_2_1> ;
    skos:definition "Developing new technologies from scratch to integrate into a revised portfolio of solutions. Develop new technological processes, models, and/or implements in-house, with the objective of improving existing solutions or creating new ones. Consider market realities, as well as the portfolio of products/services. Assess the results in conjunction with senior executives and personnel responsible for the design, processing, and delivery of these solutions. Engage the R&D function, and consider external sources such as offshore providers, specialized research agencies, and crowdsourcing communities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.2.1.2" ;
    skos:prefLabel "Develop new technologies"@en .

<http://ots.local/thesaurus/apqc/2_2_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_2_1> ;
    skos:definition "Appraising the feasibility of integrating new technologies, whether developed as a custom solution or adopted from an external source, into revised portfolio of solution offerings. Examine recently developed technological advances for suitability to incorporate them into the concept of revised and/or new solution offerings. Enlist senior management, in consultation with in-house personnel responsible for the design, processing, and delivery of these solutions, as well as key supply-chain stakeholders."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.2.1.3" ;
    skos:prefLabel "Assess feasibility of integrating new leading technologies into product/service concepts"@en .

<http://ots.local/thesaurus/apqc/2_2_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_2_2> ;
    skos:definition "Collecting necessary items, documents, regulatory requirements, etc., based on Generate and define new product/service ideas [19698]"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.2.2.1" ;
    skos:prefLabel "Gather new product/service ideas and requirements"@en .

<http://ots.local/thesaurus/apqc/2_2_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_2_2> ;
    skos:definition "Assessing and reviewing the concepts and requirements of Generate and define new product/service ideas [19698]"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.2.2.2" ;
    skos:prefLabel "Analyze new product/service ideas and requirements"@en .

<http://ots.local/thesaurus/apqc/2_2_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_2_2> ;
    skos:definition "Assessing and reviewing the required inputs and necessary elements such as automation, technology, hardware installation, regulatory requirements, certifications, etc., for new products/services through defined process and analysis."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.2.2.3" ;
    skos:prefLabel "Evaluate new product/service inputs and requirements"@en .

<http://ots.local/thesaurus/apqc/2_2_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_2_2> ;
    skos:definition "Devising ideas and elements necessary for thoughts on new product/service development."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.2.2.4" ;
    skos:prefLabel "Formulate new product/service concepts"@en .

<http://ots.local/thesaurus/apqc/2_2_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_2_2> ;
    skos:definition "Defining potential enhancements to current products/services in order to take advantage of a shift in market expectations. Identify how the existing line of products/services may be revised--through enhancements to individual solutions or across-the-board renovations--in order to capitalize on present opportunities in the market."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.2.2.5" ;
    skos:prefLabel "Identify potential improvements to existing products and services"@en .

<http://ots.local/thesaurus/apqc/2_2_3_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_2_3_1> ;
    skos:definition "Determining the operations of functions related to the product/service in the marketing environment."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.2.3.1.1" ;
    skos:prefLabel "Define basic functional requirements"@en .

<http://ots.local/thesaurus/apqc/2_2_3_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_2_3_1> ;
    skos:definition "Determining the ability of products and services to work together, exchange and use information in a multi-vendor, multi-network, and multi-service environment."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.2.3.1.2" ;
    skos:prefLabel "Derive interoperability requirements for products and services"@en .

<http://ots.local/thesaurus/apqc/2_2_3_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_2_3_1> ;
    skos:definition "Developing safety requirements in line with environmental safety, occupational health and safety, and community health and safety guidelines."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.2.3.1.3" ;
    skos:prefLabel "Derive safety requirements for products and services"@en .

<http://ots.local/thesaurus/apqc/2_2_3_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_2_3_1> ;
    skos:definition "Implementing security requirements through authentication and encryption of CE device data stream.  Utilize security measures such as cryptographic protocols and hardware security (smart cards)."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.2.3.1.4" ;
    skos:prefLabel "Derive security requirements for products and services"@en .

<http://ots.local/thesaurus/apqc/2_2_3_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_2_3_1> ;
    skos:definition "Meeting regulatory requirements set forth by such directives as RoHS, WEEE, ELV, and REACH."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.2.3.1.5" ;
    skos:prefLabel "Derive regulatory compliance requirements"@en .

<http://ots.local/thesaurus/apqc/2_2_3_1_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_2_3_1> ;
    skos:definition "Complying with consumer electronic industry standards developed by the Consumer Technology Association (CTA)."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.2.3.1.6" ;
    skos:prefLabel "Derive requirements from industry standards"@en .

<http://ots.local/thesaurus/apqc/2_2_3_1_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_2_3_1> ;
    skos:definition "Identifying and creating steps and tools to develop the user experience."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.2.3.1.7" ;
    skos:prefLabel "Develop user experience requirements"@en .

<http://ots.local/thesaurus/apqc/2_2_3_1_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_2_3_1> ;
    skos:definition "Productizing the service by defining the scope of the service/cost.  Target market for the service and make the service more tangible."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.2.3.1.8" ;
    skos:prefLabel "Derive ‘services-as-a-product’ offering"@en .

<http://ots.local/thesaurus/apqc/2_2_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_2_3> ;
    skos:definition "Defining SLAs (Service Level Agreement) and service level KPIs (Key Performance Indicator)."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.2.3.2" ;
    skos:prefLabel "Define post launch support model"@en .

<http://ots.local/thesaurus/apqc/2_2_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_2_3> ;
    skos:definition "Establishing areas of growth and further development of product/service mix, customization, market based changes, etc., to further demonstrate value to the customer in the competition."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.2.3.3" ;
    skos:prefLabel "Identify product/service bundling opportunities"@en .

<http://ots.local/thesaurus/apqc/2_3_1_10> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_1> ;
    skos:definition "Creating the new manufacturing/delivery processes for the new products/services, and testing them to ensure proper functioning. Create the production/delivery process for the prototypes that have been built for the new products/services. Conduct trial-runs to test these processes and their integration with the organization's other processes."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.1.10" ;
    skos:prefLabel "Develop and test prototype production and/or service delivery process"@en .

<http://ots.local/thesaurus/apqc/2_3_1_11> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_1> ;
    skos:definition "Eliminating any problems relating to utility of the product/service over the course of its expected lifetime. Tweak the prototype in order to comply with the required quality and reliability standards. Further refine the prototype, so it may be subjected to testing."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.1.11" ;
    skos:prefLabel "Eliminate quality and reliability problems"@en .

<http://ots.local/thesaurus/apqc/2_3_1_12> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_1> ;
    skos:definition "Carrying out an in-house appraisal of the prototypes in order to validate design and feasibility. Test the product/service prototypes to confirm their compliance with design and usability standards. Corroborate the viability of the design, and validate the feasibility of their production. Identify any areas for improvement."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.1.12" ;
    skos:prefLabel "Conduct in-house product/service testing and evaluate feasibility"@en .

<http://ots.local/thesaurus/apqc/2_3_1_13> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_1> ;
    skos:definition "Identifying performance parameters. Determine the parameters to measure performance of the design and development of the product/service concepts into prototypes."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.1.13" ;
    skos:prefLabel "Identify design/development performance indicators"@en .

<http://ots.local/thesaurus/apqc/2_3_1_14> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_1> ;
    skos:definition "Interacting with suppliers and manufactures to determine design decisions. Collaborate with vendors, suppliers, contractors, and subcontractors to verify feasibility of co-producing the prototype's design. Ensure that efforts can be coordinated with other stakeholders in the organization's supply chain ecosystem at the time of manufacturing, producing, or packaging the finished product/service."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.1.14" ;
    skos:prefLabel "Collaborate on design with suppliers and external partners"@en .

<http://ots.local/thesaurus/apqc/2_3_1_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_1_1> ;
    skos:definition "Determining essential elements for collaborators involved in blueprint/development of product/service."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.1.1.1" ;
    skos:prefLabel "Identify requirements for product/service design/development partners"@en .

<http://ots.local/thesaurus/apqc/2_3_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_1> ;
    skos:definition "Preparing a business-level business case and a technical feasibility assessment in order to move the product/service projects forward. Weigh the costs and benefits of designing, developing, and evaluating the shortlisted product/service concepts. Prepare a business case to justify the product/service projects. Conduct a technical appraisal to ensure that the organization has the technical know-how and resources to further develop these concepts."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.1.2" ;
    skos:prefLabel "Prepare high-level business case and technical assessment"@en .

<http://ots.local/thesaurus/apqc/2_3_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_1> ;
    skos:definition "Creating design specifications. Create specifications for the design of new or revised product/service concepts as a measure to meet during development. Have the senior functional-level solutioning or design staff create a framework of compliance standards for these products/services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.1.3" ;
    skos:prefLabel "Develop product/service design specifications"@en .

<http://ots.local/thesaurus/apqc/2_3_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_1> ;
    skos:definition "Determining the usability and user experience of products and the business impact it creates."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.1.4" ;
    skos:prefLabel "Develop user experience design specifications"@en .

<http://ots.local/thesaurus/apqc/2_3_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_1> ;
    skos:definition "Providing warranty plan and pricing specifications for recommendation."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.1.5" ;
    skos:prefLabel "Provide warranty-related recommendations"@en .

<http://ots.local/thesaurus/apqc/2_3_1_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_1> ;
    skos:definition "Documenting requirements to meet in the design of new or revised products/services. Specify technical, quality, and costing requirements, as well as ergonomic, safety, and servicing requirements for such products/services. Ensure the information presented can be understood by the personnel executing the design and includes examples, anecdotal references, and illustrations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.1.6" ;
    skos:prefLabel "Document design specifications"@en .

<http://ots.local/thesaurus/apqc/2_3_1_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_1> ;
    skos:definition "Conducting any mandatory and elective appraisals of the product/service design specifications in order to ensure compliance with external standards. Carry out external reviews of specifications created for the development of new product/service designs. Conduct mandatory appraisals such as legal and regulatory, as well as any optional assessments that, for instance, pitch the specifications against industrial benchmarks."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.1.7" ;
    skos:prefLabel "Conduct mandatory and elective external reviews"@en .

<http://ots.local/thesaurus/apqc/2_3_1_8_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_1_8> ;
    skos:definition "Carrying out the steps necessary to appropriately manufacture correct parts.  This includes designing application, product hardware, mold, casting, mechanical, and electrical aspects of the product."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.1.8.1" ;
    skos:prefLabel "Design for manufacturing"@en .

<http://ots.local/thesaurus/apqc/2_3_1_8_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_1_8> ;
    skos:definition "Creating product application service view to allow for product servicing and refurbishing."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.1.8.2" ;
    skos:prefLabel "Design for product servicing"@en .

<http://ots.local/thesaurus/apqc/2_3_1_8_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_1_8> ;
    skos:definition "Replacing core components and republishing."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.1.8.3" ;
    skos:prefLabel "Design for re-manufacturing"@en .

<http://ots.local/thesaurus/apqc/2_3_1_8_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_1_8> ;
    skos:definition "Reviewing the design and approach for troubleshooting the product."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.1.8.4" ;
    skos:prefLabel "Review product troubleshooting methodology"@en .

<http://ots.local/thesaurus/apqc/2_3_1_8_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_1_8> ;
    skos:definition "Designing the BOM-Bill of material, manufacturing BOM and Service BOMA bill of materials list for all the raw materials and components/parts used in the producing end product."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.1.8.5" ;
    skos:prefLabel "Design and manage product data, design, and bill of materials"@en .

<http://ots.local/thesaurus/apqc/2_3_1_8_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_1_8> ;
    skos:definition "Designing hardware and software upgrade techniques."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.1.8.6" ;
    skos:prefLabel "Design for product upgrades"@en .

<http://ots.local/thesaurus/apqc/2_3_1_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_1> ;
    skos:definition "Building prototypes for shortlisted product/service concepts. Develop prototypes for those product/service concepts that have been identified for further development. Provide proof-of-concepts, and test any processes involved. Build prototypes in line with the design specifications already outlined. Enlist the solutioning and/or design staff."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.1.9" ;
    skos:prefLabel "Build prototypes/proof of concepts"@en .

<http://ots.local/thesaurus/apqc/2_3_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_2> ;
    skos:definition "Composing a detailed study of the market ecosystem in light of new products/services. Conduct a detailed analysis of the targeted market(s) in order to Introduce new products/services [10077]. Examine the competition, market size and growth rate, market trends, customer segments and their characteristics, market influencers, distribution channels, and profitability. Enlist in-house marketing and/or solutioning teams, or outsource to specialized professional services agencies."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.2.1" ;
    skos:prefLabel "Prepare detailed market study"@en .

<http://ots.local/thesaurus/apqc/2_3_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_2> ;
    skos:definition "Conducting both qualitative and quantitative studies to determine the fit between the newly developed products/services and the customers. Conduct external tests of the new product/service, and then refine them to maximize the customer uptake. Gather feedback from prospective customers and targeted populations by conducting surveys, focus groups, interviews, and detailed studies. Enlist professional services such as public relations or market research organizations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.2.2" ;
    skos:prefLabel "Conduct customer tests and interviews"@en .

<http://ots.local/thesaurus/apqc/2_3_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_2> ;
    skos:definition "Finalizing the characteristics of new products/services by appropriately weighing feedback from prospective customers against a cost-benefit analysis in order to produce a profitable business proposition. Refine the attributes of the newly developed products/services, in light of the feedback and insights collected during Conduct customer tests and interviews [10094]. Revisit the high-level business case to justify the resources assigned to the product/service project against the anticipated benefits."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.2.3" ;
    skos:prefLabel "Finalize product/service characteristics and business cases"@en .

<http://ots.local/thesaurus/apqc/2_3_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_2> ;
    skos:definition "Reassessing the technical requirements in light of the final product/service attributes. Revisit the technical assessment to revalidate the organization's capacity for progressing with new product/service projects, in light of the revised product/service characteristics."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.2.4" ;
    skos:prefLabel "Finalize technical requirements"@en .

<http://ots.local/thesaurus/apqc/2_3_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_3> ;
    skos:definition "Developing and/or sourcing the essential machinery needed for creating purpose-built processes, as well as the raw materials, to produce the new products/services. Either design the equipment and materials needed internally, or source from external vendors. Obtain the feedstock or raw materials needed to prepare the finished products, as well as the machinery - hardware and software - needed to arrange production lines, factory operations, assemblies, and manufacturing processes. Revisit the technologies that underpin the new or revised products/services in order to source the right equipment and materials."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.3.1" ;
    skos:prefLabel "Design and obtain necessary capabilities/materials and equipment"@en .

<http://ots.local/thesaurus/apqc/2_3_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_3> ;
    skos:definition "Identifying any changes that need to be effectuated in the organization's internal processes for manufacturing, and delivering the newly developed products/services. Determine if any changes need to be made to the production and distribution processes, in light of the new products/services. Begin production process planning. Prepare for factory layout planning. Generate shop-floor instructions and changes to the supply chain."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.3.2" ;
    skos:prefLabel "Identify requirements for changes to manufacturing/delivery processes"@en .

<http://ots.local/thesaurus/apqc/2_3_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_3> ;
    skos:definition "Requesting changes in the production and/or delivery operations for processing the new or revised products/services. Rectify any problems identified in the manufacturing or delivery processes (through Monitor production runs [11417]). Seek changes in components, repair machinery, optimize production lines, and tweak factory assemblies through a formal notice to the concerned division, known as an engineering change order."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.3.3" ;
    skos:prefLabel "Request engineering/process change"@en .

<http://ots.local/thesaurus/apqc/2_3_3_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_3_4> ;
    skos:definition "Regularly monitoring production runs of the production and/or delivery operations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.3.4.1" ;
    skos:prefLabel "Monitor initial production runs"@en .

<http://ots.local/thesaurus/apqc/2_3_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_3> ;
    skos:definition "Verifying the measures/processes/techniques through systems and tools involved in the introduction of products and services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.3.5" ;
    skos:prefLabel "Validate launch procedures"@en .

<http://ots.local/thesaurus/apqc/2_3_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_4> ;
    skos:definition "Establishing warranty policies to assure customers that the company will guarantee its warranties that it issues."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.4.1" ;
    skos:prefLabel "Determine and document warranty policies"@en .

<http://ots.local/thesaurus/apqc/2_3_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_4> ;
    skos:definition "Establishing and maintaining claims processing and routing rules. Establish and maintain claims processing and routing rules for product warranties, coverage lists, repair, fault, trouble codes, repair time setup, and warranty policy registration. This also includes rolling out the codes and rules, and the improvements/updates to these rules and codes via systematic updates."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.4.2" ;
    skos:prefLabel "Create and manage warranty rules/claim codes for products"@en .

<http://ots.local/thesaurus/apqc/2_3_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_4> ;
    skos:definition "Negotiating with manufacturers and dealers the obligations of each party in upholding warranties."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.4.3" ;
    skos:prefLabel "Agree on warranty responsibilities with suppliers"@en .

<http://ots.local/thesaurus/apqc/2_3_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_4> ;
    skos:definition "Informing customers about warranties that apply to promoted products or services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.4.4" ;
    skos:prefLabel "Define warranty related offerings for customers"@en .

<http://ots.local/thesaurus/apqc/2_3_4_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3_4> ;
    skos:definition "Communicating rules and updates via training manuals for new products and training resources."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.4.5" ;
    skos:prefLabel "Communicate warranty policies and offerings"@en .

<http://ots.local/thesaurus/apqc/2_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/2_3> ;
    skos:definition "Establishing procedures to handle recalls of defective products."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "2.3.5" ;
    skos:prefLabel "Develop recall strategy"@en .

<http://ots.local/thesaurus/apqc/3_1_1_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_1_1_1> ;
    skos:definition "Identifying the factors that drive the targeted market segment. Model customer purchasing patterns, and forecast their future purchasing behavior."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.1.1.1.1" ;
    skos:prefLabel "Understand consumer needs and historical behaviors"@en .

<http://ots.local/thesaurus/apqc/3_1_1_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_1_1_1> ;
    skos:definition "Using customer segmentation tools to examine past customer behavior to predict future purchasing patterns."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.1.1.1.2" ;
    skos:prefLabel "Predict customer purchasing behavior"@en .

<http://ots.local/thesaurus/apqc/3_1_1_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_1_1_2> ;
    skos:definition "Determining the increase or decrease of the company's sales volume in the targeted markets. Conduct an analysis to determine the factors and underlying causes that affect the changes in the demand for products or services offered. Consider changes in offerings or in the business strategy to regain or increase the market share."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.1.1.2.1" ;
    skos:prefLabel "Determine market share gain/loss"@en .

<http://ots.local/thesaurus/apqc/3_1_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_1_1> ;
    skos:definition "Examining large-scale shifts and trends, with relevance to the organization's products/services. Vet the industrial and larger market landscape to identify broad-based movements that could have a direct or tangential impact on the uptake of the organization's products/services. Examine, among other things, the market capitalization of similar products, the profitability of organizations offering competing products/services, the stock price of key vendors/suppliers in the organizational value-chain, the rate and scale of innovation activity in the organization's product/service category, the price and availability of raw materials, and the shelf-life of similar products/services. Conduct primary and secondary research, and consider enlisting professional services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.1.1.3" ;
    skos:prefLabel "Analyze market and industry trends"@en .

<http://ots.local/thesaurus/apqc/3_1_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_1_1> ;
    skos:definition "Examining the strengths and weaknesses of competing organizations. Assess competing organizations for offerings, product strategy, marketing and delivery channels, etc. Analyze the usability experience, durability, USP, and other key attributes of competing and substitute products. Gather competitive intelligence, and consider enlisting professional services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.1.1.4" ;
    skos:prefLabel "Analyze competing organizations, competitive/substitute products/services"@en .

<http://ots.local/thesaurus/apqc/3_1_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_1_1> ;
    skos:definition "Examining the brands owned and products offered in the market. Determine the relative position of the existing products/brands in the marketplace."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.1.1.5" ;
    skos:prefLabel "Evaluate existing products/services"@en .

<http://ots.local/thesaurus/apqc/3_1_1_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_1_1> ;
    skos:definition "Understanding the culture and environment in which you're operating. Analyze how internal decision-making, thought processes, financial circumstances, and more affect the ability to bring new products to market. Survey or analyze the market into which the products would be introduced."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.1.1.6" ;
    skos:prefLabel "Assess internal and external business environment"@en .

<http://ots.local/thesaurus/apqc/3_1_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_1_2> ;
    skos:definition "Attaching quantifiable indicators to opportunities that have been identified in the market. Compute estimated figures of the approximate value that can be captured with the provision of existing products/services (i.e., the extent of financial benefits that can be reaped in the market)."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.1.2.1" ;
    skos:prefLabel "Quantify market opportunities"@en .

<http://ots.local/thesaurus/apqc/3_1_2_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_1_2_2> ;
    skos:definition "Determining which groups of potential customers do not yet, or already do have access to the product or a service that the company produces or markets. Use those findings to create specialized product offerings and differentiated marketing campaigns."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.1.2.2.1" ;
    skos:prefLabel "Identify under-served and saturated market segments"@en .

<http://ots.local/thesaurus/apqc/3_1_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_1_2> ;
    skos:definition "Creating an index of market opportunities, and arrange them in order of preference. Prioritize based on the opportunities' adherence to the overall business strategy. Correlate with the competencies and capacities that the organization, as a whole, processes."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.1.2.3" ;
    skos:prefLabel "Prioritize opportunities consistent with capabilities and overall business strategy"@en .

<http://ots.local/thesaurus/apqc/3_1_2_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_1_2_4> ;
    skos:definition "Validating identified market opportunities by testing company's offerings on limited-size samples of the consumer population that are hypothesized to be representative of the target market at large and to have similar purchasing behavior. The feedback gained through consumer testing can be used to modify or reject product offerings before their full scale launch, saving the company valuable resources, should the initial offering not be successful."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.1.2.4.1" ;
    skos:prefLabel "Test with customers/consumers"@en .

<http://ots.local/thesaurus/apqc/3_1_2_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_1_2_4> ;
    skos:definition "Verifying that the company has sufficient infrastructure and resources to deliver their offerings in a timely and cost-effective manner, and that it is able to scale up from the small-scale market samples, used for consumer testing, to the entire identified market segment."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.1.2.4.2" ;
    skos:prefLabel "Confirm internal capabilities"@en .

<http://ots.local/thesaurus/apqc/3_2_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_1> ;
    skos:definition "Defining problem(s) that the organization's products/services solve for the customers, thereby determining how they are positioned in the market. Refine the product/service concepts from the perspective of customers. Succinctly outline the problem the organization's offerings solves for the customers, making a case for why the customer should buy a product or use a service. Define the offering's unique value."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.1.1" ;
    skos:prefLabel "Define offering and positioning"@en .

<http://ots.local/thesaurus/apqc/3_2_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_1> ;
    skos:definition "Boosting the attractiveness of products/services to the targeted customers, and creating a unique brand projection around these features. Identify and enhance those product/service features that reinforce the attractiveness of these offerings, for these segment of customers. Underscore the perceived value delivered to the customers by clearly specifying the relevance and desirability of these products/services. Once it has been clarified how the organization's offerings meet the customer's expectations or deliver specific benefits, position the brands around these benefits."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.1.2" ;
    skos:prefLabel "Develop value proposition including brand positioning for target segments"@en .

<http://ots.local/thesaurus/apqc/3_2_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_1> ;
    skos:definition "Validating the desirability of the perceived value delivered by the organization's offerings, to the targeted customer segment. Substantiate the value of the benefits accrued to the customers through the organization's offerings. Justify the value proposition in light of the targeted segments by gathering feedback (using teaser demonstrations, surveys, interviews, primary research studies, and customer case studies). Corroborate the benefits of the organization's offerings."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.1.3" ;
    skos:prefLabel "Validate value proposition with target segments"@en .

<http://ots.local/thesaurus/apqc/3_2_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_2> ;
    skos:definition "Analyzing external social and digital feedback related to brands to assess public perception, sentiment trends, and emerging reputation risks or opportunities, and to inform brand positioning and management decisions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.2.1" ;
    skos:prefLabel "Conduct brand level social sentiment analysis"@en .

<http://ots.local/thesaurus/apqc/3_2_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_2> ;
    skos:definition "Defining brand-specific marketing direction, priorities, and strategic choices to support brand introduction, growth, positioning, and ongoing performance within the broader marketing strategy."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.2.2" ;
    skos:prefLabel "Develop marketing strategy for new and existing brands"@en .

<http://ots.local/thesaurus/apqc/3_2_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_2> ;
    skos:definition "Establishing the desired brand value, differentiation, and market perception relative to competitors and target audiences, including the attributes and associations the brand is intended to represent."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.2.3" ;
    skos:prefLabel "Define brand equity position"@en .

<http://ots.local/thesaurus/apqc/3_2_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_2> ;
    skos:definition "Evaluating brand performance against defined objectives and expectations to inform brand positioning adjustments, investment decisions, and ongoing brand management actions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.2.4" ;
    skos:prefLabel "Assess brand performance management"@en .

<http://ots.local/thesaurus/apqc/3_2_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_3> ;
    skos:definition "Analyzing marketing objectives, consumer demand, product attributes, competitors' pricing, and economic trends to determine optimum prices for the set of products and services that the company offers or intends to offer by delivering maximum ROI."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.3.1" ;
    skos:prefLabel "Conduct pricing analysis"@en .

<http://ots.local/thesaurus/apqc/3_2_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_3> ;
    skos:definition "Creating a framework that allows for a uniform methodology while determining the price of individual offerings. Devise a blueprint for establishing the pricing of specific products/services. Create guidelines that factor in the cost of production/servicing, price sensitivity, product lifecycle, and the price of competing/substitute products."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.3.2" ;
    skos:prefLabel "Establish guidelines for applying pricing and discounting of products/services"@en .

<http://ots.local/thesaurus/apqc/3_2_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_3> ;
    skos:definition "Determining optimum prices for individual products or services on the basis of the cost of producing, distributing and marketing the offerings, pricing analysis and general pricing strategy."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.3.3" ;
    skos:prefLabel "Establish pricing targets"@en .

<http://ots.local/thesaurus/apqc/3_2_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_3> ;
    skos:definition "Confirming the strategy and specifications developed for pricing the organization's products/services. Approve pricing guidelines by vetting the soundness of the methodology and the guidelines' alignment with the value proposition."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.3.4" ;
    skos:prefLabel "Approve pricing strategies/policies and targets"@en .

<http://ots.local/thesaurus/apqc/3_2_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_4> ;
    skos:definition "Deciding which distributors, wholesalers and retailers the company will use to promote its offerings and to distribute its products and services to the target market. Narrowing down which intermediaries the company will use will affect retail prices of individual products, and should therefore be included in the pricing analysis."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.4.1" ;
    skos:prefLabel "Determine channels to be supported"@en .

<http://ots.local/thesaurus/apqc/3_2_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_4> ;
    skos:definition "Identifying the role that each chosen marketing channels plays in the larger distribution network with respect to the organizational marketing strategy. Determine intermediary costs for shipping, handling, transporting, warehousing, insurance and marketing that incur and accumulate in the distribution channel."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.4.2" ;
    skos:prefLabel "Establish channel objectives"@en .

<http://ots.local/thesaurus/apqc/3_2_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_4> ;
    skos:definition "Analyze the various channels for their relevance to the targeted segments. Identify the channel that can effectively market to the targeted customers in regard to the drives, desires, and characteristics of these populations, their uptake, extent of engagement, frequency of use, and effectiveness in communicating."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.4.3" ;
    skos:prefLabel "Determine channel role and fit with target segments"@en .

<http://ots.local/thesaurus/apqc/3_2_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_4> ;
    skos:definition "Choose the most pertinent marketing channel for the targeted segments (based on Determine channel fit with target segments [10127])."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.4.4" ;
    skos:prefLabel "Select channels for target segments"@en .

<http://ots.local/thesaurus/apqc/3_2_4_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_4> ;
    skos:definition "Determining the maximum output rate required from a distribution channel to optimally market and deliver the products and services the company offers or would like to offer. Ideally, a channel should be able to adapt to a certain degree of variability in the demand for the offerings, and able scale up if needed."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.4.5" ;
    skos:prefLabel "Identify required channel capabilities"@en .

<http://ots.local/thesaurus/apqc/3_2_4_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_4> ;
    skos:definition "Assessing the attributes of all marketing channels, and evaluating the key partners in those channels. Closely examine the various characteristics of all available marketing channels such as the cost of using them, durability of impact, applicability to the organization's products/services, turn-around time, involvement of middlemen, and conversion rate. Analyze key partners in the marketing channels including those who have been associated with the organization; evaluate their capabilities, the scale and scope of their operations, quality of support provided, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.4.6" ;
    skos:prefLabel "Evaluate channel attributes and potential partners"@en .

<http://ots.local/thesaurus/apqc/3_2_4_7_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_4_7> ;
    skos:definition "Devising a strategy to market company's products or services seamlessly through all or most channels that are in widespread use among the target market. This may mean cross-channel access to customer preferences and purchasing history to accept returned merchandise, provide refunds, resolve payment issues or to provide technical support."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.4.7.1" ;
    skos:prefLabel "Define omni-channel strategy"@en .

<http://ots.local/thesaurus/apqc/3_2_4_7_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_4_7> ;
    skos:definition "Identifying necessary preconditions that a channel should fulfill in order to be included as one of the adopted channels, such as required throughput capacities, service capabilities, competitive pricing, and alignment with organizational marketing strategies."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.4.7.2" ;
    skos:prefLabel "Define omni-channel requirements"@en .

<http://ots.local/thesaurus/apqc/3_2_4_7_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_4_7> ;
    skos:definition "Determining the detailed policies and procedures that each of the channels needs to follow in order to conform to the organizational marketing strategy and to provide seamless customer service experience."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.4.7.3" ;
    skos:prefLabel "Develop omni-channel policies and procedures"@en .

<http://ots.local/thesaurus/apqc/3_2_4_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_4> ;
    skos:definition "Determining the actions that need to be taken for successful multichannel marketing, the ordering, timing and dependencies of the steps, and the governance mechanism for reviewing and changing the protocol, if needed."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.4.8" ;
    skos:prefLabel "Develop and manage execution roadmap"@en .

<http://ots.local/thesaurus/apqc/3_2_4_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_4> ;
    skos:definition "Establishing and overseeing the strategic role, structure, and positioning of marketing channels and customer engagement formats, including how they are used to reach target audiences, deliver brand experiences, and support overall marketing objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.4.9" ;
    skos:prefLabel "Define and manage channel/store format strategy"@en .

<http://ots.local/thesaurus/apqc/3_2_5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_5> ;
    skos:definition "Determining measurable parameters to be used for comparing the performance of different marketing channels. Decide on benchmarks and values for optimum or desired performance."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.5.1" ;
    skos:prefLabel "Establish channel-specific measures and targets"@en .

<http://ots.local/thesaurus/apqc/3_2_5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_5> ;
    skos:definition "Tracking trends and changes in performance inside individual marketing channels and in channels collectively. Summarize and document results. Alert relevant parties about significant or unexpected deviations from expected behaviors."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.5.2" ;
    skos:prefLabel "Monitor and report performance"@en .

<http://ots.local/thesaurus/apqc/3_2_5_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_5> ;
    skos:definition "Analyzing the factors and circumstances that influence desired outcomes. Communicate core findings to relevant parties."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.5.3" ;
    skos:prefLabel "Monitor and report events influencing factors"@en .

<http://ots.local/thesaurus/apqc/3_2_5_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_5> ;
    skos:definition "Conducting an analysis to review channel performance with respect to chosen metrics, benchmarks and performance targets [16573]. Compare to past performance and forecasts for the channel."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.5.4" ;
    skos:prefLabel "Analyze channel performance"@en .

<http://ots.local/thesaurus/apqc/3_2_5_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_5> ;
    skos:definition "Devising a course of action to be taken to improve under-performing channels and to promote or expand channels that surpass expectations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.5.5" ;
    skos:prefLabel "Develop plan for channel improvements"@en .

<http://ots.local/thesaurus/apqc/3_2_6_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_6> ;
    skos:definition "Timing and scheduling the delivery of marketing messages to maximize their impact on customer purchasing behavior. Integrate individual messages to larger marketing campaigns and to seasonal purchasing patterns."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.6.1" ;
    skos:prefLabel "Develop customer communication calendar"@en .

<http://ots.local/thesaurus/apqc/3_2_6_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_6> ;
    skos:definition "Deciding how to promote and maintain a favorable public image of the company in the eyes of its employees, customers, investors, suppliers, politicians or the general public. This may involve various means but is frequently conducted through publicity, education, corporate social responsibility, charitable causes or civic engagements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.6.2" ;
    skos:prefLabel "Define public relations (PR) strategy"@en .

<http://ots.local/thesaurus/apqc/3_2_6_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_6> ;
    skos:definition "Devising a master plan how to select potential customers or qualified clients for customized offers, and contact them on one-to-one basis through chat, phone, email or regular mail. The strategy would need to take into account that personalizing offers and contacting customers individually is an effective but resource-intensive marketing technique, and that ill-targeted offers risk at angering and alienating the contactees."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.6.3" ;
    skos:prefLabel "Define direct marketing strategy"@en .

<http://ots.local/thesaurus/apqc/3_2_6_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_6> ;
    skos:definition "Developing a program to promote the objectives, values, products and services of the company to its employees by treating them as potential customers, in order to extend company client base, increase employee engagement or to foster brand advocacy."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.6.4" ;
    skos:prefLabel "Define internal marketing communication strategy"@en .

<http://ots.local/thesaurus/apqc/3_2_6_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_6> ;
    skos:definition "Finding emerging media based on digital or other technologies that would enable the company to increase the speed and volume of marketing communications, to make communications more interactive and to customize promotional messages more easily to the target audience, thus rendering them more effective."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.6.5" ;
    skos:prefLabel "Identify new media for marketing communication"@en .

<http://ots.local/thesaurus/apqc/3_2_6_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_6> ;
    skos:definition "Developing a marketing strategy that is maximally effective in a new or emerging media channel by capitalizing on its novel attributes and capabilities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.6.6" ;
    skos:prefLabel "Define new media communication strategy"@en .

<http://ots.local/thesaurus/apqc/3_2_6_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_6> ;
    skos:definition "Establishing a framework for coordinated marketing to increase the profitability and increase brand awareness at the point of sale. This may include promotional posters on product shelves or island displays, advertisements in shopping carts, stickers on the floor that lead consumers to the promoted product, multi-buy promotions, coupons on sales receipts, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.6.7" ;
    skos:prefLabel "Define point of sale (POS) communication strategy"@en .

<http://ots.local/thesaurus/apqc/3_2_6_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_6> ;
    skos:definition "Establishing standardized procedures for effective communication that maximizes ROI, promotes brand awareness and respects customers. In its simplest form, it includes a message (what is to be said), a target (to whom the message is reaching) and a medium or a channel (where the message is to be said)."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.6.8" ;
    skos:prefLabel "Define communication guidelines and mechanisms"@en .

<http://ots.local/thesaurus/apqc/3_2_7_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_7> ;
    skos:definition "Devising procedures and mechanisms to retain existing customers, promote repeat business and increase the likelihood that previous customers to continue to buy products or services from the company. This may be achieved by rewarding customers for repeat business by means of gifts, discounts, redeemable \"points\", or prioritized access to new products, events or services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.7.1" ;
    skos:prefLabel "Define customer loyalty program"@en .

<http://ots.local/thesaurus/apqc/3_2_7_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_7> ;
    skos:definition "Convincing customers to register their personal information with the company and be assigned a unique identifier that they use when making purchases. The identifier makes it easier for the company to track customer purchases. Customers are rewarded by various incentives that encourage repeat business [20007]."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.7.2" ;
    skos:prefLabel "Acquire members to customer loyalty program"@en .

<http://ots.local/thesaurus/apqc/3_2_7_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_7> ;
    skos:definition "Building deeper relationships between a customer and a brand in order to promote customer loyalty and derive repeat business. Besides making frequent purchases, highly engaged customers refer family, friends and colleagues to make purchases as well, consume and re-broadcast promotional materials, provide feedback to the purchases they make and do not support competing brands."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.7.3" ;
    skos:prefLabel "Build engagement and relationship with members"@en .

<http://ots.local/thesaurus/apqc/3_2_7_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_7> ;
    skos:definition "Surveying and tracking the benefits of customer loyalty programs both for the company and for customers. Compare with comparable loyalty programs instituted in competitor companies. Propose changes as needed to keep up with market trends."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.7.4" ;
    skos:prefLabel "Monitor customer loyalty program benefits to the enterprise and the customer"@en .

<http://ots.local/thesaurus/apqc/3_2_7_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_2_7> ;
    skos:definition "Enhancing the customer loyalty program so that it will yield maximum value both for the company and for the patrons enrolled in the program, increasing customer retention and continued engagement."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.2.7.5" ;
    skos:prefLabel "Optimize loyalty program value to both the enterprise and the customer"@en .

<http://ots.local/thesaurus/apqc/3_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3> ;
    skos:definition "Determining what to achieve by marketing. Create qualitative and quantitative targets. Establish metrics to track performance (for individual Market segments [10109] and Channels for target segments [10129]). Enlist the head of marketing to determine marketing priorities and the related measures. (The decision in establishing these goals, objectives, and metrics is founded in Develop marketing strategy [10102] and takes cues from current priorities and organizational strategy.)"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.1" ;
    skos:prefLabel "Establish goals, objectives, and measures for products/services by channel/segment"@en .

<http://ots.local/thesaurus/apqc/3_3_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_2> ;
    skos:definition "Ensuring corroboration of the marketing strategy and the organizational strategy. Ensure the organization's marketing strategy/plan aligns with the overall business strategy. Fine-tune the marketing plan according to the organizational strategy."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.2.1" ;
    skos:prefLabel "Confirm marketing alignment to business strategy"@en .

<http://ots.local/thesaurus/apqc/3_3_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_2> ;
    skos:definition "Calculating the total cost of marketing the organization's portfolio of products/services. Calculate the total outlay needed for promoting, selling, and delivering the organization's products/services to customers. Account for all costs to acquire customers and sustain a relationship with them. Include the expenses needed for promotional actives, warehousing, transactional costs, and distribution of the organization's offering."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.2.2" ;
    skos:prefLabel "Determine costs of marketing"@en .

<http://ots.local/thesaurus/apqc/3_3_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_2> ;
    skos:definition "Estimating the outlay required for promoting, selling, and distributing the products/services of the organization. Add up the expenses of all activities necessitated in marketing, such as promotional campaigns, advertising, marketing communications, PR campaigns, employing skilled personnel, and office space."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.2.3" ;
    skos:prefLabel "Create marketing budget"@en .

<http://ots.local/thesaurus/apqc/3_3_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_2> ;
    skos:definition "Estimating how much profit the company would generate for its expenses on marketing . Forecasted return on investment, used as a metric to gauge the efficiency of marketing, is beneficial in revising marketing budgets and adjusting costs to improve the overall yield."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.2.4" ;
    skos:prefLabel "Determine projected ROI for marketing investment"@en .

<http://ots.local/thesaurus/apqc/3_3_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_3> ;
    skos:definition "Determining the production and distribution costs for each product or service, and each channel or method as factors in determining overall pricing."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.3.1" ;
    skos:prefLabel "Understand resource requirements for each product/service and delivery channel/method"@en .

<http://ots.local/thesaurus/apqc/3_3_3_10> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_3> ;
    skos:definition "Obtaining internal price approvals and governmental approvals that are required for licensed products and for products that can be reimbursed by the government."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.3.10" ;
    skos:prefLabel "Achieve regulatory approval for pricing"@en .

<http://ots.local/thesaurus/apqc/3_3_3_11> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_3> ;
    skos:definition "Analyzing competitor pricing across relevant channels and markets to understand relative price positioning, identify pricing gaps or risks, and inform pricing strategy and adjustments."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.3.11" ;
    skos:prefLabel "Conduct competitive pricing review (online, offline etc.)"@en .

<http://ots.local/thesaurus/apqc/3_3_3_12> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_3> ;
    skos:definition "Defining pricing approaches and price levels for specific customer segments based on value propositions, market conditions, and strategic pricing objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.3.12" ;
    skos:prefLabel "Determine customer segment specific pricing"@en .

<http://ots.local/thesaurus/apqc/3_3_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_3> ;
    skos:definition "Introducing financial inducements, such as discounts, to distributors, resellers or vendors as a motivation to prioritize selling company's products or services over those of its competitors."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.3.2" ;
    skos:prefLabel "Determine corporate incentives"@en .

<http://ots.local/thesaurus/apqc/3_3_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_3> ;
    skos:definition "Establishing a dynamic pricing mechanism for the organization's offerings that is supported by the number of units in production. Outline a system for determining the optimum price point for each product/service. Based this model on an estimation of the volume of anticipated sales for each offering and variable costs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.3.3" ;
    skos:prefLabel "Determine pricing based on volume/unit forecast"@en .

<http://ots.local/thesaurus/apqc/3_3_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_3> ;
    skos:definition "Implementing the pricing mechanism to determine prices for all individual offerings in the organizational portfolio. Calculate the prices of all offerings based on the established methodology and/or formulaic structure."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.3.4" ;
    skos:prefLabel "Execute pricing plan"@en .

<http://ots.local/thesaurus/apqc/3_3_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_3> ;
    skos:definition "Examining the efficiency of pricing with the objective of identifying any divergence from the equilibrium prices and avoiding any deadweight loss. Gauge the performance of the pricing plan by tracking growth in the revenue and/or customer uptake, secured as a result of new prices. Measure the performance of pricing by periodically checking the profits generated from the sale of each of the organization's offerings against the backdrop of any events that may have influenced the uptake of a certain good/service by the customer base."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.3.5" ;
    skos:prefLabel "Evaluate pricing performance"@en .

<http://ots.local/thesaurus/apqc/3_3_3_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_3> ;
    skos:definition "Refining the pricing mechanism to create equitable prices for all products/services with the objective of maximizing the profits and/or customer uptake of these offerings. Reconcile the pricing mechanism in order to achieve equilibrium pricing. Adjust the prices for all of the organization's offerings, using the insights gleaned from examining how much profit or customer uptake is generated by the present pricing strategy."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.3.6" ;
    skos:prefLabel "Refine pricing as needed"@en .

<http://ots.local/thesaurus/apqc/3_3_3_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_3> ;
    skos:definition "Managing schemes that offer lower pricing for a limited time as a promotional and sales incentive when launching a new product or a service."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.3.7" ;
    skos:prefLabel "Implement promotional pricing programs"@en .

<http://ots.local/thesaurus/apqc/3_3_3_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_3> ;
    skos:definition "Determining the optimum consumer pricing for each product or service at the point of sale, based on production and distribution costs and estimated sales volume."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.3.8" ;
    skos:prefLabel "Implement other retail pricing programs"@en .

<http://ots.local/thesaurus/apqc/3_3_3_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_3> ;
    skos:definition "Assigning new prices or pricing adjustments to products or services to replace the original base prices. Update the prices in product catalogs and databases, and disseminate the information through all involved distribution and marketing channels."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.3.9" ;
    skos:prefLabel "Communicate and implement price changes"@en .

<http://ots.local/thesaurus/apqc/3_3_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_4> ;
    skos:definition "Outlining a conceptual framework for all promotional activity in order to create an overarching aspiration and ensure consistency. Create a plan for running promotional programs and designing the associated activities in order to increase visibility or sales. Determine how the organization quantifies what it wishes to achieve from these activities, what sort of messages the organization comfortable publicizing, what channels the organization wishes to employ, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.4.1" ;
    skos:prefLabel "Define promotional concepts and objectives"@en .

<http://ots.local/thesaurus/apqc/3_3_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_4> ;
    skos:definition "Developing the central messages for a segment of its customers. Craft concise statements that position the value proposition of individual products/services around the pressing concerns in the market, thereby showing how the organization's offerings are the right fit for the customers."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.4.2" ;
    skos:prefLabel "Develop marketing messages"@en .

<http://ots.local/thesaurus/apqc/3_3_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_4> ;
    skos:definition "Determining the appropriate audience to direct marketing efforts at. Identify the particular group of customers to target. Discover the appropriate customer groups at a micro-level. Use techniques such as segmentation analysis, whereby the entire population is sliced according to certain demographic or behavioral attributes."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.4.3" ;
    skos:prefLabel "Define target audience"@en .

<http://ots.local/thesaurus/apqc/3_3_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_4> ;
    skos:definition "Developing a scheme for executing the promotional programs and campaigns, and testing these on sample audiences. Create a program plan, and carry out trials for promotional activities. Develop a scheme for how, when, where, and by whom the promotional schemes and campaigns will be deployed. Design incentives that convince or tempt the consumer to take up the organization's offerings. Conduct focus groups and pilot programs that reach out to a smaller number of people from among the target audiences to validate effectiveness."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.4.4" ;
    skos:prefLabel "Plan and test promotional activities"@en .

<http://ots.local/thesaurus/apqc/3_3_4_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_4> ;
    skos:definition "Executing promotional programs in the market for reaching out to the desired customer segments. Implement the promotional schemes and campaigns. Create collaterals for the dissemination of information about the product, product line, brand, or company to the target audiences in an effective manner. Leverage relationships with distributors, vendors, and retailers. Consider enlisting professional services such as design, PR, and advertising firms."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.4.5" ;
    skos:prefLabel "Execute promotional activities"@en .

<http://ots.local/thesaurus/apqc/3_3_4_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_4> ;
    skos:definition "Evaluating the success of promotional programs through metrics that track the impact of these activities. Examine the performance of promotional activities. Measure the success of these programs through metrics representative of customer uptake, market penetration, sustenance of impact created, revenue growth through offerings marketed, etc. Measure through primary data collection. Analyze through various statistical techniques to generate insights."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.4.6" ;
    skos:prefLabel "Evaluate promotional performance metrics"@en .

<http://ots.local/thesaurus/apqc/3_3_4_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_4> ;
    skos:definition "Fine-tuning promotional activities by employing the insights gleaned from the quantitative, as well as any qualitative, performance evaluations. Change certain attributes of the schemes, campaigns, and programs deployed in order to increase the impact generated, in terms of measures already agreed upon such as customer uptake, market penetration, sustenance of impact created, and revenue growth through offerings marketed."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.4.7" ;
    skos:prefLabel "Refine promotional performance metrics"@en .

<http://ots.local/thesaurus/apqc/3_3_4_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_4> ;
    skos:definition "Incorporating the understanding developed by studying promotional activities as well as refining them. Include the best practices and value-enhancing attributes identified in Refine promotional activities [10171] into similarly planned schemes, programs, and campaigns. Adjust promotional activities to further increase the effectiveness of the overall promotional efforts."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.4.8" ;
    skos:prefLabel "Incorporate learning into future/planned consumer promotions"@en .

<http://ots.local/thesaurus/apqc/3_3_5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_5> ;
    skos:definition "Estimating customer loyalty and the average contribution made by them to revenues, over their lifespan. Use metrics to quantify the commitment of customers to the offerings of the organization, such as measures of tendency to switch brands/providers, number/proportion of return customers, and the number of customers using multiple substitutable offerings."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.5.1" ;
    skos:prefLabel "Determine customer lifetime value"@en .

<http://ots.local/thesaurus/apqc/3_3_5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_5> ;
    skos:definition "Analyzing the revenue stream generated by the sale of the organization's products/services in order to identify trends therein. Examine data relating to the inflow of revenue from individual/groups of customers in order to identify patterns in the generation and sustenance of receivables. Conduct statistical analysis over the stream of revenue collected and the point of origin associated with each unit of sale through metrics such as the accounting rate of return, the GAAP revenue over a given period, and customer lifetime revenue."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.5.2" ;
    skos:prefLabel "Analyze customer revenue trend"@en .

<http://ots.local/thesaurus/apqc/3_3_5_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_5> ;
    skos:definition "Calculating measures that capture the proportion of customers the organization is able to retain to those it is losing. Compute metrics such as the tendency to switch brands/providers and the proportion of return customers to comprehend the trends within the customer attrition and retention rates."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.5.3" ;
    skos:prefLabel "Analyze customer attrition and retention rates"@en .

<http://ots.local/thesaurus/apqc/3_3_5_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_5> ;
    skos:definition "Studying all measures of the customer's behavior and conduct toward the organization's offerings in order to glean insight and identify patterns into their decision making. Closely examine all categories of data sets over a customer base. Analyze data points related to customer loyalty, retention, value, conversion, level of satisfaction, attrition, etc. Flesh out measures for an all-encompassing analysis that provides a macro-level picture of the customer's behavior and mindset related to the organization's products/services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.5.4" ;
    skos:prefLabel "Analyze customer metrics"@en .

<http://ots.local/thesaurus/apqc/3_3_5_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_5> ;
    skos:definition "Reviewing and reappraising the strategies, objectives, and plans for all customer-centered processes. Revisit all customer-focused processes and activities--which relate to their acquisition, conversion, and retention--with the objective of revising them in light of customer analysis. Revise accordingly."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.5.5" ;
    skos:prefLabel "Revise customer strategies, objectives, and plans based on metrics"@en .

<http://ots.local/thesaurus/apqc/3_3_6_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_6> ;
    skos:definition "Following postings on social media to promote offerings, raise brand awareness, interact with customers, increase customer engagement and brand loyalty, respond to queries, gauge sentiment regarding company's products or services, and to derive customer insight."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.6.1" ;
    skos:prefLabel "Monitor and respond to social media activity"@en .

<http://ots.local/thesaurus/apqc/3_3_6_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_6> ;
    skos:definition "Examining user activity on company, vendor or reseller websites to improve traffic on and to the website, improve user experience on the website to simplify purchasing process and encourage repeat purchases, and to increase the site's visibility in search engine results. Various metrics can be used to measure user activity, such as number of users who are new, returning or unique, time spent on page, session duration, bounce rate, click through rate, conversion rate, and others."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.6.2" ;
    skos:prefLabel "Analyze customer website activity"@en .

<http://ots.local/thesaurus/apqc/3_3_6_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_6> ;
    skos:definition "Conducting analyses to uncover customer purchasing habits. Detect patterns and categorize users based on similar characteristics and behaviors, demographic information, geographic location, search history, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.6.3" ;
    skos:prefLabel "Analyze customer purchase patterns"@en .

<http://ots.local/thesaurus/apqc/3_3_6_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_6> ;
    skos:definition "Creating formulas for personalized offers, purchasing recommendations and targeted advertisements for customers on the basis of previously detected purchase patterns [16615]."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.6.4" ;
    skos:prefLabel "Develop business rules to provide personalized offers"@en .

<http://ots.local/thesaurus/apqc/3_3_6_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_6> ;
    skos:definition "Analyzing how well the targeted offers perform to see whether they result in an increased conversion rate. Reanalyze the purchase patterns or modify those business rules that are produce effective recommendations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.6.5" ;
    skos:prefLabel "Monitor effectiveness of personalized offers and adjust offers accordingly"@en .

<http://ots.local/thesaurus/apqc/3_3_7_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_7> ;
    skos:definition "Creating a strategic road map for how to package products/services into desirable solutions while increasing profitability. Create a scheme for how the organization will bundle and wrap its products/services into a presentable and sellable offering. Consider what aspects or components of an offering the organization can extract the maximum revenue from, and reduce the less profitable constituents while maintaining a high perceptible value for the customers. Balance maximizing profit with benefits to the customer."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.7.1" ;
    skos:prefLabel "Plan packaging strategy"@en .

<http://ots.local/thesaurus/apqc/3_3_7_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_7> ;
    skos:definition "Piloting the packaged products/services in the market with a test audience. Create trial runs using techniques such as focus groups of the final product, wrapped and bundled."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.7.2" ;
    skos:prefLabel "Test packaging options"@en .

<http://ots.local/thesaurus/apqc/3_3_7_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_7> ;
    skos:definition "Implementing the final packaging. Put into action the packaging strategy in light of the insights accumulated from testing various options."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.7.3" ;
    skos:prefLabel "Execute packaging strategy"@en .

<http://ots.local/thesaurus/apqc/3_3_7_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_7> ;
    skos:definition "Fine-tuning the packaging that has been developed and tested using insights gleaned from feedback."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.7.4" ;
    skos:prefLabel "Refine packaging"@en .

<http://ots.local/thesaurus/apqc/3_3_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3> ;
    skos:definition "Creation of a plan detailing how a company plans to execute a successful product release and promotion, and ultimately its sale to customers."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.8" ;
    skos:prefLabel "Develop go-to-market strategy"@en .

<http://ots.local/thesaurus/apqc/3_3_9_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_9> ;
    skos:definition "Producing or overseeing the creation or acquisition of photos, images and graphics for a product description, advertisement or a website. Like the copy [18131], product images are chosen and edited to enhance the product description and to convince consumers to purchase the product."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.9.1" ;
    skos:prefLabel "Manage product images"@en .

<http://ots.local/thesaurus/apqc/3_3_9_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_3_9> ;
    skos:definition "Authoring or overseeing the creation of the textual portion of a product description, advertisement, or web page, including the headline, body, product attributes, and brand or advertiser information. A copy is designed to provide information about the product and to catch and hold the interest of prospective buyers long enough to persuade them to make a purchase. The copy of a website is called its content."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.3.9.2" ;
    skos:prefLabel "Manage product copy"@en .

<http://ots.local/thesaurus/apqc/3_4_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_4_1> ;
    skos:definition "Gathering all information about sales orders into an index. Create a directory of all sales orders, whether open or those which have been fulfilled. Track what product/service was ordered, the quantity ordered, who ordered it, the delivery date, the shipping method, the unit price and line total, payment terms, and any discount applied."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.4.1.1" ;
    skos:prefLabel "Gather current and historic order information"@en .

<http://ots.local/thesaurus/apqc/3_4_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_4_1> ;
    skos:definition "Analyzing sales order data to identify patterns in order to capitalize on emerging trends in the industry or the economy. Closely examine the directory of sales orders. Discern any patterns from this index, which is representative of the demand for the organization's offerings. Identify trends among the various segments of the organization's customer base to create forecasts. Glean patterns from this analysis, including the triangulation of segments that are showing the most growth in demand or those that represent the highest decline revenue, industry-wide trends such as decline/boost in overall demand, and any unusual trends that lie outside of the organization's expectations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.4.1.2" ;
    skos:prefLabel "Analyze sales trends and patterns"@en .

<http://ots.local/thesaurus/apqc/3_4_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_4_1> ;
    skos:definition "Calculating the future demand for the organization's products/services. Use the trends and patterns identified in the sales data to estimate future demand. Use forecast to prepare for future customer demand and to recalibrate the strategic course of functions and business units."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.4.1.3" ;
    skos:prefLabel "Generate sales forecast"@en .

<http://ots.local/thesaurus/apqc/3_4_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_4_1> ;
    skos:definition "Reviewing promotional activities' effect on the sales orders. Analyze all promotional events and campaigns that the organization has already employed or is planning to deploy."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.4.1.4" ;
    skos:prefLabel "Analyze historical and planned promotions and events"@en .

<http://ots.local/thesaurus/apqc/3_4_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_4_2> ;
    skos:definition "Identifying collaboration opportunities for selling, marketing, and distributing the organization's products/services. Determine any scope for partnering with other economic agents, with synergies for the marketing, sales, and/or distribution of the organization's products/services. Identify alliance opportunities that target customer segments who would be interested."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.4.2.1" ;
    skos:prefLabel "Identify alliance opportunities"@en .

<http://ots.local/thesaurus/apqc/3_4_2_10> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_4_2> ;
    skos:definition "Combining scheduled promotional, category management and trade marketing events into unified timetables. Update the calendars. Register new events."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.4.2.10" ;
    skos:prefLabel "Develop promotional and category management calendars (trade marketing calendars)"@en .

<http://ots.local/thesaurus/apqc/3_4_2_11> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_4_2> ;
    skos:definition "Establishing long term customer sales plans to assess current sales and to determine future sales objectives, strategies for achieving the goals, and available resources."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.4.2.11" ;
    skos:prefLabel "Create strategic and tactical sales plans by customer"@en .

<http://ots.local/thesaurus/apqc/3_4_2_12> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_4_2> ;
    skos:definition "Sending invitations and distributing information about upcoming events to customer teams and other involved entities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.4.2.12" ;
    skos:prefLabel "Communicate planning information to customer teams"@en .

<http://ots.local/thesaurus/apqc/3_4_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_4_2> ;
    skos:definition "Creating the frameworks needed to select alliance partners, and maintaining relationships with them. Create a framework for structured programs that can receive and support multiple alliances. Clearly outline the responsibilities and benefits of the alliance partners. Create frameworks for selecting the right alliance partners, and maintain a relationship with them. Create or repurpose teams of relationship managers and outline a methodology for selecting alliance partners."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.4.2.2" ;
    skos:prefLabel "Design alliance programs and methods for selecting and managing relationships"@en .

<http://ots.local/thesaurus/apqc/3_4_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_4_2> ;
    skos:definition "Choosing alliance partners using the selected programs and methodology. Select the most feasible and profitable alliance partners, based on Design alliance programs and methods for selecting and managing relationships [10139] and through a careful scrutiny of the potential alliance."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.4.2.3" ;
    skos:prefLabel "Select alliances"@en .

<http://ots.local/thesaurus/apqc/3_4_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_4_2> ;
    skos:definition "Implementing category management strategies for customers through the use of consumer insights and understanding of customer specifics. Develop consumer and channel insights. Establish long term strategies, objectives and targets across the brand."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.4.2.4" ;
    skos:prefLabel "Develop customer trade strategy and customer objectives/targets"@en .

<http://ots.local/thesaurus/apqc/3_4_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_4_2> ;
    skos:definition "Establishing business-to-business marketing campaigns and financial incentives for wholesalers, dealers, distributors and other intermediaries that the company uses to distribute its products or services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.4.2.5" ;
    skos:prefLabel "Define trade programs and funding options"@en .

<http://ots.local/thesaurus/apqc/3_4_2_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_4_2> ;
    skos:definition "Arranging meetings with trade partners to coordinate logistics, manage critical resources, resolve bottlenecks, and schedule urgent or time-sensitive matters."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.4.2.6" ;
    skos:prefLabel "Conduct planning activities for major trade customers"@en .

<http://ots.local/thesaurus/apqc/3_4_2_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_4_2> ;
    skos:definition "Designing strategies for effectively managing, identifying, and countering any possible issues from the alliance partnerships formed. Create a strategic road map for managing the partnerships forged through Design alliance programs and methods for selecting and managing relationships [10139]. Determine where the alliance partnerships are headed, possible problems or pushback from the partners, how these issues might be countered, how these alliance partnerships would evolve in the future, any other business cases where these partnerships might be deployed, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.4.2.7" ;
    skos:prefLabel "Develop partner and alliance management strategies"@en .

<http://ots.local/thesaurus/apqc/3_4_2_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_4_2> ;
    skos:definition "Setting targets for organizational achievement. This includes what the organization aims to achieve from and how it wishes to manage both the individual partners and the alliance as a whole. Set immediate through long-term goals including revenue targets, market penetration, footfall numbers, and geographical coverage."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.4.2.8" ;
    skos:prefLabel "Establish partner and alliance management goals"@en .

<http://ots.local/thesaurus/apqc/3_4_2_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_4_2> ;
    skos:definition "Setting up strategic alliances with key trade partners and ratifying partnership agreements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.4.2.9" ;
    skos:prefLabel "Establish partner and alliance agreements"@en .

<http://ots.local/thesaurus/apqc/3_4_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_4_3> ;
    skos:definition "Determining the percentage of total sales volume in the market for a particular product."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.4.3.1" ;
    skos:prefLabel "Calculate product market share"@en .

<http://ots.local/thesaurus/apqc/3_4_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_4_3> ;
    skos:definition "Estimating revenue from the sale of products/services. Approximate the anticipated sale of products/services and multiply it by the selling price of the respective offering. (This represents the total amount of money that the organization receives from the sale of its portfolio of offerings.)"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.4.3.2" ;
    skos:prefLabel "Calculate product revenue"@en .

<http://ots.local/thesaurus/apqc/3_4_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_4_3> ;
    skos:definition "Calculating the variable costs of production. Approximate those costs that depend on the volume of products/services produced by the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.4.3.3" ;
    skos:prefLabel "Determine variable costs"@en .

<http://ots.local/thesaurus/apqc/3_4_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_4_3> ;
    skos:definition "Calculating the overhead costs associated with selling the organization's products/services. Determine fixed costs that are not directly related to the volume of products/services processed or the sale of these offerings (e.g., expense over machinery and equipment)."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.4.3.4" ;
    skos:prefLabel "Determine overhead and fixed costs"@en .

<http://ots.local/thesaurus/apqc/3_4_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_4_3> ;
    skos:definition "Calculating the net income. Calculate the organization's profitability by accounting for Determine overhead and fixed costs [10145] and Determine variable costs [10144]."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.4.3.5" ;
    skos:prefLabel "Calculate net profit"@en .

<http://ots.local/thesaurus/apqc/3_4_3_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_4_3> ;
    skos:definition "Creating a plan in measurable terms for the financial outlay that best captures resource allocation for the sales forecast. Consider the outlay of capital, HR, raw materials, and provisions needed to reach sales targets."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.4.3.6" ;
    skos:prefLabel "Create budget"@en .

<http://ots.local/thesaurus/apqc/3_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_4> ;
    skos:definition "Establishing specific quantitative and qualitative measures of realizing sales targets. Create sales targets by analyzing historical sales data and comparing the forecasts to results, in light of customer and market intelligence. Examine the performance of sales personnel in light of market opportunities. Based on this review, establish sales targets along with metrics to quantify these goals, corresponding with the overall business strategy."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.4.4" ;
    skos:prefLabel "Establish sales goals and measures"@en .

<http://ots.local/thesaurus/apqc/3_4_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_4> ;
    skos:definition "Identifying the appropriate measures that can represent key attributes of the customer management function. Select measures to track customer activity, feedback, satisfaction, organizational responsiveness to customer needs, and general data on how the organization is managing customer accounts, leads, and contacts. Build on customer and market intelligence to identify metrics gauging aspects related to customer management. Select measures based on the nature of the business, the type and size of customer base, strategic goals, and the model used to structure sales and customer relationships."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.4.5" ;
    skos:prefLabel "Establish customer management measures"@en .

<http://ots.local/thesaurus/apqc/3_5_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_1> ;
    skos:definition "Identifying people who can be converted into customers. Leverage personal and professional networks, business research over databases and directories, and secondary research."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.1.1" ;
    skos:prefLabel "Identify potential customers"@en .

<http://ots.local/thesaurus/apqc/3_5_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_1> ;
    skos:definition "Qualifying the prospective customers into credible leads by gauging their behavior against the organization's offering. Triangulate leads to increase the efficiency of sales and marketing efforts. Build a detailed profile of the prospects. Determine what products/services they already use, if they have decision-making authority, their views on the products/services they already use, how prone they are to switch, if the organization's solution better in some attributes than those prospects currently use, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.1.2" ;
    skos:prefLabel "Identify/receive leads/opportunities"@en .

<http://ots.local/thesaurus/apqc/3_5_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_1> ;
    skos:definition "Reviewing the set of potential customers and sales opportunities. Approve the leads that meet company requirements on new businesses."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.1.3" ;
    skos:prefLabel "Validate and qualify leads/opportunities"@en .

<http://ots.local/thesaurus/apqc/3_5_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_1> ;
    skos:definition "Aligning sales leads with business objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.1.4" ;
    skos:prefLabel "Match opportunities to business strategy"@en .

<http://ots.local/thesaurus/apqc/3_5_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_1> ;
    skos:definition "Creating plans about how to close leads and win sales opportunities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.1.5" ;
    skos:prefLabel "Develop opportunity win plans"@en .

<http://ots.local/thesaurus/apqc/3_5_1_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_1> ;
    skos:definition "Overseeing and planning the acquisition of new customers."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.1.6" ;
    skos:prefLabel "Manage opportunity pipeline"@en .

<http://ots.local/thesaurus/apqc/3_5_1_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_1> ;
    skos:definition "Planning the distribution of personnel across various sales functions. Match the capabilities of individual employees with the skill sets needed for specific roles. Seek assistance from HR."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.1.7" ;
    skos:prefLabel "Determine sales resource allocation"@en .

<http://ots.local/thesaurus/apqc/3_5_1_8_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_1_8> ;
    skos:definition "Communicating with customers and prospects with the intent of creating sales opportunities. Reach out to existing and prospective customers through alternate media and networking channels, apart from cold calling/emailing."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.1.8.1" ;
    skos:prefLabel "Perform sales calls"@en .

<http://ots.local/thesaurus/apqc/3_5_1_8_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_1_8> ;
    skos:definition "Capitalizing on sales calls by pitching on bids and closing deals. Outline the nature and scope of the work, draft agreement terms, prepare proposals and agreements, and propose timelines and prices."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.1.8.2" ;
    skos:prefLabel "Perform pre-sales activities"@en .

<http://ots.local/thesaurus/apqc/3_5_1_8_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_1_8> ;
    skos:definition "Arranging and leading meetings, seminars, workshops and training events with customers to educate them about current offerings, best practices and technological advances to provide more value to customers and to increase their attrition and loyalty."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.1.8.3" ;
    skos:prefLabel "Manage customer meetings/workshops"@en .

<http://ots.local/thesaurus/apqc/3_5_1_8_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_1_8> ;
    skos:definition "Formalizing a sale by reaching an agreement on terms of the deal. Negotiate on the price, and reach a consensus on the terms and conditions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.1.8.4" ;
    skos:prefLabel "Close the sale"@en .

<http://ots.local/thesaurus/apqc/3_5_1_8_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_1_8> ;
    skos:definition "Completing all the paper-work associated with the sale of its products/services. Exchange any pertinent legal/financial information required for completing the sale, signing of a contract/work-order, and issuing copies of bills/invoices."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.1.8.5" ;
    skos:prefLabel "Record outcome of sales process"@en .

<http://ots.local/thesaurus/apqc/3_5_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_2> ;
    skos:definition "Choosing principal clients that are vital for the company."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.2.1" ;
    skos:prefLabel "Select key customers/accounts"@en .

<http://ots.local/thesaurus/apqc/3_5_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_2> ;
    skos:definition "Creating a plan for managing the accounts of key customers in order to better maintain relationships with them. Chart a scheme for managing sales. Create a plan for administering accounts of the significant and most important customers of the organization. Coordinate the accounts of principal clients."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.2.2" ;
    skos:prefLabel "Develop sales/key account plan"@en .

<http://ots.local/thesaurus/apqc/3_5_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_2> ;
    skos:definition "Handling the accounts of important clients."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.2.3" ;
    skos:prefLabel "Manage sales/key account plan"@en .

<http://ots.local/thesaurus/apqc/3_5_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_2> ;
    skos:definition "Managing the organization's relationship with its customers, by systematically coordinating interactions over multiple touch points, on a regular basis. Coordinate the organization's efforts to reach out to its customers. Create and manage effective touch points for interactions from the customers, which could include emails, social-media interactions, newsletters, and direct conversations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.2.4" ;
    skos:prefLabel "Manage customer relationships"@en .

<http://ots.local/thesaurus/apqc/3_5_2_5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_2_5> ;
    skos:definition "Gathering the data about customers. Combine the information available locally with the data obtained from external sources."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.2.5.1" ;
    skos:prefLabel "Collect and merge internal and third-party customer information"@en .

<http://ots.local/thesaurus/apqc/3_5_2_5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_2_5> ;
    skos:definition "Eliminating redundant information in customer data."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.2.5.2" ;
    skos:prefLabel "De-duplicate customer data"@en .

<http://ots.local/thesaurus/apqc/3_5_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_3> ;
    skos:definition "Accepting procurement proposals."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.3.1" ;
    skos:prefLabel "Receive Request For Proposal (RFP)/Request For Quote (RFQ)"@en .

<http://ots.local/thesaurus/apqc/3_5_3_10> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_3> ;
    skos:definition "Reviewing profitability data. Analyze systematically all relevant metrics and parameters. Report findings and make recommendations for changes to operational strategies."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.3.10" ;
    skos:prefLabel "Conduct profitability analysis"@en .

<http://ots.local/thesaurus/apqc/3_5_3_11> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_3> ;
    skos:definition "Overseeing the internal review process."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.3.11" ;
    skos:prefLabel "Manage internal reviews"@en .

<http://ots.local/thesaurus/apqc/3_5_3_12> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_3> ;
    skos:definition "Obtaining required company-internal authorizations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.3.12" ;
    skos:prefLabel "Manage internal approvals"@en .

<http://ots.local/thesaurus/apqc/3_5_3_13> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_3> ;
    skos:definition "Delivering the proposal to the potential client."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.3.13" ;
    skos:prefLabel "Submit/present bid/proposal/quote to customer"@en .

<http://ots.local/thesaurus/apqc/3_5_3_14> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_3> ;
    skos:definition "Amending bids, proposals or quotes with more accurate time, cost or delivery estimates."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.3.14" ;
    skos:prefLabel "Revise bid/proposal/quote"@en .

<http://ots.local/thesaurus/apqc/3_5_3_15> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_3> ;
    skos:definition "Handling proposals depending on whether they were accepted or rejected."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.3.15" ;
    skos:prefLabel "Manage notification outcome"@en .

<http://ots.local/thesaurus/apqc/3_5_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_3> ;
    skos:definition "Clarifying the details about procurement requests, such as the scope, timeline, data sources, type and characteristics and evaluation criteria for the goods or services to be delivered, and any additional terms, conditions or special requirements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.3.2" ;
    skos:prefLabel "Refine customer requirements"@en .

<http://ots.local/thesaurus/apqc/3_5_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_3> ;
    skos:definition "Evaluating individual price and delivery solicitations for their strengths and weaknesses. Analyze how closely the submitted bids respond to the requirements outlined in the RFPs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.3.3" ;
    skos:prefLabel "Review RFP/RFQ request"@en .

<http://ots.local/thesaurus/apqc/3_5_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_3> ;
    skos:definition "Comparing the proposals submitted by different bidders in terms of cost, efficiency and value."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.3.4" ;
    skos:prefLabel "Perform competitive analysis"@en .

<http://ots.local/thesaurus/apqc/3_5_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_3> ;
    skos:definition "Assessing the business strategy, forecasted performance, financing and cash flow of the proposals."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.3.5" ;
    skos:prefLabel "Validate with strategy/business plans"@en .

<http://ots.local/thesaurus/apqc/3_5_3_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_3> ;
    skos:definition "Deepening knowledge about the customer's field of operation and business needs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.3.6" ;
    skos:prefLabel "Understand customer business and requirements"@en .

<http://ots.local/thesaurus/apqc/3_5_3_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_3> ;
    skos:definition "Creating a plan with detailed steps about how produce and deliver the goods or services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.3.7" ;
    skos:prefLabel "Develop solution and delivery approach"@en .

<http://ots.local/thesaurus/apqc/3_5_3_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_3> ;
    skos:definition "Determining the needs for internal resources and vacancies."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.3.8" ;
    skos:prefLabel "Identify staffing requirements"@en .

<http://ots.local/thesaurus/apqc/3_5_3_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_3> ;
    skos:definition "Establishing predicted delivery costs, fees and timelines."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.3.9" ;
    skos:prefLabel "Develop pricing and scheduling estimates"@en .

<http://ots.local/thesaurus/apqc/3_5_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_4> ;
    skos:definition "Receiving and confirming orders from customers. Verify that no extra expenses have to be disbursed on part of the organization for labor or inventory when processing the order."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.4.1" ;
    skos:prefLabel "Accept and validate sales orders"@en .

<http://ots.local/thesaurus/apqc/3_5_4_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_4_2> ;
    skos:definition "Managing essential information of customer accounts."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.4.2.1" ;
    skos:prefLabel "Administer key account details"@en .

<http://ots.local/thesaurus/apqc/3_5_4_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_4_2> ;
    skos:definition "Obtaining detailed information about customers."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.4.2.2" ;
    skos:prefLabel "Retrieve full customer details"@en .

<http://ots.local/thesaurus/apqc/3_5_4_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_4_2> ;
    skos:definition "Altering information about involved parties."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.4.2.3" ;
    skos:prefLabel "Modify involved party details"@en .

<http://ots.local/thesaurus/apqc/3_5_4_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_4_2> ;
    skos:definition "Documenting address information."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.4.2.4" ;
    skos:prefLabel "Record address details"@en .

<http://ots.local/thesaurus/apqc/3_5_4_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_4_2> ;
    skos:definition "Documenting contact information."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.4.2.5" ;
    skos:prefLabel "Record contact details"@en .

<http://ots.local/thesaurus/apqc/3_5_4_2_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_4_2> ;
    skos:definition "Providing information about important business rules regarding communicating with customers."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.4.2.6" ;
    skos:prefLabel "Record key customer communication profile details"@en .

<http://ots.local/thesaurus/apqc/3_5_4_2_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_4_2> ;
    skos:definition "Revising information about involved parties."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.4.2.7" ;
    skos:prefLabel "Review involved party information"@en .

<http://ots.local/thesaurus/apqc/3_5_4_2_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_4_2> ;
    skos:definition "Dismissing information about involved parties."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.4.2.8" ;
    skos:prefLabel "Terminate involved party information"@en .

<http://ots.local/thesaurus/apqc/3_5_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_4> ;
    skos:definition "Ascertaining the volume or scale of products/services to provide to customers to fulfill sales orders. Check the finished products stored in warehouses, the production capacity, and (in the case of services) the processing speed, as well as work force availability."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.4.3" ;
    skos:prefLabel "Determine availability"@en .

<http://ots.local/thesaurus/apqc/3_5_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_4> ;
    skos:definition "Devising a blueprint for order fulfillment. Create a schematic flow encompassing all activities to deliver orders to the customers. Outline a procedure for satisfying these orders by answering questions about what needs to happen in sequence to realize an order."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.4.4" ;
    skos:prefLabel "Determine fulfillment process"@en .

<http://ots.local/thesaurus/apqc/3_5_4_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_4> ;
    skos:definition "Processing any unfulfilled orders, and updating the status of any orders that have been accepted and are being attended to. Deliver on any purchase orders that remain unserviced due to temporary unavailability of the product/service. Manage any updates to the sales orders. Revise their status in the order system."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.4.5" ;
    skos:prefLabel "Process back orders and updates"@en .

<http://ots.local/thesaurus/apqc/3_5_4_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_4> ;
    skos:definition "Attending to any queries received from the customers, even after a sales order has been serviced. Deploy ad hoc personnel for managing these enquiries."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.4.6" ;
    skos:prefLabel "Handle sales order inquiries including post-order fulfillment transactions"@en .

<http://ots.local/thesaurus/apqc/3_5_4_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_4> ;
    skos:definition "Providing visibility into the status and progress of products associated with customer orders to support order fulfillment, customer communication, and issue resolution."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.4.7" ;
    skos:prefLabel "Provide product tracking"@en .

<http://ots.local/thesaurus/apqc/3_5_5_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_5_1> ;
    skos:definition "Provide training and certification to develop strategies for marketing-driven sales."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.5.1.1" ;
    skos:prefLabel "Provide certification enablement training"@en .

<http://ots.local/thesaurus/apqc/3_5_5_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_5_1> ;
    skos:definition "Reviewing, processing and issuing certifications and accrediting skills and competencies."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.5.1.2" ;
    skos:prefLabel "Manage certifications and skills"@en .

<http://ots.local/thesaurus/apqc/3_5_5_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_5_1> ;
    skos:definition "Backing sales partners and strategic alliances."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.5.1.3" ;
    skos:prefLabel "Provide support to partners/alliances"@en .

<http://ots.local/thesaurus/apqc/3_5_5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_5> ;
    skos:definition "Distributing marketing materials and sales brochures to entities that the company partners with."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.5.2" ;
    skos:prefLabel "Provide marketing materials to sales partners/alliances"@en .

<http://ots.local/thesaurus/apqc/3_5_5_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_5> ;
    skos:definition "Examining the performance of its partners/alliances in selling its products/services. Use metrics such as growth in revenue generated, conversion rate, and total outreach to customers for assessing the performance results."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.5.3" ;
    skos:prefLabel "Evaluate partner/alliance results"@en .

<http://ots.local/thesaurus/apqc/3_5_5_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5_5> ;
    skos:definition "Managing the repository of data relating to the organization's partners/alliances over time. Store, maintain, access, revise, and use all data on partners/alliances. Manage data. Ensure its security. Determine legitimate use cases that are beneficial to the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.5.4" ;
    skos:prefLabel "Manage sales partner/alliance master data"@en .

<http://ots.local/thesaurus/apqc/3_5_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5> ;
    skos:definition "Execution of sales at physical / brick and mortar locations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.6" ;
    skos:prefLabel "Perform sales at physical outlets"@en .

<http://ots.local/thesaurus/apqc/3_5_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5> ;
    skos:definition "Execution of sales within field/remote locations.  This could be any location that is not part of a headquarters location."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.7" ;
    skos:prefLabel "Perform field sales"@en .

<http://ots.local/thesaurus/apqc/3_5_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/3_5> ;
    skos:definition "Execution of sales in an online environment."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "3.5.8" ;
    skos:prefLabel "Perform digital sales"@en .

<http://ots.local/thesaurus/apqc/4_1_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_1> ;
    skos:definition "Creating quantifiable strategic objectives for each manufacturing segment in conjunction with sales projections."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.1.1" ;
    skos:prefLabel "Define manufacturing goals"@en .

<http://ots.local/thesaurus/apqc/4_1_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_1> ;
    skos:definition "Setting up internal rules and regulations regarding the employees and the materials."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.1.2" ;
    skos:prefLabel "Define labor and materials policies"@en .

<http://ots.local/thesaurus/apqc/4_1_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_1> ;
    skos:definition "Creating rules and regulations regarding contracting out of a business process to another party in order to reduce costs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.1.3" ;
    skos:prefLabel "Define outsourcing policies"@en .

<http://ots.local/thesaurus/apqc/4_1_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_1> ;
    skos:definition "Designing rules and regulations pertaining to the expenditure incurred in acquiring or upgrading the existing stock of manufacturing capital."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.1.4" ;
    skos:prefLabel "Define capital expense policies"@en .

<http://ots.local/thesaurus/apqc/4_1_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_1> ;
    skos:definition "Outlining the manufacturing and processing capacities of the organization. Delineate the capabilities required for optimizing output with available resources. Analyze capabilities possessed by the organization concerning the raw materials required and the process necessitated for producing finished products."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.1.5" ;
    skos:prefLabel "Define capacities"@en .

<http://ots.local/thesaurus/apqc/4_1_1_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_1> ;
    skos:definition "Defining limitations in the ability of the organization's supply chain to deliver a new stock, and creating a network of production stakeholders. Frame and manage relationships within the flow of manufacturing and processing operations. Identify probable supply issues."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.1.6" ;
    skos:prefLabel "Define production network and supply constraints"@en .

<http://ots.local/thesaurus/apqc/4_1_1_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_1> ;
    skos:definition "Outlining the scheme of processing inventory into finished products/services. This includes the use of raw materials, machinery, skill sets, and knowledge to create new offerings."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.1.7" ;
    skos:prefLabel "Define production process"@en .

<http://ots.local/thesaurus/apqc/4_1_1_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_1> ;
    skos:definition "Establishing or prescribing methods to be followed routinely for the performance of designated operations or in designated situations. This may include step-by-step instructions to help workers carry out complex routine operations. The goal is to improve efficiency, quality, and uniformity of performance, while reducing miscommunication, failure, or rework."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.1.8" ;
    skos:prefLabel "Define standard operating procedures"@en .

<http://ots.local/thesaurus/apqc/4_1_1_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_1> ;
    skos:definition "Determining the floor plans for the processing facility that is meant for delivering finished products/services. Identify the totality of infrastructure needed for using this space in the manufacturing process, including machinery, factory floors, offices, and furniture."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.1.9" ;
    skos:prefLabel "Define production workplace layout and infrastructure"@en .

<http://ots.local/thesaurus/apqc/4_1_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_2> ;
    skos:definition "Identify the bedrock levels of market demand anticipated for the organization's products/services. Estimate future demand for product and services using historical data, analysis of the market environment and any externalities, etc. to create ex ante approximations. This includes operation planning."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.2.1" ;
    skos:prefLabel "Develop baseline demand forecasts"@en .

<http://ots.local/thesaurus/apqc/4_1_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_2> ;
    skos:definition "Working closely with the organization's customers to understand their drives and behavior, with the objective of estimating future demand. Reach out to customers through various means to understand their behavior patterns, usage elasticity, and degree of variability--and ultimately determine demand for each offering."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.2.2" ;
    skos:prefLabel "Collaborate demand with customers"@en .

<http://ots.local/thesaurus/apqc/4_1_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_2> ;
    skos:definition "Arriving at a consensus over the forecasted levels of demand for products/services. Consensus is achieved by juxtaposing decisions developed in the baseline forecast with those reached at by collaborating with customers. Enlist senior-level decision makers of the sales and marketing functions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.2.3" ;
    skos:prefLabel "Develop demand consensus forecast"@en .

<http://ots.local/thesaurus/apqc/4_1_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_2> ;
    skos:definition "Identify the volume of products/services that may be committed for delivery to fulfill sales. Figure out the amount of stock available. Forecast its volumes."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.2.4" ;
    skos:prefLabel "Determine available to promise"@en .

<http://ots.local/thesaurus/apqc/4_1_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_2> ;
    skos:definition "Picking out any activity that deviates from the forecast, and adjusting it. Closely track and study the levels of demand as they emerge. Refine the consensus forecast as needed."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.2.5" ;
    skos:prefLabel "Monitor activity against demand forecast and revise forecast"@en .

<http://ots.local/thesaurus/apqc/4_1_2_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_2> ;
    skos:definition "Examining the methodology used to estimate future demand. Refine it in light of current market realities and demand."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.2.6" ;
    skos:prefLabel "Evaluate and revise demand forecasting approach"@en .

<http://ots.local/thesaurus/apqc/4_1_2_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_2> ;
    skos:definition "Calculating and inspecting the accuracy of demand forecasts. Use metrics to check the reliability of the forecasts created."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.2.7" ;
    skos:prefLabel "Measure demand forecast accuracy"@en .

<http://ots.local/thesaurus/apqc/4_1_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_3> ;
    skos:definition "Developing a plan for raw materials and other inventory items in order to meet market demand. Ensure the availability of all inventory items such as raw materials and spares. Create a blueprint in line with Define labor and materials policies [10230]."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.3.1" ;
    skos:prefLabel "Create unconstrained plan"@en .

<http://ots.local/thesaurus/apqc/4_1_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_3> ;
    skos:definition "Collaborating with vendors and contractual manufacturers with the objective of ensuring a continual supply of raw materials and spares. Leverage long-term connections/relationships with various suppliers, and cultivate new ones. Track the activities of all vendors. Receive regular updates to prepare for any fluctuations in supply."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.3.2" ;
    skos:prefLabel "Collaborate with supplier and contract manufacturers"@en .

<http://ots.local/thesaurus/apqc/4_1_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_3> ;
    skos:definition "Identifying principal materials needed for the manufacturing process and the levels of supply that may be ensured for them. Determine the essential and crucial inventory items required for the smooth functioning of all manufacturing processes. Estimate the average, peak, and baseline capacities of various vendors and suppliers. Establish the capability of individual suppliers from the market and the vendors."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.3.3" ;
    skos:prefLabel "Identify critical materials and supplier capacity"@en .

<http://ots.local/thesaurus/apqc/4_1_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_3> ;
    skos:definition "Observing and surveying all inventory items in order to check for the veracity of their specifications. Monitor various attributes and characteristics for respective inventory items such as density, volume, and size, as well as contextualized specifications particular to the respective materials."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.3.4" ;
    skos:prefLabel "Monitor material specifications"@en .

<http://ots.local/thesaurus/apqc/4_1_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_3> ;
    skos:definition "Generating a bounded plan that takes stock of the actual supply chain scenario. Take stock of all information collected while creating an inventory supply plan."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.3.5" ;
    skos:prefLabel "Generate constrained plan"@en .

<http://ots.local/thesaurus/apqc/4_1_3_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_3> ;
    skos:definition "Defining an equitable volume for the production of products/services that adheres to an equilibrium value, and creating a scheme of control for processing items. Create schematics for systematically planning, coordinating, and directing the manufacturing activities in line with the production balance determined."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.3.6" ;
    skos:prefLabel "Define production balance and control"@en .

<http://ots.local/thesaurus/apqc/4_1_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_4> ;
    skos:definition "Create representative logical system that provides the framework to attain strategic objectives based on resources, product volumes, and processes. Provides the general sequential flow and capacity requirement relationships among raw materials, parts, resources, finished products, and product families."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.4.1" ;
    skos:prefLabel "Model production network to enable simulation and optimization"@en .

<http://ots.local/thesaurus/apqc/4_1_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_4> ;
    skos:definition "Creating  the plan for internal activities such as production, inventory, and staffing. Include forecasted quantity of items to produce based on inputs from sales planning, demand planning/forecasting, and supply chain partners."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.4.2" ;
    skos:prefLabel "Create master production schedule"@en .

<http://ots.local/thesaurus/apqc/4_1_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_4> ;
    skos:definition "Supervising and overseeing the plan for internal activities such as production, inventory, and staffing. Set the quantity of items to produce each week of a short-range planning horizon."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.4.3" ;
    skos:prefLabel "Maintain master production schedule"@en .

<http://ots.local/thesaurus/apqc/4_1_5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_5> ;
    skos:definition "Maintaining and preserving the master data plan for distribution requirements. Create a systematic collection of facts and figures regarding the distribution of the inventories. Maintain policies, processes, and tools covering the distribution function."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.5.1" ;
    skos:prefLabel "Maintain master data"@en .

<http://ots.local/thesaurus/apqc/4_1_5_10> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_5> ;
    skos:definition "Administering the load plan for partners. Manage the delivery, and dispatch from the source to the partners."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.5.10" ;
    skos:prefLabel "Manage partner load plan"@en .

<http://ots.local/thesaurus/apqc/4_1_5_11> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_5> ;
    skos:definition "Managing all expenses to provide products/services in the market. Estimate the overall cost of supplying of products/inventory, including the cost distributing it through various partners and channels. Consider the cost of all the logistical processes that occur from the moment a product is ready to be dispatched to the time it reaches the destination."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.5.11" ;
    skos:prefLabel "Manage cost of supply"@en .

<http://ots.local/thesaurus/apqc/4_1_5_12> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_5> ;
    skos:definition "Determining the capacity utilization of the organization's production process. Realize the extent to which an enterprise uses its installed productive capacity (i.e., the relationship between output and the potential output if capacity was fully used)."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.5.12" ;
    skos:prefLabel "Manage capacity utilization"@en .

<http://ots.local/thesaurus/apqc/4_1_5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_5> ;
    skos:definition "Interact with the concerned person at the destination to validate the requirements and to avoid any miscommunication of information."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.5.2" ;
    skos:prefLabel "Determine finished goods inventory requirements at destination"@en .

<http://ots.local/thesaurus/apqc/4_1_5_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_5> ;
    skos:definition "Evaluate constraints, needs, parameters, and conditions for physical storage and retrieval of components or products for future use or shipment in a storage facility within a certain timeframe."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.5.3" ;
    skos:prefLabel "Determine product storage facility requirements"@en .

<http://ots.local/thesaurus/apqc/4_1_5_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_5> ;
    skos:definition "Interact with the concerned authority at the destination to reach a specific figure that correctly represents requirements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.5.4" ;
    skos:prefLabel "Calculate requirements at destination"@en .

<http://ots.local/thesaurus/apqc/4_1_5_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_5> ;
    skos:definition "Determining the aggregate volume of products/services consolidated at the source. Calculate the number of finished products that are ready to be delivered to the customers, particularly at one date."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.5.5" ;
    skos:prefLabel "Calculate consolidation at source"@en .

<http://ots.local/thesaurus/apqc/4_1_5_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_5> ;
    skos:definition "Administering the plan for collaborative replenishment of goods. Replenish inventory by creating a plan in case of faulty production."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.5.6" ;
    skos:prefLabel "Manage collaborative replenishment planning"@en .

<http://ots.local/thesaurus/apqc/4_1_5_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_5> ;
    skos:definition "Estimating the timing and duration of the delivery of the inventory from the source to the destination. Plan the logistic details of all the distribution routes and activities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.5.7" ;
    skos:prefLabel "Calculate and optimize destination dispatch plan"@en .

<http://ots.local/thesaurus/apqc/4_1_5_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_5> ;
    skos:definition "Accomplishing the dispatch plan. Strictly follow the schedule, and adjust for deviations. Coordinate with the concerned authorities at various destinations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.5.8" ;
    skos:prefLabel "Manage dispatch plan attainment"@en .

<http://ots.local/thesaurus/apqc/4_1_5_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_5> ;
    skos:definition "Evaluating the plans for delivering loads to destinations. Create a systematic plan that specifies the load plans for every single destination."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.5.9" ;
    skos:prefLabel "Calculate and optimize destination load plans"@en .

<http://ots.local/thesaurus/apqc/4_1_6_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_6> ;
    skos:definition "Instituting the constraints for creating a layout for distribution center. Consider factors such as the number of customers, demand forecasting, product groups, condition of product conservation, warehousing, and transportation management."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.6.1" ;
    skos:prefLabel "Establish distribution center layout constraints"@en .

<http://ots.local/thesaurus/apqc/4_1_6_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_6> ;
    skos:definition "Determining any problems that might be faced while managing inventory. Identify problems and possible issues in managing the warehousing of the raw materials, spares, and other items of inventory. Take stock of inventory needs, and determine the exact quantity of the inventory needed in the near future."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.6.2" ;
    skos:prefLabel "Establish inventory management constraints"@en .

<http://ots.local/thesaurus/apqc/4_1_6_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_6> ;
    skos:definition "Identifying any potential constraints while deciding on the dispatch and delivery plan from the source to the various distribution centers. Decide how the inventory will be transported , which and how many transportation means to use, what route to take, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.6.3" ;
    skos:prefLabel "Establish transportation management constraints"@en .

<http://ots.local/thesaurus/apqc/4_1_6_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_6> ;
    skos:definition "Determining potential constraints for physical storage and retrieval of components or products in a storage facility within a certain timeframe. Consider factors such as the building shape, height, capacity, door locations, lift equipment, automation, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.6.4" ;
    skos:prefLabel "Establish storage management constraints"@en .

<http://ots.local/thesaurus/apqc/4_1_7_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_7> ;
    skos:definition "Evaluating the system that defines how the products/inventory would reach from the source (i.e., manufacturer) to the destination (i.e., retailer/distributer)."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.7.1" ;
    skos:prefLabel "Review distribution network"@en .

<http://ots.local/thesaurus/apqc/4_1_7_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_7> ;
    skos:definition "Establishing relationships with transportation/distribution sources in order to ensure an effective distribution network and strategy. Screen and evaluate various sources available to pick out the best among them."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.7.2" ;
    skos:prefLabel "Establish sourcing relationships"@en .

<http://ots.local/thesaurus/apqc/4_1_7_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_7> ;
    skos:definition "Creating strategic guidelines on the availability of the products at all the distribution centers. Create a dynamic network to ensure availability at all times, even in cases of defaults."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.7.3" ;
    skos:prefLabel "Establish dynamic deployment policies"@en .

<http://ots.local/thesaurus/apqc/4_1_8_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_8> ;
    skos:definition "Defining specific qualitative and quantitative target figures."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.8.1" ;
    skos:prefLabel "Establish quality targets"@en .

<http://ots.local/thesaurus/apqc/4_1_8_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_8> ;
    skos:definition "Creating standard procedures for testing the quality of products/services. Describe the steps of key processes to help ensure consistent and quality output. Define the routine instructions for performing the quality testing activity."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.8.2" ;
    skos:prefLabel "Develop standard testing procedures"@en .

<http://ots.local/thesaurus/apqc/4_1_8_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_1_8> ;
    skos:definition "Communicating the desired quality specifications to the manufacturing units, as well as the distribution centers, to avoid any misunderstanding or misinterpretation."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.1.8.3" ;
    skos:prefLabel "Communicate quality specifications"@en .

<http://ots.local/thesaurus/apqc/4_2_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_2_1> ;
    skos:definition "Creating a plan for procuring materials and services. Plan what to buy, when, and from what sources. Include project requirements, the procurement team, the justification for the procurement, a timeline of events, and an explanation of the supplier selection process. Outline specific actions to start and complete purchases in order to adhere to best practices."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.2.1.1" ;
    skos:prefLabel "Develop procurement plan"@en .

<http://ots.local/thesaurus/apqc/4_2_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_2_1> ;
    skos:definition "Defining the purchasing requirements for materials and services. Specify the exact inventory required for the production process. Create a specific quotation for all the sources in order to avoid any duplication or overlap."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.2.1.2" ;
    skos:prefLabel "Clarify purchasing requirements"@en .

<http://ots.local/thesaurus/apqc/4_2_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_2_1> ;
    skos:definition "Developing a strategy to deal with issues projected to arise during implementation of the inventory plan. Identify how to react to issues that arise and require changes to the inventory plan, such as a vendor failing to deliver materials on time. Collaborate with production and suppliers to prepare solutions to projected problems."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.2.1.3" ;
    skos:prefLabel "Establish materials management contingency plans"@en .

<http://ots.local/thesaurus/apqc/4_2_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_2_1> ;
    skos:definition "Synchronizing the requirements of materials and services and the capacity of suppliers for providing these materials and services. Revamp the procurement needs of the company in consideration of the capabilities of the suppliers."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.2.1.4" ;
    skos:prefLabel "Match needs to supply capabilities"@en .

<http://ots.local/thesaurus/apqc/4_2_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_2_1> ;
    skos:definition "Evaluating the spend profile of the organization. Collect, cleanse, classify, and analyze the procurement data with the purpose of reducing procurement costs, improving efficiency, and monitoring compliance."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.2.1.5" ;
    skos:prefLabel "Analyze organization’s spend profile"@en .

<http://ots.local/thesaurus/apqc/4_2_1_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_2_1> ;
    skos:definition "Seeking the most efficient sourcing and procurement opportunities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.2.1.6" ;
    skos:prefLabel "Seek opportunities to improve efficiency and value"@en .

<http://ots.local/thesaurus/apqc/4_2_1_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_2_1> ;
    skos:definition "Collaborating with the suppliers of materials and services in order to determine new opportunities for sourcing, share market insights, manage risk, identify and align supplier capabilities with long-term business goals."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.2.1.7" ;
    skos:prefLabel "Collaborate with suppliers to align with long term business goals"@en .

<http://ots.local/thesaurus/apqc/4_2_1_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_2_1> ;
    skos:definition "Collaborating with the suppliers of materials and services in order to determine new opportunities for sourcing."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.2.1.8" ;
    skos:prefLabel "Collaborate with suppliers to identify sourcing opportunities"@en .

<http://ots.local/thesaurus/apqc/4_2_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_2_2> ;
    skos:definition "Analyzing the position and performance of sourcing categories or products based on spend, supplier dynamics, market conditions, and value contribution to inform category planning decisions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.2.2.1" ;
    skos:prefLabel "Analyze category/product positioning and performance"@en .

<http://ots.local/thesaurus/apqc/4_2_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_2_2> ;
    skos:definition "Forecasting demand for sourcing categories across relevant markets or consumption channels to support planning, supplier strategy, and capacity alignment."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.2.2.2" ;
    skos:prefLabel "Forecast demand for each category by market"@en .

<http://ots.local/thesaurus/apqc/4_2_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_2_2> ;
    skos:definition "Establishing revenue, cost, and margin targets for sourcing categories to guide category strategy, sourcing decisions, and performance evaluation."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.2.2.3" ;
    skos:prefLabel "Assign revenue and margin targets to each category"@en .

<http://ots.local/thesaurus/apqc/4_2_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_2_3> ;
    skos:definition "Evaluating the pros and cons of various suppliers. Choose the most appropriate and cost-effective suppliers on the basis of their material quality, delivery schedules, and costs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.2.3.1" ;
    skos:prefLabel "Select suppliers"@en .

<http://ots.local/thesaurus/apqc/4_2_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_2_3> ;
    skos:definition "Validating the supply sources, and provide certification as an official supplier."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.2.3.2" ;
    skos:prefLabel "Certify and validate suppliers"@en .

<http://ots.local/thesaurus/apqc/4_2_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_2_3> ;
    skos:definition "Legally binding suppliers with the company. Negotiate contracts individually with all the suppliers that include the promised material delivery, the delivery dates and duration, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.2.3.3" ;
    skos:prefLabel "Negotiate and establish contracts"@en .

<http://ots.local/thesaurus/apqc/4_2_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_2_3> ;
    skos:definition "Keeping contracts up-to-date with routine evaluation. Maintain order and discipline with the contracts in order to avoid any loss of information and mishaps."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.2.3.4" ;
    skos:prefLabel "Manage contracts"@en .

<http://ots.local/thesaurus/apqc/4_2_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_2_4> ;
    skos:definition "Handling operations related to processing/reviewing the requisitions. Establish and maintain procedures for the initiation, authorization, and processing of purchase requirements to procure products/services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.2.4.1" ;
    skos:prefLabel "Process/Review requisitions"@en .

<http://ots.local/thesaurus/apqc/4_2_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_2_4> ;
    skos:definition "Approving requisitions for materials and services. Examine distributor-specific requests, and validate them individually."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.2.4.2" ;
    skos:prefLabel "Approve requisitions"@en .

<http://ots.local/thesaurus/apqc/4_2_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_2_4> ;
    skos:definition "Requesting quotes from suppliers. Use a request for quotation (RFQ) to invite suppliers into a bidding process for specific products/services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.2.4.3" ;
    skos:prefLabel "Solicit supplier quotes"@en .

<http://ots.local/thesaurus/apqc/4_2_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_2_4> ;
    skos:definition "Creating and placing the orders for purchasing materials and services from suppliers. Analyze vendor quotes. Choose the most cost-effective vendors. Create vendor-specific orders. Distribute them in order to initiate the purchasing process."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.2.4.4" ;
    skos:prefLabel "Create/Distribute purchase orders"@en .

<http://ots.local/thesaurus/apqc/4_2_4_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_2_4> ;
    skos:definition "Accelerating the purchase orders in order to fulfill the internal needs (for raw materials) depicted through inquiries."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.2.4.5" ;
    skos:prefLabel "Expedite orders and satisfy inquiries"@en .

<http://ots.local/thesaurus/apqc/4_2_4_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_2_4> ;
    skos:definition "Verify that purchase orders are filled as expected: verify that items and quantities are delivered as expected, based on purchase order details and goods receipts."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.2.4.6" ;
    skos:prefLabel "Reconcile purchase orders"@en .

<http://ots.local/thesaurus/apqc/4_2_4_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_2_4> ;
    skos:definition "Identifying and resolving any exceptions. Address the internal needs/inquiries for materials that cannot be procured immediately. Research inquiries that require the need of exceptional materials."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.2.4.7" ;
    skos:prefLabel "Research/Resolve order exceptions"@en .

<http://ots.local/thesaurus/apqc/4_2_5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_2_5> ;
    skos:definition "Create and maintain vendor master files. Examining procurement and vendor performance. Report delivery timing and the quality of the materials procured through different vendors.  This data must align with vendor master file, see PCFID 10869."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.2.5.1" ;
    skos:prefLabel "Monitor/Manage supplier information"@en .

<http://ots.local/thesaurus/apqc/4_2_5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_2_5> ;
    skos:definition "Assisting the production and inventory processes through the information and reports created. Use the information and metrics of the procurement and vendor performance to enhance or improve the production process."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.2.5.2" ;
    skos:prefLabel "Prepare/Analyze procurement and supplier performance"@en .

<http://ots.local/thesaurus/apqc/4_2_5_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_2_5> ;
    skos:definition "Support inventory and production processes by analyzing impact of procurement decisions and collaborating to constantly improve. (For example, perhaps minimum order requirements could be negotiated to be lower, to reduce excessive inventory and make production more flexible.)"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.2.5.3" ;
    skos:prefLabel "Support inventory and production processes"@en .

<http://ots.local/thesaurus/apqc/4_2_5_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_2_5> ;
    skos:definition "Track the performance of the suppliers on product quality. Use this information to further improve sourcing and supplier performance."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.2.5.4" ;
    skos:prefLabel "Monitor quality of product delivered"@en .

<http://ots.local/thesaurus/apqc/4_3_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_3_1> ;
    skos:definition "Creating a representation of plant facilities to optimize material flow, resource utilization, and logistics for all levels of plant planning from global production facilities, through local plants, to specific lines and enabling the comparison of production�alternatives,."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.3.1.1" ;
    skos:prefLabel "Model and simulate plant"@en .

<http://ots.local/thesaurus/apqc/4_3_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_3_1> ;
    skos:definition "Initiating the line-level plan for production. Break down the production schedule into specific lines, specifying the various objectives the production schedule."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.3.1.2" ;
    skos:prefLabel "Generate line level plan"@en .

<http://ots.local/thesaurus/apqc/4_3_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_3_1> ;
    skos:definition "Broadening the line-level plan. Specify all the individual production processes, along with the timing and the duration to come up with a working schedule that tracks the whole process and any deviations that might occur."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.3.1.3" ;
    skos:prefLabel "Generate detailed schedule"@en .

<http://ots.local/thesaurus/apqc/4_3_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_3_1> ;
    skos:definition "Creating a schedule to commence production of orders received, and creating lots to consolidate the processing. Plan when the production orders are to be initiated by commencing the operations for processing products/services. Specify which materials to produce, where to produce them, which operations will facilitate this, and on which date production is to start. Define the size of production lots, demarcating the durations of batch production."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.3.1.4" ;
    skos:prefLabel "Schedule production orders and create lots"@en .

<http://ots.local/thesaurus/apqc/4_3_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_3_1> ;
    skos:definition "Scheduling planned maintenance of the production equipment."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.3.1.5" ;
    skos:prefLabel "Plan for preventive maintenance"@en .

<http://ots.local/thesaurus/apqc/4_3_1_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_3_1> ;
    skos:definition "Scheduling requested maintenance in order to address breakdowns where repairs or corrective remedies are needed immediately. Create a scheme for undertaking unplanned maintenance work on equipment/machinery that has come to be in urgent need for it. Express turnaround to redress using specialized personnel."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.3.1.6" ;
    skos:prefLabel "Request unplanned maintenance"@en .

<http://ots.local/thesaurus/apqc/4_3_1_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_3_1> ;
    skos:definition "Initiating the delivery of production orders, and creating lots. Communicate the order that specifies which material to produce, where to produce it, which operations to require, and on which date production takes place. Define how to settle the order costs. Create production lots, which is a particular production unit of an assembly that is planned and manufactured."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.3.1.7" ;
    skos:prefLabel "Release production orders and create lots"@en .

<http://ots.local/thesaurus/apqc/4_3_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_3_2> ;
    skos:definition "Administering the inventory of raw materials. Manage the total cost of all component parts in stock but not yet used. Manage the cost of the direct materials (i.e., materials incorporated into the final product) and indirect materials (i.e., materials not incorporated into the final product but consumed during the production process)."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.3.2.1" ;
    skos:prefLabel "Manage raw material inventory"@en .

<http://ots.local/thesaurus/apqc/4_3_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_3_2> ;
    skos:definition "Creating and implementing the detailed line production schedule on the ground level."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.3.2.2" ;
    skos:prefLabel "Execute detailed line schedule"@en .

<http://ots.local/thesaurus/apqc/4_3_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_3_2> ;
    skos:definition "Recording and reporting any deviations or issues in the maintenance schedule, in the performance to the production management team, and for unplanned maintenance."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.3.2.3" ;
    skos:prefLabel "Report maintenance issues"@en .

<http://ots.local/thesaurus/apqc/4_3_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_3_2> ;
    skos:definition "Reproducing the items produced defectively. Assess the produced items by conducting quality and standardization tests in order to diagnose any discrepancies. Reproduce defective items."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.3.2.4" ;
    skos:prefLabel "Rerun defective items"@en .

<http://ots.local/thesaurus/apqc/4_3_2_5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_3_2_5> ;
    skos:definition "Creating and applying technology to monitor and control the production and delivery of products and services. Automation involves a broad range of technologies."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.3.2.5.1" ;
    skos:prefLabel "Automate and control plant"@en .

<http://ots.local/thesaurus/apqc/4_3_2_5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_3_2_5> ;
    skos:definition "Including a broad range of techniques and technologies implemented within industrial process control systems that are routinely reviewed, audited, and improved, advanced process controls typically address particular performance or economic improvement opportunities. An advanced set of process control measures can be used to reduce variation and identify primary improvement options. Results of analysis are fed back into process design for incorporation into production."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.3.2.5.2" ;
    skos:prefLabel "Perform advanced process control"@en .

<http://ots.local/thesaurus/apqc/4_3_2_5_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_3_2_5> ;
    skos:definition "Helping organizations increase performance and efficiency, real-time optimization is a category of closed-loop process control that aims at optimizing process performance in real time for systems. It is normally built upon model-based optimization systems and is usually large scale. Real-time optimization automatically detects errors, and can modify and eliminate both random and non-random errors, as well as analyze and monitor all systems involved."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.3.2.5.3" ;
    skos:prefLabel "Perform real-time optimization"@en .

<http://ots.local/thesaurus/apqc/4_3_2_5_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_3_2_5> ;
    skos:definition "Applying human factors and instrumentation engineering and systems thinking to manage the design of an alarm or alert system to increase its usability. Typical challenges include having too many alarms in a plant, poorly designed alarms/alerts, improperly set alarm/alert points, unclear alarm/alert messages, etc. Poor alarm management is one of the leading causes of unplanned downtime."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.3.2.5.4" ;
    skos:prefLabel "Manage plant alarms and alerts"@en .

<http://ots.local/thesaurus/apqc/4_3_2_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_3_2> ;
    skos:definition "Analyzing and benchmarking the production process to judge its effectiveness and efficiency. Create production metrics to numerically calculate the performance of the production process."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.3.2.6" ;
    skos:prefLabel "Assess production performance"@en .

<http://ots.local/thesaurus/apqc/4_3_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_3_3> ;
    skos:definition "Regulating the equipment used for performing quality tests. Assess correspondence between the quality testing equipment and the desired quality standards. Ensure the calibration standard is more accurate than the instrument being tested."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.3.3.1" ;
    skos:prefLabel "Calibrate test equipment"@en .

<http://ots.local/thesaurus/apqc/4_3_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_3_3> ;
    skos:definition "Performing testing using calibrated equipment and in consent with the standard testing procedure, including testing time."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.3.3.2" ;
    skos:prefLabel "Perform testing using the standard testing procedure"@en .

<http://ots.local/thesaurus/apqc/4_3_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_3_3> ;
    skos:definition "Selecting a set of elements from a product lot to draw conclusions or make inferences about the quality of the product lot from which the sample is drawn. Sampling is frequently used because gathering data on every product produced by a company is often impossible, impractical, or too costly to collect."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.3.3.3" ;
    skos:prefLabel "Manage quality samples"@en .

<http://ots.local/thesaurus/apqc/4_3_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_3_3> ;
    skos:definition "Documenting the results and outcomes of the quality tests. Track the performance of the production process. Record/Document it to evaluate the qualitative efficiency of the production process. Use electronic devices and software in order to ensure effectiveness in recording the results and outcomes of the test."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.3.3.4" ;
    skos:prefLabel "Record test results"@en .

<http://ots.local/thesaurus/apqc/4_3_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_3_3> ;
    skos:definition "Managing and monitoring the occurrences of problems with a process or product. It is important that nonconformance occurrences are tracked in a standardized way so the data can easily be reviewed to assess the impact of the problem. Ongoing analysis of trends in nonconformance gives an organization the ability to make process changes to reduce the incidence and cost of nonconformances."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.3.3.5" ;
    skos:prefLabel "Track and analyze non-conformance trends"@en .

<http://ots.local/thesaurus/apqc/4_3_3_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_3_3> ;
    skos:definition "Using a technique that helps people answer the question of why a problem occurred in the first place. It seeks to identify the origin of a problem using a specific set of steps, with associated tools, to find the primary cause of the problem to determine what happened, why, and how to reduce the likelihood that it will happen again."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.3.3.6" ;
    skos:prefLabel "Perform root cause analysis"@en .

<http://ots.local/thesaurus/apqc/4_3_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_3_4> ;
    skos:definition "Allotting an identification number to a particular quantity or lot of material manufactured. Assign lot numbers on the basis of specific production units, material similarity, etc. Place lot numbers on the outside of packaging."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.3.4.1" ;
    skos:prefLabel "Determine lot numbering system"@en .

<http://ots.local/thesaurus/apqc/4_3_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_3_4> ;
    skos:definition "Identifying the use of production lots. Define where, how, and when to use a specific production lot."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.3.4.2" ;
    skos:prefLabel "Determine lot use"@en .

<http://ots.local/thesaurus/apqc/4_4_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_1> ;
    skos:definition "Determining the requirements for managing the flow of things between the point of origin and the point of consumption by assessing the service requirements of the customers."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.1.1" ;
    skos:prefLabel "Translate customer service requirements into logistics requirements"@en .

<http://ots.local/thesaurus/apqc/4_4_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_1> ;
    skos:definition "Developing a network for logistical activities. Create a network of entities through which materials and information flow, encompassing all related activities associated with the flow of transformation of products."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.1.2" ;
    skos:prefLabel "Design logistics network"@en .

<http://ots.local/thesaurus/apqc/4_4_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_1> ;
    skos:definition "Conveying outsourcing needs within the organization, with the objective of sourcing the assistance required. Define the portion of logistical activities that can be transferred to outside suppliers. Assess third-party agencies to carefully select the most appropriate agencies for outsourcing. Convey these needs to management or the appropriate authority."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.1.3" ;
    skos:prefLabel "Communicate outsourcing needs"@en .

<http://ots.local/thesaurus/apqc/4_4_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_1> ;
    skos:definition "Establishing rules and regulations, as well as the terms and conditions regarding the delivery of service by the company. Develop a delivery plan that specifies what, how, when, and in which way to deliver services to the customer."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.1.4" ;
    skos:prefLabel "Develop and maintain delivery service policy"@en .

<http://ots.local/thesaurus/apqc/4_4_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_1> ;
    skos:definition "Optimizing the schedule and costs of transportation services. Design a logistics strategy by strategically creating delivery routes and systems, which optimizes the overall transportation schedules and costs. Evaluate different transportation sources in order to select the most appropriate and cost-effective sources."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.1.5" ;
    skos:prefLabel "Optimize transportation schedules and costs"@en .

<http://ots.local/thesaurus/apqc/4_4_1_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_1> ;
    skos:definition "Establishing measures for evaluating the performance of the logistics strategy of the organization. Establish key performance indicators, including the logistics performance index, delivery in full, and delivery on time."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.1.6" ;
    skos:prefLabel "Define key performance measures"@en .

<http://ots.local/thesaurus/apqc/4_4_1_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_1> ;
    skos:definition "Establish a strategy that includes rules and regulations for the physical handling, information processing, and disposition of product and packaging returned by the buyer to the seller or an intermediary. Include return approval, transportation coordination, advance communication, product tracking, receipt, disposition of the return, and processing warranty claims in the strategy."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.1.7" ;
    skos:prefLabel "Define reverse logistics strategy"@en .

<http://ots.local/thesaurus/apqc/4_4_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_2> ;
    skos:definition "Managing the receipts of inbound materials. Create a plan accounting for the materials procured from the source of supply and the materials delivered to the distribution center or the warehouse."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.2.1" ;
    skos:prefLabel "Plan inbound material receipts"@en .

<http://ots.local/thesaurus/apqc/4_4_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_2> ;
    skos:definition "Managing all the internal activities related to the flow/transfer of materials. Manage materials being delivered to distribution center or warehouse. Gauge the time taken for delivery and if the delivery process is on time."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.2.2" ;
    skos:prefLabel "Manage inbound material flow"@en .

<http://ots.local/thesaurus/apqc/4_4_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_2> ;
    skos:definition "Overseeing the performance of an inbound delivery system. Check the present delivery system's efficiency, cost effectiveness, and adherence to a delivery schedule."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.2.3" ;
    skos:prefLabel "Monitor inbound delivery performance"@en .

<http://ots.local/thesaurus/apqc/4_4_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_2> ;
    skos:definition "Tracking and taking care of the products that have been internally returned either because of their deficiency or in cases of incorrect delivery."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.2.4" ;
    skos:prefLabel "Manage flow of returned products"@en .

<http://ots.local/thesaurus/apqc/4_4_2_5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_2_5> ;
    skos:definition "Implement a checks and balances system to verify that returned parts meet acceptable quality standards to determine appropriate disposition activity."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.2.5.1" ;
    skos:prefLabel "Determine quality of controlled part"@en .

<http://ots.local/thesaurus/apqc/4_4_2_5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_2_5> ;
    skos:definition "Executing activities for reinstating the returned products. Present the customer with additional incentives of compensation in case of any defective products delivery or any discrepancy in the product specifications in order to save the order from being permanently returned."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.2.5.2" ;
    skos:prefLabel "Perform salvage activities"@en .

<http://ots.local/thesaurus/apqc/4_4_2_5_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_2_5> ;
    skos:definition "Administering the reinstatement of the returned product in order to return them back to customers. Repair or remanufacture the defective or ineffective products returned by the customer. Process the delivery of the repaired or remanufactured products back to the customer."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.2.5.3" ;
    skos:prefLabel "Manage repair/refurbishment"@en .

<http://ots.local/thesaurus/apqc/4_4_2_5_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_2_5> ;
    skos:definition "Moving a returned product back to inventory or stock. Whether a product is sufficient as returned, repaired, or refurbished, moving that product back to inventory for resale or returning to customer is the fnal step in Manage disposition of returned products."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.2.5.4" ;
    skos:prefLabel "Return to finished goods inventory"@en .

<http://ots.local/thesaurus/apqc/4_4_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_3> ;
    skos:definition "Tracking the logistical act of delivering or releasing an inventory item or entity to targeted end users. Track how much inventory has been deployed at all the distribution centers, individually."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.3.1" ;
    skos:prefLabel "Manage and track inventory deployment"@en .

<http://ots.local/thesaurus/apqc/4_4_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_3> ;
    skos:definition "Coordinating the incoming inbound materials/products. Accept the delivery of these materials and the subsequent storage. Track them at the warehouse/distribution center."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.3.2" ;
    skos:prefLabel "Receive, inspect, and store inbound deliveries"@en .

<http://ots.local/thesaurus/apqc/4_4_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_3> ;
    skos:definition "Keeping track of the availability of different materials/products at the warehouse and distribution centers."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.3.3" ;
    skos:prefLabel "Track product availability"@en .

<http://ots.local/thesaurus/apqc/4_4_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_3> ;
    skos:definition "Packing and shipping the product to deliver to the customer. Take care of the internal and external packaging of the products in order to ensure safe transportation of the products from the warehouse to delivery locations. Notify the ERP system and/or Accounts Receivable Dept."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.3.4" ;
    skos:prefLabel "Pick, pack, and ship product for delivery"@en .

<http://ots.local/thesaurus/apqc/4_4_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_3> ;
    skos:definition "Monitoring any discrepancies between electronic records that represent the inventory and the physical state of the inventory. Look for discrepancies such as phantom inventory, which includes products that an inventory accounting system considers to be available at the storage location but are not actually available."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.3.5" ;
    skos:prefLabel "Track inventory accuracy"@en .

<http://ots.local/thesaurus/apqc/4_4_3_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_3> ;
    skos:definition "Keeping a track on the storage and shipping performance of third-party agencies. Monitor logistics storage and shipping performance for third-party agencies. Use measures such as a logistics scoreboard, activity-based costing, economic value analysis, and balanced scorecards."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.3.6" ;
    skos:prefLabel "Track third-party logistics storage and shipping performance"@en .

<http://ots.local/thesaurus/apqc/4_4_3_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_3> ;
    skos:definition "Administering the movement of the finished products that are processed by the organization through its warehouses. Track goods through the use of systems such as barcodes in order to monitor the volumes available, quantity of out-flowing goods, remaining shelf life of the product, etc.--ultimately, to best manage the warehouse capacity."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.3.7" ;
    skos:prefLabel "Manage physical finished goods inventory"@en .

<http://ots.local/thesaurus/apqc/4_4_3_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_3> ;
    skos:definition "Shipping items from one warehouse to another in a multi-warehouse environment. A warehouse transfer is typically handled electronically in a system designed to replicate the physical processes involved with transferring items from one warehouse to another."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.3.8" ;
    skos:prefLabel "Manage warehouse transfers"@en .

<http://ots.local/thesaurus/apqc/4_4_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_4> ;
    skos:definition "Organizing the transportation and delivery of outbound products. Plan and organize the transportation, shipping, and delivery of the end products. Create a plan that specifies dispatch and delivery of the product to its destination, as well the transportation."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.4.1" ;
    skos:prefLabel "Plan, transport, and deliver outbound product"@en .

<http://ots.local/thesaurus/apqc/4_4_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_4> ;
    skos:definition "Monitoring delivery performance when carrying products from the warehouse/distribution centers to the retailers or end consumers. Create a performance metrics based on the key performance indicators."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.4.2" ;
    skos:prefLabel "Track carrier delivery performance"@en .

<http://ots.local/thesaurus/apqc/4_4_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_4> ;
    skos:definition "Taking care of a range of functions related to the means of transport used for delivering the end products. Manage vehicle financing, vehicle maintenance, vehicle telematics (tracking and diagnostics), driver management, speed management, fuel management, and health and safety management."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.4.3" ;
    skos:prefLabel "Manage transportation fleet"@en .

<http://ots.local/thesaurus/apqc/4_4_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_4> ;
    skos:definition "Organizing and inspecting all account statements and any other documentation for the carriers used in delivery. Create, manage, and inspect all documents related to the financial, regulatory, and administrative accounts of all the carriers/freights. Generate receipts for all freight transactions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.4.4" ;
    skos:prefLabel "Process and audit carrier invoices and documents"@en .

<http://ots.local/thesaurus/apqc/4_4_5_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_5_1> ;
    skos:definition "Soliciting or acquiring information using various sources such as databases, customer interactions, and customer request forms. Hand them further up the hierarchy to deal with them. Categorize the user's request, determining if the request is supportable and prioritizing the request."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.5.1.1" ;
    skos:prefLabel "Process customer request"@en .

<http://ots.local/thesaurus/apqc/4_4_5_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_5_1> ;
    skos:definition "Documenting the individual customer service requirements solicited, along with personal information of the customers, in order to generate customized profiles that hasten the delivery process."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.5.1.2" ;
    skos:prefLabel "Create customer profile"@en .

<http://ots.local/thesaurus/apqc/4_4_5_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_5_1> ;
    skos:definition "Designing a short-term agreement between the service provider and customer. One-time services are ordered by the service recipient and resource-related billing is performed upon completion. Use the service order to document service and customer service work."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.5.1.3" ;
    skos:prefLabel "Generate last mile delivery order"@en .

<http://ots.local/thesaurus/apqc/4_4_5_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_5_2> ;
    skos:definition "Developing a plan for sourcing and deploying the resources required to fulfill customer service needs. Document a detailed summary of all types of resources (equipment, finance, personnel, time, etc.) required to complete customer service requests and procure these resources. Identify and assess various sources in order to effectively create a resourcing plan."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.5.2.1" ;
    skos:prefLabel "Create resourcing plan and schedule"@en .

<http://ots.local/thesaurus/apqc/4_4_5_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_5_2> ;
    skos:definition "Designing a detailed summary of customer service order requirements, along with information concerning the timing and duration for these services. Categorize the customer needs. Monitor the services delivered."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.5.2.2" ;
    skos:prefLabel "Create last mile delivery service order fulfillment schedule"@en .

<http://ots.local/thesaurus/apqc/4_4_5_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_5_3> ;
    skos:definition "Laying out a daily plan of specific service orders that need to be fulfilled. Document and systematically order these activities to ensure high effectiveness and efficiency."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.5.3.1" ;
    skos:prefLabel "Organize daily last mile delivery order fulfillment schedule"@en .

<http://ots.local/thesaurus/apqc/4_4_5_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_5_3> ;
    skos:definition "Dispatching and delivering the resources needed for the specific service requirements from the source/warehouse. Manage the dispatch, transportation, and delivery of the services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.5.3.2" ;
    skos:prefLabel "Execute product delivery"@en .

<http://ots.local/thesaurus/apqc/4_4_5_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_5_3> ;
    skos:definition "Handling and managing orders fulfilled, along with the orders are not or partially fulfilled to track the order fulfillment progress. Use electronic devices such as trackers and GPS in order track and ensure delivery of the orders."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.5.3.3" ;
    skos:prefLabel "Manage last mile delivery order fulfillment"@en .

<http://ots.local/thesaurus/apqc/4_4_5_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_5_4> ;
    skos:definition "Determining the service orders that have been successfully delivered. Identify the service orders completed and delivered to the customer. Leverage communication systems to ensure coordination with the customers in order to avoid mishaps."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.5.4.1" ;
    skos:prefLabel "Identify completed last mile delivery orders for feedback"@en .

<http://ots.local/thesaurus/apqc/4_4_5_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_5_4> ;
    skos:definition "Determining orders which have not been completed or delivered. Identify the service orders that are partially or entirely incomplete, as well as the orders that have not been delivered to the customer. Use techniques such as project trackers to recognize the progress of the service orders."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.5.4.2" ;
    skos:prefLabel "Identify incomplete last mile delivery orders and last mile delivery service failures"@en .

<http://ots.local/thesaurus/apqc/4_4_5_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_5_4> ;
    skos:definition "Obtaining and procuring customer reviews or feedback on the services delivered. Design a customer feedback form, or communicate with the customer through the phone or online."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.5.4.3" ;
    skos:prefLabel "Solicit customer feedback on last mile services delivered"@en .

<http://ots.local/thesaurus/apqc/4_4_5_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/4_4_5_4> ;
    skos:definition "Assessing and incorporating customer reviews/feedback into the service plan to ensure high quality of service."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "4.4.5.4.4" ;
    skos:prefLabel "Process customer feedback on last mile services delivered"@en .

<http://ots.local/thesaurus/apqc/5_1_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_1_1> ;
    skos:definition "Providing a system for which to manage customer needs and a structure for which to facilitate service delivery to fulfill those needs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.1.1.1" ;
    skos:prefLabel "Set up and maintain service delivery governance and management system"@en .

<http://ots.local/thesaurus/apqc/5_1_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_1_1> ;
    skos:definition "Conducting and implementing performance measures to ensure successful delivery of service to the customer."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.1.1.2" ;
    skos:prefLabel "Manage service delivery performance"@en .

<http://ots.local/thesaurus/apqc/5_1_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_1_1> ;
    skos:definition "Providing guidance of resources to ensure that the development and direction of service delivery is in line with customer needs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.1.1.3" ;
    skos:prefLabel "Manage service delivery development and direction"@en .

<http://ots.local/thesaurus/apqc/5_1_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_1_1> ;
    skos:definition "Engaging the customer post delivery to gauge the effectiveness of services rendered in order to improve on key delivery functions going forward."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.1.1.4" ;
    skos:prefLabel "Solicit feedback from customer on service delivery satisfaction"@en .

<http://ots.local/thesaurus/apqc/5_1_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_1_2> ;
    skos:definition "Aligning organization practices to meet the needs of the customer by creating service delivery goals."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.1.2.1" ;
    skos:prefLabel "Define service delivery goals"@en .

<http://ots.local/thesaurus/apqc/5_1_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_1_2> ;
    skos:definition "Outlining labor policies for resources and ensuring that those policies meet the needs of the organization, the customer, and government regulations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.1.2.2" ;
    skos:prefLabel "Define labor policies"@en .

<http://ots.local/thesaurus/apqc/5_1_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_1_2> ;
    skos:definition "Understanding the needs of the customer and providing the necessary resources to meet those requirements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.1.2.3" ;
    skos:prefLabel "Evaluate resource availability"@en .

<http://ots.local/thesaurus/apqc/5_1_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_1_2> ;
    skos:definition "Identifying and understanding the limitations imposed upon service delivery network and supply."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.1.2.4" ;
    skos:prefLabel "Define service delivery network and supply constraints"@en .

<http://ots.local/thesaurus/apqc/5_1_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_1_2> ;
    skos:definition "Defanging policies and procedures that focus on meeting the needs and expectations of the customer within the working parameters of the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.1.2.5" ;
    skos:prefLabel "Define service delivery process"@en .

<http://ots.local/thesaurus/apqc/5_1_2_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_1_2> ;
    skos:definition "Revisioning service delivery procedures that fall short of performance parameters. Realign procedures with specified expectations in order to provide successful service delivery."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.1.2.6" ;
    skos:prefLabel "Review and validate service delivery procedures"@en .

<http://ots.local/thesaurus/apqc/5_1_2_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_1_2> ;
    skos:definition "Creating a workplace that best serves the needs of the organization and customer through strategic layout and infrastructure."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.1.2.7" ;
    skos:prefLabel "Define service delivery workplace layout and infrastructure"@en .

<http://ots.local/thesaurus/apqc/5_2_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_2_1> ;
    skos:definition "Tracking potential opportunities as they move through the various stages of the pipeline."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.2.1.1" ;
    skos:prefLabel "Monitor pipeline"@en .

<http://ots.local/thesaurus/apqc/5_2_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_2_1> ;
    skos:definition "Identifying the demand anticipated for the organization's services. Estimate future demand for services using historical data, analysis of the market environment, and external data."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.2.1.2" ;
    skos:prefLabel "Develop baseline forecasts"@en .

<http://ots.local/thesaurus/apqc/5_2_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_2_1> ;
    skos:definition "Providing a collaborative meeting in which to engage the customer to understand the scope of their needs and constructing solutions based on need and constraints."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.2.1.3" ;
    skos:prefLabel "Collaborate with customers"@en .

<http://ots.local/thesaurus/apqc/5_2_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_2_1> ;
    skos:definition "Arriving at a consensus over the forecasted levels of demand for services by analyzing baseline forecasts and customer input."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.2.1.4" ;
    skos:prefLabel "Develop consensus forecast"@en .

<http://ots.local/thesaurus/apqc/5_2_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_2_1> ;
    skos:definition "Identifying what skillset is necessary for the delivery of opportunities. Determine the forecast of customer orders based upon those skillsets and the resources available."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.2.1.5" ;
    skos:prefLabel "Determine availability of skills to deliver on current and forecast customer orders"@en .

<http://ots.local/thesaurus/apqc/5_2_1_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_2_1> ;
    skos:definition "Overseeing all activities necessary to deliver services to customer. Revise forecast to account for any issues that may arise. This could be changes in market trend, resource changes, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.2.1.6" ;
    skos:prefLabel "Monitor activity against forecast and revise forecast"@en .

<http://ots.local/thesaurus/apqc/5_2_1_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_2_1> ;
    skos:definition "Recognizing potential problems in the current forecast and making the necessary changes to align the forecast meet demand."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.2.1.7" ;
    skos:prefLabel "Evaluate and revise forecasting approach"@en .

<http://ots.local/thesaurus/apqc/5_2_1_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_2_1> ;
    skos:definition "Analyzing forecasting against actuals to determine accuracy. Modify forecasting to align with actual need."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.2.1.8" ;
    skos:prefLabel "Measure forecast accuracy"@en .

<http://ots.local/thesaurus/apqc/5_2_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_2_2> ;
    skos:definition "Analyzing the skills needed to perform services to be delivered. Classify and organize these skills requirements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.2.2.1" ;
    skos:prefLabel "Define and manage skills taxonomy"@en .

<http://ots.local/thesaurus/apqc/5_2_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_2_2> ;
    skos:definition "Creating a plan to ensure that all resources are available to carry out services required for the customer. This can include physical resources and personnel."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.2.2.2" ;
    skos:prefLabel "Create resource plan"@en .

<http://ots.local/thesaurus/apqc/5_2_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_2_2> ;
    skos:definition "Matching demand with skills and capability. Enlisting suppliers and partners to help with demand when needed."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.2.2.3" ;
    skos:prefLabel "Match resource demand with capacity, skills, and capabilities"@en .

<http://ots.local/thesaurus/apqc/5_2_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_2_2> ;
    skos:definition "Understanding organizational need to enlist suppliers to provide resources for gaps in skills and capabilities. Identify where additional skills are needed and collaborate with third parties to fill those demands."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.2.2.4" ;
    skos:prefLabel "Collaborate with suppliers and partners to supplement skills and capabilities"@en .

<http://ots.local/thesaurus/apqc/5_2_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_2_2> ;
    skos:definition "Realizing critical resources required to perform and carry out customer needs. Engage with suppliers to fulfill those needs, if necessary. Identify supplier threshold for performing those needs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.2.2.5" ;
    skos:prefLabel "Identify critical resources and supplier capacity"@en .

<http://ots.local/thesaurus/apqc/5_2_2_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_2_2> ;
    skos:definition "Directing and managing workforce needs. Ensure that resources are at full capacity. Monitor that all resources are able to skilled in their respective rolls. Make sure that necessary resources are available to provide the needed services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.2.2.6" ;
    skos:prefLabel "Monitor and manage resource capacity and availability"@en .

<http://ots.local/thesaurus/apqc/5_2_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_2_3> ;
    skos:definition "Creating a detailed summary of all the actions relevant to teaching a person a particular skill or type of behavior. Determine who will deliver the training. Determine when and where the apprentice or trainee needs to go to receive the structured component of the training."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.2.3.1" ;
    skos:prefLabel "Develop service delivery training plan"@en .

<http://ots.local/thesaurus/apqc/5_2_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_2_3> ;
    skos:definition "Developing materials necessary to provide comprehensive training for the skills or behavior needed to deliver services. This can be any number for formats such as classroom or computer based training."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.2.3.2" ;
    skos:prefLabel "Develop training materials"@en .

<http://ots.local/thesaurus/apqc/5_2_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_2_3> ;
    skos:definition "Providing training to the employee within a manageable timeframe to meet the needs of both the individual and the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.2.3.3" ;
    skos:prefLabel "Manage training schedule"@en .

<http://ots.local/thesaurus/apqc/5_2_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_2_3> ;
    skos:definition "Educating service delivery personnel on all aspects of the operations process of the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.2.3.4" ;
    skos:prefLabel "Deliver operations training"@en .

<http://ots.local/thesaurus/apqc/5_2_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_2_3> ;
    skos:definition "Ensuring that all personnel are trained on all technical aspects of service delivery to include compliance with constraints on how advanced technologies including artificial intelligence (AI) are used."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.2.3.5" ;
    skos:prefLabel "Deliver technical training"@en .

<http://ots.local/thesaurus/apqc/5_2_3_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_2_3> ;
    skos:definition "Verifying that training provided to the person was successful through the administration testing and the application of skills for practical use."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.2.3.6" ;
    skos:prefLabel "Perform skill and capability testing"@en .

<http://ots.local/thesaurus/apqc/5_2_3_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_2_3> ;
    skos:definition "Eliciting feedback from various sources to evaluate the training provided. This can be achieved through testing and the practical application of skills. Additionally, manager or student feedback can be garnered to evaluate training effectiveness."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.2.3.7" ;
    skos:prefLabel "Evaluate training effectiveness"@en .

<http://ots.local/thesaurus/apqc/5_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_3> ;
    skos:definition "Planning the service delivery system by defining service requirements, capacity, resources, and delivery approaches needed to support effective and reliable service provision."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.3.1" ;
    skos:prefLabel "Perform service delivery system planning"@en .

<http://ots.local/thesaurus/apqc/5_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_3> ;
    skos:definition "Establishing and activating the service delivery system, including preparing resources, processes, and controls required to begin delivering services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.3.2" ;
    skos:prefLabel "Perform service delivery system startup"@en .

<http://ots.local/thesaurus/apqc/5_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_3> ;
    skos:definition "Executing day-to-day service delivery activities using the established service delivery system to meet service commitments, performance expectations, and customer needs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.3.3" ;
    skos:prefLabel "Operate service delivery system"@en .

<http://ots.local/thesaurus/apqc/5_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_3> ;
    skos:definition "Monitoring and assuring service delivery system performance to maintain service quality, reliability, and compliance with defined service standards and expectations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.3.4" ;
    skos:prefLabel "Assure service delivery system service"@en .

<http://ots.local/thesaurus/apqc/5_4_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_4_1> ;
    skos:definition "Meeting with the customer, partner, and/or supplier to review the terms of the solutions contract and agree on the terms set forth."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.4.1.1" ;
    skos:prefLabel "Review contract and agreed terms"@en .

<http://ots.local/thesaurus/apqc/5_4_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_4_1> ;
    skos:definition "Taking the customer requirements for a solution and applying those requirements to a refined approach for service."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.4.1.2" ;
    skos:prefLabel "Understand customer requirements and define refine approach"@en .

<http://ots.local/thesaurus/apqc/5_4_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_4_1> ;
    skos:definition "Updating the project plan to align with the new solution approach agreed upon with the customer."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.4.1.3" ;
    skos:prefLabel "Modify/revise and approve project plan"@en .

<http://ots.local/thesaurus/apqc/5_4_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_4_1> ;
    skos:definition "Aligning the customer business objectives with the agreed service delivery solution."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.4.1.4" ;
    skos:prefLabel "Review customer business objectives"@en .

<http://ots.local/thesaurus/apqc/5_4_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_4_1> ;
    skos:definition "Confirming that the organization has the recourses necessary to meet the expectations for the solution for service delivery."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.4.1.5" ;
    skos:prefLabel "Confirm environmental readiness"@en .

<http://ots.local/thesaurus/apqc/5_4_1_6_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_4_1_6> ;
    skos:definition "Providing the workforce with a plan of action and goals necessary to provide a service. Make sure that those objectives are met."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.4.1.6.1" ;
    skos:prefLabel "Establish people objectives"@en .

<http://ots.local/thesaurus/apqc/5_4_1_6_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_4_1_6> ;
    skos:definition "Establishing guidelines for how resources engage with the customer. For example, set rules of accountability, interaction, and accommodation when engaging the customer. Resources should be polite, empathetic, and attentive."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.4.1.6.2" ;
    skos:prefLabel "Establish engagement rules"@en .

<http://ots.local/thesaurus/apqc/5_4_1_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_4_1> ;
    skos:definition "Establishing a plan of action to successfully render a solution for service delivery."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.4.1.7" ;
    skos:prefLabel "Plan for service delivery"@en .

<http://ots.local/thesaurus/apqc/5_4_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_4_2> ;
    skos:definition "Understanding the needs of the customer and providing the necessary resources to meet those requirements within the scope of the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.4.2.1" ;
    skos:prefLabel "Analyze environment and customer needs"@en .

<http://ots.local/thesaurus/apqc/5_4_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_4_2> ;
    skos:definition "Creating a plan of action to provide service delivery to the customer through a possible solution. This solution should be in response to a collaborative effort made by the organization and the customer to meet service delivery needs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.4.2.2" ;
    skos:prefLabel "Define solution"@en .

<http://ots.local/thesaurus/apqc/5_4_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_4_2> ;
    skos:definition "Validating that the proposed solution is feasible and provides the needed services for the customer."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.4.2.3" ;
    skos:prefLabel "Validate solution"@en .

<http://ots.local/thesaurus/apqc/5_4_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_4_2> ;
    skos:definition "Realizing issues within the original drafted solution and providing changes to correct those issues."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.4.2.4" ;
    skos:prefLabel "Identify changes"@en .

<http://ots.local/thesaurus/apqc/5_4_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_4_2> ;
    skos:definition "Gaining approval from all avenues to proceed with providing solutions for service delivery."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.4.2.5" ;
    skos:prefLabel "Obtain approval to proceed"@en .

<http://ots.local/thesaurus/apqc/5_4_2_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_4_2> ;
    skos:definition "Constructing or purchasing solutions necessary to provide service delivery."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.4.2.6" ;
    skos:prefLabel "Make build/buy solution"@en .

<http://ots.local/thesaurus/apqc/5_4_2_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_4_2> ;
    skos:definition "Providing the customer with promised services and solutions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.4.2.7" ;
    skos:prefLabel "Deploy solution"@en .

<http://ots.local/thesaurus/apqc/5_4_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_4_3> ;
    skos:definition "Reviewing the entire service delivery process to evaluate the success of the project from beginning to end."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.4.3.1" ;
    skos:prefLabel "Conduct service delivery/project review and evaluate success"@en .

<http://ots.local/thesaurus/apqc/5_4_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_4_3> ;
    skos:definition "Insuring all payments are received and all activates therein are completed."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.4.3.2" ;
    skos:prefLabel "Complete/finalize financial management activities"@en .

<http://ots.local/thesaurus/apqc/5_4_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_4_3> ;
    skos:definition "Confirming that the organization has satisfied all terms of the delivery contract set forth in collaboration between the organization and customer."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.4.3.3" ;
    skos:prefLabel "Confirm delivery according to contract terms"@en .

<http://ots.local/thesaurus/apqc/5_4_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_4_3> ;
    skos:definition "Discharging leveraged resources from service delivery commitments upon completion. Returning resources to the resource pool."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.4.3.4" ;
    skos:prefLabel "Release resources"@en .

<http://ots.local/thesaurus/apqc/5_4_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_4_3> ;
    skos:definition "Ensuring that all aspects of the service delivery process are completed both internally and externally."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.4.3.5" ;
    skos:prefLabel "Manage service delivery completion"@en .

<http://ots.local/thesaurus/apqc/5_4_3_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_4_3> ;
    skos:definition "Garnering feedback from all avenues to collect a knowledge base concerning services rendered."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.4.3.6" ;
    skos:prefLabel "Harvest knowledge"@en .

<http://ots.local/thesaurus/apqc/5_4_3_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/5_4_3> ;
    skos:definition "Completing and archiving all records associated with requested services. Update all necessary systems to reflect those changes."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "5.4.3.7" ;
    skos:prefLabel "Archive records and update systems"@en .

<http://ots.local/thesaurus/apqc/6_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_1> ;
    skos:definition "Identifying the customer service requirements across the organization, including the needs and expectations of different customer segments. Additionally this includes defining a set of behaviors, skills, and policies needed to provide customer service effectively across the enterprise."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.1.1" ;
    skos:prefLabel "Define customer service requirements across the enterprise"@en .

<http://ots.local/thesaurus/apqc/6_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_1> ;
    skos:definition "Communicating how customer service interactions are handled including what is expected when engaging the customer. Relate service level expectations to the workforce. Ensure positive customer experience."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.1.2" ;
    skos:prefLabel "Define customer service experience"@en .

<http://ots.local/thesaurus/apqc/6_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_1> ;
    skos:definition "Define the channels and communication methods that will be used to deliver customer service, including phone, email, chat, social media, and in-person interactions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.1.3" ;
    skos:prefLabel "Define and manage customer service channel strategy"@en .

<http://ots.local/thesaurus/apqc/6_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_1> ;
    skos:definition "Develop policies and procedures for delivering customer service, including handling customer complaints, resolving issues, and maintaining customer records."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.1.4" ;
    skos:prefLabel "Define customer service policies and procedures"@en .

<http://ots.local/thesaurus/apqc/6_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_1> ;
    skos:definition "Determining and implementing levels for customer services. Benchmark certain customer service practices, and base customer level services on those benchmarks. Create a service level agreement, which is an agreement designed to create a common understanding about services, priorities, and responsibilities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.1.5" ;
    skos:prefLabel "Establish target service level for each customer segment"@en .

<http://ots.local/thesaurus/apqc/6_1_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_1> ;
    skos:definition "Define how the customer service strategy will integrate with other departments like marketing, sales, and product development to ensure a seamless customer experience."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.1.6" ;
    skos:prefLabel "Identify and define customer service strategy integrations"@en .

<http://ots.local/thesaurus/apqc/6_2_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_2_1> ;
    skos:definition "Projecting the total workforce required to service customer service inquiries in order to effectively predict the volume of vendor contracts required. Estimate the number of the customer service contracts in an agreed-upon time frame in order to strategically maintain the workforce necessitated for customer inquires. Analyze historical data around customer service contracts, the universe of customer inquiries, frequency of inquiries, servicing capability (per head) of the employees, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.2.1.1" ;
    skos:prefLabel "Forecast volume of customer service contacts"@en .

<http://ots.local/thesaurus/apqc/6_2_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_2_1> ;
    skos:definition "Deploying the workforce to manage customer service contracts. Create a systematic summary of the operations and service required, as well as the specific amount of workforce that is to be deployed to the customer service operations. Ensure workforce is directly proportional to the estimated forecast of customer service contracts."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.2.1.2" ;
    skos:prefLabel "Schedule customer service workforce"@en .

<http://ots.local/thesaurus/apqc/6_2_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_2_1> ;
    skos:definition "Tracking the utilization of workforce deployed for managing customer service operations. Monitor the utility of the workforce deployed for managing customer service operations in order to evaluate its efficiency and cost effectiveness. Calculate the overall labor effectiveness, which measures the utility, performance, and quality of the workforce."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.2.1.3" ;
    skos:prefLabel "Track workforce utilization"@en .

<http://ots.local/thesaurus/apqc/6_2_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_2_1> ;
    skos:definition "Tracking and determining the quality of interactions between the customer and customer representatives. Use technology, including artificial intelligence (AI), to record and effectively assess customer representatives' interactions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.2.1.4" ;
    skos:prefLabel "Monitor and evaluate quality of customer interactions with customer service representatives"@en .

<http://ots.local/thesaurus/apqc/6_2_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_2_2> ;
    skos:definition "Receiving requests for information from customers over multiple channels. Receive various requests and inquiries from customers regarding products/services. Accept these inquiries through channels such as email, telephone, online forms, text messages, social media, and in person. Supply dedicated equipment, systems, and personnel."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.2.2.1" ;
    skos:prefLabel "Receive customer problems, requests, and inquiries"@en .

<http://ots.local/thesaurus/apqc/6_2_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_2_2> ;
    skos:definition "Analyzing various requests and inquiries from customers regarding products/services. Provide answers and offerings to satisfy the customer's needs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.2.2.2" ;
    skos:prefLabel "Analyze problems, requests, and inquiries"@en .

<http://ots.local/thesaurus/apqc/6_2_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_2_2> ;
    skos:definition "Routing customer inquiries in order to service them with the most apposite response. Direct customer inquires to the best suited personnel or system. Have a system or procedure capable of efficiently channeling these requests."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.2.2.3" ;
    skos:prefLabel "Resolve customer problems, requests, and inquiries"@en .

<http://ots.local/thesaurus/apqc/6_2_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_2_2> ;
    skos:definition "Responding to customer requests by email, conversation, interactive voice response, mail, etc. with the most appropriate reply. Instill a robust process to locate the right information for a solution to a customer's problem."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.2.2.4" ;
    skos:prefLabel "Respond to customer problems, requests, and inquiries"@en .

<http://ots.local/thesaurus/apqc/6_2_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_2_2> ;
    skos:definition "Utilizing customer inquiries as opportunities to either provide a comparable service to the one in question, offer additional complimentary service, or suggest a service that is better than what was initially offered."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.2.2.5" ;
    skos:prefLabel "Identify and capture upsell/cross-sell opportunities"@en .

<http://ots.local/thesaurus/apqc/6_2_2_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_2_2> ;
    skos:definition "Providing possible sales leads to the sales team in an effort to garner more business opportunities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.2.2.6" ;
    skos:prefLabel "Deliver opportunity to sales team"@en .

<http://ots.local/thesaurus/apqc/6_2_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_2_3> ;
    skos:definition "Receiving any complaints or grievances from customers for the organization's products/services. Receive objections, complaints, and criticism from customers regarding products/services through email, telephone, online forms, text messages, social media, in person, etc. Dedicate equipment, systems, and personnel."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.2.3.1" ;
    skos:prefLabel "Receive customer complaints"@en .

<http://ots.local/thesaurus/apqc/6_2_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_2_3> ;
    skos:definition "Routing any complaints or grievances received from customers in order to address them in the most appropriate manner. Direct complaints to the best suited personnel or system. Implement a system or procedure capable of efficiently channeling the various objections, complaints, and criticism from customers over the offerings provided by the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.2.3.2" ;
    skos:prefLabel "Route customer complaints"@en .

<http://ots.local/thesaurus/apqc/6_2_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_2_3> ;
    skos:definition "Resolving any customer complaints that are deemed to be sound and reasonable. Redress any objections, grievances, and complaints received from customers regarding the offerings provided by the organization. Identify the legitimate complaints, where the situation needs to be appropriately corrected. Deploy personnel who can rectify the issue within a stipulated time frame."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.2.3.3" ;
    skos:prefLabel "Resolve customer complaints"@en .

<http://ots.local/thesaurus/apqc/6_2_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_2_3> ;
    skos:definition "Responding to customer complaints including all activities necessitated to service any objections, complaints, or grievances with the most appropriate reply. Source the right information to formulate a response that eases the discomfort being experienced by the customer. (Closely coordinate with Resolve customer complaints [10399].)"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.2.3.4" ;
    skos:prefLabel "Respond to customer complaints"@en .

<http://ots.local/thesaurus/apqc/6_2_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_2_3> ;
    skos:definition "Analyzing complaint logs to provide input for continuous service improvement and customer profiling."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.2.3.5" ;
    skos:prefLabel "Analyze customer complaints and response/redressal"@en .

<http://ots.local/thesaurus/apqc/6_2_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_2_4> ;
    skos:definition "Approving and carrying forward the requests by the customers to return the product. This is part of the process of returning a product in order to receive a refund, replacement, or repair during the product's warranty period."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.2.4.1" ;
    skos:prefLabel "Authorize return"@en .

<http://ots.local/thesaurus/apqc/6_2_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_2_4> ;
    skos:definition "Notating the reason for the return of the product."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.2.4.2" ;
    skos:prefLabel "Process return and record reason"@en .

<http://ots.local/thesaurus/apqc/6_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_2> ;
    skos:definition "Notifying all stakeholders, legal, and industry regulatory bodies of the incidents and risks related to a return or recall, if needed."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.2.5" ;
    skos:prefLabel "Report incidents and risks to regulatory bodies"@en .

<http://ots.local/thesaurus/apqc/6_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3> ;
    skos:definition "Filing product registrations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.1" ;
    skos:prefLabel "Register products"@en .

<http://ots.local/thesaurus/apqc/6_3_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3_2> ;
    skos:definition "Receiving incoming warranty claims. Route claim to correct department. Document claim."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.2.1" ;
    skos:prefLabel "Receive warranty claim"@en .

<http://ots.local/thesaurus/apqc/6_3_2_10> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3_2> ;
    skos:definition "Assuring that the warranty transaction has been completed."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.2.10" ;
    skos:prefLabel "Reconcile warranty transaction disposition"@en .

<http://ots.local/thesaurus/apqc/6_3_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3_2> ;
    skos:definition "Ensuring that the claim falls within the parameters of the warranty in question. After validation is made, the claim must be investigated."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.2.2" ;
    skos:prefLabel "Validate warranty claim"@en .

<http://ots.local/thesaurus/apqc/6_3_2_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3_2_3> ;
    skos:definition "Defining the issue of the claim. The warranty team will look into the issue and understand whether it is covered by the claim code or if more detail is required. Field service will be scheduled to further qualify the definition of the issue and to collect more evidence."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.2.3.1" ;
    skos:prefLabel "Define issue"@en .

<http://ots.local/thesaurus/apqc/6_3_2_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3_2_3> ;
    skos:definition "Scheduling additional investigative field service. This is performed for high priority claims or claims that require additional investigation. Field service engineers will gather additional information, perform further investigation, and qualify the definition of the issue."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.2.3.2" ;
    skos:prefLabel "Schedule field service"@en .

<http://ots.local/thesaurus/apqc/6_3_2_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3_2_3> ;
    skos:definition "Requesting receipt of a defective part for further investigation."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.2.3.3" ;
    skos:prefLabel "Request and receive defective part"@en .

<http://ots.local/thesaurus/apqc/6_3_2_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3_2_3> ;
    skos:definition "Investigating claims by an appropriate functional representative. Once the issue has been clearly defined and diagnosed and a recommendation for corrective action is determined, it will be provided to the warranty management team."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.2.3.4" ;
    skos:prefLabel "Investigate issue/perform root cause analysis"@en .

<http://ots.local/thesaurus/apqc/6_3_2_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3_2_3> ;
    skos:definition "Receiving investigative results to assess claim approval or denial. The warranty team will assess the results of the investigation and the recommendations for corrective action."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.2.3.5" ;
    skos:prefLabel "Receive investigation result/recommendation for corrective action"@en .

<http://ots.local/thesaurus/apqc/6_3_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3_2> ;
    skos:definition "Identifying responsible party for a claim. There is no negotiation with the supplier at this point. There can be multiple warranties applicable to the same part: a new part warranty, a new product warranty (for the product the part is installed on), and a supplier warranty from the company that last repaired the part. The information required for this decision would be the output of Receive component/part and analyze fault [19728].\""@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.2.4" ;
    skos:prefLabel "Determine responsible party"@en .

<http://ots.local/thesaurus/apqc/6_3_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3_2> ;
    skos:definition "Authorizing claims prior to submittal."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.2.5" ;
    skos:prefLabel "Manage pre-authorizations"@en .

<http://ots.local/thesaurus/apqc/6_3_2_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3_2> ;
    skos:definition "Following Defining issue [20098], an approval or rejection with be made against the warranty claim. If it is deemed that the claim falls within the warranty parameters, the claim will be approved. If the claim is deemed to fall outside warranty parameters, the claim with be rejected."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.2.6" ;
    skos:prefLabel "Approve or reject warranty claim"@en .

<http://ots.local/thesaurus/apqc/6_3_2_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3_2> ;
    skos:definition "Contacting the originator of whether the warranty claim has been approved or rejected."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.2.7" ;
    skos:prefLabel "Notify originator of approve/reject decision"@en .

<http://ots.local/thesaurus/apqc/6_3_2_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3_2> ;
    skos:definition "Allowing for a payment to be made to the claimant."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.2.8" ;
    skos:prefLabel "Authorize payment"@en .

<http://ots.local/thesaurus/apqc/6_3_2_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3_2> ;
    skos:definition "Archiving and closing the warranty claim after a final decision has been made to either approve or reject."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.2.9" ;
    skos:prefLabel "Close claim"@en .

<http://ots.local/thesaurus/apqc/6_3_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3_3> ;
    skos:definition "Raising a supplier recovery claim. This is based off the decision made in Receive investigation result/recommendation for corrective action [20100]."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.3.1" ;
    skos:prefLabel "Create supplier recovery claims"@en .

<http://ots.local/thesaurus/apqc/6_3_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3_3> ;
    skos:definition "Arranging the returns of recalled products to suppliers."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.3.2" ;
    skos:prefLabel "Negotiate recoveries with suppliers"@en .

<http://ots.local/thesaurus/apqc/6_3_4_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3_4_1> ;
    skos:definition "Soliciting or acquiring information using various sources such as databases, customer interactions, and customer request forms. Hand them further up the hierarchy to deal with them. Categorize the user's request, determining if the request is supportable and prioritizing the request."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.4.1.1" ;
    skos:prefLabel "Process customer request"@en .

<http://ots.local/thesaurus/apqc/6_3_4_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3_4_1> ;
    skos:definition "Documenting the individual customer service requirements solicited, along with personal information of the customers, in order to generate customized profiles that hasten the delivery process."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.4.1.2" ;
    skos:prefLabel "Create customer profile"@en .

<http://ots.local/thesaurus/apqc/6_3_4_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3_4_1> ;
    skos:definition "Designing a short-term agreement between the service provider and customer. One-time services are ordered by the service recipient and resource-related billing is performed upon completion. Use the service order to document service and customer service work."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.4.1.3" ;
    skos:prefLabel "Generate service order"@en .

<http://ots.local/thesaurus/apqc/6_3_4_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3_4_2> ;
    skos:definition "Developing a plan for sourcing and deploying the resources required to fulfill customer service needs. Document a detailed summary of all types of resources (equipment, finance, personnel, time, etc.) required to complete customer service requests and procure these resources. Identify and assess various sources in order to effectively create a resourcing plan."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.4.2.1" ;
    skos:prefLabel "Create resourcing plan and schedule"@en .

<http://ots.local/thesaurus/apqc/6_3_4_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3_4_2> ;
    skos:definition "Designing a detailed summary of customer service order requirements, along with information concerning the timing and duration for these services. Categorize the customer needs. Monitor the services delivered."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.4.2.2" ;
    skos:prefLabel "Create service order fulfillment schedule"@en .

<http://ots.local/thesaurus/apqc/6_3_4_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3_4_3> ;
    skos:definition "Laying out a daily plan of specific service orders that need to be fulfilled. Document and systematically order these activities to ensure high effectiveness and efficiency."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.4.3.1" ;
    skos:prefLabel "Organize daily service order fulfillment schedule"@en .

<http://ots.local/thesaurus/apqc/6_3_4_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3_4_3> ;
    skos:definition "Dispatching and delivering the resources needed for the specific service requirements from the source/warehouse. Manage the dispatch, transportation, and delivery of the services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.4.3.2" ;
    skos:prefLabel "Execute product repair"@en .

<http://ots.local/thesaurus/apqc/6_3_4_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3_4_3> ;
    skos:definition "Handling and managing orders fulfilled, along with the orders are not or partially fulfilled to track the order fulfillment progress. Use electronic devices such as trackers and GPS in order track and ensure delivery of the orders."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.4.3.3" ;
    skos:prefLabel "Manage service order fulfillment"@en .

<http://ots.local/thesaurus/apqc/6_3_4_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3_4_4> ;
    skos:definition "Determining the service orders that have been successfully delivered. Identify the service orders completed and delivered to the customer. Leverage communication systems to ensure coordination with the customers in order to avoid mishaps."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.4.4.1" ;
    skos:prefLabel "Identify completed service orders for feedback"@en .

<http://ots.local/thesaurus/apqc/6_3_4_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3_4_4> ;
    skos:definition "Determining orders which have not been completed or delivered. Identify the service orders that are partially or entirely incomplete, as well as the orders that have not been delivered to the customer. Use techniques such as project trackers to recognize the progress of the service orders."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.4.4.2" ;
    skos:prefLabel "Identify incomplete service orders and service failures"@en .

<http://ots.local/thesaurus/apqc/6_3_4_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3_4_4> ;
    skos:definition "Obtaining and procuring customer reviews or feedback on the services delivered. Design a customer feedback form, or communicate with the customer through the phone or online."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.4.4.3" ;
    skos:prefLabel "Solicit customer feedback on services delivered"@en .

<http://ots.local/thesaurus/apqc/6_3_4_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_3_4_4> ;
    skos:definition "Assessing and incorporating customer reviews/feedback into the service plan to ensure high quality of service."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.3.4.4.4" ;
    skos:prefLabel "Process customer feedback on services delivered"@en .

<http://ots.local/thesaurus/apqc/6_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_4> ;
    skos:definition "Commencing the removal process of defective products."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.4.1" ;
    skos:prefLabel "Initiate recall"@en .

<http://ots.local/thesaurus/apqc/6_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_4> ;
    skos:definition "Performing risk analysis. Identify all dangers, evaluate how probable they are, and what kinds of negative results or or adverse side effect they carry."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.4.2" ;
    skos:prefLabel "Assess the likelihood and consequences of occurrence of any hazards"@en .

<http://ots.local/thesaurus/apqc/6_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_4> ;
    skos:definition "Handling communications that are related to product recalls."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.4.3" ;
    skos:prefLabel "Manage recall related communications"@en .

<http://ots.local/thesaurus/apqc/6_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_4> ;
    skos:definition "Creating and delivering reports to regulatory agencies to provide details about handling product recalls."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.4.4" ;
    skos:prefLabel "Submit regulatory reports"@en .

<http://ots.local/thesaurus/apqc/6_4_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_4> ;
    skos:definition "Analyzing the effectiveness of product recalls."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.4.5" ;
    skos:prefLabel "Monitor and audit recall effectiveness"@en .

<http://ots.local/thesaurus/apqc/6_4_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_4> ;
    skos:definition "Ending product recalls, communicating to the public and filing reports."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.4.6" ;
    skos:prefLabel "Manage recall termination"@en .

<http://ots.local/thesaurus/apqc/6_5_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_5_1> ;
    skos:definition "Creating an avenue for which the customer can provide feedback on their experience with how their inquiry, problem, or request was handled."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.5.1.1" ;
    skos:prefLabel "Solicit customer feedback on customer service experience"@en .

<http://ots.local/thesaurus/apqc/6_5_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_5_1> ;
    skos:definition "Reviewing customer service feedback to identify areas in which improvements can be made. Engage with management to discuss issues."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.5.1.2" ;
    skos:prefLabel "Analyze customer service data and identify improvement opportunities"@en .

<http://ots.local/thesaurus/apqc/6_5_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_5_1> ;
    skos:definition "Handing over data to management to analyze common issues in regards to customer service."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.5.1.3" ;
    skos:prefLabel "Provide customer feedback to product management on customer service experience"@en .

<http://ots.local/thesaurus/apqc/6_5_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_5_2> ;
    skos:definition "Requesting customer feedback on the process of handling and resolving customer complaints. Obtain information about the effectiveness and performance of the customer complaint handling process from the customers through various means (e.g., online and by phone)."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.5.2.1" ;
    skos:prefLabel "Solicit customer feedback on complaint handling and resolution"@en .

<http://ots.local/thesaurus/apqc/6_5_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_5_2> ;
    skos:definition "Examining the information obtained through handling and resolving complaints for development/improvement opportunities. Categorize the customer complaints data on the basis of speed, accuracy, courtesy, price, product choice, availability, hours, location, etc. Determine complaint patterns in order to diagnose areas needing enhancement."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.5.2.2" ;
    skos:prefLabel "Analyze customer complaint data and identify improvement opportunities"@en .

<http://ots.local/thesaurus/apqc/6_5_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_5_2> ;
    skos:definition "Determining complaint patterns in order to identify common issues. Document common problems for correction."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.5.2.3" ;
    skos:prefLabel "Identify common customer complaints"@en .

<http://ots.local/thesaurus/apqc/6_5_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_5_3> ;
    skos:definition "Obtaining customer feedback/review on the quality and utility derived from the products/services after the sale is complete. Use techniques such as surveys, feedback boxes, and user activity and usability tests."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.5.3.1" ;
    skos:prefLabel "Gather and solicit post-sale customer feedback on products and services"@en .

<http://ots.local/thesaurus/apqc/6_5_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_5_3> ;
    skos:definition "Assessing the influence of promotions on purchasing behavior. Use techniques such as surveys and product recognition tests, questionnaires or feedback flyers, and toll-free numbers in order to encourage customer interaction after the sale."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.5.3.2" ;
    skos:prefLabel "Solicit post-sale customer feedback on promotion effectiveness"@en .

<http://ots.local/thesaurus/apqc/6_5_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_5_3> ;
    skos:definition "Engaging with the customer to understand their cross-channel experience. Find out what channels were effective and what areas need improvement."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.5.3.3" ;
    skos:prefLabel "Solicit customer feedback on cross-channel experience"@en .

<http://ots.local/thesaurus/apqc/6_5_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_5_3> ;
    skos:definition "Assessing the information collected on customer satisfaction levels with products/services in order to determine areas for improvement. Examine the data and information extracted from the customer feedback and reviews to measure the satisfaction levels of the customers. Identify opportunities that could enhance the customer satisfaction levels and the overall customer service strategy."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.5.3.4" ;
    skos:prefLabel "Analyze product and service satisfaction data and identify improvement opportunities"@en .

<http://ots.local/thesaurus/apqc/6_5_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_5_3> ;
    skos:definition "Providing feedback from customers on products/services to the product management team. Analyze information collected through Gather and solicit post-sale customer feedback on products/services [11238]. Share with the product management team for consideration while improving existing offerings or developing new products/services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.5.3.5" ;
    skos:prefLabel "Provide feedback and insights to appropriate teams (product design/development, marketing, manufacturing)"@en .

<http://ots.local/thesaurus/apqc/6_5_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_5_4> ;
    skos:definition "Evaluating how satisfied customers are with how product warranties are managed and resolved."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.5.4.1" ;
    skos:prefLabel "Measure customer satisfaction with warranty handling and resolution"@en .

<http://ots.local/thesaurus/apqc/6_5_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_5_4> ;
    skos:definition "Comparing warranties by using applicable metrics to see how they are handled and resolved. Develop and submit reports that summarize significant conclusions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.5.4.2" ;
    skos:prefLabel "Monitor and report on warranty management metrics"@en .

<http://ots.local/thesaurus/apqc/6_5_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_5_4> ;
    skos:definition "Determining how warranties and warranty management can be made better and more efficient."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.5.4.3" ;
    skos:prefLabel "Identify improvement opportunities"@en .

<http://ots.local/thesaurus/apqc/6_5_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_5_4> ;
    skos:definition "Finding ways to phase out unused or seldom used warranties."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.5.4.4" ;
    skos:prefLabel "Identify opportunities to eliminate warranty waste"@en .

<http://ots.local/thesaurus/apqc/6_5_4_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_5_4> ;
    skos:definition "Reviewing and assessing claims that contain deliberately incorrect information or that have been submitted with the goal to deceive the system."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.5.4.5" ;
    skos:prefLabel "Investigate fraudulent claims"@en .

<http://ots.local/thesaurus/apqc/6_5_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/6_5> ;
    skos:definition "Reviewing customer service feedback to identify areas in which improvements can be made. Engage with management to discuss issues."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "6.5.5" ;
    skos:prefLabel "Evaluate recall performance"@en .

<http://ots.local/thesaurus/apqc/7_1_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_1> ;
    skos:definition "Strategically defining the current and future needs for developing an efficient HR strategy."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.1.1" ;
    skos:prefLabel "Identify strategic HR needs"@en .

<http://ots.local/thesaurus/apqc/7_1_1_10> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_1> ;
    skos:definition "Designing the intended end-to-end employee experience across key moments in the employee lifecycle to support engagement, performance, retention, and alignment with organizational culture and workforce objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.1.10" ;
    skos:prefLabel "Design the employee experience"@en .

<http://ots.local/thesaurus/apqc/7_1_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_1> ;
    skos:definition "Outlining the charge and duty of the HR function by defining its responsibility areas, as well as ensuring its accountability. Establish the HR function by laying out the roles and responsibilities for this function and the rules and regulations guiding HR. Define the goals and objectives of the HR, as well as a mission and vision for this function. Create a mechanism involving a set of policies, code of conduct, and institutional procedure to ensure HR accountability."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.1.2" ;
    skos:prefLabel "Define HR and business function roles and accountability"@en .

<http://ots.local/thesaurus/apqc/7_1_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_1> ;
    skos:definition "Establishing the roles that are required to execute the HR function.  This process also examines the organizational structure required to support the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.1.3" ;
    skos:prefLabel "Determine HR function roles and structure"@en .

<http://ots.local/thesaurus/apqc/7_1_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_1> ;
    skos:definition "Determining how an organization's human resources department offers services to and interacts with employees."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.1.4" ;
    skos:prefLabel "Determine HR delivery model"@en .

<http://ots.local/thesaurus/apqc/7_1_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_1> ;
    skos:definition "Ascertaining the costs and expenses of the HR function. Identify and report HR investments using, for example, a cost approach or a present value of future earnings approach."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.1.5" ;
    skos:prefLabel "Determine HR costs"@en .

<http://ots.local/thesaurus/apqc/7_1_1_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_1> ;
    skos:definition "Evaluating the performance of HR function. Lay out the course of HR procedures that would formulate a plan of action needed to fulfill strategic HR needs. Deploy measures such as hiring policies, leave management, internal code of conducts, and compensation structure."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.1.6" ;
    skos:prefLabel "Establish HR measures"@en .

<http://ots.local/thesaurus/apqc/7_1_1_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_1> ;
    skos:definition "Conveying the strategies of HR function to employees and management. Effectively explain the vision, plans, and anticipated benefits of the HR strategy to employees, as well as the public. Develop statements and messages that are easy to read, informative, and relevant to the audience."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.1.7" ;
    skos:prefLabel "Communicate HR strategies"@en .

<http://ots.local/thesaurus/apqc/7_1_1_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_1> ;
    skos:definition "Creating a strategy for the use of systems/technologies/tools in operating the HR function. This is inclusive of all forms of new and evolving technology such as artificial intelligence (AI). Create a strategy concerning the use and utility of HR support tools and technologies. Decide what specific tools to use and in what quantity. Determine the levels of technology required for the HR management."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.1.8" ;
    skos:prefLabel "Develop strategy for HR systems/technologies/tools"@en .

<http://ots.local/thesaurus/apqc/7_1_1_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_1> ;
    skos:definition "Creating, maintaining and communicating company's reputation and values to keep current employees and attract potential hires."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.1.9" ;
    skos:prefLabel "Manage employer branding"@en .

<http://ots.local/thesaurus/apqc/7_1_2_10> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_2> ;
    skos:definition "Creating rules and regulations that govern the HR function. Develop a policy plan that serves as a guideline for setting rules and regulations that help in achieving the HR goals and objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.2.10" ;
    skos:prefLabel "Develop HR policies"@en .

<http://ots.local/thesaurus/apqc/7_1_2_11> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_2> ;
    skos:definition "Ensuring rules and regulations are followed and are flexible enough to accommodate indispensable deviations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.2.11" ;
    skos:prefLabel "Administer HR policies"@en .

<http://ots.local/thesaurus/apqc/7_1_2_12> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_2> ;
    skos:definition "Planning benefits in kind (also called fringe benefits, perquisites, or perks). Include various types of non-wage compensations provided to employees in addition to normal wages or salaries."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.2.12" ;
    skos:prefLabel "Plan employee benefits"@en .

<http://ots.local/thesaurus/apqc/7_1_2_13> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_2> ;
    skos:definition "Creating and implementing models for effectively strategizing the work force of the organization. Develop a model that specifies the organization's overall approach for maximizing the performance of its work force by defining the goals, objectives, and expectations of the work force. Manage all aspects of performance required for the work force to function, including recruitment, selection, retention, and professional development."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.2.13" ;
    skos:prefLabel "Develop workforce strategy models"@en .

<http://ots.local/thesaurus/apqc/7_1_2_14> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_2> ;
    skos:definition "Implementing models for effectively strategizing the work force of the organization. Carry out all aspects of performance required for the work force to function, including recruitment, selection, retention, and professional development."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.2.14" ;
    skos:prefLabel "Implement workforce strategy models"@en .

<http://ots.local/thesaurus/apqc/7_1_2_15> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_2> ;
    skos:definition "Overseeing a group of similar individual or teams with similar education, skills, training, or experience."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.2.15" ;
    skos:prefLabel "Manage job families"@en .

<http://ots.local/thesaurus/apqc/7_1_2_16> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_2> ;
    skos:definition "Creating descriptions for job requisitions. Define the normal components of a job description, such as the overall position description with general areas of responsibility listed, essential functions of the job described with a couple of examples of each, required knowledge, skills, abilities, required education and experience, a description of the physical demands, and a description of the work environment."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.2.16" ;
    skos:prefLabel "Develop and maintain job descriptions"@en .

<http://ots.local/thesaurus/apqc/7_1_2_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_2_1> ;
    skos:definition "Defining and maintaining the structure, principles, and approaches used to assess workforce supply and demand, capabilities, and gaps over the strategic planning horizon."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.2.1.1" ;
    skos:prefLabel "Develop and manage strategic workforce planning framework"@en .

<http://ots.local/thesaurus/apqc/7_1_2_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_2_1> ;
    skos:definition "Determining the requirements for employees and the need for employee resourcing for each unit/function. Lay out a plan detailing employee resourcing requirements of individual functions and the organization as a whole."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.2.1.2" ;
    skos:prefLabel "Perform business unit workforce planning"@en .

<http://ots.local/thesaurus/apqc/7_1_2_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_2_1> ;
    skos:definition "Providing guidance and expertise to business leaders on applying the strategic workforce planning framework to inform workforce decisions, plans, and initiatives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.2.1.3" ;
    skos:prefLabel "Advise business in implementing strategic workforce planning"@en .

<http://ots.local/thesaurus/apqc/7_1_2_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_2_1> ;
    skos:definition "Collaborating with business leaders to translate workforce plans into actionable initiatives and to support execution of agreed workforce actions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.2.1.4" ;
    skos:prefLabel "Partner with the business to execute workforce plan"@en .

<http://ots.local/thesaurus/apqc/7_1_2_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_2_1> ;
    skos:definition "Tracking workforce outcomes and changes in business needs to update workforce plans and address emerging gaps, risks, or opportunities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.2.1.5" ;
    skos:prefLabel "Monitor and adjust strategic workforce plan"@en .

<http://ots.local/thesaurus/apqc/7_1_2_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_2_2> ;
    skos:definition "Defining the strategic approach for wages, salaries, and benefits to support workforce attraction, retention, performance, and alignment with organizational objectives and market conditions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.2.2.1" ;
    skos:prefLabel "Establish wages, salaries, and benefits strategy"@en .

<http://ots.local/thesaurus/apqc/7_1_2_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_2_2> ;
    skos:definition "Creating a scheme of rewards and recognition for employees to promote a results-based culture. Create specific incentives to reach desired outcomes, such as landing key clients, growing the customer base, providing exceptional servicing, and increasing profit margins."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.2.2.2" ;
    skos:prefLabel "Establish incentive strategy"@en .

<http://ots.local/thesaurus/apqc/7_1_2_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_2_2> ;
    skos:definition "Defining the approach to severance pay, including principles and guidelines, to support workforce transitions while managing financial, legal, and reputational considerations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.2.2.3" ;
    skos:prefLabel "Establish a severance pay strategy"@en .

<http://ots.local/thesaurus/apqc/7_1_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_2> ;
    skos:definition "Creating and implementing the plan for continuation of key positions within the organization. Identify internal people with the potential to fill key business leadership positions. Provide critical development experiences to employees who can move into important roles. Engage leaders to support the development of high-potential leaders."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.2.3" ;
    skos:prefLabel "Develop succession plan"@en .

<http://ots.local/thesaurus/apqc/7_1_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_2> ;
    skos:definition "Creating a program that incorporates incentives and compensation put forth by the organization to recognize high performing workers and excellence in leadership."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.2.4" ;
    skos:prefLabel "Develop high performers/leadership programs"@en .

<http://ots.local/thesaurus/apqc/7_1_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_2> ;
    skos:definition "Creating and implementing the plan for ensuring a diverse work force. Develop and hire employees with varying characteristics including, but not limited to, religious and political beliefs, gender, ethnicity, education, socioeconomic background, sexual orientation, and geographic location."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.2.5" ;
    skos:prefLabel "Develop diversity, equity, and inclusion plan"@en .

<http://ots.local/thesaurus/apqc/7_1_2_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_2> ;
    skos:definition "Execution of diversity, equity, and inclusion plans within an organization.  Often called a DEI plan."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.2.6" ;
    skos:prefLabel "Implement diversity, equity, and inclusion plan"@en .

<http://ots.local/thesaurus/apqc/7_1_2_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_2> ;
    skos:definition "Developing a program to entice prospective resources to engage with the organization for a position of employment."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.2.7" ;
    skos:prefLabel "Design talent acquisition program"@en .

<http://ots.local/thesaurus/apqc/7_1_2_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_2> ;
    skos:definition "Identifying skills, knowledge, and attributes that need enhancement in order to perform a job. Develop the appropriate training programs. These programs can be computer-based, classroom, or on-the-job training, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.2.8" ;
    skos:prefLabel "Design talent development program"@en .

<http://ots.local/thesaurus/apqc/7_1_2_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_2> ;
    skos:definition "Creating HR programs and services such as employee engagements programs to promote positive employee behavior. Create a variety of programs and services to support employees' professional and personal needs at work and at home."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.2.9" ;
    skos:prefLabel "Develop other HR programs"@en .

<http://ots.local/thesaurus/apqc/7_1_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_3> ;
    skos:definition "Determining the accomplishment of HR and workforce goals and objectives. Evaluate the effectiveness of the HR function by estimating the present rate of achievement of the established objectives. Use metrics to determine if the objectives are being realized. Leverage measures such as turnover, training, return on human capital, costs of labor, and expenses per employee."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.3.1" ;
    skos:prefLabel "Measure realization of HR objectives"@en .

<http://ots.local/thesaurus/apqc/7_1_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_3> ;
    skos:definition "Determining the role of the HR function in implementing the organizational strategy. Measure the correlation between the HR and workforce performance and the overall business strategy. Calculate the amount of contribution of the HR function to the overall business growth."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.3.2" ;
    skos:prefLabel "Measure contribution of HR to business strategy"@en .

<http://ots.local/thesaurus/apqc/7_1_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_3> ;
    skos:definition "Conveying the plans for HR function to stakeholders. Ensure that the HR plans and strategy are effectively communicated to the people who can affect or be affected by the organization's actions, objectives, and policies such as the creditors, shareholders, employees, and suppliers. Provide regular updates to these stakeholders to ensure effective communication."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.3.3" ;
    skos:prefLabel "Communicate HR plans and provide updates to stakeholders"@en .

<http://ots.local/thesaurus/apqc/7_1_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1_3> ;
    skos:definition "Reassessing the strategies, plans, and policies of the HR function, with the objective of revising them. Revisit the schematic plans for the HR function. Taking stock of any suggestions or feedback from the stakeholders, revamp the blueprint of HR strategies and plans."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.3.4" ;
    skos:prefLabel "Review and revise HR plans"@en .

<http://ots.local/thesaurus/apqc/7_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_1> ;
    skos:definition "Creating and implementing the tools for managing the competency levels of HR. Design a model for integrating HR planning with business planning. Assess current HR capacity based on the competencies against the capacity needed to achieve the vision, mission, and business goals of the organization. Consider factors such as employee development, career path, compensation policies, and performance management."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.1.4" ;
    skos:prefLabel "Develop competency management models"@en .

<http://ots.local/thesaurus/apqc/7_2_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_2_1> ;
    skos:definition "Creating a correspondence between the plan for hiring new employees and the desired employee requirements. Staff an adequate amount of people with the appropriate skills to effectively accomplish its legislative, regulatory, service, and production requirements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.2.1.1" ;
    skos:prefLabel "Align staffing plan to work force plan and business unit strategies/resource needs"@en .

<http://ots.local/thesaurus/apqc/7_2_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_2_1> ;
    skos:definition "Developing specific job requisitions, and ensuring their accessibility. Create and open a job requisition to fill the vacant positions within the organization. Clearly describe the job title, department, fill date, and the requisite skills and qualifications for the job."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.2.1.2" ;
    skos:prefLabel "Open job requisitions"@en .

<http://ots.local/thesaurus/apqc/7_2_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_2_1> ;
    skos:definition "Reviewing and authorizing requests to fill positions to ensure alignment with workforce plans, budget constraints, and organizational approval requirements"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.2.1.3" ;
    skos:prefLabel "Approve job requisition"@en .

<http://ots.local/thesaurus/apqc/7_2_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_2_1> ;
    skos:definition "Posting and advertising job descriptions. Display open job descriptions internally and externally. Use public portals, online portals, and websites to upload these requisitions in order for applications to be received."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.2.1.4" ;
    skos:prefLabel "Post job requisitions"@en .

<http://ots.local/thesaurus/apqc/7_2_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_2_1> ;
    skos:definition "Making the necessary alterations to job requisitions. Revamp or revise the job requisitions in case a position is filled or is not vacant anymore, as well as in case of any new openings. (It involves Manage the internal/external job posting websites [10449] to make the necessary changes.)"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.2.1.5" ;
    skos:prefLabel "Modify job requisitions"@en .

<http://ots.local/thesaurus/apqc/7_2_1_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_2_1> ;
    skos:definition "Informing and communicating with the hiring manager. Notify the manager responsible for the hiring process in cases of any new position openings or changes."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.2.1.6" ;
    skos:prefLabel "Notify hiring manager"@en .

<http://ots.local/thesaurus/apqc/7_2_1_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_2_1> ;
    skos:definition "Determining and managing the dates for the employee requisition process."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.2.1.7" ;
    skos:prefLabel "Manage requisition dates"@en .

<http://ots.local/thesaurus/apqc/7_2_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_2_2> ;
    skos:definition "Defining the methods and channels for recruitments in order to maximize the amount of candidate availability. Use channels such as headhunting, job postings, job portals, networking websites, and media advertising. Choose from the various methods of recruitment such as internal/external third-party sourcing."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.2.2.1" ;
    skos:prefLabel "Determine recruitment methods and channels"@en .

<http://ots.local/thesaurus/apqc/7_2_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_2_2> ;
    skos:definition "Organizing and executing recruiting activities and events. Activities and events include on-campus hiring, refresher courses, information sessions, career fairs, etc. to increase the coverage of the sourcing in order to ensure that the most deserving and appropriate candidates are hired."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.2.2.2" ;
    skos:prefLabel "Perform recruiting activities/events"@en .

<http://ots.local/thesaurus/apqc/7_2_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_2_2> ;
    skos:definition "Cultivating relationships with potential job candidates even when there are no immediate openings. Building the talent pipeline for potential future hiring needs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.2.2.3" ;
    skos:prefLabel "Develop and maintain candidate pool"@en .

<http://ots.local/thesaurus/apqc/7_2_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_2_2> ;
    skos:definition "Establishing and maintaining relationships with recruitment vendors (suppliers). Create and maintain relationships with third-party agencies such as staffing and firms to expand. Use these relationships to implement the sourcing process effectively."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.2.2.4" ;
    skos:prefLabel "Manage recruitment vendors"@en .

<http://ots.local/thesaurus/apqc/7_2_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_2_2> ;
    skos:definition "Creating and managing a recruiting strategy where current employees are rewarded for referring qualified candidates for employment."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.2.2.5" ;
    skos:prefLabel "Manage employee referral programs"@en .

<http://ots.local/thesaurus/apqc/7_2_2_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_2_2> ;
    skos:definition "Establishing and maintaining internal and external channels for recruiting. Extract the best out of every recruitment channel. Manage all the processes related to all the sourcing channels including maintaining career pages on the organization website."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.2.2.6" ;
    skos:prefLabel "Manage recruitment channels"@en .

<http://ots.local/thesaurus/apqc/7_2_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_2_3> ;
    skos:definition "Identifying and implementing tools for the selection of candidates. Recognize candidate selection tools such as screening, telephone interviews, hiring manager interviews, drug testing, and skills assessment. Effectively deploy these tools to check if the candidates fit in the workplace or not, as well as to ensure workplace safety."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.2.3.1" ;
    skos:prefLabel "Identify and deploy candidate selection tools"@en .

<http://ots.local/thesaurus/apqc/7_2_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_2_3> ;
    skos:definition "Assessing the candidates by their performance in the interviews. Conduct HR interview, technical interview, hiring manager interview, etc. Understand the mindset of the candidate, and comprehend his/her personal and professional lives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.2.3.2" ;
    skos:prefLabel "Interview candidates"@en .

<http://ots.local/thesaurus/apqc/7_2_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_2_3> ;
    skos:definition "Examining the candidates through tests. Prepare tools such as aptitude, technical, and grammar tests. Test the skills of the candidate through a written, oral, or computerized test."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.2.3.3" ;
    skos:prefLabel "Test candidates"@en .

<http://ots.local/thesaurus/apqc/7_2_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_2_3> ;
    skos:definition "Approving the deserving candidates, and rejecting the others. Examining the performance of candidates. Ensure candidates would fit well with the organization. (Assess performance from Interview candidates [10457] and Test candidates [10458].)"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.2.3.4" ;
    skos:prefLabel "Select and reject candidates"@en .

<http://ots.local/thesaurus/apqc/7_2_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_2_4> ;
    skos:definition "Compiling job-related information for the selected candidates in order to make up a job. Include information about the job description, reporting relationship, salary, bonus potential, benefits, and vacation allotment."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.2.4.1" ;
    skos:prefLabel "Draw up and make offer"@en .

<http://ots.local/thesaurus/apqc/7_2_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_2_4> ;
    skos:definition "Negotiating an offer with selected candidates. Discuss the job offer with the candidate to ensure a mutual understanding."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.2.4.2" ;
    skos:prefLabel "Negotiate offer"@en .

<http://ots.local/thesaurus/apqc/7_2_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_2_4> ;
    skos:definition "Wrapping up the process for hiring candidates. Agree to all hiring terms and conditions. Have the candidate accept and sign the job offer."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.2.4.3" ;
    skos:prefLabel "Hire candidate"@en .

<http://ots.local/thesaurus/apqc/7_2_5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_2_5> ;
    skos:definition "Conducting a background investigation on the candidates with the objective of gathering and compiling criminal, commercial, medical, and financial information."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.2.5.1" ;
    skos:prefLabel "Obtain candidate background information"@en .

<http://ots.local/thesaurus/apqc/7_2_5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_2_5> ;
    skos:definition "Creating and documenting the records of all applicants. Manage all individual applicants, including hires and non-hires. Maintain records to avoid any duplication and promote efficiency."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.2.5.2" ;
    skos:prefLabel "Create applicant record"@en .

<http://ots.local/thesaurus/apqc/7_2_5_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_2_5_3> ;
    skos:definition "Identifying the requirements for the position to be filled. Determine the experience and skills necessary to perform the tasks outlined."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.2.5.3.1" ;
    skos:prefLabel "Complete position classification and level of experience"@en .

<http://ots.local/thesaurus/apqc/7_2_5_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_2_5> ;
    skos:definition "Retaining and storing the records of the candidates who were rejected and not hired to ensure future availability in case the need arises. Create a centralized repository of profiles. Label these records in order to readily identify them. Add remarks for any future consideration."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.2.5.4" ;
    skos:prefLabel "Archive and retain records of non-hires"@en .

<http://ots.local/thesaurus/apqc/7_3_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_3_1> ;
    skos:definition "Creating and maintaining a mechanism through which new employees acquire the necessary knowledge, skills, and behaviors to become effective organizational members and insiders. Conduct formal meetings, lectures, videos, printed materials, and/or computer-based orientations to introduce newcomers to their new jobs and the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.3.1.1" ;
    skos:prefLabel "Develop employee onboarding program"@en .

<http://ots.local/thesaurus/apqc/7_3_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_3_1> ;
    skos:definition "Bringing the employee on-boarding program into effect. Implement Develop employee onboarding program [10474]. Conduct training sessions and employee engagement programs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.3.1.2" ;
    skos:prefLabel "Implement employee onboarding program"@en .

<http://ots.local/thesaurus/apqc/7_3_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_3_1> ;
    skos:definition "Assessing the performance and effectiveness of employee on-boarding program. Examine the performance of on-boarding program through feedback and reviews from the new employees. Create web and written forms. Obtain information through face-to-face discussions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.3.1.3" ;
    skos:prefLabel "Monitor and update employee onboarding program"@en .

<http://ots.local/thesaurus/apqc/7_3_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_3_2> ;
    skos:definition "Outlining the objectives for employee performance. Establish key performance objectives and measures such as customer-focus objectives, financially focused objectives, and employee growth objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.3.2.1" ;
    skos:prefLabel "Define employee performance objectives"@en .

<http://ots.local/thesaurus/apqc/7_3_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_3_2> ;
    skos:definition "Execution of employee reviews/performance on a frequent basis. May include ongoing feedback and coaching activities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.3.2.2" ;
    skos:prefLabel "Review employee performance"@en .

<http://ots.local/thesaurus/apqc/7_3_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_3_2> ;
    skos:definition "Document the results of both formal reviews to include both positive and negative feedback and commentary. May include acknowledgement by involved parties."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.3.2.3" ;
    skos:prefLabel "Document employee performance"@en .

<http://ots.local/thesaurus/apqc/7_3_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_3_2> ;
    skos:definition "Assessing and revamping performance programs, including the instruments used to measure employee performance standards. Review and upgrade these performance programs to avoid any deprivations and ensure effectiveness."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.3.2.4" ;
    skos:prefLabel "Monitor and update performance program"@en .

<http://ots.local/thesaurus/apqc/7_3_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_3_3> ;
    skos:definition "Outlining the guidelines for development of employees. Design development policies and procedures to identify areas of growth for employees, either in their current position or in preparation for future roles. Include topics related to knowledge and skill development."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.3.3.1" ;
    skos:prefLabel "Define employee development guidelines"@en .

<http://ots.local/thesaurus/apqc/7_3_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_3_3> ;
    skos:definition "Designing a future career path for the employees that encourages them to explore and gather information."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.3.3.2" ;
    skos:prefLabel "Develop employee career plans and career paths"@en .

<http://ots.local/thesaurus/apqc/7_3_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_3_3> ;
    skos:definition "Administering the development of employee skills. Conduct training, coaching and mentoring, job-rotation and cross training, lateral moves, etc. Maintain records of employee skills and competencies."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.3.3.3" ;
    skos:prefLabel "Manage employee skill and competency development"@en .

<http://ots.local/thesaurus/apqc/7_3_3_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_3_3_4> ;
    skos:definition "Determining roles that are essential to organizational performance or continuity and that require succession planning."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.3.3.4.1" ;
    skos:prefLabel "Identify critical roles"@en .

<http://ots.local/thesaurus/apqc/7_3_3_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_3_3_4> ;
    skos:definition "Identifying and selecting employees with the potential to assume critical roles based on defined criteria and future capability requirements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.3.3.4.2" ;
    skos:prefLabel "Select potential successors"@en .

<http://ots.local/thesaurus/apqc/7_3_3_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_3_3_4> ;
    skos:definition "Creating and executing development plans for identified successors to prepare them for future roles through targeted learning and experience opportunities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.3.3.4.3" ;
    skos:prefLabel "Develop and implement individual succession plans"@en .

<http://ots.local/thesaurus/apqc/7_3_3_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_3_3_4> ;
    skos:definition "Reviewing succession plans on a regular basis and updating them to reflect changes in roles, talent, organizational priorities, and performance outcomes."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.3.3.4.4" ;
    skos:prefLabel "Review and update succession plans"@en .

<http://ots.local/thesaurus/apqc/7_3_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_3_4> ;
    skos:definition "Identifying the skills, competencies, and knowledge required by the organization to achieve its strategic goals and ensuring employees' growth directly contributes to achieving those goals."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.3.4.1" ;
    skos:prefLabel "Align organizational development needs to employees"@en .

<http://ots.local/thesaurus/apqc/7_3_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_3_4> ;
    skos:definition "Defining the skills, knowledge, abilities, and attributes needed to achieve the desired core capabilities and competencies of the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.3.4.2" ;
    skos:prefLabel "Define employees competencies and skills"@en .

<http://ots.local/thesaurus/apqc/7_3_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_3_4> ;
    skos:definition "Aligning the learning programs with the core capabilities and competencies of the organization. Contextualize the training programs so that employees can expand their knowledge base and add new skills in line with the core competencies of the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.3.4.3" ;
    skos:prefLabel "Align learning programs with competencies and skills"@en .

<http://ots.local/thesaurus/apqc/7_3_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_3_4> ;
    skos:definition "Determining the training necessitated by business processes, using an examination of skill sets that are needed by the organization and those already possessed. Examine the various skills required by individual employees. Design training in light of the availability of resources to provide specific segments of training."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.3.4.4" ;
    skos:prefLabel "Establish training needs by analysis of required and available skills"@en .

<http://ots.local/thesaurus/apqc/7_3_4_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_3_4> ;
    skos:definition "Creating, implementing, and managing the programs for training employees. Create and design sessions on the basis of the needs and the availability of the skills. Conduct the sessions in person or virtually. Manage all aspects related to the training programs. Consider including literacy training, interpersonal skills training, technical training, problem-solving training, diversity or sensitivity training, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.3.4.5" ;
    skos:prefLabel "Develop, conduct, and manage employee training programs"@en .

<http://ots.local/thesaurus/apqc/7_3_4_6_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_3_4_6> ;
    skos:definition "Coordinating with third party certification authorities to provide training and certifications for necessary skills."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.3.4.6.1" ;
    skos:prefLabel "Liaise with external certification authorities"@en .

<http://ots.local/thesaurus/apqc/7_3_4_6_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_3_4_6> ;
    skos:definition "Providing tests to the workforce that will satisfy completion of certifications."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.3.4.6.2" ;
    skos:prefLabel "Administer certification tests"@en .

<http://ots.local/thesaurus/apqc/7_3_4_6_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_3_4_6> ;
    skos:definition "Ascertaining the experience level needed to qualify for a specific job or certification within the organization. Some certificates require practical experience as well as training programs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.3.4.6.3" ;
    skos:prefLabel "Appraise experience qualifications"@en .

<http://ots.local/thesaurus/apqc/7_3_4_6_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_3_4_6> ;
    skos:definition "Administering certificates to all candidates that have successfully met experience qualifications, and passed all tests necessary to obtain the certificate."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.3.4.6.4" ;
    skos:prefLabel "Administer certificate issue and maintenance"@en .

<http://ots.local/thesaurus/apqc/7_3_4_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_3_4> ;
    skos:definition "Oversight of the organization's learning programs.  This process also includes the effectiveness of these programs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.3.4.7" ;
    skos:prefLabel "Monitor and evaluate learning programs"@en .

<http://ots.local/thesaurus/apqc/7_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_4> ;
    skos:definition "Managing labor relations, the collective bargaining process, and the relationships between the labor and management. Take care of employee grievances."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.4.1" ;
    skos:prefLabel "Manage labor relations"@en .

<http://ots.local/thesaurus/apqc/7_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_4> ;
    skos:definition "Managing any negotiations between an employer and a group of employees that determine the conditions of employment. Engage employees to reach agreements in regulating working conditions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.4.2" ;
    skos:prefLabel "Manage collective bargaining process"@en .

<http://ots.local/thesaurus/apqc/7_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_4> ;
    skos:definition "Handling partnerships between labor and management. Develop a lasting two-way relationship that is beneficial for the labor, management, and the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.4.3" ;
    skos:prefLabel "Manage labor management partnerships"@en .

<http://ots.local/thesaurus/apqc/7_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_4> ;
    skos:definition "Taking care or resolving any complaint raised by an employee by procedures provided for in a collective agreement, an employment contract, or by other mechanisms established by an employer."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.4.4" ;
    skos:prefLabel "Manage employee grievances"@en .

<http://ots.local/thesaurus/apqc/7_4_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_4> ;
    skos:definition "Awareness of the employee legislature that is in place for the organization.  The regulatory environment could include areas, regions, countries, or technologies (around AI, for example)."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.4.5" ;
    skos:prefLabel "Monitor legal and regulatory environment"@en .

<http://ots.local/thesaurus/apqc/7_5_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_5_1> ;
    skos:definition "Creating the framework for the provision of salary/compensation to employees. Break down the salary structure into different components such as fixed pay, variable pay, bonus, and allowances such medical allowance, and rent allowance, etc. Develop, adjust, and maintain a pay structure."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.5.1.1" ;
    skos:prefLabel "Develop salary/compensation structure and plan"@en .

<http://ots.local/thesaurus/apqc/7_5_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_5_1> ;
    skos:definition "Developing a plan for provision of rewards, commission, and benefits to employees. Plan health benefits, retirement benefits, wellness plans, and non-monetary benefits, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.5.1.2" ;
    skos:prefLabel "Develop benefits and rewards plan"@en .

<http://ots.local/thesaurus/apqc/7_5_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_5_1> ;
    skos:definition "Analyzing and evaluating the organization's benefits and rewards plan. Compare/Benchmark the benefits and employees plan with other organizations to adhere to industry standard practices."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.5.1.3" ;
    skos:prefLabel "Perform competitive analysis of benefits and rewards"@en .

<http://ots.local/thesaurus/apqc/7_5_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_5_1> ;
    skos:definition "Recognizing the employee requirements for compensation on the basis of the financial, benefits, and HR policies of the organization. Recognize individual compensation requirements regarding the financial policies of the organization. Consider the benefits plan and overall HR policies while selecting compensation requirements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.5.1.4" ;
    skos:prefLabel "Identify compensation requirements based on financial, benefits, and HR policies"@en .

<http://ots.local/thesaurus/apqc/7_5_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_5_1> ;
    skos:definition "Managing the provision of compensations and rewards to the employees while maintaining consistency with the compensation and benefits plan. Follow the compensation and benefits plan rigorously in order to avoid any discrepancies."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.5.1.5" ;
    skos:prefLabel "Administer compensation and rewards to employees"@en .

<http://ots.local/thesaurus/apqc/7_5_1_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_5_1> ;
    skos:definition "Rewarding and stimulating the performance efforts of employees. Create methods for motivating employees. Spur extrinsic and intrinsic motivation."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.5.1.6" ;
    skos:prefLabel "Reward and motivate employees"@en .

<http://ots.local/thesaurus/apqc/7_5_1_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_5_1> ;
    skos:definition "Reassessing the indicators for retention and motivation of employees. Monitor the indicators that signal the levels of motivation and retention. Regularly update and upgrade indicators to avoid depreciation and ensure high efficiency."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.5.1.7" ;
    skos:prefLabel "Review engagement and retention indicators"@en .

<http://ots.local/thesaurus/apqc/7_5_1_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_5_1> ;
    skos:definition "Analyzing existing compensation plans and making changes necessary to continue to retain employees."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.5.1.8" ;
    skos:prefLabel "Review compensation plan"@en .

<http://ots.local/thesaurus/apqc/7_5_1_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_5_1> ;
    skos:definition "Evaluating benefits and rewards plans to assess effectiveness, alignment with workforce needs, and consistency with organizational reward and recognition objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.5.1.9" ;
    skos:prefLabel "Review benefits and rewards plan"@en .

<http://ots.local/thesaurus/apqc/7_5_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_5_2> ;
    skos:definition "Implementing the programs that specify employee benefits, other than salary provided, such as those concerning medical care, death, and disability."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.5.2.1" ;
    skos:prefLabel "Deliver employee benefits program"@en .

<http://ots.local/thesaurus/apqc/7_5_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_5_2> ;
    skos:definition "Handling the employee enrollment for obtaining benefits. Manage employee enrollment and eligibility, including work and life status/event changes. Encourage employees to enroll for benefits."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.5.2.2" ;
    skos:prefLabel "Administer benefit enrollment"@en .

<http://ots.local/thesaurus/apqc/7_5_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_5_2> ;
    skos:definition "Processing any formal requests or demands made by the employees claiming that they have earned some benefits. Includes escalation to management."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.5.2.3" ;
    skos:prefLabel "Process benefits claims"@en .

<http://ots.local/thesaurus/apqc/7_5_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_5_2> ;
    skos:definition "Carrying out reconciliation of benefits delivered to employees. Compare the estimated benefit requirement made by the employee and the actual amount of benefits the employee is entitled to receive."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.5.2.4" ;
    skos:prefLabel "Perform benefit reconciliation"@en .

<http://ots.local/thesaurus/apqc/7_5_3_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_5_3_1> ;
    skos:definition "Creation and execution of a plan that might allow for work from home days, or alternate hours."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.5.3.1.1" ;
    skos:prefLabel "Manage flexible working"@en .

<http://ots.local/thesaurus/apqc/7_5_3_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_5_3_1> ;
    skos:definition "Managing transportation-related programs and services provided to employees to support commuting, mobility, and work/life balance objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.5.3.1.2" ;
    skos:prefLabel "Manage transportation programs and services"@en .

<http://ots.local/thesaurus/apqc/7_5_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_5_3> ;
    skos:definition "Creating a support structure that aligns with local and federal laws that allow for support for families. This could include things like maternity leave, care for a family member, or in some cases, extended sick leave."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.5.3.2" ;
    skos:prefLabel "Develop employee and family support systems"@en .

<http://ots.local/thesaurus/apqc/7_5_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_5> ;
    skos:definition "Managing the sum of all financial records of salaries for an employee, including wages, bonuses, and deductions. Use a payroll management system to deal with the financial aspects of employees' salaries, allowances, deductions, gross pay, net pay, etc. Generate pay slips for a specific period."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.5.4" ;
    skos:prefLabel "Administer Payroll"@en .

<http://ots.local/thesaurus/apqc/7_5_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_5> ;
    skos:definition "Procuring and handling suggestions from employees, and performing research on employees. Manage and analyze the programs that help the organization to tap into employee ideas for improving the organization's processes and/or products. Use surveys, focus groups, and other data-gathering methods to find out the attitudes, opinions, and feelings of members of an organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.5.5" ;
    skos:prefLabel "Manage/Collect employee suggestions and perform employee research"@en .

<http://ots.local/thesaurus/apqc/7_6_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_6> ;
    skos:definition "Administering the process of promoting and demoting employees. Design a system for advancing or demoting an employee's rank or position. Leverage techniques such as horizontal promotion, vertical promotion, dry promotion, and involuntary/voluntary demotion."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.6.1" ;
    skos:prefLabel "Manage promotion and demotion process"@en .

<http://ots.local/thesaurus/apqc/7_6_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_6_2> ;
    skos:definition "Managing and administering instances where a person stops employment completely."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.6.2.1" ;
    skos:prefLabel "Manage retirement"@en .

<http://ots.local/thesaurus/apqc/7_6_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_6_2> ;
    skos:definition "Managing the period of time that an employee must be away from their primary job, while maintaining the status of employee (i.e., paid and unpaid leave of absence but not vacations, holidays, hiatuses, sabbaticals, and work-from-home programs)."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.6.2.2" ;
    skos:prefLabel "Manage leave of absence"@en .

<http://ots.local/thesaurus/apqc/7_6_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_6_2> ;
    skos:definition "Coordinating activities related to employee departures, including transitions, knowledge transfer, and administrative actions, to support orderly and compliant workforce exits."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.6.2.3" ;
    skos:prefLabel "Manage offboarding"@en .

<http://ots.local/thesaurus/apqc/7_6_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_6_2> ;
    skos:definition "Helping former employees transition to new jobs or to re-orient themselves in the job market. Deliver help through one-on-one sessions or in a group format. Provide guidance in career evaluation, resume writing, interview preparation, developing networks, and job searching."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.6.2.4" ;
    skos:prefLabel "Develop and implement employee outplacement"@en .

<http://ots.local/thesaurus/apqc/7_6_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_6_3> ;
    skos:definition "Manage employees who are sent to live abroad or hired from abroad for a defined time period."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.6.3.1" ;
    skos:prefLabel "Manage expatriates"@en .

<http://ots.local/thesaurus/apqc/7_7_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_7> ;
    skos:definition "Providing information and reports regarding employees to management."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.7.1" ;
    skos:prefLabel "Manage reporting processes"@en .

<http://ots.local/thesaurus/apqc/7_7_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_7> ;
    skos:definition "Handling instances where an employee believes that he/she has been inappropriately treated or he/she desires clarification. Encourage employees to inquire when needed. Record and clarify the issues for which the enquiry has been made."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.7.2" ;
    skos:prefLabel "Manage employee inquiry process"@en .

<http://ots.local/thesaurus/apqc/7_7_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_7> ;
    skos:definition "Capturing and updating employee information and data and information on the employees."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.7.3" ;
    skos:prefLabel "Manage and maintain employee data"@en .

<http://ots.local/thesaurus/apqc/7_7_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_7> ;
    skos:definition "Administering and maintaining HR information systems that take care of activities related to HR, accounting, management, and payroll."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.7.4" ;
    skos:prefLabel "Manage human resource information systems"@en .

<http://ots.local/thesaurus/apqc/7_7_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_7> ;
    skos:definition "Creating and maintaining performance metrics for employees. Create and manage a strategic system of data and statistics to accurately gauge each employee's information. Consider productivity metrics, efficiency metrics, training metrics, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.7.5" ;
    skos:prefLabel "Develop and manage employee measures"@en .

<http://ots.local/thesaurus/apqc/7_7_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_7> ;
    skos:definition "Developing and maintaining systems for managing the time and attendance of employees. Routinely upgrade the process and systems that track when employees start and stop work, the department where the work is performed, attendance in addition to tracking meals and breaks, the type of work performed, and the number of items produced."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.7.6" ;
    skos:prefLabel "Develop and manage time and attendance systems"@en .

<http://ots.local/thesaurus/apqc/7_7_7_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_7_7> ;
    skos:definition "Collect and manage requirements from various enterprise stakeholders about workforce analytics."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.7.7.1" ;
    skos:prefLabel "Determine stakeholder requirements"@en .

<http://ots.local/thesaurus/apqc/7_7_7_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_7_7> ;
    skos:definition "Summarize stakeholder requirements into discrete research questions in support of workforce analytics."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.7.7.2" ;
    skos:prefLabel "Identify research questions"@en .

<http://ots.local/thesaurus/apqc/7_7_7_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_7_7> ;
    skos:definition "Consider stakeholder requirements, research questions, and organizations standards around research to select appropriate research methodology in support of workforce analytics."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.7.7.3" ;
    skos:prefLabel "Select workforce analysis methodology"@en .

<http://ots.local/thesaurus/apqc/7_7_7_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_7_7> ;
    skos:definition "Identify appropriate data sources for workforce analytics data while considering organizational standards for data sources."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.7.7.4" ;
    skos:prefLabel "Identify workforce data sources"@en .

<http://ots.local/thesaurus/apqc/7_7_7_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_7_7> ;
    skos:definition "Collect and procure, as needed, workforce data from internal and external data sources in support of workforce analytics."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.7.7.5" ;
    skos:prefLabel "Gather workforce data"@en .

<http://ots.local/thesaurus/apqc/7_7_8_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_7_8> ;
    skos:definition "Logically and statistically validate collected or purchased data in support of analytics needs"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.7.8.1" ;
    skos:prefLabel "Transform workforce analysis data"@en .

<http://ots.local/thesaurus/apqc/7_7_8_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_7_8> ;
    skos:definition "Synthesize insights from workforce analytics data"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.7.8.2" ;
    skos:prefLabel "Develop insights into workforce analytics outcomes"@en .

<http://ots.local/thesaurus/apqc/7_7_8_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_7_8> ;
    skos:definition "Summarize, package, and distribute results of workforce analysis."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.7.8.3" ;
    skos:prefLabel "Communicate workforce analysis outcomes"@en .

<http://ots.local/thesaurus/apqc/7_8_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_8> ;
    skos:definition "Creating a plan for managing communication among employees. Inform employees of direction. Counter resistance with change management approaches. Seek specific areas of input to the decision-making process. Seek varying degrees of involvement and co-creation."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.8.1" ;
    skos:prefLabel "Develop employee communication plan"@en .

<http://ots.local/thesaurus/apqc/7_8_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_8> ;
    skos:definition "Questioning employees to ascertain overall workplace satisfaction."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.8.2" ;
    skos:prefLabel "Conduct employee engagement surveys"@en .

<http://ots.local/thesaurus/apqc/7_8_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/7_8> ;
    skos:definition "Implementing the communication plan for employees. Initiate dialogues and engagement by monitoring the exchange of ideas and opinions, the development of personal relationships, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "7.8.3" ;
    skos:prefLabel "Deliver employee communications"@en .

<http://ots.local/thesaurus/apqc/8_1_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_1> ;
    skos:definition "Interacting with IT customers to understand the IT needs through a collaborative community through involvement, connection, and informed communication."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.1.1" ;
    skos:prefLabel "Understand IT customer communities"@en .

<http://ots.local/thesaurus/apqc/8_1_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_1> ;
    skos:definition "Evaluate the ability of the group of staff dependent on information technology, to align resources and critical processes according to organizational vision being able to deliver effectively and efficiently."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.1.2" ;
    skos:prefLabel "Assess IT customer operational capabilities"@en .

<http://ots.local/thesaurus/apqc/8_1_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_2> ;
    skos:definition "Understanding business requirements for the existing IT environment as well as future IT needs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.2.1" ;
    skos:prefLabel "Understand business requirements for IT capabilities"@en .

<http://ots.local/thesaurus/apqc/8_1_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_2> ;
    skos:definition "Understanding the complete logical structure and working of the organization's IT landscape. Assess the configuration of hardware and software (IT Assets) across the organization that supports overall business operations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.2.2" ;
    skos:prefLabel "Understand IT landscape"@en .

<http://ots.local/thesaurus/apqc/8_1_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_2> ;
    skos:definition "Developing goals to define IT vision. Define and document ideas, direction, and activities which enable information technology to reach these goals."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.2.3" ;
    skos:prefLabel "Develop IT visioning"@en .

<http://ots.local/thesaurus/apqc/8_1_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_2> ;
    skos:definition "Defining a roadmap to meet organizational expectations from information technology services while considering how it will affect the business."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.2.4" ;
    skos:prefLabel "Outline IT service expectations"@en .

<http://ots.local/thesaurus/apqc/8_1_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_3> ;
    skos:definition "Managing customer expectations of the existing IT environment while considering how it will affect the business."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.3.1" ;
    skos:prefLabel "Manage IT customer expectations"@en .

<http://ots.local/thesaurus/apqc/8_1_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_3> ;
    skos:definition "Defining the expected demand and usage of information technology services to meet organization's future business goals. Gather necessary information about the processes, resource requirements, and structures pertaining to planned business growth."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.3.2" ;
    skos:prefLabel "Define future IT services"@en .

<http://ots.local/thesaurus/apqc/8_1_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_3> ;
    skos:definition "Determining IT KPIs crucial to the organization's success. Measure indicators such as IT costs as percentage of revenue, IT maintenance ratio, and system downtime in an effort to evaluate the performance of IT across the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.3.3" ;
    skos:prefLabel "Determine IT performance indicators"@en .

<http://ots.local/thesaurus/apqc/8_1_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_3> ;
    skos:definition "Developing concise statements that position the value proposition around the pressing concerns of the internal IT user base, thereby showing how the IT offerings are the right fit for a segment of IT customers."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.3.4" ;
    skos:prefLabel "Create IT marketing messages"@en .

<http://ots.local/thesaurus/apqc/8_1_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_3> ;
    skos:definition "Creating a marketing strategy for IT offerings to customers. Plan processes for making budgets; identifying and developing media; and managing marketing content and promotional activities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.3.5" ;
    skos:prefLabel "Create IT service marketing plan"@en .

<http://ots.local/thesaurus/apqc/8_1_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_4> ;
    skos:definition "Developing a robust plan to replace or upgrade an organization's information technology systems. Understanding the business need of IT transformation from current to an expected state for the business. Developing a strategic plan for IT operating model, governance, service delivery, and workforce transformation."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.4.1" ;
    skos:prefLabel "Develop IT transformation plans"@en .

<http://ots.local/thesaurus/apqc/8_1_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_4> ;
    skos:definition "Identifying existing or potential IT gaps between the expected business performance levels and current business outcomes."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.4.2" ;
    skos:prefLabel "Collect IT customer requirements"@en .

<http://ots.local/thesaurus/apqc/8_1_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_4> ;
    skos:definition "Assessing identified IT gaps to plan for remediation efforts to allow outcomes to meet established performance levels."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.4.3" ;
    skos:prefLabel "Analyze IT customer requirements"@en .

<http://ots.local/thesaurus/apqc/8_1_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_4> ;
    skos:definition "Identifying IT opportunities on the basis of collection and analysis of IT customer requirements, then prioritize the identified IT opportunities on the basis of their importance."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.4.4" ;
    skos:prefLabel "Identify and prioritize IT opportunities"@en .

<http://ots.local/thesaurus/apqc/8_1_4_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_4> ;
    skos:definition "Providing a plan of action to provide solution to IT customers. The solution design should be based on the collection and analysis of IT customer requirements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.4.5" ;
    skos:prefLabel "Facilitate solution design activities"@en .

<http://ots.local/thesaurus/apqc/8_1_4_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_4> ;
    skos:definition "Prioritizing IT outcomes based on need, effectiveness, and efficiency."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.4.6" ;
    skos:prefLabel "Prioritize IT outcomes"@en .

<http://ots.local/thesaurus/apqc/8_1_4_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_4> ;
    skos:definition "Create a business case with value proposition indicating current situation, proposed solution, financial analysis, and measurable benefits to the IT customers."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.4.7" ;
    skos:prefLabel "Develop business cases"@en .

<http://ots.local/thesaurus/apqc/8_1_4_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_4> ;
    skos:definition "Supporting business case with supporting research, business analysis, and background information on IT transformation."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.4.8" ;
    skos:prefLabel "Support business case"@en .

<http://ots.local/thesaurus/apqc/8_1_4_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_4> ;
    skos:definition "Creating a blueprint for execution of IT transformation from the existing state to the planned organizational structure based on the value proposition and projected business growth."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.4.9" ;
    skos:prefLabel "Develop transformation roadmap"@en .

<http://ots.local/thesaurus/apqc/8_1_5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_5> ;
    skos:definition "Understand requirements related to information technology services considering enterprise-level effects and understand potential achievements in the business environment."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.5.1" ;
    skos:prefLabel "Understand IT service requirements"@en .

<http://ots.local/thesaurus/apqc/8_1_5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_5> ;
    skos:definition "Forecasting demand for IT services using current business growth, research, and customer feedback. Refine these forecasts, inspect the approach used in creating forecasts, and determine its accuracy."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.5.2" ;
    skos:prefLabel "Forecast IT service demand"@en .

<http://ots.local/thesaurus/apqc/8_1_5_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_5> ;
    skos:definition "Maintain information about IT deliverables, prices, contact points, and processes for requesting a service."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.5.3" ;
    skos:prefLabel "Maintain IT services catalog"@en .

<http://ots.local/thesaurus/apqc/8_1_5_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_5> ;
    skos:definition "Designing and maintaining commitment of service by performance evaluation of IT services and communicate the results to the management."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.5.4" ;
    skos:prefLabel "Define service level agreement"@en .

<http://ots.local/thesaurus/apqc/8_1_5_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_5> ;
    skos:definition "Maintaining and documenting commitment of service to staff for information technology contracts including providing software or hardware solution through communication channels like phone, email, and on-site services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.5.5" ;
    skos:prefLabel "Maintain IT customer contracts"@en .

<http://ots.local/thesaurus/apqc/8_1_5_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_5> ;
    skos:definition "Establish a service level agreement, which is a negotiated agreement designed to create a common understanding about services, priorities, and responsibilities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.5.6" ;
    skos:prefLabel "Negotiate and establish service level agreements"@en .

<http://ots.local/thesaurus/apqc/8_1_5_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_5> ;
    skos:definition "Conveying the improvement opportunities for the business and level of IT services. Leverage the results obtained from the performance metrics of the business and IT service levels to identify and recognize any opportunities that would improve or enhance the efficiency of the business and IT service-level structure. Communicate these opportunities to management in order for the improvements to take effect."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.5.7" ;
    skos:prefLabel "Develop and maintain improvement processes"@en .

<http://ots.local/thesaurus/apqc/8_1_6_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_6> ;
    skos:definition "Create mechanisms for effective public relationship in order to preserve the image and goodwill of the organization through the process."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.6.1" ;
    skos:prefLabel "Establish relationship management mechanisms"@en .

<http://ots.local/thesaurus/apqc/8_1_6_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_6> ;
    skos:definition "Understanding the strategy for staff dependent on information technology. Create a plan to create services and solutions, conduct daily operations, and train new employees."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.6.2" ;
    skos:prefLabel "Understand IT customer strategy"@en .

<http://ots.local/thesaurus/apqc/8_1_6_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_6> ;
    skos:definition "Understanding the environment of staff dependent on information technology. Assess and evaluate services and solutions used by customers to conduct daily operations, and train new employees."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.6.3" ;
    skos:prefLabel "Understand IT customer environment"@en .

<http://ots.local/thesaurus/apqc/8_1_6_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_6> ;
    skos:definition "Conveying the goals and objectives of the IT function and how it contributes to the overall business objectives to staff and departments across the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.6.4" ;
    skos:prefLabel "Communicate IT capabilities"@en .

<http://ots.local/thesaurus/apqc/8_1_6_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_6> ;
    skos:definition "Managing the IT requirements for business objectives. Identify the requirements of hardware and software equipment to store, retrieve, transmit, and manipulate data related to business operations. Consider factors such as functional, design, growth phases, and delivery schedule while managing IT requirements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.6.5" ;
    skos:prefLabel "Manage IT requirements"@en .

<http://ots.local/thesaurus/apqc/8_1_7_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_7> ;
    skos:definition "Gather data from each service target defined in an SLA for a time segment or review period to evaluate an overall performance percentage."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.7.1" ;
    skos:prefLabel "Assess SLA compliance"@en .

<http://ots.local/thesaurus/apqc/8_1_7_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_7> ;
    skos:definition "Prioritizing SLA compliance issues and plan for remediation."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.7.2" ;
    skos:prefLabel "Triage SLA compliance issues"@en .

<http://ots.local/thesaurus/apqc/8_1_7_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_7> ;
    skos:definition "Collecting customer feedback about IT products and services effectiveness based on overall satisfaction. The data is collected through surveys, customer responses, and feedbacks based on the delivered products/services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.7.3" ;
    skos:prefLabel "Collect feedback about IT products and services"@en .

<http://ots.local/thesaurus/apqc/8_1_7_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_1_7> ;
    skos:definition "Providing stakeholders with collected IT performance measures for further development based on evaluation."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.1.7.4" ;
    skos:prefLabel "Synthesize and distribute IT performance information"@en .

<http://ots.local/thesaurus/apqc/8_2_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_1> ;
    skos:definition "Building and maintaining intelligence towards changing organizational goals, supporting management, and operational or functional levels of the business. It is the ability to understand business trends that present threats or opportunities for IT in an organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.1.1" ;
    skos:prefLabel "Build and maintain IT strategic intelligence"@en .

<http://ots.local/thesaurus/apqc/8_2_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_1> ;
    skos:definition "Monitoring and evaluating existing and forthcoming technologies to meet the current and future growth plans for business operations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.1.2" ;
    skos:prefLabel "Monitor and map current and emerging technologies"@en .

<http://ots.local/thesaurus/apqc/8_2_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_1> ;
    skos:definition "Defining the integration of digital technology into business operations and service delivery, and convey the strategy to different segments of business. It is always backed by continuous improvement followed by periodic review and change per requirement of the business."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.1.3" ;
    skos:prefLabel "Define and communicate digital transformation strategy"@en .

<http://ots.local/thesaurus/apqc/8_2_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_1> ;
    skos:definition "Developing the process of aligning the organization's business divisions and staff members with the organization's planned objectives for IT."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.1.4" ;
    skos:prefLabel "Develop IT strategic alignment"@en .

<http://ots.local/thesaurus/apqc/8_2_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_1> ;
    skos:definition "Systematic approach to clearly communicate and operate the usage of information technology as it relates to business objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.1.5" ;
    skos:prefLabel "Articulate IT alignment principles"@en .

<http://ots.local/thesaurus/apqc/8_2_1_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_1> ;
    skos:definition "Maintaining alignment of the organization's business divisions and staff members with the organization's planned objectives for IT."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.1.6" ;
    skos:prefLabel "Maintain IT strategic alignment"@en .

<http://ots.local/thesaurus/apqc/8_2_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_2> ;
    skos:definition "Create and certify the standards to determine the value of the investments, projects, and activities of IT function for the overall business objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.2.1" ;
    skos:prefLabel "Establish and validate IT value criteria"@en .

<http://ots.local/thesaurus/apqc/8_2_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_2> ;
    skos:definition "Determining the uninvested amount out of the total approved amount for overall IT management, IT investments, projects, and activities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.2.2" ;
    skos:prefLabel "Determine IT portfolio investment balance"@en .

<http://ots.local/thesaurus/apqc/8_2_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_2> ;
    skos:definition "Evaluating IT investment projects to achieve overall business objectives in regard to implementation, efficiency, and profitability."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.2.3" ;
    skos:prefLabel "Evaluate proposed IT investment projects"@en .

<http://ots.local/thesaurus/apqc/8_2_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_2> ;
    skos:definition "Listing the IT projects in the order of most important to the least. Determining which of many IT projects are most important or critical to business operations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.2.4" ;
    skos:prefLabel "Prioritize IT projects"@en .

<http://ots.local/thesaurus/apqc/8_2_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_2> ;
    skos:definition "Aligning physical IT resources like software, IT infrastructure, networks, and non-physical resources like technology expertise, to strategic objectives ranked by their importance in achieving the strategic goals."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.2.5" ;
    skos:prefLabel "Align IT resources to strategic priorities"@en .

<http://ots.local/thesaurus/apqc/8_2_2_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_2> ;
    skos:definition "Aligning IT investments, projects, and activities to achieve overall business objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.2.6" ;
    skos:prefLabel "Align IT portfolio to business objectives"@en .

<http://ots.local/thesaurus/apqc/8_2_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_3> ;
    skos:definition "Creating and publishing high level statements of the fundamental values (principles) based on the organization's objectives that guide Information Technology decision-making and activities, and are the foundation for enterprise architecture."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.3.1" ;
    skos:prefLabel "Create and publish enterprise architecture principles"@en .

<http://ots.local/thesaurus/apqc/8_2_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_3> ;
    skos:definition "Establishing and operating a structure by which an enterprise defines appropriate strategies and ensures development alignment with those strategies. Create and establish the rules, regulations, policies, and standards that will govern the individual components of the IT architecture, as well as the architecture in its entirety."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.3.2" ;
    skos:prefLabel "Establish and operate enterprise architecture governance"@en .

<http://ots.local/thesaurus/apqc/8_2_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_3> ;
    skos:definition "Systematically investigating and studying materials and sources relevant to the IT function. Reach meaningful insights and conclusions in the form of new ideas and innovation for delivering IT services and solutions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.3.3" ;
    skos:prefLabel "Research technologies to innovate IT services and solutions"@en .

<http://ots.local/thesaurus/apqc/8_2_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_3> ;
    skos:definition "Analyze the value driven through IT projects and redefine and/or reprioritize. Evaluate planning, organizing, and implementation of IT projects based on research outcomes and business objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.3.4" ;
    skos:prefLabel "Provide input to definition and prioritization of IT projects"@en .

<http://ots.local/thesaurus/apqc/8_2_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_4> ;
    skos:definition "Implementing strategy for designing, delivering, managing, and improving the way information technology be used in the organization. The goal of IT Service Management is to ensure that the right processes, people, and technology are in place to meet business goals."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.4.1" ;
    skos:prefLabel "Establish IT service management strategy and goals"@en .

<http://ots.local/thesaurus/apqc/8_2_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_4> ;
    skos:definition "Identifying operating and process requirement for designing, delivering, managing, and improving the way information technology be used in the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.4.2" ;
    skos:prefLabel "Identify IT service operating and process requirements"@en .

<http://ots.local/thesaurus/apqc/8_2_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_4> ;
    skos:definition "Create and design an organized and curated collection of all IT-related services that can be performed by, for, or within the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.4.3" ;
    skos:prefLabel "Define IT service catalog"@en .

<http://ots.local/thesaurus/apqc/8_2_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_4> ;
    skos:definition "Create a layered structure for IT service management framework ensuring right processes, people, and technology are in place to meet business goals."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.4.4" ;
    skos:prefLabel "Establish IT service management framework"@en .

<http://ots.local/thesaurus/apqc/8_2_4_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_4> ;
    skos:definition "Defining and implementing activities involved in designing, creating, delivering, supporting, and managing the lifecycle of information technology services within an organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.4.5" ;
    skos:prefLabel "Define and implement IT service management"@en .

<http://ots.local/thesaurus/apqc/8_2_4_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_4> ;
    skos:definition "Establishing services for providing support to users of IT services and solutions. Define the plethora of services along with tools and methods by which the organization assists users of computers, software products, or other electronic/mechanical products."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.4.6" ;
    skos:prefLabel "Define and deploy support service management process tools and methods"@en .

<http://ots.local/thesaurus/apqc/8_2_4_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_4> ;
    skos:definition "Supervising, analyzing, and reporting performance of information technology to ensure they are on-course and on-schedule in meeting the organizational objectives and performance targets."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.4.7" ;
    skos:prefLabel "Monitor and report IT performance"@en .

<http://ots.local/thesaurus/apqc/8_2_5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_5> ;
    skos:definition "Determining measures for evaluating the performance of IT services in the organization. Establish key performance indicators, including the IT services performance index."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.5.1" ;
    skos:prefLabel "Determine IT performance measures"@en .

<http://ots.local/thesaurus/apqc/8_2_5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_5> ;
    skos:definition "Establishing a governance model with its own structure and functions from where full or partial control can be exercised over the entire IT management system. Specify evaluation and quality control procedures in the structure."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.5.2" ;
    skos:prefLabel "Define IT control points and assurance procedures governance model"@en .

<http://ots.local/thesaurus/apqc/8_2_5_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_5> ;
    skos:definition "Monitoring and analyzing information technology performance measures to ensure timely completion, and that quality assurance is met at all steps of IT services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.5.3" ;
    skos:prefLabel "Monitor and analyze overall IT performance"@en .

<http://ots.local/thesaurus/apqc/8_2_5_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_5> ;
    skos:definition "Checking and analyzing predetermined financial targets and timelines of IT management system. Monitoring their profitability, feasibility, and consistency. Study the revenues generated."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.5.4" ;
    skos:prefLabel "Monitor and analyze IT financial performance"@en .

<http://ots.local/thesaurus/apqc/8_2_5_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_5> ;
    skos:definition "Examining and analyzing the value and benefits of IT service management to ensure benefits outweigh incurred costs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.5.5" ;
    skos:prefLabel "Monitor and analyze IT value and benefits"@en .

<http://ots.local/thesaurus/apqc/8_2_5_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_5> ;
    skos:definition "Create process to assign and manage IT assets that support organization's strategic goals."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.5.6" ;
    skos:prefLabel "Optimize IT resource allocation"@en .

<http://ots.local/thesaurus/apqc/8_2_5_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_5> ;
    skos:definition "Manage capabilities required for the successful delivery of information technology projects, which, by extension, affect the success of the overall IT services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.5.7" ;
    skos:prefLabel "Manage IT projects and services interdependencies"@en .

<http://ots.local/thesaurus/apqc/8_2_5_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_5> ;
    skos:definition "Process of collecting, analyzing, and reporting information regarding the performance of IT services and projects."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.5.8" ;
    skos:prefLabel "Report IT service and project performance"@en .

<http://ots.local/thesaurus/apqc/8_2_5_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_5> ;
    skos:definition "Select, establish, and operate analytics tool to analyze data and extract actionable and commercially relevant information on IT performance to evaluate or increase performance."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.5.9" ;
    skos:prefLabel "Select, deploy, and operate IT performance analytics tools"@en .

<http://ots.local/thesaurus/apqc/8_2_6_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_6> ;
    skos:definition "Process of evaluating performance to collect and analyze IT services and projects. Ensure expected IT service and project value based on established criteria."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.6.1" ;
    skos:prefLabel "Assess performance against IT service and project value criteria"@en .

<http://ots.local/thesaurus/apqc/8_2_6_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_6> ;
    skos:definition "Evaluate the value of the investments, projects, and activities of IT function by assigning it a quantifiable value with a profitable return to business operations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.6.2" ;
    skos:prefLabel "Quantify value of IT service and project portfolio investments"@en .

<http://ots.local/thesaurus/apqc/8_2_6_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_6> ;
    skos:definition "Conveying the value addition through adopting technology targeting towards integrated profitable business operations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.6.3" ;
    skos:prefLabel "Communicate business technology value contribution"@en .

<http://ots.local/thesaurus/apqc/8_2_6_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_6> ;
    skos:definition "Determining and implementing IT investments, projects, and activities based on trending technological advancements in the existing environment in order to achieve overall business objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.6.4" ;
    skos:prefLabel "Determine and implement IT portfolio adjustments"@en .

<http://ots.local/thesaurus/apqc/8_2_7_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_7> ;
    skos:definition "Establishing the standard for selecting IT research initiatives to align with organizational criteria for implementing future technologies."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.7.1" ;
    skos:prefLabel "Establish selection criteria for research initiatives"@en .

<http://ots.local/thesaurus/apqc/8_2_7_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_7> ;
    skos:definition "Assessing new and future technologies relevant to the organization's vision of its IT capabilities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.7.2" ;
    skos:prefLabel "Analyze emerging technology concepts"@en .

<http://ots.local/thesaurus/apqc/8_2_7_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_7> ;
    skos:definition "Identification of conceptual elements that define the benefits of technology to business."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.7.3" ;
    skos:prefLabel "Identify technology concepts and capabilities"@en .

<http://ots.local/thesaurus/apqc/8_2_7_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_7> ;
    skos:definition "Implement information technology research projects that focus on meeting the goals of the organization's IT services and capabilities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.7.4" ;
    skos:prefLabel "Execute IT research projects"@en .

<http://ots.local/thesaurus/apqc/8_2_7_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_7> ;
    skos:definition "Assessing IT research projects based on defined outcome expectations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.7.5" ;
    skos:prefLabel "Evaluate IT research project outcomes"@en .

<http://ots.local/thesaurus/apqc/8_2_7_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_7> ;
    skos:definition "Determine project viability. Promote relevant IT innovations that meet business objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.7.6" ;
    skos:prefLabel "Identify and promote viable concepts"@en .

<http://ots.local/thesaurus/apqc/8_2_7_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_2_7> ;
    skos:definition "Develop and plan long-term allocation of funds for information technology endeavors to meet business goals."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.2.7.7" ;
    skos:prefLabel "Develop and plan IT investment projects"@en .

<http://ots.local/thesaurus/apqc/8_3_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_1> ;
    skos:definition "Determining and evaluating IT regulatory and audit requirements. Train employees on regulatory and audit requirements. Records for the appropriate regulatory and audit agencies must be maintained and the new product process must be approved by the appropriate regulatory body before it is published to the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.1.1" ;
    skos:prefLabel "Determine and evaluate IT regulatory and audit requirements"@en .

<http://ots.local/thesaurus/apqc/8_3_1_10_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_1_10> ;
    skos:definition "Include alignment with established cybersecurity frameworks like NIST CSF, ISO 27001, and ENISA risk management guidelines."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.1.10.1" ;
    skos:prefLabel "Align IT risk management with cybersecurity frameworks"@en .

<http://ots.local/thesaurus/apqc/8_3_1_10_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_1_10> ;
    skos:definition "Ensure risk management processes are extended to cover OT systems and environments."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.1.10.2" ;
    skos:prefLabel "Integrate IT and OT risk management strategies"@en .

<http://ots.local/thesaurus/apqc/8_3_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_1> ;
    skos:definition "Understand the risk tolerance levels of individual business units, given risk-return trade-offs for one or more anticipated and predictable consequences."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.1.2" ;
    skos:prefLabel "Understand business unit risk tolerance"@en .

<http://ots.local/thesaurus/apqc/8_3_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_1> ;
    skos:definition "Determine the specific maximum risk to take in quantitative terms for each relevant risk sub-category, including strategic, operational, financial, and compliance risks."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.1.3" ;
    skos:prefLabel "Establish IT risk tolerance"@en .

<http://ots.local/thesaurus/apqc/8_3_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_1> ;
    skos:definition "Establish an individual or a group who is ultimately accountable for ensuring that IT risks are managed appropriately."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.1.4" ;
    skos:prefLabel "Establish risk ownership"@en .

<http://ots.local/thesaurus/apqc/8_3_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_1> ;
    skos:definition "Determine and maintain roles that are specialized in each risk areas and coordinating all risk management activities for IT function with due escalation structure."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.1.5" ;
    skos:prefLabel "Establish and maintain risk management roles"@en .

<http://ots.local/thesaurus/apqc/8_3_1_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_1> ;
    skos:definition "Establishing compliance objectives which ensures that the organization has systems of internal controls that adequately measure and manage IT risk."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.1.6" ;
    skos:prefLabel "Establish compliance objectives"@en .

<http://ots.local/thesaurus/apqc/8_3_1_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_1> ;
    skos:definition "Identifying and adopting information technology solutions to support changing regulatory compliance. Safeguard compliance and manage risk by outlining the risk policies and procedures."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.1.7" ;
    skos:prefLabel "Identify systems to support compliance"@en .

<http://ots.local/thesaurus/apqc/8_3_1_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_1> ;
    skos:definition "Developing a timely and continuous process to identify and evaluate activities that might hinder IT operations or an IT project's goals."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.1.8" ;
    skos:prefLabel "Identify and evaluate IT risk"@en .

<http://ots.local/thesaurus/apqc/8_3_1_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_1> ;
    skos:definition "Assess IT-related risk resilience strategies to ensure that the organization effectively manages its risk."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.1.9" ;
    skos:prefLabel "Evaluate IT-related risks resiliency"@en .

<http://ots.local/thesaurus/apqc/8_3_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_2> ;
    skos:definition "Determining resilience strategies to ensure that IT effectively manages it's delivery process to mitigate risk."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.2.1" ;
    skos:prefLabel "Determine IT delivery resiliency"@en .

<http://ots.local/thesaurus/apqc/8_3_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_2> ;
    skos:definition "Determining risks that could disrupt objectives of IT including physical, security, data, network, and cybersecurity."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.2.2" ;
    skos:prefLabel "Determine critical IT risks"@en .

<http://ots.local/thesaurus/apqc/8_3_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_2> ;
    skos:definition "Prioritize potential IT risks based on business need to ensure overall IT stability."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.2.3" ;
    skos:prefLabel "Prioritize IT risks"@en .

<http://ots.local/thesaurus/apqc/8_3_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_2> ;
    skos:definition "Establishing activities to improve opportunities and lessen threats for IT."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.2.4" ;
    skos:prefLabel "Establish mitigation approaches for IT risks"@en .

<http://ots.local/thesaurus/apqc/8_3_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_3> ;
    skos:definition "Evaluation of dynamic, strategic, and integrated approach to manage regulatory requirements and compliance obligations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.3.1" ;
    skos:prefLabel "Evaluate enterprise regulatory and compliance obligations"@en .

<http://ots.local/thesaurus/apqc/8_3_3_10> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_3> ;
    skos:definition "Identifying and supervising a blueprint of measures for managing risk in IT. Monitor actions to enhance opportunities and reduce threats to project objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.3.10" ;
    skos:prefLabel "Identify, supervise and monitor IT risk mitigation measures"@en .

<http://ots.local/thesaurus/apqc/8_3_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_3> ;
    skos:definition "Analyzing the impact of threats to critical IT assets across different departments and functions in the organization in terms of quantifiable results."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.3.2" ;
    skos:prefLabel "Analyze IT security threat impact"@en .

<http://ots.local/thesaurus/apqc/8_3_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_3> ;
    skos:definition "Develop and maintain IT compliance standards. Maintaining requirements set forth by such directives as GRCP, PMI RMP, CGRC, CGEIT, CRMA."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.3.3" ;
    skos:prefLabel "Create and maintain IT compliance requirements"@en .

<http://ots.local/thesaurus/apqc/8_3_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_3> ;
    skos:definition "Develop and maintain an architecture for securing and ensuring the privacy of data flows throughout the organization. Create, test, evaluate, and implement IT security policies to ensure the safe use of IT services and solutions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.3.4" ;
    skos:prefLabel "Create and maintain IT security policies, standards, and procedures"@en .

<http://ots.local/thesaurus/apqc/8_3_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_3> ;
    skos:definition "Develop and implement training in regard to managing IT risks, understanding criticality, impact, and opportunities associated with business objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.3.5" ;
    skos:prefLabel "Develop and deploy risk management training"@en .

<http://ots.local/thesaurus/apqc/8_3_3_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_3> ;
    skos:definition "Establishing processes to communicate IT risk to the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.3.6" ;
    skos:prefLabel "Establish risk reporting capabilities and responsibilities"@en .

<http://ots.local/thesaurus/apqc/8_3_3_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_3> ;
    skos:definition "Establishing standards for communications within the organization which creates the road map for successful understanding of strategic initiatives for both business units and information technology services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.3.7" ;
    skos:prefLabel "Establish communication standards"@en .

<http://ots.local/thesaurus/apqc/8_3_3_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_3> ;
    skos:definition "Evaluate IT risk and threat assessments by way of IT assets, information security, and breach points within the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.3.8" ;
    skos:prefLabel "Conduct IT risk and threat assessments"@en .

<http://ots.local/thesaurus/apqc/8_3_3_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_3> ;
    skos:definition "Monitoring and managing risks related to IT adoption within the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.3.9" ;
    skos:prefLabel "Monitor and manage IT activity risk"@en .

<http://ots.local/thesaurus/apqc/8_3_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_4> ;
    skos:definition "Evaluating IT business needs and IT's ability to recover from internal or external threat exposure."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.4.1" ;
    skos:prefLabel "Evaluate IT continuity"@en .

<http://ots.local/thesaurus/apqc/8_3_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_4> ;
    skos:definition "Identifying the limitations of the IT organization's ability to remediate disruptions in IT services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.4.2" ;
    skos:prefLabel "Identify IT continuity gaps"@en .

<http://ots.local/thesaurus/apqc/8_3_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_4> ;
    skos:definition "Integrating the disciplines of Emergency Response, Crisis Management, Disaster Recovery (technology continuity) and Business Continuity for IT."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.4.3" ;
    skos:prefLabel "Manage IT business continuity"@en .

<http://ots.local/thesaurus/apqc/8_3_5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_5> ;
    skos:definition "Evaluate principles or rules employed in controlling, directing, or managing IT services. Assessing requirements and policies related to confidentiality."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.5.1" ;
    skos:prefLabel "Assess IT regulatory and confidentiality requirements and policies"@en .

<http://ots.local/thesaurus/apqc/8_3_5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_5> ;
    skos:definition "Defining and managing organization's approach to governing IT security and ensuring the privacy of data flows throughout the organization. Establish and manage tools to support the governance process in order to avoid misuse of information and breach of organizational privacy."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.5.2" ;
    skos:prefLabel "Create IT security, privacy, and data protection risk governance"@en .

<http://ots.local/thesaurus/apqc/8_3_5_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_5> ;
    skos:definition "Outlining and establishing policies, regulations, standards, and procedures for IT data security and privacy."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.5.3" ;
    skos:prefLabel "Define IT data security and privacy policies, standards, and procedures"@en .

<http://ots.local/thesaurus/apqc/8_3_5_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_5> ;
    skos:definition "Identifying, examining, and reviewing physical and logical IT data security measures such as hardware security (smart cards), cryptographic protocols, and access control."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.5.4" ;
    skos:prefLabel "Review and monitor physical and logical IT data security measures"@en .

<http://ots.local/thesaurus/apqc/8_3_5_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_5> ;
    skos:definition "Identifying, examining, and reviewing security control for IT applications. Test, analyze, and implement security protocols in order to safeguard IT applications."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.5.5" ;
    skos:prefLabel "Review and monitor application security controls"@en .

<http://ots.local/thesaurus/apqc/8_3_5_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_5> ;
    skos:definition "Identifying and examining security controls for physical environment of information technology such as business facilities, equipment, and resources."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.5.6" ;
    skos:prefLabel "Review and monitor IT physical environment security controls"@en .

<http://ots.local/thesaurus/apqc/8_3_5_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_5> ;
    skos:definition "Monitoring and evaluating network intrusion detection for any malicious activity or policy violations. Identify the gaps in order to resolve threats and enhance existing network security."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.5.7" ;
    skos:prefLabel "Monitor/analyze network intrusion detection data and resolve threats"@en .

<http://ots.local/thesaurus/apqc/8_3_6_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_6> ;
    skos:definition "Conducting projects in order to enhance set standards, established guidelines, and risk preventive measures for IT risk and resilience."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.6.1" ;
    skos:prefLabel "Conduct projects to enhance IT compliance and remediate risk"@en .

<http://ots.local/thesaurus/apqc/8_3_6_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_6> ;
    skos:definition "Examine compliance control systems and tools implemented for internal and external IT services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.6.2" ;
    skos:prefLabel "Conduct IT compliance control auditing of internal and external services"@en .

<http://ots.local/thesaurus/apqc/8_3_6_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_6> ;
    skos:definition "Execute IT compliance reporting in order to review processes, standards, regulations, and laws are followed as laid out by the regulatory bodies."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.6.3" ;
    skos:prefLabel "Perform IT compliance reporting"@en .

<http://ots.local/thesaurus/apqc/8_3_6_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_6> ;
    skos:definition "Identify and escalate issues related to IT compliance to ensure that corrective measures are taken."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.6.4" ;
    skos:prefLabel "Identify and escalate IT compliance issues and remediation requirements"@en .

<http://ots.local/thesaurus/apqc/8_3_6_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_6> ;
    skos:definition "Supporting audits and reports through external resources. This process requires the organization to follow all the regulations set forth by external auditors."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.6.5" ;
    skos:prefLabel "Support external audits and reports"@en .

<http://ots.local/thesaurus/apqc/8_3_7_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_7> ;
    skos:definition "Conducting projects to improve the strategy and process for rapidly adapting to any threat in IT."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.7.1" ;
    skos:prefLabel "Conduct IT resilience improvement projects"@en .

<http://ots.local/thesaurus/apqc/8_3_7_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_7> ;
    skos:definition "Develop, document, and maintain plans to ensure uninterrupted operations of critical IT services (for example, ransomware recovery). Determine resources such as specialized personnel, equipment, support infrastructure, third-party access, legal and financial aspects."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.7.2" ;
    skos:prefLabel "Develop, document, and maintain IT business continuity planning"@en .

<http://ots.local/thesaurus/apqc/8_3_7_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_7> ;
    skos:definition "Implement and enforce procedures and policies in order to control changes in IT services and solutions. Manage changes in a rational and predictable manner for optimum resource utilization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.7.3" ;
    skos:prefLabel "Implement and enforce change control procedures"@en .

<http://ots.local/thesaurus/apqc/8_3_7_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_7> ;
    skos:definition "Review and implement resources (including external parties) necessary to support uninterrupted operations of critical IT services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.7.4" ;
    skos:prefLabel "Execute recurring IT service provider business continuity"@en .

<http://ots.local/thesaurus/apqc/8_3_7_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_7> ;
    skos:definition "Conduct and manage employee training programs on IT resilience so that prospective risks can be avoided."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.7.5" ;
    skos:prefLabel "Provide IT resilience training"@en .

<http://ots.local/thesaurus/apqc/8_3_7_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_7> ;
    skos:definition "Implement regular resources supporting uninterrupted operations of critical IT services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.7.6" ;
    skos:prefLabel "Execute recurring IT business operations continuity"@en .

<http://ots.local/thesaurus/apqc/8_3_8_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_8> ;
    skos:definition "Create and implement policies that integrate authorization policies with authorized profiles of users meant to access network resources."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.8.1" ;
    skos:prefLabel "Support integration of identity and authorization policies"@en .

<http://ots.local/thesaurus/apqc/8_3_8_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_8> ;
    skos:definition "Managing directory of user profiles and access requirements across different levels in the organization's IT network."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.8.2" ;
    skos:prefLabel "Manage IT user directory"@en .

<http://ots.local/thesaurus/apqc/8_3_8_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_8> ;
    skos:definition "Managing the process of authorizing IT users to access applications, systems, IT components, or networks by associating user rights."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.8.3" ;
    skos:prefLabel "Manage IT user authorization"@en .

<http://ots.local/thesaurus/apqc/8_3_8_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_8_4> ;
    skos:definition "Adopting MFA to ensure secure user authentication across all systems."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.8.4.1" ;
    skos:prefLabel "Implement multi-factor authentication (MFA)"@en .

<http://ots.local/thesaurus/apqc/8_3_8_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_8_4> ;
    skos:definition "Integrating identity federation and SSO solutions to enhance user experience and security."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.8.4.2" ;
    skos:prefLabel "Implement identity federation and single sign-on (SSO)"@en .

<http://ots.local/thesaurus/apqc/8_3_8_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_8> ;
    skos:definition "Examine the processes responsible for reviewing IT user identity and authorization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.8.5" ;
    skos:prefLabel "Audit IT user identity and authorization systems"@en .

<http://ots.local/thesaurus/apqc/8_3_8_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_8> ;
    skos:definition "Address any form of unauthorized network breach such as unauthorized access or usage of data, applications, services, networks, and/or devices. Identify the root cause and take corrective measures to resolve the breach."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.8.6" ;
    skos:prefLabel "Respond to IT information security and network breaches"@en .

<http://ots.local/thesaurus/apqc/8_3_8_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_8> ;
    skos:definition "Conduct penetration testing (pen test) through an authorized stimulated attack to identify security weakness in an IT environment by evaluating the system or network with various harmful techniques."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.8.7" ;
    skos:prefLabel "Conduct penetration testing"@en .

<http://ots.local/thesaurus/apqc/8_3_8_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_3_8> ;
    skos:definition "Reviewing the processes responsible for integration of user identity and access authorization in order to confirm that all the required regulations are followed."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.3.8.8" ;
    skos:prefLabel "Audit integration of user identity and authorization systems"@en .

<http://ots.local/thesaurus/apqc/8_4_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_4_1> ;
    skos:definition "Implementing strategies for securing and ensuring the privacy of data flows throughout the organization. Create protocols and guidelines for individual IT components. Outline analytic objectives in order to avoid misuse of information."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.4.1.1" ;
    skos:prefLabel "Establish data, information, and analytic objectives"@en .

<http://ots.local/thesaurus/apqc/8_4_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_4_1> ;
    skos:definition "Creating a set of guidelines that ensure effective and efficient use of IT. Define data, information, and analytic governance to reach the organization's goal."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.4.1.2" ;
    skos:prefLabel "Establish data, information, and analytic governance"@en .

<http://ots.local/thesaurus/apqc/8_4_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_4_1> ;
    skos:definition "Determining the request for data accessibility and analysis. Review the details based on internal data security policies and permit data access only if internal policies and data access parameters are met."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.4.1.3" ;
    skos:prefLabel "Access IT data/analytic capabilities"@en .

<http://ots.local/thesaurus/apqc/8_4_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_4_2> ;
    skos:definition "Determining strategies to manage the enterprise wide flow of business information and content. Outline the required architecture for information resources."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.4.2.1" ;
    skos:prefLabel "Determine enterprise business information requirements"@en .

<http://ots.local/thesaurus/apqc/8_4_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_4_2> ;
    skos:definition "Define different ways of representation, usage, and identification of data with independent or interdependent sources across the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.4.2.2" ;
    skos:prefLabel "Define enterprise data models"@en .

<http://ots.local/thesaurus/apqc/8_4_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_4_2> ;
    skos:definition "Identifying and understanding external sources of data in relevance of reliability, security, and authenticity."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.4.2.3" ;
    skos:prefLabel "Identify and understand external data sources"@en .

<http://ots.local/thesaurus/apqc/8_4_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_4_2> ;
    skos:definition "Establishing entities responsible for data accuracy, integrity, and timeliness that can authorize or deny access to certain data. Develop data utilizing governance processes to ensure fitness of data elements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.4.2.4" ;
    skos:prefLabel "Establish data ownership and stewardship responsibilities"@en .

<http://ots.local/thesaurus/apqc/8_4_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_4_2> ;
    skos:definition "Creating and maintaining the process of designing, creating, deploying, and managing strategies to maintain enterprise data and information architecture."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.4.2.5" ;
    skos:prefLabel "Maintain and evolve enterprise data and information architecture"@en .

<http://ots.local/thesaurus/apqc/8_4_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_4_3> ;
    skos:definition "Outlining and establishing policies for information and setting information standards and procedures. Establish policies to regulate the creation, use, storage, access, communication, and dissemination of information."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.4.3.1" ;
    skos:prefLabel "Define and maintain enterprise information policies, standards, and procedures"@en .

<http://ots.local/thesaurus/apqc/8_4_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_4_3> ;
    skos:definition "Implementing and executing strategies for processes and technologies that support the collection, managing, and storing of data."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.4.3.2" ;
    skos:prefLabel "Implement and execute data administration responsibilities"@en .

<http://ots.local/thesaurus/apqc/8_4_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_4_4> ;
    skos:definition "Defining the rules, diction, and logic that make up the framework of the organization's information architecture. Monitoring and controlling information attributes that flow through the IT framework."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.4.4.1" ;
    skos:prefLabel "Monitor and control business information"@en .

<http://ots.local/thesaurus/apqc/8_4_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_4_4> ;
    skos:definition "Maintain information feedstock along with IT hardware and software needed for storage, access, and retrieval of business information."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.4.4.2" ;
    skos:prefLabel "Maintain business information feeds and repositories"@en .

<http://ots.local/thesaurus/apqc/8_4_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_4_4> ;
    skos:definition "Verification of information access and usage through regular reports on organizational performance."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.4.4.3" ;
    skos:prefLabel "Perform internal usage audits"@en .

<http://ots.local/thesaurus/apqc/8_4_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_4_4> ;
    skos:definition "Implement and manage the process for accessing information including issues related to copyright, open source, privacy, and security."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.4.4.4" ;
    skos:prefLabel "Implement and administer business information access"@en .

<http://ots.local/thesaurus/apqc/8_5_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5_1> ;
    skos:definition "Determining the development of IT service/solution. Analyze the pros and cons of IT service/solution and it's methods on the basis of their cost effectiveness and development value."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.1.1" ;
    skos:prefLabel "Determine IT service/solution development"@en .

<http://ots.local/thesaurus/apqc/8_5_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5_1> ;
    skos:definition "Establishing the methods and processes as the foundation for developing new IT platforms, components, software, and explore new standards for better IT usage in the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.1.2" ;
    skos:prefLabel "Define IT service/solution development processes/standards"@en .

<http://ots.local/thesaurus/apqc/8_5_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5_1> ;
    skos:definition "Identifying and implementing techniques and tools for development based on overall value addition to the IT environment."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.1.3" ;
    skos:prefLabel "Identify, deploy, and support development methodologies and tools"@en .

<http://ots.local/thesaurus/apqc/8_5_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5_1> ;
    skos:definition "Establishing standards for selection of IT service components."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.1.4" ;
    skos:prefLabel "Establish service component criteria"@en .

<http://ots.local/thesaurus/apqc/8_5_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5_1> ;
    skos:definition "Understanding and selecting reusable service components so that they can be cost-effective and efficient."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.1.5" ;
    skos:prefLabel "Understand and select reusable service components"@en .

<http://ots.local/thesaurus/apqc/8_5_1_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5_1> ;
    skos:definition "Creating and establishing service component portfolio by defining investments, and activities. Analyze and examine the value of the service component portfolio, and allocate resources towards it."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.1.6" ;
    skos:prefLabel "Maintain service component portfolio"@en .

<http://ots.local/thesaurus/apqc/8_5_1_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5_1> ;
    skos:definition "Creating standards and procedures for developing IT services/solutions outside of defined business parameters."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.1.7" ;
    skos:prefLabel "Establish development standards exception governance"@en .

<http://ots.local/thesaurus/apqc/8_5_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5_2> ;
    skos:definition "Perform a systematic investigation to new and future technology capabilities for future upgrades."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.2.1" ;
    skos:prefLabel "Monitor and track emerging technology capabilities"@en .

<http://ots.local/thesaurus/apqc/8_5_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5_2> ;
    skos:definition "Identifying processes and supporting procedures that are performed by an organization to design, plan, deliver, operate, and control information technology services/solutions offered to customers."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.2.2" ;
    skos:prefLabel "Identify IT services/solutions"@en .

<http://ots.local/thesaurus/apqc/8_5_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5_2> ;
    skos:definition "Determining an approach to create a base for delivering IT service/solution aligned with overall business needs while maintaining a tight control on delivery and costs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.2.3" ;
    skos:prefLabel "Determine IT service/solution approach"@en .

<http://ots.local/thesaurus/apqc/8_5_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5_2> ;
    skos:definition "Defining solutions to satisfy business needs. IT solution lifecycle provides a means to address the full life cycle of an information technology solution and addresses the current and future state of IT services and solutions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.2.4" ;
    skos:prefLabel "Define IT solution lifecycle"@en .

<http://ots.local/thesaurus/apqc/8_5_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5_2> ;
    skos:definition "Developing plans to retire IT service/solution resources when the service/solution is no longer feasible."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.2.5" ;
    skos:prefLabel "Develop IT service/solution \"sunset\" plans"@en .

<http://ots.local/thesaurus/apqc/8_5_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5_3> ;
    skos:definition "Assessing limitations in IT application and infrastructure architecture that may hinder expected performance."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.3.1" ;
    skos:prefLabel "Assess IT application and infrastructure architecture constraints"@en .

<http://ots.local/thesaurus/apqc/8_5_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5_3> ;
    skos:definition "Evaluate business limitations that may hinder IT service/solution performance."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.3.2" ;
    skos:prefLabel "Assess business constraints on IT service/solution"@en .

<http://ots.local/thesaurus/apqc/8_5_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5_3> ;
    skos:definition "Determining the requirements to integrate IT components such as hardware, software, database, telecommunication, and network."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.3.3" ;
    skos:prefLabel "Determine IT component integration requirements"@en .

<http://ots.local/thesaurus/apqc/8_5_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5_3> ;
    skos:definition "Identification of opportunities for reusing IT components so that they can be cost-effective and efficient."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.3.4" ;
    skos:prefLabel "Identify opportunities for IT component reuse"@en .

<http://ots.local/thesaurus/apqc/8_5_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5_3> ;
    skos:definition "Encouraging acceptance of existing IT service/solution architecture in the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.3.5" ;
    skos:prefLabel "Promote adoption of existing service/solution architecture"@en .

<http://ots.local/thesaurus/apqc/8_5_3_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5_3> ;
    skos:definition "Creating and maintaining a services and solutions architecture over a network that can be revised as needed or even eliminated in case of inefficiencies."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.3.6" ;
    skos:prefLabel "Develop and maintain service/solution architectures"@en .

<http://ots.local/thesaurus/apqc/8_5_3_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5_3> ;
    skos:definition "Assessing functional compliance of the IT service/solution architecture. Safeguard compliance with guidelines for the architecture."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.3.7" ;
    skos:prefLabel "Assess IT service/solution architecture conformance"@en .

<http://ots.local/thesaurus/apqc/8_5_3_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5_3> ;
    skos:definition "Identifying and resolving any architectural exceptions. Address the internal inquiries related to architecture that cannot be addressed immediately. Research inquiries that require the need of exceptional methods."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.3.8" ;
    skos:prefLabel "Manage architectural exceptions"@en .

<http://ots.local/thesaurus/apqc/8_5_4_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5_4_1> ;
    skos:definition "Evaluating and validating the requirements and needs of IT service/solution."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.4.1.1" ;
    skos:prefLabel "Assess and validate IT service/solution requirements"@en .

<http://ots.local/thesaurus/apqc/8_5_4_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5_4_1> ;
    skos:definition "Formulating a design for service/solution that helps an organization to meet its objectives. Develop a new framework for molding the service/solution processes into a coherent and structured form."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.4.1.2" ;
    skos:prefLabel "Create service/solution design"@en .

<http://ots.local/thesaurus/apqc/8_5_4_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5_4_1> ;
    skos:definition "Building and testing new components required for the development of IT services and solutions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.4.1.3" ;
    skos:prefLabel "Build and test IT service/solution components"@en .

<http://ots.local/thesaurus/apqc/8_5_4_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5_4_1> ;
    skos:definition "Combining the newly built IT component along with IT services in order to gain optimum output."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.4.1.4" ;
    skos:prefLabel "Integrate IT components and services"@en .

<http://ots.local/thesaurus/apqc/8_5_4_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5_4_1> ;
    skos:definition "Validating that the proposed IT service/solution is feasible and provides the needed services for the customer."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.4.1.5" ;
    skos:prefLabel "Execute IT service/solution validation"@en .

<http://ots.local/thesaurus/apqc/8_5_4_1_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5_4_1> ;
    skos:definition "Creating and implementing a strategy for the deployment of IT service/solution by defining all of the activities that make the IT function available for use. Define the deployment process, procedures, and tools. Select the most feasible and practical methodologies for the deployment process."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.4.1.6" ;
    skos:prefLabel "Bundle service/solution deployment packaging"@en .

<http://ots.local/thesaurus/apqc/8_5_4_1_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5_4_1> ;
    skos:definition "Identifying and resolving internal needs/inquiries for service/solution that cannot be resolved immediately. Research inquiries that require the need of exceptional solutions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.4.1.7" ;
    skos:prefLabel "Manage service/solution process exceptions"@en .

<http://ots.local/thesaurus/apqc/8_5_5_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5_5_1> ;
    skos:definition "Evaluate plans to address information technology environmental adulteration for rectification efforts."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.5.1.1" ;
    skos:prefLabel "Assess IT remediation"@en .

<http://ots.local/thesaurus/apqc/8_5_5_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5_5_1> ;
    skos:definition "Redesign the roadmap to seek solution or service with an overall process flow and impact timeframe."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.5.1.2" ;
    skos:prefLabel "Modify service/solution design"@en .

<http://ots.local/thesaurus/apqc/8_5_5_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5_5_1> ;
    skos:definition "Administering the efforts and activities for IT service/solution remediation. This process element requires the organization to create plans for corrective action in collaboration with government agencies and pertinent professional services agencies which specialize in remediation efforts relevant to the organization's service/solution. Additionally, the organization needs to consult experts to validate the plan, determine resources allocation, resolve any legal concerns, and formulate a company-wide policy for IT service/solution remediation."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.5.1.3" ;
    skos:prefLabel "Perform IT service/solution remediation"@en .

<http://ots.local/thesaurus/apqc/8_5_5_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5_5_1> ;
    skos:definition "Understanding customer requirements. Managing services/solutions based on the requirements. Develop components for providing the requirements. Train resources to provide support. Confirm the customer experience post-sale. Evaluate the performance of service/solution. Communicate the results to the management."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.5.1.4" ;
    skos:prefLabel "Manage service/solution operations"@en .

<http://ots.local/thesaurus/apqc/8_5_5_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_5_5_1> ;
    skos:definition "Developing packaging for fixed/enhanced service/solution based on the standalone or bundled offerings to be used by the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.5.5.1.5" ;
    skos:prefLabel "Prepare fixed/enhanced service/solution packaging"@en .

<http://ots.local/thesaurus/apqc/8_6_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_1> ;
    skos:definition "Evaluate the impact of IT deployment (products/services) on the business. Compare pre and post development performance, behavior of resources, and cost to assess organizational benefit."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.1.1" ;
    skos:prefLabel "Assess IT deployment business impact"@en .

<http://ots.local/thesaurus/apqc/8_6_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_1> ;
    skos:definition "Defining deployment policies regarding IT services and solutions to allow employees to plan accordingly. Reduce the negative impact to the user community."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.1.2" ;
    skos:prefLabel "Establish IT deployment policies"@en .

<http://ots.local/thesaurus/apqc/8_6_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_1> ;
    skos:definition "Outlining processes, methods, and equipment for deployment of IT solutions. Manage core operations servers like subversion server, production server, and development server, to make the IT services and solutions available for internal/client use."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.1.3" ;
    skos:prefLabel "Define and create deployment procedure workflow"@en .

<http://ots.local/thesaurus/apqc/8_6_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_1> ;
    skos:definition "Establishing guidelines for the changed/released IT services and solutions to meet business objectives with optimum utilization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.1.4" ;
    skos:prefLabel "Define IT change/release standards"@en .

<http://ots.local/thesaurus/apqc/8_6_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_1> ;
    skos:definition "Coordinating development approval responsibilities based on defined change standards."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.1.5" ;
    skos:prefLabel "Assign deployment approval responsibilities"@en .

<http://ots.local/thesaurus/apqc/8_6_1_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_1> ;
    skos:definition "Evaluating the impact (pros and cons) of IT services deployment."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.1.6" ;
    skos:prefLabel "Analyze deployments outcomes"@en .

<http://ots.local/thesaurus/apqc/8_6_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_2> ;
    skos:definition "Accessing threats and potential failures related to the deployment of IT services/solutions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.2.1" ;
    skos:prefLabel "Assess IT deployment risk"@en .

<http://ots.local/thesaurus/apqc/8_6_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_2> ;
    skos:definition "Defining the schedule for implementation of change. Plan and carry out a process or procedure to implement the predefined changes."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.2.2" ;
    skos:prefLabel "Define implementation schedule and roll-out sequence"@en .

<http://ots.local/thesaurus/apqc/8_6_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_2> ;
    skos:definition "Determine requirements for implementation of IT deployment. Carry out a pre-implementation audit to assess the impact and use case. Gauge the possible vulnerabilities and impact the business operations during and after the implementation."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.2.3" ;
    skos:prefLabel "Determine implementation requirements"@en .

<http://ots.local/thesaurus/apqc/8_6_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_2> ;
    skos:definition "Plan methodologies and align resources for user testing of IT deployment."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.2.4" ;
    skos:prefLabel "Plan and align user testing and resources"@en .

<http://ots.local/thesaurus/apqc/8_6_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_2> ;
    skos:definition "Create and manage employee training programs by considering the need and availability of these programs. Manage all aspects related to the training programs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.2.5" ;
    skos:prefLabel "Develop IT training"@en .

<http://ots.local/thesaurus/apqc/8_6_2_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_2> ;
    skos:definition "Coordinating change implementation in IT services and solutions communications with employees and stakeholders."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.2.6" ;
    skos:prefLabel "Create implementation communications"@en .

<http://ots.local/thesaurus/apqc/8_6_2_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_2> ;
    skos:definition "Managing procedures to return to initial pre-deployment stage or previous state from current environment."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.2.7" ;
    skos:prefLabel "Manage IT roll-back procedures"@en .

<http://ots.local/thesaurus/apqc/8_6_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_3> ;
    skos:definition "Evaluating the impact of IT change/release on the business."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.3.1" ;
    skos:prefLabel "Asses IT change/release impact"@en .

<http://ots.local/thesaurus/apqc/8_6_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_3> ;
    skos:definition "Ensure that change/release meets change guidelines set by the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.3.2" ;
    skos:prefLabel "Confirm change/release compliance"@en .

<http://ots.local/thesaurus/apqc/8_6_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_3> ;
    skos:definition "Evaluating for any kind of risks or threats which could be caused due to IT change/release deployment."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.3.3" ;
    skos:prefLabel "Assess IT change/release risk"@en .

<http://ots.local/thesaurus/apqc/8_6_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_3> ;
    skos:definition "Integrate all forms of changes in IT in order to make more efficient use of resources and down time, and optimizing results."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.3.4" ;
    skos:prefLabel "Consolidate IT change"@en .

<http://ots.local/thesaurus/apqc/8_6_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_3> ;
    skos:definition "Defining and communicating the schedule for implementation to related stakeholders and functions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.3.5" ;
    skos:prefLabel "Create and communicate deployment schedule"@en .

<http://ots.local/thesaurus/apqc/8_6_3_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_3> ;
    skos:definition "Permitting for the change/release deployment. Approve deployment based on the evaluation of business impact due to change/release."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.3.6" ;
    skos:prefLabel "Approve change/release deployment"@en .

<http://ots.local/thesaurus/apqc/8_6_3_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_3> ;
    skos:definition "Recording outcomes related to the change/release deployment."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.3.7" ;
    skos:prefLabel "Document IT change/release outcome"@en .

<http://ots.local/thesaurus/apqc/8_6_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_4> ;
    skos:definition "Confirm if hardware/software are operating as per the expectation."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.4.1" ;
    skos:prefLabel "Confirm hardware/software operational status"@en .

<http://ots.local/thesaurus/apqc/8_6_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_4> ;
    skos:definition "Confirm if operational activities of IT services could be performed."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.4.2" ;
    skos:prefLabel "Confirm operational availability"@en .

<http://ots.local/thesaurus/apqc/8_6_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_4> ;
    skos:definition "Executing IT implementation plan to make the IT services and solutions available for internal use."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.4.3" ;
    skos:prefLabel "Execute internal IT implementation plan"@en .

<http://ots.local/thesaurus/apqc/8_6_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_4> ;
    skos:definition "Confirming the completion of IT implementation."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.4.4" ;
    skos:prefLabel "Confirm implementation completion"@en .

<http://ots.local/thesaurus/apqc/8_6_4_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_4> ;
    skos:definition "Executing changes in software and services as per change/release schedule."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.4.5" ;
    skos:prefLabel "Implement software change/release"@en .

<http://ots.local/thesaurus/apqc/8_6_4_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_4> ;
    skos:definition "Perform testing after installation to confirm expected performance is met."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.4.6" ;
    skos:prefLabel "Perform post-installation testing"@en .

<http://ots.local/thesaurus/apqc/8_6_4_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_4> ;
    skos:definition "Distributing and implementing the release of changed IT solutions. Administer, implement, and install the releases onto internal systems. Provide methods for installing releases on client users."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.4.7" ;
    skos:prefLabel "Distribute software components network-wide"@en .

<http://ots.local/thesaurus/apqc/8_6_4_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_4> ;
    skos:definition "Confirming that the release has met expectations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.4.8" ;
    skos:prefLabel "Verify change/release implementation success"@en .

<http://ots.local/thesaurus/apqc/8_6_4_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_4> ;
    skos:definition "Execution of plan to return to the previous operating state if the change/release impedes operational expectations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.4.9" ;
    skos:prefLabel "Execute roll-back plan"@en .

<http://ots.local/thesaurus/apqc/8_6_5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_5> ;
    skos:definition "Preparing users for changes in IT solutions. Conduct training sessions and engagement activities to familiarize users with the new changes. Implementing the programs for training IT employees."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.5.1" ;
    skos:prefLabel "Conduct IT training"@en .

<http://ots.local/thesaurus/apqc/8_6_5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_5> ;
    skos:definition "Coordinating communications regarding the changes in IT services and solutions with employees in the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.5.2" ;
    skos:prefLabel "Prepare and distribute service/solution communications"@en .

<http://ots.local/thesaurus/apqc/8_6_5_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_5> ;
    skos:definition "Creating a strategy for providing support for organizational changes. Providing support to users of IT services and solutions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.5.3" ;
    skos:prefLabel "Support organizational changes"@en .

<http://ots.local/thesaurus/apqc/8_6_5_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_5> ;
    skos:definition "Executing a plan for introducing the IT services and solutions to the organization's end user base."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.5.4" ;
    skos:prefLabel "Execute rollout plans"@en .

<http://ots.local/thesaurus/apqc/8_6_5_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_5> ;
    skos:definition "Establishing services for providing support to users of IT services and solutions for rollout. Define the plethora of services by which the organization assists users of technology products."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.5.5" ;
    skos:prefLabel "Provide rollout support"@en .

<http://ots.local/thesaurus/apqc/8_6_5_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_5> ;
    skos:definition "Managing the necessary skills and competencies required to efficiently provide IT resolution for rollout through the support structure. Identify the gaps and needs in support structure."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.5.6" ;
    skos:prefLabel "Manage rollout support capabilities"@en .

<http://ots.local/thesaurus/apqc/8_6_5_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_6_5> ;
    skos:definition "Track and record any issues being faced due to rollout. Define methodology of assessment for measuring and monitoring issues."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.6.5.7" ;
    skos:prefLabel "Monitor and record rollout issues"@en .

<http://ots.local/thesaurus/apqc/8_7_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_1> ;
    skos:definition "Assessing the goals and objectives of IT service delivery and how it contributes to the overall business objectives. Align with the business objectives of the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.1.1" ;
    skos:prefLabel "Assess business objectives and IT service delivery"@en .

<http://ots.local/thesaurus/apqc/8_7_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_1> ;
    skos:definition "Creating and establishing a repository of IT service delivery offerings."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.1.2" ;
    skos:prefLabel "Define IT service delivery portfolio"@en .

<http://ots.local/thesaurus/apqc/8_7_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_1> ;
    skos:definition "Design and maintaining an IT service delivery model that defines the processes and procedures needed to deliver the IT services and solutions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.1.3" ;
    skos:prefLabel "Create and maintain IT service delivery model"@en .

<http://ots.local/thesaurus/apqc/8_7_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_1> ;
    skos:definition "Determining locations and types of IT services and solutions which need to be delivered."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.1.4" ;
    skos:prefLabel "Determine IT service delivery locations and activities"@en .

<http://ots.local/thesaurus/apqc/8_7_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_1> ;
    skos:definition "Defining a strategy for sourcing delivery of IT services and solutions. Examine the pros and cons of various sources that can support the delivery process. Select the most feasible and cost-effective sources."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.1.5" ;
    skos:prefLabel "Define IT service delivery sourcing strategy"@en .

<http://ots.local/thesaurus/apqc/8_7_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_2> ;
    skos:definition "Assessing the goals of IT service support delivery and how it aligns to contribute to the overall business objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.2.1" ;
    skos:prefLabel "Assess business objectives and IT service support delivery"@en .

<http://ots.local/thesaurus/apqc/8_7_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_2> ;
    skos:definition "Defining different IT support services and solutions such as remote support and cloud support. Include planned IT initiatives and ongoing IT services (such as application support)."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.2.2" ;
    skos:prefLabel "Define IT service support portfolio"@en .

<http://ots.local/thesaurus/apqc/8_7_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_2> ;
    skos:definition "Design and maintaining an IT support model that defines the processes and procedures needed to support users of IT services and solutions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.2.3" ;
    skos:prefLabel "Create and maintain IT support model"@en .

<http://ots.local/thesaurus/apqc/8_7_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_2> ;
    skos:definition "Developing a strategy for sourcing resources to support users of IT services and solutions. Establish sources that will make use of e-mail, live support software online, or a tool where users can log a call or incident in order to retrieve IT support."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.2.4" ;
    skos:prefLabel "Develop IT support service sourcing strategy"@en .

<http://ots.local/thesaurus/apqc/8_7_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_2> ;
    skos:definition "Creating an agenda for the rules and regulations of support service that deal with providing support to users of IT services and solutions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.2.5" ;
    skos:prefLabel "Establish support service framework"@en .

<http://ots.local/thesaurus/apqc/8_7_2_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_2> ;
    skos:definition "Providing the tools and techniques to support users of IT services and solutions, and choosing the most appropriate tools and techniques. Evaluate the pros and cons of all the methodologies and tools available. Choose the most efficient and effective methodology."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.2.6" ;
    skos:prefLabel "Provide service support tools and technology"@en .

<http://ots.local/thesaurus/apqc/8_7_3_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_3_1> ;
    skos:definition "Scheduling resources to provide service delivery to IT users. Ensure design, development, deployment, and operations are aligned with the business objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.3.1.1" ;
    skos:prefLabel "Schedule service delivery resources"@en .

<http://ots.local/thesaurus/apqc/8_7_3_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_3_1> ;
    skos:definition "Maintaining and scheduling batch jobs to run in the background at a certain date and time."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.3.1.2" ;
    skos:prefLabel "Maintain/optimize batch job schedule"@en .

<http://ots.local/thesaurus/apqc/8_7_3_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_3_1> ;
    skos:definition "Determine the timely change or release of IT services or support. Assign periodic release/change to IT systems or services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.3.1.3" ;
    skos:prefLabel "Schedule change/release windows"@en .

<http://ots.local/thesaurus/apqc/8_7_3_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_3_1> ;
    skos:definition "Schedule or optimize backup and archive activities for IT services and solutions. Use a backup system or application and archive operations data for future retrieval."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.3.1.4" ;
    skos:prefLabel "Schedule/optimize backup and archive activities"@en .

<http://ots.local/thesaurus/apqc/8_7_3_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_3_1> ;
    skos:definition "Balancing workloads of all the processes and services that are provisioned to their internal or external clients, across available components of IT infrastructure. No component should be over or under utilized with the workflow of the IT operations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.3.1.5" ;
    skos:prefLabel "Balance operational workloads across available infrastructure components"@en .

<http://ots.local/thesaurus/apqc/8_7_3_1_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_3_1> ;
    skos:definition "Determining process and procedure to provide support for specific IT service problems."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.3.1.6" ;
    skos:prefLabel "Determine specific problem support procedures"@en .

<http://ots.local/thesaurus/apqc/8_7_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_4> ;
    skos:definition "Creating a strategy for delivering IT services and solutions. Establish the sourcing strategy. Establish the delivery process procedures and tools. Examine and choose the most effective methodologies and tools."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.4.1" ;
    skos:prefLabel "Develop IT service delivery strategy"@en .

<http://ots.local/thesaurus/apqc/8_7_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_4> ;
    skos:definition "Assessing the goals and objectives of IT infrastructure and how it contributes to the overall business objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.4.2" ;
    skos:prefLabel "Assess IT infrastructure business objectives"@en .

<http://ots.local/thesaurus/apqc/8_7_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_4> ;
    skos:definition "Determining existing IT infrastructure capabilities. Identify the gaps and needs in order to enhance the existing IT infrastructure to meet growth objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.4.3" ;
    skos:prefLabel "Determine ongoing IT infrastructure capabilities"@en .

<http://ots.local/thesaurus/apqc/8_7_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_4> ;
    skos:definition "Identify the gaps and needs of existing IT infrastructure. Plan and develop strategies to upgrade/replace existing IT infrastructure."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.4.4" ;
    skos:prefLabel "Plan IT infrastructure change"@en .

<http://ots.local/thesaurus/apqc/8_7_4_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_4> ;
    skos:definition "Creating a plan associated with usage volumes of IT licenses. Develop a framework to govern the licensing of an IT services along with identified usage volumes. Determine the amount of investment in IT license usage volumes and how would the license volumes be financed."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.4.5" ;
    skos:prefLabel "Plan and budget IT license usage volumes"@en .

<http://ots.local/thesaurus/apqc/8_7_5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_5> ;
    skos:definition "Evaluate criticality catered by the IT support and expectations to resolve raised or identified issues. Determine the usual requests received for IT support for each area of IT operations. Ensure resolution to every identified or reported issue within specified SLAs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.5.1" ;
    skos:prefLabel "Understand IT support demand patterns"@en .

<http://ots.local/thesaurus/apqc/8_7_5_10> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_5> ;
    skos:definition "Defining methodology and frequency of assessment for measuring and monitoring performance of various processes and activities of IT service support against standard set goals."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.5.10" ;
    skos:prefLabel "Monitor IT service support performance"@en .

<http://ots.local/thesaurus/apqc/8_7_5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_5> ;
    skos:definition "Determining levels of required support resources along with their responsibilities, and capabilities to resolve IT issues. Evaluate and ensure that support resources are fulfilling their responsibilities n a timely manner."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.5.2" ;
    skos:prefLabel "Determine required support resource levels, responsibilities, and capabilities"@en .

<http://ots.local/thesaurus/apqc/8_7_5_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_5> ;
    skos:definition "Create and maintain service support knowledge repository. Store, maintain, access, revise, and use knowledge for IT services. Review knowledge trends and implement knowledge transfer methodologies for competitive advantage."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.5.3" ;
    skos:prefLabel "Maintain service support knowledge repository"@en .

<http://ots.local/thesaurus/apqc/8_7_5_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_5> ;
    skos:definition "Maintaining and transfer of knowledge towards service support with the change/upgrade in technology over a stipulated period. Ensure IT staff is well trained and tested on the new learning of service support."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.5.4" ;
    skos:prefLabel "Maintain service support learning"@en .

<http://ots.local/thesaurus/apqc/8_7_5_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_5> ;
    skos:definition "Conveying service support needs within the organization, with the objective of providing required support services. Define processes and procedures needed to support users of IT services and solutions. Convey these procedures to appropriate governing authority."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.5.5" ;
    skos:prefLabel "Communicate service support needs"@en .

<http://ots.local/thesaurus/apqc/8_7_5_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_5> ;
    skos:definition "Determining mechanisms to report for a higher degree of decision making depending on the criticality of IT escalations. Define the processes and procedures needed to follow for IT escalation at different levels. Convey the mechanisms within the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.5.6" ;
    skos:prefLabel "Define IT escalation mechanisms"@en .

<http://ots.local/thesaurus/apqc/8_7_5_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_5> ;
    skos:definition "Managing resources required for administration of IT service support. Establish sources that will make use of e-mail, live support software online, or a tool where users can log a call or incident in order to retrieve IT support."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.5.7" ;
    skos:prefLabel "Manage IT service support resources"@en .

<http://ots.local/thesaurus/apqc/8_7_5_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_5> ;
    skos:definition "Developing a strategy that will make use of multiple resources to coordinate with external support providers in order to make the support services work more smoother."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.5.8" ;
    skos:prefLabel "Coordinate with external support providers"@en .

<http://ots.local/thesaurus/apqc/8_7_5_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_5> ;
    skos:definition "Sorting the incidents of IT service delivery in certain order so that the services could be delivered based on the criticality."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.5.9" ;
    skos:prefLabel "Triage IT service delivery incidents"@en .

<http://ots.local/thesaurus/apqc/8_7_6_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_6> ;
    skos:definition "Operating and defining methodology of assessment for measuring and monitoring performance of online systems against its expected result."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.6.1" ;
    skos:prefLabel "Operate and monitor online systems"@en .

<http://ots.local/thesaurus/apqc/8_7_6_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_6> ;
    skos:definition "Operate and monitor the application of scheduling batch jobs to be run in the background at a certain date and time."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.6.2" ;
    skos:prefLabel "Run and monitor batch job schedule"@en .

<http://ots.local/thesaurus/apqc/8_7_6_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_6> ;
    skos:definition "Analyze and manage workload needs in relation to service delivery. Plan resources and mechanism around those workload needs so that services could be delivered smoothly."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.6.3" ;
    skos:prefLabel "Manage service delivery workloads"@en .

<http://ots.local/thesaurus/apqc/8_7_6_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_6> ;
    skos:definition "Managing the performance and capacity of infrastructure by using key performance indicators to routinely track the performance and capacity levels. Review performance. Evaluate the efficiency and effectiveness of the infrastructure."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.6.4" ;
    skos:prefLabel "Manage infrastructure performance and capacity"@en .

<http://ots.local/thesaurus/apqc/8_7_6_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_6> ;
    skos:definition "Addressing to an issue in operational activities within the IT function, that occur outside of normal routine or preventative maintenance."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.6.5" ;
    skos:prefLabel "Respond to unplanned operational issues"@en .

<http://ots.local/thesaurus/apqc/8_7_6_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_6> ;
    skos:definition "Identify and introduce resources to display output in a viewable form to key decision makers and evaluators."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.6.6" ;
    skos:prefLabel "Produce and distribute output media"@en .

<http://ots.local/thesaurus/apqc/8_7_6_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_6> ;
    skos:definition "Identifying, examining, and recognizing any flaw or breach in security of IT infrastructure. Ensure that protocols and guidelines for individual IT components are being followed and there is no misuse of information and breach of individual or organizational privacy."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.6.7" ;
    skos:prefLabel "Monitor IT infrastructure security"@en .

<http://ots.local/thesaurus/apqc/8_7_6_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_6> ;
    skos:definition "Managing resources of IT infrastructure and their recovery capacity. Manage storage, computer hardware, software, and infrastructure resources that can be stored as inventory or provided by the organization as needed. Managing backup/recovery for IT services and solutions. Use a backup system or application."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.6.8" ;
    skos:prefLabel "Manage IT infrastructure/data recovery"@en .

<http://ots.local/thesaurus/apqc/8_7_7_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_7> ;
    skos:definition "Identifying and tracking individual configuration items, documenting functional capabilities and interdependencies of IT infrastructure. Determining the gaps and needs in order to enhance existing infrastructure configuration."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.7.1" ;
    skos:prefLabel "Manage infrastructure configuration"@en .

<http://ots.local/thesaurus/apqc/8_7_7_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_7> ;
    skos:definition "Evaluating and maintaining all aspects of infrastructure component maintenance. Ensure that all components of an IT infrastructure are functioning properly as per the expectation. Maintenance includes all preventative, routine, and corrective measures."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.7.2" ;
    skos:prefLabel "Perform infrastructure component maintenance"@en .

<http://ots.local/thesaurus/apqc/8_7_7_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_7> ;
    skos:definition "Installing/configuring/upgrading all the components required for operational activities within IT infrastructure. Ensure that all components of an IT infrastructure are functioning properly and updated to latest version/technology."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.7.3" ;
    skos:prefLabel "Install/configure/upgrade infrastructure components"@en .

<http://ots.local/thesaurus/apqc/8_7_7_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_7> ;
    skos:definition "Maintaining the complete list of IT items or resources available with the organization with the details on date of purchase, licenses, deployment and SLAs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.7.4" ;
    skos:prefLabel "Maintain IT asset records"@en .

<http://ots.local/thesaurus/apqc/8_7_7_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_7> ;
    skos:definition "Administering and overseeing the terms and policies associated with licensing the IT intellectual property. Create and manage the policies and terms governing the possible granting of a license to any external agent. Demarcate a clear framework that governs the licensing of any patents or copyrights held by the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.7.5" ;
    skos:prefLabel "Administer IT licenses/user agreements"@en .

<http://ots.local/thesaurus/apqc/8_7_7_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_7> ;
    skos:definition "Providing all the infrastructure services and capabilities required for operational activities within the IT function supporting overall business objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.7.6" ;
    skos:prefLabel "Provide IT infrastructure service and capabilities"@en .

<http://ots.local/thesaurus/apqc/8_7_8_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_8> ;
    skos:definition "Evaluate and assign IT issues/requests accordingly to allow for the correct routing of IT issues to the relevant support teams."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.8.1" ;
    skos:prefLabel "Triage IT issues/requests"@en .

<http://ots.local/thesaurus/apqc/8_7_8_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_8> ;
    skos:definition "Providing the necessary skills and competencies required to efficiently provide IT resolution through the support structure."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.8.2" ;
    skos:prefLabel "Provide IT resolution capabilities"@en .

<http://ots.local/thesaurus/apqc/8_7_8_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_8> ;
    skos:definition "Creating an effective plan and structure to address and resolve requests of IT users. Determine, record, and monitor user requests. Obtain information about the effectiveness and performance of the user request handling process from the IT users through various means."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.8.3" ;
    skos:prefLabel "Manage IT user requests"@en .

<http://ots.local/thesaurus/apqc/8_7_8_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_8> ;
    skos:definition "Follow processes and procedures to escalate IT requests to required levels for resolution or effective decision making when necessary."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.8.4" ;
    skos:prefLabel "Escalate IT requests"@en .

<http://ots.local/thesaurus/apqc/8_7_8_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_8> ;
    skos:definition "Creating a structure to resolve issues/requests of IT services using different mechanisms."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.8.5" ;
    skos:prefLabel "Resolve IT issues/requests"@en .

<http://ots.local/thesaurus/apqc/8_7_8_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/8_7_8> ;
    skos:definition "Successfully implement preventive measures to manage IT risk of exposure to internal and external threats. Integrating the disciplines of Emergency Response, Crisis Management, Disaster Recovery (technology continuity) and Business Continuity for IT."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "8.7.8.6" ;
    skos:prefLabel "Execute IT continuity and recovery action"@en .

<http://ots.local/thesaurus/apqc/9_10_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_10> ;
    skos:definition "Forecasting and monitoring changes in foreign currency value or interest rates around the world that play an important role in the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.10.1" ;
    skos:prefLabel "Monitor international rates"@en .

<http://ots.local/thesaurus/apqc/9_10_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_10> ;
    skos:definition "Managing any transfer of funds in the course of conducting cross-border trades or investments, including conversion across currencies. Find the most suitable alternative for making payments, while saving taxes and avoiding any unwarranted regulation, with the objective of protecting capital."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.10.2" ;
    skos:prefLabel "Manage transactions"@en .

<http://ots.local/thesaurus/apqc/9_10_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_10> ;
    skos:definition "Assessing exposure to potential financial losses as a result of changes in the value of currencies. Forecast the impact of movements in foreign currency values. Enter into financial transactions designed to offset or limit potential exposure to loss."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.10.3" ;
    skos:prefLabel "Monitor currency exposure/hedge currency"@en .

<http://ots.local/thesaurus/apqc/9_10_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_10> ;
    skos:definition "Documenting and reporting accounting entries to formally report financial gains or losses experienced as a result of foreign exchange activity."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.10.4" ;
    skos:prefLabel "Report results"@en .

<http://ots.local/thesaurus/apqc/9_11_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_11> ;
    skos:definition "Evaluating the approved list of parties for engaging in international trade in order to ensure the safety of the organization's business transactions. Examine agents that have been granted legal rights to engage in global trade and their credentials."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.11.1" ;
    skos:prefLabel "Screen sanctioned party list"@en .

<http://ots.local/thesaurus/apqc/9_11_10> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_11> ;
    skos:definition "Creating a document assuring that a seller will receive payment when certain delivery conditions are met. (If the buyer is unable to make payment on the purchase, a bank covers the outstanding amount.)"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.11.10" ;
    skos:prefLabel "Prepare letter of credit"@en .

<http://ots.local/thesaurus/apqc/9_11_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_11> ;
    skos:definition "Overseeing and directing the flow of trade to/from the organization in order to ensure financial gains."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.11.2" ;
    skos:prefLabel "Control exports and imports"@en .

<http://ots.local/thesaurus/apqc/9_11_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_11> ;
    skos:definition "Systematically categorizing products/services for their suitability to international trade. Create classes and categories for demarcating the types of products suitable for international trade. Study requisite national and international standards and the adherence of the organization's portfolio of offerings to these."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.11.3" ;
    skos:prefLabel "Classify products"@en .

<http://ots.local/thesaurus/apqc/9_11_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_11> ;
    skos:definition "Identifying current exchange rates between two currencies and converting the foreign currency to that of the local monetary unit. I.E., yen to US dollar."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.11.4" ;
    skos:prefLabel "Perform currency conversion"@en .

<http://ots.local/thesaurus/apqc/9_11_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_11> ;
    skos:definition "Computing the excise duty to be paid during international trade."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.11.5" ;
    skos:prefLabel "Calculate duty"@en .

<http://ots.local/thesaurus/apqc/9_11_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_11> ;
    skos:definition "Communicating with the customs department to ensure fluid compliance. Share pertinent information mandated by law with the government agency that controls and collects the duties levied for the international exchange of products/services."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.11.6" ;
    skos:prefLabel "Communicate with customs"@en .

<http://ots.local/thesaurus/apqc/9_11_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_11> ;
    skos:definition "Documenting and recording the trade processes while making transactions, noting the description, quality, number, transportation medium, indemnity, and inspection."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.11.7" ;
    skos:prefLabel "Document trade"@en .

<http://ots.local/thesaurus/apqc/9_11_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_11> ;
    skos:definition "Preparing global trade under preference, which allows the organization to import/export products at a lower or nil rate of customs duty and/or levy charge."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.11.8" ;
    skos:prefLabel "Process trade preferences"@en .

<http://ots.local/thesaurus/apqc/9_11_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_11> ;
    skos:definition "Administering and overseeing all restitution activities the organization may be subjected to. Manage compliance with apposite legal frameworks. Make any restitution that may be required by law; comply with authorities over any fines or non-financial measures imposed."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.11.9" ;
    skos:prefLabel "Handle restitution"@en .

<http://ots.local/thesaurus/apqc/9_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_1> ;
    skos:definition "Ensuring the effective allocation, utilization, and sustainability of financial assets. Activities include analyzing internal and external financial drivers; identifying long-term funding needs; evaluating investment, capital, and liquidity requirements; and defining guiding financial principles that support enterprise objectives."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.1.1" ;
    skos:prefLabel "Develop and manage financial resources strategy"@en .

<http://ots.local/thesaurus/apqc/9_1_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_1_2> ;
    skos:definition "Formulating financial budgetary guidelines and strategies. Develop a framework for rules and regulations regarding budgets. Create a step-by-step process to achieve financial goals."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.1.2.1" ;
    skos:prefLabel "Develop and maintain budget policies and procedures"@en .

<http://ots.local/thesaurus/apqc/9_1_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_1_2> ;
    skos:definition "Creating reports on a quarterly or annual basis for fund allocation. Create a financial statement that estimates revenues and expenses over a specific period of time. (Leverage budget methods such as cost-based and zero-based budgeting techniques, in light of the periodic targets outlined during Develop and maintain budget policies and procedures [10771].)"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.1.2.2" ;
    skos:prefLabel "Prepare periodic budgets and plans"@en .

<http://ots.local/thesaurus/apqc/9_1_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_1_2> ;
    skos:definition "Putting budgeting plans into practical use keeping within designated forecasting parameters."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.1.2.3" ;
    skos:prefLabel "Operationalize and implement plans to achieve budget"@en .

<http://ots.local/thesaurus/apqc/9_1_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_1_2> ;
    skos:definition "Creating estimates of the projected income and expenses required over a predetermined time frame. Develop the projections of profit and loss statements, balance sheets, and the cash flow forecast."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.1.2.4" ;
    skos:prefLabel "Prepare periodic financial forecasts"@en .

<http://ots.local/thesaurus/apqc/9_1_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_1_2> ;
    skos:definition "Conducting a quantitative analysis between what was forecasted and budgeted and actual financial behavior."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.1.2.5" ;
    skos:prefLabel "Perform variance analysis against forecasts and budgets"@en .

<http://ots.local/thesaurus/apqc/9_1_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_1_3> ;
    skos:definition "Conducting accounting for assets, and finding reasons for changes (depreciation, obsolescence, deterioration, change in customer taste, increased demand, decreased market supply, etc.)."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.1.3.1" ;
    skos:prefLabel "Perform inventory accounting"@en .

<http://ots.local/thesaurus/apqc/9_1_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_1_3> ;
    skos:definition "Determining the revenue, profits, and losses incurred by each unit within the organization that produces profit."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.1.3.2" ;
    skos:prefLabel "Perform profit center accounting"@en .

<http://ots.local/thesaurus/apqc/9_1_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_1_3> ;
    skos:definition "Studying expenses directly associated with product. Analyze the cost of sales, which is the cost of manufacturing products."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.1.3.3" ;
    skos:prefLabel "Perform cost of sales analysis"@en .

<http://ots.local/thesaurus/apqc/9_1_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_1_3> ;
    skos:definition "Studying and finding out the relevant cost center for a product by studying every resource used in its making."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.1.3.4" ;
    skos:prefLabel "Perform product costing"@en .

<http://ots.local/thesaurus/apqc/9_1_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_1_3> ;
    skos:definition "Discovering the changes between forecasted and actual costing. Analyze actual and planned behavior by reviewing the amount of a variance on a trend line in order to maintain control over a business."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.1.3.5" ;
    skos:prefLabel "Perform variance analysis"@en .

<http://ots.local/thesaurus/apqc/9_1_3_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_1_3> ;
    skos:definition "Making a report about revenues generated by the organization or business unit concerned. This process requires the organization to create a report which shows how business is generating profits. Profits are the part which is left after paying all expenses directly related to the generation of the revenue, such as producing a product, and other expenses related to conducting business activities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.1.3.6" ;
    skos:prefLabel "Report on profitability"@en .

<http://ots.local/thesaurus/apqc/9_1_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_1_4> ;
    skos:definition "Defining cost drivers for a particular activity."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.1.4.1" ;
    skos:prefLabel "Determine key cost drivers"@en .

<http://ots.local/thesaurus/apqc/9_1_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_1_4> ;
    skos:definition "Calculating cost drivers."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.1.4.2" ;
    skos:prefLabel "Measure cost drivers"@en .

<http://ots.local/thesaurus/apqc/9_1_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_1_4> ;
    skos:definition "Determine the activities that hinder the progress of finance activities. This requires the organization to determine those business activities carried out by the financial function of the organization and which are indispensable. This undertaking helps the organization triangulate those activities which are essential and where costs cannot be slashed."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.1.4.3" ;
    skos:prefLabel "Determine critical activities"@en .

<http://ots.local/thesaurus/apqc/9_1_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_1_4> ;
    skos:definition "Distributing or allocating asset resources in different processes for optimal utilization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.1.4.4" ;
    skos:prefLabel "Manage asset resource deployment and utilization"@en .

<http://ots.local/thesaurus/apqc/9_1_5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_1_5> ;
    skos:definition "Studying product demand and targeted customer preferences. Study customers' demands or preferences after deducting the cost of delivering the final product."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.1.5.1" ;
    skos:prefLabel "Assess customer and product profitability"@en .

<http://ots.local/thesaurus/apqc/9_1_5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_1_5> ;
    skos:definition "Checking demand about a specific product by a customer segment. Conduct a detailed study--or research a customer behavior or preference for a product--in order to determine its production and profitability in a specific market."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.1.5.2" ;
    skos:prefLabel "Evaluate new products"@en .

<http://ots.local/thesaurus/apqc/9_1_5_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_1_5> ;
    skos:definition "Determining the cost of delivering an end product at different stages of production. Study the total life cycle of a product/process to determine how much revenue and production cost will be incurred at every stage in order to make strategic decisions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.1.5.3" ;
    skos:prefLabel "Perform life cycle costing"@en .

<http://ots.local/thesaurus/apqc/9_1_5_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_1_5> ;
    skos:definition "Creating the best fit between a product and the end user. Maximize the customer base by providing different products in the market."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.1.5.4" ;
    skos:prefLabel "Optimize customer and product mix"@en .

<http://ots.local/thesaurus/apqc/9_1_5_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_1_5> ;
    skos:definition "Observing the behavior of a new set of customers for different products. Prepare strategies to improve sales and profits."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.1.5.5" ;
    skos:prefLabel "Track performance of new-customer and product strategies"@en .

<http://ots.local/thesaurus/apqc/9_1_5_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_1_5> ;
    skos:definition "Evaluating performance based on different sets of activities created by management to measure performance."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.1.5.6" ;
    skos:prefLabel "Prepare activity-based performance measures"@en .

<http://ots.local/thesaurus/apqc/9_1_5_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_1_5> ;
    skos:definition "Conducting activities to improve cost distribution regularly. Follow or adopt different ways of reducing costs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.1.5.7" ;
    skos:prefLabel "Manage continuous cost improvement"@en .

<http://ots.local/thesaurus/apqc/9_2_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2_1> ;
    skos:definition "Creating guidelines for providing advances. Set up credit standards, credit terms, and collection policies."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.1.1" ;
    skos:prefLabel "Establish credit policies"@en .

<http://ots.local/thesaurus/apqc/9_2_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2_1> ;
    skos:definition "Checking and accepting new requests based on eligibility criteria. Analyze the status of applicants and requirements to be met for a new account."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.1.2" ;
    skos:prefLabel "Analyze/Approve new account applications"@en .

<http://ots.local/thesaurus/apqc/9_2_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2_1> ;
    skos:definition "Reviewing past credit scores to determine the if a line of credit will be extended to potential customers. This could also include extending additional credit to existing accounts."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.1.3" ;
    skos:prefLabel "Analyze credit scoring history"@en .

<http://ots.local/thesaurus/apqc/9_2_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2_1> ;
    skos:definition "Planning credit score requirements based on established credit policies."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.1.4" ;
    skos:prefLabel "Forecast credit scoring requirement"@en .

<http://ots.local/thesaurus/apqc/9_2_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2_1> ;
    skos:definition "Evaluating existing account holders and their past performance. Regularly review existing accounts to get the required information about the status at present."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.1.5" ;
    skos:prefLabel "Review existing accounts"@en .

<http://ots.local/thesaurus/apqc/9_2_1_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2_1> ;
    skos:definition "Preparing account payable reports about payments to be made according to accounting rules and principles, and providing the reports to management."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.1.6" ;
    skos:prefLabel "Produce credit/collection reports"@en .

<http://ots.local/thesaurus/apqc/9_2_1_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2_1> ;
    skos:definition "Closing or restarting accounts according to changes made in credit policies."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.1.7" ;
    skos:prefLabel "Reinstate or suspend accounts based on credit policies"@en .

<http://ots.local/thesaurus/apqc/9_2_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2_2> ;
    skos:definition "Creating and updating a record of customers and the products being purchased by them in a database. This process element requires the organization to maintain a database of customers and their purchases. Such a master-file can be used to ensure customer touch point, enhance customer satisfaction, explore cross selling opportunities, and identify future trends. This database will include several particulars about the personal details of the organization's customers and a tracking of the products being sold."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.2.1" ;
    skos:prefLabel "Maintain customer/product master files"@en .

<http://ots.local/thesaurus/apqc/9_2_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2_2> ;
    skos:definition "Preparing detailed reports about products purchased by customers. Record and generate a detail account of transactions made by customers fat a particular time and location. Include all details about products such as price, quantity, and name."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.2.2" ;
    skos:prefLabel "Generate customer billing data"@en .

<http://ots.local/thesaurus/apqc/9_2_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2_2> ;
    skos:definition "Providing information to customers about purchases made by them. Communicate the details of purchases. Provide customers with a copy of details for their reference."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.2.3" ;
    skos:prefLabel "Transmit billing data to customers"@en .

<http://ots.local/thesaurus/apqc/9_2_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2_2> ;
    skos:definition "Registering transactions and their scheduled payments."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.2.4" ;
    skos:prefLabel "Post receivable entries"@en .

<http://ots.local/thesaurus/apqc/9_2_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2_2> ;
    skos:definition "Checking and solving billing queries raised by customers."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.2.5" ;
    skos:prefLabel "Resolve customer billing inquiries"@en .

<http://ots.local/thesaurus/apqc/9_2_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2_3> ;
    skos:definition "Creating rules and regulations to be followed in case of credit sales to customers. Create rules and procedures to follow at the time of sale (e.g., the allowable number of installments)."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.3.1" ;
    skos:prefLabel "Establish AR policies"@en .

<http://ots.local/thesaurus/apqc/9_2_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2_3> ;
    skos:definition "Collecting cash from customers. Deposit it into bank account. Make entries into the books of accounts."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.3.2" ;
    skos:prefLabel "Receive/Deposit customer payments"@en .

<http://ots.local/thesaurus/apqc/9_2_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2_3> ;
    skos:definition "Checking and moving funds between countries for business activities, typically through authorized remittance agents."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.3.3" ;
    skos:prefLabel "Apply cash remittances"@en .

<http://ots.local/thesaurus/apqc/9_2_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2_3> ;
    skos:definition "Preparing reports that detail balances due or what to collect from customers at a certain point in time."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.3.4" ;
    skos:prefLabel "Prepare AR reports"@en .

<http://ots.local/thesaurus/apqc/9_2_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2_3> ;
    skos:definition "Preparing the general ledger for account receivables from journals. Place all journal entries related to accounts receivables in the general ledger accounts of a business."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.3.5" ;
    skos:prefLabel "Post AR activity to the general ledger"@en .

<http://ots.local/thesaurus/apqc/9_2_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2_4> ;
    skos:definition "Creating a process to follow in case of a failed payment by account holders. Create rules and regulations for the account holder who has failed to make at least the minimum monthly payment by the due date."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.4.1" ;
    skos:prefLabel "Establish policies for delinquent accounts"@en .

<http://ots.local/thesaurus/apqc/9_2_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2_4> ;
    skos:definition "Examining balance statements of accountholders who failed to make required payments. Study or review the account details of customers' past payments when preparing negotiations policies."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.4.2" ;
    skos:prefLabel "Analyze delinquent account balances"@en .

<http://ots.local/thesaurus/apqc/9_2_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2_4> ;
    skos:definition "Determine ways for customers in default to repay debts (e.g., allowing more time or discounts)."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.4.3" ;
    skos:prefLabel "Correspond/Negotiate with delinquent accounts"@en .

<http://ots.local/thesaurus/apqc/9_2_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2_4> ;
    skos:definition "Determining rules for handling accounts. Discuss and plan with internal parties (department heads, managers, and senior management) about rules to follow in coming months."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.4.4" ;
    skos:prefLabel "Discuss account resolution with internal parties"@en .

<http://ots.local/thesaurus/apqc/9_2_4_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2_4> ;
    skos:definition "Maintaining reserves for write-offs and adjustments. Adjust or write off certain expenses and losses."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.4.5" ;
    skos:prefLabel "Process adjustments/write off balances"@en .

<http://ots.local/thesaurus/apqc/9_2_4_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2_4> ;
    skos:definition "Renegotiating the terms of a loan agreement in order to recoup money from a default account."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.4.6" ;
    skos:prefLabel "Perform recovery workout"@en .

<http://ots.local/thesaurus/apqc/9_2_4_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2_4> ;
    skos:definition "Managing accounts that have not met the requirements agreed upon to pay off outstanding debts."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.4.7" ;
    skos:prefLabel "Manage default accounts"@en .

<http://ots.local/thesaurus/apqc/9_2_5_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2_5> ;
    skos:definition "Creating guidelines to follow in case of adjustments to business processes."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.5.1" ;
    skos:prefLabel "Establish policies/procedures for adjustments"@en .

<http://ots.local/thesaurus/apqc/9_2_5_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2_5> ;
    skos:definition "Checking changes made in accounts during the year. Examine the alterations made in final accounts to rectify errors/omissions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.5.2" ;
    skos:prefLabel "Analyze adjustments"@en .

<http://ots.local/thesaurus/apqc/9_2_5_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2_5> ;
    skos:definition "Providing suitable offers to customers. Present different offers (e.g., discounts) available for customers or buyers."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.5.3" ;
    skos:prefLabel "Correspond/Negotiate with customer"@en .

<http://ots.local/thesaurus/apqc/9_2_5_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2_5> ;
    skos:definition "Discussing and planning with internal parties (department heads, managers, and senior management) about rules to follow in coming months."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.5.4" ;
    skos:prefLabel "Discuss resolution with internal parties"@en .

<http://ots.local/thesaurus/apqc/9_2_5_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2_5> ;
    skos:definition "Creating a mechanism for consumer protection in case of a higher price charged. When a supplier sells a product at a higher price to the distributor than the price they have set with the end user, submit a chargeback to the supplier to recover the money lost in the transaction."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.5.5" ;
    skos:prefLabel "Prepare chargeback invoices"@en .

<http://ots.local/thesaurus/apqc/9_2_5_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_2_5> ;
    skos:definition "Recording business transactions as they occur in order to provide a balanced accounts for financial reporting."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.2.5.6" ;
    skos:prefLabel "Process related entries"@en .

<http://ots.local/thesaurus/apqc/9_3_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3_1> ;
    skos:definition "Agreeing upon terms and conditions. Negotiate an agreement between two or more parties, the customer and service providers. Specify scope, quality, and responsibilities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.1.1" ;
    skos:prefLabel "Negotiate service-level agreements"@en .

<http://ots.local/thesaurus/apqc/9_3_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3_1> ;
    skos:definition "Establishing policies and procedures to prepare financial statements, including methods, measurement systems, and procedures for providing disclosures."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.1.2" ;
    skos:prefLabel "Establish accounting policies"@en .

<http://ots.local/thesaurus/apqc/9_3_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3_1> ;
    skos:definition "Creating a written copy of agreed-upon procedures for preparing financial statements, and making them available to the public."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.1.3" ;
    skos:prefLabel "Publish accounting policies"@en .

<http://ots.local/thesaurus/apqc/9_3_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3_1> ;
    skos:definition "Implementing parameters for accounting. Apply set conditions for any approval process."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.1.4" ;
    skos:prefLabel "Set and enforce approval limits"@en .

<http://ots.local/thesaurus/apqc/9_3_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3_1> ;
    skos:definition "Establishing processes and procedures to exercise financial control and accountability. Record, verify, and report transactions that affect revenues, expenditures, assets, and liabilities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.1.5" ;
    skos:prefLabel "Establish common financial systems"@en .

<http://ots.local/thesaurus/apqc/9_3_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3_2> ;
    skos:definition "Preparing trial balance account from general ledgers. List all accounts used in the general ledger. Alter accounts according to business requirements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.2.1" ;
    skos:prefLabel "Maintain chart of accounts"@en .

<http://ots.local/thesaurus/apqc/9_3_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3_2> ;
    skos:definition "Making ledger and trial balance accounts from journal entries. This process requires the organization to record every transaction into accounts done by business. It is a base documents for preparing final accounts of company."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.2.2" ;
    skos:prefLabel "Process journal entries"@en .

<http://ots.local/thesaurus/apqc/9_3_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3_2> ;
    skos:definition "Allocating funds across functions. Apportion funds in line with the budgets created. Formalize allocations in centralized internal records."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.2.3" ;
    skos:prefLabel "Process allocations"@en .

<http://ots.local/thesaurus/apqc/9_3_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3_2> ;
    skos:definition "Updating journal entries to adjust the balance of income and expenses at the end of an accounting period."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.2.4" ;
    skos:prefLabel "Process period end adjustments"@en .

<http://ots.local/thesaurus/apqc/9_3_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3_2> ;
    skos:definition "Checking accounts separately for a parent and subsidiary company. Manage relationship between a parent company and subsidiaries. Document intercompany transactions in separate financial statements."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.2.5" ;
    skos:prefLabel "Post and reconcile intercompany transactions"@en .

<http://ots.local/thesaurus/apqc/9_3_2_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3_2> ;
    skos:definition "Reviewing general ledger accounts for a parent and subsidiaries companies. Validate the integrity of account balances on the company's general ledger of accounts. Review and compare general ledger accounts balances with source documents to ensure that balances match."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.2.6" ;
    skos:prefLabel "Reconcile general ledger accounts"@en .

<http://ots.local/thesaurus/apqc/9_3_2_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3_2> ;
    skos:definition "Aggregating different processes in the business. Eliminate discontinued processes."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.2.7" ;
    skos:prefLabel "Perform consolidations and process eliminations"@en .

<http://ots.local/thesaurus/apqc/9_3_2_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3_2> ;
    skos:definition "Balancing debit and credit balances of trial balance to preparing final accounts. Calculate the total debits and credits in company's accounts. Correspond the sum of all debits with the sum of all credits. Adjust entries as appropriate."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.2.8" ;
    skos:prefLabel "Prepare trial balance"@en .

<http://ots.local/thesaurus/apqc/9_3_2_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3_2> ;
    skos:definition "Accounting for changes due to country-level policy changes. Record adjustments made by management in the accounts."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.2.9" ;
    skos:prefLabel "Prepare and post management adjustments"@en .

<http://ots.local/thesaurus/apqc/9_3_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3_3> ;
    skos:definition "Creating rules for fixed assets market valuation. Make rules and regulations for fixed assets regarding depreciation, provisions, resale, usage, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.3.1" ;
    skos:prefLabel "Establish fixed-asset policies and procedures"@en .

<http://ots.local/thesaurus/apqc/9_3_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3_3> ;
    skos:definition "Keeping reports up-to-date regarding fixed assets. Create a fixed assets database detailing price, life cycle, depreciation rate, resale value, installation information, usage information, etc."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.3.2" ;
    skos:prefLabel "Maintain fixed-asset master data files"@en .

<http://ots.local/thesaurus/apqc/9_3_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3_3> ;
    skos:definition "Keeping a summary of sales and purchases of assets. Record any expenses made for new assets purchased and sales of any old assets during the fiscal year."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.3.3" ;
    skos:prefLabel "Process and record fixed-asset additions and retires"@en .

<http://ots.local/thesaurus/apqc/9_3_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3_3> ;
    skos:definition "Keeping a summary of expenses for installing and modifying assets. Record any expenses made for new assets purchased, any expenses incurred on improvements, the valuation of assets to reach current market price, and any transfer assets from one location to another during the fiscal year."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.3.4" ;
    skos:prefLabel "Process and record fixed-asset adjustments, enhancements, revaluations, and transfers"@en .

<http://ots.local/thesaurus/apqc/9_3_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3_3> ;
    skos:definition "Maintaining a record of expenses necessitated for repairs and the preservation of assets. Administer and oversee the maintenance and repair of any fixed assets. Record all related transactions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.3.5" ;
    skos:prefLabel "Process and record fixed-asset maintenance and repair expenses"@en .

<http://ots.local/thesaurus/apqc/9_3_3_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3_3> ;
    skos:definition "Carrying out accounting for depreciation over fixed assets. Compute the sums necessitated. Maintain a record of the cost value of fixed assets over their useful life in the book of accounts."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.3.6" ;
    skos:prefLabel "Calculate and record depreciation expense"@en .

<http://ots.local/thesaurus/apqc/9_3_3_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3_3> ;
    skos:definition "Balancing the ledger account balance for fixed assets. Correct errors in the books of fixed assets. Provide correct information in relevant accounts."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.3.7" ;
    skos:prefLabel "Reconcile fixed-asset ledger"@en .

<http://ots.local/thesaurus/apqc/9_3_3_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3_3> ;
    skos:definition "Checking and updating the record of all raw materials and fixed assets. Track all fixes asset. Maintain a record of all inventory items."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.3.8" ;
    skos:prefLabel "Track fixed-assets including physical inventory"@en .

<http://ots.local/thesaurus/apqc/9_3_3_9> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3_3> ;
    skos:definition "Showing market value and related expenses on fixed assets data for taxation. Provide complete information recorded in the books of fixed assets about purchase price, depreciation, installation charges, resale market value etc. for tax and regulatory purposes."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.3.9" ;
    skos:prefLabel "Provide fixed-asset data to support tax, statutory, and regulatory reporting"@en .

<http://ots.local/thesaurus/apqc/9_3_4_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3_4> ;
    skos:definition "Making reports of subsidiaries units to show profits generated from them. Prepare financial statements (balance sheets, income statements, cash flow statements and statements of shareholders' equity) for a single unit of a business."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.4.1" ;
    skos:prefLabel "Prepare business unit financial statements"@en .

<http://ots.local/thesaurus/apqc/9_3_4_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3_4> ;
    skos:definition "Making final accounts for all units of company together. Prepare combined financial statements of a parent company and its subsidiaries (i.e., separate legal entities controlled by a parent company) showing assets, liabilities, equity, income, expenses, and cash flows."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.4.2" ;
    skos:prefLabel "Prepare consolidated financial statements"@en .

<http://ots.local/thesaurus/apqc/9_3_4_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3_4> ;
    skos:definition "Making reports for units/subsidiaries to help management in decision making. Prepare financial statements (balance sheets, income statements, cash flow statements, and statements of shareholders' equity) for a single unit of a business. Break down profits and losses by function/unit, clients, products, and region."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.4.3" ;
    skos:prefLabel "Perform business unit reporting/review management reports"@en .

<http://ots.local/thesaurus/apqc/9_3_4_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3_4> ;
    skos:definition "Making reports for all units to help higher management in decision making. Prepare combined financial statements of a parent company and its all subsidiaries (separate legal entities controlled by a parent company) showing assets, liabilities, equity, income, expenses and cash flows, and also going through periodic reports which shows the actual and estimated costs and their variances."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.4.4" ;
    skos:prefLabel "Perform consolidated reporting/review of cost management reports"@en .

<http://ots.local/thesaurus/apqc/9_3_4_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3_4> ;
    skos:definition "Preparing a draft of financial statements for the board to review before they are sent to the auditor."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.4.5" ;
    skos:prefLabel "Prepare statements for board review"@en .

<http://ots.local/thesaurus/apqc/9_3_4_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3_4> ;
    skos:definition "Making and presenting financial reports to stakeholders. Create annual and quarterly financial statements for reporting purposes. Prepare shareholder reports with details of the profit-and-loss account, balance sheet, and past year's business activities."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.4.6" ;
    skos:prefLabel "Produce quarterly/annual filings and shareholder reports"@en .

<http://ots.local/thesaurus/apqc/9_3_4_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3_4> ;
    skos:definition "Reporting raw or summary data for final accounts following rules and regulations."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.4.7" ;
    skos:prefLabel "Produce regulatory reports"@en .

<http://ots.local/thesaurus/apqc/9_3_4_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_3_4> ;
    skos:definition "Carrying out activities associated with legal and management consolidation. Legal consolidation can include currency conversion, balance carry forward, and consolidation of journal entries. Management consolidation can include reporting on financials on a reporting cycle basis to gauge the performance of the organization."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.3.4.8" ;
    skos:prefLabel "Perform legal and management consolidation"@en .

<http://ots.local/thesaurus/apqc/9_4_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_4_1> ;
    skos:definition "Creating procedures and policies to follow for investing in capital projects. Create rules and regulations regarding large investment plans, which require in-depth forecasting for expenditure and revenue."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.4.1.1" ;
    skos:prefLabel "Develop capital investment policies and procedures"@en .

<http://ots.local/thesaurus/apqc/9_4_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_4_1> ;
    skos:definition "Creating budgets, and soliciting approvals for capital projects. Prepare budgets for projects that require heavy investments. Secure approvals from management."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.4.1.2" ;
    skos:prefLabel "Develop and approve capital expenditure plans and budgets"@en .

<http://ots.local/thesaurus/apqc/9_4_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_4_1> ;
    skos:definition "Evaluating and supporting capital investments in projects and fixed assets. Confirm details of capital projects. Secure approvals from managements for large investments."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.4.1.3" ;
    skos:prefLabel "Review and approve capital projects and fixed-asset acquisitions"@en .

<http://ots.local/thesaurus/apqc/9_4_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_4_1> ;
    skos:definition "Reviewing all project business cases in order to substantiate projected financial gains. Validate any project's business case. Juxtapose the benefits derived from moving a project forward against the associated costs."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.4.1.4" ;
    skos:prefLabel "Conduct financial justification for project approval"@en .

<http://ots.local/thesaurus/apqc/9_4_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_4_2> ;
    skos:definition "Giving reference codes for every project."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.4.2.1" ;
    skos:prefLabel "Create project account codes"@en .

<http://ots.local/thesaurus/apqc/9_4_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_4_2> ;
    skos:definition "Noting every transaction during a project in a common financial database. Document all transactions associated with any project. Maintain a centralized repository of all such financial data."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.4.2.2" ;
    skos:prefLabel "Record project-related transactions"@en .

<http://ots.local/thesaurus/apqc/9_4_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_4_2> ;
    skos:definition "Evaluating project progress and funds invested. Observe and track significant funds invested on any long-term project. Compare to budget."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.4.2.3" ;
    skos:prefLabel "Monitor and track capital projects and budget spending"@en .

<http://ots.local/thesaurus/apqc/9_4_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_4_2> ;
    skos:definition "Checking for returns generated from projects for decision making. Evaluate capital projects that require heavy investments. Decide whether to proceed based on the revenues generated."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.4.2.4" ;
    skos:prefLabel "Close/Capitalize projects"@en .

<http://ots.local/thesaurus/apqc/9_4_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_4_2> ;
    skos:definition "Comparing a finished project's profitability with forecasted returns. Scrutinize revenues generated by completed projects that required heavy investments. Determine profitability."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.4.2.5" ;
    skos:prefLabel "Measure financial returns on completed capital projects"@en .

<http://ots.local/thesaurus/apqc/9_5_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_5_1> ;
    skos:definition "Developing policies and procedures for the HR function to calculate compensation."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.5.1.1" ;
    skos:prefLabel "Establish policies and procedures"@en .

<http://ots.local/thesaurus/apqc/9_5_1_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_5_1> ;
    skos:definition "Tracking billing hours of each employee on daily basis."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.5.1.2" ;
    skos:prefLabel "Collect and record employee time worked"@en .

<http://ots.local/thesaurus/apqc/9_5_1_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_5_1> ;
    skos:definition "Tracking leaves allowed and taken by employees."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.5.1.3" ;
    skos:prefLabel "Analyze and report paid and unpaid leave"@en .

<http://ots.local/thesaurus/apqc/9_5_1_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_5_1> ;
    skos:definition "Observing the number of hours worked by an employees on daily basis. Track the number of hours worked by an employee, as well as the number of hours worked beyond normal working hour's according to company standards."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.5.1.4" ;
    skos:prefLabel "Monitor regular, overtime, and other hours"@en .

<http://ots.local/thesaurus/apqc/9_5_1_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_5_1> ;
    skos:definition "Monitoring the number of productive hours for employees."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.5.1.5" ;
    skos:prefLabel "Analyze and report employee utilization"@en .

<http://ots.local/thesaurus/apqc/9_5_2_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_5_2> ;
    skos:definition "Tracking the number of hours worked for the payroll system. Register the number of hours worked by an employee into the payroll system for the purpose of calculating salaries or wages."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.5.2.1" ;
    skos:prefLabel "Enter employee time worked into payroll system"@en .

<http://ots.local/thesaurus/apqc/9_5_2_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_5_2> ;
    skos:definition "Tracking and oversee salary breakups of employees. This process requires the organization to manage and update information pertaining to the structure of every employee's salary. This would involve the updating any changes to the salary structures of the employees, in a central repository which can be accessed by pertinent departments."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.5.2.2" ;
    skos:prefLabel "Maintain and administer employee earnings information"@en .

<http://ots.local/thesaurus/apqc/9_5_2_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_5_2> ;
    skos:definition "Processing salary deductions for tax purposes. Keep and manage the details of every employee's salary deductions based on their expenses and investments during the year."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.5.2.3" ;
    skos:prefLabel "Maintain and administer applicable deductions"@en .

<http://ots.local/thesaurus/apqc/9_5_2_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_5_2> ;
    skos:definition "Tracking changes in the salary structure of employees for tax deductions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.5.2.4" ;
    skos:prefLabel "Monitor changes in tax status of employees"@en .

<http://ots.local/thesaurus/apqc/9_5_2_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_5_2> ;
    skos:definition "Processing and distributing salaries to all employees. Execute the payroll management function through the dispensation of employee salaries. Leverage a centralized database of all payroll expenses."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.5.2.5" ;
    skos:prefLabel "Process and distribute payments"@en .

<http://ots.local/thesaurus/apqc/9_5_2_6> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_5_2> ;
    skos:definition "Handling incorrect/omitted salary payments."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.5.2.6" ;
    skos:prefLabel "Process and distribute manual checks"@en .

<http://ots.local/thesaurus/apqc/9_5_2_7> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_5_2> ;
    skos:definition "Adjusting salary deductions for tax purposes at the end of the year."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.5.2.7" ;
    skos:prefLabel "Process period-end adjustments"@en .

<http://ots.local/thesaurus/apqc/9_5_2_8> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_5_2> ;
    skos:definition "Addressing salary-related queries raised by employees."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.5.2.8" ;
    skos:prefLabel "Respond to employee payroll inquiries"@en .

<http://ots.local/thesaurus/apqc/9_5_3_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_5_3> ;
    skos:definition "Devising a method to minimize payroll tax liability by means of allowances, deductions, exclusions or exemptions."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.5.3.1" ;
    skos:prefLabel "Develop tax plan"@en .

<http://ots.local/thesaurus/apqc/9_5_3_2> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_5_3> ;
    skos:definition "Overseeing maintaining the reduction of payroll taxes [14075]."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.5.3.2" ;
    skos:prefLabel "Manage tax plan"@en .

<http://ots.local/thesaurus/apqc/9_5_3_3> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_5_3> ;
    skos:definition "Paying tax according to appropriate deductions made from salaries. Calculate and pay the tax liabilities according to the salaries and tax regulations of employees with the help of certified chartered accountants."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.5.3.3" ;
    skos:prefLabel "Calculate and pay applicable payroll taxes"@en .

<http://ots.local/thesaurus/apqc/9_5_3_4> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_5_3> ;
    skos:definition "Providing tax deductions statements created by certified chartered accountants to every employee for their reference or refunds."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.5.3.4" ;
    skos:prefLabel "Produce and distribute employee annual tax statements"@en .

<http://ots.local/thesaurus/apqc/9_5_3_5> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_5_3> ;
    skos:definition "Filling taxes, and highlighting different sources of income and expenditures made."@en ;
    skos:inScheme thes:apqc ;
    skos:notation "9.5.3.5" ;
    skos:prefLabel "File regulatory payroll tax forms"@en .

<http://ots.local/thesaurus/apqc/9_6_1_1> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/9_6_1> ;
