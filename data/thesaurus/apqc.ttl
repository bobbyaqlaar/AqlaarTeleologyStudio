    skos:prefLabel "Gain resource strategy and resource plans Stakeholders approval"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA6_EA9308> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA6_EA9169> ;
    skos:definition "Not used for this process element<br/>"@en ;
