    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7357" ;
    skos:prefLabel "Define Marketing Campaign Proposition"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA1_EA7358> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA1_EA7349> ;
    skos:definition "Design Marketing Campaign workflow designs the marketing campaign workflow which includes establishing and scheduling waves, or periodical steps in the campaign. Each wave is designed to take into account responses from those targeted by the campaign.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7358" ;
    skos:prefLabel "Design Marketing Campaign Workflow"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA1_EA7359> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA1_EA7349> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7359" ;
    skos:prefLabel "Obtain Marketing Campaign Agreement"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA1_EA7360> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA1_EA7395> ;
    skos:definition "Establish Market Participation processes focus on agreement across the enterprise with respect to markets in which the enterprise will participate.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7360" ;
    skos:prefLabel "Establish Market Participation"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA1_EA7361> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA1_EA7395> ;
    skos:definition "Establish Market Strategy Objectives processes focus on defining the Objectives to be achieved and the broad strategies to be followed to achieve the objectives<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7361" ;
    skos:prefLabel "Establish Market Strategy Objectives"@en .

