    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7894" ;
    skos:prefLabel "Analyze Customer Requests & Contacts"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7895> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7906> ;
