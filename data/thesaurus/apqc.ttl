    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7780" ;
    skos:prefLabel "Control Customer Inventory Access"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7781> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7716> ;
    skos:definition "Ensuring the customer inventory repository accurately captures and records all identified customer details, through use of automated or manual audits. Monitoring and reporting on the quality of the data maintained in the inventory. The customer inventory maintains records of all customers, their interactions with the enterprise, any contracts established, and any other customer related- information, required to support CRM and other processes.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7781" ;
    skos:prefLabel "Ensure Customer Inventory Data Quality"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7782> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7716> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7782" ;
    skos:prefLabel "Track Customer Inventory Usage"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7783> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7716> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7783" ;
    skos:prefLabel "Identify Customer Inventory Shortcomings"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7784> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7774> ;
    skos:definition "Deliver Customer Order Carry Through Capability processes ensure there are organizations, processes and technology to monitor customer order delivery progress, to secure delivery according to promised timelines, and engage with the customer and respond to changing delivery expectations, and to accurately manage promised timelines based on fulfillment planning lead times and estimates.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7784" ;
    skos:prefLabel "Deliver Customer Order Carry Through Capability"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7785> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7774> ;
    skos:definition "Deliver Customer Order Creation Capability processes ensure there are organizations, processes and technology to meet customer expectations of orders across all channels and products.<br/>This set of processes ensure the organization implements the capability to sense and manage customer demand accurately, to create and change the customer orders.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7785" ;
    skos:prefLabel "Deliver Customer Order Creation Capability"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7786> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7931> ;
    skos:definition "Contact Customer will keep the customer informed and manage their expectations. It includes tasks to communicate the problem details, resolution steps, and soliciting feedback from the customer.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7786" ;
    skos:prefLabel "Contact Customer"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7787> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7931> ;
    skos:definition "Validate Customer Problem Report will maintain the integrity of the customer problem management processes that includes tasks to review the problem report, correct any errors, and confirm the report validity.<br/>This process was renamed in 23.5. Old name was Complete and Validate Customer Problem Report<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7787" ;
    skos:prefLabel "Validate Customer Problem Report"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7788> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7931> ;
    skos:definition "Update Customer Problem Restoration Time will manage expectations and plan the resolution process. It includes tasks to calculate the restoration time based on the problem complexity and resources and update the problem report and customer accordingly.<br/>This process was 23.5 Name was Update Time to Restore Service<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7788" ;
    skos:prefLabel "Update Customer Problem Restoration Time"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7789> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7931> ;
    skos:definition "Finalize Customer Problem Report will document the problem and its resolution for future reference. It includes tasks to fill in the problem report with the resolution details, root cause analysis, and lessons learned.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7789" ;
    skos:prefLabel "Finalize Customer Problem Report"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7790> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7931> ;
    skos:definition "Communicate Customer Problem Improvement will continuously improve the service. It includes tasks to identify, document, and communicate any improvement suggestions or best practices to the relevant stakeholders.<br/>This process was renamed in 23.5. old name was Communicate Service improvement Opportunity<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7790" ;
    skos:prefLabel "Communicate Customer Problem Improvement Opportunity"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7791> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7820> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7791" ;
    skos:prefLabel "Generate Customer Bill Inquiry"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7792> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7820> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7792" ;
    skos:prefLabel "Convert Customer Bill Inquiry"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7793> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7820> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7793" ;
    skos:prefLabel "Request Additional Bill Inquiry Information"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7794> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7715> ;
    skos:definition "Manage Customer Billing Account's purpose pertains to effective management of the customer’s billing account as it relates to the products purchased and consumed throughout the appropriate billing cycle. This process focuses on managing changes to the customer’s billing account (for example, customer billing address, etc.) as it relates to the customer’s service portfolio, such as ensuring that the correct purchased products are assigned to the customer’s billing account for accurate billing.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7794" ;
    skos:prefLabel "Manage Customer Billing Account"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7798> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7711> ;
    skos:definition "The purpose of this process is to create a new customer record in the customer inventory. This process follows the processes in Establish Customer Relationship that make sure that a single record is created for each customer, and it persists the customer data in the customer inventory.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7798" ;
    skos:prefLabel "Create Customer Record"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7799> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7711> ;
    skos:definition "The purpose of this process is to update the customer data in the customer inventory. This can happen as a result of direct notification from the customer, as a result of information gathered as part of other processes (such as selling and order handling) or as a result of back office processes (such as customer data cleansing).<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7799" ;
    skos:prefLabel "Update Customer Data"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7800> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7711> ;
    skos:definition "The purpose of this process is notify other processes that customer data has been changed. Other processes (mostly long-lived processes) might need to know about such changes in order to adapt to such changes. In addition some processes which gather the data for centralized systems (such as Data Warehouse or Master Data Management) should be notified about such changes.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7800" ;
    skos:prefLabel "Notify Customer Data Change"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7801> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7711> ;
    skos:definition "The purpose of this process is to archive and clean up customer data when it is no longer needed as part of the customer inventory. The information is archived according to the CSP policies and the local regulations. In most cases customer information is not deleted unless this is specifically required by the customer.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7801" ;
    skos:prefLabel "Archive Customer Data"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7802> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7711> ;
    skos:definition "The purpose of this process is to create a single customer record from the information stored in multiple systems and present a single, most updated record of the customer information. This process invokes business rules in order to reconcile the customer data in a single accurate record. This process may be activated immediately upon any update of customer data or may be invoked on request to retrieve the customer data. This process may replicate data from other systems or calculate the unified record on the fly without persisting any customer data.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7802" ;
    skos:prefLabel "Build a unified customer view"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7803> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7719> ;
    skos:definition "The Customer Privacy Management Definition process manage the definition of the privacy management that applies to a particular category of customer.<br/>It is used to determine the legal expectations of entities that want to apply and use customer information (such as jurisdiction, location, regulation, and standards).<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7803" ;
    skos:prefLabel "Manage Customer Privacy Definition"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7805> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7719> ;
    skos:definition "Customer Privacy Profile Agreement and Amendment processes provides Customers the ability to create agreement about processing of their information.<br/>This process is used to prove the conformance with Laws & Regulation, particularly showing the explicit consent and information about the Purposes and Retention of any personal identifiable information.<br/><br/>It creates the agreement regarding the privacy management of a customer. In all engagement with Customers, an agreement with the privacy policy needs to be acknowledged.<br/><br/>Depending on the flexibility of the personal identifiable information privacy attributes, the customer can agree to some requirement or change them.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7805" ;
    skos:prefLabel "Manage Customer Privacy Profile Agreement and Amendment"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7806> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7897> ;
    skos:definition "Incorporate into the customer profile, all relevant information gathered through all contacts with the customer (usage pattern, demographics, life stage, household, community of interest, business direction). Customer and market information from other sources may be gathered, which will build a better understanding of the customer. The purpose of this process is to ensure that Service Provider and the customer feel confident that the relationship is founded on up-to-date, accurate and legally compliant information.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7806" ;
    skos:prefLabel "Gather Customer Information"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7807> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7897> ;
    skos:definition "Not used for this process element<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7807" ;
    skos:prefLabel "Report Customer Information"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7808> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7773> ;
    skos:definition "Deliver Customer Engagement Data Structuring Capability processes implement the supporting processes and technology to identify and structure customer engagement data, and to make the structures of customer events/activities data ready for analysis.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7808" ;
    skos:prefLabel "Deliver Customer Engagement Data Structuring Capability"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7809> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7773> ;
    skos:definition "Deliver Customer Engagement Analyzing Capability processes implement the organization, supporting processes and technology necessary to analyze the customer engagement data in order to discover insights about customers and the customers' interactions with the company, related to the customer's products, customer segment and customer journey.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7809" ;
    skos:prefLabel "Deliver Customer Engagement Analyzing Capability"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7810> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7933> ;
    skos:definition "Manage Customer Problem Restoration will ensure the problem is resolved and service is restored promptly. It includes tasks to coordinate the restoration activities, monitor the restoration progress, and report the restoration status.<br/><br/>This process was renamed in 23.5. old name was Manage Product Restoration<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7810" ;
    skos:prefLabel "Manage Customer Problem Restoration"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7811> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7933> ;
    skos:definition "Report Customer Product Restoration will keep everyone informed about the status of the service. It includes tasks to document the restoration details, communicate the restoration results, and update the problem report and customer accordingly.<br/>This process was renamed in 23.5. old name was Report Product Restoration Results<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7811" ;
    skos:prefLabel "Report Customer Product Restoration"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7812> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7933> ;
    skos:definition "Determine Customer Problem Resolution Feasibility will find the most effective and efficient solution. It includes tasks to evaluate the possible solutions, select the optimal one, and plan the implementation steps.<br/>This process was renamed in 23.5. old name was Determine Resolution Feasibility and Justification<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7812" ;
    skos:prefLabel "Determine Customer Problem Resolution Feasibility"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7813> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7933> ;
    skos:definition "Implement Workaround will restore service as quickly as possible while a permanent solution is being found. It includes tasks to identify, apply, and document the workaround.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7813" ;
    skos:prefLabel "Implement Customer Problem Workaround"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7814> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7933> ;
    skos:definition "Validate Customer Problem Solution will confirm the problem has been fixed. It includes tasks to verify the solution effectiveness, measure the resolution results, and obtain customer feedback.<br/>This process was renamed in 23.5 old process was Test & Validate Implemented Solution<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7814" ;
    skos:prefLabel "Validate Customer Problem Solution"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7815> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7933> ;
    skos:definition "Initiate Customer Problem Change Request will manage changes in a controlled manner by starting a change request if the problem’s resolution requires a change. It includes tasks to create, submit, and approve the change request.<br/>This process was renamed in 23.5. old name was Initiate Change Request<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7815" ;
    skos:prefLabel "Initiate Customer Problem Change Request"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7816> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7933> ;
    skos:definition "Review Major Customer Problem will learn from these issues and prevent them from recurring. It includes tasks to review the root cause analysis, correlate the lessons learned, and recommend the improvement actions giving an understanding of the cause and impact.<br/>This process was renamed in 23.5. old name was Review Major Customer Problem<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7816" ;
    skos:prefLabel "Review Major Problem"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7817> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7852> ;
    skos:definition "Not used for this process element.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7817" ;
    skos:prefLabel "Obtain Billing Events"@en .

