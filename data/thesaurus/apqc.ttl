    skos:notation "etom:EARoot_EA5_EA1_EA3_EA7876" ;
    skos:prefLabel "Analyze QoS Violation"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7877> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA3_EA7881> ;
