<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10187> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10582> ;
    skos:definition "Manage Enterprise Catalog Management Policy activity set the policies for catalog management across the enterprises catalogs.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10187" ;
    skos:prefLabel "Manage Enterprise Catalog Management Policy"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10188> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10582> ;
    skos:definition "Manage Enterprise Catalog Management Standard activity identify and promulgate rules and references for managing conformity of Catalogs for information integrity across the enterprises catalogs.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10188" ;
    skos:prefLabel "Manage Enterprise Catalog Management Standard"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10189> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10340> ;
    skos:definition "Metric Collection Job Specification specifies the time schedule for a data collection task (\"job\") for a Metric, applied to a selected set of objects. Metric Collection Job Specification defines the frequency, periodicity, or any time-based repetition of a measurement campaign. Metric Collection Job Specification also defines any additional constraints and conditions driving the Collection Job.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10189" ;
    skos:prefLabel "Specify Metric Collection Job"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10190> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10340> ;
    skos:definition "Metric Monitoring Criteria Specification defines filters which are used to select a scope of objects to be measured according to a Metric.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10190" ;
    skos:prefLabel "Specify Metric Monitoring Criteria"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10191> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10524> ;
    skos:definition "Manage Operational Requirements business activity is in charge of collecting, documenting, analyzing, tracing, prioritizing and agreeing on needs and wants that support fulfillment, assurance and accounting for management and use of enterprise resources. <br/><br/>Manage Operational Requirements business activity include capturing operational actions needed to effect ongoing operational activities and procedures (under fulfillment, assurance and accounting)in order to address operational mandates. It includes including capturing overarching operations deficiencies, evolving operational requirements, and understanding operational threats that must be addressed.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10191" ;
    skos:prefLabel "Manage Operational Requirements"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10193> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10610> ;
    skos:definition "Manage Performance Activity Consolidation business activity collect data, eliminating intercompany positions, performing equity accounting and establishing group financial statements and analyzing financials.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10193" ;
    skos:prefLabel "Manage Performance Activity Consolidation"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10194> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10610> ;
    skos:definition "Manage Performance Activity Reconciliation business activity support the implementation and enforcement of reconciliation standards, policies, and procedures, and reconciling accounts and documenting accuracy.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10194" ;
    skos:prefLabel "Manage Performance Activity Reconciliation"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10195> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10610> ;
    skos:definition "Manage Performance Activity Closure business activity ensure closing readiness, close sub-ledgers, manage intercompany accounting and transfer pricing, execute general ledger accounting and close, reconcile accounts, prepare financial statements, perform management review and calculate tax provisions according to statutory mandates.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10195" ;
    skos:prefLabel "Manage Performance Activity Closure"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10196> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10504> ;
    skos:definition "Manage Capital Budgeting business activity directs and controls the evaluation of prospective investment. <br/><br/>Manage Capital Budgeting helps to map out the cash outlays and cash inflows associated with an investment.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10196" ;
    skos:prefLabel "Manage Capital Budgeting"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10197> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10504> ;
    skos:definition "Manage Capital Structure business activity directs and controls how the enterprise is financing its operations.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10197" ;
    skos:prefLabel "Manage Capital Structure"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10198> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10562> ;
    skos:definition "Define Default Privacy Information process identifies the information that can be considered Personal Identifiable Information. Such information may include, but not limited to:<br/>Information explicitly defined for storage.<br/>Information about Service Usage, for example the Product Usage records<br/>Information very specific to a service, such as customer demographic<br/>etc.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10198" ;
    skos:prefLabel "Define Default Privacy Information"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10199> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10562> ;
    skos:definition "Define Default Privacy Profile Rules process ensure that minimum mandatory rules are in place to support processing personally identifiable information of customers. This includes:<br/>Internal Purpose Rule (the purpose behind each possible use)<br/>External Purpose Rule (the purpose behind each possible use of a personal identifiable information)<br/>Internal Retention Rule (possible retention times for each personal identifiable information)<br/>External Retention Rule (possible retention times for each personal identifiable information)<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10199" ;
    skos:prefLabel "Define Default Privacy Profile Rules"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10200> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10562> ;
    skos:definition "Define Privacy Policy Rules Requirement process is used to define the requirements possible for each Privacy Profile Rule (Internal/External Purpose Rules, Internal/External Retention Rules). <br/>This establishes privacy options available to a customer, which can be engaged through consent.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10200" ;
    skos:prefLabel "Define Privacy Policy Rules Requirement"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10201> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10181> ;
    skos:definition "Assess Learning Needs business activity analyze and evaluate participants learning needs to identify what participants have learned, how well and where there was struggle. Assess Learning Needs is a key activity in the learning lifecycle management. Learning Need is the gap between the learner's current level of knowledge and skills, and the level of knowledge and skills required to perform a task or a set of tasks. Assess Learning Needs helps to determine target, examine learning goals, and determine learning resources.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10201" ;
    skos:prefLabel "Assess Learning Needs"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10205> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10181> ;
    skos:definition "Implement Learning Program business activity instantiates all the related learning plans and coordinates them under an integrated initiative to support achieving the learning program's experience objective. Implement Learning Program implements the individual units of competency and provides the detailed plans for learners to achieve the specified learning outcomes. 'Learning Program' provide 'Training Management' with input for 'Evaluate Training Program'.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10205" ;
    skos:prefLabel "Implement Learning Program"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10207> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10533> ;
    skos:definition "Employee Relations processes cover a variety of processes, e.g., counseling programs, interface to employee groups, employee involvement in the community and charities in the name of the company, etc. Employee Relations processes focus on relationships with employees at an enterprise and employee group level<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10207" ;
    skos:prefLabel "Manage Employee Relations"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10208> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10533> ;
    skos:definition "Labor Relations processes include definition of terms of employment, labor contracts development, union contract negotiations, arbitration management, etc. Labor Relations processes focus on relationships with employees at an enterprise and employee group level<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10208" ;
    skos:prefLabel "Manage Labor Relations"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10209> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10512> ;
    skos:definition "Manage Production Execution business activity support capturing actual production information from products/services/resources to support overall production control and cost management processes.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10209" ;
    skos:prefLabel "Manage Production Execution"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10210> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10512> ;
    skos:definition "Manage Production Scheduling business activity support assigning of production orders to resources, services, and products based on required sequence and time frame.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10210" ;
    skos:prefLabel "Manage Production Scheduling"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10211> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10527> ;
    skos:definition "Define Standardization Requirement<br/>Manage Standardization Requirement business activity states and describes the needs that must support the development of standards across the enterprise. <br/><br/>Manage Standardization Requirement supports the Manage Standards business activity by ensuring that there exists the steps and check points that assure there is consensus underpinning the establishment, documenting, analyzing, tracing, prioritizing and agreeing on requirements for standards.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10211" ;
    skos:prefLabel "Define Standardization Requirement"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10212> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10527> ;
    skos:definition "Establish Best Practices Model business activity sets up the generally accepted ideas or methods that are considered superior and documents them along with the results they produce.<br/><br/>Establish Best Practice Model business activities include tasks that describe the representational view or framework that embody the practice and proven solutions that help to address a problem or goals for the best practice. The value behind establishing these best practices model is to identify methods that are confirmed as effective, and reduce the need to 'reinvent the wheel'.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10212" ;
    skos:prefLabel "Establish Best Practice Model"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10213> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10527> ;
    skos:definition "Legitimize Standard business activity is in charge of approve and allowing a standard to be formally accepted by the enterprise and its business functions.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10213" ;
    skos:prefLabel "Legitimize Standard"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10214> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10527> ;
    skos:definition "Systematize Standards Use business activity is in charge of applying, evaluating and managing the lifecycle of standards formally recognized by the enterprise.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10214" ;
    skos:prefLabel "Systematize Standards Use"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10215> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10437> ;
    skos:definition "Objectives entails the organization leaders defining financial controls and procedures, and obtaining approval for the financial management approach from key stakeholders, including the sponsor’s finance entity. This process ensures that the program leadership has defined the scope and objectives of the overall Financial Management process, including investment decisions, financial decisions and dividend decisions. The scope of Financial Management generally involves the planning, organizing, directing, and controlling of financial activities such as procurement and utilization of funds. Typical objectives in Financial Management are: <br/><br/>1) Profit maximization, <br/>2) Wealth maximization, <br/>3) Maintaining proper cash flow,<br/> 4) Survival of company and <br/>5) Creating reserves.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10215" ;
    skos:prefLabel "Define Financial Management Scope & Objectives"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10216> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10437> ;
    skos:definition "Define Financial Management Process ensures that the program leadership has defined the overall Financial Management process. The Financial Management Process is a systematic approach to managing an organization’s financial resources. It involves three key elements:<br/><br/>1) Financial Planning<br/>2) Financial Control<br/>3) Financial Decision Making<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10216" ;
    skos:prefLabel "Define Financial Management Process"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10217> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10437> ;
    skos:definition "The Determine Costing/Budgeting Factors process involves identifying and analyzing elements that influence costs and budget requirements. Key steps include identifying cost drivers, analyzing historical data, estimating costs, setting budget assumptions, allocating financial resources, and monitoring and adjusting as needed. The main goals are to ensure accurate budgeting, optimize financial resource allocation, and maintain financial control.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10217" ;
    skos:prefLabel "Determine Costing/Budgeting Factors"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10218> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10437> ;
    skos:definition "Finalizing a Financial Management Approach involves understanding and implementing effective financial management which includes:<br/>Strategic Financial Decision-Making, Data-Driven Insights and Stakeholder Engagement.<br/><br/>The approach should ensure responsible and sustainable financial practices .In addition to these, procedures are set regarding how the finance team will process and distribute financial data, like invoices, payments, and reports, with security and accuracy. These written procedures also outline who is responsible for making financial decisions at the company—and who signs off on those decisions. The finalized approach should align with the organization’s goals, resources, and risk tolerance.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10218" ;
    skos:prefLabel "Finalize Financial Management Approach"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10219> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10202> ;
    skos:definition "Identify Learning Topics business activity discover relevant to support a learning objective based on the learners needs assessment outcome.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10219" ;
    skos:prefLabel "Identify Learning Topics"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10220> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10202> ;
    skos:definition "Acquire Learning Resource Content business activity obtain content relevant to establish curriculum for a Learning Topic.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10220" ;
    skos:prefLabel "Acquire Learning Resource Content"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10221> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10202> ;
    skos:definition "Develop Learning Concepts business activity establish and evolve ideas that promote successful learning resource delivery. This business activity support Training Management by providing methods for training in order to get learners to think about the 'how' and 'why' of learning.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10221" ;
    skos:prefLabel "Develop Learning Concepts"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10222> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10498> ;
    skos:definition "Asset Acquisition business activity handle the purchase or buying of assets by the enterprise.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10222" ;
    skos:prefLabel "Acquire Asset"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10223> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10498> ;
    skos:definition "Inventory Assets business activity handle the inventory of products, parts or raw materials that the organization intends to sell or dispose.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10223" ;
    skos:prefLabel "Inventory Asset"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10224> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10498> ;
    skos:definition "Allocate Asset business activity implement the strategy of assignment of assets in the enterprise.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10224" ;
    skos:prefLabel "Allocate Asset"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10225> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10498> ;
    skos:definition "Track Asset business activity monitor all assets, their movements, value and state based on established asset lifecycle management.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10225" ;
    skos:prefLabel "Track Asset"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10226> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10498> ;
    skos:definition "Decommission Asset business activity handle the activities that remove assets from active use by following the established asset management policy.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10226" ;
    skos:prefLabel "Decommission Asset"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10232> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10174> ;
    skos:definition "The objective of the Manage a Transformation Assurance Framework process is to establish an enterprise-wide transformation assurance policy framework, and an associated operational capability aimed at ensuring risks along change and transformation are recognized, owned, understood and actively managed to minimize financial and customer impact during transformation projects. The Transformation Assurance process focusses on providing consultancy within change processes in the enterprise and transparency on early identified risks, their assignment, assessment and defining build-in controls for enabling “error-free” transformation. For handling this role of a consultant during the transformation projects, a standard Business Assurance Change methodology can be defined that starts from project assessment to identify the risk areas and risk level, standard Business Assurance requirements for “build-in” controls, standard Business Assurance requirements for data export and proceeding to project specific requirements.<br/>This process was renamed in 24.0 Old process name Transformation Assurance<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10232" ;
    skos:prefLabel "Manage Transformation Assurance Framework"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10233> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10174> ;
    skos:definition "The objective of the Manage Ecosystem Assurance Framework process is to establish an enterprise-wide ecosystem assurance policy framework, and an associated operational capability aimed at assuring continual trust for customers and ecosystem partners through application of “assurance by design” principles, ensuring that new and digital services work from day one and create value. Ecosystem Assurance process focusses on providing visibility and traceability of end-to-end digital services, across the partner ecosystem value-chain via enabling and assuring a standardized Open API connectivity, Plug & Play assurance models, multi-way anomaly detection and accurate multi-partner settlement process.<br/><br/>This process was renamed in 24.0 Old process name was Ecosystem Assurance<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10233" ;
    skos:prefLabel "Manage Ecosystem Assurance Framework"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10234> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10174> ;
    skos:definition "The objective of Manage Regulatory Assurance Framework process is the proper implementation of regulations across all processes with Business Assurance remit and to assure a proper implementation of protective measures according to different regulations in place, new or updated ones.<br/><br/>The regulatory requirements might be very different in different countries, therefore the risks and control objectives are different. Just few examples of controls to ensure the regulatory compliance:<br/>•Metering accuracy comply with regulatory requirements<br/>•Bill accuracy comply with regulatory requirements<br/>•Customer complaints processed within legal frame<br/>•Regulated prices implemented correctly<br/>•Limit notifications sent according to regulation<br/>•Tax compliance <br/>•Transfer of ownership<br/>•Traceability<br/>•Data breach risk<br/>•Prevention against mobile payment-related money laundering<br/>This process also covers the most efficient exploitation of given regulation by monitoring the compliance with regards to maximum price (e.g. Charging of MVNO and interconnection), efficient cost strategies (e.g. least license costs for of allocated numbers ranges) and the enforcement as well as the correct implementation of legally granted fair use policies (e.g. Roam like Home).<br/><br/>This process was renamed in 24.0 Old process name was Regulatory Assurance<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10234" ;
    skos:prefLabel "Manage Regulatory Assurance Framework"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10236> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10455> ;
    skos:definition "Develop Training Plan business activity generate the detailed schedule and sequence of training activities that support achieving the training program.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10236" ;
    skos:prefLabel "Develop Training Plan"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10237> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10244> ;
    skos:definition "Describe Research Analysis Method business activity defines the approach that matches the objectives of the research. Described Research Analysis Methods cover the tools and procedures used to collect and analyze data (for example, experiments, surveys, and statistical tests).<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10237" ;
    skos:prefLabel "Describe Research Analysis Method"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10238> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10244> ;
    skos:definition "Describe Research Data Collection Method business activity define the research data collect information, and the research data collection sources to provide research insights and answers. Describe Research Data Collection Method takes an input from 'describe research methodology' to identify the appropriate means sources of data collection, methods of data collection include documents review, observation, questioning, measuring, or a combination of different methods required.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10238" ;
    skos:prefLabel "Describe Research Data Collection Method"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10239> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10244> ;
    skos:definition "Describe Research Methodology business activity define the procedures and techniques that are used to identify, select, process, and analyze information about a research topic. Describe Research Methodology business activity define how a researcher systematically designs a study to ensure valid and reliable results that address the research aims and objectives. Research Methodology describe research strategies, processes flows or techniques that will be utilized in the collection of data or evidence for analysis.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10239" ;
    skos:prefLabel "Describe Research Methodology"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10240> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10244> ;
    skos:definition "Evaluate and Justify Research Methodology business activity assess research method and account for the methodological approach. Evaluate and Justify Research Methodology begin by introducing overall approach to the research, evaluating the methods of data collection and/or selection, providing analysis on the methods and choices.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10240" ;
    skos:prefLabel "Evaluate and Justify Research Methodology"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10241> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10500> ;
    skos:definition "Assess Asset business activity handles periodic inspection and monitoring of assets to determine the condition and state of an asset.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10241" ;
    skos:prefLabel "Assess Asset"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10242> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10500> ;
    skos:definition "Price Asset business activity handles fixing the value of an asset through pricing principles and valuation models.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10242" ;
    skos:prefLabel "Price Asset"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10243> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10500> ;
    skos:definition "Asset Audit business activity handles the verification to compare an enterprises “official\" catalog of assets to actual assets \"physically\" located / us within the enterprise, or for business.<br/><br/>Asset Audit ensures that accounting for capital assets and depreciation is in compliance with business management objectives.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10243" ;
    skos:prefLabel "Audit Asset"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10247> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10180> ;
    skos:definition "Deliver Research Results business activity address modeling research reports for research report recipients with clear insights, ad actionable recommendations for a research.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10247" ;
    skos:prefLabel "Deliver Research Results"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10248> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10439> ;
    skos:definition "Manage Accounts Payable process involves handling the enterprise’s short-term debts to suppliers. Key steps include processing and verifying invoices, obtaining necessary approvals, scheduling and making payments, maintaining accurate records, and reconciling accounts with supplier statements. The main goals are to manage cash flow, maintain good supplier relationships, ensure financial accuracy, and comply with regulations.<br/>This process was renamed in 24.5 old name was Process Accounts Payable<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10248" ;
    skos:prefLabel "Manage Accounts Payable"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10249> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10439> ;
    skos:definition "Manage Payroll process involves overseeing the payment of wages and salaries to employees. Key steps include managing employee data, calculating payroll, processing payments, maintaining records, and ensuring compliance with laws and regulations. The main goals are to ensure accurate and timely payments, comply with legal requirements, and maintain accurate financial records.<br/><br/>This process was renamed in 24.5 old name was Process Payroll<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10249" ;
    skos:prefLabel "Manage Payroll"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10250> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10439> ;
    skos:definition "Manage General Accounting Transactions focuses on the detailed steps involved in recording and managing individual financial transactions. This includes the following tasks:<br/><br/>Record Transactions<br/>Post to Ledger<br/>Trial Balance<br/>Adjust Entries<br/>Prepare financial reports<br/>Finalize accounts for the next period<br/>This process differs from General Accounting Management which has a broader oversight of the entire accounting process, ensuring accuracy and compliance.<br/><br/>This process was renamed in 24.5. Old name was Process General Accounting<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10250" ;
    skos:prefLabel "Manage General Accounting"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10251> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10439> ;
    skos:definition "Managing inventory Transactions process ensures accurate tracking and control of inventory within an organization, it involves the following steps:<br/><br/>Receiving Inventory: When new inventory arrives, it is checked for accuracy against purchase orders and recorded into the inventory management system.<br/>Storing Inventory: This includes organizing items in the warehouse and updating inventory records.<br/>Issuing Inventory: When inventory is needed for production or sales, it is issued from storage and the transaction is recorded to update inventory levels.<br/>Tracking Inventory Movements: All movements of inventory, including transfers between locations, returns, and adjustments, are tracked and recorded to maintain accurate inventory records.<br/>Conducting Inventory Audits: Regular audits are conducted to verify the accuracy of inventory records and identify any discrepancies.<br/>Reporting: Generate reports on inventory levels, movements, and discrepancies to provide insights for decision-making and ensure efficient inventory management.<br/>By effectively managing inventory transactions, organizations can maintain accurate inventory records, reduce costs, and improve overall efficiency.<br/><br/><br/>This process was renamed in 24.5 Process Inventory Transactions<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10251" ;
    skos:prefLabel "Managing inventory Transactions"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10252> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10439> ;
    skos:definition "Manage Accounting for Fixed Assets process involves tracking, recording, and managing the financial aspects of an enterprise’s fixed assets. Key steps include identifying and valuing assets, calculating depreciation, tracking maintenance and upgrades, documenting asset disposal, and preparing financial reports. The main goals are to ensure financial accuracy, comply with regulations, and support informed decision-making about assets.<br/>This process was renamed in 24.5 old Account for Fixed Assets<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10252" ;
    skos:prefLabel "Manage Accounting for Fixed Assets"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10253> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10439> ;
    skos:definition "Manage Project Accounting process involves tracking and managing the financial aspects of specific projects. Key steps include developing project budgets, tracking costs, recognizing revenue, preparing financial reports, analyzing variances, and ensuring compliance. The main goals are to maintain budget control, provide accurate financial information, optimize financial resource allocation, and measure project performance.<br/>This process was renamed n 24.5 old name was Project Accounting<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10253" ;
    skos:prefLabel "Manage Project Accounting"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10254> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10439> ;
    skos:definition "Finalize Accounts process involves finalizing all accounting activities for a specific period. Key steps include recording final transactions, reconciling accounts, reviewing and adjusting entries, preparing financial statements, closing temporary accounts, and obtaining necessary approvals. The main goals are to ensure financial accuracy, comply with regulations, measure performance, and prepare for the next accounting period.<br/>this process was renamed in 24.5 old name was Close the Books<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10254" ;
    skos:prefLabel "Finalize Accounts"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10255> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10229> ;
    skos:definition "The objective of the Manage Policies and Controls for Margin Assurance process is to establish and manage a framework of policies and measurable controls that are used to manage the risk associated with margin assurance, and to optimize the enterprise’s appetite for margin related risks. <br/>These processes are responsible for, but not limited to: <br/>•Establishing and managing a margin assurance policy framework which is aligned with the overall enterprise goals and objectives<br/>•Developing a framework of controls and KPIs which achieves the defined margin assurance goals and objectives <br/>•Gaining enterprise-wide commitment to and knowledge of the framework <br/>•Regularly reviewing the margin assurance framework to ensure that its outcomes remain aligned with the enterprise’s objectives<br/><br/>The Manage Margin Assurance Framework process has a specific responsibility in developing and defining controls and Key Performance Indicators (KPIs) used for MA, in conjunction with operational and other processes elsewhere in the enterprise.<br/><br/><br/>This process was renamed in 24.0 Old process name was Manage Margin Assurance Policy Framework<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10255" ;
    skos:prefLabel "Manage Policies and Controls for Margin Assurance"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10256> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10229> ;
    skos:definition "The objective of the Implement Margin Assurance Operations is to perform a conception of how to implement the controls identified within the Manage Margin Assurance Policy Framework, to meet the requested objectives used to identify the minimum level of satisfactory performance required for a given control point or a process.<br/>It's aim is to analyze the business process of a given control point, identify the data sources and their formats, set up and perform an ETL process and develop a Margin Assurance Artifact and configure its alarming, most preferably by delivering automated results. <br/><br/>The responsibilities of the processes include, but are not limited to:<br/>•Conception of Margins Assurance artifacts like KPIs, controls and metrics<br/>•Ad hoc analysis and results of low level investigations driven by request of stakeholders, triggered alarms or expert judgement<br/>•End-to-end implementation of artifacts, starting with ETL procedure of source data and configuration in mid-layer systems to enable monitoring <br/>•Testing and fine-tuning of the artifacts<br/>•Implemented artifacts (control, metric)<br/>•Documentation (control / metric attributes, dataflow)<br/>•Updated repositories<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10256" ;
    skos:prefLabel "Implement Margin Assurance Operations"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10257> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10229> ;
    skos:definition "The Analyze Margin Assurance Operations processes should deliver detailed information on service provider margins and profits, delivered through a comprehensive analysis of the full value-chain. The Margin Assurance Operations process responsibilities lies in the detection and investigation of outliers in margins over time and includes monitoring of commissions, sales fees and other direct and indirect costs, such as 3rd Party and Content Commissions, Interconnection, Roaming and Mobile Financial Services as well as detection of deliberate or involuntary financial leakages and goodwill credit notes together with promotions and discounts which lead to negative or low margin customers, unprofitable tariffs, unprofitable subscribers, unprofitable partners, unprofitable transit services and unprofitable marketing campaigns. The operational capabilities should support analysis and creating of cases based on identified underperformance, monitoring and tracking the open cases, quantification and reporting.<br/><br/><br/><br/>This process was renamed in 24.0 Old process name was Manage Margin Assurance Operations<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10257" ;
    skos:prefLabel "Analyze Margin Assurance Operations"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10258> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10229> ;
    skos:definition "The objectives of the Support Margin Assurance Operations processes are twofold: <br/>•support the Manage Margin Assurance Operations processes by managing requirements for infrastructure to support the operational processes, and<br/>•monitoring, managing and reporting on the capability of the Manage Margin Assurance Operations processes <br/><br/>The responsibilities of the processes include, but are not limited to: <br/>•Developing and maintaining a repository of margin assurance KPIs to support the Manage Margin Operations processes<br/>•Monitoring and analyzing the report produced by Operations processes to identify potential margin assurance problems that may be arising across operational processes as a whole<br/>•Establishing and managing margin assurance data collection schedules, including managing the collection of the necessary information from the Resource Data Collection & Distribution processes, to support proactive monitoring and analysis activity, and requests from Manage Margin Assurance Operations processes <br/>•Implement Margin Assurance Operations processes for additional data to support revenue and cost assurance performance analysis<br/> •Monitoring of the Manage Margin Assurance Operations processes and associated costs (including to where the processes extend to infrastructure, deployed and managed by third parties), and reporting on the capability of the Manage Margin Assurance Operations processes<br/>•Establishing and managing resource performance notification facilities and lists to support the Manage Margin Assurance Operations notification and reporting processes and the Implement Margin Assurance Operations processes <br/>•Creating, deploying, modifying and/or upgrading of margin assurance infrastructure deployment support tools and processes for new and/or modified revenue and cost assurance infrastructure <br/>•Authoring, reviewing and approving operational procedures developed by Resource Development & processes prior to resource infrastructure deployment<br/>•Testing and acceptance of new and/or modified margin assurance infrastructure support tools as part of the handover procedure from the Resource Development & processes <br/>•Detecting margin assurance infrastructure operational limitations and/or deployment incompatibilities and providing requirements to address these aspects to Resource Development & processes<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10258" ;
    skos:prefLabel "Support Margin Assurance Operations"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10259> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10528> ;
    skos:definition "Remediate Integrity Assessment business activity is in charge of responding to findings from the enterprises integrity assessment.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10259" ;
    skos:prefLabel "Remediate Integrity Assessment"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10260> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10528> ;
    skos:definition "Assess Integrity business activity is in charge of defining assessment criteria, selecting assessment measures, designing assessment plans, collecting assessment results and interpreting integrity assessment results.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10260" ;
    skos:prefLabel "Assess Integrity"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10261> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10528> ;
    skos:definition "Manage Ethics business activity is in charge of creating, directing and controlling how actions of all internal enterprise stakeholder follow moral values or principles established by the enterprise. <br/><br/>This business activity is in charge of directing, as well as control enterprise tasks and outcomes that focus on meeting well-defined moral values or principles created. Manage Ethics is a key business activity to support Manage Integrity.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10261" ;
    skos:prefLabel "Manage Ethics"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10262> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10528> ;
    skos:definition "Manage Reputation business activity is in charge of directing and controlling the influence and perception of the enterprise brand.<br/><br/>Manage Reputation business activity includes activities that responding to customer, business partner, employee and all other stakeholder feedback, monitoring enterprise reputation, addressing any content or feedback (from employees, customers, business partners and external parties) that can damage the brand. Manage Reputation is a key business activity to support Manage Integrity.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10262" ;
    skos:prefLabel "Manage Reputation"@en .

<http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10263> a skos:Concept ;
    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA8_EA10363> ;
    skos:definition "Authorize Program business activity is in charge of getting all permissions and formal authorities needed for Initiate Program business activity.<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA8_EA10263" ;
    skos:prefLabel "Authorize Program"@en .

