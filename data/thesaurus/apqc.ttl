    skos:broader <http://ots.local/thesaurus/apqc/etom_EARoot_EA5_EA1_EA1_EA7320> ;
    skos:definition "Ensure that there is capability (for example, information, materials, systems and resources) so that a marketing communication can be delivered. Monitor planned communications and redistribute existing capability or enable new capability (people, facilities, infrastructure).<br/>"@en ;
    skos:inScheme thes:apqc ;
    skos:notation "etom:EARoot_EA5_EA1_EA1_EA7371" ;
    skos:prefLabel "Ensure Marketing Communication Capability"@en .

