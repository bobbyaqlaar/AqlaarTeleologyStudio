@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ots: <http://ots.local/ontology/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ots:PerformDiscoveryResearch_2_2_1 a owl:Class ;
    rdfs:label "Perform discovery research"@en ;
    ots:functionUnit "products" ;
    ots:precedes ots:GenerateNewProductServiceConcepts_2_2_2 ;
    dcterms:source "APQC PCF v8 2.2.1 (PCF ID 10065)" ;
    rdfs:comment "Coordinating R&D activity to identify new technologies to integrate into the revamped portfolio of products/services. This is inclusive of all forms of new and evolving technology such as artificial intelligence (AI). Conduct early-stage R&D activity to close gaps between existing solution offerings and changing market expectations. Triangulate appropriate technologies that can support the development of a revised product/service portfolio."@en ;
    rdfs:subClassOf ots:GenerateAndDefineNewProductServiceIdeas_2_2 .

ots:precedes a owl:ObjectProperty ;
    rdfs:label "precedes"@en .

ots:AnalyzeAndRespondToCustomerInsight_3_3_6 a owl:Class ;
    rdfs:label "Analyze and respond to customer insight"@en ;
    ots:functionUnit "marketing" ;
    ots:precedes ots:DevelopAndManagePackagingStrategy_3_3_7 ;
    dcterms:source "APQC PCF v8 3.3.6 (PCF ID 16613)" ;
    rdfs:comment "Reviewing and responding to customer feedback. Create tickets to initiate bug fixes or to propose feature updates. Monitor and track progress."@en ;
    rdfs:subClassOf ots:DevelopAndManageMarketingPlans_3_3 .

ots:DefineProductServiceDevelopmentRequirements_2_2_3 a owl:Class ;
    rdfs:label "Define product/service development requirements"@en ;
    ots:functionUnit "products" ;
    ots:precedes ots:DesignAndPrototypeProductsAndServices_2_3_1 ;
    dcterms:source "APQC PCF v8 2.2.3 (PCF ID 19990)" ;
    rdfs:comment "Encompassing the identification and capture of new product/service requirements or potential improvements to current products/services. Collaborating with members of the supply chain to ensure the feasibility of what is being defined in the requirements. For example, a product with manufacturing requirements that supply chain cannot currently fulfill requires a corporate decision to either upgrade manufacturing capabilities or abandon the new product. Enterprise-level effects and needs must be considered. Depending on the nature of the final product or service, these requirements are often defined as a set of abilities, such as availability or reliability, that influence product development decisions."@en ;
    rdfs:subClassOf ots:GenerateAndDefineNewProductServiceIdeas_2_2 .

ots:DefineWarrantyClaims_2_3_4 a owl:Class ;
    rdfs:label "Define warranty claims"@en ;
    ots:functionUnit "products" ;
    ots:precedes ots:DevelopRecallStrategy_2_3_5 ;
    dcterms:source "APQC PCF v8 2.3.4 (PCF ID 20089)" ;
    rdfs:comment "Determining the exact terms and conditions under which specific warranties apply to certain goods or services."@en ;
    rdfs:subClassOf ots:DevelopProductsAndServices_2_3 .

ots:DesignAndPrototypeProductsAndServices_2_3_1 a owl:Class ;
    rdfs:label "Design and prototype products and services"@en ;
    ots:functionUnit "products" ;
    ots:precedes ots:TestMarketForNewOrRevisedProductsAndServices_2_3_2 ;
    dcterms:source "APQC PCF v8 2.3.1 (PCF ID 19993)" ;
    rdfs:comment "Sketching and standardizing product and service based on the market. Analyze the data market competitiveness and innovation attained for the product and service development."@en ;
    rdfs:subClassOf ots:DevelopProductsAndServices_2_3 .

ots:DevelopAndManagePackagingStrategy_3_3_7 a owl:Class ;
    rdfs:label "Develop and manage packaging strategy"@en ;
    ots:functionUnit "marketing" ;
    ots:precedes ots:DevelopGoToMarketStrategy_3_3_8 ;
    dcterms:source "APQC PCF v8 3.3.7 (PCF ID 10154)" ;
    rdfs:comment "Creating, executing, and administering a strategic road map for packaging products/services. Determine how to package products/services into finished offerings that can be directly marketed to prospective customers. Consider physicality, perishability, and shelf-life. Develop a strategy for packaging products/services. Test alternatives. Collect feedback. Refine the option chosen for execution. Have marketing, product development, and supply chain functions work together to develop sound packaging."@en ;
    rdfs:subClassOf ots:DevelopAndManageMarketingPlans_3_3 .

ots:DevelopAndManagePricing_3_3_3 a owl:Class ;
    rdfs:label "Develop and manage pricing"@en ;
    ots:functionUnit "marketing" ;
    ots:precedes ots:DevelopAndManagePromotionalActivities_3_3_4 ;
    dcterms:source "APQC PCF v8 3.3.3 (PCF ID 20593)" ;
    rdfs:comment "Determining and maintaining a pricing mechanism based on forecasted sales and that enables a pricing equilibrium for the lifecycles of products/services. Create a pricing mechanism, factoring in attributes relating to the market, customers, sales, and the cost of production. Implement this pricing mechanism over all products/services. Analyze its performance, and adjust accordingly."@en ;
    rdfs:subClassOf ots:DevelopAndManageMarketingPlans_3_3 .

ots:DevelopAndManagePromotionalActivities_3_3_4 a owl:Class ;
    rdfs:label "Develop and manage promotional activities"@en ;
    ots:functionUnit "marketing" ;
    ots:precedes ots:TrackCustomerManagementMeasures_3_3_5 ;
    dcterms:source "APQC PCF v8 3.3.4 (PCF ID 20010)" ;
    rdfs:comment "Conceptualizing, testing, and executing product/service/brand promotions. Once a promotion has launched, this process continues as the organization tweaks parts of the promotion or chooses to use ideas or lessons learned during the promotion in future activities. The promotion's performance according to organizational measures is also evaluated in this process. Determine early on whether you need third party help with promotion. Purchase lists, consult with social media experts, hire seasonal staff, or pay for additional research."@en ;
    rdfs:subClassOf ots:DevelopAndManageMarketingPlans_3_3 .

ots:DevelopGoToMarketStrategy_3_3_8 a owl:Class ;
    rdfs:label "Develop go-to-market strategy"@en ;
    ots:functionUnit "marketing" ;
    ots:precedes ots:ManageProductMarketingMaterial_3_3_9 ;
    dcterms:source "APQC PCF v8 3.3.8 (PCF ID 21425)" ;
    rdfs:comment "Creation of a plan detailing how a company plans to execute a successful product release and promotion, and ultimately its sale to customers."@en ;
    rdfs:subClassOf ots:DevelopAndManageMarketingPlans_3_3 .

ots:DevelopRecallStrategy_2_3_5 a owl:Class ;
    rdfs:label "Develop recall strategy"@en ;
    ots:functionUnit "products" ;
    ots:precedes ots:EstablishGoalsObjectivesAndMeasuresForProductsServicesByChannelSegment_3_3_1 ;
    dcterms:source "APQC PCF v8 2.3.5 (PCF ID 20092)" ;
    rdfs:comment "Establishing procedures to handle recalls of defective products."@en ;
    rdfs:subClassOf ots:DevelopProductsAndServices_2_3 .

ots:EstablishGoalsObjectivesAndMeasuresForProductsServicesByChannelSegment_3_3_1 a owl:Class ;
    rdfs:label "Establish goals, objectives, and measures for products/services by channel/segment"@en ;
    ots:functionUnit "marketing" ;
    ots:precedes ots:EstablishMarketingBudgets_3_3_2 ;
    dcterms:source "APQC PCF v8 3.3.1 (PCF ID 10148)" ;
    rdfs:comment "Determining what to achieve by marketing. Create qualitative and quantitative targets. Establish metrics to track performance (for individual Market segments [10109] and Channels for target segments [10129]). Enlist the head of marketing to determine marketing priorities and the related measures. (The decision in establishing these goals, objectives, and metrics is founded in Develop marketing strategy [10102] and takes cues from current priorities and organizational strategy.)"@en ;
    rdfs:subClassOf ots:DevelopAndManageMarketingPlans_3_3 .

ots:EstablishMarketingBudgets_3_3_2 a owl:Class ;
    rdfs:label "Establish marketing budgets"@en ;
    ots:functionUnit "marketing" ;
    ots:precedes ots:DevelopAndManagePricing_3_3_3 ;
    dcterms:source "APQC PCF v8 3.3.2 (PCF ID 10149)" ;
    rdfs:comment "Creating a budget for the organization's marketing efforts, in line with the business-wide strategic outlook. Create a plan to distribute resources for achieving the marketing strategy in light of the overall business strategy. Make cost assumptions; calculate the estimated total revenue from the marketing activities against the costs/expenses of these activities. Forecast the return on investment. Attribute costs to the appropriate marketing activities such as promotional campaigns, advertising, marketing communications, PR campaigns, personnel, and office space. Enlist the financial and marketing functions."@en ;
    rdfs:subClassOf ots:DevelopAndManageMarketingPlans_3_3 .

ots:GenerateNewProductServiceConcepts_2_2_2 a owl:Class ;
    rdfs:label "Generate new product/service concepts"@en ;
    ots:functionUnit "products" ;
    ots:precedes ots:DefineProductServiceDevelopmentRequirements_2_2_3 ;
    dcterms:source "APQC PCF v8 2.2.2 (PCF ID 19669)" ;
    rdfs:comment "Producing and defining ideologies for new product/service offerings."@en ;
    rdfs:subClassOf ots:GenerateAndDefineNewProductServiceIdeas_2_2 .

ots:ManageProductMarketingMaterial_3_3_9 a owl:Class ;
    rdfs:label "Manage product marketing material"@en ;
    ots:functionUnit "marketing" ;
    dcterms:source "APQC PCF v8 3.3.9 (PCF ID 16629)" ;
    rdfs:comment "Creating descriptions of products that are promotional and informative in content in order to initiate and increase sales. Marketing content consists of text, and optionally, images."@en ;
    rdfs:subClassOf ots:DevelopAndManageMarketingPlans_3_3 .

ots:PrepareForProductionServiceDelivery_2_3_3 a owl:Class ;
    rdfs:label "Prepare for production/service delivery"@en ;
    ots:functionUnit "products" ;
    ots:precedes ots:DefineWarrantyClaims_2_3_4 ;
    dcterms:source "APQC PCF v8 2.3.3 (PCF ID 19997)" ;
    rdfs:comment "Devising business plans and procedures for manufacturing/operations/production and delivery of services offered by the organization. Further in general terms the total amount of output that the manufacturing department is responsible to produce for each period."@en ;
    rdfs:subClassOf ots:DevelopProductsAndServices_2_3 .

ots:TestMarketForNewOrRevisedProductsAndServices_2_3_2 a owl:Class ;
    rdfs:label "Test market for new or revised products and services"@en ;
    ots:functionUnit "products" ;
    ots:precedes ots:PrepareForProductionServiceDelivery_2_3_3 ;
    dcterms:source "APQC PCF v8 2.3.2 (PCF ID 19996)" ;
    rdfs:comment "Expanding on the marketplace analysis that took place earlier in the product development lifecycle by testing the market against offerings. The results from this in-depth analysis will help the organization finalize product/service characteristics and technical requirements and also identify any needed changes in the manufacturing and delivery processes that support market delivery. To prepare a detailed market study that accounts for any changes in the global environment, the organization may want to conduct a series of interviews, workshops, and focus groups with potential and existing customers."@en ;
    rdfs:subClassOf ots:DevelopProductsAndServices_2_3 .

ots:TrackCustomerManagementMeasures_3_3_5 a owl:Class ;
    rdfs:label "Track customer management measures"@en ;
    ots:functionUnit "marketing" ;
    ots:precedes ots:AnalyzeAndRespondToCustomerInsight_3_3_6 ;
    dcterms:source "APQC PCF v8 3.3.5 (PCF ID 10153)" ;
    rdfs:comment "Collating all customer-centered metrics. The objective is to create a big-picture view of the customers' mindset and their behavior pertaining to the organization's offerings."@en ;
    rdfs:subClassOf ots:DevelopAndManageMarketingPlans_3_3 .

ots:ConceptToMarket a owl:Class ;
    rdfs:label "Concept to market"@en .

ots:GenerateAndDefineNewProductServiceIdeas_2_2 a owl:Class ;
    rdfs:label "Generate and define new product/service ideas"@en ;
    ots:functionUnit "products" ;
    dcterms:source "APQC PCF v8 2.2 (PCF ID 19698)" ;
    rdfs:comment "Identifying and describing new product or service thoughts based on organizational objectives/targets."@en ;
    rdfs:subClassOf ots:ConceptToMarket .

ots:DevelopProductsAndServices_2_3 a owl:Class ;
    rdfs:label "Develop products and services"@en ;
    ots:functionUnit "products" ;
    dcterms:source "APQC PCF v8 2.3 (PCF ID 10062)" ;
    rdfs:comment "Developing new products/services from scratch, including all activities associated with the design, prototyping, evaluation, and market testing of these planned offerings."@en ;
    rdfs:subClassOf ots:ConceptToMarket .

ots:DevelopAndManageMarketingPlans_3_3 a owl:Class ;
    rdfs:label "Develop and manage marketing plans"@en ;
    ots:functionUnit "marketing" ;
    dcterms:source "APQC PCF v8 3.3 (PCF ID 20008)" ;
    rdfs:comment "Creating specific plans to market offerings to customers. This process group includes processes for making budgets, identifying and developing media, pricing products and services, managing packaging, managing marketing content and promotional activities, tracking and responding to customer insight and monitoring measures established within \"develop marketing strategy\". Additionally, in this process group, organizations take action on plans made in earlier processes. Here, marketing and customers are managed and measured along with any supporting materials."@en ;
    rdfs:subClassOf ots:ConceptToMarket .

